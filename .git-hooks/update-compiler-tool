#!/bin/bash

dotnet tool uninstall --local ghul.compiler >/dev/null 2>&1

TMP=$(mktemp /tmp/ghu-hook.XXXXXX)

if dotnet tool install --local ghul.compiler >${TMP} 2>&1 ; then
    echo "Installed latest public version of compiler: $(dotnet ghul-compiler)"
    rm -f ${TMP}
else
    cat ${TMP}
    rm -f ${TMP}
    exit 1
fi

# `dotnet tool install` rewrites the manifest without a trailing newline.
# Restore it so the file matches the committed shape and we don't get
# a spurious one-byte diff on every checkout / commit.
if [ -f .config/dotnet-tools.json ] && [ -n "$(tail -c1 .config/dotnet-tools.json)" ]; then
    echo "" >> .config/dotnet-tools.json
fi
