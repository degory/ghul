namespace LibDefaultVariant is
    // Default-variant marker round-trips through the assembly. The
    // consumer's `?` and `!` should lower to isa/cast against
    // RESULT.OK exactly as if RESULT were defined in the same
    // assembly.
    union RESULT[T, E] is
        OK(value: T) default;
        ERR(error: E);
    si

    // Implicit-default form: own-field-count counts only own
    // (non-inherited) fields. SOME has one own field; NONE has
    // none — so SOME is the implicit default and the marker
    // names it.
    union OPTION[T] is
        SOME(value: T);
        NONE;
    si

    entry() is si
si
