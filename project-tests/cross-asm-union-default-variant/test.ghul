use IO.Std.write_line;

use LibDefaultVariant.RESULT;
use LibDefaultVariant.OPTION;

ok[T](v: T) -> RESULT[T, string] => RESULT.OK[T, string](v);
err[E](e: E) -> RESULT[int, E] => RESULT.ERR[int, E](e);

some[T](v: T) -> OPTION[T] => OPTION.SOME[T](v);
none[T]() -> OPTION[T] => OPTION.NONE[T]();

entry() is
    // Explicit default — `default` modifier.
    let good = ok(42);
    let bad = err("oops");

    write_line("good?: {good?}");
    write_line("bad?: {bad?}");
    write_line("good!: {good!}");

    // Implicit default — sole own-field variant.
    let s = some("hi");
    let n = none[string]();

    write_line("s?: {s?}");
    write_line("n?: {n?}");
    write_line("s!: {s!}");
si
