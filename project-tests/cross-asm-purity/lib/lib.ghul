namespace LibPurity is
    // PURE function in a library: the compiler emits
    // Ghul.Internal.PURE_ATTRIBUTE on its .NET method. A consumer
    // in another assembly reads the attribute at import time and
    // narrowing across the call survives.
    double_it(x: int) -> int pure => x * 2;

    // MUT function: emits Ghul.Internal.MUT_ATTRIBUTE. Call-site
    // narrowing of paths rooted at the receiver drops; siblings
    // survive.
    class HOLDER is
        _last: int;
        last: int => _last;

        init() is si

        // Mutates the receiver only.
        note(x: int) mut is _last = x; si
    si

    // ghūl currently always builds an entry-point-bearing assembly;
    // this stub satisfies that requirement so the lib can be
    // referenced cross-assembly.
    entry() is si
si
