use IO.Std.write_line;

use LibPurity.HOLDER;
use LibPurity.double_it;

// Cross-assembly purity contract: `double_it` is declared `pure`
// in lib; `HOLDER.note` is declared `mut`. The compiler emits
// `Ghul.Internal.PURE_ATTRIBUTE` / `MUT_ATTRIBUTE` markers on
// each. On import here, the reflection layer reads the markers
// and sets the imported Function symbols' purity accordingly,
// so flow-sensitive narrowing across each call uses the right
// dispatch.

class CONTEXT is
    name: string?;
    init(name: string?) is self.name = name; si
si

check_pure(c: CONTEXT) -> string is
    if c.name? then
        let doubled = double_it(7);
        // PURE callee: c.name narrowing intact, the assignment
        // to a non-optional slot type-checks.
        let n: string = c.name;
        return "pure: n={n} doubled={doubled}";
    fi
    return "pure: absent";
si

check_mut(c: CONTEXT, h: HOLDER) -> string is
    if c.name? then
        h.note(42);
        // MUT callee on `h`: drops paths rooted at `h`, but
        // c.name (rooted at `c`) survives.
        let m: string = c.name;
        return "mut: m={m} last={h.last}";
    fi
    return "mut: absent";
si

entry() is
    let c = CONTEXT("hello");
    let h = HOLDER();
    write_line(check_pure(c));
    write_line(check_mut(c, h));
si
