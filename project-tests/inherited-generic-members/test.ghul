namespace Test is
    use IO.Std.write_line;

    use InheritedGenericMembers;

    // Regression test for issue #987.
    //
    // When a class is loaded via reflection from another assembly and
    // inherits members from a constructed-generic base, the inherited
    // members surface with their type-parameter references substituted
    // to concrete types (e.g. an inherited `Method(TSubject)` arrives
    // typed as `Method(System.Object)` when the base is `Base<object,...>`).
    // The CLR requires the methodref / fieldref signature in the IL to use
    // the open-generic indexed form (`!0`, `!!0`), not the substituted
    // form, so emitting the wrong shape produces MissingMethodException /
    // MissingFieldException at the call site.
    //
    // The exercises below all touch members inherited by `Concrete` from
    // `GenericBase<object, Concrete>`. Every one of them emits a methodref
    // or fieldref whose signature would be malformed if the loader didn't
    // recover the open-generic form.
    class Main is
        entry() static is
            let c = new Concrete();

            // Inherited methods.
            write_line("describe_subject: " + c.describe_subject(123));
            write_line("return_self: " + c.return_self());
            write_line("take_self: " + c.take_self(c));
            write_line("wrap_self.and: " + c.wrap_self().and);

            // Inherited fields, including one whose type is itself a
            // constructed generic parameterised by the base's type parameter.
            write_line("subject_field: " + c.subject_field);
            write_line("self_field: " + c.self_field);
            write_line("wrapped_self_field.and: " + c.wrapped_self_field.and);
        si
    si
si
