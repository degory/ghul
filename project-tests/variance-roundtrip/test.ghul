namespace Test is
    use IO.Std.write_line;

    use VarianceLib;

    // `STREAM`1` is imported from a separate ghūl assembly that
    // declared it `[T: out]`. ghūl reads the covariance back from the
    // assembly metadata, so a `STREAM[CAT]` is usable where a
    // `STREAM[ANIMAL]` is expected — variance survives the round-trip.
    trait ANIMAL is
        speak() -> string;
    si

    class CAT: ANIMAL is
        init() is si
        speak() -> string => "meow";
    si

    class SINGLE[T]: STREAM[T] is
        _value: T;
        init(value: T) is _value = value; si
        head() -> T => _value;
    si

    class Main is
        entry() static is
            let cats: STREAM[CAT] = SINGLE[CAT](CAT());
            let animals: STREAM[ANIMAL] = cats;

            write_line(animals.head().speak());
        si
    si
si
