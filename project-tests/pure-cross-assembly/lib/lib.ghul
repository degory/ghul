namespace PureLib is
    trait TICKER is
        tick() -> int pure;
    si

    entry() is
    si

    class SOURCE is
        label: string? public;

        init(l: string?) is
            label = l;
        si

        describe() -> int pure is
            return "abc".to_upper().length;
        si

        select(f: (int) -> int pure, x: int) -> int pure => f(x);
    si
si
