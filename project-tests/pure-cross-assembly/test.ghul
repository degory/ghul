// Purity round-trips across assemblies: the imported describe() is
// declared pure in lib, so a field narrow survives calling it; the
// imported select() has a pure function-typed parameter, so a
// store-free literal passes silently and an unprovable one warns; an
// impure local implementation of the imported pure trait member is
// rejected in this, the overriding, assembly - pinned in the sibling
// integration tests, kept positive-only here so the snapshot stays
// path-free.

use Std = IO.Std;
use PureLib;

class LOCAL_TICKER: PureLib.TICKER is
    _base: int;
    init(base: int) is _base = base; si
    tick() -> int => _base + 1;
si

class HOLDER is
    _tag: string?;

    init(t: string?) is
        _tag = t;
    si

    probe(source: PureLib.SOURCE) is
        if _tag? then
            let n = source.describe();

            Std.write_line("kept: {_tag.length} {n}");
        fi

        if _tag? then
            let m = source.select(y => y + 1, 41);

            Std.write_line("kept2: {_tag.length} {m}");
        fi
    si
si

entry() is
    HOLDER("hi").probe(PureLib.SOURCE("x"));
    Std.write_line("{LOCAL_TICKER(1).tick()}");
si
