namespace CrossAssemblyGenericGlobals is
    use Collections;

    trait Holder[T] is
        value: T;
    si

    class CELL[T]: Holder[T] is
        value: T;

        init(value: T) is
            self.value = value;
        si
    si

    wrap[T](value: T) -> Holder[T] => CELL[T](value);

    first[T](source: Iterable[T]) -> T is
        for element in source do
            return element;
        od

        throw System.InvalidOperationException("empty");
    si

    entry() is si
si
