namespace Test is
    use IO.Std.write_line;
    use CrossAssemblyGenericGlobals;

    class Main is
        entry() static is
            let cell = wrap(42);
            write_line("wrap(42).value: " + cell.value);

            let head = first([10, 20, 30]);
            write_line("first([10, 20, 30]): " + head);

            let qualified_cell = CrossAssemblyGenericGlobals.wrap(99);
            write_line("CrossAssemblyGenericGlobals.wrap(99).value: " + qualified_cell.value);
        si
    si
si
