namespace Test is
    use IO.Std.write_line;

    use GenericConstraintNewImported;

    // `Factory`1` is imported from a C# assembly declaring
    // `where T : new()`. ghūl reads the parameterless-constructor
    // constraint from the assembly metadata and enforces it where the
    // generic is instantiated. `WIDGET` declares a parameterless
    // `init`, so it satisfies the constraint and the generic is used
    // normally. (A type argument that does not — a class with only a
    // parameterised `init` — is a constraint error; that path is
    // covered by GENERIC_CONSTRAINT_CHECKER's unit tests.)
    class WIDGET is
        init() is si
        to_string() -> string => "widget";
    si

    class Main is
        entry() static is
            let factory = Factory`1[WIDGET]();

            write_line("created: {factory.create()}");
        si
    si
si
