namespace Test is
    use IO.Std.write_line;

    use GenericConstraintImported;

    // `RefCell`1` is imported from a C# assembly declaring
    // `where T : class`. ghūl reads the constraint from the assembly
    // metadata: `string` satisfies it, so the type is used normally.
    // (A value-type argument here would be a constraint error — the
    // enforcement path is covered by the semantic/ integration tests.)
    class Main is
        entry() static is
            let cell = RefCell`1[string]("held");

            write_line("cell.value: {cell.value}");
        si
    si
si
