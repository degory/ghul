namespace LibUnion is
    // A simple two-variant union exported from a library so a
    // consumer in another assembly can construct and destructure
    // each variant.
    union RESULT[T] is
        OK(value: T);
        ERR(message: string);
    si

    // A function returning the union so callers can drive both
    // branches without constructing the variants themselves.
    classify(n: int) -> RESULT[int] is
        if n >= 0 then
            return RESULT.OK(n);
        else
            return RESULT.ERR("negative: {n}");
        fi
    si

    // ghūl currently always builds an entry-point-bearing assembly;
    // this stub satisfies that requirement so the lib can be
    // referenced cross-assembly.
    entry() is si
si
