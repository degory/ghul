    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <AssemblyName>cross-asm-union-variant-lib</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <GhulSources Include="*.ghul" />
  </ItemGroup>
</Project>
