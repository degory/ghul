use IO.Std.write_line;

use LibUnion.RESULT;
use LibUnion.classify;

// Cross-asm union variant access:
//   - `RESULT.OK(...)` / `RESULT.ERR(...)` constructor access via
//     a union reflected from another assembly,
//   - `is_ok` / `is_err` predicate properties on the reflected
//     union,
//   - per-variant `.value` / `.message` member access after
//     narrowing.
describe(r: RESULT[int]) -> string is
    if r.is_ok then
        return "ok({r.value})";
    elif r.is_err then
        return "err({r.message})";
    fi

    return "??";
si

entry() is
    write_line(describe(RESULT.OK(42)));
    write_line(describe(RESULT.ERR[int]("nope")));
    write_line(describe(classify(7)));
    write_line(describe(classify(-3)));
si
