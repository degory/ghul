namespace TupleRoundtrip is
    class Geometry is
        // return type is a named tuple — its element names must survive
        // into the IL (TupleElementNamesAttribute) for a cross-assembly
        // consumer to recover them
        make_point(a: int, b: int) -> (x: int, y: int) static => (a, b);

        size(w: int, h: int) -> (width: int, height: int) static => (w, h);
    si

    // the tuple mentions the class type parameter, so the reflected
    // return type is an open ValueTuple — it must still map as a tuple
    // for the names to survive and for `(T, string)` to render as a
    // tuple rather than as the underlying generic
    class LABELLED[T] is
        _value: T;

        init(value: T) is
            _value = value;
        si

        entry: (key: T, label: string) => (_value, "labelled");

        unnamed() -> (T, string) => (_value, "unnamed");
    si

    // a field-backed member: the names ride on the generated accessor,
    // not on the underlying field
    class STORED is
        slot: (key: int, label: string) field;

        init() is
            slot = (5, "stored");
        si
    si

    // ghūl always builds an entry-point-bearing assembly
    entry() is si
si
