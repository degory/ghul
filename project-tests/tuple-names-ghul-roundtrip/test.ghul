namespace Test is
    use IO.Std.write_line;
    use TupleRoundtrip;

    class Main is
        entry() static is
            let p = Geometry.make_point(3, 4);
            write_line("p.x={p.x} p.y={p.y}");

            let s = Geometry.size(80, 25);
            write_line("s.width={s.width} s.height={s.height}");
        si
    si
si
