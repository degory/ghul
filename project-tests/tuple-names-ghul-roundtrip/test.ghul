namespace Test is
    use IO.Std.write_line;
    use TupleRoundtrip;

    class Main is
        entry() static is
            let p = Geometry.make_point(3, 4);
            write_line("p.x={p.x} p.y={p.y}");

            let s = Geometry.size(80, 25);
            write_line("s.width={s.width} s.height={s.height}");

            let l = LABELLED[int](7);
            write_line("l.key={l.entry.key} l.label={l.entry.label}");

            let (value, label) = l.unnamed();
            write_line("value={value} label={label}");

            let stored = STORED();
            write_line("slot.key={stored.slot.key} slot.label={stored.slot.label}");
        si
    si
si
