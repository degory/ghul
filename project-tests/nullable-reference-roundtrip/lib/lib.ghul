namespace NullableReferenceRoundtrip is
    use Collections;

    // A library surface that uses reference-type `?` on every emission
    // site the compiler marks: method parameter, return type, field,
    // property. A cross-assembly consumer must see each `?` annotation
    // come back via reflection (it rides on a NullableAttribute custom
    // attribute on the slot) so it can pass null where the source
    // allows it and refuse null where it doesn't.
    //
    // The nested cases (`List[string?]`, `List[string]?`) drive the
    // byte[] form of the attribute, where the position bytes walk the
    // type tree pre-order — outer first, then each generic argument.
    class CARTON is
        // Reference-`?` field — survives reflection as `CARTON?`.
        cargo: CARTON? public;

        // Reference-`?` property — same.
        label: string? public;

        // Nested case: inner `?`. The outer list is non-optional but
        // its element type is `string?`, so the position bytes encode
        // [1, 2] (list non-`?`, string `?`). Without the byte[] form,
        // the consumer reads back `List[string]` and rejects a null
        // element on assignment / construction.
        things: List[string?] public;

        // Nested case: outer `?`. Position bytes [2, 1] — list `?`,
        // string non-`?`. The field itself can be null; its elements
        // can't be.
        maybe_things: List[string]? public;

        init(
            cargo: CARTON?,
            label: string?,
            things: List[string?],
            maybe_things: List[string]?
        ) is
            self.cargo = cargo;
            self.label = label;
            self.things = things;
            self.maybe_things = maybe_things;
        si

        // Reference-`?` parameter and return — both must accept null
        // when the consumer drives them from another assembly. Without
        // the attribute round-trip, reflection sees `string` (non-`?`)
        // for the parameter, and a bare `null` argument is rejected.
        wrap(other: string?) -> string? is
            return other;
        si

        // Nested parameter `List[string?]` — the consumer must be
        // able to construct one containing a null element and pass
        // it across the assembly boundary.
        first(items: List[string?]) -> string? is
            if items.count == 0 then
                return null;
            fi

            return items[0];
        si
    si

    // ghūl always builds an entry-point-bearing assembly
    entry() is si
si
