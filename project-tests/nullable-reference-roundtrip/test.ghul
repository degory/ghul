namespace Test is
    use Collections;

    use IO.Std.write_line;

    use NullableReferenceRoundtrip;

    class Main is
        entry() static is
            // Top-level reference-`?` round-trip. Without the
            // attribute, the constructor's reflected parameter types
            // come back as the non-`?` form and the null literals get
            // rejected at compile time on this very line.
            let inner_things = LIST[string?]();
            inner_things.add("a");
            inner_things.add(null);

            let inner = CARTON(null, "inner", inner_things, null);

            let outer_things = LIST[string?]();
            outer_things.add(null);

            let outer = CARTON(inner, null, outer_things, null);

            write_line("inner.cargo? = {inner.cargo?}");
            write_line("inner.label = {inner.label}");
            write_line("outer.cargo? = {outer.cargo?}");
            write_line("outer.label? = {outer.label?}");

            // Reference-`?` parameter and return — a bare null must
            // reach the reflected method.
            write_line("wrap(\"hello\") = {outer.wrap("hello")}");
            write_line("wrap(null)? = {outer.wrap(null)?}");

            // Reference-`?` field/property assignment from null.
            outer.cargo = null;
            outer.label = "outer-label";
            write_line("after-assign cargo? = {outer.cargo?}");
            write_line("after-assign label = {outer.label}");

            // Nested: `List[string?]` field, element-level null. The
            // inner element-`?` must survive the round-trip so the
            // assignment of a null-bearing list type-checks against
            // the field's reflected `List[string?]` type. Reading an
            // element back as null is the smoking-gun observation.
            write_line("inner.things[0] = {inner.things[0]}");
            write_line("inner.things[1]? = {inner.things[1]?}");
            write_line("outer.things[0]? = {outer.things[0]?}");

            // Nested: `List[string?]` parameter and `string?` return.
            let probe = LIST[string?]();
            probe.add(null);
            probe.add("late");
            write_line("first(probe)? = {outer.first(probe)?}");
            write_line("first(empty)? = {outer.first(LIST[string?]())?}");

            // Nested: outer-`?` field. The list as a whole can be
            // null; its elements stay non-`?`.
            outer.maybe_things = null;
            write_line("after-null maybe_things? = {outer.maybe_things?}");

            let some = LIST[string]();
            some.add("present");
            outer.maybe_things = some;
            write_line("after-set maybe_things? = {outer.maybe_things?}");
            write_line("after-set maybe_things![0] = {outer.maybe_things![0]}");
        si
    si
si
