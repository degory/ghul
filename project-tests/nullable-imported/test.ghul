namespace Test is
    use IO.Std.write_line;

    use NullableImported;

    // `Probe.halve` returns a C#-declared `int?` (System.Nullable[int]).
    // ghūl reflects it as a value-type nullable: `?`, `!` and `if let`
    // all drive it, the same as a ghūl-written `int?`.
    class Main is
        entry() static is
            let h = Probe.halve(84);

            write_line(h?);
            write_line(h!);

            if let v = Probe.halve(84) then
                write_line("half of 84 is {v}");
            fi

            if let v = Probe.halve(7) then
                write_line("should not bind {v}");
            else
                write_line("7 has no half");
            fi
        si
    si
si
