namespace LibTrait is
    // A trait with both an abstract property and a default method.
    // The default `say_hello` calls the abstract `name` — a typical
    // "template method" shape.
    trait HasName is
        name: string;

        say_hello() -> string => "Hello from {name}!";
    si

    // A concrete class implementing the trait. Provides the
    // abstract `name`; inherits `say_hello` from the trait.
    // Cross-assembly consumers of this class should see
    // `say_hello` as a callable member without needing to spell
    // out HasName.
    class GREETER: HasName is
        _name: string;

        name: string => _name;

        init(name: string) is
            _name = name;
        si
    si

    // ghūl currently always builds an entry-point-bearing assembly;
    // this stub satisfies that requirement so the lib can be
    // referenced cross-assembly.
    entry() is si
si
