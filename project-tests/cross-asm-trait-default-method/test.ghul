use IO.Std.write_line;

use LibTrait.GREETER;

// `GREETER` is defined in another assembly (lib). It implements
// `HasName` which has a default `say_hello`. Calling `say_hello`
// on a cross-asm `GREETER` instance exercises the
// trait-default-method-on-reflected-class path — symbol_factory
// has to copy the default method from the reflected `HasName`
// trait into the reflected `GREETER`'s symbol table at
// materialization time.
entry() is
    let g = GREETER("world");

    write_line(g.say_hello());
si
