namespace Test is
    use IO.Std.write_line;

    use ConstraintLib;

    // `HOLDER[T: class]` is declared in a separate ghūl library. Its
    // `class` constraint is emitted into the library's metadata and
    // read back when the library is imported here — a `class`/`class`
    // round-trip. `string` satisfies the constraint. (A value-type
    // argument is a constraint error; that path is covered by the
    // semantic/ integration tests.)
    class Main is
        entry() static is
            let h = HOLDER[string]("held");

            write_line("h.value: {h.value}");
        si
    si
si
