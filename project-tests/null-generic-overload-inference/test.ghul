namespace Test is
    use IO.Std.write_line;

    use NullGenericOverloadInference.Results2;
    use NullGenericOverloadInference.IThing;

    // Calling an imported generic overload with a bare null: the argument
    // binds the optional `TValue?` parameter without pinning TValue, so
    // TValue defaults to object and the call is fully specialized. Before
    // the fix this emitted an unresolved !!0 type argument and crashed at
    // load with BadImageFormatException.
    class Main is
        entry() static is
            let from_null: IThing = Results2.ok(null);
            let from_value: IThing = Results2.ok("hello");

            write_line("from_null: {from_null.describe()}");
            write_line("from_value: {from_value.describe()}");
        si
    si
si
