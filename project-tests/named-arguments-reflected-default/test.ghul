namespace Test is
    use IO.Std.write_line;

    use ReflectedDefaults;

    // Cross-assembly reflection of .NET-declared parameter defaults: a
    // named-argument call to one of the methods below may omit the
    // optional parameter, and the compiler fills it from the constant
    // recorded in the referenced assembly's metadata. The expected
    // output below is what each declared default produces.
    class Main is
        entry() static is
            write_line(Defaults.int32(x = 1));
            write_line(Defaults.int64(x = 2));
            write_line(Defaults.boolean(x = 3));
            write_line(Defaults.string(x = 4));
            write_line(Defaults.double(x = 5));
            write_line(Defaults.single(x = 6));
            write_line(Defaults.character(x = 7));
            write_line(Defaults.`enum(x = 8));
            write_line(Defaults.null_string(x = 9));

            // Supplying the optional positionally still works.
            write_line(Defaults.int32(11, 22));
            write_line(Defaults.`enum(33, Color.BLUE));
        si
    si
si
