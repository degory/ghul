namespace Test is
    use IO.Std.write_line;

    use CovariantRedeclaredMembers.IShape;
    use CovariantRedeclaredMembers.Shapes;

    // An imported interface hierarchy that redeclares inherited members
    // covariantly (`Parent`, `Children`) and abstractly-over-a-default
    // (`Describe`). Each redeclaration reaches an implementing type
    // through a separate ancestor, so a single member satisfies every
    // inherited slot; importing it must not report an inheritance clash.
    class Main is
        entry() static is
            let shape = Shapes.make("root");

            write_line("describe: {shape.describe()}");
            write_line("parent is null: {!shape.parent?}");
            write_line("child count: {shape.children() | .count()}");
        si
    si
si
