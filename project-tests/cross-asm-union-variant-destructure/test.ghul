use IO.Std.write_line;

use LibUnion2.PAIR;

// SCENARIO: tuple destructuring of a cross-assembly union variant.
//
// Intra-assembly this works:
//   let (v) = some_one;          // OK — binds v to ONE.value
//   let (l, r) = some_two;       // OK — binds l/r to TWO.left/TWO.right
//
// Cross-assembly today this fails with "cannot destructure PAIR.ONE"
// / "variable is not defined here". Variants populate their field-
// name list (`Classy._field_names`) during source compilation
// (`declare_variable` in classy.ghul), but `symbol_factory`'s
// reflection-side path never sets `_field_names` — the destructure
// machinery in `compile_expressions` then reports the union as
// non-destructurable. The fields *are* visible on the reflected
// variant as ordinary instance fields (`.value`, `.left`, `.right`
// member access works — exercised by the sibling
// `cross-asm-union-variant` test), so positional destructuring is
// the only remaining gap.
//
// This test directory is disabled — see the `disabled` marker
// file. Enable once `symbol_factory.materialize_variant` populates
// `_field_names` from the reflected variant's instance-field order.
describe(p: PAIR) -> string is
    if p.is_one then
        let (v) = p;
        return "one({v})";
    elif p.is_two then
        let (l, r) = p;
        return "two({l}, {r})";
    fi

    return "??";
si

entry() is
    write_line(describe(PAIR.ONE(1)));
    write_line(describe(PAIR.TWO(2, 3)));
si
