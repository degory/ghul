use IO.Std.write_line;

use LibUnion2.PAIR;

// Cross-assembly tuple destructuring of a union variant. Narrowing
// via `if let v: V = x` binds the variant at its concrete reflected
// type; the destructure then unpacks the bound variant's fields in
// the order they were declared.
describe(p: PAIR) -> string is
    if let one: PAIR.ONE = p then
        let (v) = one;
        return "one({v})";
    elif let two: PAIR.TWO = p then
        let (l, r) = two;
        return "two({l}, {r})";
    fi

    return "??";
si

entry() is
    write_line(describe(PAIR.ONE(1)));
    write_line(describe(PAIR.TWO(2, 3)));
si
