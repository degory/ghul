namespace Test is
    use IO.Std.write_line;

    use NullableInterop;

    // Bidirectional interop between ghūl's value-type `T?` and .NET's
    // System.Nullable<T>, exercised across an assembly boundary (the
    // reflected `NullableInterop` lib). A reflected `Nullable<T>` must
    // behave as the same value optional a ghūl-written `T?` produces:
    // optional, widening from a bare `T`, narrowable, and boxing as the
    // CLR's Nullable.
    class Main is
        entry() static is
            // Inbound: constructor parameter `int?` accepts a bare `int`
            // (the widening that was rejected at overload resolution
            // when the reflected `int?` wasn't recognised as optional).
            let s = Sink(7);

            // Inbound: `int?` field read back as a ghūl `int?`.
            write_line("seed: {s.describe(s.seed)}");

            // Inbound: bare `int` widened into an `int?` method parameter.
            write_line("bare: {s.describe(99)}");

            // Inbound: a bare `null` argument to a reflected `int?`
            // parameter lowers to the empty optional, not a null ref.
            write_line("null-arg: {s.describe(null)}");

            // Inbound: `int?` return value, narrowed and unwrapped.
            let m = s.maybe(true);
            if m? then
                write_line("maybe-present: {m!}");
            fi

            let n = s.maybe(false);
            write_line("maybe-absent: {if n? then "{n!}" else "absent" fi}");

            // Inbound: `T?` in a type-argument position (`Box[int?]`),
            // narrowed and unwrapped directly off the reflected generic
            // field — `ldflda` on a reference-type receiver must load the
            // reference, not the address of the local holding it.
            let b = Interop.make_box(123);
            write_line("box-present: {b.value?}");
            write_line("box-value: {b.value!}");

            // Outbound: boxing a ghūl `int?` to `object` follows CLR
            // Nullable boxing — a present optional boxes to a boxed int,
            // an empty one to a null reference. `int?` doesn't satisfy
            // non-optional `object` directly under strict-optional; the
            // `cast object(...)` makes the implicit boxing explicit.
            let present: int? = 5;
            write_line("inspect-present: {Interop.inspect(cast object(present))}");

            let absent: int? = null;
            write_line("inspect-absent: {Interop.inspect(cast object(absent))}");

            // Outbound: `typeof int?` is `typeof(Nullable<int>)`.
            write_line("typeof: {Interop.is_nullable_int(typeof int?)}");
        si
    si
si
