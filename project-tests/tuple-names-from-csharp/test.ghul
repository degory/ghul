namespace Test is
    use IO.Std.write_line;
    use TupleNamesFromCSharp;

    class Main is
        entry() static is
            let p = Points.make_point(3, 4);

            // element access through names recovered from the C# assembly
            write_line("p.x={p.x} p.y={p.y}");

            // pass a tuple to a C# method whose parameter is a named tuple
            write_line("describe: {Points.describe((10, 20))}");
        si
    si
si
