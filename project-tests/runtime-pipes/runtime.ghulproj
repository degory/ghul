<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <GhulCompiler>dotnet ghul-compiler</GhulCompiler>
    <AssemblyName>binary</AssemblyName>
    <GhulOptions>--suppress non-snake-case-member,non-snake-case-name,non-upper-snake-case-name</GhulOptions>
  </PropertyGroup>

  <ItemGroup>
    <GhulSources Include="**/*.ghul" />

    <PackageReference Include="MSTest.TestFramework" />
  </ItemGroup>
</Project>
