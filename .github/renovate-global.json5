{
  // Renovate configuration for the instance the Renovate workflow runs. It
  // updates other repositories, not this one, so it lives under .github/ and
  // is named distinctly rather than being a repository-level renovate.json.

  // These have to form a chain and never a cycle. An update landing in one
  // publishes a package, and publishing a package is what prompts the next
  // update, so a repository that ends up building against something it
  // published would hand updates back and forth indefinitely, every round
  // producing a real new version.
  //
  // A chain is fine because it ends. ghul-test publishes ghul.test, which
  // ghul-examples builds against, and ghul-examples publishes nothing, so that
  // one stops there.
  //
  // ghul is what would close the loop, and stays out: it builds against
  // ghul.test and ghul.runtime, and publishes the ghul.compiler that ghul-test
  // builds against. So ghul-test is safe to update automatically only for as
  // long as ghul is not. Adding ghul means first gating it so a person decides
  // when it republishes - a loop only runs by itself if every step in it is
  // automatic. ghul-runtime is absent for the same reason as ghul-test would
  // be: it is one edge of that same loop.
  repositories: [
    'degory/ghul-templates',
    'degory/ghul-repository-template',
    'degory/ghul-examples',
    'degory/ghul-dev',
    'degory/ghul-mcp',
    'degory/ghul-vsce',
    'degory/ghul-debug',
    'degory/ghul-code-review',
    'degory/ghul-web-api',
    'degory/ghul-test',
  ],

  // None of them carries a renovate.json, and none needs one: this file is the
  // single place the behaviour is described. Without these two settings
  // Renovate would instead open a pull request in each of them offering to add
  // one.
  onboarding: false,
  requireConfig: 'optional',

  dependencyDashboard: true,

  // A merged pull request's body becomes the release description in the
  // repository it updated, so the body carries only what describes the change:
  // which packages moved, to what, and their release notes. The default
  // template also appends how to interact with Renovate itself - its schedule,
  // whether it automerges, when it rebases, and a checkbox to request one -
  // which is addressed to whoever is reviewing the pull request and means
  // nothing to someone reading the release afterwards.
  prBodyTemplate: '{{{header}}}{{{table}}}{{{warnings}}}{{{notes}}}{{{changelogs}}}',

  // The classlib tests reference the package the template itself builds, which
  // is produced locally and never published, so looking it up finds nothing.
  ignoreDeps: ['example.classlib'],

  // A .ghulproj is not an extension any updater recognises, but no ghūl
  // project declares package versions in one: they come from the
  // Directory.Build.props and Directory.Packages.props beside it, and the
  // nuget manager reads .props files directly, as it reads the pinned compiler
  // in .config/dotnet-tools.json. So the ghūl projects need no special
  // handling here.
  packageRules: [
    {
      // One pull request for the ghūl packages together rather than one each.
      // Merging any of these publishes a new package, and a run of separate
      // merges publishes a burst of them, which NuGet rate limits.
      matchManagers: ['nuget'],
      matchPackageNames: ['/^ghul\\./'],
      groupName: 'ghūl packages',
    },
    {
      matchManagers: ['nuget'],
      matchPackageNames: ['!/^ghul\\./'],
      groupName: 'dependencies',
    },
    {
      // Release notes are kept for the ghūl packages, where they describe
      // changes to this project and are worth carrying into the release the
      // pull request becomes. For anything else they are another project's
      // changelog reproduced in full, long enough on its own to push the
      // description past the length the platform will store.
      matchPackageNames: ['!/^ghul\\./'],
      fetchChangeLogs: 'off',
    },
    {
      // One pull request for a repository's action updates together rather
      // than one each. Where a CODEOWNERS entry covers .github/workflows an
      // action update needs a review, and grouping asks for one review per run
      // instead of one per action.
      matchManagers: ['github-actions'],
      groupName: 'workflow actions',
    },
    {
      // Every target repository's CI builds what it depends on and runs the
      // result, so a version that breaks it fails the checks and Renovate
      // leaves the pull request open. That gate is what makes merging without
      // review reasonable here, including across major versions - the ghūl
      // compiler reaches a new major often, and a repository pinned to an old
      // one is the problem this is meant to solve.
      //
      // Where CODEOWNERS covers .github/workflows an action update waits for
      // that review as well. Automerge stays armed and lands it once the
      // review arrives.
      matchManagers: ['nuget', 'github-actions'],
      automerge: true,
    },
  ],
}
