{
  // Renovate configuration for the instance the Renovate workflow runs. It
  // updates other repositories, not this one, so it lives under .github/ and
  // is named distinctly rather than being a repository-level renovate.json.

  // Only repositories that publish nothing another automatically updated
  // repository builds against. An update landing here publishes a package, and
  // publishing a package is what prompts the next update, so a cycle in this
  // list would be a release loop with nothing to stop it. ghul, ghul-runtime,
  // ghul-test and ghul-targets all publish packages the others consume and are
  // deliberately absent.
  repositories: [
    'degory/ghul-templates',
    'degory/ghul-repository-template',
  ],

  // Neither repository carries a renovate.json, and neither needs one: this
  // file is the single place the behaviour is described. Without these two
  // settings Renovate would instead open a pull request in each of them
  // offering to add one.
  onboarding: false,
  requireConfig: 'optional',

  dependencyDashboard: true,

  // The classlib tests reference the package the template itself builds, which
  // is produced locally and never published, so looking it up finds nothing.
  ignoreDeps: ['example.classlib'],

  // A .ghulproj is not an extension any updater recognises, but it declares no
  // package references either - they come from the Directory.Build.props and
  // Directory.Packages.props beside it, and the nuget manager reads .props
  // files directly. So the ghūl projects need no special handling here.
  packageRules: [
    {
      // One pull request for the ghūl packages together rather than one each.
      // Merging any of these publishes a new package, and a run of separate
      // merges publishes a burst of them, which NuGet rate limits.
      matchManagers: ['nuget'],
      matchPackageNames: ['/^ghul\\./'],
      groupName: 'ghūl packages',
    },
    {
      matchManagers: ['nuget'],
      matchPackageNames: ['!/^ghul\\./'],
      groupName: 'dependencies',
    },
    {
      // Every target repository's CI builds the template and runs what it
      // produces, so a version that breaks it fails the checks and Renovate
      // leaves the pull request open. That gate is what makes merging without
      // review reasonable here, including across major versions - the ghūl
      // compiler reaches a new major often, and a template pinned to an old
      // one is the problem this is meant to solve.
      matchManagers: ['nuget', 'github-actions'],
      automerge: true,
    },
  ],
}
