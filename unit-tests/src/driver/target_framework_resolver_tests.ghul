namespace Driver.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    class TARGET_FRAMEWORK_RESOLVER_TESTS is
        @test()

        init() is si

        resolver() -> Driver.TARGET_FRAMEWORK_RESOLVER =>
            Driver.TARGET_FRAMEWORK_RESOLVER();

        explicit_override_wins_over_other_inputs() is
            @test()

            let r = resolver();

            Assert.are_equal("net11.0", r.resolve_tfm("net11.0", "/dotnet/packs/Microsoft.NETCore.App.Ref/10.0.8/ref/net10.0", "net8.0"));
        si

        sdk_reference_path_used_when_no_override() is
            @test()

            let r = resolver();

            Assert.are_equal("net10.0", r.resolve_tfm(null, "/dotnet/packs/Microsoft.NETCore.App.Ref/10.0.8/ref/net10.0", "net8.0"));
        si

        trailing_separator_in_path_is_stripped() is
            @test()

            let r = resolver();

            Assert.are_equal("net10.0", r.resolve_tfm(null, "/dotnet/packs/Microsoft.NETCore.App.Ref/10.0.8/ref/net10.0/", "net8.0"));
        si

        host_tfm_used_when_no_override_or_path() is
            @test()

            let r = resolver();

            Assert.are_equal("net10.0", r.resolve_tfm(null, null, "net10.0"));
        si

        empty_override_falls_through_to_path() is
            @test()

            let r = resolver();

            Assert.are_equal("net10.0", r.resolve_tfm("", "/dotnet/packs/Microsoft.NETCore.App.Ref/10.0.8/ref/net10.0", "net8.0"));
        si

        empty_path_falls_through_to_host() is
            @test()

            let r = resolver();

            Assert.are_equal("net8.0", r.resolve_tfm(null, "", "net8.0"));
        si

        all_inputs_null_returns_legacy_default() is
            @test()

            let r = resolver();

            Assert.are_equal("net10.0", r.resolve_tfm(null, null, null));
        si

        framework_version_for_net8() is
            @test()

            Assert.are_equal("8.0.0", resolver().resolve_framework_version("net8.0"));
        si

        framework_version_for_net10() is
            @test()

            Assert.are_equal("10.0.0", resolver().resolve_framework_version("net10.0"));
        si

        framework_version_for_net11() is
            @test()

            Assert.are_equal("11.0.0", resolver().resolve_framework_version("net11.0"));
        si

        framework_version_for_legacy_netcoreapp() is
            @test()

            Assert.are_equal("8.0.0", resolver().resolve_framework_version("netcoreapp8.0"));
        si

        unrecognised_tfm_returns_unchanged() is
            @test()

            Assert.are_equal("netstandard2.1", resolver().resolve_framework_version("netstandard2.1"));
        si

        extract_tfm_finds_value_in_runtimeconfig() is
            @test()

            let content = "{{\"runtimeOptions\":{{\"tfm\":\"net10.0\",\"framework\":{{\"name\":\"Microsoft.NETCore.App\",\"version\":\"10.0.0\"}}}}}}";

            Assert.are_equal("net10.0", resolver().extract_tfm(content));
        si

        extract_tfm_returns_null_when_missing() is
            @test()

            let content = "{{\"runtimeOptions\":{{\"framework\":{{\"name\":\"Microsoft.NETCore.App\"}}}}}}";

            Assert.is_null(resolver().extract_tfm(content));
        si
    si
si
