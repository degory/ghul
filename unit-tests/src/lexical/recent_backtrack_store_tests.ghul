namespace Lexical.UnitTests is
    class RECENT_BACKTRACK_STORE_TESTS is
        @test()

        init() is si

        // A genuine, non-terminating speculation loop commits no forward
        // progress, so its identical backtracks all carry the same
        // progress value. The store must still detect that and throw.
        given_repeated_backtracks_with_no_progress__record_backtrack__should_throw() is
            @test()

            let store = Lexical.RECENT_BACKTRACK_STORE();

            let threw mut = false;

            try
                for i in 0..8 do
                    store.record_backtrack(10, 5, 0);
                od
            catch e: System.Exception
                threw = true;
            yrt

            assert threw;
        si

        // The same span re-parsed after real forward progress — a
        // speculative probe followed by the real parse — carries a
        // different progress value each time, and must never be mistaken
        // for a loop however often it recurs.
        given_repeated_backtracks_with_advancing_progress__record_backtrack__should_not_throw() is
            @test()

            let store = Lexical.RECENT_BACKTRACK_STORE();

            let threw mut = false;

            try
                for i in 0..20 do
                    store.record_backtrack(10, 5, i);
                od
            catch e: System.Exception
                threw = true;
            yrt

            assert !threw;
        si
    si
si
