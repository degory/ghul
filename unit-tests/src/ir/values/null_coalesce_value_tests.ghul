namespace IR.Values.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;

    class NULL_COALESCE_VALUE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(NAMED(c));
            return c.type!;
        si

        type_t() -> Type =>
            CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0).type!;

        gen_to_string(value: IR.Values.Value) -> string is
            let context = IR.CONTEXT(null, null);
            context.enter_buffer(false);
            value.gen(context);
            return context.leave_buffer();
        si

        make(result_t: Type) -> NULL_COALESCE_VALUE =>
            NULL_COALESCE_VALUE(
                RAW(type_t(), "// recv"),
                RAW("// has-value"),
                RAW("// extract"),
                RAW("// present-arm"),
                RAW("// absent-arm"),
                result_t
            );

        NULL_COALESCE_VALUE_should_type_as_the_result_type() is
            @test()

            let result_t = make_class_type("Foo");

            let nc = make(result_t);

            Assert.is_true(nc.type?);
            Assert.are_same(result_t, nc.type);
        si

        NULL_COALESCE_VALUE_should_not_be_lightweight_pure() is
            @test()

            // Composes a branching IL sequence with a spilled local —
            // never short-circuited away by callers that gate on
            // is_lightweight_pure.
            let nc = make(make_class_type("Foo"));

            Assert.is_false(nc.is_lightweight_pure);
        si

        gen_should_spill_test_extract_then_branch_to_the_absent_arm() is
            @test()

            // The shell: spill the receiver to a hoisted local, test
            // presence through the spilled address, extract the
            // payload and run the present arm, and reach the absent
            // arm only behind the brfalse — the fallback must not
            // evaluate on the present path.
            let il = gen_to_string(make(type_t()));

            let recv = il.index_of("// recv");
            let spill = il.index_of("stloc");
            let presence = il.index_of("// has-value");
            let branch = il.index_of("brfalse");
            let extract = il.index_of("// extract");
            let present = il.index_of("// present-arm");
            let jump_end = il.index_of("br ");
            let absent = il.index_of("// absent-arm");

            Assert.is_true(il.contains(".locals init"));
            Assert.is_true(recv >= 0 /\ spill > recv);
            Assert.is_true(presence > spill /\ branch > presence);
            Assert.is_true(extract > branch /\ present > extract);
            Assert.is_true(jump_end > present /\ absent > jump_end);
        si
    si
si
