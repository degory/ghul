namespace IR.Values.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.STRUCT;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;

    // ADDRESS wraps a value whose address is needed: it generates the
    // wrapped value's own address when it has one, and spills to an
    // addressed temporary when it does not. has_address must delegate
    // to the wrapped value so a wrapped in-place lvalue stays an
    // lvalue and a wrapped copy stays a copy.
    class ADDRESS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_struct_type(name: string) -> Type is
            let s = STRUCT(loc(), loc(), null, name, empty_names(), false, null);
            s.set_type(NAMED(s));
            return s.type!;
        si

        address_of_addressable_value_should_report_address() is
            @test()

            let t = make_struct_type("S");

            let address = ADDRESS(STACK_TOP_ADDRESS(t));

            Assert.is_true(address.has_address);
        si

        address_of_copy_should_not_report_address() is
            @test()

            let t = make_struct_type("S");

            let address = ADDRESS(STACK_TOP(t));

            Assert.is_false(address.has_address);
        si
    si
si
