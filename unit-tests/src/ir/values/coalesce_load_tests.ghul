namespace IR.Values.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;

    // Focused tests for the IR values backing `?.` coalescing access:
    // STACK_TOP / STACK_TOP_ADDRESS as receiver stand-ins for already-
    // on-stack values, and COALESCE_LOAD emitting the dup / null-test
    // / load / null-sentinel sequence. Type-system fixtures follow
    // the patterns in narrow_env_tests / condition_analysis_tests.
    class COALESCE_LOAD_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(NAMED(c));
            return c.type;
        si

        STACK_TOP_should_type_as_the_underlying_value() is
            @test()

            let t = make_class_type("Foo");
            let st = STACK_TOP(t);

            Assert.is_true(st.type?);
            Assert.are_same(t, st.type);
        si

        STACK_TOP_should_not_report_address() is
            @test()

            let t = make_class_type("Foo");
            let st = STACK_TOP(t);

            Assert.is_false(st.has_address);
        si

        STACK_TOP_should_be_lightweight_pure() is
            @test()

            let t = make_class_type("Foo");
            let st = STACK_TOP(t);

            Assert.is_true(st.is_lightweight_pure);
        si

        STACK_TOP_ADDRESS_should_report_address() is
            @test()

            let t = make_class_type("Foo");
            let sta = STACK_TOP_ADDRESS(t);

            Assert.is_true(sta.has_address);
        si

        STACK_TOP_ADDRESS_should_type_as_the_underlying_value() is
            @test()

            let t = make_class_type("Foo");
            let sta = STACK_TOP_ADDRESS(t);

            Assert.is_true(sta.type?);
            Assert.are_same(t, sta.type);
        si

        COALESCE_LOAD_should_type_as_the_result_type() is
            @test()

            let recv_t = make_class_type("FooOptional");
            let result_t = make_class_type("BarOptional");
            let recv = STACK_TOP(recv_t);
            let member_load = STACK_TOP(make_class_type("Bar"));
            let null_value = IR.RAW(result_t, "ldnull");

            let coalesce = COALESCE_LOAD(recv, member_load, null_value, result_t);

            Assert.is_true(coalesce.type?);
            Assert.are_same(result_t, coalesce.type);
        si

        COALESCE_LOAD_value_type_overload_should_type_as_the_result_type() is
            @test()

            let recv_t = make_class_type("FooOptional");
            let inner_t = make_class_type("FooInner");
            let bool_t = make_class_type("bool");
            let result_t = make_class_type("BarOptional");

            let recv = STACK_TOP(recv_t);
            let presence_test = STACK_TOP(bool_t);
            let value_extract = STACK_TOP(inner_t);
            let member_load = STACK_TOP(make_class_type("Bar"));
            let null_value = IR.RAW(result_t, "ldnull");

            let coalesce =
                COALESCE_LOAD(
                    recv,
                    presence_test,
                    value_extract,
                    member_load,
                    null_value,
                    result_t
                );

            Assert.is_true(coalesce.type?);
            Assert.are_same(result_t, coalesce.type);
        si

        COALESCE_LOAD_should_not_be_lightweight_pure() is
            @test()

            // Coalesce composes branching IL and a stack-top
            // null-sentinel — never short-circuited away.
            let recv_t = make_class_type("FooOptional");
            let result_t = make_class_type("BarOptional");
            let recv = STACK_TOP(recv_t);
            let member_load = STACK_TOP(make_class_type("Bar"));
            let null_value = IR.RAW(result_t, "ldnull");

            let coalesce = COALESCE_LOAD(recv, member_load, null_value, result_t);

            Assert.is_false(coalesce.is_lightweight_pure);
        si

        build_optional_type_should_return_already_optional_unchanged() is
            @test()

            // Already-optional → identity; widening is a no-op and
            // never reaches the InnateSymbolLookup. null InnateSymbolLookup
            // here pins that contract — any access would NRE.
            let t = make_class_type("Foo");
            let optional = t.as_optional();

            let result = Syntax.Process.COMPILE_ACCESS.build_optional_type(optional, null);

            Assert.are_same(optional, result);
        si

        build_optional_type_should_flag_reference_type() is
            @test()

            // Reference T → T flagged optional via NAMED.as_optional —
            // IL identity, the type system carries the `?` view, the
            // lookup is bypassed (null below pins that).
            let t = make_class_type("Foo");

            let result = Syntax.Process.COMPILE_ACCESS.build_optional_type(t, null);

            Assert.is_true(result.is_optional);
        si

        build_optional_type_should_return_null_input_unchanged() is
            @test()

            // Defensive: a null input survives the widen, callers can
            // null-check the result. The lookup is again bypassed.
            let result = Syntax.Process.COMPILE_ACCESS.build_optional_type(null, null);

            Assert.is_null(result);
        si
    si
si
