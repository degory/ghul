namespace IR.Values.Literal.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use IR.Values.Literal.DECIMAL;

    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;

    class DECIMAL_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        any_type() -> Semantic.Types.Type =>
            CLASSY_GENERIC_ARGUMENT(loc(), null, "decimal", 0).type;

        gen_to_string(value: IR.Values.Value) -> string is
            let context = IR.CONTEXT(null, null);
            context.enter_buffer(false);
            value.gen(context);
            return context.leave_buffer();
        si

        ctor_il() -> string =>
            "newobj instance void valuetype ['System.Runtime']'System'.'Decimal'::'.ctor'(int32, int32, int32, bool, unsigned int8)\n";

        // gen emits five `ldc.i4`s in (lo, mid, hi, isNegative, scale)
        // order followed by the constructor call. Sign is always 0 here
        // — unary `-` wraps the call elsewhere. A regression that
        // reorders the ldc.i4s or drops the isNegative slot would
        // produce silently-incorrect decimal values.
        Calling__gen__emits_lo_mid_hi_zero_scale_then_ctor() is
            @test()

            let value = DECIMAL("12.34", any_type(), 1234, 0, 0, 2);

            Assert.are_equal(
                "ldc.i4 1234\nldc.i4 0\nldc.i4 0\nldc.i4 0\nldc.i4 2\n{ctor_il()}",
                gen_to_string(value)
            );
        si

        // Non-zero mid/hi flow through verbatim — gen has no
        // arithmetic, it's a pure projection of the constructor
        // arguments.
        Calling__gen__with_nonzero_mid__passes_through_to_ldc() is
            @test()

            let value = DECIMAL("10000000000", any_type(), 1410065408, 2, 0, 0);

            Assert.are_equal(
                "ldc.i4 1410065408\nldc.i4 2\nldc.i4 0\nldc.i4 0\nldc.i4 0\n{ctor_il()}",
                gen_to_string(value)
            );
        si

        is_lightweight_pure__should_be_true() is
            @test()

            // Decimal literals are pure constants — no side effects —
            // and Value.get_temp_copier uses this to skip materialising
            // a TEMP for repeated references. A regression to false
            // would emit redundant locals.
            let value = DECIMAL("1", any_type(), 1, 0, 0, 0);

            Assert.is_true(value.is_lightweight_pure);
        si

        // === decompose: happy paths ===

        // A digit-only literal lands its value in the low 32-bit slot
        // with scale = 0.
        Calling__decompose__on_integer_literal__lands_in_lo_with_zero_scale() is
            @test()

            let r = DECIMAL.decompose("100");

            Assert.is_null(r.error);
            Assert.are_equal(100, r.lo);
            Assert.are_equal(0, r.mid);
            Assert.are_equal(0, r.hi);
            Assert.are_equal(0, r.scale);
        si

        // Scale equals the count of digits after the dot; the digits
        // concatenate into a single base-10 mantissa.
        Calling__decompose__on_fractional_literal__sets_scale_from_dot_position() is
            @test()

            let r = DECIMAL.decompose("12.34");

            Assert.is_null(r.error);
            Assert.are_equal(1234, r.lo);
            Assert.are_equal(2, r.scale);
        si

        // Leading-zero fractions count every digit after the dot
        // toward scale, not just the significant ones.
        Calling__decompose__on_subunit_fraction__counts_full_digit_span() is
            @test()

            let r = DECIMAL.decompose("0.001");

            Assert.is_null(r.error);
            Assert.are_equal(1, r.lo);
            Assert.are_equal(3, r.scale);
        si

        // A mantissa exceeding 32 bits propagates carry into the mid
        // slot. 10_000_000_000 = 0x2_540B_E400.
        Calling__decompose__on_value_above_2_to_32__propagates_carry_into_mid() is
            @test()

            let r = DECIMAL.decompose("10000000000");

            Assert.is_null(r.error);
            Assert.are_equal(1410065408, r.lo);
            Assert.are_equal(2, r.mid);
            Assert.are_equal(0, r.hi);
        si

        // === decompose: range diagnostics ===

        // Decimal's scale slot is a uint8 capped at 28; reject scale
        // overflow at parse time with a clear error rather than
        // emitting a ctor call the BCL throws on at construction.
        Calling__decompose__with_scale_above_28__returns_error() is
            @test()

            // 29 digits after the dot.
            let r = DECIMAL.decompose("0.12345678901234567890123456789");

            Assert.is_not_null(r.error);
            Assert.is_true(r.error.contains("28"));
        si

        // Scale exactly at the limit is accepted — the bound is
        // inclusive, matching Decimal's actual representation range.
        Calling__decompose__with_scale_28__is_accepted() is
            @test()

            // 28 digits after the dot.
            let r = DECIMAL.decompose("0.1234567890123456789012345678");

            Assert.is_null(r.error);
            Assert.are_equal(28, r.scale);
        si

        // A mantissa that overflows the 96-bit slot is rejected. 30
        // nines exceeds 2^96 - 1 (~7.9e28); silently masking would
        // produce a truncated value. The check fires inside the loop
        // when prod_hi exceeds 32 bits.
        Calling__decompose__with_mantissa_above_96_bits__returns_error() is
            @test()

            // 30 nines (~9.99e29) — well past 2^96 - 1.
            let r = DECIMAL.decompose("999999999999999999999999999999");

            Assert.is_not_null(r.error);
        si
    si
si
