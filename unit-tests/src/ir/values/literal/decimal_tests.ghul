namespace IR.Values.Literal.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use IR.Values.Literal.DECIMAL;

    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;

    class DECIMAL_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        any_type() -> Semantic.Types.Type =>
            CLASSY_GENERIC_ARGUMENT(loc(), null, "decimal", 0).type;

        gen_to_string(value: IR.Values.Value) -> string is
            let context = IR.CONTEXT(null, null);
            context.enter_buffer(false);
            value.gen(context);
            return context.leave_buffer();
        si

        ctor_il() -> string =>
            "newobj instance void valuetype ['System.Runtime']'System'.'Decimal'::'.ctor'(int32, int32, int32, bool, unsigned int8)\n";

        // A digit-only literal decomposes to its integer value in the low
        // 32-bit slot with scale = 0. Sign bit stays 0; unary `-` wraps
        // the call elsewhere.
        Calling__gen__on_integer_literal__emits_low_only() is
            @test()

            let value = DECIMAL("100", any_type());

            Assert.are_equal(
                "ldc.i4 100\nldc.i4 0\nldc.i4 0\nldc.i4 0\nldc.i4 0\n{ctor_il()}",
                gen_to_string(value)
            );
        si

        // A fractional literal's scale equals the count of digits after
        // the dot; the digits concatenate into one base-10 mantissa.
        // 12.34 -> mantissa 1234, scale 2.
        Calling__gen__on_fractional_literal__sets_scale_from_dot_position() is
            @test()

            let value = DECIMAL("12.34", any_type());

            Assert.are_equal(
                "ldc.i4 1234\nldc.i4 0\nldc.i4 0\nldc.i4 0\nldc.i4 2\n{ctor_il()}",
                gen_to_string(value)
            );
        si

        // Leading-zero fractions still count every digit after the dot
        // into the scale — 0.001 is mantissa 1 with scale 3, not scale 1.
        // The mantissa contributes only one nonzero digit but the loop
        // still consumed three.
        Calling__gen__on_subunit_fraction__scales_full_digit_count() is
            @test()

            let value = DECIMAL("0.001", any_type());

            Assert.are_equal(
                "ldc.i4 1\nldc.i4 0\nldc.i4 0\nldc.i4 0\nldc.i4 3\n{ctor_il()}",
                gen_to_string(value)
            );
        si

        // A mantissa that exceeds 32 bits propagates carry into the mid
        // slot. 10_000_000_000 = 0x2_540B_E400 — low = 0x540B_E400,
        // mid = 0x2. A regression that drops the carry would silently
        // truncate the literal to its low 32 bits.
        Calling__gen__on_value_above_2_to_32__propagates_carry_into_mid() is
            @test()

            let value = DECIMAL("10000000000", any_type());

            // 0x540B_E400 as signed int32 = 1410065408.
            Assert.are_equal(
                "ldc.i4 1410065408\nldc.i4 2\nldc.i4 0\nldc.i4 0\nldc.i4 0\n{ctor_il()}",
                gen_to_string(value)
            );
        si

        is_lightweight_pure__should_be_true() is
            @test()

            // Decimal literals are pure constants — no side effects —
            // and Value.get_temp_copier uses this to skip materialising
            // a TEMP for repeated references. A regression to false
            // would emit redundant locals.
            let value = DECIMAL("1", any_type());

            Assert.is_true(value.is_lightweight_pure);
        si
    si
si
