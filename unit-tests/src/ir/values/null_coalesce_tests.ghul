namespace IR.Values.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;

    class NULL_COALESCE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(NAMED(c));
            return c.type;
        si

        NULL_COALESCE_should_type_as_the_result_type() is
            @test()

            let result_t = make_class_type("Foo");
            let left = STACK_TOP(make_class_type("FooOptional"));
            let right = STACK_TOP(result_t);

            let nc = NULL_COALESCE(left, right, result_t);

            Assert.is_true(nc.has_type);
            Assert.are_same(result_t, nc.type);
        si

        NULL_COALESCE_should_not_be_lightweight_pure() is
            @test()

            // Composes a branching IL sequence — never short-circuited
            // away by callers that gate on is_lightweight_pure.
            let result_t = make_class_type("Foo");
            let left = STACK_TOP(make_class_type("FooOptional"));
            let right = STACK_TOP(result_t);

            let nc = NULL_COALESCE(left, right, result_t);

            Assert.is_false(nc.is_lightweight_pure);
        si
    si
si
