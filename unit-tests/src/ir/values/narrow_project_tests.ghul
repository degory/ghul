namespace IR.Values.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use IR.RAW;
    use IR.Values.NARROW_PROJECT;

    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;

    class NARROW_PROJECT_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        type_t() -> Semantic.Types.Type =>
            CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0).type;

        typed(text: string, type: Semantic.Types.Type) -> Value =>
            IR.Values.TYPE_WRAPPER(type, RAW(text));

        gen_to_string(value: IR.Values.Value) -> string is
            let context = IR.CONTEXT(null, null);
            context.enter_buffer(false);
            value.gen(context);
            return context.leave_buffer();
        si

        type__should_be_the_projected_inner_T() is
            @test()

            // The narrowed view is the inner `T`, not the wrapper —
            // member access, operators and slot-boundary acceptance
            // all consult `type`, so this is what unlocks them.
            let inner_type = type_t();
            let underlying = typed("// wrapper", type_t());
            let projected = typed("// inner", inner_type);
            let value = NARROW_PROJECT(underlying, projected);

            Assert.are_same(inner_type, value.type);
        si

        peel__should_return_underlying_for_a_NARROW_PROJECT() is
            @test()

            // `?`, `!` and refutable bindings call `peel` to get the
            // wrapper-shaped load back.
            let underlying = typed("// wrapper", type_t());
            let projected = typed("// inner", type_t());
            let value = NARROW_PROJECT(underlying, projected);

            Assert.are_same(underlying, NARROW_PROJECT.peel(value));
        si

        peel__should_pass_through_a_non_projection() is
            @test()

            // A consumer that calls `peel` on a load that isn't a
            // projection gets it back unchanged.
            let plain = typed("// plain", type_t());

            Assert.are_same(plain, NARROW_PROJECT.peel(plain));
        si

        gen__should_emit_the_projected_IR() is
            @test()

            // IL gen is the projection — at runtime the wrapper struct
            // is loaded and the `.value` access leaves the inner `T`
            // on the stack. The wrapper itself is not emitted twice.
            let underlying = typed("// wrapper", type_t());
            let projected = typed("// inner", type_t());
            let value = NARROW_PROJECT(underlying, projected);

            Assert.are_equal("// inner\n", gen_to_string(value));
        si
    si
si
