namespace IR.Values.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use IR.RAW;
    use IR.Values.CONSTRAINED;

    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;

    // CONSTRAINED is the receiver of a constrained instance call - a call
    // to a member through a type parameter's bound. The `constrained.`
    // prefix it carries must land immediately before the `callvirt`,
    // after the arguments are on the stack, or the runtime rejects the IL
    // at JIT time. So `gen` loads only the receiver address and the
    // enclosing call emits the prefix separately, via `gen_prefix`, once
    // the arguments are generated. These pin that split.
    class CONSTRAINED_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        receiver() -> CONSTRAINED =>
            CONSTRAINED(RAW(CLASSY_GENERIC_ARGUMENT(loc(), null, "E", 0).type!, "// receiver"));

        Calling__gen__should_load_the_receiver_without_the_constrained_prefix() is
            @test()

            let context = IR.CONTEXT(null, null);
            context.enter_buffer(false);
            receiver().gen(context);

            // the prefix is the enclosing call's job, emitted after the args
            Assert.is_false(context.leave_buffer().contains("constrained."));
        si

        Calling__gen_prefix__should_emit_the_constrained_prefix_for_the_receiver_type() is
            @test()

            let context = IR.CONTEXT(null, null);
            context.enter_buffer(false);
            receiver().gen_prefix(context);

            Assert.are_equal("constrained. !0 \n", context.leave_buffer());
        si
    si
si
