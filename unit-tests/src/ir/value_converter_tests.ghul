namespace IR.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use NSubstitute;
    use NSubstitute.SubstituteExtensions.returns;

    use Source.LOCATION;

    use Semantic.Lookups.InnateSymbolLookup;
    use Semantic.Symbols.CLASS;
    use Semantic.Types.Type;

    use IR.VALUE_CONVERTER;

    class VALUE_CONVERTER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        // Numeric-primitive stand-ins for the decimal-conversion path.
        // Each `get_*_type()` mock returns the same Type instance every
        // call so callers can identity-compare. Distinct names keep the
        // converter's qualified_name map keys from colliding. Other
        // members on `InnateSymbolLookup` aren't touched by the
        // decimal-conversion path; NSubstitute auto-stubs them.
        build() -> (converter: VALUE_CONVERTER, lookup: InnateSymbolLookup) is
            let arguments = System.Array.empty`[object]();
            let lookup = NSubstitute.Substitute.`for`[InnateSymbolLookup](arguments);

            // VALUE_CONVERTER walks every numeric primitive at init
            // time to register its decimal-conversion neighbour, so
            // each one needs a distinct Type with a non-null symbol.
            let bool_type = CLASS(loc(), loc(), null, "bool", LIST[string](), false, null).type;
            let char_type = CLASS(loc(), loc(), null, "char", LIST[string](), false, null).type;
            let byte_type = CLASS(loc(), loc(), null, "byte", LIST[string](), false, null).type;
            let ubyte_type = CLASS(loc(), loc(), null, "ubyte", LIST[string](), false, null).type;
            let short_type = CLASS(loc(), loc(), null, "short", LIST[string](), false, null).type;
            let ushort_type = CLASS(loc(), loc(), null, "ushort", LIST[string](), false, null).type;
            let int_type = CLASS(loc(), loc(), null, "int", LIST[string](), false, null).type;
            let uint_type = CLASS(loc(), loc(), null, "uint", LIST[string](), false, null).type;
            let long_type = CLASS(loc(), loc(), null, "long", LIST[string](), false, null).type;
            let ulong_type = CLASS(loc(), loc(), null, "ulong", LIST[string](), false, null).type;
            let single_type = CLASS(loc(), loc(), null, "single", LIST[string](), false, null).type;
            let double_type = CLASS(loc(), loc(), null, "double", LIST[string](), false, null).type;
            let decimal_type = CLASS(loc(), loc(), null, "decimal", LIST[string](), false, null).type;

            returns(lookup.get_bool_type(), bool_type, null);
            returns(lookup.get_char_type(), char_type, null);
            returns(lookup.get_byte_type(), byte_type, null);
            returns(lookup.get_ubyte_type(), ubyte_type, null);
            returns(lookup.get_short_type(), short_type, null);
            returns(lookup.get_ushort_type(), ushort_type, null);
            returns(lookup.get_int_type(), int_type, null);
            returns(lookup.get_uint_type(), uint_type, null);
            returns(lookup.get_long_type(), long_type, null);
            returns(lookup.get_ulong_type(), ulong_type, null);
            returns(lookup.get_single_type(), single_type, null);
            returns(lookup.get_double_type(), double_type, null);
            returns(lookup.get_decimal_type(), decimal_type, null);

            let converter = VALUE_CONVERTER(null, lookup);
            return (converter, lookup);
        si

        decimal_il() -> string =>
            "valuetype ['System.Runtime']'System'.'Decimal'";

        // Conversions that don't touch decimal don't go through the
        // decimal call path — the existing single-instruction
        // `get_instruction` covers them. A non-null return here would
        // make TYPE_CASTER emit a decimal call for, say,
        // `cast int(some_double)`, which is wrong.
        get_decimal_conversion_instruction__no_decimal__returns_null() is
            @test()

            let b = build();

            Assert.is_null(b.converter.get_decimal_conversion_instruction(b.lookup.get_int_type(), b.lookup.get_double_type()));
        si

        // Widening integral -> decimal uses op_Implicit. Catches a
        // regression that flipped to op_Explicit (which exists for
        // float source but not for ints), making the call fail to
        // resolve at JIT.
        get_decimal_conversion_instruction__int_to_decimal__uses_op_Implicit_int32() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_int_type(), b.lookup.get_decimal_type());

            Assert.are_equal("call {decimal_il()} {decimal_il()}::op_Implicit(int32)", il);
        si

        get_decimal_conversion_instruction__long_to_decimal__uses_op_Implicit_int64() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_long_type(), b.lookup.get_decimal_type());

            Assert.are_equal("call {decimal_il()} {decimal_il()}::op_Implicit(int64)", il);
        si

        // Lossy float -> decimal uses op_Explicit, not op_Implicit
        // (there's no implicit float -> decimal in .NET). Flipping to
        // op_Implicit here would emit a methodref the loader rejects.
        get_decimal_conversion_instruction__double_to_decimal__uses_op_Explicit_float64() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_double_type(), b.lookup.get_decimal_type());

            Assert.are_equal("call {decimal_il()} {decimal_il()}::op_Explicit(float64)", il);
        si

        // decimal -> any numeric always uses op_Explicit (no implicit
        // narrowing exists). Return type drives overload selection on
        // the Decimal class.
        get_decimal_conversion_instruction__decimal_to_int__uses_op_Explicit_returning_int32() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_decimal_type(), b.lookup.get_int_type());

            Assert.are_equal("call int32 {decimal_il()}::op_Explicit({decimal_il()})", il);
        si

        // decimal -> decimal is the identity. We emit `nop` rather
        // than null so TYPE_CASTER can still wrap with CONVERT
        // (keeping the stack-type annotation consistent) but the
        // result is no IL work at runtime.
        get_decimal_conversion_instruction__decimal_to_decimal__emits_nop() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_decimal_type(), b.lookup.get_decimal_type());

            Assert.are_equal("nop", il);
        si

        // A target Decimal has no op_*(bool) overload — bool is
        // simply not in the convertible set. Null is the contract
        // for "decimal involved but no conversion"; TYPE_CASTER's
        // decimal-touches-decimal gate then promotes that to an
        // explicit "cannot convert" error rather than falling
        // through to `conv.u1` on a 128-bit struct (unverifiable IL).
        get_decimal_conversion_instruction__decimal_to_bool__returns_null() is
            @test()

            let b = build();

            Assert.is_null(b.converter.get_decimal_conversion_instruction(b.lookup.get_decimal_type(), b.lookup.get_bool_type()));
        si

        get_decimal_conversion_instruction__bool_to_decimal__returns_null() is
            @test()

            let b = build();

            Assert.is_null(b.converter.get_decimal_conversion_instruction(b.lookup.get_bool_type(), b.lookup.get_decimal_type()));
        si

        // System.Decimal has no op_*(char) overload (char <-> decimal
        // is routed through int in .NET). Registering char as a
        // neighbour would emit a methodref the loader rejects, so the
        // converter must report no-conversion for char in both
        // directions and let TYPE_CASTER surface a clean error.
        get_decimal_conversion_instruction__char_to_decimal__returns_null() is
            @test()

            let b = build();

            Assert.is_null(b.converter.get_decimal_conversion_instruction(b.lookup.get_char_type(), b.lookup.get_decimal_type()));
        si

        get_decimal_conversion_instruction__decimal_to_char__returns_null() is
            @test()

            let b = build();

            Assert.is_null(b.converter.get_decimal_conversion_instruction(b.lookup.get_decimal_type(), b.lookup.get_char_type()));
        si
    si
si
