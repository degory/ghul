namespace IR.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Lookups.InnateSymbolLookup;
    use Semantic.Symbols.CLASS;
    use Semantic.Types.Type;

    use IR.VALUE_CONVERTER;

    // Stand-in `InnateSymbolLookup` exposing only the numeric primitives
    // the decimal-conversion path depends on. Each get_*_type() returns
    // the same Type instance every call so callers can identity-compare.
    // Symbols are constructed with distinct names so their
    // qualified_name keys (the converter's internal map keys) don't
    // collide.
    class DECIMAL_LOOKUP: InnateSymbolLookup is
        _bool: Type;
        _char: Type;
        _byte: Type;
        _ubyte: Type;
        _short: Type;
        _ushort: Type;
        _int: Type;
        _uint: Type;
        _long: Type;
        _ulong: Type;
        _single: Type;
        _double: Type;
        _decimal: Type;

        init() is
            super.init();

            _bool = CLASS(loc(), loc(), null, "bool", LIST[string](), false, null).type;
            _char = CLASS(loc(), loc(), null, "char", LIST[string](), false, null).type;
            _byte = CLASS(loc(), loc(), null, "byte", LIST[string](), false, null).type;
            _ubyte = CLASS(loc(), loc(), null, "ubyte", LIST[string](), false, null).type;
            _short = CLASS(loc(), loc(), null, "short", LIST[string](), false, null).type;
            _ushort = CLASS(loc(), loc(), null, "ushort", LIST[string](), false, null).type;
            _int = CLASS(loc(), loc(), null, "int", LIST[string](), false, null).type;
            _uint = CLASS(loc(), loc(), null, "uint", LIST[string](), false, null).type;
            _long = CLASS(loc(), loc(), null, "long", LIST[string](), false, null).type;
            _ulong = CLASS(loc(), loc(), null, "ulong", LIST[string](), false, null).type;
            _single = CLASS(loc(), loc(), null, "single", LIST[string](), false, null).type;
            _double = CLASS(loc(), loc(), null, "double", LIST[string](), false, null).type;
            _decimal = CLASS(loc(), loc(), null, "decimal", LIST[string](), false, null).type;
        si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        get_enum_type() -> Type;
        get_tuple_type(types: Collections.List[Type], names: Collections.List[string]) -> Type;
        get_function_type(types: Collections.List[Type]) -> Type;
        get_array_type(type: Type) -> Type;
        get_optional_type(type: Type) -> Type;
        get_maybe_type(type: Type) -> Type? => null;
        get_pointer_type(type: Type) -> Type;
        get_reference_type(type: Type) -> Type;
        get_bool_type() -> Type => _bool;
        get_char_type() -> Type => _char;
        get_byte_type() -> Type => _byte;
        get_ubyte_type() -> Type => _ubyte;
        get_short_type() -> Type => _short;
        get_ushort_type() -> Type => _ushort;
        get_int_type() -> Type => _int;
        get_uint_type() -> Type => _uint;
        get_long_type() -> Type => _long;
        get_ulong_type() -> Type => _ulong;
        get_word_type() -> Type;
        get_uword_type() -> Type;
        get_single_type() -> Type => _single;
        get_double_type() -> Type => _double;
        get_decimal_type() -> Type => _decimal;
        get_void_type() -> Type;
        get_object_type() -> Type;
        get_value_type() -> Type;
        get_string_type() -> Type;
        get_exception_type() -> Type;
        get_type_type() -> Type;
        get_unspecialized_iterable_type() -> Type;
        get_unspecialized_iterator_type() -> Type;
        get_unspecialized_pipe_type() -> Type? => null;
        get_unspecialized_task_type() -> Type? => null;
        get_unspecialized_async_task_method_builder_type() -> Type? => null;
        get_unspecialized_task_awaiter_type() -> Type? => null;
        get_interpolated_string_handler_type() -> Type;
        get_idisposable_type() -> Type;
        get_box_type(type: Type) -> Type;
        get_task_type(type: Type) -> Type? => null;
        get_void_task_type() -> Type? => null;
        get_async_task_method_builder_type(type: Type) -> Type? => null;
        get_async_task_method_builder_void_type() -> Type? => null;
        get_async_state_machine_interface_type() -> Type? => null;
        get_task_awaiter_type(type: Type) -> Type? => null;
        get_task_awaiter_void_type() -> Type? => null;
    si

    class VALUE_CONVERTER_TESTS is
        @test()

        init() is si

        build() -> (converter: VALUE_CONVERTER, lookup: DECIMAL_LOOKUP) is
            let lookup = DECIMAL_LOOKUP();
            let converter = VALUE_CONVERTER(null, lookup);
            return (converter, lookup);
        si

        decimal_il() -> string =>
            "valuetype ['System.Runtime']'System'.'Decimal'";

        // Conversions that don't touch decimal don't go through the
        // decimal call path — the existing single-instruction
        // `get_instruction` covers them. A non-null return here would
        // make TYPE_CASTER emit a decimal call for, say,
        // `cast int(some_double)`, which is wrong.
        get_decimal_conversion_instruction__no_decimal__returns_null() is
            @test()

            let b = build();

            Assert.is_null(b.converter.get_decimal_conversion_instruction(b.lookup.get_int_type(), b.lookup.get_double_type()));
        si

        // Widening integral -> decimal uses op_Implicit. Catches a
        // regression that flipped to op_Explicit (which exists for
        // float source but not for ints), making the call fail to
        // resolve at JIT.
        get_decimal_conversion_instruction__int_to_decimal__uses_op_Implicit_int32() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_int_type(), b.lookup.get_decimal_type());

            Assert.are_equal("call {decimal_il()} {decimal_il()}::op_Implicit(int32)", il);
        si

        get_decimal_conversion_instruction__long_to_decimal__uses_op_Implicit_int64() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_long_type(), b.lookup.get_decimal_type());

            Assert.are_equal("call {decimal_il()} {decimal_il()}::op_Implicit(int64)", il);
        si

        // Lossy float -> decimal uses op_Explicit, not op_Implicit
        // (there's no implicit float -> decimal in .NET). Flipping to
        // op_Implicit here would emit a methodref the loader rejects.
        get_decimal_conversion_instruction__double_to_decimal__uses_op_Explicit_float64() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_double_type(), b.lookup.get_decimal_type());

            Assert.are_equal("call {decimal_il()} {decimal_il()}::op_Explicit(float64)", il);
        si

        // decimal -> any numeric always uses op_Explicit (no implicit
        // narrowing exists). Return type drives overload selection on
        // the Decimal class.
        get_decimal_conversion_instruction__decimal_to_int__uses_op_Explicit_returning_int32() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_decimal_type(), b.lookup.get_int_type());

            Assert.are_equal("call int32 {decimal_il()}::op_Explicit({decimal_il()})", il);
        si

        // decimal -> decimal is the identity. We emit `nop` rather
        // than null so TYPE_CASTER can still wrap with CONVERT
        // (keeping the stack-type annotation consistent) but the
        // result is no IL work at runtime.
        get_decimal_conversion_instruction__decimal_to_decimal__emits_nop() is
            @test()

            let b = build();
            let il = b.converter.get_decimal_conversion_instruction(b.lookup.get_decimal_type(), b.lookup.get_decimal_type());

            Assert.are_equal("nop", il);
        si

        // A target Decimal has no op_*(bool) overload — bool is
        // simply not in the convertible set. Returning null lets
        // TYPE_CASTER fall through to its "cannot convert" error
        // rather than emitting an unresolvable methodref.
        get_decimal_conversion_instruction__decimal_to_bool__returns_null() is
            @test()

            let b = build();

            Assert.is_null(b.converter.get_decimal_conversion_instruction(b.lookup.get_decimal_type(), b.lookup.get_bool_type()));
        si

        get_decimal_conversion_instruction__bool_to_decimal__returns_null() is
            @test()

            let b = build();

            Assert.is_null(b.converter.get_decimal_conversion_instruction(b.lookup.get_bool_type(), b.lookup.get_decimal_type()));
        si
    si
si
