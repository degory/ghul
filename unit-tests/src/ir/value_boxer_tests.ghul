namespace IR.UnitTests is
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.STRUCT;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;

    use IR.RAW;
    use IR.VALUE_BOXER;
    use IR.Values.BOX;
    use IR.Values.Value;

    // RAW's `has_type` defaults to false (it stores a type field but
    // never overrides the base getter), so `is_value_type` reads as
    // false on RAW regardless of the supplied type. The boxer
    // branches on `is_value_type`, so the unit tests need a Value
    // whose has_type does fire. TYPED_RAW is the minimum extension.
    class TYPED_RAW: RAW is
        has_type: bool => type?;

        init(type: Semantic.Types.Type, value: string) is
            super.init(type, value);
        si
    si

    // Tests for VALUE_BOXER's value-shape orchestration — the
    // boundary code that decides whether a value flowing into a slot
    // needs boxing (value-type → object), a T -> T? wrap (value-type
    // optional widening), or no change.
    //
    // The MAYBE -> reference-T? `.value` coercion in `wrap_if_needed`
    // and `box_arguments` goes through `IoC.CONTAINER.instance
    // .symbol_loader`, which would need full IoC bootstrap; those
    // paths are covered end-to-end by
    // `integration-tests/execution/maybe-as-optional-probe` (which
    // exercises both the return-value slot and the argument-pass
    // slot — the latter is the corner box_arguments has to handle
    // before the boxing branch fires).
    class VALUE_BOXER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // Silent logger — DIAGNOSTICS_STORE collects everything
        // without writing it anywhere, so a poisoning bug in the
        // boxer wouldn't pollute test output.
        a_logger() -> Logging.Logger => Logging.DIAGNOSTICS_STORE();

        // Reference type — its `is_value_type` is false, so it
        // never trips the value-into-reference-slot boxing branch.
        a_reference_class() -> CLASS =>
            CLASS(loc(), loc(), null, "Ref", empty_names(), false, null);

        // Value type — its `is_value_type` is true, so a flow into
        // a reference slot DOES trip the boxing branch.
        a_value_struct() -> STRUCT =>
            STRUCT(loc(), loc(), null, "Val", empty_names(), false, null);

        ref_type() -> Type => a_reference_class().type;
        val_type() -> Type => a_value_struct().type;

        ref_value() -> Value => TYPED_RAW(ref_type(), "// ref");
        val_value() -> Value => TYPED_RAW(val_type(), "// val");

        boxer(want_boxing: bool) -> VALUE_BOXER is
            let b = VALUE_BOXER(a_logger());
            b.want_boxing = want_boxing;
            return b;
        si

        // ===== box_if_value =====

        box_if_value__when_want_boxing_off__returns_value_unchanged() is
            @test()

            let v = val_value();

            let result = boxer(false).box_if_value(v);

            // No wrap — the boxer is in "leave it as a value type"
            // mode (the IoC-default outside of object-slot contexts).
            Assert.are_same(v, result);
        si

        box_if_value__when_want_boxing_and_value_type__wraps_in_BOX() is
            @test()

            let v = val_value();

            let result = boxer(true).box_if_value(v);

            Assert.is_true(isa BOX(result));
        si

        box_if_value__when_want_boxing_and_reference_type__leaves_alone() is
            @test()

            // A reference type is already an object — boxing it
            // would be a `box object`, which is malformed IL.
            let v = ref_value();

            let result = boxer(true).box_if_value(v);

            Assert.are_same(v, result);
        si

        // ===== wrap_if_needed: early-return paths =====

        wrap_if_needed__null_value__returns_null() is
            @test()

            // Defensive — the boxer is called from a lot of places
            // and a null source here means an upstream pass already
            // poisoned; the boxer must not crash trying to wrap it.
            let result = boxer(false).wrap_if_needed(null, val_type());

            Assert.is_null(result);
        si

        wrap_if_needed__null_target_type__returns_value_unchanged() is
            @test()

            let v = val_value();

            let result = boxer(false).wrap_if_needed(v, null);

            Assert.are_same(v, result);
        si

        wrap_if_needed__non_optional_target__returns_value_unchanged() is
            @test()

            // The wrap fires only at a `T?` slot — a bare-T target
            // skips the wrap entirely so a plain `T → T` assignment
            // has zero extra IR.
            let v = val_value();
            let bare = val_type();

            let result = boxer(false).wrap_if_needed(v, bare);

            Assert.are_same(v, result);
        si

        wrap_if_needed__reference_optional_target_non_MAYBE_source__returns_value_unchanged() is
            @test()

            // A flagged-NAMED `Ref?` accepts a bare `Ref` by SAME
            // (same CLR type, only the type-system flag differs);
            // no IL wrap is needed. Pinned so a refactor of the
            // MAYBE branch can't accidentally widen the wrap path.
            let v = ref_value();
            let optional_ref = ref_type().as_optional();

            let result = boxer(false).wrap_if_needed(v, optional_ref);

            Assert.are_same(v, result);
        si

        // ===== box_arguments =====

        box_arguments__no_changes_needed__returns_same_list_identity() is
            @test()

            // Optimisation contract — when nothing needs wrapping
            // or boxing, the caller gets back the input list, not a
            // freshly-allocated copy. The argument-rewriting passes
            // can rely on identity to short-circuit follow-up walks.
            let args = LIST[Value]();
            args.add(ref_value());
            args.add(ref_value());

            let types = LIST[Type]();
            types.add(ref_type());
            types.add(ref_type());

            let result = boxer(false).box_arguments(args, types);

            Assert.are_same(args, result);
        si

        box_arguments__value_into_reference_slot__wraps_in_BOX() is
            @test()

            // The classic boxing path — a value type flowing into a
            // `object`-shaped (or any reference) formal parameter
            // gets `box`'d. The fix in this PR moves the wrap check
            // before the box check, so we need to pin that a bare
            // value (no wrap target) still boxes correctly.
            let args = LIST[Value]();
            args.add(val_value());

            let types = LIST[Type]();
            types.add(ref_type());

            let result = boxer(true).box_arguments(args, types);

            Assert.are_equal(1, result.count);
            Assert.is_true(isa BOX(result[0]));
        si

        box_arguments__arity_preserved() is
            @test()

            // box_arguments rebuilds the list when changes are
            // needed; pin that the result has the same arity even
            // when an early-out is skipped.
            let args = LIST[Value]();
            args.add(val_value());
            args.add(ref_value());
            args.add(val_value());

            let types = LIST[Type]();
            types.add(ref_type());
            types.add(ref_type());
            types.add(ref_type());

            let result = boxer(true).box_arguments(args, types);

            Assert.are_equal(args.count, result.count);
        si

        box_arguments__empty_list__returns_empty() is
            @test()

            let args = LIST[Value]();
            let types = LIST[Type]();

            let result = boxer(false).box_arguments(args, types);

            // No iterations → any_need_change stays false → input
            // returned as-is.
            Assert.are_same(args, result);
        si
    si
si
