namespace Logging.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;
    use Logging.TAB_DELIMITED_DIAGNOSTIC_FORMATTER;

    class DIAGNOSTICS_STORE_TESTS is
        @test()

        init() is si

        loc(path: string, line: int) -> LOCATION => LOCATION(path, line, 1, line, 10);

        // Log `count` pre-analysis warnings into the store — the shape the
        // check-name-conventions post-parse pass produces, spread across
        // several files.
        add_pre_analysis_warnings(store: DIAGNOSTICS_STORE, count: int) is
            for i in 0..count do
                store.warn(loc("warnings{i % 3}.ghul", i + 1), "some-warning-code", "warning number {i}");
            od
        si

        write_diagnostics(store: DIAGNOSTICS_STORE) -> string is
            let buffer = IO.StringWriter();
            store.write_all_diagnostics(buffer, TAB_DELIMITED_DIAGNOSTIC_FORMATTER());
            return buffer.to_string();
        si

        many_standing_warnings_do_not_arm_the_cascade_filter() is
            @test()

            let store = DIAGNOSTICS_STORE();

            add_pre_analysis_warnings(store, 40);

            store.start_analysis();
            store.error(loc("broken.ghul", 3), "Ghul.string is not assignable to Ghul.int");
            store.end_analysis();

            Assert.is_false(store.only.is_possible_error_cascade);

            let written = write_diagnostics(store);

            Assert.is_true(
                written.contains("not assignable"),
                "semantic error missing from diagnostics output:\n{written}"
            );
        si

        many_syntax_errors_arm_the_cascade_filter() is
            @test()

            let store = DIAGNOSTICS_STORE();

            for i in 0..31 do
                store.error(loc("broken.ghul", i + 1), "syntax error number {i}");
            od

            store.start_analysis();
            store.error(loc("broken.ghul", 40), "downstream semantic error");
            store.end_analysis();

            Assert.is_true(store.only.is_possible_error_cascade);

            let written = write_diagnostics(store);

            Assert.is_false(
                written.contains("downstream semantic error"),
                "cascade-filtered output should hold back analysis diagnostics:\n{written}"
            );

            Assert.is_true(
                written.contains("syntax error number 0"),
                "cascade-filtered output should still carry the leading syntax errors:\n{written}"
            );
        si

        warnings_do_not_count_towards_the_cascade_error_threshold() is
            @test()

            let store = DIAGNOSTICS_STORE();

            add_pre_analysis_warnings(store, 40);

            // One genuine syntax error, but nowhere near 30 errors in
            // total — the standing warnings must not tip the threshold.
            store.error(loc("broken.ghul", 1), "expected identifier");

            store.start_analysis();
            store.error(loc("broken.ghul", 3), "downstream semantic error");
            store.end_analysis();

            Assert.is_false(store.only.is_possible_error_cascade);

            let written = write_diagnostics(store);

            Assert.is_true(
                written.contains("downstream semantic error"),
                "semantic error missing from diagnostics output:\n{written}"
            );
        si

        set_open_files__reports_change_when_first_populated() is
            @test()

            let store = DIAGNOSTICS_STORE();

            Assert.is_true(
                store.set_open_files(["a.ghul"]),
                "populating an empty open-file set must count as a change"
            );
        si

        set_open_files__reports_no_change_on_identical_replacement() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul", "b.ghul"]);

            Assert.is_false(
                store.set_open_files(["a.ghul", "b.ghul"]),
                "replacing the open-file set with an identical one must report no change"
            );
        si

        set_open_files__reports_no_change_on_reorder() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul", "b.ghul"]);

            Assert.is_false(
                store.set_open_files(["b.ghul", "a.ghul"]),
                "set membership is order-insensitive"
            );
        si

        set_open_files__reports_no_change_on_duplicates() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul"]);

            Assert.is_false(
                store.set_open_files(["a.ghul", "a.ghul"]),
                "duplicate paths collapse in a set"
            );
        si

        set_open_files__reports_change_on_added_path() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul"]);

            Assert.is_true(
                store.set_open_files(["a.ghul", "b.ghul"]),
                "adding a path must count as a change"
            );
        si

        set_open_files__reports_change_on_removed_path() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul", "b.ghul"]);

            Assert.is_true(
                store.set_open_files(["a.ghul"]),
                "dropping a path must count as a change"
            );
        si

        set_open_files__reports_change_on_swapped_path() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul"]);

            Assert.is_true(
                store.set_open_files(["b.ghul"]),
                "swapping paths with equal count must count as a change"
            );
        si

        set_open_files__reports_change_on_clear() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul"]);

            Assert.is_true(
                store.set_open_files(Collections.LIST[string]()),
                "clearing a non-empty open-file set must count as a change"
            );
        si

        set_open_files__reports_no_change_on_empty_to_empty() is
            @test()

            let store = DIAGNOSTICS_STORE();

            Assert.is_false(
                store.set_open_files(Collections.LIST[string]()),
                "empty-to-empty must report no change"
            );
        si

        demote_to_hint__drops_the_warning_in_batch_compilation() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.demote_to_hint("cast-may-throw");

            store.warn(loc("a.ghul", 1), "cast-may-throw", "cast may throw here");

            Assert.is_false(store.any_warnings, "a demoted warning must not count as a warning");
            Assert.are_equal(0, store.only.count, "a demoted warning must not be recorded in batch compilation");

            let written = write_diagnostics(store);

            Assert.is_false(
                written.contains("cast may throw here"),
                "a demoted warning must not reach batch output:\n{written}"
            );
        si

        demote_to_hint__surfaces_as_a_hint_for_an_open_file_in_analysis() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul"]);
            store.demote_to_hint("cast-may-throw");

            store.start_analysis();
            store.warn(loc("a.ghul", 1), "cast-may-throw", "cast may throw here");
            store.end_analysis();

            Assert.is_false(store.any_warnings, "a demoted warning is a hint, not a warning");
            Assert.is_false(store.any_errors, "a demoted warning is a hint, not an error");

            let written = write_diagnostics(store);

            Assert.is_true(
                written.contains("cast may throw here"),
                "a demoted warning must surface as a hint for an open file in analysis:\n{written}"
            );

            // Tab-delimited severity column: HINT is 4.
            Assert.is_true(
                written.contains("\t4\t"),
                "a demoted warning must carry HINT severity:\n{written}"
            );
        si

        demote_to_hint__drops_the_hint_for_a_file_the_client_is_not_viewing() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["other.ghul"]);
            store.demote_to_hint("cast-may-throw");

            store.start_analysis();
            store.warn(loc("a.ghul", 1), "cast-may-throw", "cast may throw here");
            store.end_analysis();

            Assert.are_equal(0, store.only.count, "a demoted hint must be dropped for a file that is not open");
        si

        suppress_wins_over_demote_to_hint() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul"]);
            store.demote_to_hint("cast-may-throw");
            store.suppress("cast-may-throw");

            store.start_analysis();
            store.warn(loc("a.ghul", 1), "cast-may-throw", "cast may throw here");
            store.end_analysis();

            Assert.are_equal(0, store.only.count, "suppression must win over demotion to hint");
        si

        demote_to_hint__wins_over_promote_to_error() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul"]);
            store.demote_to_hint("cast-may-throw");
            store.promote_to_error("cast-may-throw");

            store.start_analysis();
            store.warn(loc("a.ghul", 1), "cast-may-throw", "cast may throw here");
            store.end_analysis();

            Assert.is_false(store.any_errors, "demotion to hint must win over promotion to error");
        si

        demote_to_info__keeps_the_diagnostic_visible_in_batch_as_info() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.demote_to_info("cast-may-throw");

            // Batch compilation: not analysis, no open files.
            store.warn(loc("a.ghul", 1), "cast-may-throw", "cast may throw here");

            Assert.is_false(store.any_warnings, "a demoted warning is info, not a warning");
            Assert.is_false(store.any_errors, "a demoted warning is info, not an error");
            Assert.are_equal(1, store.only.count, "info stays a batch-visible diagnostic");

            // Tab-delimited severity column: INFO is 3.
            let written = write_diagnostics(store);

            Assert.is_true(
                written.contains("\t3\t"),
                "a warning demoted to info must carry INFO severity:\n{written}"
            );
        si

        suppress_wins_over_demote_to_info() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.demote_to_info("cast-may-throw");
            store.suppress("cast-may-throw");

            store.warn(loc("a.ghul", 1), "cast-may-throw", "cast may throw here");

            Assert.are_equal(0, store.only.count, "suppression must win over demotion to info");
        si

        demote_to_hint_wins_over_demote_to_info() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.demote_to_hint("cast-may-throw");
            store.demote_to_info("cast-may-throw");

            // Batch: a hint is gated away, an info would remain. If hint
            // wins, nothing is recorded in batch.
            store.warn(loc("a.ghul", 1), "cast-may-throw", "cast may throw here");

            Assert.are_equal(0, store.only.count, "demotion to hint must take precedence over demotion to info");
        si

        want_hint_for__in_analysis_gates_on_the_open_file_set() is
            @test()

            let store = DIAGNOSTICS_STORE();

            store.set_open_files(["a.ghul"]);
            store.start_analysis();

            Assert.is_true(store.want_hint_for(loc("a.ghul", 1)), "an open file wants hints in analysis");
            Assert.is_false(store.want_hint_for(loc("b.ghul", 1)), "a file the client is not viewing does not");

            store.end_analysis();

            Assert.is_false(store.want_hint_for(loc("a.ghul", 1)), "outside analysis, hints are off again");
        si
    si
si
