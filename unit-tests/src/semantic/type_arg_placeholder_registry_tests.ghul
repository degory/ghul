namespace Semantic.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    use Semantic.SYMBOL_TABLE;
    use Semantic.TYPE_ARG_PLACEHOLDER_REGISTRY;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INSTANCE_METHOD;
    use Semantic.Symbols.Variable;

    use Semantic.Types.Type;

    use Syntax.Trees.Node;

    // Tests for TYPE_ARG_PLACEHOLDER_REGISTRY — the stateful cache
    // that backs iterative-inference at constructor expressions.
    //
    // The cache's correctness rests on two properties:
    //
    //   - Stability: re-asking for the same cache_key returns the
    //     SAME LIST instance with the SAME phantom Variables. Body-
    //     retry depends on this — constraints pushed into a phantom's
    //     _lub_map on iteration N must be visible to the LUB lookup
    //     on iteration N+1.
    //
    //   - Width: get_or_create produces exactly one phantom per
    //     argument_name on the type symbol. Phantom_origins lists
    //     consumed by OWNER_TYPE_ARG_SPECIALIZER align positionally
    //     with argument_names; a too-short list would silently leave
    //     slots unbound.
    //
    // specialize_with_placeholders is the entry consumed by
    // resolve_constructor — bail-out branches are tested directly;
    // the positive path (which calls GENERIC.try_create_from +
    // find_specialized_function) is integration-test territory.
    class TYPE_ARG_PLACEHOLDER_REGISTRY_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();
        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        build_registry() -> TYPE_ARG_PLACEHOLDER_REGISTRY is
            let logger = DIAGNOSTICS_STORE();
            let symbol_table = SYMBOL_TABLE(logger);
            return TYPE_ARG_PLACEHOLDER_REGISTRY(symbol_table);
        si

        // === get_or_create ===

        Calling__get_or_create__on_one_arg_classy__produces_one_phantom() is
            @test()

            let registry = build_registry();
            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);
            let key = Node(loc());

            let origins = registry.get_or_create(key, loc(), box);

            Assert.is_not_null(origins);
            Assert.are_equal(1, origins.count);
            Assert.is_not_null(origins[0]);
        si

        Calling__get_or_create__on_two_arg_classy__produces_two_phantoms() is
            @test()

            let registry = build_registry();
            let pair = CLASS(loc(), loc(), null, "Pair", names_for(["T", "U"]), false, null);
            let key = Node(loc());

            let origins = registry.get_or_create(key, loc(), pair);

            Assert.are_equal(2, origins.count);
            Assert.is_not_null(origins[0]);
            Assert.is_not_null(origins[1]);
        si

        // Stability: re-asking the same cache_key returns the SAME
        // list instance (not just one equal in content). Body-retry's
        // constraint accumulation depends on this — iter N+1 reads
        // the same phantom-_lub_map iter N wrote to.
        Calling__get_or_create__with_same_cache_key__returns_same_list() is
            @test()

            let registry = build_registry();
            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);
            let key = Node(loc());

            let first = registry.get_or_create(key, loc(), box);
            let second = registry.get_or_create(key, loc(), box);

            Assert.are_same(first, second);
            Assert.are_same(first[0], second[0]);
        si

        // Distinct cache_keys produce distinct phantom lists. Each
        // call expression in the source gets its own phantoms so
        // match propagation at one call site doesn't bleed into another.
        Calling__get_or_create__with_distinct_cache_keys__returns_distinct_lists() is
            @test()

            let registry = build_registry();
            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);
            let key_a = Node(loc());
            let key_b = Node(loc());

            let a = registry.get_or_create(key_a, loc(), box);
            let b = registry.get_or_create(key_b, loc(), box);

            Assert.are_not_same(a, b);
            Assert.are_not_same(a[0], b[0]);
        si

        // === clear ===

        // After clear(), a previously-cached key triggers a fresh
        // create — i.e. the cache is genuinely empty. Pinned because
        // apply()-boundary clear() is the only thing keeping a
        // recompile of the same file from reusing phantoms that
        // reference Type instances from the now-wiped symbol table.
        Calling__clear__discards_cached_entries() is
            @test()

            let registry = build_registry();
            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);
            let key = Node(loc());

            let before = registry.get_or_create(key, loc(), box);
            registry.clear();
            let after = registry.get_or_create(key, loc(), box);

            Assert.are_not_same(before, after);
        si

        // === specialize_with_placeholders: bail-out branches ===

        Calling__specialize_with_placeholders__with_null_cache_key__returns_candidate() is
            @test()

            let registry = build_registry();
            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);
            let init = INSTANCE_METHOD(loc(), loc(), box, "init", null);

            let result = registry.specialize_with_placeholders(loc(), init, null);

            Assert.are_same(init, result);
        si

        Calling__specialize_with_placeholders__on_non_generic_owner__returns_candidate() is
            @test()

            let registry = build_registry();
            let plain = CLASS(loc(), loc(), null, "Plain", empty_names(), false, null);
            let init = INSTANCE_METHOD(loc(), loc(), plain, "init", null);
            let key = Node(loc());

            let result = registry.specialize_with_placeholders(loc(), init, key);

            Assert.are_same(init, result);
        si

        // === fill_in_defaults ===

        // Empty registry: nothing to fill. Pinned because the visitor
        // calls this unconditionally after every body-retry loop and
        // relies on the false return to skip the extra walk when
        // there were no phantoms.
        Calling__fill_in_defaults__on_empty_registry__returns_false() is
            @test()

            let registry = build_registry();
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);

            let result = registry.fill_in_defaults(object_class.type);

            Assert.is_false(result);
        si

        // With a phantom-list present, fill_in_defaults adds the
        // object_type constraint to every unresolved phantom and
        // returns true. Confirms the loop iterates the cache map,
        // not just the most-recent list.
        Calling__fill_in_defaults__with_unresolved_phantoms__returns_true() is
            @test()

            let registry = build_registry();
            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            let key = Node(loc());

            registry.get_or_create(key, loc(), box);

            let result = registry.fill_in_defaults(object_class.type);

            Assert.is_true(result);
        si
    si
si
