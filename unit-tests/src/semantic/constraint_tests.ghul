namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;

    use Semantic.Types.ERROR;
    use Semantic.Types.INFERED_RETURN_TYPE;
    use Semantic.Types.INFERRED_VARIABLE_TYPE;

    use Semantic.Constraint;
    use Semantic.MEMBER_CONSTRAINT;
    use Semantic.CALL_CONSTRAINT;

    // Tests for the operation-constraint abstraction consulted by
    // the constraint-aware LUB. The discharge function is the lever
    // the LUB uses to filter candidate types — a false positive
    // lets it pick a candidate that doesn't actually expose the
    // operation, leading to broken IL or runtime type errors. Pin
    // the conservative-rejection paths here so refactors can't
    // accidentally flip them.
    class MEMBER_CONSTRAINT_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        // Conservative-rejection axis 1: null candidates. A null
        // type cannot expose any member, so discharge returns false.
        Calling__try_discharge__on_a_null_candidate__should_return_false() is
            @test()

            let c = MEMBER_CONSTRAINT("foo");

            Assert.is_false(c.try_discharge(null));
        si

        // Conservative-rejection axis 2: ERROR-typed candidates.
        // ERROR is a hard-failure marker; treating it as a valid
        // discharge target would let the LUB resolve a placeholder
        // to ERROR, silently propagating the failure further into
        // IL generation. Reject explicitly.
        Calling__try_discharge__on_an_error_candidate__should_return_false() is
            @test()

            let c = MEMBER_CONSTRAINT("foo");

            Assert.is_false(c.try_discharge(ERROR()));
        si

        // Conservative-rejection axis 3: placeholder candidates.
        // An INFERRED_VARIABLE_TYPE or INFERED_RETURN_TYPE is
        // itself awaiting resolution. Discharging against another
        // placeholder produces a circular chain that never lands
        // on a real type — reject so the solver picks something
        // concrete instead.
        Calling__try_discharge__on_an_inferred_variable_type_candidate__should_return_false() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let placeholder = INFERRED_VARIABLE_TYPE(origin);
            let c = MEMBER_CONSTRAINT("foo");

            Assert.is_false(c.try_discharge(placeholder));
        si

        Calling__try_discharge__on_an_inferred_return_type_candidate__should_return_false() is
            @test()

            let c = MEMBER_CONSTRAINT("foo");

            Assert.is_false(c.try_discharge(INFERED_RETURN_TYPE()));
        si

        // Member-name miss: a candidate that doesn't carry the
        // requested member name fails to discharge. This is the
        // most common path during solving — most candidate types
        // won't have the specific operation site's member.
        Calling__try_discharge__on_a_class_without_the_requested_member__should_return_false() is
            @test()

            let k = CLASS(loc(), loc(), null, "Empty", empty_names(), false, null);
            let c = MEMBER_CONSTRAINT("nonexistent_member");

            Assert.is_false(c.try_discharge(k.type));
        si

        // Equality + hash. Two MEMBER_CONSTRAINTs asking for the
        // same member name MUST collide so the SET-based
        // accumulator on Variable folds repeat emissions from
        // re-walks. Pinning both `equals` and `get_hash_code` here
        // so subclasses can't accidentally diverge — the SET
        // breaks silently if hash and equality disagree.
        Two__MEMBER_CONSTRAINT__instances_with_the_same_name__should_be_equal() is
            @test()

            let a = MEMBER_CONSTRAINT("foo");
            let b = MEMBER_CONSTRAINT("foo");

            Assert.is_true(a.equals(b));
            Assert.are_equal(a.get_hash_code(), b.get_hash_code());
        si

        Two__MEMBER_CONSTRAINT__instances_with_different_names__should_not_be_equal() is
            @test()

            let a = MEMBER_CONSTRAINT("foo");
            let b = MEMBER_CONSTRAINT("bar");

            Assert.is_false(a.equals(b));
        si

        // Cross-subclass equality returns false. Subclasses must
        // stay distinguishable even when they share a "name" or
        // other shape, because the Variable._constraints SET
        // accumulator relies on equals/get_hash_code to dedup
        // per-shape.
        A__MEMBER_CONSTRAINT__should_not_be_equal_to_a_base_Constraint() is
            @test()

            let a = MEMBER_CONSTRAINT("foo");
            let b = Constraint();

            Assert.is_false(a.equals(b));
            Assert.is_false(b.equals(a));
        si

        // A null other is rejected, never NREs. The set machinery
        // shouldn't pass null but we're defensive.
        Calling__equals__with_null_other__should_return_false() is
            @test()

            let a = MEMBER_CONSTRAINT("foo");

            Assert.is_false(a.equals(null));
        si
    si

    // Tests for CALL_CONSTRAINT — emitted at `_visit(call)` when
    // the receiver is itself an INFERRED_VARIABLE_TYPE placeholder
    // (e.g. self-applied shapes like `(f, x) => f(f(x))`, where
    // the inner `f(x)` calls a placeholder-typed receiver).
    //
    // Pinning conservative-rejection paths so accidental loosening
    // can't push CALL_CONSTRAINT into accepting non-callable types
    // or mis-matched-arity types as discharge candidates — both
    // failures would let the LUB resolve a placeholder to a type
    // the call site can't actually invoke, producing broken IL.
    class CALL_CONSTRAINT_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        types() -> LIST[Semantic.Types.Type] => LIST[Semantic.Types.Type]();
        types(a: Semantic.Types.Type) -> LIST[Semantic.Types.Type] is
            let result = LIST[Semantic.Types.Type]();
            result.add(a);
            return result;
        si
        types(a: Semantic.Types.Type, b: Semantic.Types.Type) -> LIST[Semantic.Types.Type] is
            let result = LIST[Semantic.Types.Type]();
            result.add(a);
            result.add(b);
            return result;
        si

        // Conservative-rejection axis 1: null candidate cannot be
        // callable, discharge returns false. Same shape as
        // MEMBER_CONSTRAINT_TESTS' axis 1 — pinned here as the
        // CALL_CONSTRAINT-specific equivalent.
        Calling__try_discharge__on_a_null_candidate__should_return_false() is
            @test()

            let c = CALL_CONSTRAINT(types());

            Assert.is_false(c.try_discharge(null));
        si

        // Conservative-rejection axis 2: ERROR candidate. Same
        // rationale as MEMBER_CONSTRAINT — treating ERROR as a
        // valid discharge target lets the LUB silently propagate
        // failure.
        Calling__try_discharge__on_an_error_candidate__should_return_false() is
            @test()

            let c = CALL_CONSTRAINT(types());

            Assert.is_false(c.try_discharge(ERROR()));
        si

        // Conservative-rejection axis 3: placeholder candidate.
        // We can't determine callability of a not-yet-resolved
        // placeholder; defer.
        Calling__try_discharge__on_an_inferred_variable_type_candidate__should_return_false() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let placeholder = INFERRED_VARIABLE_TYPE(origin);
            let c = CALL_CONSTRAINT(types());

            Assert.is_false(c.try_discharge(placeholder));
        si

        // Captured args containing a placeholder defer discharge.
        // The discharge can flip to true later — once the
        // iteration resolves the captured-arg placeholder — but
        // on the current tick the constraint says "not yet".
        // Pinning so a future optimisation can't shortcut by
        // treating placeholder args as universally compatible.
        Calling__try_discharge__when_a_captured_arg_is_a_placeholder__should_return_false() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let placeholder_arg = INFERRED_VARIABLE_TYPE(origin);
            let c = CALL_CONSTRAINT(types(placeholder_arg));

            // Candidate is a concrete int — irrelevant; the
            // constraint bails on the placeholder ARG, not on
            // the candidate.
            let int_class = CLASS(loc(), loc(), null, "int", empty_names(), false, null);

            Assert.is_false(c.try_discharge(int_class.type));
        si

        // Non-function candidate: discharge false. A class type
        // with no special function shape isn't callable. Pinned
        // because a regression that accepted "has invoke member"
        // instead of strictly Function/Action would let user-
        // defined classes resolve as placeholders for callable
        // sites — confusing behaviour even when ghūl supports it
        // in principle.
        Calling__try_discharge__on_a_non_function_class_type__should_return_false() is
            @test()

            let k = CLASS(loc(), loc(), null, "Empty", empty_names(), false, null);
            let c = CALL_CONSTRAINT(types());

            Assert.is_false(c.try_discharge(k.type));
        si

        // Equality + hash. Two CALL_CONSTRAINTs with structurally-
        // equal captured argument lists collide so the SET
        // accumulator on Variable folds re-emissions from re-walks.
        // Two with different arity or different arg types stay
        // distinct.
        Two__CALL_CONSTRAINT__instances_with_same_empty_args__should_be_equal() is
            @test()

            let a = CALL_CONSTRAINT(types());
            let b = CALL_CONSTRAINT(types());

            Assert.is_true(a.equals(b));
            Assert.are_equal(a.get_hash_code(), b.get_hash_code());
        si

        Two__CALL_CONSTRAINT__instances_with_different_arity__should_not_be_equal() is
            @test()

            let int_class = CLASS(loc(), loc(), null, "int", empty_names(), false, null);
            let int_t = int_class.type;

            let a = CALL_CONSTRAINT(types(int_t));
            let b = CALL_CONSTRAINT(types(int_t, int_t));

            Assert.is_false(a.equals(b));
        si

        A__CALL_CONSTRAINT__should_not_be_equal_to_a_MEMBER_CONSTRAINT() is
            @test()

            let a = CALL_CONSTRAINT(types());
            let b = MEMBER_CONSTRAINT("invoke");

            Assert.is_false(a.equals(b));
            Assert.is_false(b.equals(a));
        si

        A__CALL_CONSTRAINT__should_not_be_equal_to_a_base_Constraint() is
            @test()

            let a = CALL_CONSTRAINT(types());
            let b = Constraint();

            Assert.is_false(a.equals(b));
            Assert.is_false(b.equals(a));
        si

        Calling__equals__with_null_other__should_return_false() is
            @test()

            let a = CALL_CONSTRAINT(types());

            Assert.is_false(a.equals(null));
        si
    si
si
