namespace Semantic.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    use Semantic.Types.Type;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Symbols.INSTANCE_METHOD;
    use Semantic.Symbols.FUNCTION_GROUP;

    class OVERLOAD_RESOLVER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        // Regression: OVERLOAD_RESOLVER._resolve must tolerate a null actual
        // argument type. In analysis mode an expression's type can still be
        // unresolved when overload resolution runs (e.g. resolving `==` on the
        // result of calling a function destructured from a tuple whose element
        // type was inferred), so a null reaches the actual-argument list even
        // though its element type is not declared optional. Resolution used to
        // dereference the null; resolve() caught the resulting exception, logged
        // it and returned null.
        Resolving_a_group_with_a_null_actual_argument_type_should_not_throw() is
            @test()

            let owner = CLASS(loc(), loc(), null, "Owner", names_for(["T"]), false, null);
            let t = CLASSY_GENERIC_ARGUMENT(loc(), owner, "T", 0);

            let foo = INSTANCE_METHOD(loc(), loc(), owner, "foo", null);
            let foo_arguments = LIST[Type]();
            foo_arguments.add(t.type!);
            foo.arguments = foo_arguments;

            let group = FUNCTION_GROUP(loc(), null, "foo");
            group.add(foo);

            // A single null actual argument type — the analysis-mode reality
            // the strict-optional List[Type] element type does not express.
            let arguments = LIST[Type]();
            arguments.add(cast Type(null));

            let logger = DIAGNOSTICS_STORE();
            let resolver = OVERLOAD_RESOLVER(logger);

            resolver.resolve(loc(), group, arguments, false, true, false);

            // resolve() swallows any exception from _resolve into a null result
            // plus a logged EXCEPTION diagnostic; a clean run logs nothing.
            Assert.are_equal(
                0,
                logger.error_count,
                "overload resolution logged a diagnostic — the null actual argument type was not tolerated"
            );
        si
    si
si
