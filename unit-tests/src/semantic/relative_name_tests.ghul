namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use NSubstitute;
    use NSubstitute.SubstituteExtensions.returns;

    use Source.LOCATION;

    use Semantic.Scope;
    use Semantic.RELATIVE_NAME;

    use Semantic.Symbols.Symbol;
    use Semantic.Symbols.NAMESPACE;
    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INSTANCE_METHOD;
    use Semantic.Symbols.GLOBAL_FUNCTION;
    use Semantic.Symbols.LABEL;

    // Exercises the RELATIVE_NAME rendering rule branch by branch.
    //
    // The render scope is stubbed: `find_enclosing` is the only thing the
    // rule asks of it, so a substitute that resolves a chosen name back to
    // a chosen symbol models exactly "this name is in scope here" — the
    // same signal a real scope produces for an in-scope declaration or a
    // `use` import. The symbols under test are real, so their owner chain,
    // name, and qualified_name are the genuine article.
    class RELATIVE_NAME_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // A real namespace `Semantic.Symbols`. The stored qualified_name
        // carries the leading-dot sentinel that NAMESPACE.qualify strips.
        symbols_namespace() -> NAMESPACE =>
            NAMESPACE(loc(), "Symbols", null, ".Semantic.Symbols", false);

        a_class(owner: Scope) -> CLASS =>
            CLASS(loc(), loc(), owner, "INSTANCE_METHOD", empty_names(), false, null);

        // A scope that resolves nothing — models a render position from
        // which the target is not visible.
        empty_scope() -> Scope =>
            Substitute.`for`[Scope](System.Array.empty`[object]());

        // A scope in which `name` resolves back to `symbol`.
        scope_resolving(name: string, symbol: Symbol) -> Scope is
            let scope = Substitute.`for`[Scope](System.Array.empty`[object]());
            returns(scope.find_enclosing(name), symbol, null);
            return scope;
        si

        Calling__name_for__with_null_scope__returns_qualified_name() is
            @test()

            let c = a_class(symbols_namespace());

            Assert.are_equal(c.qualified_name, RELATIVE_NAME().name_for(c, null));
        si

        Calling__name_for__on_in_scope_type__returns_bare_name() is
            @test()

            let c = a_class(symbols_namespace());

            Assert.are_equal("INSTANCE_METHOD", RELATIVE_NAME().name_for(c, scope_resolving("INSTANCE_METHOD", c)));
        si

        Calling__name_for__on_out_of_scope_type__returns_full_namespace() is
            @test()

            let c = a_class(symbols_namespace());

            Assert.are_equal("Semantic.Symbols.INSTANCE_METHOD", RELATIVE_NAME().name_for(c, empty_scope()));
        si

        Calling__name_for__on_member_with_in_scope_owner__returns_type_dot_member() is
            @test()

            let c = a_class(symbols_namespace());
            let m = INSTANCE_METHOD(loc(), loc(), c, "describe", null);

            Assert.are_equal("INSTANCE_METHOD.describe", RELATIVE_NAME().name_for(m, scope_resolving("INSTANCE_METHOD", c)));
        si

        Calling__name_for__on_member_with_out_of_scope_owner__returns_full_path() is
            @test()

            let c = a_class(symbols_namespace());
            let m = INSTANCE_METHOD(loc(), loc(), c, "describe", null);

            Assert.are_equal("Semantic.Symbols.INSTANCE_METHOD.describe", RELATIVE_NAME().name_for(m, empty_scope()));
        si

        Calling__name_for__on_in_scope_global__returns_bare_name() is
            @test()

            let g = GLOBAL_FUNCTION(loc(), loc(), symbols_namespace(), "write_line", null);

            Assert.are_equal("write_line", RELATIVE_NAME().name_for(g, scope_resolving("write_line", g)));
        si

        Calling__name_for__on_out_of_scope_global__returns_full_namespace() is
            @test()

            let g = GLOBAL_FUNCTION(loc(), loc(), symbols_namespace(), "write_line", null);

            Assert.are_equal("Semantic.Symbols.write_line", RELATIVE_NAME().name_for(g, empty_scope()));
        si

        // A symbol owned by a function (local, parameter, or label) is
        // always bare — its owner is neither a type nor a namespace.
        Calling__name_for__on_function_owned_symbol__returns_bare_name() is
            @test()

            let c = a_class(symbols_namespace());
            let m = INSTANCE_METHOD(loc(), loc(), c, "describe", null);
            let label = LABEL(loc(), m, "loop");

            Assert.are_equal("loop", RELATIVE_NAME().name_for(label, empty_scope()));
        si
    si
si
