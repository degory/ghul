namespace Semantic.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    use IR.VALUE_BOXER;

    use Semantic.FUNCTION_CALLER;
    use Semantic.OWNER_CONSTRAINT_SPECIALIZER;
    use Semantic.SYMBOL_TABLE;
    use Semantic.TYPE_ARG_PLACEHOLDER_REGISTRY;
    use Semantic.UNIT_VARIANT_CONSTRUCTOR;

    use Semantic.Symbols.UNION;
    use Semantic.Symbols.VARIANT;

    use Syntax.Trees.Node;

    // Tests for UNIT_VARIANT_CONSTRUCTOR — the helper that lowers a
    // bare unit-variant reference (`Color.RED`, `Option.NONE`) to a
    // NEW pointing at the singleton instance the existing interning
    // path emits as `ldsfld _instance`.
    //
    // The bail-out branches are pinned here so future refactors keep
    // the "fall back to TYPE_EXPRESSION" contract intact at each
    // gate. The positive paths (the constraint-driven specialization
    // and the phantom-placeholder install) are exercised end-to-end
    // by `integration-tests/execution/union-unit-variant-bare`,
    // which checks reference identity against the interned singleton
    // and pins the type-argument-inference flow through the variable
    // initializer and function-argument slots.
    class UNIT_VARIANT_CONSTRUCTOR_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // Construct a helper that's safe to invoke on every bail-out
        // path. The function caller's value_boxer / call_constructor
        // never run on these — try_load returns before reaching them
        // when the variant is null / has fields / has no init group.
        build_constructor() -> UNIT_VARIANT_CONSTRUCTOR is
            let logger = DIAGNOSTICS_STORE();
            let symbol_table = SYMBOL_TABLE(logger);
            let value_boxer = VALUE_BOXER(logger);
            let function_caller = FUNCTION_CALLER(symbol_table, value_boxer);
            let owner_constraint_specializer = OWNER_CONSTRAINT_SPECIALIZER();
            let placeholder_registry = TYPE_ARG_PLACEHOLDER_REGISTRY(symbol_table);

            return UNIT_VARIANT_CONSTRUCTOR(owner_constraint_specializer, placeholder_registry, function_caller);
        si

        // Null variant → null. The call sites check the resolved
        // symbol's `is_variant` predicate before calling try_load, but
        // pin the no-op anyway: the helper must not NRE if a caller
        // ever forgets the guard.
        Calling__try_load__with_null_variant__returns_null() is
            @test()

            let lowerer = build_constructor();
            let key = Node(loc());

            let result = lowerer.try_load(loc(), null, null, key);

            Assert.is_null(result);
        si

        // A variant with at least one field is NOT a unit variant —
        // its `()` constructor takes arguments and must route through
        // the standard resolve_constructor path. The caller falls
        // back to TYPE_EXPRESSION on a null return.
        Calling__try_load__on_a_non_unit_variant__returns_null() is
            @test()

            let leaf = VARIANT(loc(), loc(), null, "LEAF", empty_names(), false, null);
            leaf.register_reflected_field_name("value");

            Assert.is_false(leaf.is_unit_variant);

            let lowerer = build_constructor();
            let key = Node(loc());

            let result = lowerer.try_load(loc(), leaf, null, key);

            Assert.is_null(result);
        si

        // No `init` group declared on the variant → null. The
        // production-time `init` declaration is what makes this code
        // path workable; if it's missing (a malformed source tree),
        // fall back to TYPE_EXPRESSION rather than emit a malformed
        // NEW.
        Calling__try_load__on_a_unit_variant_with_no_init__returns_null() is
            @test()

            let red = VARIANT(loc(), loc(), null, "RED", empty_names(), false, null);
            Assert.is_true(red.is_unit_variant);

            let lowerer = build_constructor();
            let key = Node(loc());

            let result = lowerer.try_load(loc(), red, null, key);

            Assert.is_null(result);
        si
    si
si
