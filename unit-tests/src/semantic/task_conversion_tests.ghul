namespace Semantic.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Lookups.InnateSymbolLookup;
    use Semantic.TASK_CONVERSION;

    use Semantic.Symbols.CLASS;

    use Semantic.Types.Type;

    // Pins for TASK_CONVERSION.try_get_task_element_type — the
    // predicate compile-lambdas now uses to recognise a slot
    // expecting `Tasks.TASK[T]` and flip the inferred-return wrap on.
    // The wrap mechanism itself is exercised end-to-end by the
    // integration tests under
    // `integration-tests/execution/async-lambda-task-slot-wrap` and
    // `async-return-wrap-*`; this fixture pins the predicate's
    // contract against a stand-in InnateSymbolLookup so changes to
    // the underlying Task-detection shape can't silently break the
    // wrap gate.
    class TASK_CONVERSION_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();
        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        types(values: Iterable[Type]) -> LIST[Type] is
            let result = LIST[Type]();
            for v in values do result.add(v); od
            return result;
        si

        // Build a CLASS playing the role of the open-generic
        // `System.Threading.Tasks.Task`1` — single type parameter,
        // referred to by its symbol identity from inside
        // `try_get_task_element_type`.
        build_task_class() -> CLASS =>
            CLASS(loc(), loc(), null, "Task", names_for(["T"]), false, null);

        int_class() -> CLASS => CLASS(loc(), loc(), null, "int", empty_names(), false, null);
        string_class() -> CLASS => CLASS(loc(), loc(), null, "string", empty_names(), false, null);

        // Constructed Task[T] over the supplied element type, using
        // the same Task class symbol that the stub lookup will hand
        // back from `get_unspecialized_task_type` — the predicate
        // compares the underlying classy by reference identity.
        constructed_task(task: CLASS, element: Type) -> Semantic.Types.GENERIC =>
            Semantic.Types.GENERIC(loc(), task, types([element]));

        // === Task[T] -> T ===

        Calling__try_get_task_element_type__with_constructed_task_int__returns_int() is
            @test()

            let task = build_task_class();
            let int_t = int_class().type;
            let task_of_int = constructed_task(task, int_t);

            let lookup = STUB_TASK_LOOKUP(constructed_task(task, int_class().type));
            let conversion = TASK_CONVERSION(lookup);

            Assert.are_same(int_t, conversion.try_get_task_element_type(task_of_int));
        si

        // === non-Task generic returns null ===
        //
        // Same construction shape but a different underlying classy
        // symbol — the predicate must reject by symbol identity, not
        // by name, arity, or generic-ness.
        Calling__try_get_task_element_type__with_unrelated_generic__returns_null() is
            @test()

            let task = build_task_class();
            let other = CLASS(loc(), loc(), null, "Other", names_for(["T"]), false, null);
            let int_t = int_class().type;

            let lookup = STUB_TASK_LOOKUP(constructed_task(task, int_class().type));
            let conversion = TASK_CONVERSION(lookup);

            Assert.is_null(conversion.try_get_task_element_type(constructed_task(other, int_t)));
        si

        // === non-generic type returns null ===

        Calling__try_get_task_element_type__with_non_generic_type__returns_null() is
            @test()

            let task = build_task_class();
            let int_t = int_class().type;

            let lookup = STUB_TASK_LOOKUP(constructed_task(task, int_class().type));
            let conversion = TASK_CONVERSION(lookup);

            Assert.is_null(conversion.try_get_task_element_type(int_t));
        si

        // === null guard ===

        Calling__try_get_task_element_type__with_null_type__returns_null() is
            @test()

            let task = build_task_class();

            let lookup = STUB_TASK_LOOKUP(constructed_task(task, int_class().type));
            let conversion = TASK_CONVERSION(lookup);

            Assert.is_null(conversion.try_get_task_element_type(null));
        si

        // === lookup with no Task type returns null ===
        //
        // Bootstrap / stubs-source builds (`get_unspecialized_task_type
        // -> Type?` is optional) leave the predicate disabled — every
        // call returns null so the wrap stays off.
        Calling__try_get_task_element_type__with_absent_unspecialized_task__returns_null() is
            @test()

            let task = build_task_class();
            let int_t = int_class().type;
            let task_of_int = constructed_task(task, int_t);

            let lookup = STUB_TASK_LOOKUP(null);
            let conversion = TASK_CONVERSION(lookup);

            Assert.is_null(conversion.try_get_task_element_type(task_of_int));
        si
    si

    // Stand-in InnateSymbolLookup for TASK_CONVERSION tests. Only
    // `get_unspecialized_task_type` is consumed by the predicate
    // under test; every other member stays abstract.
    class STUB_TASK_LOOKUP: InnateSymbolLookup is
        _unspecialized_task: Type?;

        init(unspecialized_task: Type?) is
            super.init();

            _unspecialized_task = unspecialized_task;
        si

        get_enum_type() -> Type;
        get_tuple_type(types: Collections.List[Type], names: Collections.List[string]) -> Type;
        get_function_type(types: Collections.List[Type]) -> Type;
        get_array_type(type: Type) -> Type;
        get_optional_type(type: Type) -> Type;
        get_maybe_type(type: Type) -> Type? => null;
        get_pointer_type(type: Type) -> Type;
        get_reference_type(type: Type) -> Type;
        get_bool_type() -> Type;
        get_char_type() -> Type;
        get_byte_type() -> Type;
        get_ubyte_type() -> Type;
        get_short_type() -> Type;
        get_ushort_type() -> Type;
        get_int_type() -> Type;
        get_uint_type() -> Type;
        get_long_type() -> Type;
        get_ulong_type() -> Type;
        get_word_type() -> Type;
        get_uword_type() -> Type;
        get_single_type() -> Type;
        get_double_type() -> Type;
        get_decimal_type() -> Type;
        get_void_type() -> Type;
        get_object_type() -> Type;
        get_value_type() -> Type;
        get_string_type() -> Type;
        get_exception_type() -> Type;
        get_type_type() -> Type;
        get_unspecialized_iterable_type() -> Type;
        get_unspecialized_iterator_type() -> Type;
        get_unspecialized_pipe_type() -> Type?;
        get_unspecialized_task_type() -> Type? => _unspecialized_task;
        get_unspecialized_async_task_method_builder_type() -> Type?;
        get_unspecialized_task_awaiter_type() -> Type?;
        get_interpolated_string_handler_type() -> Type;
        get_idisposable_type() -> Type;
        get_box_type(type: Type) -> Type;
        get_task_type(type: Type) -> Type?;
        get_void_task_type() -> Type?;
        get_async_task_method_builder_type(type: Type) -> Type?;
        get_async_task_method_builder_void_type() -> Type?;
        get_async_state_machine_interface_type() -> Type?;
        get_task_awaiter_type(type: Type) -> Type?;
        get_task_awaiter_void_type() -> Type?;
    si
si
