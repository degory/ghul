namespace Semantic.Symbols.UnitTests is
    use System.Text.StringBuilder;

    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    // Pins the IL contract of STATIC_CONSTRUCTOR — the symbol produced for
    // `init() static`. It must render as the CLR's `.cctor` (not the
    // instance `.ctor`) with the type-initializer flag shape, and report
    // is_static_constructor so overload resolution and the beforefieldinit
    // decision can exclude / react to it.
    class STATIC_CONSTRUCTOR_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        static_constructor() -> STATIC_CONSTRUCTOR is
            let owner = CLASS(loc(), loc(), null, "OWNER", LIST[string](), false, null);
            return STATIC_CONSTRUCTOR(loc(), loc(), owner, "init", null);
        si

        A_static_constructor_reports_is_static_constructor() is
            @test()

            Assert.is_true(static_constructor().is_static_constructor);
        si

        A_static_constructor_is_not_an_instance_constructor() is
            @test()

            // is_constructor keys on the `.ctor` IL name; a static
            // constructor is `.cctor`, so it must read false — the guard
            // that keeps it out of the instance-construction path.
            Assert.is_false(static_constructor().is_constructor);
        si

        A_static_constructor_renders_as_cctor() is
            @test()

            Assert.are_equal("'.cctor'", static_constructor().il_name);
        si

        A_static_constructor_emits_type_initializer_flags() is
            @test()

            let buffer = StringBuilder();
            static_constructor().gen_flags(buffer);

            Assert.are_equal("hidebysig specialname rtspecialname static ", buffer.to_string());
        si

        A_static_constructor_emits_private_access() is
            @test()

            let buffer = StringBuilder();
            static_constructor().gen_access(buffer);

            Assert.are_equal("private ", buffer.to_string());
        si
    si
si
