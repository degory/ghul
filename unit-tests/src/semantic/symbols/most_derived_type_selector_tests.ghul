namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;

    // Tests for MOST_DERIVED_TYPE_SELECTOR — given a set of types expected
    // to form a single subtype chain (as covariantly-redeclared interface
    // members do), it returns the index of the most-derived one, or -1 when
    // they don't form a chain.
    class MOST_DERIVED_TYPE_SELECTOR_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // A tiny hierarchy: object <- animal <- cat, plus a sibling plant.
        build_hierarchy() -> (object_class: CLASS, animal: CLASS, cat: CLASS, plant: CLASS) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let animal = CLASS(loc(), loc(), null, "animal", empty_names(), false, null);
            animal.add_ancestor(object_class.type!);

            let cat = CLASS(loc(), loc(), null, "cat", empty_names(), false, null);
            cat.add_ancestor(animal.type!);

            let plant = CLASS(loc(), loc(), null, "plant", empty_names(), false, null);
            plant.add_ancestor(object_class.type!);

            return (object_class, animal, cat, plant);
        si

        types(values: Collections.Iterable[Type?]) -> LIST[Type?] is
            let result = LIST[Type?]();
            for v in values do result.add(v); od
            return result;
        si

        Selecting_from_an_empty_set_returns_minus_one() is
            @test()
            Assert.are_equal(-1, MOST_DERIVED_TYPE_SELECTOR().select(LIST[Type?]()));
        si

        Selecting_from_a_single_type_returns_its_index() is
            @test()
            let h = build_hierarchy();
            Assert.are_equal(0, MOST_DERIVED_TYPE_SELECTOR().select(types([h.cat.type])));
        si

        Selecting_a_chain_returns_the_most_derived_regardless_of_order() is
            @test()
            let h = build_hierarchy();

            Assert.are_equal(
                2,
                MOST_DERIVED_TYPE_SELECTOR().select(types([h.object_class.type, h.animal.type, h.cat.type]))
            );

            Assert.are_equal(
                0,
                MOST_DERIVED_TYPE_SELECTOR().select(types([h.cat.type, h.animal.type, h.object_class.type]))
            );
        si

        Selecting_when_the_same_type_repeats_returns_a_valid_index() is
            @test()
            let h = build_hierarchy();
            Assert.are_equal(0, MOST_DERIVED_TYPE_SELECTOR().select(types([h.cat.type, h.cat.type])));
        si

        Selecting_from_sibling_types_returns_minus_one() is
            @test()
            let h = build_hierarchy();
            Assert.are_equal(-1, MOST_DERIVED_TYPE_SELECTOR().select(types([h.cat.type, h.plant.type])));
        si

        Selecting_with_a_sibling_alongside_a_chain_returns_minus_one() is
            @test()
            let h = build_hierarchy();
            Assert.are_equal(
                -1,
                MOST_DERIVED_TYPE_SELECTOR().select(types([h.animal.type, h.cat.type, h.plant.type]))
            );
        si
    si
si
