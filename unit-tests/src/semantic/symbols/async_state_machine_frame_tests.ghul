namespace Semantic.Symbols.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    // A value-async lambda whose inferred return type hasn't pinned
    // yet constructs its frame with a null result type, and declare()
    // returns early until ensure_result_field fills the type in. The
    // argument and awaiter field lists must still be usable in that
    // window — await emission can ask for an awaiter slot without a
    // completed declare() run.
    class ASYNC_STATE_MACHINE_FRAME_TESTS is
        @test()

        init() is
            if !LOCATION.internal? then
                LOCATION.init_static();
            fi
        si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        make_frame_with_unpinned_result() -> ASYNC_STATE_MACHINE_FRAME is
            let owner = CLASS(loc(), loc(), null, "Owner", System.Array.empty[string](), false, null);
            let function = STATIC_METHOD(loc(), loc(), owner, "do_async", null);

            return ASYNC_STATE_MACHINE_FRAME(owner, function, null, false);
        si

        Constructing_a_frame_with_unpinned_result_type__should_leave_field_lists_iterable() is
            @test()

            let frame = make_frame_with_unpinned_result();

            let count mut = 0;
            for f in frame.argument_fields do
                count = count + 1;
            od
            for f in frame.awaiter_fields do
                count = count + 1;
            od

            Assert.are_equal(0, count);
        si

        Calling__declare_awaiter_field__after_declare_returned_early_on_unpinned_result__should_record_the_field() is
            @test()

            let frame = make_frame_with_unpinned_result();

            // Value-async with no result type yet: declare() waits
            // for ensure_result_field rather than declaring members.
            frame.declare();

            let awaiter_type = CLASSY_GENERIC_ARGUMENT(loc(), null, "awaiter", 0).type;

            let awaiter_field = frame.declare_awaiter_field(awaiter_type);

            Assert.is_true(awaiter_field?);

            let count mut = 0;
            let seen: Field? mut = null;
            for f in frame.awaiter_fields do
                count = count + 1;
                seen = f;
            od

            Assert.are_equal(1, count);
            Assert.are_same(awaiter_field, seen);
        si
    si
si
