namespace Semantic.Symbols.UnitTests is
    use System.Text.StringBuilder;

    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    // Tests for the IL emission of Classy's generic-argument lists.
    //
    // gen_actual_type_arguments writes a class's *own* type-parameter list
    // as `!0,!1,...` — used wherever the IL needs a self-reference to the
    // open-generic class (e.g. `class Foo`1<!0>` in field signatures of
    // generic types). gen_formal_type_arguments writes the same list as
    // single-quoted *names* (`'T','U'`) — the form required only inside
    // the `.class` directive that *declares* the generic class.
    //
    // Mixing these up — emitting names where indices belong, or vice versa
    // — produces malformed IL the runtime either rejects at load time or
    // can't resolve. These tests anchor each call site's expected output
    // shape.
    class CLASSY_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        Calling__gen_actual_type_arguments__should_emit_indexed_references_for_each_parameter() is
            @test()

            let names = names_for(["T", "U"]);
            let symbol = CLASS(loc(), loc(), null, "Test", names, false, null);
            let buffer = StringBuilder();

            symbol.gen_actual_type_arguments(buffer);

            Assert.are_equal("!0,!1", buffer.to_string());
        si

        Calling__gen_actual_type_arguments__on_single_arg_class__should_emit_one_indexed_reference() is
            @test()

            let names = names_for(["T"]);
            let symbol = CLASS(loc(), loc(), null, "Test", names, false, null);
            let buffer = StringBuilder();

            symbol.gen_actual_type_arguments(buffer);

            Assert.are_equal("!0", buffer.to_string());
        si

        Calling__gen_actual_type_arguments__on_class_with_no_args__should_emit_nothing() is
            @test()

            let names = LIST[string]();
            let symbol = CLASS(loc(), loc(), null, "Test", names, false, null);
            let buffer = StringBuilder();

            symbol.gen_actual_type_arguments(buffer);

            Assert.are_equal("", buffer.to_string());
        si

        Calling__gen_formal_type_arguments__should_emit_quoted_names() is
            @test()

            let names = names_for(["TSubject", "TAssertions"]);
            let symbol = CLASS(loc(), loc(), null, "Test", names, false, null);
            let buffer = StringBuilder();

            symbol.gen_formal_type_arguments(buffer);

            Assert.are_equal("'TSubject','TAssertions'", buffer.to_string());
        si

        is_generic__should_be_false_for_class_with_no_arguments() is
            @test()

            let names = LIST[string]();
            let symbol = CLASS(loc(), loc(), null, "Test", names, false, null);

            Assert.is_false(symbol.is_generic);
        si

        is_generic__should_be_true_for_class_with_arguments() is
            @test()

            let names = names_for(["T"]);
            let symbol = CLASS(loc(), loc(), null, "Test", names, false, null);

            Assert.is_true(symbol.is_generic);
        si

        get_argument_constraint_kind__should_be_NONE_when_no_constraint_kinds_list() is
            @test()

            let symbol = CLASS(loc(), loc(), null, "Test", names_for(["T"]), false, null);

            Assert.is_true(symbol.get_argument_constraint_kind(0) == TypeParameterConstraintKind.NONE);
        si

        get_argument_constraint_kind__should_read_the_constraint_kinds_list() is
            @test()

            let symbol = CLASS(loc(), loc(), null, "Test", names_for(["T"]), false, null);

            symbol.argument_constraint_kinds = [TypeParameterConstraintKind.VALUE];

            Assert.is_true(symbol.get_argument_constraint_kind(0) == TypeParameterConstraintKind.VALUE);
        si

        // Implicit-abstract from body-less methods. The marking
        // happens in DECLARE_SYMBOLS — the symbol-level test pins
        // that the signal flows through `is_abstract` once set.
        // The DECLARE_SYMBOLS-side exclusions (property accessors,
        // static methods, `init`) are exercised by the integration
        // tests `integration-tests/execution/concrete-class-with-
        // write-only-property` and `concrete-class-with-body-less-
        // static-method`.
        is_abstract__is_false_on_a_fresh_class_with_no_bodyless_marker() is
            @test()

            let symbol = CLASS(loc(), loc(), null, "Test", LIST[string](), false, null);

            Assert.is_false(symbol.is_abstract);
        si

        is_abstract__is_true_after_mark_has_bodyless_method() is
            @test()

            let symbol = CLASS(loc(), loc(), null, "Test", LIST[string](), false, null);
            symbol.mark_has_bodyless_method();

            Assert.is_true(symbol.is_abstract);
        si

        is_abstract__is_true_after_explicit_mark_abstract() is
            @test()

            let symbol = CLASS(loc(), loc(), null, "Test", LIST[string](), false, null);
            symbol.mark_abstract();

            Assert.is_true(symbol.is_abstract);
        si

        // is_closed_root: closed-by-default applies to ghūl-declared
        // CLASS — bare class out of the box is a closed root. Open
        // classes, traits, and structs are not. Unions are covered
        // by the union_tests fixture.
        is_closed_root__is_true_for_a_default_class() is
            @test()

            let symbol = CLASS(loc(), loc(), null, "Test", LIST[string](), false, null);

            Assert.is_true(symbol.is_closed_root);
        si

        is_closed_root__is_false_for_an_open_class() is
            @test()

            let symbol = CLASS(loc(), loc(), null, "Test", LIST[string](), false, null);
            symbol.mark_open();

            Assert.is_false(symbol.is_closed_root);
        si

        // closed_alternatives: walks _implementors, filtered to ghūl-
        // declared CLASS subclasses. Mirrors closed_subclasses (same
        // underlying mechanism) but with a polymorphic name for the
        // shared narrowing/constraint code paths.
        closed_alternatives__on_a_class_with_no_implementors__is_empty() is
            @test()

            let symbol = CLASS(loc(), loc(), null, "Test", LIST[string](), false, null);

            let count mut = 0;
            for s in symbol.closed_alternatives do
                count = count + 1;
            od

            Assert.are_equal(0, count);
        si

        closed_alternatives__on_a_class_with_subclasses__yields_them() is
            @test()

            let root = CLASS(loc(), loc(), null, "Root", LIST[string](), false, null);
            let sub_a = CLASS(loc(), loc(), null, "SubA", LIST[string](), false, null);
            let sub_b = CLASS(loc(), loc(), null, "SubB", LIST[string](), false, null);

            root.add_implementor(sub_a);
            root.add_implementor(sub_b);

            let collected = LIST[Classy]();
            for s in root.closed_alternatives do
                collected.add(s);
            od

            Assert.are_equal(2, collected.count);
        si

        // A type with an explicit static constructor must not be emitted
        // `beforefieldinit` — that flag lets the CLR run the `.cctor` at
        // an unspecified point before first static-field access, whereas
        // a user-written initializer wants to run precisely before first
        // use.
        A_class_without_a_static_constructor_is_emitted_beforefieldinit() is
            @test()

            let c = CLASS(loc(), loc(), null, "Plain", LIST[string](), false, null);

            Assert.is_false(c.has_static_constructor);

            let buffer = StringBuilder();
            c.gen_flags(buffer);

            Assert.are_equal("auto ansi beforefieldinit ", buffer.to_string());
        si

        A_class_with_a_static_constructor_drops_beforefieldinit() is
            @test()

            let c = CLASS(loc(), loc(), null, "WithCctor", LIST[string](), false, null);
            let ctor = c.declare_function(loc(), loc(), "init", true, false, true, c, null);

            Assert.is_true(ctor.is_static_constructor);
            Assert.is_true(c.has_static_constructor);

            let buffer = StringBuilder();
            c.gen_flags(buffer);

            Assert.are_equal("auto ansi ", buffer.to_string());
        si
    si
si
