namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;

    // Property.specialize must attribute the specialized clone to the
    // constructed generic it was specialized for, so a property reached
    // through BOX[arg] renders its owner with the actual type arguments
    // rather than the unspecialized head's formal parameters - the same
    // owner attribution fields and methods get when they specialize.
    class PROPERTY_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        Calling__specialize__should_attribute_the_clone_to_the_constructed_generic() is
            @test()

            // Head: a generic class BOX[T] owning a property typed T.
            let type_parameters = LIST[string]();
            type_parameters.add("T");

            let box = CLASS(loc(), loc(), null, "BOX", type_parameters, false, null);
            let t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);

            let p = INSTANCE_PROPERTY(loc(), loc(), box, "thing", false, false);
            p.set_type(t.type);

            // The constructed generic BOX[arg].
            let arg = CLASS(loc(), loc(), null, "arg", LIST[string](), false, null);

            let arguments = LIST[Type]();
            arguments.add(arg.type!);

            let constructed = GENERIC(loc(), box, arguments);

            let specialized = cast Property(p.specialize(Collections.MAP[string,Type](), constructed));

            Assert.are_same(constructed, specialized.owner);
        si
    si
si
