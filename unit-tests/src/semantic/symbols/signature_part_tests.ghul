namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Direct tests on the SIGNATURE_PART tree and the TEXT_RENDERER
    // that walks it. Each variant renders in isolation, and a full
    // WRAPPABLE-inside-SEQUENCE composition renders to the same shape
    // the pre-refactor description templates produce.
    class SIGNATURE_PART_TESTS is
        @test()

        init() is si

        render(part: SIGNATURE_PART) -> string =>
            TEXT_RENDERER(DESCRIBE_CONTEXT.instance).render(part);

        literal_renders_verbatim() is
            @test()

            Assert.are_equal("class ", render(SIGNATURE_PART.LITERAL("class ")));
        si

        nil_renders_as_empty_string() is
            @test()

            Assert.are_equal("", render(SIGNATURE_PART.NIL()));
        si

        sequence_concatenates_children() is
            @test()

            let parts = LIST[SIGNATURE_PART]();
            parts.add(SIGNATURE_PART.LITERAL("class "));
            parts.add(SIGNATURE_PART.LITERAL("Foo"));

            Assert.are_equal("class Foo", render(SIGNATURE_PART.SEQUENCE(parts)));
        si

        // WRAPPABLE flat form: open + items joined by the exact
        // separator + close.
        wrappable_flattens_with_the_exact_separator() is
            @test()

            let items = LIST[SIGNATURE_PART]();
            items.add(SIGNATURE_PART.LITERAL("a: int"));
            items.add(SIGNATURE_PART.LITERAL("b: string"));

            Assert.are_equal(
                "(a: int, b: string)",
                render(SIGNATURE_PART.WRAPPABLE("(", ",", false, ")", items))
            );
        si

        // Zero items → open + close directly, no separator.
        wrappable_with_no_items_renders_empty() is
            @test()

            let items = LIST[SIGNATURE_PART]();

            Assert.are_equal(
                "()",
                render(SIGNATURE_PART.WRAPPABLE("(", ",", false, ")", items))
            );
        si

        // Compact separator for generic-argument brackets — no space.
        wrappable_supports_no_space_separator_for_generic_brackets() is
            @test()

            let items = LIST[SIGNATURE_PART]();
            items.add(SIGNATURE_PART.LITERAL("T"));
            items.add(SIGNATURE_PART.LITERAL("U"));

            Assert.are_equal(
                "[T,U]",
                render(SIGNATURE_PART.WRAPPABLE("[", ",", true, "]", items))
            );
        si

        // Composition — the shape of a Function description with
        // literal-only parts as a stand-in for NAME/TYPE_REF.
        composed_signature_renders_flat() is
            @test()

            let args = LIST[SIGNATURE_PART]();
            args.add(SIGNATURE_PART.LITERAL("x: int"));
            args.add(SIGNATURE_PART.LITERAL("y: int"));

            let parts = LIST[SIGNATURE_PART]();
            parts.add(SIGNATURE_PART.LITERAL("Foo.bar"));
            parts.add(SIGNATURE_PART.WRAPPABLE("(", ",", false, ")", args));
            parts.add(SIGNATURE_PART.LITERAL(" -> int // instance method"));

            Assert.are_equal(
                "Foo.bar(x: int, y: int) -> int // instance method",
                render(SIGNATURE_PART.SEQUENCE(parts))
            );
        si
    si
si
