namespace Semantic.Symbols.UnitTests is
    use System.Text.StringBuilder;

    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;

    // Tests for Field.gen_reference — the fieldref emitter that bug #987
    // also depended on. Like Function.gen_actual_arguments_list, it prefers
    // `unspecialized_type` over `type` when both are populated, so that the
    // open-generic form (e.g. `!0`) reaches the IL even though `type`
    // carries the substituted concrete type. These tests pin that
    // preference; without it, fieldref signatures from inherited fields on
    // a constructed-generic base regress to the buggy substituted form.
    class FIELD_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        Calling__gen_reference__should_use_type_when_no_unspecialized_set() is
            @test()

            // Owner: a non-generic class (so its self-reference is just `class Test`).
            let owner = CLASS(loc(), loc(), null, "Test", empty_names(), false, null);

            // Field type: a class generic argument that emits `!0`.
            let t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);

            let f = INSTANCE_FIELD(loc(), owner, "thing");
            f.set_type(t.type);

            let buffer = StringBuilder();
            f.gen_reference(buffer);

            // Format: <type> <owner> :: <name>. Owner emission is exercised
            // here; what matters for the regression is that the field type
            // came from `type` (`!0`) and not anywhere else.
            Assert.is_true(buffer.to_string().contains("!0"));
            Assert.is_true(buffer.to_string().contains("'thing'"));
        si

        Calling__gen_reference__should_prefer_unspecialized_type_when_both_are_set() is
            @test()

            let owner = CLASS(loc(), loc(), null, "Test", empty_names(), false, null);

            // Open form on `unspecialized_type`: `!0`.
            let open_t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);

            // Distinct symbol on `type` — so we can tell which one was emitted.
            let sub_a = CLASSY_GENERIC_ARGUMENT(loc(), null, "A", 5);

            let f = INSTANCE_FIELD(loc(), owner, "thing");
            f.set_type(sub_a.type);
            f.unspecialized_type = open_t.type;

            let buffer = StringBuilder();
            f.gen_reference(buffer);

            // With the preference: `!0` (from open_t). Without: `!5` (from sub_a).
            Assert.is_true(buffer.to_string().contains("!0"));
            Assert.is_false(buffer.to_string().contains("!5"));
        si

        Calling__specialize__should_record_pre_specialize_type_as_unspecialized() is
            @test()

            let owner = CLASS(loc(), loc(), null, "Test", empty_names(), false, null);
            let t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);

            let f = INSTANCE_FIELD(loc(), owner, "thing");
            f.set_type(t.type);

            // Empty type_map — substitution is a no-op for the type, but
            // specialize() should still copy the original type into
            // unspecialized_type so later lookups via gen_reference pick up
            // the open form (the contract Field.gen_reference depends on).
            let empty_map = Collections.MAP[string,Type]();
            let specialized = cast Field(f.specialize(empty_map, null));

            Assert.are_same(t.type, specialized.unspecialized_type);
        si
    si
si
