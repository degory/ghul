namespace Semantic.Symbols.UnitTests is
    use System.Text.StringBuilder;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    // Tests for the IL emission of generic-parameter symbols.
    //
    // CLASSY_GENERIC_ARGUMENT.gen_type and FUNCTION_GENERIC_ARGUMENT.gen_type
    // are the foundation for every methodref / fieldref signature that names
    // an enclosing class- or method-level type parameter. Issue #987 was
    // ultimately a failure to *reach* this code (the loader was supplying
    // substituted concrete types instead of these parameter symbols), so
    // anchoring their behaviour in unit tests means a future regression in
    // either the emitter or its preferred inputs is caught immediately.
    class GENERIC_ARGUMENT_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        Calling__gen_type__on_classy_generic_argument__should_emit_indexed_class_reference() is
            @test()

            let symbol = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let buffer = StringBuilder();

            symbol.gen_type(buffer);

            Assert.are_equal("!0 ", buffer.to_string());
        si

        Calling__gen_type__on_classy_generic_argument__should_use_the_provided_index() is
            @test()

            let symbol = CLASSY_GENERIC_ARGUMENT(loc(), null, "U", 7);
            let buffer = StringBuilder();

            symbol.gen_type(buffer);

            Assert.are_equal("!7 ", buffer.to_string());
        si

        Calling__gen_type__on_function_generic_argument__should_emit_double_bang_indexed_reference() is
            @test()

            let symbol = FUNCTION_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let buffer = StringBuilder();

            symbol.gen_type(buffer);

            Assert.are_equal("!!0 ", buffer.to_string());
        si

        Calling__gen_type__on_function_generic_argument__should_use_the_provided_index() is
            @test()

            let symbol = FUNCTION_GENERIC_ARGUMENT(loc(), null, "TResult", 3);
            let buffer = StringBuilder();

            symbol.gen_type(buffer);

            Assert.are_equal("!!3 ", buffer.to_string());
        si

        Setting__gen_type_override__on_classy_generic_argument__should_redirect_emission() is
            @test()

            let symbol = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let buffer = StringBuilder();

            symbol.gen_type_override((s, b) is b.append("OVERRIDDEN"); si);
            symbol.gen_type(buffer);

            Assert.are_equal("OVERRIDDEN", buffer.to_string());
        si

        Setting__gen_type_override__on_function_generic_argument__should_redirect_emission() is
            @test()

            let symbol = FUNCTION_GENERIC_ARGUMENT(loc(), null, "TResult", 0);
            let buffer = StringBuilder();

            symbol.gen_type_override((s, b) is b.append("OVERRIDDEN"); si);
            symbol.gen_type(buffer);

            Assert.are_equal("OVERRIDDEN", buffer.to_string());
        si

        Clearing__gen_type_override__should_restore_indexed_emission() is
            @test()

            let symbol = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 2);
            let buffer = StringBuilder();

            symbol.gen_type_override((s, b) is b.append("X"); si);
            symbol.gen_type_override(null);
            symbol.gen_type(buffer);

            Assert.are_equal("!2 ", buffer.to_string());
        si
    si
si
