namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Closure;
    use Semantic.Symbols.Field;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.LOCAL_VARIABLE;
    use Semantic.Symbols.Symbol;

    use Semantic.Types.ERROR;
    use Semantic.Types.GENERIC;
    use Semantic.Types.INFERRED_VARIABLE_TYPE;
    use Semantic.Types.Type;

    // Pins the predicate that drives `Closure.find_or_add_capture`'s
    // re-capture refresh — the gate that fixed the curried-lambda
    // back-propagation case where a captured field stayed pinned to
    // its first-iteration `INFERRED_VARIABLE_TYPE` even after the
    // source resolved to `Function[T,U]`. The contract:
    //
    //   - source-side: source.type is non-null, non-sentinel; for a
    //     LOCAL_VARIABLE source, is_defined must be true.
    //   - existing-side: the field's recorded type is either null or
    //     not yet `is_settled`.
    //
    // The body-retry loop relies on this firing the moment the source
    // shape becomes usable, even with inner generic slots still
    // un-resolved (`Function[placeholder, int]` qualifies). Without
    // this, curried `f => x => f(f(x))` shapes don't converge.
    class CLOSURE_REFRESH_CAPTURE_TESTS is
        @test()

        init() is
            // LOCAL_VARIABLE's init reads IoC.CONTAINER.instance.local_id_generator;
            // ensure it's wired up with a function-id-stack frame so the
            // id allocator works.
            if !IoC.CONTAINER.instance.local_id_generator? then
                IoC.CONTAINER.instance.local_id_generator = IR.LOCAL_ID_GENERATOR();
            fi
            IoC.CONTAINER.instance.local_id_generator.enter_function();
        si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        // A bare CLASS suffices as the owning Classy for an INSTANCE_FIELD
        // — find_or_add_capture's refresh path doesn't read class state.
        owner_class() -> CLASS =>
            CLASS(loc(), loc(), null, "Owner", System.Array.empty[string](), false, null);

        // Field whose recorded type we'll observe. The existing field's
        // type can be set or left null — both feed the predicate.
        make_field(name: string, recorded_type: Type) -> Field is
            let `field = INSTANCE_FIELD(loc(), owner_class(), name);
            if recorded_type? then
                `field.set_type(recorded_type);
            fi
            return `field;
        si

        // LOCAL_VARIABLE source — needs is_defined toggling to exercise
        // the forward-self-reference gate.
        make_local(name: string, source_type: Type, is_defined: bool) -> LOCAL_VARIABLE is
            let v = LOCAL_VARIABLE(loc(), owner_class(), name);
            v.set_type(source_type);
            v.is_defined = is_defined;
            return v;
        si

        placeholder_for(v: LOCAL_VARIABLE) -> Type => INFERRED_VARIABLE_TYPE(v);

        concrete_named() -> Type =>
            CLASS(loc(), loc(), null, "Concrete", System.Array.empty[string](), false, null).type;

        // ====== source-side gates ======

        Calling__should_refresh_capture__with_null_existing__returns_false() is
            @test()

            let local = make_local("v", concrete_named(), true);

            Assert.is_false(Closure.should_refresh_capture(null, local));
        si

        Calling__should_refresh_capture__with_null_source__returns_false() is
            @test()

            let `field = make_field("x", null);

            Assert.is_false(Closure.should_refresh_capture(`field, null));
        si

        Calling__should_refresh_capture__with_source_lacking_type__returns_false() is
            @test()

            // LOCAL_VARIABLE before set_type has run.
            let v = LOCAL_VARIABLE(loc(), owner_class(), "v");
            v.is_defined = true;
            let `field = make_field("v", null);

            Assert.is_false(Closure.should_refresh_capture(`field, v));
        si

        Calling__should_refresh_capture__with_sentinel_source_type__returns_false() is
            @test()

            // Source still bears its first-iter placeholder; the refresh
            // gate is "source has resolved", so this must NOT fire.
            let v = make_local("v", null, true);
            v.set_type(placeholder_for(v));
            let `field = make_field("v", placeholder_for(v));

            Assert.is_false(Closure.should_refresh_capture(`field, v));
        si

        Calling__should_refresh_capture__with_local_source_not_defined__returns_false() is
            @test()

            // Forward-self-reference gate: a `let f = ... f ...` capture
            // reaches the variable before define() has run. Even with a
            // non-sentinel observed type the refresh must not fire —
            // otherwise the user-visible "unresolved return type"
            // diagnostic is silently masked.
            let v = make_local("f", concrete_named(), false);
            let `field = make_field("f", placeholder_for(v));

            Assert.is_false(Closure.should_refresh_capture(`field, v));
        si

        // ====== existing-side gates ======

        Calling__should_refresh_capture__with_settled_existing_type__returns_false() is
            @test()

            // The field already holds a fully-resolved type. Re-running
            // refresh would clobber valid IL-stable state with whatever
            // the source currently reports.
            let v = make_local("v", concrete_named(), true);
            let `field = make_field("v", concrete_named());

            Assert.is_false(Closure.should_refresh_capture(`field, v));
        si

        // ====== happy paths ======

        Calling__should_refresh_capture__with_null_existing_type_and_ready_source__returns_true() is
            @test()

            // First-iter capture happened before the source's type was
            // installed — field.type was null. Now the source has a
            // shape, refresh installs it.
            let v = make_local("v", concrete_named(), true);
            let `field = make_field("v", null);

            Assert.is_true(Closure.should_refresh_capture(`field, v));
        si

        Calling__should_refresh_capture__with_sentinel_existing_and_ready_source__returns_true() is
            @test()

            // The canonical re-capture refresh case the curried-lambda
            // bug fix targets: the field was pinned to a placeholder
            // sentinel on first iter; the source has now resolved to a
            // real type; the second iter must replace the field's type.
            let v = make_local("v", concrete_named(), true);
            let `field = make_field("v", placeholder_for(v));

            Assert.is_true(Closure.should_refresh_capture(`field, v));
        si

        Calling__should_refresh_capture__with_composite_carrying_inner_placeholder__returns_true() is
            @test()

            // Load-bearing: the source's type is NOT fully `is_settled`
            // because an inner generic slot still holds a placeholder,
            // but the outer shape is non-sentinel. Refresh must still
            // fire so the field promotes from `INFERRED_VARIABLE_TYPE`
            // to e.g. `Box[T]` and call sites see a NAMED receiver. The
            // fix that made the curried-lambda case converge — i.e. the
            // change from `is_settled` to `!is_sentinel` on the source
            // gate. A settled type satisfies both predicates equally;
            // only a provisional composite distinguishes them.
            let v = make_local("v", null, true);
            let box_class = CLASS(loc(), loc(), null, "Box", ["T"], false, null);
            let inner_placeholder_origin = LOCAL_VARIABLE(loc(), owner_class(), "inner");
            let args = LIST[Type]();
            args.add(INFERRED_VARIABLE_TYPE(inner_placeholder_origin));
            let provisional_composite = GENERIC(loc(), box_class, args);

            Assert.is_false(provisional_composite.is_sentinel);
            Assert.is_false(provisional_composite.is_settled);

            v.set_type(provisional_composite);
            let `field = make_field("v", placeholder_for(v));

            Assert.is_true(Closure.should_refresh_capture(`field, v));
        si
    si
si
