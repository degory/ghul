namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    // Tests for GENERIC_CONSTRAINT_CHECKER — whether a type argument
    // satisfies a `class` / `struct` / `optional` kind constraint.
    // Uncheckable actuals (error types, type variables) must report
    // "satisfied" so no spurious constraint error cascades from them.
    class GENERIC_CONSTRAINT_CHECKER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        no_names() -> LIST[string] => LIST[string]();

        reference_type() -> Semantic.Types.Type =>
            CLASS(loc(), loc(), null, "RefThing", no_names(), false, null).type;

        value_type() -> Semantic.Types.Type =>
            STRUCT(loc(), loc(), null, "ValThing", no_names(), false, null).type;

        type_variable() -> Semantic.Types.Type =>
            CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0).type;

        // A reference type's `T?` form — the same NAMED carrying the
        // optional flag.
        optional_reference_type() -> Semantic.Types.Type =>
            reference_type().as_optional();

        error_type() -> Semantic.Types.Type => Semantic.Types.ERROR();

        A_class_constraint_is_satisfied_by_a_reference_type() is
            @test()
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TypeParameterConstraintKind.REFERENCE, reference_type()));
        si

        A_class_constraint_is_not_satisfied_by_a_value_type() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TypeParameterConstraintKind.REFERENCE, value_type()));
        si

        A_struct_constraint_is_satisfied_by_a_value_type() is
            @test()
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TypeParameterConstraintKind.VALUE, value_type()));
        si

        A_struct_constraint_is_not_satisfied_by_a_reference_type() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TypeParameterConstraintKind.VALUE, reference_type()));
        si

        The_unconstrained_kind_is_satisfied_by_any_type() is
            @test()
            let checker = GENERIC_CONSTRAINT_CHECKER();
            Assert.is_true(checker.is_satisfied(TypeParameterConstraintKind.NONE, reference_type()));
            Assert.is_true(checker.is_satisfied(TypeParameterConstraintKind.NONE, value_type()));
        si

        An_optional_constraint_is_satisfied_by_an_optional_type() is
            @test()
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TypeParameterConstraintKind.OPTIONAL, optional_reference_type()));
        si

        An_optional_constraint_is_not_satisfied_by_a_non_optional_reference_type() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TypeParameterConstraintKind.OPTIONAL, reference_type()));
        si

        An_optional_constraint_is_not_satisfied_by_a_non_optional_value_type() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TypeParameterConstraintKind.OPTIONAL, value_type()));
        si

        An_error_type_satisfies_any_constraint_so_no_cascade() is
            @test()
            let checker = GENERIC_CONSTRAINT_CHECKER();
            Assert.is_true(checker.is_satisfied(TypeParameterConstraintKind.REFERENCE, error_type()));
            Assert.is_true(checker.is_satisfied(TypeParameterConstraintKind.VALUE, error_type()));
            Assert.is_true(checker.is_satisfied(TypeParameterConstraintKind.OPTIONAL, error_type()));
        si

        A_type_variable_satisfies_any_constraint_being_unprovable() is
            @test()
            let checker = GENERIC_CONSTRAINT_CHECKER();
            Assert.is_true(checker.is_satisfied(TypeParameterConstraintKind.REFERENCE, type_variable()));
            Assert.is_true(checker.is_satisfied(TypeParameterConstraintKind.VALUE, type_variable()));
            Assert.is_true(checker.is_satisfied(TypeParameterConstraintKind.OPTIONAL, type_variable()));
        si

        An_imported_type_with_no_argument_type_bounds_reports_none() is
            @test()
            let owner = CLASS(loc(), loc(), null, "Holder", ["T"], false, null);
            Assert.is_null(owner.get_argument_type_bound(0));
        si

        An_imported_type_with_an_argument_type_bound_reports_it() is
            @test()
            let owner = CLASS(loc(), loc(), null, "Holder", ["T"], false, null);
            let bound = reference_type();
            owner.argument_type_bounds = [bound];
            Assert.are_same(bound, owner.get_argument_type_bound(0));
        si

        A_value_type_always_has_a_parameterless_constructor() is
            @test()
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().has_accessible_parameterless_constructor(value_type()));
        si

        A_reference_type_with_no_constructor_has_no_parameterless_constructor() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().has_accessible_parameterless_constructor(reference_type()));
        si

        A_reference_type_that_declares_a_parameterless_constructor_has_one() is
            @test()
            let the_class = CLASS(loc(), loc(), null, "HasCtor", no_names(), false, null);
            the_class.has_parameterless_constructor = true;
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().has_accessible_parameterless_constructor(the_class.type));
        si

        check_arguments_reports_a_type_argument_with_no_parameterless_constructor() is
            @test()
            let owner = CLASS(loc(), loc(), null, "Factory", ["T"], false, null);
            owner.argument_has_constructor_constraint = [true];

            let logger = DIAGNOSTICS_STORE();

            GENERIC_CONSTRAINT_CHECKER().check_arguments(loc(), logger, owner, ["T"], [reference_type()]);

            Assert.is_true(logger.any_errors);
        si

        check_arguments_accepts_a_type_argument_with_a_parameterless_constructor() is
            @test()
            let owner = CLASS(loc(), loc(), null, "Factory", ["T"], false, null);
            owner.argument_has_constructor_constraint = [true];

            let logger = DIAGNOSTICS_STORE();

            GENERIC_CONSTRAINT_CHECKER().check_arguments(loc(), logger, owner, ["T"], [value_type()]);

            Assert.is_false(logger.any_errors);
        si

        check_arguments_rejects_a_type_argument_that_does_not_satisfy_an_imported_type_bound() is
            @test()
            let owner = CLASS(loc(), loc(), null, "Holder", ["T"], false, null);
            let bound = reference_type();
            owner.argument_type_bounds = [bound];

            let logger = DIAGNOSTICS_STORE();

            GENERIC_CONSTRAINT_CHECKER().check_arguments(loc(), logger, owner, ["T"], [value_type()]);

            Assert.is_true(logger.any_errors);
        si

        check_arguments_accepts_a_type_argument_that_satisfies_an_imported_type_bound() is
            @test()
            let owner = CLASS(loc(), loc(), null, "Holder", ["T"], false, null);
            let bound = reference_type();
            owner.argument_type_bounds = [bound];

            let logger = DIAGNOSTICS_STORE();

            // Same reference_type instance — trivially assignable to itself.
            GENERIC_CONSTRAINT_CHECKER().check_arguments(loc(), logger, owner, ["T"], [bound]);

            Assert.is_false(logger.any_errors);
        si

        check_arguments_substitutes_sibling_parameter_in_a_type_bound() is
            @test()
            // Models a method like `M[TBase, TDerived](where TDerived: TBase)`.
            // The bound on TDerived references TBase by name; the checker must
            // substitute TBase → actual[0] before assigning. Passing the same
            // class for both should satisfy; a value type for TDerived should
            // not (TBase is the reference-type actual).
            let owner = CLASS(loc(), loc(), null, "Holder", ["TBase", "TDerived"], false, null);
            let tbase_var = CLASSY_GENERIC_ARGUMENT(loc(), null, "TBase", 0).type;
            let bounds = Collections.LIST[Semantic.Types.Type?]();
            bounds.add(null);
            bounds.add(tbase_var);
            owner.argument_type_bounds = bounds;

            let actual_base = reference_type();

            let pass_logger = DIAGNOSTICS_STORE();
            GENERIC_CONSTRAINT_CHECKER().check_arguments(
                loc(), pass_logger, owner, ["TBase", "TDerived"], [actual_base, actual_base]);
            Assert.is_false(pass_logger.any_errors);

            let fail_logger = DIAGNOSTICS_STORE();
            GENERIC_CONSTRAINT_CHECKER().check_arguments(
                loc(), fail_logger, owner, ["TBase", "TDerived"], [actual_base, value_type()]);
            Assert.is_true(fail_logger.any_errors);
        si
    si
si
