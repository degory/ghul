namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    // Tests for GENERIC_CONSTRAINT_CHECKER — whether a type argument
    // satisfies a `class` / `struct` / `optional` kind constraint.
    // Uncheckable actuals (error types, type variables) must report
    // "satisfied" so no spurious constraint error cascades from them.
    class GENERIC_CONSTRAINT_CHECKER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        no_names() -> LIST[string] => LIST[string]();

        reference_type() -> Semantic.Types.Type =>
            CLASS(loc(), loc(), null, "RefThing", no_names(), false, null).type;

        value_type() -> Semantic.Types.Type =>
            STRUCT(loc(), loc(), null, "ValThing", no_names(), false, null).type;

        type_variable() -> Semantic.Types.Type =>
            CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0).type;

        // A reference type's `T?` form — the same NAMED carrying the
        // optional flag.
        optional_reference_type() -> Semantic.Types.Type =>
            reference_type().as_optional();

        error_type() -> Semantic.Types.Type => Semantic.Types.ERROR();

        A_class_constraint_is_satisfied_by_a_reference_type() is
            @test()
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.REFERENCE, reference_type()));
        si

        A_class_constraint_is_not_satisfied_by_a_value_type() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.REFERENCE, value_type()));
        si

        A_struct_constraint_is_satisfied_by_a_value_type() is
            @test()
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.VALUE, value_type()));
        si

        A_struct_constraint_is_not_satisfied_by_a_reference_type() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.VALUE, reference_type()));
        si

        The_unconstrained_kind_is_satisfied_by_any_type() is
            @test()
            let checker = GENERIC_CONSTRAINT_CHECKER();
            Assert.is_true(checker.is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.NONE, reference_type()));
            Assert.is_true(checker.is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.NONE, value_type()));
        si

        An_optional_constraint_is_satisfied_by_an_optional_type() is
            @test()
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.OPTIONAL, optional_reference_type()));
        si

        An_optional_constraint_is_not_satisfied_by_a_non_optional_reference_type() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.OPTIONAL, reference_type()));
        si

        An_optional_constraint_is_not_satisfied_by_a_non_optional_value_type() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.OPTIONAL, value_type()));
        si

        An_error_type_satisfies_any_constraint_so_no_cascade() is
            @test()
            let checker = GENERIC_CONSTRAINT_CHECKER();
            Assert.is_true(checker.is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.REFERENCE, error_type()));
            Assert.is_true(checker.is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.VALUE, error_type()));
            Assert.is_true(checker.is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.OPTIONAL, error_type()));
        si

        A_type_variable_satisfies_any_constraint_being_unprovable() is
            @test()
            let checker = GENERIC_CONSTRAINT_CHECKER();
            Assert.is_true(checker.is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.REFERENCE, type_variable()));
            Assert.is_true(checker.is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.VALUE, type_variable()));
            Assert.is_true(checker.is_satisfied(TYPE_PARAMETER_CONSTRAINT_KIND.OPTIONAL, type_variable()));
        si

        A_type_parameter_with_no_bound_reports_no_type_bound() is
            @test()
            let parameter = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            Assert.is_null(GENERIC_CONSTRAINT_CHECKER().type_bound(parameter));
        si

        A_type_parameter_with_an_explicit_bound_reports_it() is
            @test()
            let parameter = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let bound = reference_type();
            parameter.set_ancestor_type(bound);
            Assert.are_same(bound, GENERIC_CONSTRAINT_CHECKER().type_bound(parameter));
        si

        A_value_type_always_has_a_parameterless_constructor() is
            @test()
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().has_accessible_parameterless_constructor(value_type()));
        si

        A_reference_type_with_no_constructor_has_no_parameterless_constructor() is
            @test()
            Assert.is_false(GENERIC_CONSTRAINT_CHECKER().has_accessible_parameterless_constructor(reference_type()));
        si

        A_reference_type_that_declares_a_parameterless_constructor_has_one() is
            @test()
            let the_class = CLASS(loc(), loc(), null, "HasCtor", no_names(), false, null);
            the_class.has_parameterless_constructor = true;
            Assert.is_true(GENERIC_CONSTRAINT_CHECKER().has_accessible_parameterless_constructor(the_class.type));
        si

        check_arguments_reports_a_type_argument_with_no_parameterless_constructor() is
            @test()
            let owner = CLASS(loc(), loc(), null, "Factory", ["T"], false, null);
            owner.argument_has_constructor_constraint = [true];

            let logger = DIAGNOSTICS_STORE();

            GENERIC_CONSTRAINT_CHECKER().check_arguments(loc(), logger, owner, ["T"], [reference_type()]);

            Assert.is_true(logger.any_errors);
        si

        check_arguments_accepts_a_type_argument_with_a_parameterless_constructor() is
            @test()
            let owner = CLASS(loc(), loc(), null, "Factory", ["T"], false, null);
            owner.argument_has_constructor_constraint = [true];

            let logger = DIAGNOSTICS_STORE();

            GENERIC_CONSTRAINT_CHECKER().check_arguments(loc(), logger, owner, ["T"], [value_type()]);

            Assert.is_false(logger.any_errors);
        si
    si
si
