namespace Semantic.Symbols.UnitTests is
    use System.Text.StringBuilder;

    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;

    // Tests for Function.gen_actual_arguments_list — the methodref-signature
    // emitter that bug #987 turned out to depend on. The fix relied on the
    // emitter preferring `unspecialized_arguments` over `arguments` when
    // both are populated, so that loader-supplied open-generic forms (`!0`,
    // `!!0`) reach the IL even though `arguments` carries the substituted
    // concrete types. These tests pin that preference, plus the fall-through
    // to `arguments` when no unspecialized form has been recorded.
    class FUNCTION_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        types_of(a: Symbols.GenericArgument, b: Symbols.GenericArgument) -> LIST[Type] is
            let result = LIST[Type]();
            result.add(a.type!);
            result.add(b.type!);
            return result;
        si

        Calling__gen_actual_arguments_list__should_walk_arguments_when_no_unspecialized_set() is
            @test()

            let t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let u = CLASSY_GENERIC_ARGUMENT(loc(), null, "U", 1);

            let function = INSTANCE_METHOD(loc(), loc(), null, "do_thing", null);
            function.arguments = types_of(t, u);

            let buffer = StringBuilder();
            function.gen_actual_arguments_list(buffer);

            Assert.are_equal("!0 ,!1 ", buffer.to_string());
        si

        Calling__gen_actual_arguments_list__should_prefer_unspecialized_arguments_when_both_are_set() is
            @test()

            // Open form: `T`, `U` (the original parameter symbols).
            let open_t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let open_u = CLASSY_GENERIC_ARGUMENT(loc(), null, "U", 1);

            // Substituted form: pretend T = some_other and U = some_other_2,
            // emitted via unrelated parameter symbols just so we can tell
            // which list the emitter walked.
            let sub_a = CLASSY_GENERIC_ARGUMENT(loc(), null, "A", 7);
            let sub_b = CLASSY_GENERIC_ARGUMENT(loc(), null, "B", 8);

            let function = INSTANCE_METHOD(loc(), loc(), null, "do_thing", null);
            function.arguments = types_of(sub_a, sub_b);
            function.unspecialized_arguments = types_of(open_t, open_u);

            let buffer = StringBuilder();
            function.gen_actual_arguments_list(buffer);

            // If gen_actual_arguments_list ever stops preferring unspecialized,
            // this test catches it: with the preference, the emitter produces
            // `!0,!1` (the open-form indices), not `!7,!8` (the substituted).
            Assert.are_equal("!0 ,!1 ", buffer.to_string());
        si

        Calling__gen_actual_arguments_list__on_a_function_with_no_arguments__should_emit_nothing() is
            @test()

            let function = INSTANCE_METHOD(loc(), loc(), null, "do_thing", null);
            function.arguments = LIST[Type]();

            let buffer = StringBuilder();
            function.gen_actual_arguments_list(buffer);

            Assert.are_equal("", buffer.to_string());
        si

        // The bug fix relied on specialize_function correctly preserving
        // the open-form arguments. These two tests pin that contract.

        Calling__specialize_function__should_record_arguments_as_unspecialized_when_no_unspecialized_was_set() is
            @test()

            let t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let u = CLASSY_GENERIC_ARGUMENT(loc(), null, "U", 1);

            let function = INSTANCE_METHOD(loc(), loc(), null, "do_thing", null);
            function.arguments = types_of(t, u);
            function.return_type = t.type;

            let empty_map = Collections.MAP[string,Type]();
            let specialized = function.specialize_function(empty_map, null);

            // After specialization, the original `arguments` becomes the
            // recorded `unspecialized_arguments` — which is what allows the
            // emitter to recover the open form when emitting the methodref.
            Assert.are_equal(2, specialized.unspecialized_arguments.count);
            Assert.are_same(t.type, specialized.unspecialized_arguments[0]);
            Assert.are_same(u.type, specialized.unspecialized_arguments[1]);
        si

        Calling__specialize_function__should_keep_existing_unspecialized_when_re_specializing() is
            @test()

            let t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let u = CLASSY_GENERIC_ARGUMENT(loc(), null, "U", 1);
            let already_substituted = CLASSY_GENERIC_ARGUMENT(loc(), null, "X", 9);

            let function = INSTANCE_METHOD(loc(), loc(), null, "do_thing", null);
            function.arguments = types_of(already_substituted, already_substituted);
            function.unspecialized_arguments = types_of(t, u);
            function.return_type = t.type;

            let empty_map = Collections.MAP[string,Type]();
            let specialized = function.specialize_function(empty_map, null);

            // Re-specializing must not lose the original open form. Without
            // this guarantee, double-specialization (which happens during
            // override resolution and inheritance pull-down) would erase the
            // open-form arguments and the IL would regress to substituted.
            Assert.are_equal(2, specialized.unspecialized_arguments.count);
            Assert.are_same(t.type, specialized.unspecialized_arguments[0]);
            Assert.are_same(u.type, specialized.unspecialized_arguments[1]);
        si
    si
si
