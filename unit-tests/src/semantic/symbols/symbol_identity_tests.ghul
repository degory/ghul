namespace Semantic.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Semantic.Symbols.GLOBAL_FUNCTION;
    use Semantic.Symbols.STORE_FREE_BITS;

    use Source.LOCATION;

    // Symbol ids are the transferable identity that id-keyed fact
    // tables (the store-free bits) survive symbol re-creation through:
    // unique at creation, adoptable by a replacement.
    class SYMBOL_IDENTITY_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION.internal;

        Symbols_get_distinct_ids() is
            @test()

            let first = GLOBAL_FUNCTION(loc(), loc(), null, "f", null);
            let second = GLOBAL_FUNCTION(loc(), loc(), null, "g", null);

            Assert.are_not_equal(first.id, second.id);
        si

        Adopting_transfers_the_predecessors_id() is
            @test()

            let predecessor = GLOBAL_FUNCTION(loc(), loc(), null, "f", null);
            let replacement = GLOBAL_FUNCTION(loc(), loc(), null, "f", null);

            replacement.adopt_id(predecessor);

            Assert.are_equal(predecessor.id, replacement.id);
        si

        Store_free_bit_survives_adoption() is
            @test()

            let predecessor = GLOBAL_FUNCTION(loc(), loc(), null, "f", null);
            predecessor.set_store_free(true);

            let replacement = GLOBAL_FUNCTION(loc(), loc(), null, "f", null);
            Assert.is_false(replacement.is_store_free);

            replacement.adopt_id(predecessor);
            Assert.is_true(replacement.is_store_free);

            replacement.set_store_free(false);
            Assert.is_false(replacement.is_store_free);
        si

        Clearing_the_bits_resets_every_entry() is
            @test()

            let function = GLOBAL_FUNCTION(loc(), loc(), null, "f", null);
            function.set_store_free(true);

            STORE_FREE_BITS.clear();

            Assert.is_false(function.is_store_free);
        si
    si
si
