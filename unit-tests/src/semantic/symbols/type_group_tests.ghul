namespace Semantic.Symbols.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    // Pins TYPE_GROUP's arity-dispatch + multi-member contract — the
    // foundation for source-side `class Foo is` / `class Foo[T] is`
    // coexistence. Without these, a regression in find_by_arity or
    // collapse_group_if_single_member could silently drop arity 0
    // members or misroute the bare-name case.
    class TYPE_GROUP_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        names() -> Collections.LIST[string] => Collections.LIST[string]();

        names_one() -> Collections.LIST[string] is
            let r = Collections.LIST[string]();
            r.add("T");
            return r;
        si

        names_two() -> Collections.LIST[string] is
            let r = Collections.LIST[string]();
            r.add("T");
            r.add("U");
            return r;
        si

        Calling__find_by_arity__on_a_group_with_one_arity_zero_member__returns_it() is
            @test()

            let foo = CLASS(loc(), loc(), null, "FOO", names(), true, null);
            let group = TYPE_GROUP(loc(), null, "FOO");
            group.add(foo);

            Assert.are_same(foo, group.find_by_arity(0));
        si

        Calling__find_by_arity__on_a_group_with_two_arities__returns_each_by_count() is
            @test()

            let foo_0 = CLASS(loc(), loc(), null, "FOO", names(), true, null);
            let foo_1 = CLASS(loc(), loc(), null, "FOO", names_one(), true, null);
            let foo_2 = CLASS(loc(), loc(), null, "FOO", names_two(), true, null);

            let group = TYPE_GROUP(loc(), null, "FOO");
            group.add(foo_0);
            group.add(foo_1);
            group.add(foo_2);

            Assert.are_same(foo_0, group.find_by_arity(0));
            Assert.are_same(foo_1, group.find_by_arity(1));
            Assert.are_same(foo_2, group.find_by_arity(2));
        si

        Calling__find_by_arity__with_no_matching_member__returns_null() is
            @test()

            let foo_1 = CLASS(loc(), loc(), null, "FOO", names_one(), true, null);

            let group = TYPE_GROUP(loc(), null, "FOO");
            group.add(foo_1);

            Assert.is_null(group.find_by_arity(0));
            Assert.is_null(group.find_by_arity(2));
        si

        Calling__add__marks_each_member_as_in_a_multi_arity_group() is
            @test()

            let foo_0 = CLASS(loc(), loc(), null, "FOO", names(), true, null);
            let foo_1 = CLASS(loc(), loc(), null, "FOO", names_one(), true, null);

            let group = TYPE_GROUP(loc(), null, "FOO");
            group.add(foo_0);
            group.add(foo_1);

            Assert.is_true(foo_0.is_in_multi_arity_group);
            Assert.is_true(foo_1.is_in_multi_arity_group);
        si

        Calling__arities__returns_sorted_ascending_list() is
            @test()

            let foo_2 = CLASS(loc(), loc(), null, "FOO", names_two(), true, null);
            let foo_0 = CLASS(loc(), loc(), null, "FOO", names(), true, null);
            let foo_1 = CLASS(loc(), loc(), null, "FOO", names_one(), true, null);

            let group = TYPE_GROUP(loc(), null, "FOO");
            group.add(foo_2);
            group.add(foo_0);
            group.add(foo_1);

            let arities = group.arities;

            Assert.are_equal(3, arities.count);
            Assert.are_equal(0, arities[0]);
            Assert.are_equal(1, arities[1]);
            Assert.are_equal(2, arities[2]);
        si

        Calling__collapse_group_if_single_member__with_one_member__returns_member() is
            @test()

            let foo = CLASS(loc(), loc(), null, "FOO", names(), true, null);
            let group = TYPE_GROUP(loc(), null, "FOO");
            group.add(foo);

            Assert.are_same(foo, group.collapse_group_if_single_member());
        si

        Calling__collapse_group_if_single_member__with_two_members__returns_group() is
            @test()

            let foo_0 = CLASS(loc(), loc(), null, "FOO", names(), true, null);
            let foo_1 = CLASS(loc(), loc(), null, "FOO", names_one(), true, null);
            let group = TYPE_GROUP(loc(), null, "FOO");
            group.add(foo_0);
            group.add(foo_1);

            Assert.are_same(group, group.collapse_group_if_single_member());
        si

        Calling__is_type_group__on_TYPE_GROUP__returns_true() is
            @test()

            let group = TYPE_GROUP(loc(), null, "FOO");

            Assert.is_true(group.is_type_group);
        si

        Calling__is_type__on_TYPE_GROUP__returns_true() is
            @test()

            let group = TYPE_GROUP(loc(), null, "FOO");

            Assert.is_true(group.is_type);
        si
    si
si
