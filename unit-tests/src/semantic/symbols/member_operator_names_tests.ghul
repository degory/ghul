namespace Semantic.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Semantic.Symbols.MEMBER_OPERATOR_NAMES;

    // The store-free walk's soundness argument rests on the empty
    // default: absent means no source type declares a member operator
    // of that name, which is what lets an operator over an operand the
    // walk cannot type stay store-free. Each test clears first, since
    // the set is process-global static state.
    class MEMBER_OPERATOR_NAMES_TESTS is
        @test()

        init() is si

        Empty_set__contains_no_name() is
            @test()

            MEMBER_OPERATOR_NAMES.clear();

            Assert.is_false(MEMBER_OPERATOR_NAMES.contains("%"));
        si

        Added_name__is_contained_and_others_are_not() is
            @test()

            MEMBER_OPERATOR_NAMES.clear();
            MEMBER_OPERATOR_NAMES.add("%");

            Assert.is_true(MEMBER_OPERATOR_NAMES.contains("%"));
            Assert.is_false(MEMBER_OPERATOR_NAMES.contains("&"));
        si

        Clear__removes_added_names() is
            @test()

            MEMBER_OPERATOR_NAMES.add("<>");
            MEMBER_OPERATOR_NAMES.clear();

            Assert.is_false(MEMBER_OPERATOR_NAMES.contains("<>"));
        si
    si
si
