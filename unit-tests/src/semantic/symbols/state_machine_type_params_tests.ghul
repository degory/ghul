namespace Semantic.Symbols.UnitTests is
    use System.Text.StringBuilder;

    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;
    use Semantic.Symbols.STATE_MACHINE_TYPE_PARAMS;

    // The STATE_MACHINE_TYPE_PARAMS helper is the shared bookkeeping
    // for both generator and async state machines — it captures the
    // canonical ordering of type parameters visible inside the
    // owning function (enclosing-class first, function-own next)
    // and uses that ordering both to install gen_type_override
    // hooks (so type references inside the body render as `!N` on
    // the frame class) and to build the `newobj` type-argument list.
    //
    // These tests pin the ordering invariant — generator and async
    // frames both rely on it to keep `!N` indices aligned with the
    // frame class's declared generic arguments.
    class STATE_MACHINE_TYPE_PARAMS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        rendered(arg: Symbols.GenericArgument) -> string is
            let buffer = StringBuilder();
            arg.gen_type(buffer);
            return buffer.to_string();
        si

        Calling__walk_install__with_install_true__should_set_override_emitting_class_relative_index() is
            @test()

            // Function with two own generic args, no enclosing class.
            let function = STATIC_METHOD(loc(), loc(), null, "do_thing", null);
            function.is_generic = true;

            let t = FUNCTION_GENERIC_ARGUMENT(loc(), function, "T", 0);
            let u = FUNCTION_GENERIC_ARGUMENT(loc(), function, "U", 1);

            function.declare(loc(), t, null);
            function.declare(loc(), u, null);

            let names = LIST[string]();
            names.add("T");
            names.add("U");
            function.generic_argument_names = names;

            STATE_MACHINE_TYPE_PARAMS.walk_install(function, true);

            // Both args render as class-level `!N` after install.
            Assert.are_equal("!0 ", rendered(t));
            Assert.are_equal("!1 ", rendered(u));
        si

        Calling__walk_install__with_install_false__should_clear_override_so_default_rendering_resumes() is
            @test()

            let function = STATIC_METHOD(loc(), loc(), null, "do_thing", null);
            function.is_generic = true;

            let t = FUNCTION_GENERIC_ARGUMENT(loc(), function, "T", 0);
            function.declare(loc(), t, null);

            let names = LIST[string]();
            names.add("T");
            function.generic_argument_names = names;

            // FUNCTION_GENERIC_ARGUMENT's default gen_type emits `!!N`.
            Assert.are_equal("!!0 ", rendered(t));

            STATE_MACHINE_TYPE_PARAMS.walk_install(function, true);
            Assert.are_equal("!0 ", rendered(t));

            STATE_MACHINE_TYPE_PARAMS.walk_install(function, false);
            Assert.are_equal("!!0 ", rendered(t));
        si

        Calling__construction_type_arguments__on_a_non_generic_function__should_return_null() is
            @test()

            let function = STATIC_METHOD(loc(), loc(), null, "do_thing", null);

            let result = STATE_MACHINE_TYPE_PARAMS.construction_type_arguments(function);

            Assert.is_null(result);
        si

        Calling__construction_type_arguments__on_a_generic_function__should_list_function_type_args_in_order() is
            @test()

            let function = STATIC_METHOD(loc(), loc(), null, "do_thing", null);
            function.is_generic = true;

            let t = FUNCTION_GENERIC_ARGUMENT(loc(), function, "T", 0);
            let u = FUNCTION_GENERIC_ARGUMENT(loc(), function, "U", 1);

            function.declare(loc(), t, null);
            function.declare(loc(), u, null);

            let names = LIST[string]();
            names.add("T");
            names.add("U");
            function.generic_argument_names = names;

            let args = LIST[Type]();
            args.add(t.type!);
            args.add(u.type!);
            function.generic_arguments = args;

            let result = STATE_MACHINE_TYPE_PARAMS.construction_type_arguments(function);

            Assert.is_not_null(result);
            Assert.are_equal(2, result!.count);
            Assert.are_same(t.type, result![0]);
            Assert.are_same(u.type, result![1]);
        si
    si
si
