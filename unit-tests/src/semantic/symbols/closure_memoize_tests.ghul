namespace Semantic.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.LOCAL_VARIABLE;
    use Semantic.Symbols.NAMESPACE;
    use Semantic.Symbols.STATIC_CLOSURE;

    use Semantic.Types.INFERRED_VARIABLE_TYPE;
    use Semantic.Types.Type;

    // Pins `Closure.is_memoizable_delegate`, the gate that decides whether
    // a function literal's delegate can be built once and cached in a
    // static field. It must be true only for a stateless, ground literal
    // emitted as a static/global anonymous function: no captures, no
    // captured type arguments, a fully-settled function type, and an
    // enclosing namespace to host the cache field. Each negative branch
    // is pinned because letting any one through would either cache a
    // literal that carries per-evaluation state or emit an unresolved
    // type into the cache field.
    class CLOSURE_MEMOIZE_TESTS is
        @test()

        init() is
            // LOCAL_VARIABLE's init reads the local id generator; wire it
            // up so the unsettled-type fixture can build a placeholder.
            if !IoC.CONTAINER.instance.local_id_generator? then
                IoC.CONTAINER.instance.local_id_generator = IR.LOCAL_ID_GENERATOR();
            fi
            IoC.CONTAINER.instance.local_id_generator.enter_function();
        si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        namespace_owner() -> NAMESPACE => NAMESPACE(loc(), "Test", null, ".Test", false);

        settled_type() -> Type =>
            CLASS(loc(), loc(), null, "Concrete", System.Array.empty[string](), false, null).type!;

        // A ground static closure owned by a namespace: memoizable unless
        // a test perturbs one of the gate's inputs.
        memoizable_closure() -> STATIC_CLOSURE is
            let owner = namespace_owner();
            let closure = STATIC_CLOSURE(loc(), owner, "$anon_0", owner, false);
            closure.type = settled_type();
            return closure;
        si

        Calling__is_memoizable_delegate__for_ground_static_closure__returns_true() is
            @test()

            Assert.is_true(memoizable_closure().is_memoizable_delegate);
        si

        Calling__is_memoizable_delegate__when_a_delegate__returns_false() is
            @test()

            // A self-bound delegate carries a receiver, so its instance is
            // not interchangeable across loads.
            let closure = memoizable_closure();
            closure.is_delegate = true;

            Assert.is_false(closure.is_memoizable_delegate);
        si

        Calling__is_memoizable_delegate__with_captured_type_arguments__returns_false() is
            @test()

            // A literal carrying method-level type arguments has no single
            // ground delegate to cache.
            let closure = memoizable_closure();
            closure.add_type_argument_reference(namespace_owner());

            Assert.is_false(closure.is_memoizable_delegate);
        si

        Calling__is_memoizable_delegate__with_unsettled_type__returns_false() is
            @test()

            // An unresolved function type would render placeholder comments
            // into the cache field's declaration.
            let closure = memoizable_closure();
            closure.type = INFERRED_VARIABLE_TYPE(LOCAL_VARIABLE(loc(), namespace_owner(), "v"));

            Assert.is_false(closure.is_memoizable_delegate);
        si

        Calling__is_memoizable_delegate__without_enclosing_namespace__returns_false() is
            @test()

            // No namespace in the owner chain means nowhere to host the
            // static cache field.
            let owner = CLASS(loc(), loc(), null, "Owner", System.Array.empty[string](), false, null);
            let closure = STATIC_CLOSURE(loc(), owner, "$anon_0", owner, false);
            closure.type = settled_type();

            Assert.is_false(closure.is_memoizable_delegate);
        si
    si
si
