namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    // The checker walks a class's direct class superchain looking for the
    // first ancestor that lists the trait as a direct ancestor and asks
    // whether that ancestor redeclares the member. These tests pin the
    // two structural helpers it uses to drive that walk: which ancestor
    // counts as the class parent, and whether a class lists a specific
    // trait in its directly-declared ancestor list.
    class INEFFECTIVE_TRAIT_OVERRIDE_CHECKER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        make_class(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, empty_names(), false, null);

        make_trait(name: string) -> TRAIT =>
            TRAIT(loc(), loc(), null, name, empty_names(), false, null);

        Calling__direct_class_parent__on_class_extending_class_should_return_that_class() is
            @test()

            let parent = make_class("Parent");
            let child = make_class("Child");
            child.add_ancestor(parent.type!);

            let checker = INEFFECTIVE_TRAIT_OVERRIDE_CHECKER();

            Assert.are_same(parent, checker._direct_class_parent(child));
        si

        Calling__direct_class_parent__on_class_with_trait_then_class_should_skip_trait() is
            @test()

            let `trait = make_trait("T");
            let parent = make_class("Parent");
            let child = make_class("Child");
            child.add_ancestor(`trait.type!);
            child.add_ancestor(parent.type!);

            let checker = INEFFECTIVE_TRAIT_OVERRIDE_CHECKER();

            Assert.are_same(parent, checker._direct_class_parent(child));
        si

        Calling__direct_class_parent__on_class_with_only_trait_ancestors_should_return_null() is
            @test()

            let `trait = make_trait("T");
            let child = make_class("Child");
            child.add_ancestor(`trait.type!);

            let checker = INEFFECTIVE_TRAIT_OVERRIDE_CHECKER();

            Assert.is_null(checker._direct_class_parent(child));
        si

        Calling__has_trait_in_direct_ancestors__when_trait_is_listed_should_return_true() is
            @test()

            let `trait = make_trait("T");
            let parent = make_class("Parent");
            let child = make_class("Child");
            child.add_ancestor(parent.type!);
            child.add_ancestor(`trait.type!);

            let checker = INEFFECTIVE_TRAIT_OVERRIDE_CHECKER();

            Assert.is_true(checker._has_trait_in_direct_ancestors(child, `trait));
        si

        Calling__has_trait_in_direct_ancestors__when_trait_is_not_listed_should_return_false() is
            @test()

            let `trait = make_trait("T");
            let other_trait = make_trait("Other");
            let child = make_class("Child");
            child.add_ancestor(other_trait.type!);

            let checker = INEFFECTIVE_TRAIT_OVERRIDE_CHECKER();

            Assert.is_false(checker._has_trait_in_direct_ancestors(child, `trait));
        si

        Calling__has_trait_in_direct_ancestors__on_class_that_inherits_trait_via_class_parent_should_return_false() is
            @test()

            // Direct-only check: a class whose class parent lists the trait
            // is not considered to list the trait itself. The walk handles
            // transitive cases by stepping up to that parent in turn.
            let `trait = make_trait("T");
            let parent = make_class("Parent");
            parent.add_ancestor(`trait.type!);

            let child = make_class("Child");
            child.add_ancestor(parent.type!);

            let checker = INEFFECTIVE_TRAIT_OVERRIDE_CHECKER();

            Assert.is_false(checker._has_trait_in_direct_ancestors(child, `trait));
            Assert.is_true(checker._has_trait_in_direct_ancestors(parent, `trait));
        si
    si
si
