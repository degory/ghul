namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;

    use Semantic.Types.Type;

    use Semantic.MEMBER_CONSTRAINT;

    // Tests for the operation-constraint integration in
    // `Variable.try_get_inferred_type`. The `_constraints`
    // accumulator is only useful when the inferred-type lookup
    // *actually consults it* — pin the contract here so future
    // refactors of the LUB pipeline can't silently bypass the
    // constraint filter.
    //
    // These tests deliberately avoid constructing class-with-members
    // fixtures because the existing `MEMBER_CONSTRAINT_TESTS`
    // already pins the discharge function's per-candidate semantics
    // — what we're testing here is that `try_get_inferred_type`
    // calls `try_discharge` on every accumulated constraint and
    // rejects when any returns false.
    class VARIABLE_CONSTRAINT_INTEGRATION_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        // Baseline: with a type-bound LUB constraint and no
        // operation constraints, the resolution returns the LUB
        // result as before. Pins the "no-constraints path
        // unchanged" contract.
        With_a_type_constraint_and_no_operation_constraints__try_get_inferred_type__should_return_the_LUB_result() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_true(origin.add_constraint(c.type));

            Assert.are_same(c.type, origin.try_get_inferred_type());
        si

        // With an operation constraint that rejects the LUB
        // candidate, the lookup returns null even though the LUB
        // has a concrete result. This is the key behaviour of
        // the operation-constraint filter: a candidate that
        // doesn't expose the required operation is NOT a valid
        // resolution.
        With_an_operation_constraint_that_rejects_the_LUB_candidate__try_get_inferred_type__should_return_null() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_true(origin.add_constraint(c.type));
            Assert.is_true(origin.add_constraint(MEMBER_CONSTRAINT("nonexistent")));

            Assert.is_null(origin.try_get_inferred_type());
        si

        // No type constraint at all: today returns null (nothing
        // in the LUB to widen toward). Adding an operation
        // constraint without a type constraint doesn't fabricate
        // a candidate.
        With_no_type_constraint_and_an_operation_constraint__try_get_inferred_type__should_return_null() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");

            Assert.is_true(origin.add_constraint(MEMBER_CONSTRAINT("foo")));

            Assert.is_null(origin.try_get_inferred_type());
        si
    si
si
