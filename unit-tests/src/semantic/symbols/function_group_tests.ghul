namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;

    // Tests for FUNCTION_GROUP.merged_over - the overload join used when a
    // member function group shadows an enclosing scope's group of the same
    // name: the member group's functions win their override class, the
    // outer group contributes only overloads the member group doesn't have.
    class FUNCTION_GROUP_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        zero_arg_method(name: string) -> INSTANCE_METHOD is
            let result = INSTANCE_METHOD(loc(), loc(), null, name, null);
            result.arguments = LIST[Type]();
            return result;
        si

        one_arg_method(name: string, argument: Type) -> INSTANCE_METHOD is
            let result = INSTANCE_METHOD(loc(), loc(), null, name, null);

            let arguments = LIST[Type]();
            arguments.add(argument);
            result.arguments = arguments;

            return result;
        si

        group_of(functions: Function[]) -> FUNCTION_GROUP is
            let result = FUNCTION_GROUP(loc(), null, "foo");

            for f in functions do
                result.add(f);
            od

            return result;
        si

        Calling__merged_over__should_append_outer_overloads_the_member_group_lacks() is
            @test()

            let t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);

            let member_function = zero_arg_method("foo");
            let outer_function = one_arg_method("foo", t.type!);

            let merged = group_of([member_function]).merged_over(group_of([outer_function]));

            Assert.are_equal(2, merged.functions.count);
            Assert.are_same(member_function, merged.functions[0]);
            Assert.are_same(outer_function, merged.functions[1]);
        si

        Calling__merged_over__should_drop_outer_overloads_the_member_group_already_has() is
            @test()

            let member_function = zero_arg_method("foo");
            let outer_function = zero_arg_method("foo");

            let merged = group_of([member_function]).merged_over(group_of([outer_function]));

            Assert.are_equal(1, merged.functions.count);
            Assert.are_same(member_function, merged.functions[0]);
        si

        Calling__merged_over__on_disjoint_multi_function_groups__should_keep_every_overload() is
            @test()

            let t = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0);
            let u = CLASSY_GENERIC_ARGUMENT(loc(), null, "U", 1);

            let member_a = zero_arg_method("foo");
            let member_b = one_arg_method("foo", t.type!);
            let outer_matching = one_arg_method("foo", t.type!);
            let outer_extra = one_arg_method("foo", u.type!);

            let merged = group_of([member_a, member_b]).merged_over(group_of([outer_matching, outer_extra]));

            Assert.are_equal(3, merged.functions.count);
            Assert.are_same(member_a, merged.functions[0]);
            Assert.are_same(member_b, merged.functions[1]);
            Assert.are_same(outer_extra, merged.functions[2]);
        si
    si
si
