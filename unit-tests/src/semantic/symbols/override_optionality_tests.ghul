namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;

    // Optionality is erased from emitted signatures, so a member whose
    // type differs from its overridee's only in optionality overrides it
    // at run time regardless of what the resolver records. These tests
    // pin the rules that follow from that: the override relationship is
    // always linked, weakening the overridden contract is an error
    // (optional return or property type over a non-optional contract,
    // non-optional argument where the overridee accepts optional, any
    // optionality change to an assignable property), strengthening is
    // legal, and the exemptions hold (optional type-variable arguments,
    // internal accessor functions).
    class OVERRIDE_OPTIONALITY_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        make_class(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, LIST[string](), false, null);

        make_method(name: string, argument: Type?, return_type: Type) -> INSTANCE_METHOD is
            let result = INSTANCE_METHOD(loc(), loc(), null, name, null);

            let arguments = LIST[Type]();

            if argument? then
                arguments.add(argument);
            fi

            result.arguments = arguments;
            result.return_type = return_type;

            return result;
        si

        make_property(name: string, `type: Type, is_assignable: bool) -> INSTANCE_PROPERTY is
            let result = INSTANCE_PROPERTY(loc(), loc(), null, name, is_assignable, false);

            result.set_type(`type);

            return result;
        si

        contains(symbols: Collections.Iterable[Symbol]?, symbol: Symbol) -> bool =>
            symbols? /\ symbols | .any(s => s == symbol);

        Calling__try_instance_override_me__when_override_widens_return_to_optional_should_error_and_still_link() is
            @test()

            let t = make_class("THING").type!;

            let overridee = make_method("fetch", null, t);
            let overrider = make_method("fetch", null, t.as_optional());

            let logger = Logging.DIAGNOSTICS_STORE();

            overridee.try_instance_override_me(make_class("INTO"), overrider, logger);

            Assert.are_equal(1, logger.error_count);
            Assert.is_true(contains(overridee.overriders, overrider));
        si

        Calling__try_instance_override_me__when_override_tightens_optional_return_should_link_without_diagnostics() is
            @test()

            let t = make_class("THING").type!;

            let overridee = make_method("fetch", null, t.as_optional());
            let overrider = make_method("fetch", null, t);

            let logger = Logging.DIAGNOSTICS_STORE();

            overridee.try_instance_override_me(make_class("INTO"), overrider, logger);

            Assert.are_equal(0, logger.error_count);
            Assert.is_false(logger.any_warnings);
            Assert.is_true(contains(overridee.overriders, overrider));
        si

        Calling__try_instance_override_me__when_override_tightens_optional_argument_should_error() is
            @test()

            let t = make_class("THING").type!;
            let r = make_class("RESULT").type!;

            let overridee = make_method("greet", t.as_optional(), r);
            let overrider = make_method("greet", t, r);

            let logger = Logging.DIAGNOSTICS_STORE();

            overridee.try_instance_override_me(make_class("INTO"), overrider, logger);

            Assert.are_equal(1, logger.error_count);
        si

        Calling__try_instance_override_me__when_override_widens_argument_to_optional_should_not_error() is
            @test()

            let t = make_class("THING").type!;
            let r = make_class("RESULT").type!;

            let overridee = make_method("greet", t, r);
            let overrider = make_method("greet", t.as_optional(), r);

            let logger = Logging.DIAGNOSTICS_STORE();

            overridee.try_instance_override_me(make_class("INTO"), overrider, logger);

            Assert.are_equal(0, logger.error_count);
        si

        Calling__ensure_arguments_accept_optionals__with_optional_type_variable_argument_should_not_error() is
            @test()

            let tv = CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0).type!;
            let r = make_class("RESULT").type!;

            let overridee = make_method("compare", tv.as_optional(), r);
            let overrider = make_method("compare", tv, r);

            let logger = Logging.DIAGNOSTICS_STORE();

            overrider.ensure_arguments_accept_optionals(make_class("INTO"), overridee, false, logger);

            Assert.are_equal(0, logger.error_count);
        si

        Calling__ensure_return_type_matches__on_internal_accessor_should_not_report_optionality() is
            @test()

            let t = make_class("THING").type!;

            let overridee = make_method("$get_x", null, t);
            let overrider = make_method("$get_x", null, t.as_optional());

            let logger = Logging.DIAGNOSTICS_STORE();

            overrider.ensure_return_type_matches(make_class("INTO"), overridee, true, logger);

            Assert.are_equal(0, logger.error_count);
        si

        Calling__handle_property_overridee__when_override_widens_to_optional_should_error_and_still_link() is
            @test()

            let t = make_class("THING").type!;

            let overridee = make_property("name", t, false);
            let overrider = make_property("name", t.as_optional(), false);

            let logger = Logging.DIAGNOSTICS_STORE();

            SYMBOL_INHERITANCE_RESOLVER(make_class("INTO"))
                .handle_property_overridee(overrider, overridee, logger);

            Assert.are_equal(1, logger.error_count);
            Assert.is_true(contains(overridee.overriders, overrider));
        si

        Calling__handle_property_overridee__when_assignable_property_tightens_should_error() is
            @test()

            let t = make_class("THING").type!;

            let overridee = make_property("name", t.as_optional(), true);
            let overrider = make_property("name", t, true);

            let logger = Logging.DIAGNOSTICS_STORE();

            SYMBOL_INHERITANCE_RESOLVER(make_class("INTO"))
                .handle_property_overridee(overrider, overridee, logger);

            Assert.are_equal(1, logger.error_count);
        si

        Calling__handle_property_overridee__when_read_only_property_tightens_should_link_without_diagnostics() is
            @test()

            let t = make_class("THING").type!;

            let overridee = make_property("name", t.as_optional(), false);
            let overrider = make_property("name", t, false);

            let logger = Logging.DIAGNOSTICS_STORE();

            SYMBOL_INHERITANCE_RESOLVER(make_class("INTO"))
                .handle_property_overridee(overrider, overridee, logger);

            Assert.are_equal(0, logger.error_count);
            Assert.is_false(logger.any_warnings);
            Assert.is_true(contains(overridee.overriders, overrider));
        si
    si
si
