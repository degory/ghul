namespace Semantic.Symbols.UnitTests is
    use System.Text.StringBuilder;

    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    // Pins the emission and access-policy contract of the underscore method
    // kinds chosen by Classy._make_instance_method / _make_static_method:
    // both private and protected emit assembly (the policy distinction is a
    // compile-time rule, not an IL keyword), private methods are non-virtual,
    // and is_accessible_to encodes declaring-class (private) vs owner-or-
    // subclass (protected). access_prefix drives the hover text.
    class UNDERSCORE_METHOD_ACCESS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        a_class(name: string) -> CLASS => CLASS(loc(), loc(), null, name, LIST[string](), false, null);

        gen_access_of(m: Function) -> string is
            let buffer = StringBuilder();
            m.gen_access(buffer);
            return buffer.to_string();
        si

        private_method_emits_assembly_is_non_virtual_and_hovers_private() is
            @test()

            let owner = a_class("A");
            let m = PRIVATE_METHOD(loc(), loc(), owner, "_helper", owner);

            Assert.are_equal("assembly ", gen_access_of(m));
            Assert.is_false(m.is_virtual);
            Assert.are_equal("private ", m.access_prefix);
        si

        protected_method_emits_assembly_is_virtual_and_hovers_protected() is
            @test()

            let owner = a_class("A");
            let m = PROTECTED_METHOD(loc(), loc(), owner, "_helper", owner);

            Assert.are_equal("assembly ", gen_access_of(m));
            Assert.is_true(m.is_virtual);
            Assert.are_equal("protected ", m.access_prefix);
        si

        plain_instance_method_stays_public_and_accessible() is
            @test()

            let owner = a_class("A");
            let m = INSTANCE_METHOD(loc(), loc(), owner, "helper", owner);

            Assert.are_equal("public ", gen_access_of(m));
            Assert.is_true(m.is_virtual);
            Assert.are_equal("", m.access_prefix);
            Assert.is_true(m.is_accessible_to(a_class("Unrelated")));
        si

        private_method_reachable_only_from_declaring_class() is
            @test()

            let owner = a_class("A");
            let m = PRIVATE_METHOD(loc(), loc(), owner, "_helper", owner);

            Assert.is_true(m.is_accessible_to(owner));
            Assert.is_false(m.is_accessible_to(a_class("Other")));
            Assert.is_false(m.is_accessible_to(null));
        si

        private_static_method_emits_assembly_and_hovers_private() is
            @test()

            let owner = a_class("A");
            let m = PRIVATE_STATIC_METHOD(loc(), loc(), owner, "_helper", owner);

            Assert.are_equal("assembly ", gen_access_of(m));
            Assert.are_equal("private ", m.access_prefix);
            Assert.is_true(m.is_accessible_to(owner));
            Assert.is_false(m.is_accessible_to(a_class("Other")));
        si
    si
si
