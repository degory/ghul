namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;
    use Semantic.Symbols.TYPE_ARGUMENT_EXTRACTOR;

    // TYPE_ARGUMENT_EXTRACTOR pulls the first type argument out of a
    // type viewed as an instantiation of one of a set of candidate
    // generic classes — used by the generator + async state-machine
    // setup to extract `T` from `Iterable[T]` / `Tasks.TASK[T]`.
    //
    // Three failure modes the helper has to handle and these tests
    // pin:
    //   - the type-of-interest is the candidate itself, not a
    //     subtype (find_ancestor doesn't self-match);
    //   - the type's symbol is wrapped in `Symbols.GENERIC` and has
    //     to be unwrapped before comparison;
    //   - the type doesn't match any candidate (returns null).
    class TYPE_ARGUMENT_EXTRACTOR_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        names_for(values: Collections.Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        Calling__extract__on_a_direct_instantiation__should_return_its_first_type_argument() is
            @test()

            // Box[T] — a generic class with one type parameter.
            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);

            // The thing we'll feed in: Box[int_arg]. We don't have
            // ints in test fixtures, so use a CLASSY_GENERIC_ARGUMENT
            // as the type argument — the extractor doesn't care.
            let int_arg = CLASSY_GENERIC_ARGUMENT(loc(), null, "int_arg", 0);
            let args = LIST[Type]();
            args.add(int_arg.type);

            let constructed = Types.GENERIC(loc(), box, args);

            let result = TYPE_ARGUMENT_EXTRACTOR.extract(constructed, box.type!);

            Assert.are_same(int_arg.type, result);
        si

        Calling__extract__on_a_non_matching_type__should_return_null() is
            @test()

            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);
            let other = CLASS(loc(), loc(), null, "Other", names_for(["T"]), false, null);

            let int_arg = CLASSY_GENERIC_ARGUMENT(loc(), null, "int_arg", 0);
            let args = LIST[Type]();
            args.add(int_arg.type);

            let constructed_box = Types.GENERIC(loc(), box, args);

            // Asking for Other[T]'s argument from a Box[T] value — no match.
            let result = TYPE_ARGUMENT_EXTRACTOR.extract(constructed_box, other.type!);

            Assert.is_null(result);
        si

        Calling__extract_from_any__with_two_candidates__should_match_the_first_one_present() is
            @test()

            let iterable = CLASS(loc(), loc(), null, "Iterable", names_for(["T"]), false, null);
            let iterator = CLASS(loc(), loc(), null, "Iterator", names_for(["T"]), false, null);

            let int_arg = CLASSY_GENERIC_ARGUMENT(loc(), null, "int_arg", 0);
            let args = LIST[Type]();
            args.add(int_arg.type);

            let constructed_iterable = Types.GENERIC(loc(), iterable, args);

            let candidates = LIST[Type]();
            candidates.add(iterator.type!);
            candidates.add(iterable.type!);

            let result = TYPE_ARGUMENT_EXTRACTOR.extract_from_any(constructed_iterable, candidates);

            Assert.are_same(int_arg.type, result);
        si

        Calling__extract_from_any__with_no_matching_candidate__should_return_null() is
            @test()

            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);
            let other_a = CLASS(loc(), loc(), null, "OtherA", names_for(["T"]), false, null);
            let other_b = CLASS(loc(), loc(), null, "OtherB", names_for(["T"]), false, null);

            let int_arg = CLASSY_GENERIC_ARGUMENT(loc(), null, "int_arg", 0);
            let args = LIST[Type]();
            args.add(int_arg.type);

            let constructed_box = Types.GENERIC(loc(), box, args);

            let candidates = LIST[Type]();
            candidates.add(other_a.type!);
            candidates.add(other_b.type!);

            let result = TYPE_ARGUMENT_EXTRACTOR.extract_from_any(constructed_box, candidates);

            Assert.is_null(result);
        si

        Calling__extract__on_a_null_input_or_null_candidate__should_return_null() is
            @test()

            let box = CLASS(loc(), loc(), null, "Box", names_for(["T"]), false, null);

            Assert.is_null(TYPE_ARGUMENT_EXTRACTOR.extract(null, box.type!));
            Assert.is_null(TYPE_ARGUMENT_EXTRACTOR.extract(box.type!, null));
        si
    si
si
