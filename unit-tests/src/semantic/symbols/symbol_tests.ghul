namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Symbol;

    // Pins `Symbol.is_positional_member_name`, the shared recognizer for
    // auto-generated positional tuple/destructure member names (a bare
    // decimal index). Used by the least-upper-bound element-name merge,
    // the primary-constructor deconstruct rewrite, and the destructure
    // backward-compatibility retry.
    class SYMBOL_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        // A class carrying a single positional member spelled the legacy
        // way (a backtick-prefixed index), as it would arrive by
        // reflection from an assembly built by an older compiler.
        legacy_positional_class() -> CLASS is
            let c = CLASS(loc(), loc(), null, "PAIR", LIST[string](), false, null);
            c.declare_variable(loc(), "`0", false, null);
            return c;
        si

        find_destructure_member_retries_legacy_backtick_name() is
            @test()

            // get_destructure_member_name(0) is the bare index "0"; no
            // member has that name, so the retry falls back to the
            // legacy "`0" spelling and resolves it.
            let t = legacy_positional_class().type;

            Assert.is_not_null(t.find_destructure_member(0));
        si

        bare_index_is_positional() is
            @test()

            Assert.is_true(Symbol.is_positional_member_name("0"));
            Assert.is_true(Symbol.is_positional_member_name("12"));
        si

        empty_name_is_not_positional() is
            @test()

            Assert.is_false(Symbol.is_positional_member_name(""));
        si

        name_with_non_digit_is_not_positional() is
            @test()

            Assert.is_false(Symbol.is_positional_member_name("1a"));
            Assert.is_false(Symbol.is_positional_member_name("abc"));
        si

        backtick_prefixed_index_is_not_positional() is
            @test()

            // The legacy spelling carries the backtick; the recognizer
            // matches the bare index only.
            Assert.is_false(Symbol.is_positional_member_name("`0"));
        si
    si
si
