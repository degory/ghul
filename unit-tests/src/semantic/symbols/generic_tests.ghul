namespace Semantic.Symbols.UnitTests is
    use System.Text.StringBuilder;

    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;

    // Tests for GENERIC.gen_actual_type_arguments — the constructed-generic
    // type-argument emitter (e.g. the `<...,...>` part of
    // `class Lib.FooBase\`2<class System.Object, class Lib.Foo>::method`).
    // It iterates `arguments` and delegates to each one's `gen_type`, so the
    // emitted shape is purely a function of (a) iteration order and (b) what
    // each argument's gen_type writes. These tests anchor both, including
    // the comma separation between arguments.
    class GENERIC_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        types_of(a: GenericArgument, b: GenericArgument) -> LIST[Type] is
            let result = LIST[Type]();
            result.add(a.type);
            result.add(b.type);
            return result;
        si

        Calling__gen_actual_type_arguments__should_emit_each_arguments_gen_type_separated_by_commas() is
            @test()

            // A two-parameter generic class.
            let owner = CLASS(loc(), loc(), null, "Outer", names_for(["T", "U"]), false, null);

            // Two arguments — each writes its own indexed reference via gen_type.
            let arg_a = CLASSY_GENERIC_ARGUMENT(loc(), null, "A", 0);
            let arg_b = CLASSY_GENERIC_ARGUMENT(loc(), null, "B", 1);

            let generic = GENERIC(loc(), owner, types_of(arg_a, arg_b));

            let buffer = StringBuilder();
            generic.gen_actual_type_arguments(buffer);

            // Indexed references separated by a comma — the shape the CLR
            // requires for a constructed-type spec inside a methodref.
            Assert.are_equal("!0 ,!1 ", buffer.to_string());
        si

        Calling__gen_actual_type_arguments__should_walk_arguments_in_iteration_order() is
            @test()

            let owner = CLASS(loc(), loc(), null, "Outer", names_for(["T", "U"]), false, null);

            // Deliberately swap the parameter indices to verify iteration
            // order, not numeric order, is what the emitter follows.
            let arg_high = CLASSY_GENERIC_ARGUMENT(loc(), null, "A", 5);
            let arg_low = CLASSY_GENERIC_ARGUMENT(loc(), null, "B", 0);

            let generic = GENERIC(loc(), owner, types_of(arg_high, arg_low));

            let buffer = StringBuilder();
            generic.gen_actual_type_arguments(buffer);

            Assert.are_equal("!5 ,!0 ", buffer.to_string());
        si
    si
si
