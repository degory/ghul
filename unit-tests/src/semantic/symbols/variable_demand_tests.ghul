namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;

    use Semantic.Types.Type;

    use Semantic.MEMBER_DEMAND;

    // Tests for the demand-discharge integration in
    // `Variable.try_get_inferred_type`. The demand accumulator is
    // only useful when the inferred-type lookup *actually consults
    // it* — pin the contract here so future refactors of the LUB
    // pipeline can't silently bypass the demand filter.
    //
    // These tests deliberately avoid constructing class-with-members
    // fixtures because the existing `MEMBER_DEMAND_TESTS` already
    // pins the discharge function's per-candidate semantics — what
    // we're testing here is that `try_get_inferred_type` calls
    // `try_discharge` on every accumulated demand and rejects when
    // any returns false.
    class VARIABLE_DEMAND_INTEGRATION_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        // Baseline: with a LUB constraint and no demands, the
        // resolution returns the LUB result as before. This pins
        // the "demand-free path unchanged" contract.
        With_a_constraint_and_no_demands__try_get_inferred_type__should_return_the_LUB_result() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_true(origin.add_constraint(c.type));

            Assert.are_same(c.type, origin.try_get_inferred_type());
        si

        // With a demand that rejects the LUB candidate, the lookup
        // returns null even though the LUB has a concrete result.
        // This is the key behaviour change introduced by demand-
        // driven inference: a candidate that doesn't expose the
        // demanded operation is NOT a valid resolution.
        With_a_demand_that_rejects_the_LUB_candidate__try_get_inferred_type__should_return_null() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_true(origin.add_constraint(c.type));
            Assert.is_true(origin.add_demand(MEMBER_DEMAND("nonexistent")));

            Assert.is_null(origin.try_get_inferred_type());
        si

        // No constraint at all: today returns null (nothing in the
        // LUB to widen toward). Adding demands without a constraint
        // doesn't fabricate a candidate.
        With_no_constraint_and_a_demand__try_get_inferred_type__should_return_null() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");

            Assert.is_true(origin.add_demand(MEMBER_DEMAND("foo")));

            Assert.is_null(origin.try_get_inferred_type());
        si
    si
si
