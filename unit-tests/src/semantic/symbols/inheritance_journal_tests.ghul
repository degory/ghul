namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Types.Type;

    // Pins the pull-down journal contract: pull_down_super_symbols records
    // every mutation it makes on behalf of a class - members pulled into
    // its store, override links, implementor registrations - and
    // reset_pulled_down_symbols reverses them exactly, leaving the symbol
    // graph as it was before the pull-down so resolve-overrides can run
    // again for that class. Also pins that the override / implementor
    // edge-sets deduplicate.
    class INHERITANCE_JOURNAL_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        int_type() -> Type is
            let int_class = CLASS(loc(), loc(), null, "int", empty_names(), false, null);
            return int_class.type!;
        si

        class_named(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, empty_names(), false, null);

        method(name: string, owner: CLASS, return_type: Type) -> INSTANCE_METHOD is
            let result = INSTANCE_METHOD(loc(), loc(), owner, name, null);

            result.arguments = LIST[Type]();
            result.return_type = return_type;

            return result;
        si

        contains(symbols: Collections.Iterable[Symbol]?, symbol: Symbol) -> bool is
            if !symbols? then
                return false;
            fi

            for s in symbols do
                if s == symbol then
                    return true;
                fi
            od

            return false;
        si

        count(symbols: Collections.Iterable[Symbol]?) -> int is
            if !symbols? then
                return 0;
            fi

            let result mut = 0;

            for s in symbols do
                result = result + 1;
            od

            return result;
        si

        Pull_down_then_reset__restores_the_member_store_and_implementors() is
            @test()

            let return_type = int_type();

            let base = class_named("BASE");
            base.add_member(method("frob", base, return_type));

            let derived = class_named("DERIVED");
            derived.add_ancestor(base.type!);

            derived.pull_down_super_symbols();

            Assert.is_true(derived.find_direct("frob")?, "expected frob pulled down into DERIVED");
            Assert.is_true(contains(base.implementors, derived), "expected DERIVED registered as BASE implementor");

            derived.reset_pulled_down_symbols();

            Assert.is_false(derived.find_direct("frob")?, "expected pulled-down frob removed from DERIVED");
            Assert.is_false(contains(base.implementors, derived), "expected DERIVED removed from BASE implementors");
        si

        Pull_down_after_reset__reproduces_the_first_resolution() is
            @test()

            let return_type = int_type();

            let base = class_named("BASE");
            base.add_member(method("frob", base, return_type));

            let derived = class_named("DERIVED");
            derived.add_ancestor(base.type!);

            derived.pull_down_super_symbols();
            derived.reset_pulled_down_symbols();
            derived.pull_down_super_symbols();

            Assert.is_true(derived.find_direct("frob")?, "expected frob pulled down again after reset");
            Assert.are_equal(1, count(base.implementors), "expected exactly one implementor registration after re-resolve");
        si

        Pull_down_then_reset__unlinks_override_edges() is
            @test()

            let return_type = int_type();

            let base = class_named("BASE");
            let base_method = method("frob", base, return_type);
            base.add_member(base_method);

            let derived = class_named("DERIVED");
            let derived_method = method("frob", derived, return_type);
            derived.add_member(derived_method);
            derived.add_ancestor(base.type!);

            derived.pull_down_super_symbols();

            Assert.is_true(contains(base_method.overriders, derived_method), "expected DERIVED.frob linked as overrider of BASE.frob");
            Assert.is_true(contains(derived_method.overridees, base_method), "expected BASE.frob linked as overridee of DERIVED.frob");

            derived.reset_pulled_down_symbols();

            Assert.is_false(contains(base_method.overriders, derived_method), "expected overrider link removed on reset");
            Assert.is_false(contains(derived_method.overridees, base_method), "expected overridee link removed on reset");
        si

        Add_overrider_twice__keeps_a_single_edge() is
            @test()

            let return_type = int_type();

            let base = class_named("BASE");
            let base_method = method("frob", base, return_type);

            let derived = class_named("DERIVED");
            let derived_method = method("frob", derived, return_type);

            base_method.add_overrider(derived_method);
            base_method.add_overrider(derived_method);

            Assert.are_equal(1, count(base_method.overriders), "expected the duplicate overrider edge deduplicated");
        si

        Add_implementor_twice__keeps_a_single_registration() is
            @test()

            let base = class_named("BASE");
            let derived = class_named("DERIVED");

            base.add_implementor(derived);
            base.add_implementor(derived);

            Assert.are_equal(1, count(base.implementors), "expected the duplicate implementor registration deduplicated");
        si

        Reset_without_a_prior_pull_down__is_a_no_op() is
            @test()

            let derived = class_named("DERIVED");

            derived.reset_pulled_down_symbols();

            Assert.is_false(derived.find_direct("anything")?, "expected no members on an unresolved class");
        si
    si
si
