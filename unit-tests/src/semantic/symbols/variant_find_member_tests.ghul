namespace Semantic.Symbols.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    // Pins the filter rule on `Symbols.VARIANT.find_member` that
    // governs which union-owned members are visible through a
    // variant. The filter hides $-prefixed union internals
    // (e.g. `$get_value` / backing fields) and the legacy
    // default-variant accessor pair (`value`, `has_value`) — every
    // other user-facing union member, notably the auto-properties
    // synthesised from a union primary-constructor header, passes
    // through so variants inherit shared state from the union base.
    //
    // Real compile populates a variant's direct scope with inherited
    // members via the symbol pull-down pass. These tests bypass that
    // by constructing each property with `owner = the union` and
    // declaring it directly on the variant's scope — the filter only
    // gates on the direct_result's owner, so the resulting state is
    // indistinguishable from the post-pull-down configuration and
    // lets each filter branch be exercised in isolation.
    class VARIANT_FIND_MEMBER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        names() -> LIST[string] is
            let result = LIST[string]();
            return result;
        si

        make_union() -> UNION =>
            UNION(loc(), loc(), null, "U", names(), false, null);

        make_variant(`union: UNION) -> VARIANT =>
            VARIANT(loc(), loc(), `union, "V", names(), false, `union);

        union_owned_property_visible_from(variant: VARIANT, `union: UNION, name: string) is
            let p = INSTANCE_PROPERTY(loc(), loc(), `union, name, false, false);
            variant.declare(loc(), p, null);
        si

        Variant_find_member__primary_param_auto_property__visible() is
            @test()

            let u = make_union();
            let v = make_variant(u);

            union_owned_property_visible_from(v, u, "location");

            Assert.is_not_null(v.find_member("location"));
        si

        Variant_find_member__dollar_prefixed_union_member__hidden() is
            @test()

            let u = make_union();
            let v = make_variant(u);

            union_owned_property_visible_from(v, u, "$get_value");

            Assert.is_null(v.find_member("$get_value"));
        si

        Variant_find_member__legacy_value_accessor__hidden() is
            @test()

            let u = make_union();
            let v = make_variant(u);

            union_owned_property_visible_from(v, u, "value");

            Assert.is_null(v.find_member("value"));
        si

        Variant_find_member__legacy_has_value_accessor__hidden() is
            @test()

            let u = make_union();
            let v = make_variant(u);

            union_owned_property_visible_from(v, u, "has_value");

            Assert.is_null(v.find_member("has_value"));
        si

        Variant_find_member__plain_public_union_property__visible() is
            @test()

            let u = make_union();
            let v = make_variant(u);

            union_owned_property_visible_from(v, u, "kind");

            Assert.is_not_null(v.find_member("kind"));
        si

        Variant_find_member__variant_owned_property__visible() is
            @test()

            let u = make_union();
            let v = make_variant(u);

            // Owner is the variant itself — filter only applies when
            // the direct result is union-owned, so variant-own members
            // always pass through regardless of name.
            let p = INSTANCE_PROPERTY(loc(), loc(), v, "value", false, false);
            v.declare(loc(), p, null);

            Assert.is_not_null(v.find_member("value"));
        si

        Variant_find_member__unknown_name__null() is
            @test()

            let u = make_union();
            let v = make_variant(u);

            Assert.is_null(v.find_member("not_a_member"));
        si
    si
si
