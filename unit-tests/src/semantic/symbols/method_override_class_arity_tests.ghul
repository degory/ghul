namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Semantic.METHOD_OVERRIDE_CLASS;

    use Semantic.Types.Type;

    // Pins the arity dimension of METHOD_OVERRIDE_CLASS equality. Two
    // functions whose arguments lists match but whose generic arities
    // differ must hash and compare unequal — that's what lets
    // `foo()` (arity 0) coexist with `foo[T]()` (arity 1) without the
    // duplicate-method checker flagging them.
    class METHOD_OVERRIDE_CLASS_ARITY_TESTS is
        @test()

        init() is si

        empty_args() -> LIST[Type] => LIST[Type]();

        Two_override_classes_with_same_args_and_arity_are_equal() is
            @test()

            let a = METHOD_OVERRIDE_CLASS(empty_args(), 0);
            let b = METHOD_OVERRIDE_CLASS(empty_args(), 0);

            Assert.is_true(a.equals(b));
        si

        Two_override_classes_with_same_args_but_different_arity_are_not_equal() is
            @test()

            let a = METHOD_OVERRIDE_CLASS(empty_args(), 0);
            let b = METHOD_OVERRIDE_CLASS(empty_args(), 1);

            Assert.is_false(a.equals(b));
        si

        Two_override_classes_with_same_arity_at_one_and_two_are_not_equal() is
            @test()

            let a = METHOD_OVERRIDE_CLASS(empty_args(), 1);
            let b = METHOD_OVERRIDE_CLASS(empty_args(), 2);

            Assert.is_false(a.equals(b));
        si

        Hash_codes_for_distinct_arities_should_typically_differ() is
            @test()

            let a = METHOD_OVERRIDE_CLASS(empty_args(), 0);
            let b = METHOD_OVERRIDE_CLASS(empty_args(), 1);

            Assert.are_not_equal(a.get_hash_code(), b.get_hash_code());
        si

        Default_init_overload_keeps_arity_at_zero() is
            @test()

            let a = METHOD_OVERRIDE_CLASS(empty_args());

            Assert.are_equal(0, a.generic_arity);
        si
    si
si
