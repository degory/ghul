namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;

    use Semantic.Types.Type;

    // Tests for the upper-bound bucket on Variable. Upper bounds
    // are recorded when a placeholder is passed AS a concretely-
    // typed argument slot — they validate the eventual lower-
    // bound LUB without polluting it. F07's failure mode:
    // treating an upper-bound `object` as a peer LUB candidate
    // dominates a `bool` assignment and widens the variable to
    // object. The fix recorded behaviour pinned here.
    class VARIABLE_UPPER_BOUND_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        // First add of an upper bound carries information and
        // signals progress to the retry loop.
        Adding_a_new_upper_bound__should_return_true() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_true(origin.add_upper_bound(c.type));
        si

        // Duplicate add (same Type instance) is rejected as
        // non-information. Pins the dedup-by-`=~` contract so
        // the retry loop doesn't churn forever on stable upper-
        // bound back-feeds.
        Adding_the_same_upper_bound_twice__should_return_false_the_second_time() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_true(origin.add_upper_bound(c.type));
            Assert.is_false(origin.add_upper_bound(c.type));
        si

        // Null bound never carries information.
        Adding_a_null_upper_bound__should_return_false() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");

            Assert.is_false(origin.add_upper_bound(null));
        si

        // No lower-bound LUB candidate, single upper bound:
        // falls back to the upper bound. Pins the "only signal
        // is an upper bound" preservation case — without this,
        // `let v; g(v)` where g takes object would stop inferring
        // and break otherwise-working code that has only an
        // upper-bound signal.
        With_no_lower_bound_and_a_single_upper_bound__try_get_inferred_type__should_return_the_upper_bound() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_true(origin.add_upper_bound(c.type));
            Assert.are_same(c.type, origin.try_get_inferred_type());
        si

        // No lower-bound LUB candidate, multiple upper bounds:
        // returns null. Conservative — no narrowest-of-uppers
        // heuristic yet. Surfaces if a future change adds GLB-
        // style multi-upper resolution.
        With_no_lower_bound_and_multiple_upper_bounds__try_get_inferred_type__should_return_null() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c1 = CLASS(loc(), loc(), null, "C1", empty_names(), false, null);
            let c2 = CLASS(loc(), loc(), null, "C2", empty_names(), false, null);

            Assert.is_true(origin.add_upper_bound(c1.type));
            Assert.is_true(origin.add_upper_bound(c2.type));

            Assert.is_null(origin.try_get_inferred_type());
        si

        // Lower-bound LUB candidate matches its own upper-bound
        // entry (same type both directions): validation accepts.
        // Trivial case but pins the "no spurious rejection" path.
        With_matching_lower_and_upper_bound__try_get_inferred_type__should_return_the_candidate() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_true(origin.add_constraint(c.type));
            Assert.is_true(origin.add_upper_bound(c.type));

            Assert.are_same(c.type, origin.try_get_inferred_type());
        si

        // LUB candidate NOT assignable to an upper bound:
        // returns null. The F07 failure-mode test in fixture
        // form: a placeholder asked to be both C1 (lower) and
        // C2 (upper) when the two are unrelated must surface as
        // unresolved rather than picking either silently.
        With_lower_bound_not_assignable_to_upper_bound__try_get_inferred_type__should_return_null() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T");
            let c1 = CLASS(loc(), loc(), null, "C1", empty_names(), false, null);
            let c2 = CLASS(loc(), loc(), null, "C2", empty_names(), false, null);

            Assert.is_true(origin.add_constraint(c1.type));
            Assert.is_true(origin.add_upper_bound(c2.type));

            Assert.is_null(origin.try_get_inferred_type());
        si
    si
si
