namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.METHOD_OVERRIDE_MAP;
    use Semantic.Symbols.Symbol;
    use Semantic.Symbols.CLASS;

    // Pins the two stateful invariants METHOD_OVERRIDE_MAP relies on for the
    // override-resolution hot path: the memoized `symbols` projection must not
    // go stale across a mutation, and the shared empty sentinel must stay empty.
    class METHOD_OVERRIDE_MAP_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        a_symbol(name: string) -> Symbol =>
            CLASS(loc(), loc(), null, name, LIST[string](), false, null);

        symbols_reflects_a_symbol_added_after_a_prior_read() is
            @test()

            let map = METHOD_OVERRIDE_MAP("m");

            map.add(a_symbol("A"));

            // Read once to populate the memoized projection.
            Assert.are_equal(1, map.symbols | .count());

            map.add(a_symbol("B"));

            // The second add must have invalidated the cache.
            Assert.are_equal(2, map.symbols | .count());
        si

        empty_sentinel_is_empty_and_safe_to_read() is
            @test()

            let empty = METHOD_OVERRIDE_MAP.empty;

            Assert.is_false(empty.contains_any_methods);
            Assert.is_false(empty.contains_any_symbols);
            Assert.is_null(empty.first_symbol);
            Assert.are_equal(0, empty.symbols | .count());
        si
    si
si
