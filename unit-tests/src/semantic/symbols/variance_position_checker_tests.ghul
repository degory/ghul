namespace Semantic.Symbols.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    use Semantic.Types.TypeVariance;

    // Tests for VARIANCE_POSITION_CHECKER's variance algebra — `compose`
    // (the required variance of a position descended through a generic
    // argument's own variance) and `flip`. The end-to-end position
    // checking is covered by the variance integration tests.
    class VARIANCE_POSITION_CHECKER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        checker() -> VARIANCE_POSITION_CHECKER =>
            VARIANCE_POSITION_CHECKER(
                TRAIT(loc(), loc(), null, "A_TRAIT", LIST[string](), false, null),
                DIAGNOSTICS_STORE()
            );

        Composing_covariant_through_covariant_stays_covariant() is
            @test()
            Assert.is_true(checker().compose(TypeVariance.COVARIANT, TypeVariance.COVARIANT) == TypeVariance.COVARIANT);
        si

        Composing_covariant_through_contravariant_flips_to_contravariant() is
            @test()
            Assert.is_true(checker().compose(TypeVariance.COVARIANT, TypeVariance.CONTRAVARIANT) == TypeVariance.CONTRAVARIANT);
        si

        Composing_contravariant_through_contravariant_flips_to_covariant() is
            @test()
            Assert.is_true(checker().compose(TypeVariance.CONTRAVARIANT, TypeVariance.CONTRAVARIANT) == TypeVariance.COVARIANT);
        si

        Composing_through_an_invariant_argument_is_invariant() is
            @test()
            Assert.is_true(checker().compose(TypeVariance.COVARIANT, TypeVariance.INVARIANT) == TypeVariance.INVARIANT);
        si

        Composing_within_an_invariant_position_stays_invariant() is
            @test()
            Assert.is_true(checker().compose(TypeVariance.INVARIANT, TypeVariance.COVARIANT) == TypeVariance.INVARIANT);
        si

        Flipping_covariant_gives_contravariant() is
            @test()
            Assert.is_true(checker().flip(TypeVariance.COVARIANT) == TypeVariance.CONTRAVARIANT);
        si

        Flipping_contravariant_gives_covariant() is
            @test()
            Assert.is_true(checker().flip(TypeVariance.CONTRAVARIANT) == TypeVariance.COVARIANT);
        si

        Flipping_invariant_stays_invariant() is
            @test()
            Assert.is_true(checker().flip(TypeVariance.INVARIANT) == TypeVariance.INVARIANT);
        si
    si
si
