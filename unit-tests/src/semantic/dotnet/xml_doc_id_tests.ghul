namespace Semantic.DotNet.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Semantic.DotNet.XML_DOC_ID;

    // Pins the C# XML doc-ID format computed from reflected
    // `MethodInfo`s. These are the keys JetBrains
    // ExternalAnnotations uses in its XML; getting them wrong
    // silently drops every matched purity classification.
    //
    // What's covered: simple methods, primitive-type parameters,
    // empty parameter lists, and single-dim array parameters.
    class XML_DOC_ID_TESTS is
        @test()

        init() is si

        math_abs_int_doc_id__is_canonical_form() is
            @test()

            let int_type = System.Type.get_type("System.Int32")!;
            let method = System.Type.get_type("System.Math").get_method("Abs", [int_type]);
            let actual = XML_DOC_ID.for_method(method!);
            Assert.are_equal("M:System.Math.Abs(System.Int32)", actual);
        si

        math_abs_long_doc_id__uses_Int64() is
            @test()

            let long_type = System.Type.get_type("System.Int64")!;
            let method = System.Type.get_type("System.Math").get_method("Abs", [long_type]);
            let actual = XML_DOC_ID.for_method(method!);
            Assert.are_equal("M:System.Math.Abs(System.Int64)", actual);
        si

        string_substring_two_arg_doc_id__lists_both_params() is
            @test()

            let int_type = System.Type.get_type("System.Int32")!;
            let method = System.Type.get_type("System.String").get_method("Substring", [int_type, int_type]);
            let actual = XML_DOC_ID.for_method(method!);
            Assert.are_equal("M:System.String.Substring(System.Int32,System.Int32)", actual);
        si

        no_args_method_doc_id__has_no_parens() is
            @test()

            let no_args = System.Array.empty`[System.Type]();
            let method = System.Type.get_type("System.String").get_method("GetHashCode", no_args);
            let actual = XML_DOC_ID.for_method(method!);
            Assert.are_equal("M:System.String.GetHashCode", actual);
        si

        single_dim_array_param_doc_id__has_bracket_suffix() is
            @test()

            let str_type = System.Type.get_type("System.String")!;
            let str_array_type = System.Type.get_type("System.String[]")!;
            let method = str_type.get_method("Join", [str_type, str_array_type]);
            let actual = XML_DOC_ID.for_method(method!);
            Assert.are_equal("M:System.String.Join(System.String,System.String[])", actual);
        si

        constructed_generic_param_drops_arity_backtick() is
            @test()

            // The C# doc-comment ID grammar drops `` `N `` from
            // the open generic's name when a brace substitution
            // list follows. `List<int>` is
            // `System.Collections.Generic.List{System.Int32}`,
            // never `List`1{System.Int32}`. Skipping this strip
            // means every JB annotation on a method taking a
            // constructed-generic parameter (most of LINQ) silently
            // misses.
            let int_type = System.Type.get_type("System.Int32")!;
            let list_int = System.Type.get_type("System.Collections.Generic.List`1[System.Int32]")!;
            let method = list_int.get_method("Contains", [int_type]);
            let actual = XML_DOC_ID.for_method(method!);
            Assert.are_equal("M:System.Collections.Generic.List{System.Int32}.Contains(System.Int32)", actual);
        si
    si
si
