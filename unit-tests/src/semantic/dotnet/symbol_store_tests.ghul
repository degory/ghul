namespace Semantic.DotNet.UnitTests is
    use TYPE = System.Type;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.Scoped;
    use Semantic.Symbols.NAMESPACE;

    use Semantic.DotNet.SYMBOL_STORE;

    // remove_symbol undoes an add_symbol whose type failed to finish
    // materializing: the by-dotnet-type slot always goes, the shared
    // bare-name slot only when it still points at the same symbol.
    class SYMBOL_STORE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        a_symbol(name: string) -> Scoped =>
            NAMESPACE(loc(), name, null, ".{name}", false);

        remove_symbol_clears_both_the_type_and_name_slots() is
            @test()

            let store = SYMBOL_STORE();
            let symbol = a_symbol("INT");

            store.add_symbol(typeof int, "Foo.INT", symbol);

            Assert.are_same(symbol, store.get_symbol(typeof int));
            Assert.are_same(symbol, store.get_symbol("Foo.INT"));

            store.remove_symbol(typeof int, "Foo.INT", symbol);

            Assert.is_null(store.get_symbol(typeof int));
            Assert.is_null(store.get_symbol("Foo.INT"));
        si

        remove_symbol_leaves_a_shared_name_slot_owned_by_another_type() is
            @test()

            let store = SYMBOL_STORE();

            // Argument-count overloading: two reflected types stripped to
            // the same ghul name. The first to be added owns the bare-name
            // slot (add_symbol is first-wins on the name).
            let first = a_symbol("PAIR");
            let second = a_symbol("PAIR");

            store.add_symbol(typeof int, "Bar.PAIR", first);
            store.add_symbol(typeof string, "Bar.PAIR", second);

            Assert.are_same(first, store.get_symbol("Bar.PAIR"));

            // Rolling back the second type must not evict the first's
            // ownership of the shared name.
            store.remove_symbol(typeof string, "Bar.PAIR", second);

            Assert.is_null(store.get_symbol(typeof string));
            Assert.are_same(first, store.get_symbol("Bar.PAIR"));
            Assert.are_same(first, store.get_symbol(typeof int));
        si
    si
si
