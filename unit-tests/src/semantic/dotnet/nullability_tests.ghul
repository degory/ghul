namespace Semantic.DotNet.UnitTests is
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;

    use Semantic.Types.Type;

    use Semantic.DotNet.NULLABILITY;

    // Tests for the NullableAttribute carrier. The byte tree the
    // emitter writes is the same one the importer walks, so an
    // off-by-one in either direction silently regresses cross-
    // assembly `?` round-trip on every reference-typed slot.
    class NULLABILITY_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        bytes(values: int[]) -> LIST[int] is
            let result = LIST[int]();

            for v in values do
                result.add(v);
            od

            return result;
        si

        Calling__gen_attribute_blob_for_bytes__with_single_oblivious__should_render_zero() is
            @test()

            Assert.are_equal(
                "( 01 00 00 00 00 )",
                NULLABILITY.gen_attribute_blob_for_bytes(bytes([0]))
            );
        si

        Calling__gen_attribute_blob_for_bytes__with_single_non_optional__should_render_one() is
            @test()

            Assert.are_equal(
                "( 01 00 01 00 00 )",
                NULLABILITY.gen_attribute_blob_for_bytes(bytes([1]))
            );
        si

        Calling__gen_attribute_blob_for_bytes__with_single_optional__should_render_two() is
            @test()

            Assert.are_equal(
                "( 01 00 02 00 00 )",
                NULLABILITY.gen_attribute_blob_for_bytes(bytes([2]))
            );
        si

        Calling__gen_attribute_blob_for_bytes__with_single_byte_max__should_render_FF() is
            @test()

            Assert.are_equal(
                "( 01 00 FF 00 00 )",
                NULLABILITY.gen_attribute_blob_for_bytes(bytes([255]))
            );
        si

        Calling__gen_attribute_blob_for_bytes__with_above_byte_range__should_mask_to_byte() is
            @test()

            Assert.are_equal(
                "( 01 00 00 00 00 )",
                NULLABILITY.gen_attribute_blob_for_bytes(bytes([256]))
            );
        si

        Calling__gen_attribute_blob_for_bytes__with_two_bytes__should_emit_byte_array_form() is
            @test()

            Assert.are_equal(
                "( 01 00 02 00 00 00 01 02 00 00 )",
                NULLABILITY.gen_attribute_blob_for_bytes(bytes([1, 2]))
            );
        si

        Calling__gen_attribute_blob_for_bytes__with_three_bytes__should_emit_byte_array_form() is
            @test()

            Assert.are_equal(
                "( 01 00 03 00 00 00 01 02 02 00 00 )",
                NULLABILITY.gen_attribute_blob_for_bytes(bytes([1, 2, 2]))
            );
        si

        Calling__gen_attribute_line_for_bytes__with_single_byte__should_pick_uint8_ctor() is
            @test()

            Assert.are_equal(
                ".custom instance void [System.Runtime]System.Runtime.CompilerServices.NullableAttribute::.ctor(uint8) = ( 01 00 02 00 00 )",
                NULLABILITY.gen_attribute_line_for_bytes(bytes([2]))
            );
        si

        Calling__gen_attribute_line_for_bytes__with_multiple_bytes__should_pick_uint8_array_ctor() is
            @test()

            Assert.are_equal(
                ".custom instance void [System.Runtime]System.Runtime.CompilerServices.NullableAttribute::.ctor(uint8[]) = ( 01 00 02 00 00 00 01 02 00 00 )",
                NULLABILITY.gen_attribute_line_for_bytes(bytes([1, 2]))
            );
        si

        Calling__read_bytes__with_null_attributes__should_return_null() is
            @test()

            Assert.is_null(NULLABILITY.read_bytes(null));
        si

        Calling__read_bytes__with_empty_attributes__should_return_null() is
            @test()

            let empty = LIST[System.Reflection.CustomAttributeData]();

            Assert.is_null(NULLABILITY.read_bytes(empty));
        si

        Calling__needs_attribute__with_null_type__should_return_false() is
            @test()

            Assert.is_false(NULLABILITY.needs_attribute(null));
        si

        Calling__needs_attribute__with_non_optional_reference_type__should_return_false() is
            @test()

            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);

            Assert.is_false(NULLABILITY.needs_attribute(c.type));
        si

        Calling__needs_attribute__with_optional_reference_type__should_return_true() is
            @test()

            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);
            let optional = c.type.as_optional_unchecked();

            Assert.is_true(NULLABILITY.needs_attribute(optional));
        si

        Calling__compute_bytes__on_non_optional_reference__should_emit_single_one() is
            @test()

            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);
            let result = NULLABILITY.compute_bytes(c.type);

            Assert.are_equal(1, result.count);
            Assert.are_equal(1, result[0]);
        si

        Calling__compute_bytes__on_optional_reference__should_emit_single_two() is
            @test()

            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);
            let optional = c.type.as_optional_unchecked();
            let result = NULLABILITY.compute_bytes(optional);

            Assert.are_equal(1, result.count);
            Assert.are_equal(2, result[0]);
        si

        names_for_t() -> LIST[string] is
            let result = LIST[string]();
            result.add("T");
            return result;
        si

        // Construct a `Box[arg]` GENERIC for the nested-walk tests.
        // Mirrors the under_determination_detector_tests pattern: a
        // single-parameter CLASS wrapped in Types.GENERIC binds `T` to
        // the supplied argument. The CLASSY_GENERIC_ARGUMENT
        // registers `T` on `box` via its constructor — required for
        // the GENERIC constructor's `symbol.is_generic` assert.
        box_of(arg: Type) -> Semantic.Types.GENERIC is
            let box = CLASS(loc(), loc(), null, "Box", names_for_t(), false, null);
            let _t = CLASSY_GENERIC_ARGUMENT(loc(), box, "T", 0);
            let args = LIST[Type]();
            args.add(arg);

            return Semantic.Types.GENERIC(loc(), box, args);
        si

        string_class() -> Type =>
            CLASS(loc(), loc(), null, "string", empty_names(), false, null).type;

        Calling__compute_bytes__on_nested_non_optional__should_emit_one_one() is
            @test()

            let box = box_of(string_class());
            let result = NULLABILITY.compute_bytes(box);

            Assert.are_equal(2, result.count);
            Assert.are_equal(1, result[0]);
            Assert.are_equal(1, result[1]);
        si

        // Pins the "inner `?` survives the round-trip" contract — the
        // case the cross-assembly project test is meant to catch and
        // the off-by-one risk this test class's docstring names. Outer
        // Box is non-`?`, inner is `?`, so the walk should produce
        // `[1, 2]` — the byte[] form the importer reads back.
        Calling__compute_bytes__on_nested_inner_optional__should_emit_one_two() is
            @test()

            let inner_optional = string_class().as_optional_unchecked();
            let box = box_of(inner_optional);
            let result = NULLABILITY.compute_bytes(box);

            Assert.are_equal(2, result.count);
            Assert.are_equal(1, result[0]);
            Assert.are_equal(2, result[1]);
        si

        Calling__compute_bytes__on_nested_outer_optional__should_emit_two_one() is
            @test()

            let box = box_of(string_class());
            let outer_optional = cast Semantic.Types.GENERIC(box.as_optional_unchecked());
            let result = NULLABILITY.compute_bytes(outer_optional);

            Assert.are_equal(2, result.count);
            Assert.are_equal(2, result[0]);
            Assert.are_equal(1, result[1]);
        si

        // Inverse of the compute_bytes nested case: starting from a
        // bare Box[string] (no `?` anywhere) and the importer's bytes
        // `[1, 2]`, the inner string should come back optional and
        // the outer Box should stay non-`?`.
        Calling__apply_bytes__with_inner_only_two__should_flag_only_inner() is
            @test()

            let box = box_of(string_class());

            let bs = LIST[int]();
            bs.add(1);
            bs.add(2);

            let result = NULLABILITY.apply_bytes(box, bs);

            Assert.is_false(result.is_optional);
            Assert.are_equal(1, result.arguments.count);
            Assert.is_true(result.arguments[0].is_optional);
        si

        Calling__apply_bytes__with_outer_only_two__should_flag_only_outer() is
            @test()

            let box = box_of(string_class());

            let bs = LIST[int]();
            bs.add(2);
            bs.add(1);

            let result = NULLABILITY.apply_bytes(box, bs);

            Assert.is_true(result.is_optional);
            Assert.are_equal(1, result.arguments.count);
            Assert.is_false(result.arguments[0].is_optional);
        si

        Calling__apply_bytes__with_both_two__should_flag_both() is
            @test()

            let box = box_of(string_class());

            let bs = LIST[int]();
            bs.add(2);
            bs.add(2);

            let result = NULLABILITY.apply_bytes(box, bs);

            Assert.is_true(result.is_optional);
            Assert.are_equal(1, result.arguments.count);
            Assert.is_true(result.arguments[0].is_optional);
        si

        // Single-byte attributes broadcast to every position — the
        // CLR-standard collapse the importer must mirror.
        Calling__apply_bytes__with_single_two_byte__should_broadcast_to_all_positions() is
            @test()

            let box = box_of(string_class());

            let bs = LIST[int]();
            bs.add(2);

            let result = NULLABILITY.apply_bytes(box, bs);

            Assert.is_true(result.is_optional);
            Assert.are_equal(1, result.arguments.count);
            Assert.is_true(result.arguments[0].is_optional);
        si

        Calling__apply_bytes__with_single_one_byte__should_leave_unchanged() is
            @test()

            let box = box_of(string_class());

            let bs = LIST[int]();
            bs.add(1);

            let result = NULLABILITY.apply_bytes(box, bs);

            Assert.is_false(result.is_optional);
            Assert.are_equal(1, result.arguments.count);
            Assert.is_false(result.arguments[0].is_optional);
        si

        Calling__apply_bytes__with_null_type__should_return_null() is
            @test()

            let bs = LIST[int]();
            bs.add(2);

            Assert.is_null(NULLABILITY.apply_bytes(null, bs));
        si

        Calling__apply_bytes__with_empty_bytes__should_return_type_unchanged() is
            @test()

            let c = CLASS(loc(), loc(), null, "C", empty_names(), false, null);
            let empty = LIST[int]();

            let result = NULLABILITY.apply_bytes(c.type, empty);

            Assert.is_false(result.is_optional);
        si

        // Closing the loop: bytes computed from a nested optional type
        // should, when applied to the bare equivalent, reproduce the
        // original's optionality layout. An off-by-one in either
        // direction of `_apply_walk`'s index accounting breaks this.
        Calling__compute_then_apply__on_nested_inner_optional__should_round_trip() is
            @test()

            let original_inner = string_class().as_optional_unchecked();
            let original = box_of(original_inner);
            let bs = NULLABILITY.compute_bytes(original);

            let bare = box_of(string_class());
            let recovered = NULLABILITY.apply_bytes(bare, bs);

            Assert.is_false(recovered.is_optional);
            Assert.are_equal(1, recovered.arguments.count);
            Assert.is_true(recovered.arguments[0].is_optional);
        si

        // `compute_broadcast_bytes` walks the CLR `System.Type` tree
        // and feeds `apply_bytes`, which walks the ghūl `Types.Type`
        // tree. The two walks must produce the same number of
        // positions in the same pre-order or the broadcast bytes
        // land on the wrong slots — exactly the case the context
        // fallback exists to feed (BCL slot, `NullableContext` says
        // 2, value-type positions must take 0 anyway).

        Calling__compute_broadcast_bytes__on_reference__should_emit_default_byte() is
            @test()

            let result = NULLABILITY.compute_broadcast_bytes(typeof string, 2);

            Assert.are_equal(1, result.count);
            Assert.are_equal(2, result[0]);
        si

        Calling__compute_broadcast_bytes__on_value_type__should_emit_zero() is
            @test()

            let result = NULLABILITY.compute_broadcast_bytes(typeof int, 2);

            Assert.are_equal(1, result.count);
            Assert.are_equal(0, result[0]);
        si

        Calling__compute_broadcast_bytes__on_generic_with_reference_arg__should_emit_default_default() is
            @test()

            let result = NULLABILITY.compute_broadcast_bytes(typeof Collections.LIST[string], 2);

            Assert.are_equal(2, result.count);
            Assert.are_equal(2, result[0]);
            Assert.are_equal(2, result[1]);
        si

        Calling__compute_broadcast_bytes__on_generic_with_value_arg__should_emit_default_zero() is
            @test()

            let result = NULLABILITY.compute_broadcast_bytes(typeof Collections.LIST[int], 2);

            Assert.are_equal(2, result.count);
            Assert.are_equal(2, result[0]);
            Assert.are_equal(0, result[1]);
        si

        Calling__compute_broadcast_bytes__on_array_of_reference__should_emit_default_default() is
            @test()

            let result = NULLABILITY.compute_broadcast_bytes(typeof string[], 2);

            Assert.are_equal(2, result.count);
            Assert.are_equal(2, result[0]);
            Assert.are_equal(2, result[1]);
        si

        Calling__compute_broadcast_bytes__on_array_of_value__should_emit_default_zero() is
            @test()

            let result = NULLABILITY.compute_broadcast_bytes(typeof int[], 2);

            Assert.are_equal(2, result.count);
            Assert.are_equal(2, result[0]);
            Assert.are_equal(0, result[1]);
        si

        Calling__compute_broadcast_bytes__on_nested_generic__should_emit_default_at_every_reference() is
            @test()

            // `List[List[string]]` — three reference positions, no
            // value type. The pre-order walk must visit outer, inner,
            // then string.
            let result = NULLABILITY.compute_broadcast_bytes(
                typeof Collections.LIST[Collections.LIST[string]],
                2
            );

            Assert.are_equal(3, result.count);
            Assert.are_equal(2, result[0]);
            Assert.are_equal(2, result[1]);
            Assert.are_equal(2, result[2]);
        si

        Calling__compute_broadcast_bytes__on_value_tuple__should_emit_zero_for_struct_head_and_per_field() is
            @test()

            // `ValueTuple[int, string]` is a struct, so head is 0.
            // First field int is value type — 0. Second field string
            // is reference — broadcast 2.
            let result = NULLABILITY.compute_broadcast_bytes(typeof (int, string), 2);

            Assert.are_equal(3, result.count);
            Assert.are_equal(0, result[0]);
            Assert.are_equal(0, result[1]);
            Assert.are_equal(2, result[2]);
        si

        Calling__compute_broadcast_bytes__with_default_one__should_leave_reference_positions_non_optional() is
            @test()

            // Default byte 1 — non-`?`. apply_bytes drives the
            // matching position to byte 1 which means "no opinion
            // overrides the non-optional default" — the result is
            // simply unchanged from a non-optional input.
            let result = NULLABILITY.compute_broadcast_bytes(typeof Collections.LIST[string], 1);

            Assert.are_equal(2, result.count);
            Assert.are_equal(1, result[0]);
            Assert.are_equal(1, result[1]);
        si

        // Alignment: bytes produced from the CLR walk should drive
        // `apply_bytes` against the matching ghūl tree to the right
        // optionality marks.
        Calling__compute_broadcast_bytes__plus_apply_bytes__should_align_on_generic_with_reference_arg() is
            @test()

            // CLR: `LIST[string]` → bytes `[2, 2]`.
            // ghūl: `Box[string]` (same shape) — apply gives both
            // optional.
            let bytes = NULLABILITY.compute_broadcast_bytes(typeof Collections.LIST[string], 2);
            let bare = box_of(string_class());
            let result = NULLABILITY.apply_bytes(bare, bytes);

            Assert.is_true(result.is_optional);
            Assert.are_equal(1, result.arguments.count);
            Assert.is_true(result.arguments[0].is_optional);
        si
    si
si
