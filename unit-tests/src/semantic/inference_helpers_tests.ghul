namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.INFERENCE_HELPERS;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Symbols.FUNCTION_GENERIC_ARGUMENT;
    use Semantic.Symbols.Symbol;
    use Semantic.Symbols.UNION;
    use Semantic.Symbols.VARIANT;

    use Semantic.Types.GENERIC;
    use Semantic.Types.Type;

    // INFERENCE_HELPERS pins two pure helpers used by the
    // placeholder-formal match propagation (COMPILE_CALLS.visit_call) and the
    // closure-arg inference path (CLOSURE_ARG_RESOLVER): widening a
    // union-variant to its declaring union, and collecting the
    // method-level type-variables embedded in a Type.
    class INFERENCE_HELPERS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        names_for_T() -> LIST[string] is
            let result = LIST[string]();
            result.add("T");
            return result;
        si

        int_class() -> CLASS => CLASS(loc(), loc(), null, "int", empty_names(), false, null);

        // === widen_variant_to_union ===

        // Null is a no-op — the call site may pass a half-resolved
        // type and the helper must not NRE.
        Calling__widen_variant_to_union__with_null__returns_null() is
            @test()

            Assert.is_null(INFERENCE_HELPERS.widen_variant_to_union(null));
        si

        // A plain non-variant concrete class type passes through.
        Calling__widen_variant_to_union__with_a_non_variant_class__returns_the_class() is
            @test()

            let t = int_class().type;
            Assert.are_same(t, INFERENCE_HELPERS.widen_variant_to_union(t));
        si

        // Build the variant/union shape:
        //   union List[T] is
        //       NIL;
        //       CONS(head: T, tail: List[T]);
        //   si
        // Each variant's parent ancestor is the specialised
        // `List[T_var]` where `T_var` is the variant's own type
        // parameter — this mirrors what `declare-symbols` records in
        // production. With that wiring, `Symbols.GENERIC.get_ancestor`
        // can substitute the call-site type-arg through the variant's
        // type-map to produce the specialised union.
        build_list_union() -> (union_symbol: UNION, cons_symbol: VARIANT, nil_symbol: VARIANT) is
            let union_symbol = UNION(loc(), loc(), null, "List", names_for_T(), false, null);

            let cons_symbol = VARIANT(loc(), loc(), null, "CONS", names_for_T(), false, null);
            let cons_t = CLASSY_GENERIC_ARGUMENT(loc(), cons_symbol, "T", 0);
            cons_symbol.add_ancestor(cast Type(GENERIC(loc(), union_symbol, types(cons_t.type))));

            let nil_symbol = VARIANT(loc(), loc(), null, "NIL", names_for_T(), false, null);
            let nil_t = CLASSY_GENERIC_ARGUMENT(loc(), nil_symbol, "T", 0);
            nil_symbol.add_ancestor(cast Type(GENERIC(loc(), union_symbol, types(nil_t.type))));

            return (union_symbol, cons_symbol, nil_symbol);
        si

        Calling__widen_variant_to_union__with_a_named_variant__returns_the_declaring_union() is
            @test()

            let h = build_list_union();
            let widened = INFERENCE_HELPERS.widen_variant_to_union(h.cons_symbol.type);

            Assert.is_not_null(widened);
            Assert.are_same(h.union_symbol, widened.symbol.root_unspecialized_symbol);
        si

        // A generic wrapper over a non-variant passes through. Pin
        // that the variant check guards against widening any generic
        // — only union variants travel up to their declaring union.
        Calling__widen_variant_to_union__on_a_generic_wrapper_of_a_non_variant__returns_the_input() is
            @test()

            let plain = CLASS(loc(), loc(), null, "Box", names_for_T(), false, null);
            let int_t = int_class().type;
            let box_of_int = cast Type(GENERIC(loc(), plain, types(int_t)));

            Assert.are_same(box_of_int, INFERENCE_HELPERS.widen_variant_to_union(box_of_int));
        si

        // The motivating case: a specialised variant `CONS[int]` widens
        // to the specialised union `List[int]` carrying the same
        // type-arg substitution. Exercises the `Symbols.GENERIC` cast,
        // is_variant detection, and the specialised-ancestor lookup —
        // the production shape `let xs = CONS(...)` produces and the
        // match propagation site widens before recording onto a lambda-arg
        // placeholder.
        Calling__widen_variant_to_union__with_a_specialised_variant__returns_the_specialised_union() is
            @test()

            let h = build_list_union();
            let int_t = int_class().type;

            let cons_of_int = cast Type(GENERIC(loc(), h.cons_symbol, types(int_t)));
            let widened = INFERENCE_HELPERS.widen_variant_to_union(cons_of_int);

            Assert.is_not_null(widened);
            let widened_generic = cast GENERIC(widened);
            Assert.is_not_null(widened_generic);
            Assert.are_same(h.union_symbol, widened_generic.symbol.root_unspecialized_symbol);
            Assert.are_equal(1, widened_generic.arguments.count);
            Assert.are_same(int_t, widened_generic.arguments[0]);
        si

        // === collect_method_level_type_variables ===

        // Concrete-only types contribute nothing.
        Calling__collect_method_level_type_variables__on_a_concrete_class__returns_empty() is
            @test()

            let result = LIST[Symbol]();
            INFERENCE_HELPERS.collect_method_level_type_variables(int_class().type, result);

            Assert.are_equal(0, result.count);
        si

        // Class-level type variables (CLASSY_GENERIC_ARGUMENT) are
        // explicitly excluded — the closure's enclosing instance
        // carries them via `!N`, not `!!N`.
        Calling__collect_method_level_type_variables__on_a_class_level_type_variable__returns_empty() is
            @test()

            let host = CLASS(loc(), loc(), null, "Host", names_for_T(), false, null);
            let t = CLASSY_GENERIC_ARGUMENT(loc(), host, "T", 0);

            let result = LIST[Symbol]();
            INFERENCE_HELPERS.collect_method_level_type_variables(t.type, result);

            Assert.are_equal(0, result.count);
        si

        // A method-level type variable IS collected. Mirrors the
        // shape `f[T](x: T)` where `T` is a method-generic argument.
        Calling__collect_method_level_type_variables__on_a_method_level_type_variable__returns_it() is
            @test()

            let function_t = FUNCTION_GENERIC_ARGUMENT(loc(), null, "T", 0);

            let result = LIST[Symbol]();
            INFERENCE_HELPERS.collect_method_level_type_variables(function_t.type, result);

            Assert.are_equal(1, result.count);
            Assert.are_same(function_t, result[0]);
        si

        // Recurses into a generic's arguments — the `T` of `List[T]`
        // when `T` is a method-generic param shows up in the output.
        Calling__collect_method_level_type_variables__inside_a_generic__returns_inner_method_T() is
            @test()

            let h = build_list_union();
            let function_t = FUNCTION_GENERIC_ARGUMENT(loc(), null, "T", 0);

            let list_of_method_t = cast Type(GENERIC(loc(), h.union_symbol, types(function_t.type)));

            let result = LIST[Symbol]();
            INFERENCE_HELPERS.collect_method_level_type_variables(list_of_method_t, result);

            Assert.are_equal(1, result.count);
            Assert.are_same(function_t, result[0]);
        si

        types(a: Type) -> LIST[Type] is
            let result = LIST[Type]();
            result.add(a);
            return result;
        si
    si
si
