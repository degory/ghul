namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use NSubstitute;
    use NSubstitute.SubstituteExtensions.returns;

    use Source.LOCATION;

    use Semantic.Scope;

    use Semantic.Symbols.Symbol;
    use Semantic.Symbols.NAMESPACE;
    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.GENERIC;
    use Semantic.Symbols.INSTANCE_METHOD;
    use Semantic.Symbols.GLOBAL_FUNCTION;
    use Semantic.Symbols.LABEL;

    use Semantic.Types.Type;

    // Exercises Symbol.render_name branch by branch.
    //
    // The render scope is stubbed: `find_enclosing` is the only thing the
    // rule asks of it, so a substitute that resolves a chosen name back to
    // a chosen symbol models exactly "this name is in scope here" — the
    // same signal a real scope produces for an in-scope declaration or a
    // `use` import. The symbols under test are real, so their owner chain,
    // name, and qualified_name are the genuine article.
    class RENDER_NAME_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // A real namespace `Semantic.Symbols`. The stored qualified_name
        // carries the leading-dot sentinel that NAMESPACE.qualify strips.
        symbols_namespace() -> NAMESPACE =>
            NAMESPACE(loc(), "Symbols", null, ".Semantic.Symbols", false);

        a_class(owner: Scope) -> CLASS =>
            CLASS(loc(), loc(), owner, "INSTANCE_METHOD", empty_names(), false, null);

        names_for(values: Collections.Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        // A one-argument type: a class named `arg` with no owner, so it
        // renders bare wherever it appears. Used to fill a generic slot.
        arg_type() -> Type =>
            CLASS(loc(), loc(), null, "arg", empty_names(), false, null).type!;

        // A specialised generic `CCCC[arg]` whose head class `CCCC` is
        // owned by the namespace `Semantic.Symbols`.
        a_generic() -> GENERIC is
            let head = CLASS(loc(), loc(), symbols_namespace(), "CCCC", names_for(["T"]), false, null);
            let arguments = LIST[Type]();
            arguments.add(arg_type());
            return GENERIC(loc(), head, arguments);
        si

        // A scope that resolves nothing — models a render position from
        // which the target is not visible.
        empty_scope() -> Scope =>
            Substitute.`for`[Scope](System.Array.empty`[object]());

        // A scope in which `name` resolves back to `symbol`.
        scope_resolving(name: string, symbol: Symbol) -> Scope is
            let scope = Substitute.`for`[Scope](System.Array.empty`[object]());
            scope.find_enclosing(name) |> returns(symbol, null);
            return scope;
        si

        Calling__name_for__with_null_scope__returns_qualified_name() is
            @test()

            let c = a_class(symbols_namespace());

            Assert.are_equal(c.qualified_name, c.render_name(null));
        si

        Calling__name_for__on_in_scope_type__returns_bare_name() is
            @test()

            let c = a_class(symbols_namespace());

            Assert.are_equal("INSTANCE_METHOD", c.render_name(scope_resolving("INSTANCE_METHOD", c)));
        si

        Calling__name_for__on_out_of_scope_type__returns_full_namespace() is
            @test()

            let c = a_class(symbols_namespace());

            Assert.are_equal("Semantic.Symbols.INSTANCE_METHOD", c.render_name(empty_scope()));
        si

        Calling__name_for__on_member_with_in_scope_owner__returns_type_dot_member() is
            @test()

            let c = a_class(symbols_namespace());
            let m = INSTANCE_METHOD(loc(), loc(), c, "describe", null);

            Assert.are_equal("INSTANCE_METHOD.describe", m.render_name(scope_resolving("INSTANCE_METHOD", c)));
        si

        Calling__name_for__on_member_with_out_of_scope_owner__returns_full_path() is
            @test()

            let c = a_class(symbols_namespace());
            let m = INSTANCE_METHOD(loc(), loc(), c, "describe", null);

            Assert.are_equal("Semantic.Symbols.INSTANCE_METHOD.describe", m.render_name(empty_scope()));
        si

        Calling__name_for__on_in_scope_global__returns_bare_name() is
            @test()

            let g = GLOBAL_FUNCTION(loc(), loc(), symbols_namespace(), "write_line", null);

            Assert.are_equal("write_line", g.render_name(scope_resolving("write_line", g)));
        si

        Calling__name_for__on_out_of_scope_global__returns_full_namespace() is
            @test()

            let g = GLOBAL_FUNCTION(loc(), loc(), symbols_namespace(), "write_line", null);

            Assert.are_equal("Semantic.Symbols.write_line", g.render_name(empty_scope()));
        si

        // A symbol owned by a function (local, parameter, or label) is
        // always bare — its owner is neither a type nor a namespace.
        Calling__name_for__on_function_owned_symbol__returns_bare_name() is
            @test()

            let c = a_class(symbols_namespace());
            let m = INSTANCE_METHOD(loc(), loc(), c, "describe", null);
            let label = LABEL(loc(), m, "loop");

            Assert.are_equal("loop", label.render_name(empty_scope()));
        si

        // A specialised generic named on its own shortens only its head;
        // the type arguments are always kept.
        Calling__render_name__on_in_scope_generic__shortens_head_keeps_arguments() is
            @test()

            let g = a_generic();

            Assert.are_equal("CCCC[arg]", g.render_name(scope_resolving("CCCC", g.symbol)));
        si

        Calling__render_name__on_out_of_scope_generic__qualifies_head_keeps_arguments() is
            @test()

            let g = a_generic();

            Assert.are_equal("Semantic.Symbols.CCCC[arg]", g.render_name(empty_scope()));
        si

        // Cause #3: a member whose owner is a specialised generic renders
        // `owner.member`, routed through the owner's own render_name so the
        // head shortens while the arguments stay.
        Calling__render_name__on_member_of_generic_owner__returns_generic_dot_member() is
            @test()

            let g = a_generic();
            let m = INSTANCE_METHOD(loc(), loc(), g, "test", null);

            Assert.are_equal("CCCC[arg].test", m.render_name(scope_resolving("CCCC", g.symbol)));
        si

        // An unspecialized generic classy renders its formal type parameters.
        a_generic_class() -> CLASS =>
            CLASS(loc(), loc(), symbols_namespace(), "BOX", names_for(["T"]), false, null);

        Calling__render_name__on_generic_class__appends_type_parameters() is
            @test()

            let c = a_generic_class();

            Assert.are_equal("BOX[T]", c.render_name(scope_resolving("BOX", c)));
        si

        Calling__render_name__on_member_of_generic_class__keeps_owner_type_parameters() is
            @test()

            let c = a_generic_class();
            let m = INSTANCE_METHOD(loc(), loc(), c, "get", null);

            Assert.are_equal("BOX[T].get", m.render_name(scope_resolving("BOX", c)));
        si
    si
si
