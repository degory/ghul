namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;
    use Logging.Logger;

    use Semantic.BACK_FEED;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;
    use Semantic.Symbols.Variable;

    use Semantic.Types.ERROR;
    use Semantic.Types.GENERIC;
    use Semantic.Types.INFERRED_VARIABLE_TYPE;
    use Semantic.Types.Type;

    // Tests for BACK_FEED — the helper that pushes constraints onto
    // INFERRED_VARIABLE_TYPE placeholder origins by walking paired
    // (formal, actual) types. Extracted from OVERLOAD_RESOLVER once
    // it had three call sites (overload-resolver constructor + fn
    // paths, closure-call path in compile_expressions).
    //
    // The contract being pinned here is small but load-bearing:
    //   - constraints only push to placeholders, never to type
    //     variables (the latter would break #1210 from the other
    //     direction — see project_type_variable_back_feed_load_
    //     bearing memory)
    //   - on a successful constraint push, mark_consumed_any fires
    //     so the iterative body-retry loop knows to walk again
    //   - structural recursion descends paired type-args on
    //     matching-head generics
    //   - ancestor-walk on mismatched-head generics finds the
    //     specialised ancestor whose head matches the formal's
    class BACK_FEED_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();
        names_for_T() -> LIST[string] is
            let result = LIST[string]();
            result.add("T");
            return result;
        si

        // Concrete non-generic class fixtures.
        int_class() -> CLASS => CLASS(loc(), loc(), null, "int", empty_names(), false, null);
        string_class() -> CLASS => CLASS(loc(), loc(), null, "string", empty_names(), false, null);

        // Box[T] fixture — generic owner with one type-arg slot.
        // Returns the CLASS so caller can build GENERIC types over it.
        box_class() -> CLASS => CLASS(loc(), loc(), null, "Box", names_for_T(), false, null);

        phantom(name: string) -> Variable =>
            INFERRED_TYPE_ARG_ORIGIN(loc(), null, name);

        types(a: Type) -> LIST[Type] is
            let result = LIST[Type]();
            result.add(a);
            return result;
        si

        types(a: Type, b: Type) -> LIST[Type] is
            let result = LIST[Type]();
            result.add(a);
            result.add(b);
            return result;
        si

        // === pair: null safety ===

        // Either side null is a noop. Callers in the body-retry loop
        // may pass null when the formal list was shorter than the
        // actual list (or vice versa); back_feed must not NRE.
        Calling__pair__with_null_formal__does_nothing() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            back_feed.pair(null, int_class().type);

            Assert.is_false(logger.has_consumed_any);
        si

        Calling__pair__with_null_actual__does_nothing() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            back_feed.pair(int_class().type, null);

            Assert.is_false(logger.has_consumed_any);
        si

        // === pair: placeholder asymmetric ===

        // Concrete formal + placeholder actual is the lambda-arg
        // back-feed shape: `f(1)` where f's parameter is a placeholder.
        // The formal `int` becomes a constraint on the placeholder's
        // origin, and mark_consumed_any signals progress.
        Calling__pair__with_concrete_formal_and_placeholder_actual__pushes_constraint() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            let origin = phantom("T_lambda");
            let placeholder = cast Type(INFERRED_VARIABLE_TYPE(origin));
            let int_t = int_class().type;

            back_feed.pair(int_t, placeholder);

            Assert.is_true(logger.has_consumed_any);
            Assert.are_same(int_t, origin.try_get_inferred_type());
        si

        // Placeholder formal + concrete actual is the constructor-
        // type-arg back-feed shape: `Box[placeholder].init(42)` where
        // formal is the not-yet-bound owner type-arg and actual is
        // the concrete int. Same push, opposite direction.
        Calling__pair__with_placeholder_formal_and_concrete_actual__pushes_constraint() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            let origin = phantom("T_ctor");
            let placeholder = cast Type(INFERRED_VARIABLE_TYPE(origin));
            let string_t = string_class().type;

            back_feed.pair(placeholder, string_t);

            Assert.is_true(logger.has_consumed_any);
            Assert.are_same(string_t, origin.try_get_inferred_type());
        si

        // === pair: concrete-only cases (no constraint push) ===

        // Both sides concrete, mismatched heads: nothing to push.
        // Pinned because a regression that tried to push int onto
        // string (or vice versa) would corrupt every call site that
        // type-checks with mismatched argument types — the compare
        // already catches them, but back-feed must not interfere.
        Calling__pair__with_two_concrete_non_generic_types__pushes_nothing() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            back_feed.pair(int_class().type, string_class().type);

            Assert.is_false(logger.has_consumed_any);
        si

        // === pair: ERROR / placeholder guards on the other side ===

        // ERROR actual paired with a placeholder formal must not
        // push ERROR as a constraint — that would poison the
        // placeholder. add_constraint also guards (`constraint.is_
        // error` check), but pinning here keeps the BACK_FEED side's
        // pre-check honest.
        Calling__pair__with_placeholder_formal_and_ERROR_actual__pushes_nothing() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            let origin = phantom("T_safe");
            let placeholder = cast Type(INFERRED_VARIABLE_TYPE(origin));
            let err = cast Type(ERROR());

            back_feed.pair(placeholder, err);

            Assert.is_false(logger.has_consumed_any);
            Assert.is_null(origin.try_get_inferred_type());
        si

        // Type-variable formal + concrete actual must not push the
        // concrete actual as a constraint on the placeholder — there
        // is no placeholder here, the formal is a *type variable*
        // (an unbound generic parameter), not a placeholder. The
        // !is_type_variable guard is load-bearing for the generic-
        // function-argument-type-inference-2 case (see project_type
        // _variable_back_feed_load_bearing memory).
        //
        // Build a CLASSY_GENERIC_ARGUMENT-typed formal to exercise
        // the guard. CLASSY_GENERIC_ARGUMENT's .type IS a type
        // variable. Pairing it with a concrete int should leave
        // mark_consumed_any false.
        Calling__pair__with_type_variable_formal_and_concrete_actual__pushes_nothing() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            let box = box_class();
            let t = CLASSY_GENERIC_ARGUMENT(loc(), box, "T", 0);
            let int_t = int_class().type;

            back_feed.pair(t.type, int_t);

            Assert.is_false(logger.has_consumed_any);
        si

        // === pair: structural recursion on matching-head generics ===

        // Both sides Box[...], one with a concrete int arg, one with
        // a placeholder. The outer heads match so we recurse on the
        // paired type-args: int and the placeholder → push int onto
        // the placeholder's origin. This is the call-arg-as-
        // constraint shape (#1212).
        Calling__pair__with_same_head_generics_and_inner_placeholder__pushes_inner_constraint() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            let box = box_class();
            let int_t = int_class().type;

            let origin = phantom("T_inner");
            let placeholder = cast Type(INFERRED_VARIABLE_TYPE(origin));

            let formal = cast Type(GENERIC(loc(), box, types(int_t)));
            let actual = cast Type(GENERIC(loc(), box, types(placeholder)));

            back_feed.pair(formal, actual);

            Assert.is_true(logger.has_consumed_any);
            Assert.are_same(int_t, origin.try_get_inferred_type());
        si

        // === pair: ancestor-walk for mismatched generic heads ===
        //
        // Actual extends formal's head but the outer heads differ —
        // BACK_FEED walks the actual's specialised ancestors looking
        // for one whose head matches the formal's, then recurses on
        // the formal's args paired against the specialised ancestor's
        // args. The recurse hits the placeholder in the formal's args
        // and pushes the concrete from the ancestor's matching slot.
        //
        // Real-world shape: a constraint `STREAM[<phantom>, int]` is
        // pushed to an `if` whose branches return `STREAM.YIELD[char,
        // int]` (different head, STREAM.YIELD extends STREAM). The
        // back-feed walks YIELD's specialised STREAM[char, int]
        // ancestor and pushes char onto the constraint's phantom slot.
        // Without this leg the placeholder stays unresolved and the
        // outer generic call latches a stale type-arg.
        Calling__pair__with_actual_extending_formals_head__pushes_via_ancestor() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            // STREAM-like generic owner with one type-arg slot.
            let outer = CLASS(loc(), loc(), null, "Outer", names_for_T(), false, null);

            // YIELD-like subclass extending Outer[char].
            let int_t = int_class().type;
            let string_t = string_class().type;

            let sub = CLASS(loc(), loc(), null, "Sub", names_for_T(), false, null);
            sub.add_ancestor(GENERIC(loc(), outer, types(int_t)));

            let origin = phantom("T_phantom");
            let placeholder = cast Type(INFERRED_VARIABLE_TYPE(origin));

            let formal = cast Type(GENERIC(loc(), outer, types(placeholder)));
            let actual = cast Type(GENERIC(loc(), sub, types(string_t)));

            back_feed.pair(formal, actual);

            Assert.is_true(logger.has_consumed_any);
            Assert.are_same(int_t, origin.try_get_inferred_type());
        si

        // === pairs: list-level conveniences ===

        // pairs() truncates to the shorter list — defensive guard
        // for partial overload-resolution cases where a candidate's
        // argument count differs from the actual call's. Pinning so
        // a future "throw on mismatch" change can't sneak in and
        // break the body-retry loop's progress-on-prefix behaviour.
        Calling__pairs__with_more_actuals_than_formals__processes_only_the_prefix() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            let origin = phantom("T_first");
            let placeholder = cast Type(INFERRED_VARIABLE_TYPE(origin));
            let int_t = int_class().type;
            let string_t = string_class().type;

            let formals = types(int_t);
            let actuals = types(placeholder, string_t);

            back_feed.pairs(formals, actuals);

            Assert.is_true(logger.has_consumed_any);
            Assert.are_same(int_t, origin.try_get_inferred_type());
        si

        // Null lists on either side are a noop. Caller protection —
        // _back_feed_constraints used to guard `!chosen.arguments?`
        // before delegating; now it just calls pairs and relies on
        // this null-safety contract.
        Calling__pairs__with_null_formals__does_nothing() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            back_feed.pairs(null, types(int_class().type));

            Assert.is_false(logger.has_consumed_any);
        si

        Calling__pairs__with_null_actuals__does_nothing() is
            @test()

            let logger = DIAGNOSTICS_STORE();
            let back_feed = BACK_FEED(logger);

            back_feed.pairs(types(int_class().type), null);

            Assert.is_false(logger.has_consumed_any);
        si
    si
si
