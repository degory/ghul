namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.SETTLED_PLACEHOLDER_RESOLVER;
    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;
    use Semantic.Types.INFERRED_VARIABLE_TYPE;
    use Semantic.Types.Type;

    // Tests for SETTLED_PLACEHOLDER_RESOLVER — the helper that swaps an
    // inference placeholder for the concrete type its origin settled on,
    // so a composite assembled mid-inference doesn't carry the
    // placeholder into the type that reaches IL emission.
    //
    // The contract has three cases: a settled placeholder collapses, an
    // unsettled one is preserved (it is still gathering constraints), and
    // anything that isn't a placeholder passes through untouched.
    class SETTLED_PLACEHOLDER_RESOLVER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        a_class(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, empty_names(), false, null);

        origin() -> INFERRED_TYPE_ARG_ORIGIN =>
            INFERRED_TYPE_ARG_ORIGIN(loc(), null, "p");

        Calling__resolve__on_a_non_placeholder__should_return_it_unchanged() is
            @test()

            let cat = a_class("cat");
            let resolver = SETTLED_PLACEHOLDER_RESOLVER();

            Assert.are_same(cat.type!, resolver.resolve(cat.type!));
        si

        Calling__resolve__on_an_unsettled_placeholder__should_return_the_placeholder() is
            @test()

            let placeholder = INFERRED_VARIABLE_TYPE(origin());
            let resolver = SETTLED_PLACEHOLDER_RESOLVER();

            Assert.are_same(placeholder, resolver.resolve(placeholder));
        si

        Calling__resolve__on_a_settled_placeholder__should_return_the_settled_type() is
            @test()

            let cat = a_class("cat");
            let o = origin();

            o.add_lower_bound(cat.type!);

            let placeholder = INFERRED_VARIABLE_TYPE(o);
            let resolver = SETTLED_PLACEHOLDER_RESOLVER();

            Assert.are_same(cat.type!, resolver.resolve(placeholder));
        si

        Calling__resolve_all__should_collapse_only_the_settled_placeholders() is
            @test()

            let cat = a_class("cat");
            let dog = a_class("dog");

            let settled_origin = origin();
            settled_origin.add_lower_bound(dog.type!);

            let settled = INFERRED_VARIABLE_TYPE(settled_origin);
            let unsettled = INFERRED_VARIABLE_TYPE(origin());

            let resolver = SETTLED_PLACEHOLDER_RESOLVER();
            let result = resolver.resolve_all(LIST[Type]([cat.type!, settled, unsettled]));

            Assert.are_equal(3, result.count);
            Assert.are_same(cat.type!, result[0]);
            Assert.are_same(dog.type!, result[1]);
            Assert.are_same(unsettled, result[2]);
        si
    si
si
