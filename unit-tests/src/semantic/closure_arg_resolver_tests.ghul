namespace Semantic.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    use Semantic.CLOSURE_ARG_RESOLVER;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Symbols.Closure;
    use Semantic.Symbols.Symbol;

    use Semantic.Types.GENERIC;
    use Semantic.Types.Type;

    // Tests for CLOSURE_ARG_RESOLVER — extracted from
    // compile_expressions._visit(function) to focus the closure
    // arg-resolution loop and its in-scope-typevar guard.
    //
    // The branches `resolve()` itself selects between (symbol-
    // already-typed, written-type-expression, implied-usable,
    // inference-fallback) are exercised end-to-end by integration
    // tests under `integration-tests/execution/`. This unit fixture
    // pins the load-bearing predicate underneath:
    // `_is_implied_type_usable` / `_is_type_variable_in_scope`.
    // Those gate whether an implied type from the outer context
    // can be installed as-is or must fall through to iterative
    // inference, and the in-scope-vs-foreign distinction is the
    // reason `expect_func_T_U(null, s => s + 1)` infers s = int
    // from the body while `compose[T,U,V](f, g) => x => g(f(x))`
    // accepts T as the lambda's arg type.
    class CLOSURE_ARG_RESOLVER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        types(values: Iterable[Type]) -> LIST[Type] is
            let result = LIST[Type]();
            for v in values do result.add(v); od
            return result;
        si

        int_type() -> Type is
            let int_class = CLASS(loc(), loc(), null, "int", LIST[string](), false, null);
            return int_class.type!;
        si

        // Build a CLASS named `host` with one type-arg `T` registered
        // in its scope via `declare`. The Closure under test will use
        // this class as its enclosing scope, so `find_enclosing("T")`
        // walks closure → host (find_direct) → returns this `t`.
        build_host_with_T() -> (host: CLASS, t: CLASSY_GENERIC_ARGUMENT) is
            let host = CLASS(loc(), loc(), null, "Host", names_for(["T"]), false, null);
            let t = CLASSY_GENERIC_ARGUMENT(loc(), host, "T", 0);
            host.declare(loc(), t, null);
            return (host, t);
        si

        // Construct a Closure whose `enclosing_scope` is the host.
        // Mimics the AST shape `class Host[T] is foo() => (x => x); si`
        // — the lambda visited by _visit(function: FUNCTION) has a
        // chain back to the surrounding generic class.
        closure_in(host: CLASS) -> Closure is
            return Semantic.Symbols.STATIC_CLOSURE(loc(), host, "$anon_0", host, false);
        si

        // A foreign type-variable: same name "T" but owned by a
        // DIFFERENT class. Models the overload-resolution case where
        // a constraint carries the candidate's own type-vars; the
        // closure's enclosing scope doesn't know about them.
        build_foreign_T() -> CLASSY_GENERIC_ARGUMENT is
            let other_class = CLASS(loc(), loc(), null, "OtherClass", names_for(["T"]), false, null);
            let foreign_t = CLASSY_GENERIC_ARGUMENT(loc(), other_class, "T", 0);
            other_class.declare(loc(), foreign_t, null);
            return foreign_t;
        si

        // === _is_type_variable_in_scope ===

        // Null type-variable / null closure are noops returning false.
        // The lambda-arg-resolution path passes a closure that is
        // always non-null, but the helper guards anyway so the
        // contract is total.
        Calling__is_type_variable_in_scope__with_null_type_variable__returns_false() is
            @test()

            let h = build_host_with_T();
            let closure = closure_in(h.host);
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            Assert.is_false(resolver._is_type_variable_in_scope(null, closure));
        si

        Calling__is_type_variable_in_scope__with_null_closure__returns_false() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            Assert.is_false(resolver._is_type_variable_in_scope(t, null));
        si

        // In-scope: the type-variable's name resolves to the SAME
        // symbol via the closure's enclosing-scope chain. This is
        // the compose / box-factory case — the outer formal carries
        // its own type variable as the lambda arg's type.
        Calling__is_type_variable_in_scope__with_enclosing_class_T__returns_true() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let closure = closure_in(host);
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            Assert.is_true(resolver._is_type_variable_in_scope(t, closure));
        si

        // Foreign: same NAME "T" but a different symbol. find_
        // enclosing returns null (or a different-named symbol),
        // so the helper rejects. This is the overload-resolution-
        // constraint case where the candidate's type-vars leaked
        // into the implied type.
        Calling__is_type_variable_in_scope__with_foreign_T__returns_false() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let closure = closure_in(host);
            let foreign_t = build_foreign_T();
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            Assert.is_false(resolver._is_type_variable_in_scope(foreign_t, closure));
        si

        // === _is_implied_type_usable ===

        // Concrete types always usable — there's nothing to scope-
        // check. This is the canonical "Func[int,bool] formal pushes
        // int onto lambda arg" case.
        Calling__is_implied_type_usable__with_concrete_type__returns_true() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let closure = closure_in(host);
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            Assert.is_true(resolver._is_implied_type_usable(int_type(), closure));
        si

        // An in-scope type-variable is usable. The implied type IS
        // a type variable, and it's declared by an ancestor of the
        // closure. Installing it on the symbol lets IL emission
        // generate the corresponding `!!N` slot.
        Calling__is_implied_type_usable__with_in_scope_type_variable__returns_true() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let closure = closure_in(host);
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            Assert.is_true(resolver._is_implied_type_usable(t.type!, closure));
        si

        // A foreign type-variable is rejected — the resolver falls
        // through to the iterative-inference path. Without this
        // rejection, expect_func_T_U(null, s => s + 1) would lock
        // `s` to the candidate's foreign T instead of inferring
        // int from the body.
        Calling__is_implied_type_usable__with_foreign_type_variable__returns_false() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let closure = closure_in(host);
            let foreign_t = build_foreign_T();
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            Assert.is_false(resolver._is_implied_type_usable(foreign_t.type!, closure));
        si

        // The walk recurses into generic type-arguments — a generic
        // containing only in-scope type-vars is usable.
        Calling__is_implied_type_usable__with_generic_of_in_scope_T__returns_true() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let closure = closure_in(host);
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            // Construct LIST[T] using the host's T as the arg. Any
            // generic owner shape works for the walk.
            let list_class = CLASS(loc(), loc(), null, "List", names_for(["T"]), false, null);
            let list_of_t = cast Type(GENERIC(loc(), list_class, types([t.type!])));

            Assert.is_true(resolver._is_implied_type_usable(list_of_t, closure));
        si

        // The walk recurses into generic type-arguments — a generic
        // containing a foreign type-var is rejected. Without the
        // recursion, only direct type-variable-typed args would be
        // gated; an implied type like `Func[ForeignT, bool]` would
        // slip through.
        Calling__is_implied_type_usable__with_generic_of_foreign_T__returns_false() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let closure = closure_in(host);
            let foreign_t = build_foreign_T();
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            let list_class = CLASS(loc(), loc(), null, "List", names_for(["T"]), false, null);
            let list_of_foreign = cast Type(GENERIC(loc(), list_class, types([foreign_t.type!])));

            Assert.is_false(resolver._is_implied_type_usable(list_of_foreign, closure));
        si

        // A generic mixing in-scope and foreign type-vars is
        // rejected — the walk only needs to find ONE foreign T to
        // reject. Pinned because a regression that exited the walk
        // on first in-scope hit would let the foreign side through.
        Calling__is_implied_type_usable__with_generic_mixing_in_scope_and_foreign__returns_false() is
            @test()

            let h = build_host_with_T();
            let host = h.host;
            let t = h.t;
            let closure = closure_in(host);
            let foreign_t = build_foreign_T();
            let resolver = CLOSURE_ARG_RESOLVER(DIAGNOSTICS_STORE());

            // Func[T, ForeignT] — both type-vars present in arg slots.
            let func_class = CLASS(loc(), loc(), null, "Func", names_for(["A", "B"]), false, null);
            let mixed = cast Type(GENERIC(loc(), func_class, types([t.type!, foreign_t.type!])));

            Assert.is_false(resolver._is_implied_type_usable(mixed, closure));
        si
    si
si
