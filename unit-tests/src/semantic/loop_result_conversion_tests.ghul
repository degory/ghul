namespace Semantic.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.LOOP_RESULT_CONVERSION;

    use Trees = Syntax.Trees;
    use Syntax.Process.Printer.FORMATTER;

    // Tests for LOOP_RESULT_CONVERSION's static AST builders and
    // type-expression predicates. Pins the shape of the synthesised
    // AST that the async-loop desugar relies on, plus the syntactic
    // recognisers (`try_extract_t_ret`, `is_void_async_return_type`)
    // it uses to classify enclosing function return types.
    class LOOP_RESULT_CONVERSION_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION.internal;

        format(node: Trees.Node) -> string =>
            FORMATTER(Collections.LIST[Lexical.TRIVIA](), 100).format(node);

        // Build a `Tasks.TASK` (non-generic) AST node.
        non_generic_task() -> Trees.TypeExpressions.TypeExpression is
            let task_id =
                Trees.Identifiers.QUALIFIED(
                    loc(),
                    Trees.Identifiers.Identifier(loc(), "Tasks"),
                    "TASK",
                    loc(),
                    loc()
                );
            return Trees.TypeExpressions.NAMED(loc(), task_id);
        si

        // Build a `Tasks.TASK[arg]` AST node.
        generic_task(arg: Trees.TypeExpressions.TypeExpression) -> Trees.TypeExpressions.TypeExpression is
            let task_id =
                Trees.Identifiers.QUALIFIED(
                    loc(),
                    Trees.Identifiers.Identifier(loc(), "Tasks"),
                    "TASK",
                    loc(),
                    loc()
                );
            let args =
                Trees.TypeExpressions.LIST(
                    loc(),
                    Collections.LIST[Trees.TypeExpressions.TypeExpression]([arg]: Trees.TypeExpressions.TypeExpression)
                );
            return Trees.TypeExpressions.GENERIC(loc(), task_id, args);
        si

        // Build a `int` (or similar bare type-name) AST node.
        bare_named(name: string) -> Trees.TypeExpressions.TypeExpression =>
            Trees.TypeExpressions.NAMED(loc(), Trees.Identifiers.Identifier(loc(), name));

        // ---------- build_ghul_async_member ----------

        build_ghul_async_member_produces_two_level_chain() is
            @test()

            let expr = LOOP_RESULT_CONVERSION.build_ghul_async_member(loc(), "_for_async");

            Assert.are_equal("Ghul.Async._for_async\n", format(expr));
        si

        // ---------- build_loop_result_type_value ----------

        build_loop_result_type_value_produces_three_level_chain() is
            @test()

            let expr = LOOP_RESULT_CONVERSION.build_loop_result_type_value(loc(), "RETURN");

            Assert.are_equal("Ghul.Async._LOOP_RESULT_TYPE.RETURN\n", format(expr));
        si

        // ---------- build_continue_expression ----------

        build_continue_expression_for_void_async_omits_t_ret() is
            @test()

            let expr = LOOP_RESULT_CONVERSION.build_continue_expression(loc(), null);

            Assert.are_equal("Ghul.Async._LOOP_RESULT()\n", format(expr));
        si

        build_continue_expression_for_value_async_carries_t_ret() is
            @test()

            let expr = LOOP_RESULT_CONVERSION.build_continue_expression(loc(), bare_named("int"));

            Assert.are_equal("Ghul.Async._LOOP_RESULT[int]()\n", format(expr));
        si

        // ---------- build_return_expression ----------

        build_return_expression_for_void_async_takes_type_only() is
            @test()

            let expr = LOOP_RESULT_CONVERSION.build_return_expression(loc(), null, null);

            Assert.are_equal(
                "Ghul.Async._LOOP_RESULT(Ghul.Async._LOOP_RESULT_TYPE.RETURN)\n",
                format(expr)
            );
        si

        build_return_expression_for_value_async_carries_value_and_t_ret() is
            @test()

            let value_expr =
                Trees.Expressions.Literals.INTEGER(loc(), "42");

            let expr =
                LOOP_RESULT_CONVERSION.build_return_expression(
                    loc(),
                    bare_named("int"),
                    value_expr
                );

            Assert.are_equal(
                "Ghul.Async._LOOP_RESULT[int](Ghul.Async._LOOP_RESULT_TYPE.RETURN, 42)\n",
                format(expr)
            );
        si

        // ---------- try_extract_t_ret ----------

        try_extract_t_ret_returns_null_for_null_input() is
            @test()

            let result = LOOP_RESULT_CONVERSION.try_extract_t_ret(null);

            Assert.is_null(result);
        si

        try_extract_t_ret_returns_null_for_non_generic_tasks_task() is
            @test()

            let result = LOOP_RESULT_CONVERSION.try_extract_t_ret(non_generic_task());

            Assert.is_null(result);
        si

        try_extract_t_ret_returns_inner_arg_for_tasks_task_of_t() is
            @test()

            let int_expr = bare_named("int");
            let result = LOOP_RESULT_CONVERSION.try_extract_t_ret(generic_task(int_expr));

            Assert.is_not_null(result);
            Assert.are_equal("int\n", format(result));
        si

        try_extract_t_ret_returns_null_for_unrelated_generic_type() is
            @test()

            // `Other[int]` — not Tasks.TASK[T], should return null.
            let other_id = Trees.Identifiers.Identifier(loc(), "Other");
            let args =
                Trees.TypeExpressions.LIST(
                    loc(),
                    Collections.LIST[Trees.TypeExpressions.TypeExpression](
                        [bare_named("int")]: Trees.TypeExpressions.TypeExpression
                    )
                );
            let other_generic = Trees.TypeExpressions.GENERIC(loc(), other_id, args);

            let result = LOOP_RESULT_CONVERSION.try_extract_t_ret(other_generic);

            Assert.is_null(result);
        si

        // ---------- is_void_async_return_type ----------

        is_void_async_return_type_false_for_null() is
            @test()

            Assert.is_false(LOOP_RESULT_CONVERSION.is_void_async_return_type(null));
        si

        is_void_async_return_type_true_for_bare_tasks_task() is
            @test()

            Assert.is_true(LOOP_RESULT_CONVERSION.is_void_async_return_type(non_generic_task()));
        si

        is_void_async_return_type_false_for_generic_tasks_task() is
            @test()

            Assert.is_false(LOOP_RESULT_CONVERSION.is_void_async_return_type(generic_task(bare_named("int"))));
        si

        is_void_async_return_type_false_for_other_named_type() is
            @test()

            Assert.is_false(LOOP_RESULT_CONVERSION.is_void_async_return_type(bare_named("int")));
        si
    si
si
