namespace Semantic.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;
    use Collections.MAP;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.OWNER_TYPE_ARG_SPECIALIZER;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;
    use Semantic.Symbols.INSTANCE_METHOD;
    use Semantic.Symbols.Variable;

    use Semantic.Types.ERROR;
    use Semantic.Types.INFERRED_VARIABLE_TYPE;
    use Semantic.Types.Type;

    // Tests for OWNER_TYPE_ARG_SPECIALIZER — the helper used by the
    // sibling-arg fall-back in `resolve_constructor` (and reusable
    // elsewhere) to specialise a generic-owner candidate by binding
    // owner-generic args from concrete sibling actuals, skipping
    // actuals that are null, ERROR, or contain placeholders.
    //
    // Pinned here because the constructor-call sibling-arg path is
    // fragile: relaxing the "skip placeholders" rule poisons the
    // type-map with a placeholder-as-T binding; relaxing the "skip
    // ERROR" rule lets a failing lambda's ERROR-typed actual abort
    // the entire bind. The integration suite catches both eventually
    // but the diagnostic is several layers removed — these unit
    // tests pin the contract at the point it's defined.
    class OWNER_TYPE_ARG_SPECIALIZER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();
        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        // Build `class Pair[T] is init(a: T, b: T) si si`-shaped
        // symbols. The init method's `arguments` list carries the
        // GenericArgument *type* (not the symbol) — that's what the
        // overload resolver and specialiser see.
        build_pair() -> (pair: CLASS, t: CLASSY_GENERIC_ARGUMENT, init: INSTANCE_METHOD) is
            let pair = CLASS(loc(), loc(), null, "Pair", names_for(["T"]), false, null);
            let t = CLASSY_GENERIC_ARGUMENT(loc(), pair, "T", 0);
            let init = INSTANCE_METHOD(loc(), loc(), pair, "init", null);

            let args = LIST[Type]();
            args.add(t.type);
            args.add(t.type);
            init.arguments = args;

            return (pair, t, init);
        si

        // Build a non-generic Box-shaped class with init(value: int).
        // Used to confirm the helper bails when the owner isn't
        // generic.
        build_non_generic_box() -> (box: CLASS, init: INSTANCE_METHOD) is
            let box = CLASS(loc(), loc(), null, "Box", empty_names(), false, null);
            let init = INSTANCE_METHOD(loc(), loc(), box, "init", null);
            init.arguments = LIST[Type]();
            return (box, init);
        si

        // Concrete "int" stand-in. Doesn't need to be the real int —
        // we only use it for assignability / sibling-equality checks
        // against itself in the bind path.
        int_type() -> Type is
            let int_class = CLASS(loc(), loc(), null, "int", empty_names(), false, null);
            return int_class.type;
        si

        string_type() -> Type is
            let string_class = CLASS(loc(), loc(), null, "string", empty_names(), false, null);
            return string_class.type;
        si

        phantom() -> Variable =>
            INFERRED_TYPE_ARG_ORIGIN(loc(), null, "T_phantom");

        types(values: Iterable[Type]) -> LIST[Type] is
            let result = LIST[Type]();
            for v in values do result.add(v); od
            return result;
        si

        // === bind_owner_type_args_from_concrete_siblings ===

        // Simple positive case: Pair[T].init(a: T, b: T) bound from
        // two concrete int actuals binds T = int.
        Calling__bind_owner_type_args__with_two_concrete_actuals__binds_T() is
            @test()

            let p = build_pair();
            let int_t = int_type();
            let specializer = OWNER_TYPE_ARG_SPECIALIZER();

            let type_map = specializer.bind_owner_type_args_from_concrete_siblings(p.init, types([int_t, int_t]));

            Assert.is_not_null(type_map);
            Assert.is_true(type_map.contains_key("T"));
            Assert.are_same(int_t, type_map["T"]);
        si

        // ERROR-skip axis: a failing lambda's `placeholder -> ERROR`
        // type would otherwise abort the whole bind. By skipping the
        // ERROR-typed actual, the remaining concrete sibling still
        // binds T. This is the central sibling-arg-flow contract.
        Calling__bind_owner_type_args__skips_ERROR_actuals_and_binds_from_concrete_sibling() is
            @test()

            let p = build_pair();
            let int_t = int_type();
            let err = cast Type(ERROR());
            let specializer = OWNER_TYPE_ARG_SPECIALIZER();

            let type_map = specializer.bind_owner_type_args_from_concrete_siblings(p.init, types([int_t, err]));

            Assert.is_not_null(type_map);
            Assert.is_true(type_map.contains_key("T"));
            Assert.are_same(int_t, type_map["T"]);
        si

        // Placeholder-skip axis: an actual whose type itself is an
        // INFERRED_VARIABLE_TYPE (or contains one) is "not yet
        // useful" — skipping prevents the placeholder leaking into
        // the type-map as T's binding.
        Calling__bind_owner_type_args__skips_placeholder_actuals() is
            @test()

            let p = build_pair();
            let int_t = int_type();
            let placeholder = cast Type(INFERRED_VARIABLE_TYPE(phantom()));
            let specializer = OWNER_TYPE_ARG_SPECIALIZER();

            let type_map = specializer.bind_owner_type_args_from_concrete_siblings(p.init, types([int_t, placeholder]));

            Assert.is_not_null(type_map);
            Assert.is_true(type_map.contains_key("T"));
            Assert.are_same(int_t, type_map["T"]);
        si

        // All actuals unusable: bind returns an empty map, not null.
        // The specialise path can then fill all slots with phantoms.
        // Pinning empty-map-not-null so future refactors don't turn
        // this case into a null sentinel and silently break the
        // phantom-fill path.
        Calling__bind_owner_type_args__with_all_unusable_actuals__returns_empty_map() is
            @test()

            let p = build_pair();
            let err = cast Type(ERROR());
            let placeholder = cast Type(INFERRED_VARIABLE_TYPE(phantom()));
            let specializer = OWNER_TYPE_ARG_SPECIALIZER();

            let type_map = specializer.bind_owner_type_args_from_concrete_siblings(p.init, types([err, placeholder]));

            Assert.is_not_null(type_map);
            Assert.is_false(type_map.contains_key("T"));
        si

        // Non-generic owner: bind returns null. Caller short-circuits
        // and uses the original candidate. Pinning to catch a
        // regression that would specialise non-generic candidates
        // (which doesn't make sense and produces empty maps that
        // try_create_from would happily accept).
        Calling__bind_owner_type_args__on_non_generic_owner__returns_null() is
            @test()

            let b = build_non_generic_box();
            let int_t = int_type();
            let specializer = OWNER_TYPE_ARG_SPECIALIZER();

            let type_map = specializer.bind_owner_type_args_from_concrete_siblings(b.init, types([int_t]));

            Assert.is_null(type_map);
        si

        // Null candidate: bind returns null. Defensive — callers may
        // pass null when the single-arity lookup found no match.
        Calling__bind_owner_type_args__with_null_candidate__returns_null() is
            @test()

            let specializer = OWNER_TYPE_ARG_SPECIALIZER();
            let int_t = int_type();

            let type_map = specializer.bind_owner_type_args_from_concrete_siblings(null, types([int_t]));

            Assert.is_null(type_map);
        si

        // === specialize_from_concrete_siblings ===
        //
        // These tests exercise the integration of bind + phantom-fill,
        // BUT NOTE: they verify the unit-level contract only. The
        // full specialisation path also calls
        // GENERIC.try_create_from and find_specialized_function,
        // which need the candidate to be installed in a real init
        // function group on the owner Classy. The classy-fixture
        // pattern used here doesn't wire that up — find_specialized_
        // function will return null and the helper falls back to
        // returning the unspecialised candidate.
        //
        // CURRENT BEHAVIOUR PIN: when the test fixture's classy is
        // missing the init function group, specialize_from_concrete_
        // siblings returns the original candidate. This is the safe
        // fallback (no specialisation rather than wrong
        // specialisation). The integration test
        // generator-state-inference covers the
        // full path.

        // Non-generic owner: specialise returns the candidate
        // unchanged. Pinned because returning anything else (null,
        // a different candidate) would break the constructor-call
        // fall-back path, which trusts the result as a valid
        // function pointer.
        Calling__specialize__on_non_generic_owner__returns_original_candidate() is
            @test()

            let b = build_non_generic_box();
            let int_t = int_type();
            let specializer = OWNER_TYPE_ARG_SPECIALIZER();

            let phantoms = LIST[Variable]();
            let result = specializer.specialize_from_concrete_siblings(b.init, types([int_t]), phantoms, loc());

            Assert.are_same(b.init, result);
        si

        // Null candidate: specialise returns null (no change).
        // Defensive — _try_find_single_arity_candidate may return
        // null and the caller passes that straight through.
        Calling__specialize__with_null_candidate__returns_null() is
            @test()

            let specializer = OWNER_TYPE_ARG_SPECIALIZER();
            let int_t = int_type();
            let phantoms = LIST[Variable]();

            let result = specializer.specialize_from_concrete_siblings(null, types([int_t]), phantoms, loc());

            Assert.is_null(result);
        si

        // Missing phantoms for unbound slots: specialise must return
        // the original candidate rather than a half-formed
        // specialisation. The caller would otherwise push the
        // half-formed function's args as constraints, leaking the
        // partial state to the lambda walks.
        //
        // BEHAVIOUR PIN (may seem strict): even when SOME slots
        // bound from siblings, if the phantom_origins list is shorter
        // than the unbound count, we bail entirely. The alternative
        // — best-effort specialisation with only the bound slots —
        // would produce a Classy with fewer type-args than declared,
        // which try_create_from rejects anyway. Returning the
        // original candidate is the simpler contract.
        Calling__specialize__with_missing_phantoms_for_unbound_slots__returns_original_candidate() is
            @test()

            let p = build_pair();
            let err = cast Type(ERROR());
            let specializer = OWNER_TYPE_ARG_SPECIALIZER();

            let phantoms = LIST[Variable]();

            let result = specializer.specialize_from_concrete_siblings(p.init, types([err, err]), phantoms, loc());

            Assert.are_same(p.init, result);
        si
    si
si
