namespace Semantic.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.LOCATION_MAP;

    class LOCATION_MAP_TESTS is
        @test()

        init() is si

        loc(line: int, column: int) -> LOCATION =>
            LOCATION("test.ghul", line, column, line, column + 4);

        values_at(map: LOCATION_MAP[string], line: int, column: int) -> Collections.LIST[string] is
            let result = Collections.LIST[string]();

            let matches = map.find_all("test.ghul", line, column);

            if matches? then
                for m in matches do
                    result.add(m.value);
                od
            fi

            return result;
        si

        roll_back_removes_entries_recorded_in_the_frame() is
            @test()

            let map = LOCATION_MAP[string]();

            map.put(loc(1, 1), "permanent");

            map.speculate();
            map.put(loc(1, 1), "provisional");
            map.put(loc(2, 1), "also provisional");
            map.roll_back();

            let at_1 = values_at(map, 1, 1);

            Assert.are_equal(1, at_1.count);
            Assert.are_equal("permanent", at_1[0]);
            Assert.are_equal(0, values_at(map, 2, 1).count);
        si

        commit_at_the_bottom_of_the_stack_makes_entries_permanent() is
            @test()

            let map = LOCATION_MAP[string]();

            map.speculate();
            map.put(loc(1, 1), "kept");
            map.commit();

            Assert.are_equal(0, map.mark());

            let at_1 = values_at(map, 1, 1);

            Assert.are_equal(1, at_1.count);
            Assert.are_equal("kept", at_1[0]);
        si

        outer_roll_back_undoes_inner_committed_entries() is
            @test()

            let map = LOCATION_MAP[string]();

            map.put(loc(1, 1), "permanent");

            map.speculate();
            map.put(loc(2, 1), "outer provisional");

            map.speculate();
            map.put(loc(3, 1), "inner committed");
            map.commit();

            map.roll_back();

            Assert.are_equal(1, values_at(map, 1, 1).count);
            Assert.are_equal(0, values_at(map, 2, 1).count);
            Assert.are_equal(0, values_at(map, 3, 1).count);
        si

        put_replacing_is_undone_exactly() is
            @test()

            let map = LOCATION_MAP[string]();

            let location = loc(1, 1);

            map.put(location, "original");

            map.speculate();
            map.put_replacing(location, "replacement");

            let replaced = values_at(map, 1, 1);

            Assert.are_equal(1, replaced.count);
            Assert.are_equal("replacement", replaced[0]);

            map.roll_back();

            let restored = values_at(map, 1, 1);

            Assert.are_equal(1, restored.count);
            Assert.are_equal("original", restored[0]);
        si

        release_unwinds_every_frame_above_the_mark() is
            @test()

            let map = LOCATION_MAP[string]();

            let mark = map.mark();

            map.speculate();
            map.put(loc(1, 1), "first frame");

            map.speculate();
            map.put(loc(2, 1), "second frame");

            map.release(mark);

            Assert.are_equal(0, map.mark());
            Assert.are_equal(0, values_at(map, 1, 1).count);
            Assert.are_equal(0, values_at(map, 2, 1).count);
        si

        roll_back_removes_every_line_of_a_multi_line_entry() is
            @test()

            let map = LOCATION_MAP[string]();

            map.speculate();
            map.put(LOCATION("test.ghul", 1, 1, 3, 10), "spans three lines");
            map.roll_back();

            Assert.are_equal(0, values_at(map, 1, 1).count);
            Assert.are_equal(0, values_at(map, 2, 1).count);
            Assert.are_equal(0, values_at(map, 3, 1).count);
        si

        mutations_outside_any_frame_are_permanent_and_unjournalled() is
            @test()

            let map = LOCATION_MAP[string]();

            map.put(loc(1, 1), "no frame open");

            Assert.are_equal(0, map.mark());
            Assert.are_equal(1, values_at(map, 1, 1).count);
        si
    si
si
