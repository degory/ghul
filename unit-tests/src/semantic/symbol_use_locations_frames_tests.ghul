namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.SYMBOL_USE_LOCATIONS;
    use Semantic.SYMBOL_TABLE;
    use Semantic.Symbols.CLASS;

    // Pins the reference-set half of the use-store speculation frames:
    // find-references entries recorded inside a rolled-back frame are
    // removed, entries committed by an inner frame fall to the outer
    // frame's fate, and the discard-then-re-record shape the body
    // retry loop produces leaves exactly one reference. The hover /
    // symbol-use maps are pinned separately by LOCATION_MAP_TESTS;
    // the reference sets have their own journal, hence their own
    // tests.
    class SYMBOL_USE_LOCATIONS_FRAMES_TESTS is
        @test()

        init() is
            // SYMBOL_USE_LOCATIONS reads the current scope off the
            // container's symbol table when recording a use; a freshly
            // constructed table provides the root namespace scope.
            IoC.CONTAINER.instance.symbol_table = SYMBOL_TABLE(Logging.DIAGNOSTICS_STORE());
        si

        loc(line: int) -> LOCATION => LOCATION("test.ghul", line, 1, line, 5);

        make_class(name: string) -> CLASS =>
            CLASS(LOCATION("defs.ghul", 1, 1, 1, 5), LOCATION("defs.ghul", 1, 1, 1, 5), null, name, System.Array.empty[string](), false, null);

        references_of(uses: SYMBOL_USE_LOCATIONS, symbol: CLASS) -> LIST[LOCATION] =>
            LIST(uses.find_references_to_symbol(symbol));

        roll_back_removes_references_recorded_in_the_frame() is
            @test()

            let uses = SYMBOL_USE_LOCATIONS();
            let symbol = make_class("SUBJECT");

            uses.add_symbol_use(loc(1), symbol);

            uses.speculate();
            uses.add_symbol_use(loc(2), symbol);
            uses.roll_back();

            let references = references_of(uses, symbol);

            Assert.are_equal(1, references.count);
            Assert.are_equal(1, references[0].start_line);
        si

        outer_roll_back_removes_references_committed_by_an_inner_frame() is
            @test()

            let uses = SYMBOL_USE_LOCATIONS();
            let symbol = make_class("SUBJECT");

            uses.speculate();
            uses.add_symbol_use(loc(1), symbol);

            uses.speculate();
            uses.add_symbol_use(loc(2), symbol);
            uses.commit();

            uses.roll_back();

            Assert.are_equal(0, references_of(uses, symbol).count);
        si

        discarded_walk_then_re_record_leaves_exactly_one_reference() is
            @test()

            let uses = SYMBOL_USE_LOCATIONS();
            let symbol = make_class("SUBJECT");

            uses.speculate();
            uses.add_symbol_use(loc(1), symbol);

            uses.roll_back();
            uses.speculate();

            uses.add_symbol_use(loc(1), symbol);
            uses.commit();

            let references = references_of(uses, symbol);

            Assert.are_equal(1, references.count);
            Assert.are_equal(1, references[0].start_line);
        si

        release_unwinds_reference_frames_left_open() is
            @test()

            let uses = SYMBOL_USE_LOCATIONS();
            let symbol = make_class("SUBJECT");

            let mark = uses.mark();

            uses.speculate();
            uses.add_symbol_use(loc(1), symbol);

            uses.speculate();
            uses.add_symbol_use(loc(2), symbol);

            uses.release(mark);

            Assert.are_equal(0, uses.mark());
            Assert.are_equal(0, references_of(uses, symbol).count);
        si
    si
si
