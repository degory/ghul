namespace Semantic.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.RETURN_CONSTRAINT_FILTER;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.FUNCTION_GENERIC_ARGUMENT;
    use Semantic.Symbols.STATIC_METHOD;

    use Semantic.Types.ERROR;
    use Semantic.Types.GENERIC;
    use Semantic.Types.INFERRED_VARIABLE_TYPE;
    use Semantic.Types.Type;

    // Pins for RETURN_CONSTRAINT_FILTER — the helper that the overload
    // resolver uses as a tie-breaker when arg-side scoring leaves
    // multiple candidates and the call-site supplies a return-type
    // constraint (return-position call, assignment LHS, etc.).
    //
    // Two contracts:
    //   matches(candidate, constraint) — true when the candidate's
    //     return type fits the constraint, either as-is (shape 1) or
    //     after binding method-level type-args from the constraint
    //     (shapes 2/3). Shapes 2/3 ONLY fire when candidate.is_generic
    //     — a fully-specialized but structurally-incompatible
    //     candidate (e.g. Box[string] return against Box[int]
    //     constraint) must not survive the head match and then be
    //     picked unspecialized.
    //   try_specialize(location, candidate, constraint) — bind the
    //     candidate's method-level type-args from the constraint and
    //     return the specialized function; null when there's nothing
    //     to bind. Covered here at the bailout boundaries; the
    //     specialize-function happy path is exercised end-to-end by
    //     integration-tests/execution/return-type-overload-pick.
    class RETURN_CONSTRAINT_FILTER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();
        names_for_T() -> LIST[string] is
            let result = LIST[string]();
            result.add("T");
            return result;
        si

        types(values: Collections.Iterable[Type]) -> LIST[Type] is
            let result = LIST[Type]();
            for v in values do result.add(v); od
            return result;
        si

        int_class() -> CLASS => CLASS(loc(), loc(), null, "int", empty_names(), false, null);
        string_class() -> CLASS => CLASS(loc(), loc(), null, "string", empty_names(), false, null);

        // Build a Box[T] generic-class symbol. Used as the head for
        // constraint and candidate return types — Box[int] vs Box[T]
        // vs Box[string] vs Box (non-generic) — across the shapes.
        build_box() -> CLASS => CLASS(loc(), loc(), null, "Box", names_for_T(), false, null);

        // A method-level `T` type variable, of the shape that
        // `f[T](x) -> Box[T]` would carry on f's signature.
        build_method_T() -> FUNCTION_GENERIC_ARGUMENT =>
            FUNCTION_GENERIC_ARGUMENT(loc(), null, "T", 0);

        // Build a STATIC_METHOD with is_generic + generic_argument_names
        // + generic_arguments set so that try_specialize can interrogate
        // method-level type-vars on it. The caller supplies the
        // return_type.
        build_generic_method(name: string, t: FUNCTION_GENERIC_ARGUMENT, return_type: Type) -> STATIC_METHOD is
            let m = STATIC_METHOD(loc(), loc(), null, name, null);
            m.is_generic = true;
            let names = LIST[string](); names.add("T");
            m.generic_argument_names = names;
            m.generic_arguments = types([t.type]);
            m.return_type = return_type;
            return m;
        si

        build_non_generic_method(name: string, return_type: Type) -> STATIC_METHOD is
            let m = STATIC_METHOD(loc(), loc(), null, name, null);
            m.is_generic = false;
            m.return_type = return_type;
            return m;
        si

        // === matches ===
        //
        // Shape 1: concrete assignable return type passes regardless of
        // whether the candidate is generic. A method returning int with
        // an int constraint is the simplest positive case.
        Calling__matches__with_concrete_assignable_return_type__returns_true() is
            @test()

            let int_t = int_class().type;
            let m = build_non_generic_method("get_int", int_t);

            Assert.is_true(RETURN_CONSTRAINT_FILTER.matches(m, int_t));
        si

        // Shape 2 positive: a generic candidate whose return type
        // shares its outer head with the constraint AND still carries
        // unbound method-level type-args passes — try_specialize will
        // bind T from the constraint on the second pass.
        Calling__matches__with_generic_candidate_head_matching_constraint__returns_true() is
            @test()

            let box = build_box();
            let int_t = int_class().type;
            let t = build_method_T();

            let box_of_T = cast Type(GENERIC(loc(), box, types([t.type])));
            let box_of_int = cast Type(GENERIC(loc(), box, types([int_t])));

            let m = build_generic_method("make", t, box_of_T);

            Assert.is_true(RETURN_CONSTRAINT_FILTER.matches(m, box_of_int));
        si

        // The bot's concern, pinned: a fully-specialized candidate
        // returning Box[string] must NOT pass against a Box[int]
        // constraint. Without the is_generic gate the shared head
        // would let it through, try_specialize would return null (no
        // type-vars to bind), and the resolver would pick the
        // structurally-incompatible candidate anyway.
        Calling__matches__with_specialized_but_mismatched_head__returns_false() is
            @test()

            let box = build_box();
            let int_t = int_class().type;
            let string_t = string_class().type;

            let box_of_string = cast Type(GENERIC(loc(), box, types([string_t])));
            let box_of_int = cast Type(GENERIC(loc(), box, types([int_t])));

            let m = build_non_generic_method("make_string", box_of_string);

            Assert.is_false(RETURN_CONSTRAINT_FILTER.matches(m, box_of_int));
        si

        // Shape 3: candidate whose return type is itself a method-level
        // type variable (`f[T](x) -> T`) passes against any constraint
        // when candidate.is_generic — try_specialize can pin T from it.
        Calling__matches__with_bare_type_variable_return_on_generic_candidate__returns_true() is
            @test()

            let int_t = int_class().type;
            let t = build_method_T();
            let m = build_generic_method("identity", t, t.type);

            Assert.is_true(RETURN_CONSTRAINT_FILTER.matches(m, int_t));
        si

        // is_generic gate also covers shape 3: a function whose
        // return type IS a type variable but whose candidate isn't
        // generic (e.g. an inherited method on a class with all its
        // class-level type-args specialized) would have nothing for
        // try_specialize to bind. Reject.
        Calling__matches__with_bare_type_variable_return_on_non_generic_candidate__returns_false() is
            @test()

            let int_t = int_class().type;
            let t = build_method_T();
            let m = build_non_generic_method("inherited", t.type);

            Assert.is_false(RETURN_CONSTRAINT_FILTER.matches(m, int_t));
        si

        // Null guards: a null candidate, null return type, or null
        // constraint must reject without NREing — the resolver's
        // filter calls into matches() unconditionally inside a lambda.
        Calling__matches__with_null_candidate__returns_false() is
            @test()

            let int_t = int_class().type;

            Assert.is_false(RETURN_CONSTRAINT_FILTER.matches(null, int_t));
        si

        Calling__matches__with_null_return_type__returns_false() is
            @test()

            let int_t = int_class().type;
            let m = build_non_generic_method("missing_return", null);

            Assert.is_false(RETURN_CONSTRAINT_FILTER.matches(m, int_t));
        si

        Calling__matches__with_null_constraint__returns_false() is
            @test()

            let int_t = int_class().type;
            let m = build_non_generic_method("get_int", int_t);

            Assert.is_false(RETURN_CONSTRAINT_FILTER.matches(m, null));
        si

        // Sentinel/error return type: ERROR is a terminal inference
        // marker; INFERRED_VARIABLE_TYPE is a placeholder. Neither
        // should match — the filter must skip the candidate so other
        // candidates can be picked instead.
        Calling__matches__with_error_return_type__returns_false() is
            @test()

            let int_t = int_class().type;
            let m = build_non_generic_method("broken", cast Type(ERROR()));

            Assert.is_false(RETURN_CONSTRAINT_FILTER.matches(m, int_t));
        si

        // === try_specialize ===
        //
        // Null candidate: defensive bailout. The resolver may pass a
        // null result before its single-candidate narrowing has
        // landed.
        Calling__try_specialize__with_null_candidate__returns_null() is
            @test()

            let int_t = int_class().type;

            Assert.is_null(RETURN_CONSTRAINT_FILTER.try_specialize(loc(), null, int_t));
        si

        // Non-generic candidate: nothing for the constraint to bind,
        // return null. Without this guard specialize_function would
        // assert-fail on a non-generic method.
        Calling__try_specialize__with_non_generic_candidate__returns_null() is
            @test()

            let int_t = int_class().type;
            let m = build_non_generic_method("get_int", int_t);

            Assert.is_null(RETURN_CONSTRAINT_FILTER.try_specialize(loc(), m, int_t));
        si

        // Null return type on the candidate: guard against half-
        // formed Function symbols (poison logger paths leave one).
        Calling__try_specialize__with_null_return_type__returns_null() is
            @test()

            let int_t = int_class().type;
            let t = build_method_T();
            let m = build_generic_method("unset_return", t, null);

            Assert.is_null(RETURN_CONSTRAINT_FILTER.try_specialize(loc(), m, int_t));
        si
    si
si
