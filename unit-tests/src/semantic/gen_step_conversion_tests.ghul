namespace Semantic.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.GEN_STEP_CONVERSION;

    use Trees = Syntax.Trees;
    use Syntax.Process.Printer.FORMATTER;

    // Tests for GEN_STEP_CONVERSION's static AST builders and
    // type-expression predicates. Pins the shape of the synthesised
    // AST that the generator desugar relies on, plus the syntactic
    // recognisers (`try_extract_generator_t`, `is_generator_return_type`)
    // that classify a function's return type.
    class GEN_STEP_CONVERSION_TESTS is
        @test()

        init() is
            // The helper class threads `LOCATION.internal` through
            // its inner identifier-AST nodes for hover suppression
            // (see `_build_ghul_generators`). Outside the IoC
            // container, the LOCATION statics are null — initialise
            // them here so the builders don't trip the
            // location-must-be-non-null assertion.
            LOCATION.init_static();
        si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        format(node: Trees.Node) -> string =>
            FORMATTER(Collections.LIST[Lexical.TRIVIA](), 100).format(node);

        // Build a bare `int` (or similar) type-name AST node.
        bare_named(name: string) -> Trees.TypeExpressions.TypeExpression =>
            Trees.TypeExpressions.NAMED(loc(), Trees.Identifiers.Identifier(loc(), name));

        // Build a bare `Iterable[arg]` type-name with the given inner.
        bare_iterable(arg: Trees.TypeExpressions.TypeExpression) -> Trees.TypeExpressions.TypeExpression is
            let name = Trees.Identifiers.Identifier(loc(), "Iterable");
            let args =
                Trees.TypeExpressions.LIST(
                    loc(),
                    Collections.LIST[Trees.TypeExpressions.TypeExpression]([arg]: Trees.TypeExpressions.TypeExpression)
                );
            return Trees.TypeExpressions.GENERIC(loc(), name, args);
        si

        // Build `Collections.Iterator[arg]` — qualified form.
        qualified_iterator(arg: Trees.TypeExpressions.TypeExpression) -> Trees.TypeExpressions.TypeExpression is
            let qualified =
                Trees.Identifiers.QUALIFIED(
                    loc(),
                    Trees.Identifiers.Identifier(loc(), "Collections"),
                    "Iterator",
                    loc(),
                    loc()
                );
            let args =
                Trees.TypeExpressions.LIST(
                    loc(),
                    Collections.LIST[Trees.TypeExpressions.TypeExpression]([arg]: Trees.TypeExpressions.TypeExpression)
                );
            return Trees.TypeExpressions.GENERIC(loc(), qualified, args);
        si

        // ---------- build_ghul_generators_member ----------

        build_ghul_generators_member_produces_two_level_chain() is
            @test()

            let expr = GEN_STEP_CONVERSION.build_ghul_generators_member(loc(), "_gen_pipe");

            Assert.are_equal("Ghul.Generators._gen_pipe\n", format(expr));
        si

        // ---------- build_gen_step_kind_value ----------

        build_gen_step_kind_value_produces_three_level_chain() is
            @test()

            let expr = GEN_STEP_CONVERSION.build_gen_step_kind_value(loc(), "YIELD");

            Assert.are_equal("Ghul.Generators._GEN_STEP_KIND.YIELD\n", format(expr));
        si

        // ---------- build_done ----------

        build_done_produces_default_constructed_step() is
            @test()

            let expr = GEN_STEP_CONVERSION.build_done(loc(), bare_named("int"));

            Assert.are_equal("Ghul.Generators._GEN_STEP[int]()\n", format(expr));
        si

        // ---------- build_yield ----------

        build_yield_produces_three_arg_call() is
            @test()

            let value_expr = Trees.Expressions.Literals.INTEGER(loc(), "42");

            let expr =
                GEN_STEP_CONVERSION.build_yield(
                    loc(),
                    bare_named("int"),
                    value_expr,
                    7
                );

            Assert.are_equal(
                "Ghul.Generators._GEN_STEP[int](Ghul.Generators._GEN_STEP_KIND.YIELD, 42, 7)\n",
                format(expr)
            );
        si

        // ---------- build_transition ----------

        build_transition_emits_default_value_slot() is
            @test()

            let expr =
                GEN_STEP_CONVERSION.build_transition(
                    loc(),
                    bare_named("int"),
                    3
                );

            Assert.are_equal(
                "Ghul.Generators._GEN_STEP[int](Ghul.Generators._GEN_STEP_KIND.TRANSITION, default[int], 3)\n",
                format(expr)
            );
        si

        // ---------- try_extract_generator_t ----------

        try_extract_generator_t_returns_null_for_null_input() is
            @test()

            let result = GEN_STEP_CONVERSION.try_extract_generator_t(null);

            Assert.is_null(result);
        si

        try_extract_generator_t_returns_inner_arg_for_bare_iterable() is
            @test()

            let int_expr = bare_named("int");
            let result = GEN_STEP_CONVERSION.try_extract_generator_t(bare_iterable(int_expr));

            Assert.is_not_null(result);
            Assert.are_equal("int\n", format(result));
        si

        try_extract_generator_t_returns_inner_arg_for_qualified_iterator() is
            @test()

            let int_expr = bare_named("int");
            let result = GEN_STEP_CONVERSION.try_extract_generator_t(qualified_iterator(int_expr));

            Assert.is_not_null(result);
            Assert.are_equal("int\n", format(result));
        si

        try_extract_generator_t_returns_null_for_unrelated_type() is
            @test()

            let result = GEN_STEP_CONVERSION.try_extract_generator_t(bare_named("int"));

            Assert.is_null(result);
        si

        // ---------- is_generator_return_type ----------

        is_generator_return_type_false_for_null() is
            @test()

            Assert.is_false(GEN_STEP_CONVERSION.is_generator_return_type(null));
        si

        is_generator_return_type_true_for_iterable() is
            @test()

            Assert.is_true(GEN_STEP_CONVERSION.is_generator_return_type(bare_iterable(bare_named("int"))));
        si

        is_generator_return_type_true_for_iterator() is
            @test()

            Assert.is_true(GEN_STEP_CONVERSION.is_generator_return_type(qualified_iterator(bare_named("int"))));
        si

        is_generator_return_type_false_for_other_named_type() is
            @test()

            Assert.is_false(GEN_STEP_CONVERSION.is_generator_return_type(bare_named("int")));
        si
    si
si
