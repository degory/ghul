namespace Semantic.Types.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;
    use Semantic.Types.MATCH;

    // Pins the strict non-nullable-by-default rule landed in
    // `NAMED.compare`. The contract: a non-optional `T` slot rejects
    // a `T?` value at every subtype relationship — same symbol,
    // direct ancestor, transitive ancestor — uniformly. The earlier
    // form only checked same-symbol, so a `Derived?` value flowed
    // into a `Base` slot via the ancestor walk and downstream
    // codegen emitted a non-narrowed load that crashed at runtime.
    //
    // Companion test for `INTERSECTION._add_member`'s precision
    // tradeoff at the bottom: the dedup compares stripped-optional
    // forms so an already-narrowed intersection doesn't accumulate
    // both `A` and `A?` members.
    class STRICT_NON_NULLABLE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        // Reference class (non-struct) — `T?` is the bare-with-flag
        // form, which is what the strict check guards.
        a_reference_class(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, empty_names(), false, null);

        // Same symbol, slot non-optional, value optional → DIFFERENT.
        compare__T_slot_T_optional_value__rejects_same_symbol() is
            @test()

            let symbol = a_reference_class("Foo");
            let bare = cast NAMED(symbol.type);
            let optional = bare.as_optional();

            Assert.are_equal(cast int(MATCH.DIFFERENT), cast int(bare.compare(optional)));
        si

        // Same symbol, slot optional, value non-optional → ASSIGNABLE
        // (the implicit widening, unchanged by the new rule).
        compare__T_optional_slot_T_value__accepts_same_symbol() is
            @test()

            let symbol = a_reference_class("Foo");
            let bare = cast NAMED(symbol.type);
            let optional = bare.as_optional();

            Assert.are_equal(cast int(MATCH.ASSIGNABLE), cast int(optional.compare(bare)));
        si

        // Subtype relationship, slot non-optional Base, value `Derived?`
        // — the loophole the rule closed. The earlier form silently
        // dropped the optional flag through the ancestor walk.
        compare__base_slot_derived_optional_value__rejects_via_ancestor_walk() is
            @test()

            let base_symbol = a_reference_class("Base");
            let derived_symbol = a_reference_class("Derived");
            derived_symbol.add_ancestor(base_symbol.type);

            let base = cast NAMED(base_symbol.type);
            let derived_optional = (cast NAMED(derived_symbol.type)).as_optional();

            Assert.are_equal(cast int(MATCH.DIFFERENT), cast int(base.compare(derived_optional)));
        si

        // Same subtype relationship but both sides non-optional —
        // still ASSIGNABLE via the ancestor walk. Pins that the
        // strict check didn't break the normal subtype path.
        compare__base_slot_derived_value__accepts_via_ancestor_walk() is
            @test()

            let base_symbol = a_reference_class("Base");
            let derived_symbol = a_reference_class("Derived");
            derived_symbol.add_ancestor(base_symbol.type);

            let base = cast NAMED(base_symbol.type);
            let derived = cast NAMED(derived_symbol.type);

            Assert.are_equal(cast int(MATCH.ASSIGNABLE), cast int(base.compare(derived)));
        si

        // INTERSECTION dedup with the optional-strip: combining `A?`
        // with `A` collapses to a single survivor (the precision
        // tradeoff documented inline in `intersection._add_member`).
        // Without the strip, the new strict rule would reject the
        // subtype probe and both would survive as distinct members.
        intersection_dedup__strips_optional_on_existing_supertype() is
            @test()

            let foo_symbol = a_reference_class("Foo");
            let bare = cast NAMED(foo_symbol.type);
            let optional = bare.as_optional();

            let result = INTERSECTION.create(bare, optional);

            Assert.is_not_null(result);
            // `create` collapses a singleton survivor to the plain
            // underlying type; we only need to assert the result
            // isn't an INTERSECTION carrying both members.
            Assert.is_false(isa INTERSECTION(result));
        si
    si
si
