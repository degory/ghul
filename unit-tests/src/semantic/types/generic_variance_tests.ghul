namespace Semantic.Types.UnitTests is
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Classy;
    use Semantic.Symbols.STRUCT;
    use Semantic.Types.GENERIC;
    use Semantic.Types.TYPE_VARIANCE;
    use Semantic.Types.Type;

    // Tests for variance lookup on Types.GENERIC. ghūl reads per-parameter
    // variance from .NET reflection metadata and stores it on
    // Symbols.Classy.argument_variances; Types.GENERIC.get_argument_type_variance
    // surfaces it, applying the CLR rule that declared variance is
    // suppressed when the actual type argument is a value type.
    class GENERIC_VARIANCE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // Build a minimal {object, animal, cat} hierarchy plus an int-like
        // STRUCT (for value-type tests).
        build_hierarchy() -> (object_class: CLASS, animal: CLASS, cat: CLASS, int_struct: STRUCT) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let animal = CLASS(loc(), loc(), null, "animal", empty_names(), false, null);
            animal.add_ancestor(object_class.type);

            let cat = CLASS(loc(), loc(), null, "cat", empty_names(), false, null);
            cat.add_ancestor(animal.type);

            let int_struct = STRUCT(loc(), loc(), null, "int", empty_names(), false, null);
            int_struct.add_ancestor(object_class.type);

            return (object_class, animal, cat, int_struct);
        si

        Get_argument_variance__on_classy_with_no_variances_set__returns_INVARIANT() is
            @test()

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);

            Assert.are_equal(TYPE_VARIANCE.INVARIANT, owner.get_argument_variance(0));
        si

        Get_argument_variance__on_classy_with_variances_set__returns_declared() is
            @test()

            let owner = CLASS(loc(), loc(), null, "owner", ["T", "U"], false, null);
            owner.argument_variances = [TYPE_VARIANCE.COVARIANT, TYPE_VARIANCE.CONTRAVARIANT];

            Assert.are_equal(TYPE_VARIANCE.COVARIANT, owner.get_argument_variance(0));
            Assert.are_equal(TYPE_VARIANCE.CONTRAVARIANT, owner.get_argument_variance(1));
        si

        Get_argument_variance__with_out_of_range_index__returns_INVARIANT() is
            @test()

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);
            owner.argument_variances = [TYPE_VARIANCE.COVARIANT];

            Assert.are_equal(TYPE_VARIANCE.INVARIANT, owner.get_argument_variance(-1));
            Assert.are_equal(TYPE_VARIANCE.INVARIANT, owner.get_argument_variance(5));
        si

        Generic_type__get_argument_type_variance__with_reference_arg__returns_declared() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "iterable_like", ["T"], false, null);
            owner.argument_variances = [TYPE_VARIANCE.COVARIANT];

            let args = LIST[Type]();
            args.add(h.cat.type);

            let g = GENERIC(loc(), owner, args);

            Assert.are_equal(TYPE_VARIANCE.COVARIANT, g.get_argument_type_variance(0));
        si

        Generic_type__get_argument_type_variance__with_value_type_arg__suppresses_variance() is
            @test()

            let h = build_hierarchy();

            // Iterable[int] — even though the parameter is declared
            // covariant, IEnumerable<int> does not satisfy IEnumerable<object>
            // in C# because variance only applies to reference type
            // arguments. Verify the same here.
            let owner = CLASS(loc(), loc(), null, "iterable_like", ["T"], false, null);
            owner.argument_variances = [TYPE_VARIANCE.COVARIANT];

            let args = LIST[Type]();
            args.add(h.int_struct.type);

            let g = GENERIC(loc(), owner, args);

            Assert.are_equal(TYPE_VARIANCE.INVARIANT, g.get_argument_type_variance(0));
        si

        Generic_type__get_argument_type_variance__with_unset_variances__returns_INVARIANT() is
            @test()

            let h = build_hierarchy();

            // Source-defined ghūl classes have no variance metadata;
            // they default to INVARIANT.
            let owner = CLASS(loc(), loc(), null, "ghul_generic", ["T"], false, null);

            let args = LIST[Type]();
            args.add(h.cat.type);

            let g = GENERIC(loc(), owner, args);

            Assert.are_equal(TYPE_VARIANCE.INVARIANT, g.get_argument_type_variance(0));
        si
    si
si
