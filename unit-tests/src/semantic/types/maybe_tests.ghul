namespace Semantic.Types.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.STRUCT;
    use Semantic.Types.GENERIC;
    use Semantic.Types.MAYBE;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;

    // Tests for the `Ghul.MAYBE[T]` recognition path. The substantive
    // guarantees are:
    //
    //  - Types.MAYBE reports is_maybe = true; a plain Types.GENERIC
    //    over the same symbol reports is_maybe = false. That keeps
    //    source-side compilation of ghul-runtime's own `MAYBE` struct
    //    (which never goes through the reflected wrapper path) from
    //    triggering the implicit MAYBE -> T? conversion.
    //
    //  - NAMED.compare accepts a MAYBE[T] source when the target is a
    //    flagged-optional reference type and T matches. The value-T
    //    counterpart — `OPTION.compare_optional` accepting a MAYBE
    //    against a `Nullable[T]` target — sits in the OPTION suite
    //    rather than here; this NAMED-side rule covers only the
    //    reference-type targets. A bare value-type target via NAMED
    //    is rejected because a value-T's `T?` is OPTION, not a
    //    flagged NAMED, so the rule doesn't silently widen through
    //    this path. A mismatched-T target is rejected for the same
    //    reason.
    //
    // The MAYBE_TYPE_WRAPPER's reflected materialisation, its
    // hand-off to Types.MAYBE on specialisation, and the
    // VALUE_BOXER's `.value` property load are covered end-to-end by
    // `integration-tests/execution/maybe-as-optional-probe`; the
    // value-T layout-blit by `maybe-as-optional-value`.
    class MAYBE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        // A reference type stand-in for T — its `T?` form is a flagged
        // NAMED rather than an OPTION wrap.
        a_reference_class() -> CLASS =>
            CLASS(loc(), loc(), null, "Cat", empty_names(), false, null);

        another_reference_class() -> CLASS =>
            CLASS(loc(), loc(), null, "Dog", empty_names(), false, null);

        // A value-type stand-in for T — its `T?` form would be an
        // OPTION wrap, not a flagged NAMED, so a flagged-NAMED target
        // can never be a value-type T?.
        a_value_struct() -> STRUCT =>
            STRUCT(loc(), loc(), null, "Pixel", empty_names(), false, null);

        // A stand-in for Ghul.MAYBE[T] — declares one type parameter
        // so Symbols.GENERIC accepts it as the generic underlying.
        a_maybe_class() -> CLASS =>
            CLASS(loc(), loc(), null, "MAYBE", names_for(["T"]), false, null);

        build_maybe_over(inner: NAMED) -> MAYBE is
            let arguments = LIST[Type]();
            arguments.add(inner);
            return MAYBE(loc(), a_maybe_class(), arguments);
        si

        build_generic_over(inner: NAMED) -> GENERIC is
            let arguments = LIST[Type]();
            arguments.add(inner);
            return GENERIC(loc(), a_maybe_class(), arguments);
        si

        is_maybe__on_Types_MAYBE__is_true() is
            @test()

            let cat = cast NAMED(a_reference_class().type);

            let m = build_maybe_over(cat);

            Assert.is_true(m.is_maybe);
        si

        is_maybe__on_plain_GENERIC__is_false() is
            @test()

            let cat = cast NAMED(a_reference_class().type);

            // Same underlying symbol, but constructed as plain
            // Types.GENERIC. Stands in for ghul-runtime's own
            // source-side MAYBE definition during its own compile.
            let g = build_generic_over(cat);

            Assert.is_false(g.is_maybe);
        si

        is_maybe__on_a_plain_named_reference__is_false() is
            @test()

            let cat = cast NAMED(a_reference_class().type);

            Assert.is_false(cat.is_maybe);
        si

        compare__MAYBE_against_matching_reference_optional__is_assignable() is
            @test()

            let cat = cast NAMED(a_reference_class().type);
            let cat_optional = cast NAMED(cat.as_optional());

            let m = build_maybe_over(cat);

            // Direction matches NAMED.compare semantics:
            // target.compare(source) yields ASSIGNABLE.
            let result = cat_optional.compare(m);

            Assert.are_equal(Types.MATCH.ASSIGNABLE, result);
        si

        compare__MAYBE_against_non_optional_reference__not_assignable() is
            @test()

            let cat = cast NAMED(a_reference_class().type);

            let m = build_maybe_over(cat);

            // The flagged-optional guard rules this out — the MAYBE
            // path is for `T?` slots, not bare `T`.
            let result = cat.compare(m);

            Assert.are_not_equal(Types.MATCH.ASSIGNABLE, result);
        si

        compare__MAYBE_against_mismatched_T_optional__not_assignable() is
            @test()

            let dog = cast NAMED(another_reference_class().type);
            let dog_optional = cast NAMED(dog.as_optional());

            let cat = cast NAMED(a_reference_class().type);
            let m = build_maybe_over(cat);

            // Different T — `Dog?` does not accept `MAYBE[Cat]`.
            let result = dog_optional.compare(m);

            Assert.are_not_equal(Types.MATCH.ASSIGNABLE, result);
        si

        compare__MAYBE_against_value_type_optional__not_assignable() is
            @test()

            let pixel = cast NAMED(a_value_struct().type);

            // A value-type's `T?` is OPTION[T], not a flagged NAMED,
            // so the `!is_value_type` guard rules this out before the
            // MAYBE branch fires. Pinned so a future widen of the rule
            // can't silently flow MAYBE into a value-type-T? slot
            // through this path.
            let m = build_maybe_over(pixel);

            let result = pixel.compare(m);

            Assert.are_not_equal(Types.MATCH.ASSIGNABLE, result);
        si
    si
si
