namespace Semantic.Types.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Types.Type;

    // Type.bound_type exposes a type variable's declared upper bound so
    // narrowing / destructure / operator resolution can peel to it. It is
    // the bound for a bounded variable and null for everything else.
    class BOUND_TYPE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "Owner", empty_names(), false, null);

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            return c.type!;
        si

        make_variable(name: string) -> CLASSY_GENERIC_ARGUMENT =>
            CLASSY_GENERIC_ARGUMENT(loc(), make_owner(), name, 0);

        bound_type_returns_the_declared_bound_for_a_bounded_variable() is
            @test()

            let animal = make_class_type("Animal");
            let t = make_variable("T");
            t.set_ancestor_type(animal);

            Assert.are_same(animal, t.type.bound_type);
        si

        bound_type_is_null_for_an_unbounded_variable() is
            @test()

            let t = make_variable("T");

            Assert.is_null(t.type.bound_type);
        si

        bound_type_is_null_for_a_non_variable_type() is
            @test()

            Assert.is_null(make_class_type("Animal").bound_type);
        si
    si
si
