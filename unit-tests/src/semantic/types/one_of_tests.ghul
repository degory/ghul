namespace Semantic.Types.UnitTests is
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Classy;
    use Semantic.Symbols.UNION;
    use Semantic.Symbols.VARIANT;
    use Semantic.Types.GENERIC;
    use Semantic.Types.NAMED;
    use Semantic.Types.ONE_OF;
    use Semantic.Types.Type;

    // Tests for Types.ONE_OF — the internal narrowing-only sum
    // representing "value of closed root R restricted to a proper
    // subtype subset". The contract guards three invariants:
    //
    //   - Construction is by factory: |subtypes| = 0 → null;
    //     |subtypes| = 1 → bare subtype; |subtypes| ≥ 2 → ONE_OF.
    //     The size-1 degeneracy keeps assignability rules simple.
    //   - Membership lookup (contains_subtype) is by reference, since
    //     Classy symbols have stable identity.
    //   - build_singleton_subtype threads the underlying receiver
    //     into the constructed subtype so generic args carry through
    //     narrowing on the variant path; for a closed-class subclass
    //     the bare NAMED form is emitted (per the design note on
    //     ONE_OF.build_singleton_subtype).
    //
    // Identity (=~) is exercised end-to-end via the integration tests
    // in execution/one-of-narrowing-1265 — the NARROWING.try_push
    // "did anything change" check relies on ONE_OF !=~ plain union,
    // and the narrowing exercising that is the surest probe.
    class ONE_OF_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // Construct {union, variant_a, variant_b, variant_c} mirroring
        // how declare_variant wires variants under a union scope.
        // declare_variant is the production path — bare VARIANT(...)
        // constructors leave the variant absent from union.symbols,
        // breaking any test that probes through the union's symbol
        // table (e.g. the closed_alternatives walk).
        build_three_variant_union() -> (the_union: UNION, a: VARIANT, b: VARIANT, c: VARIANT) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let the_union = UNION(loc(), loc(), null, "U", empty_names(), false, null);
            the_union.add_ancestor(object_class.type!);

            let a = cast VARIANT(the_union.declare_variant(loc(), loc(), "A", false, null, null));
            let b = cast VARIANT(the_union.declare_variant(loc(), loc(), "B", false, null, null));
            let c = cast VARIANT(the_union.declare_variant(loc(), loc(), "C", false, null, null));

            return (the_union, a, b, c);
        si

        Create__with_empty_variants__returns_null() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();

            let result = ONE_OF.create(cast NAMED(h.the_union.type!), variants);

            Assert.is_null(result);
        si

        Create__with_one_variant_and_non_generic_underlying__returns_plain_variant_NAMED() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);

            let result = ONE_OF.create(cast NAMED(h.the_union.type!), variants);

            Assert.is_not_null(result);
            Assert.is_false(isa ONE_OF(result));
            Assert.is_true(isa NAMED(result));
            Assert.are_same(h.a, (cast NAMED(result)).symbol);
        si

        Create__with_two_variants__returns_ONE_OF() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);

            let result = ONE_OF.create(cast NAMED(h.the_union.type!), variants);

            Assert.is_not_null(result);
            Assert.is_true(isa ONE_OF(result));

            let one_of = cast ONE_OF(result);
            Assert.are_equal(2, one_of.subtypes_count);
            Assert.is_true(one_of.contains_subtype(h.a));
            Assert.is_true(one_of.contains_subtype(h.b));
            Assert.is_false(one_of.contains_subtype(h.c));
        si

        Create__with_three_variants__returns_ONE_OF_carrying_all() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);
            variants.add(h.c);

            let result = ONE_OF.create(cast NAMED(h.the_union.type!), variants);

            Assert.is_true(isa ONE_OF(result));

            let one_of = cast ONE_OF(result);
            Assert.are_equal(3, one_of.subtypes_count);
            Assert.is_true(one_of.contains_subtype(h.a));
            Assert.is_true(one_of.contains_subtype(h.b));
            Assert.is_true(one_of.contains_subtype(h.c));
        si

        Create__with_null_underlying__returns_null() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);

            let result = ONE_OF.create(null, variants);

            Assert.is_null(result);
        si

        Contains_variant__null_input__returns_false() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);

            let one_of = ONE_OF(cast NAMED(h.the_union.type!), variants);

            Assert.is_false(one_of.contains_subtype(null));
        si

        Underlying_type__exposes_constructor_argument() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);

            let underlying = cast NAMED(h.the_union.type!);
            let one_of = ONE_OF(underlying, variants);

            Assert.are_same(underlying, one_of.underlying_type);
        si

        Build_singleton_subtype__non_generic_underlying__returns_variant_NAMED() is
            @test()

            let h = build_three_variant_union();
            let underlying = cast NAMED(h.the_union.type!);

            let result = ONE_OF.build_singleton_subtype(underlying, h.a);

            Assert.is_not_null(result);
            Assert.is_false(isa GENERIC(result));
            Assert.are_same(h.a, result.symbol);
        si

        // Symbol-level: pin that UNION is recognised as a closed root.
        // The narrowing+constraint paths gate on this predicate to
        // pick a universe for the complement/discharge walk.
        Union_symbol__is_closed_root() is
            @test()

            let h = build_three_variant_union();

            Assert.is_true(h.the_union.is_closed_root);
        si

        // Symbol-level: pin that UNION exposes its variants via
        // closed_alternatives. Mirrors the closed_subclasses path
        // for CLASS.
        Union_symbol__closed_alternatives_yields_variants() is
            @test()

            let h = build_three_variant_union();

            let collected = LIST[Classy]();
            for s in h.the_union.closed_alternatives do
                collected.add(s);
            od

            Assert.are_equal(3, collected.count);
        si

        // Like build_three_variant_union but with a fourth variant,
        // so member-union joins have room to stay a proper subset.
        build_four_variant_union() -> (the_union: UNION, a: VARIANT, b: VARIANT, c: VARIANT, d: VARIANT) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let the_union = UNION(loc(), loc(), null, "U", empty_names(), false, null);
            the_union.add_ancestor(object_class.type!);

            let a = cast VARIANT(the_union.declare_variant(loc(), loc(), "A", false, null, null));
            let b = cast VARIANT(the_union.declare_variant(loc(), loc(), "B", false, null, null));
            let c = cast VARIANT(the_union.declare_variant(loc(), loc(), "C", false, null, null));
            let d = cast VARIANT(the_union.declare_variant(loc(), loc(), "D", false, null, null));

            return (the_union, a, b, c, d);
        si

        build_one_of(underlying: NAMED, first: Classy, second: Classy) -> ONE_OF is
            let variants = LIST[Classy]();
            variants.add(first);
            variants.add(second);

            return cast ONE_OF(ONE_OF.create(underlying, variants));
        si

        As_optional__preserves_shape_and_flags_optional() is
            @test()

            let h = build_three_variant_union();
            let one_of = build_one_of(cast NAMED(h.the_union.type!), h.a, h.b);

            let optional = one_of.as_optional();

            Assert.is_true(optional.is_optional);
            Assert.is_true(isa ONE_OF(optional));

            let optional_one_of = cast ONE_OF(optional);
            Assert.is_true(optional_one_of.contains_subtype(h.a));
            Assert.is_true(optional_one_of.contains_subtype(h.b));
            Assert.is_true(optional.to_string().ends_with("?"));

            let stripped = optional.as_non_optional();

            Assert.is_false(stripped.is_optional);
            Assert.is_true(isa ONE_OF(stripped));
            Assert.is_false(stripped.to_string().ends_with("?"));
        si

        Try_join__one_of_with_sibling_alternative__unions_members() is
            @test()

            let h = build_four_variant_union();
            let underlying = cast NAMED(h.the_union.type!);
            let one_of = build_one_of(underlying, h.a, h.b);

            let joined = ONE_OF.try_join(one_of, NAMED(h.c));

            Assert.is_true(isa ONE_OF(joined));

            let joined_one_of = cast ONE_OF(joined);
            Assert.are_equal(3, joined_one_of.subtypes_count);
            Assert.is_true(joined_one_of.contains_subtype(h.a));
            Assert.is_true(joined_one_of.contains_subtype(h.b));
            Assert.is_true(joined_one_of.contains_subtype(h.c));
            Assert.is_false(joined_one_of.contains_subtype(h.d));
            Assert.is_false(joined.is_optional);
        si

        Try_join__two_one_ofs__unions_members() is
            @test()

            let h = build_four_variant_union();
            let underlying = cast NAMED(h.the_union.type!);

            let joined = ONE_OF.try_join(
                build_one_of(underlying, h.a, h.b),
                build_one_of(underlying, h.b, h.c)
            );

            Assert.is_true(isa ONE_OF(joined));

            let joined_one_of = cast ONE_OF(joined);
            Assert.are_equal(3, joined_one_of.subtypes_count);
            Assert.is_false(joined_one_of.contains_subtype(h.d));
        si

        Try_join__covering_every_alternative__returns_underlying() is
            @test()

            let h = build_three_variant_union();
            let underlying = cast NAMED(h.the_union.type!);
            let one_of = build_one_of(underlying, h.a, h.b);

            let joined = ONE_OF.try_join(one_of, NAMED(h.c));

            Assert.are_same(underlying, joined);
        si

        Try_join__either_side_optional__result_is_optional() is
            @test()

            let h = build_three_variant_union();
            let underlying = cast NAMED(h.the_union.type!);
            let one_of = build_one_of(underlying, h.a, h.b);

            let joined = ONE_OF.try_join(one_of.as_optional(), NAMED(h.c));

            Assert.is_not_null(joined);
            Assert.is_true(joined.is_optional);
            Assert.is_false(isa ONE_OF(joined));
            Assert.are_same(underlying.symbol, (cast NAMED(joined)).symbol);
        si

        Try_join__no_one_of_side__returns_null() is
            @test()

            let h = build_three_variant_union();

            let joined = ONE_OF.try_join(NAMED(h.a), NAMED(h.b));

            Assert.is_null(joined);
        si

        Try_join__different_roots__returns_null() is
            @test()

            let first = build_four_variant_union();
            let second = build_three_variant_union();

            let joined = ONE_OF.try_join(
                build_one_of(cast NAMED(first.the_union.type!), first.a, first.b),
                build_one_of(cast NAMED(second.the_union.type!), second.a, second.b)
            );

            Assert.is_null(joined);
        si

        Try_join__whole_root_side__returns_underlying() is
            @test()

            let h = build_three_variant_union();
            let underlying = cast NAMED(h.the_union.type!);
            let one_of = build_one_of(underlying, h.a, h.b);

            let joined = ONE_OF.try_join(one_of, NAMED(h.the_union));

            Assert.are_same(underlying, joined);
        si
    si
si
