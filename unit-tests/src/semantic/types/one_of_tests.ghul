namespace Semantic.Types.UnitTests is
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Classy;
    use Semantic.Symbols.UNION;
    use Semantic.Symbols.VARIANT;
    use Semantic.Types.GENERIC;
    use Semantic.Types.NAMED;
    use Semantic.Types.ONE_OF;
    use Semantic.Types.Type;

    // Tests for Types.ONE_OF — the internal narrowing-only sum
    // representing "value of union U restricted to a proper variant
    // subset". The contract guards three invariants:
    //
    //   - Construction is by factory: |variants| = 0 → null;
    //     |variants| = 1 → bare variant type; |variants| ≥ 2 → ONE_OF.
    //     The size-1 degeneracy keeps assignability rules simple.
    //   - Membership lookup (contains_variant) is by reference, since
    //     variant Classy symbols have stable identity.
    //   - build_singleton_variant_type threads the underlying receiver
    //     into the constructed variant type so generic args carry
    //     through narrowing.
    //
    // Identity (=~) is exercised end-to-end via the integration tests
    // in execution/one-of-narrowing-1265 — the NARROWING.try_push
    // "did anything change" check relies on ONE_OF !=~ plain union,
    // and the narrowing exercising that is the surest probe.
    class ONE_OF_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // Construct {union, variant_a, variant_b, variant_c} mirroring
        // how declare_variant wires variants under a union scope.
        build_three_variant_union() -> (the_union: UNION, a: VARIANT, b: VARIANT, c: VARIANT) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let the_union = UNION(loc(), loc(), null, "U", empty_names(), false, null);
            the_union.add_ancestor(object_class.type);

            let a = VARIANT(loc(), loc(), the_union, "A", empty_names(), false, null);
            let b = VARIANT(loc(), loc(), the_union, "B", empty_names(), false, null);
            let c = VARIANT(loc(), loc(), the_union, "C", empty_names(), false, null);

            return (the_union, a, b, c);
        si

        Create__with_empty_variants__returns_null() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();

            let result = ONE_OF.create(cast NAMED(h.the_union.type), variants);

            Assert.is_null(result);
        si

        Create__with_one_variant_and_non_generic_underlying__returns_plain_variant_NAMED() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);

            let result = ONE_OF.create(cast NAMED(h.the_union.type), variants);

            Assert.is_not_null(result);
            Assert.is_false(isa ONE_OF(result));
            Assert.is_true(isa NAMED(result));
            Assert.are_same(h.a, (cast NAMED(result)).symbol);
        si

        Create__with_two_variants__returns_ONE_OF() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);

            let result = ONE_OF.create(cast NAMED(h.the_union.type), variants);

            Assert.is_not_null(result);
            Assert.is_true(isa ONE_OF(result));

            let one_of = cast ONE_OF(result);
            Assert.are_equal(2, one_of.variants_count);
            Assert.is_true(one_of.contains_variant(h.a));
            Assert.is_true(one_of.contains_variant(h.b));
            Assert.is_false(one_of.contains_variant(h.c));
        si

        Create__with_three_variants__returns_ONE_OF_carrying_all() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);
            variants.add(h.c);

            let result = ONE_OF.create(cast NAMED(h.the_union.type), variants);

            Assert.is_true(isa ONE_OF(result));

            let one_of = cast ONE_OF(result);
            Assert.are_equal(3, one_of.variants_count);
            Assert.is_true(one_of.contains_variant(h.a));
            Assert.is_true(one_of.contains_variant(h.b));
            Assert.is_true(one_of.contains_variant(h.c));
        si

        Create__with_null_underlying__returns_null() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);

            let result = ONE_OF.create(null, variants);

            Assert.is_null(result);
        si

        Contains_variant__null_input__returns_false() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);

            let one_of = ONE_OF(cast NAMED(h.the_union.type), variants);

            Assert.is_false(one_of.contains_variant(null));
        si

        Underlying_type__exposes_constructor_argument() is
            @test()

            let h = build_three_variant_union();
            let variants = LIST[Classy]();
            variants.add(h.a);
            variants.add(h.b);

            let underlying = cast NAMED(h.the_union.type);
            let one_of = ONE_OF(underlying, variants);

            Assert.are_same(underlying, one_of.underlying_type);
        si

        Build_singleton_variant_type__non_generic_underlying__returns_variant_NAMED() is
            @test()

            let h = build_three_variant_union();
            let underlying = cast NAMED(h.the_union.type);

            let result = ONE_OF.build_singleton_variant_type(underlying, h.a);

            Assert.is_not_null(result);
            Assert.is_false(isa GENERIC(result));
            Assert.are_same(h.a, result.symbol);
        si
    si
si
