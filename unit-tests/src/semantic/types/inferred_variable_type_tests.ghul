namespace Semantic.Types.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;
    use Semantic.Types.INFERRED_VARIABLE_TYPE;

    // INFERRED_VARIABLE_TYPE is the placeholder Type used while a
    // Variable's true type is being inferred via the body-retry loop.
    // Its `to_string` is consumed by analyse-mode HOVER through the
    // owning Symbols.GENERIC's `qualified_name` (which formats each
    // type-arg via to_string). Pin the resolution-at-render contract:
    // an unresolved phantom renders as `***`; a phantom whose origin
    // has settled renders as the resolved type's to_string.
    class INFERRED_VARIABLE_TYPE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        Calling__to_string__on_unresolved_phantom__should_return_marker() is
            @test()

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "p");
            let placeholder = INFERRED_VARIABLE_TYPE(origin);

            Assert.are_equal("***", placeholder.to_string());
        si

        Calling__to_string__on_phantom_whose_origin_has_settled__should_render_resolved_type() is
            @test()

            // Add a concrete constraint so the origin's body-retry LUB
            // resolves to that type. INFERRED_VARIABLE_TYPE.to_string
            // should forward to the resolved type's to_string rather
            // than the `***` marker.
            let cat = CLASS(loc(), loc(), null, "cat", LIST[string](), false, null);

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "p");
            origin.add_lower_bound(cat.type);

            let placeholder = INFERRED_VARIABLE_TYPE(origin);

            Assert.are_equal(cat.type.to_string(), placeholder.to_string());
        si
    si
si
