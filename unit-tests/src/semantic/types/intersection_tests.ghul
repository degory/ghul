namespace Semantic.Types.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.EMPTY_SCOPE;
    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.TRAIT;
    use Semantic.Types.NAMED;
    use Semantic.Types.INTERSECTION;

    // An INTERSECTION delegates its NAMED-level identity queries to its
    // representative member: `name` is the representative's name (never
    // null) and `scope` is the representative's symbol.
    class INTERSECTION_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        a_reference_class(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, LIST[string](), false, null);

        a_trait(name: string) -> TRAIT is
            let scope = EMPTY_SCOPE("");
            return TRAIT(loc(), loc(), scope, name, LIST[string](), false, scope);
        si

        // A class-and-trait intersection survives with the class as its
        // representative (the concrete member).
        an_intersection() -> INTERSECTION is
            let foo = cast NAMED(a_reference_class("Foo").type);
            let bar = cast NAMED(a_trait("Bar").type);

            let result = INTERSECTION.create(foo, bar);

            Assert.is_true(isa INTERSECTION(result));

            return cast INTERSECTION(result);
        si

        name__delegates_to_representative() is
            @test()

            let intersection = an_intersection();

            Assert.is_not_null(intersection.name);
            Assert.are_equal(intersection.representative.name, intersection.name);
        si

        scope__delegates_to_representative_symbol() is
            @test()

            let intersection = an_intersection();

            Assert.are_same(intersection.representative.symbol, intersection.scope);
        si

        // No runtime value carries two unrelated concrete identities,
        // so no intersection exists for such a pair.
        try_create__returns_null_for_two_unrelated_classes() is
            @test()

            let foo = cast NAMED(a_reference_class("Foo").type);
            let bar = cast NAMED(a_reference_class("Bar").type);

            Assert.is_null(INTERSECTION.try_create(foo, bar));
        si

        try_create__composes_class_and_trait() is
            @test()

            let foo = cast NAMED(a_reference_class("Foo").type);
            let bar = cast NAMED(a_trait("Bar").type);

            let result = INTERSECTION.try_create(foo, bar);

            Assert.is_not_null(result);
            Assert.is_true(isa INTERSECTION(result));
        si
    si
si
