namespace Semantic.Types.UnitTests is
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Classy;
    use Semantic.Symbols.STRUCT;
    use Semantic.Types.ClassType;
    use Semantic.Types.MATCH;
    use Semantic.Types.TYPE_OPERATIONS;
    use Semantic.Types.TYPE_VARIANCE;
    use Semantic.Types.Type;

    // Tests for the Phase 2 ClassType — the new representation that
    // owns its type arguments directly without going through
    // Symbols.GENERIC. Mirrors the existing GENERIC_VARIANCE_TESTS so
    // we can confirm parity with the old shape.
    class CLASS_TYPE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        build_hierarchy() -> (object_class: CLASS, animal: CLASS, cat: CLASS, int_struct: STRUCT) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let animal = CLASS(loc(), loc(), null, "animal", empty_names(), false, null);
            animal.add_ancestor(object_class.type);

            let cat = CLASS(loc(), loc(), null, "cat", empty_names(), false, null);
            cat.add_ancestor(animal.type);

            let int_struct = STRUCT(loc(), loc(), null, "int", empty_names(), false, null);
            int_struct.add_ancestor(object_class.type);

            return (object_class, animal, cat, int_struct);
        si

        ClassType__classy_and_arguments__are_what_was_passed_in() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);

            let args = LIST[Type]();
            args.add(h.cat.type);

            let ct = ClassType(owner, args);

            Assert.are_same(owner, ct.classy);
            Assert.are_equal(1, ct.arguments.count);
            Assert.are_same(h.cat.type, ct.arguments[0]);
        si

        ClassType__short_description__renders_classy_and_args() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);

            let args = LIST[Type]();
            args.add(h.cat.type);

            let ct = ClassType(owner, args);

            Assert.are_equal("owner[cat]", ct.short_description);
        si

        ClassType__type_map__is_keyed_by_argument_names() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "owner", ["T", "U"], false, null);

            let args = LIST[Type]();
            args.add(h.cat.type);
            args.add(h.animal.type);

            let ct = ClassType(owner, args);

            Assert.is_true(ct.type_map.contains_key("T"));
            Assert.is_true(ct.type_map.contains_key("U"));
            Assert.are_same(h.cat.type, ct.type_map["T"]);
            Assert.are_same(h.animal.type, ct.type_map["U"]);
        si

        ClassType__get_argument_type_variance__with_reference_arg__returns_declared() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "iterable_like", ["T"], false, null);
            owner.argument_variances = [TYPE_VARIANCE.COVARIANT];

            let args = LIST[Type]();
            args.add(h.cat.type);

            let ct = ClassType(owner, args);

            Assert.are_equal(TYPE_VARIANCE.COVARIANT, ct.get_argument_type_variance(0));
        si

        ClassType__get_argument_type_variance__with_value_type_arg__suppresses_variance() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "iterable_like", ["T"], false, null);
            owner.argument_variances = [TYPE_VARIANCE.COVARIANT];

            let args = LIST[Type]();
            args.add(h.int_struct.type);

            let ct = ClassType(owner, args);

            Assert.are_equal(TYPE_VARIANCE.INVARIANT, ct.get_argument_type_variance(0));
        si

        ClassType__get_argument_type_variance__with_unset_variances__returns_INVARIANT() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "ghul_generic", ["T"], false, null);

            let args = LIST[Type]();
            args.add(h.cat.type);

            let ct = ClassType(owner, args);

            Assert.are_equal(TYPE_VARIANCE.INVARIANT, ct.get_argument_type_variance(0));
        si

        ClassType__compare_self__returns_SAME() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);

            let args = LIST[Type]();
            args.add(h.cat.type);

            let ct = ClassType(owner, args);

            Assert.are_equal(MATCH.SAME, ct.compare(ct));
        si

        ClassType__compare_invariant_different_arg__returns_DIFFERENT() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);
            // No declared variance — defaults to INVARIANT.

            let cat_args = LIST[Type]();
            cat_args.add(h.cat.type);
            let cat_ct = ClassType(owner, cat_args);

            let animal_args = LIST[Type]();
            animal_args.add(h.animal.type);
            let animal_ct = ClassType(owner, animal_args);

            // Invariant: cat-of-owner is not assignable to animal-of-owner
            // even though cat is assignable to animal.
            Assert.are_equal(MATCH.DIFFERENT, animal_ct.compare(cat_ct));
        si

        ClassType__compare_covariant_subtype_arg__returns_ASSIGNABLE() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "iterable_like", ["T"], false, null);
            owner.argument_variances = [TYPE_VARIANCE.COVARIANT];

            let cat_args = LIST[Type]();
            cat_args.add(h.cat.type);
            let cat_ct = ClassType(owner, cat_args);

            let animal_args = LIST[Type]();
            animal_args.add(h.animal.type);
            let animal_ct = ClassType(owner, animal_args);

            // Covariant: cat-of-owner IS assignable to animal-of-owner
            // because cat is assignable to animal.
            Assert.are_equal(MATCH.ASSIGNABLE, animal_ct.compare(cat_ct));
        si

        ClassType__equality__same_classy_and_args__are_tilde_equal() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);

            let args1 = LIST[Type]();
            args1.add(h.cat.type);

            let args2 = LIST[Type]();
            args2.add(h.cat.type);

            let ct1 = ClassType(owner, args1);
            let ct2 = ClassType(owner, args2);

            Assert.is_true(ct1 =~ ct2);
        si

        ClassType__equality__different_args__are_not_tilde_equal() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);

            let cat_args = LIST[Type]();
            cat_args.add(h.cat.type);
            let cat_ct = ClassType(owner, cat_args);

            let animal_args = LIST[Type]();
            animal_args.add(h.animal.type);
            let animal_ct = ClassType(owner, animal_args);

            Assert.is_false(cat_ct =~ animal_ct);
        si

        TYPE_OPERATIONS__recognises_ClassType_as_application() is
            @test()

            let h = build_hierarchy();

            let owner = CLASS(loc(), loc(), null, "owner", ["T"], false, null);

            let args = LIST[Type]();
            args.add(h.cat.type);

            let ct = ClassType(owner, args);

            Assert.is_true(TYPE_OPERATIONS.is_application_of(ct, owner));
            Assert.is_true(TYPE_OPERATIONS.is_closed_application(ct));
            Assert.is_false(TYPE_OPERATIONS.is_open_application(ct));
            Assert.are_same(owner, TYPE_OPERATIONS.try_get_classy(ct));
            Assert.are_same(args, TYPE_OPERATIONS.try_get_arguments(ct));
        si
    si
si
