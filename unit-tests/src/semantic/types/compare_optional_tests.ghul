namespace Semantic.Types.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Types.NAMED;
    use Semantic.Types.NULLABLE;
    use Semantic.Types.Type;

    // Tests for the shared `Types.NULLABLE.compare_optional` static —
    // the implicit T → T? widening contract that the source-side
    // `NULLABLE[T]` and the reflected `NULLABLE_TYPE_WRAPPER` (System.
    // Nullable[T]) both delegate to. The substantive guarantee is
    // that a bare `T` against a `NULLABLE[T]` is reported as
    // ASSIGNABLE (not SAME), so an overload resolver with both
    // `f(T)` and `f(T?)` candidates and a `T` argument still
    // prefers `f(T)`.
    //
    // The NULLABLE_TYPE_WRAPPER's `compare` is a one-line delegation
    // to this same static and its `is_optional` is a hardcoded
    // `=> true`; pinning that path requires a SYMBOL_TABLE +
    // TYPE_MAPPER + real reflected `Nullable<T>` fixture, well
    // beyond the existing unit-test altitude. The reflected path
    // is covered end-to-end by `project-tests/nullable-interop`
    // and `integration-tests/execution/optional-null-argument`.
    class COMPARE_OPTIONAL_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        // The inner T's class — a plain (non-struct) class is enough
        // here, since compare_optional only consults
        // `arguments[0].is_assignable_from(other)` and the optional
        // flag, not the value-type-ness of T.
        an_inner_class() -> CLASS =>
            CLASS(loc(), loc(), null, "Inner", empty_names(), false, null);

        // A stand-in for System.Nullable[T] — must declare one
        // type parameter so `Symbols.GENERIC` accepts it as the
        // generic underlying. compare_optional uses it only as a
        // generic container; the symbol identity is never inspected.
        a_nullable_class() -> CLASS =>
            CLASS(loc(), loc(), null, "Nullable", names_for(["T"]), false, null);

        build_nullable_over(inner_class: CLASS) -> NULLABLE is
            let arguments = LIST[Type]();
            arguments.add(inner_class.type!);
            return NULLABLE(loc(), a_nullable_class(), arguments);
        si

        is_optional__on_NULLABLE__is_true() is
            @test()

            let opt = build_nullable_over(an_inner_class());

            Assert.is_true(opt.is_optional);
        si

        compare_optional__when_direct_is_SAME__returns_direct() is
            @test()

            let opt = build_nullable_over(an_inner_class());

            let result = NULLABLE.compare_optional(opt, opt, Types.MATCH.SAME);

            Assert.are_equal(Types.MATCH.SAME, result);
        si

        compare_optional__when_direct_is_ASSIGNABLE__returns_direct() is
            @test()

            let opt = build_nullable_over(an_inner_class());

            let result = NULLABLE.compare_optional(opt, opt, Types.MATCH.ASSIGNABLE);

            Assert.are_equal(Types.MATCH.ASSIGNABLE, result);
        si

        compare_optional__bare_T_against_NULLABLE_T__widens_to_ASSIGNABLE() is
            @test()

            // The central widening contract: a NULLABLE[T] sees a
            // bare T as ASSIGNABLE (not SAME), so f(T) still wins
            // overload resolution over f(T?) for a T argument.
            let inner = an_inner_class();
            let opt = build_nullable_over(inner);
            let bare_t = inner.type!;

            let result = NULLABLE.compare_optional(opt, bare_t, Types.MATCH.DIFFERENT);

            Assert.are_equal(Types.MATCH.ASSIGNABLE, result);
        si

        compare_optional__NULLABLE_T_against_already_optional_T__does_not_widen() is
            @test()

            // !other.is_optional gate: an already-optional other
            // is left to `direct`. Use the reference-type spelling
            // (NAMED.as_optional) for `other` to keep the fixture
            // simple — only its `is_optional` is consulted here.
            let inner = an_inner_class();
            let opt = build_nullable_over(inner);
            let already_optional = (cast NAMED(inner.type!)).as_optional();

            let result = NULLABLE.compare_optional(opt, already_optional, Types.MATCH.DIFFERENT);

            Assert.are_equal(Types.MATCH.DIFFERENT, result);
        si

        compare_optional__null_other__returns_direct() is
            @test()

            let opt = build_nullable_over(an_inner_class());

            let result = NULLABLE.compare_optional(opt, null, Types.MATCH.DIFFERENT);

            Assert.are_equal(Types.MATCH.DIFFERENT, result);
        si

        compare_optional__error_other__returns_direct() is
            @test()

            let opt = build_nullable_over(an_inner_class());

            let result = NULLABLE.compare_optional(opt, Types.ERROR(), Types.MATCH.DIFFERENT);

            Assert.are_equal(Types.MATCH.DIFFERENT, result);
        si

        compare__NULLABLE_T_against_bare_T__widens_to_ASSIGNABLE() is
            @test()

            // End-to-end through NULLABLE.compare (the instance
            // method that wires super.compare into compare_optional)
            // — pins the in-tree delegation alongside the static.
            let inner = an_inner_class();
            let opt = build_nullable_over(inner);

            let result = opt.compare(inner.type!);

            Assert.are_equal(Types.MATCH.ASSIGNABLE, result);
        si

        // A stand-in for Ghul.MAYBE[T] — declares one type parameter
        // so Symbols.GENERIC accepts it as the generic underlying;
        // identity comes from Types.MAYBE.
        a_maybe_class() -> CLASS =>
            CLASS(loc(), loc(), null, "MAYBE", names_for(["T"]), false, null);

        build_maybe_over(inner_class: CLASS) -> Types.MAYBE is
            let arguments = LIST[Type]();
            arguments.add(inner_class.type!);
            return Types.MAYBE(loc(), a_maybe_class(), arguments);
        si

        compare_optional__NULLABLE_T_against_MAYBE_matching_T__widens_to_ASSIGNABLE() is
            @test()

            // The value-type MAYBE -> T? widening — both ends are
            // sequential-layout structs declared `(bool, T)`, so the
            // slot boundary's struct copy already produces a
            // well-formed Nullable[T] without any IL coercion.
            // Reported ASSIGNABLE (not SAME) so a `f(T)` candidate
            // still wins overload resolution over `f(T?)`.
            let inner = an_inner_class();
            let opt = build_nullable_over(inner);
            let maybe = build_maybe_over(inner);

            let result = NULLABLE.compare_optional(opt, maybe, Types.MATCH.DIFFERENT);

            Assert.are_equal(Types.MATCH.ASSIGNABLE, result);
        si

        compare_optional__NULLABLE_T_against_MAYBE_mismatched_T__does_not_widen() is
            @test()

            // Different T — `int?` does not accept `MAYBE[Other]`.
            // Pinned so a refactor of the MAYBE branch can't
            // accidentally drop the argument check and widen any
            // single-arg generic into the optional.
            let other =
                CLASS(loc(), loc(), null, "Other", empty_names(), false, null);

            let opt = build_nullable_over(an_inner_class());
            let maybe = build_maybe_over(other);

            let result = NULLABLE.compare_optional(opt, maybe, Types.MATCH.DIFFERENT);

            Assert.are_equal(Types.MATCH.DIFFERENT, result);
        si
    si
si
