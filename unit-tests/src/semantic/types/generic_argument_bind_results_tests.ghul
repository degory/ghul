namespace Semantic.Types.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Symbols.INFERRED_TYPE_ARG_ORIGIN;
    use Semantic.Types.GENERIC_ARGUMENT_BIND_RESULTS;
    use Semantic.Types.GenericArgument;
    use Semantic.Types.INFERRED_VARIABLE_TYPE;
    use Semantic.Types.Type;

    // Tests for GENERIC_ARGUMENT_BIND_RESULTS.bind — the per-binding
    // accumulator used during overload resolution to infer concrete
    // generic-argument types from actual call-site argument types.
    //
    // The contract: when `bind(T, X)` is called repeatedly across the
    // arguments of a generic-method call, the binding for T should converge
    // on the least upper bound of all the X values seen. The current
    // pairwise-widening implementation handles the "one is assignable from
    // the other" case correctly but gives up on siblings — it sets the
    // binding to NONE and returns false, killing the overload match. These
    // tests pin both the working cases and the failing siblings case so
    // future changes to the binding logic don't silently regress overload
    // resolution.
    class GENERIC_ARGUMENT_BIND_RESULTS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        // The same animal/plant hierarchy used in the LUB tests:
        //
        //   object_class
        //     ├── animal
        //     │     ├── cat
        //     │     └── dog
        //     └── plant
        build_hierarchy() -> (object_class: CLASS, animal: CLASS, cat: CLASS, dog: CLASS, plant: CLASS) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let animal = CLASS(loc(), loc(), null, "animal", empty_names(), false, null);
            animal.add_ancestor(object_class.type!);

            let cat = CLASS(loc(), loc(), null, "cat", empty_names(), false, null);
            cat.add_ancestor(animal.type!);

            let dog = CLASS(loc(), loc(), null, "dog", empty_names(), false, null);
            dog.add_ancestor(animal.type!);

            let plant = CLASS(loc(), loc(), null, "plant", empty_names(), false, null);
            plant.add_ancestor(object_class.type!);

            return (object_class, animal, cat, dog, plant);
        si

        type_param() -> GenericArgument =>
            cast GenericArgument(CLASSY_GENERIC_ARGUMENT(loc(), null, "T", 0).type);

        Calling__bind__twice_with_the_same_type__should_resolve_to_that_type() is
            @test()

            let h = build_hierarchy();
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            Assert.is_true(r.bind(t, h.cat.type!));
            Assert.is_true(r.bind(t, h.cat.type!));

            Assert.are_same(h.cat.type!, r.bindings["T"].actual_type);
        si

        Calling__bind__with_subtype_then_ancestor__should_widen_to_ancestor() is
            @test()

            let h = build_hierarchy();
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            Assert.is_true(r.bind(t, h.cat.type!));
            Assert.is_true(r.bind(t, h.animal.type!));

            Assert.are_same(h.animal.type!, r.bindings["T"].actual_type);
        si

        Calling__bind__with_ancestor_then_subtype__should_keep_ancestor() is
            @test()

            let h = build_hierarchy();
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            Assert.is_true(r.bind(t, h.animal.type!));
            Assert.is_true(r.bind(t, h.cat.type!));

            Assert.are_same(h.animal.type!, r.bindings["T"].actual_type);
        si

        Calling__bind__with_two_siblings__should_resolve_to_their_common_ancestor() is
            @test()

            // This is the failing case that #1173 calls out: when two
            // arguments of a generic method have sibling types (Cat and
            // Dog), the binding currently sets actual_type to NONE and
            // returns false, killing the overload match. After applying
            // LUB, the binding should resolve to their common ancestor.
            let h = build_hierarchy();
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            Assert.is_true(r.bind(t, h.cat.type!));
            Assert.is_true(r.bind(t, h.dog.type!));

            Assert.are_same(h.animal.type!, r.bindings["T"].actual_type);
        si

        // The next four tests pin the match propagation behaviour added for
        // no-arg generic constructor calls inside another generic call —
        // e.g. `CONS(x, NIL())` where NIL is a no-arg union variant.
        // NIL's owner type-arg is a phantom Variable (no value args to
        // pin it from). When `bind` sees that phantom paired against an
        // already-bound concrete (from the x sibling), the concrete
        // gets pushed back onto the phantom's origin via add_constraint
        // so the body-retry resolves the phantom to the same concrete
        // rather than defaulting to object.

        Calling__bind__with_existing_concrete_then_phantom__should_propagate_concrete_to_phantom() is
            @test()

            let h = build_hierarchy();
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "phantom");
            let placeholder = INFERRED_VARIABLE_TYPE(origin);

            Assert.is_true(r.bind(t, h.cat.type!));
            Assert.is_true(r.bind(t, placeholder));

            Assert.are_same(h.cat.type!, r.bindings["T"].actual_type);
            Assert.are_same(h.cat.type!, origin.try_get_inferred_type());
        si

        Calling__bind__with_phantom_first_then_concrete__should_only_keep_concrete() is
            @test()

            // Phantom arrives before the concrete: the first call hits the
            // `actual_type.is_sentinel` branch with no existing binding and an
            // unresolved placeholder, so it adds nothing and returns true.
            // The second call then creates the binding fresh under the
            // final `else` — no match propagation involved, no replacement.
            let h = build_hierarchy();
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "phantom");
            let placeholder = INFERRED_VARIABLE_TYPE(origin);

            Assert.is_true(r.bind(t, placeholder));
            Assert.is_true(r.bind(t, h.cat.type!));

            Assert.are_same(h.cat.type!, r.bindings["T"].actual_type);
        si

        Calling__bind__with_two_phantoms__should_not_propagate_either() is
            @test()

            // Back-feeding one unresolved placeholder into another's
            // LUB would just propagate uncertainty. Skip in that case.
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            let origin_a = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "phantom_a");
            let origin_b = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "phantom_b");

            Assert.is_true(r.bind(t, INFERRED_VARIABLE_TYPE(origin_a)));
            Assert.is_true(r.bind(t, INFERRED_VARIABLE_TYPE(origin_b)));

            Assert.is_null(origin_a.try_get_inferred_type());
            Assert.is_null(origin_b.try_get_inferred_type());
        si

        Calling__bind__with_three_args_concrete_phantom_concrete__should_propagate_widest_to_phantom() is
            @test()

            // Three-arg generic call like `f[T](a: T, b: T, c: T)` with
            // actuals (cat, NIL_phantom, dog): after the third bind the
            // concrete binding has widened to animal via LUB. The phantom
            // was propagated cat at the second bind; pinning current
            // behaviour here so any future change to "re-feed on LUB
            // widen" is a deliberate decision.
            let h = build_hierarchy();
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            let origin = INFERRED_TYPE_ARG_ORIGIN(loc(), null, "phantom");
            let placeholder = INFERRED_VARIABLE_TYPE(origin);

            Assert.is_true(r.bind(t, h.cat.type!));
            Assert.is_true(r.bind(t, placeholder));
            Assert.is_true(r.bind(t, h.dog.type!));

            Assert.are_same(h.animal.type!, r.bindings["T"].actual_type);
            Assert.are_same(h.cat.type!, origin.try_get_inferred_type());
        si

        Calling__bind_type_variables__with_an_optional_reference_actual__binds_T_to_the_actual_whole() is
            @test()

            // Formal T (a bare GenericArgument) bound against an optional
            // reference like `Cat?` binds T to the full `Cat?` — we do
            // not peel `?` off the actual at bind time. The directional
            // `compare` (T? slot vs T value → ASSIGNABLE; T slot vs T?
            // value → DIFFERENT) is what keeps optional/non-optional
            // distinct during overload resolution; the binding step
            // stays faithful to the actual.
            let h = build_hierarchy();
            let r = GENERIC_ARGUMENT_BIND_RESULTS();
            let t = type_param();

            let cat_optional = h.cat.type!.as_optional();

            Assert.is_true(t.bind_type_variables(cat_optional, r));

            Assert.are_same(cat_optional, r.bindings["T"].actual_type);
        si
    si
si
