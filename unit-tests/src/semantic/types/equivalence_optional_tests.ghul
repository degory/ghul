namespace Semantic.Types.UnitTests is
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Types.GENERIC;
    use Semantic.Types.NAMED;
    use Semantic.Types.REFERENCE;
    use Semantic.Types.TypeVariance;
    use Semantic.Types.Type;

    // Truth table for the `=~` equivalence operator and for
    // `compare` at invariant generic-argument positions, focused on
    // how each treats the optional flag.
    //
    // `=~` currently ignores the flag entirely: `T? =~ T` is true at
    // the NAMED level, and GENERIC's per-argument loop inherits that
    // blindness, so `LIST[T?] =~ LIST[T]` and `T? ref =~ T ref` are
    // true as well. Because GENERIC.compare_direct delegates
    // invariant argument positions to `=~`, the blindness reaches the
    // assignability path: a `T? ref` argument satisfies a `T ref`
    // parameter, and a `LIST[T?]` value flows into a `LIST[T]` slot.
    // Both compile today and NPE at runtime. The cases below that pin
    // that behaviour are marked UNSOUND.
    //
    // Covariant argument positions go through `compare` instead,
    // which learned the strict optional rules when the option flag
    // was unified — those cases are pinned here as the behaviour the
    // invariant positions should agree with.
    class EQUIVALENCE_OPTIONAL_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        a_reference_class(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, empty_names(), false, null);

        // A generic owner with no variance metadata — its parameters
        // are invariant, like every source-defined ghūl generic.
        an_invariant_owner() -> CLASS =>
            CLASS(loc(), loc(), null, "box_like", ["T"], false, null);

        a_covariant_owner() -> CLASS is
            let owner = CLASS(loc(), loc(), null, "iterable_like", ["T"], false, null);
            owner.argument_variances = [TypeVariance.COVARIANT];
            return owner;
        si

        of(owner: CLASS, argument: Type) -> GENERIC is
            let args = LIST[Type]();
            args.add(argument);
            return GENERIC(loc(), owner, args);
        si

        ref_of(owner: CLASS, argument: Type) -> GENERIC is
            let args = LIST[Type]();
            args.add(argument);
            return REFERENCE(loc(), owner, args);
        si

        // --- =~ at the NAMED level ---------------------------------

        equiv__bare_against_same_bare__is_true() is
            @test()

            let bare = a_reference_class("cat").type;

            Assert.is_true(bare.equals(bare));
        si

        equiv__optional_against_same_optional__is_true() is
            @test()

            let bare = cast NAMED(a_reference_class("cat").type);
            let optional = bare.as_optional();

            Assert.is_true(optional.equals(optional));
        si

        equiv__different_symbols__is_false() is
            @test()

            let cat = a_reference_class("cat").type;
            let dog = a_reference_class("dog").type;

            Assert.is_false(cat.equals(dog));
        si

        equiv__bare_against_optional__is_true() is
            @test()

            // UNSOUND: `=~` compares symbols only, so the optional
            // flag is invisible to it. `cat =~ cat?` should be false.
            let bare = cast NAMED(a_reference_class("cat").type);
            let optional = bare.as_optional();

            Assert.is_true(bare.equals(optional));
        si

        equiv__optional_against_bare__is_true() is
            @test()

            // UNSOUND: mirror image of the case above.
            let bare = cast NAMED(a_reference_class("cat").type);
            let optional = bare.as_optional();

            Assert.is_true(optional.equals(bare));
        si

        // --- =~ at the GENERIC level -------------------------------

        equiv__generic_against_same_construction__is_true() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            // Two separate constructions, so the same-symbol fast
            // path misses and the per-argument loop runs.
            Assert.is_true(of(owner, cat).equals(of(owner, cat)));
        si

        equiv__generic_optional_arg_against_bare_arg__is_true() is
            @test()

            // UNSOUND: the per-argument loop compares with `=~`,
            // inheriting its optional-blindness. box_like[cat?]
            // should not be equivalent to box_like[cat].
            let owner = an_invariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.is_true(of(owner, cat.as_optional()).equals(of(owner, cat)));
        si

        equiv__outer_optional_generic_against_bare_generic__is_true() is
            @test()

            // UNSOUND: `as_optional` clones the type but shares the
            // symbol, so the same-symbol fast path answers true
            // before the outer flags are ever looked at.
            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            let bare = of(owner, cat);
            let optional = cast GENERIC(bare.as_optional());

            Assert.is_true(optional.equals(bare));
        si

        // --- compare at invariant argument positions ---------------

        compare__generic_against_same_construction__is_SAME() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            Assert.are_equal(Types.MATCH.SAME, of(owner, cat).compare(of(owner, cat)));
        si

        compare__generic_slot_against_optional_arg_value__is_SAME() is
            @test()

            // UNSOUND: this is the assignability hole. A
            // box_like[cat] slot accepts a box_like[cat?] value, so a
            // null can be read out of a supposedly non-null position.
            // Should be DIFFERENT.
            let owner = an_invariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.SAME,
                of(owner, cat).compare(of(owner, cat.as_optional()))
            );
        si

        compare__generic_optional_arg_slot_against_bare_value__is_SAME() is
            @test()

            // UNSOUND: invariance cuts both ways — box_like[cat?]
            // accepting box_like[cat] lets the callee store null into
            // the caller's non-optional container. Should be
            // DIFFERENT.
            let owner = an_invariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.SAME,
                of(owner, cat.as_optional()).compare(of(owner, cat))
            );
        si

        compare__ref_slot_against_optional_ref_value__is_SAME() is
            @test()

            // UNSOUND: `x ref` is a REFERENCE generic over the
            // operand's declared type, so passing a `cat?` local to a
            // `cat ref` parameter rides the same invariant-argument
            // hole. Should be DIFFERENT.
            let ref_owner = CLASS(loc(), loc(), null, "ref_owner", ["T"], false, null);
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.SAME,
                ref_of(ref_owner, cat).compare(ref_of(ref_owner, cat.as_optional()))
            );
        si

        compare__optional_ref_slot_against_ref_value__is_SAME() is
            @test()

            // UNSOUND: mirror image — the callee can write null
            // through a `cat? ref` parameter into the caller's
            // non-optional `cat` local. Should be DIFFERENT.
            let ref_owner = CLASS(loc(), loc(), null, "ref_owner", ["T"], false, null);
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.SAME,
                ref_of(ref_owner, cat.as_optional()).compare(ref_of(ref_owner, cat))
            );
        si

        // --- compare at covariant argument positions ---------------
        // These already treat the flag strictly; pinned so the
        // invariant-position fix can be checked against them.

        compare__covariant_optional_arg_slot_against_bare_value__is_ASSIGNABLE() is
            @test()

            // iterable_like[cat?] accepts iterable_like[cat]: a
            // covariant read-only position widens cat to cat?.
            let owner = a_covariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.ASSIGNABLE,
                of(owner, cat.as_optional()).compare(of(owner, cat))
            );
        si

        compare__covariant_bare_arg_slot_against_optional_value__is_DIFFERENT() is
            @test()

            // iterable_like[cat] rejects iterable_like[cat?]: the
            // strict non-nullable rule holds at covariant positions.
            let owner = a_covariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.DIFFERENT,
                of(owner, cat).compare(of(owner, cat.as_optional()))
            );
        si

        // --- compare outer flag on the whole generic ---------------
        // Same-symbol constructions take the fast path, which already
        // handles the outer flag correctly.

        compare__optional_generic_slot_against_bare_generic__is_ASSIGNABLE() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            let bare = of(owner, cat);
            let optional = bare.as_optional();

            Assert.are_equal(Types.MATCH.ASSIGNABLE, optional.compare(bare));
        si

        compare__bare_generic_slot_against_optional_generic__is_DIFFERENT() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            let bare = of(owner, cat);
            let optional = bare.as_optional();

            Assert.are_equal(Types.MATCH.DIFFERENT, bare.compare(optional));
        si
    si
si
