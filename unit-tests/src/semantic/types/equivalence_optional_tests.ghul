namespace Semantic.Types.UnitTests is
    use Collections.LIST;
    use Collections.List;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Types.GENERIC;
    use Semantic.Types.NAMED;
    use Semantic.Types.REFERENCE;
    use Semantic.Types.TypeVariance;
    use Semantic.Types.Type;

    // Truth table for the two type-identity relations and for
    // `compare` at generic-argument positions, focused on the
    // reference-`?` optional flag.
    //
    // `=~` is erased identity: the flag is ignored (`cat? =~ cat`),
    // matching the CLR view where the annotation has no runtime
    // existence. Override matching and reflected-signature
    // comparison depend on that erasure.
    //
    // `is_equivalent_to` is full equivalence: `=~` plus the flag, at
    // every nesting depth. Invariant generic-argument positions
    // compare with it, which is what keeps a `box_like[cat?]` value
    // out of a `box_like[cat]` slot and a `cat?` local out of a
    // `cat ref` parameter — both used to compile and NPE at runtime.
    //
    // (`=~` is spelled `equals` here: the operator's IL name is
    // Equals, and the test project sees the compiler through an
    // assembly reference, which surfaces it under that name.)
    class EQUIVALENCE_OPTIONAL_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        a_reference_class(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, empty_names(), false, null);

        // A generic owner with no variance metadata — its parameters
        // are invariant, like every source-defined ghūl generic.
        an_invariant_owner() -> CLASS =>
            CLASS(loc(), loc(), null, "box_like", ["T"], false, null);

        a_covariant_owner() -> CLASS is
            let owner = CLASS(loc(), loc(), null, "iterable_like", ["T"], false, null);
            owner.argument_variances = [TypeVariance.COVARIANT];
            return owner;
        si

        of(owner: CLASS, argument: Type) -> GENERIC is
            let args = LIST[Type]();
            args.add(argument);
            return GENERIC(loc(), owner, args);
        si

        ref_of(owner: CLASS, argument: Type) -> GENERIC is
            let args = LIST[Type]();
            args.add(argument);
            return REFERENCE(loc(), owner, args);
        si

        // --- =~ : erased identity ----------------------------------

        erased__bare_against_same_bare__is_true() is
            @test()

            let bare = a_reference_class("cat").type;

            Assert.is_true(bare.equals(bare));
        si

        erased__different_symbols__is_false() is
            @test()

            let cat = a_reference_class("cat").type;
            let dog = a_reference_class("dog").type;

            Assert.is_false(cat.equals(dog));
        si

        erased__bare_against_optional__is_true() is
            @test()

            // The flag erases: `cat? =~ cat`. Override matching
            // against nullable-annotated reflected signatures
            // (to_string() -> string? and friends) depends on this.
            let bare = cast NAMED(a_reference_class("cat").type);
            let optional = bare.as_optional();

            Assert.is_true(bare.equals(optional));
            Assert.is_true(optional.equals(bare));
        si

        erased__generic_optional_arg_against_bare_arg__is_true() is
            @test()

            let owner = an_invariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.is_true(of(owner, cat.as_optional()).equals(of(owner, cat)));
        si

        // --- is_equivalent_to : full equivalence -------------------

        equivalent__bare_against_same_bare__is_true() is
            @test()

            let bare = a_reference_class("cat").type;

            Assert.is_true(bare.is_equivalent_to(bare));
        si

        equivalent__optional_against_same_optional__is_true() is
            @test()

            let bare = cast NAMED(a_reference_class("cat").type);
            let optional = bare.as_optional();

            Assert.is_true(optional.is_equivalent_to(optional));
        si

        equivalent__different_symbols__is_false() is
            @test()

            let cat = a_reference_class("cat").type;
            let dog = a_reference_class("dog").type;

            Assert.is_false(cat.is_equivalent_to(dog));
        si

        equivalent__bare_against_optional__is_false() is
            @test()

            let bare = cast NAMED(a_reference_class("cat").type);
            let optional = bare.as_optional();

            Assert.is_false(bare.is_equivalent_to(optional));
            Assert.is_false(optional.is_equivalent_to(bare));
        si

        equivalent__generic_against_same_construction__is_true() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            // Two separate constructions, so the same-symbol fast
            // path misses and the per-argument walk runs.
            Assert.is_true(of(owner, cat).is_equivalent_to(of(owner, cat)));
        si

        equivalent__generic_optional_arg_against_bare_arg__is_false() is
            @test()

            let owner = an_invariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.is_false(of(owner, cat.as_optional()).is_equivalent_to(of(owner, cat)));
        si

        equivalent__outer_optional_generic_against_bare_generic__is_false() is
            @test()

            // `as_optional` clones the type but shares the symbol, so
            // this exercises the outer-flag check ahead of the
            // same-symbol fast path.
            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            let bare = of(owner, cat);
            let optional = cast GENERIC(bare.as_optional());

            Assert.is_false(optional.is_equivalent_to(bare));
        si

        equivalent__nested_optional_arg_at_depth_two__is_false() is
            @test()

            // box_like[box_like[cat?]] vs box_like[box_like[cat]]:
            // the walk recurses through is_equivalent_to, so the flag
            // holds at every depth, not just the first.
            let owner = an_invariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            let nested_optional = of(owner, of(owner, cat.as_optional()));
            let nested_bare = of(owner, of(owner, cat));

            Assert.is_false(nested_optional.is_equivalent_to(nested_bare));
        si

        // --- compare at invariant argument positions ---------------
        // Invariance rejects a flag mismatch in either direction:
        // reading from the slot could surface a null the slot's type
        // denies, and writing through it could store one.

        compare__generic_against_same_construction__is_SAME() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            Assert.are_equal(Types.MATCH.SAME, of(owner, cat).compare(of(owner, cat)));
        si

        compare__generic_slot_against_optional_arg_value__is_DIFFERENT() is
            @test()

            let owner = an_invariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.DIFFERENT,
                of(owner, cat).compare(of(owner, cat.as_optional()))
            );
        si

        compare__generic_optional_arg_slot_against_bare_value__is_DIFFERENT() is
            @test()

            let owner = an_invariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.DIFFERENT,
                of(owner, cat.as_optional()).compare(of(owner, cat))
            );
        si

        compare__ref_slot_against_optional_ref_value__is_DIFFERENT() is
            @test()

            // `x ref` is a REFERENCE generic over the operand's
            // declared type, so a `cat?` local offered to a `cat ref`
            // parameter is exactly the invariant-argument case: the
            // callee would read a possibly-absent value through a
            // reference whose type promises presence.
            let ref_owner = CLASS(loc(), loc(), null, "ref_owner", ["T"], false, null);
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.DIFFERENT,
                ref_of(ref_owner, cat).compare(ref_of(ref_owner, cat.as_optional()))
            );
        si

        compare__optional_ref_slot_against_ref_value__is_DIFFERENT() is
            @test()

            // Mirror image: through a `cat? ref` parameter the callee
            // can write null into the caller's non-optional local.
            let ref_owner = CLASS(loc(), loc(), null, "ref_owner", ["T"], false, null);
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.DIFFERENT,
                ref_of(ref_owner, cat.as_optional()).compare(ref_of(ref_owner, cat))
            );
        si

        // --- compare at covariant argument positions ---------------

        compare__covariant_optional_arg_slot_against_bare_value__is_ASSIGNABLE() is
            @test()

            // iterable_like[cat?] accepts iterable_like[cat]: a
            // covariant read-only position widens cat to cat?.
            let owner = a_covariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.ASSIGNABLE,
                of(owner, cat.as_optional()).compare(of(owner, cat))
            );
        si

        compare__covariant_bare_arg_slot_against_optional_value__is_DIFFERENT() is
            @test()

            // iterable_like[cat] rejects iterable_like[cat?]: the
            // strict non-nullable rule holds at covariant positions.
            let owner = a_covariant_owner();
            let cat = cast NAMED(a_reference_class("cat").type);

            Assert.are_equal(
                Types.MATCH.DIFFERENT,
                of(owner, cat).compare(of(owner, cat.as_optional()))
            );
        si

        // --- compare outer flag on the whole generic ---------------
        // `T?` accepts `T` (widening), `T` rejects `T?` — whether the
        // two sides share a symbol instance (the fast path) or not
        // (the structural walk).

        compare__optional_generic_slot_against_bare_generic__is_ASSIGNABLE() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            let bare = of(owner, cat);
            let optional = bare.as_optional();

            Assert.are_equal(Types.MATCH.ASSIGNABLE, optional.compare(bare));
        si

        compare__bare_generic_slot_against_optional_generic__is_DIFFERENT() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            let bare = of(owner, cat);
            let optional = bare.as_optional();

            Assert.are_equal(Types.MATCH.DIFFERENT, bare.compare(optional));
        si

        compare__outer_optional_slot_against_separate_bare_construction__is_ASSIGNABLE() is
            @test()

            // Separate constructions don't share a symbol instance,
            // so this takes the structural walk rather than the
            // fast path — the outer flag must hold there too.
            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            let optional = of(owner, cat).as_optional();

            Assert.are_equal(Types.MATCH.ASSIGNABLE, optional.compare(of(owner, cat)));
        si

        compare__bare_slot_against_separate_outer_optional_construction__is_DIFFERENT() is
            @test()

            let owner = an_invariant_owner();
            let cat = a_reference_class("cat").type;

            let optional = of(owner, cat).as_optional();

            Assert.are_equal(Types.MATCH.DIFFERENT, of(owner, cat).compare(optional));
        si
    si
si
