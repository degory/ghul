namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;
    use Logging.Logger;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.PURITY;
    use Semantic.SYMBOL_TABLE;
    use Semantic.NAMESPACES;
    use Semantic.STABLE_SYMBOLS;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;

    use Syntax.Process.INFER_PURITY;

    use Syntax.Trees.Expressions.Expression;
    use Syntax.Trees.Expressions.IDENTIFIER;
    use Syntax.Trees.Expressions.MEMBER;
    use Syntax.Trees.Expressions.SELF;
    use Syntax.Trees.Expressions.SIMPLE_LEFT_EXPRESSION;
    use Syntax.Trees.Identifiers.Identifier;
    use Syntax.Trees.Identifiers.QUALIFIED;

    // Tests for INFER_PURITY — the body-shape classification pass
    // that refines block-bodied functions left at the default
    // IMPURE by declare-symbols. The walk accumulates a worst-
    // case signal across assignment LHS shapes and yield; these
    // tests pin the LHS classifier on minimal AST fixtures.
    //
    // The rule under test (per `_classify_left`):
    //   - bare-local LHS                            -> PURE
    //   - bare-identifier resolving to a field of
    //     the current instance context              -> MUT
    //   - bare-identifier with no symbol-table hit  -> PURE
    //     (typically a let in a deeper block we
    //     can't see yet)
    //   - `self.foo`                                -> MUT
    //   - `local.foo`                               -> IMPURE
    //   - qualified-identifier LHS                  -> IMPURE
    class INFER_PURITY_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        // Helper: build an enclosing class and enter its scope
        // on the symbol table — so `current_instance_context`
        // reflects what a function body inside the class would
        // see.
        make_class_in_scope(symbol_table: SYMBOL_TABLE, name: string) -> CLASS is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(NAMED(c));
            symbol_table.enter_scope(c);
            return c;
        si

        add_field(owner: CLASS, name: string) is
            let t = NAMED(CLASS(loc(), loc(), null, "T_{name}", empty_names(), false, null));
            let f = INSTANCE_FIELD(loc(), owner, name);
            f.set_type(t);
            owner.add_member(f);
        si

        make_infer_purity(symbol_table: SYMBOL_TABLE) -> INFER_PURITY is
            let logger: Logger = DIAGNOSTICS_STORE();
            let stable = STABLE_SYMBOLS();
            let namespaces = NAMESPACES(logger, symbol_table);
            return INFER_PURITY(logger, stable, symbol_table, namespaces);
        si

        bare_identifier(name: string) -> IDENTIFIER =>
            IDENTIFIER(loc(), Identifier(loc(), name));

        self_dot(member_name: string) -> MEMBER =>
            MEMBER(loc(), SELF(loc()), Identifier(loc(), member_name), loc());

        bare_dot(local_name: string, member_name: string) -> MEMBER =>
            MEMBER(loc(), bare_identifier(local_name), Identifier(loc(), member_name), loc());

        qualified_identifier(qual_name: string, name: string) -> IDENTIFIER =>
            IDENTIFIER(loc(), QUALIFIED(loc(), Identifier(loc(), qual_name), name, loc(), loc()));

        simple(expr: Expression) -> SIMPLE_LEFT_EXPRESSION =>
            SIMPLE_LEFT_EXPRESSION(loc(), expr);

        Classify_left_bare_local_should_be_pure() is
            @test()

            let logger: Logger = DIAGNOSTICS_STORE();
            let symbol_table = SYMBOL_TABLE(logger);
            let owner = make_class_in_scope(symbol_table, "Owner");

            let infer = make_infer_purity(symbol_table);

            // `x = e` where `x` doesn't resolve in scope: the
            // classifier treats it as a local-shape PURE.
            let lhs = simple(bare_identifier("x"));

            Assert.are_equal(PURITY.PURE, infer._classify_left(lhs));
        si

        Classify_left_field_on_this_should_be_mut() is
            @test()

            let logger: Logger = DIAGNOSTICS_STORE();
            let symbol_table = SYMBOL_TABLE(logger);
            let owner = make_class_in_scope(symbol_table, "Owner");
            add_field(owner, "field_a");

            let infer = make_infer_purity(symbol_table);

            // `field_a = e` where `field_a` resolves through
            // the current instance context to a member: MUT.
            let lhs = simple(bare_identifier("field_a"));

            Assert.are_equal(PURITY.MUT, infer._classify_left(lhs));
        si

        Classify_left_self_dot_member_should_be_mut() is
            @test()

            let logger: Logger = DIAGNOSTICS_STORE();
            let symbol_table = SYMBOL_TABLE(logger);
            let owner = make_class_in_scope(symbol_table, "Owner");

            let infer = make_infer_purity(symbol_table);

            // `self.foo = e` — MEMBER over SELF, MUT.
            let lhs = simple(self_dot("foo"));

            Assert.are_equal(PURITY.MUT, infer._classify_left(lhs));
        si

        Classify_left_arbitrary_member_access_should_be_impure() is
            @test()

            let logger: Logger = DIAGNOSTICS_STORE();
            let symbol_table = SYMBOL_TABLE(logger);
            let owner = make_class_in_scope(symbol_table, "Owner");

            let infer = make_infer_purity(symbol_table);

            // `x.foo = e` — MEMBER over a bare-local
            // identifier. The receiver could alias something
            // the caller sees; IMPURE.
            let lhs = simple(bare_dot("x", "foo"));

            Assert.are_equal(PURITY.IMPURE, infer._classify_left(lhs));
        si

        Classify_left_qualified_identifier_should_be_impure() is
            @test()

            let logger: Logger = DIAGNOSTICS_STORE();
            let symbol_table = SYMBOL_TABLE(logger);
            let owner = make_class_in_scope(symbol_table, "Owner");

            let infer = make_infer_purity(symbol_table);

            // `Static.foo = e` — qualified bare-identifier
            // LHS, IMPURE.
            let lhs = simple(qualified_identifier("Static", "foo"));

            Assert.are_equal(PURITY.IMPURE, infer._classify_left(lhs));
        si
    si
si
