namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.STRUCT;
    use Semantic.Symbols.CLASSY_GENERIC_ARGUMENT;
    use Semantic.Types.Type;
    use Semantic.Types.NULL;
    use Semantic.Types.ERROR;

    use Syntax.Process.ARM_NULL_JOIN;
    use Syntax.Process.ArmNullJoinDecision;

    // Tests for the arm-join decision that visit_if / visit_case make once
    // the non-null arms' LUB is known: whether a value-type LUB widens to
    // its optional carrier, a reference-type LUB widens to the reference
    // optional, or a value-type LUB against only non-genuine null arms is
    // incompatible. The `is_settled`-based genuine/sentinel split is what
    // lets recursive-lambda inference converge, so it is pinned directly.
    class ARM_NULL_JOIN_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        names_t() -> LIST[string] is
            let names = LIST[string]();
            names.add("T");
            return names;
        si

        // Value type: is_value_type true, is_type_variable false.
        val_type() -> Type =>
            STRUCT(loc(), loc(), null, "Val", empty_names(), false, null).type!;

        // Reference type: is_value_type false.
        ref_type() -> Type =>
            CLASS(loc(), loc(), null, "Ref", empty_names(), false, null).type!;

        // Type variable: is_value_type answers true spuriously (as every
        // GenericArgument does) and is_type_variable is true.
        type_var_type() -> Type =>
            CLASSY_GENERIC_ARGUMENT(
                loc(),
                CLASS(loc(), loc(), null, "Owner", names_t(), false, null),
                "T",
                0
            ).type!;

        // ===== is_genuine_null =====

        is_genuine_null__for_the_null_literal_type__is_true() is
            @test()

            // NULL is settled (not inferred, not error), so it is a genuine
            // null arm that can drive widening.
            Assert.is_true(ARM_NULL_JOIN().is_genuine_null(NULL()));
        si

        is_genuine_null__for_an_error_type__is_false() is
            @test()

            // ERROR answers is_null but is not settled — an undefined
            // reference or in-progress inference, never a genuine null.
            Assert.is_false(ARM_NULL_JOIN().is_genuine_null(ERROR()));
        si

        // ===== decide =====

        decide__value_lub_with_genuine_null__widens_to_value_optional() is
            @test()

            Assert.are_equal(
                ArmNullJoinDecision.WIDEN_VALUE_OPTIONAL,
                ARM_NULL_JOIN().decide(val_type(), true, true)
            );
        si

        decide__value_lub_with_only_sentinel_null__is_incompatible() is
            @test()

            // The sentinel-leaves-the-LUB-untouched path: a value-type LUB
            // against an unsettled (non-genuine) null arm does not widen. The
            // caller reports it, keeping the value-type LUB so a speculative
            // inference pass can still converge on a later, settled type.
            Assert.are_equal(
                ArmNullJoinDecision.INCOMPATIBLE,
                ARM_NULL_JOIN().decide(val_type(), false, true)
            );
        si

        decide__reference_lub_with_null__widens_to_reference_optional() is
            @test()

            Assert.are_equal(
                ArmNullJoinDecision.WIDEN_REFERENCE_OPTIONAL,
                ARM_NULL_JOIN().decide(ref_type(), true, true)
            );
        si

        type_variable_fixture__answers_both_value_type_and_type_variable() is
            @test()

            // The premise the !is_type_variable guard rests on: a type
            // variable answers is_value_type true (spuriously) yet is a type
            // variable, so it must not be treated as a plain value type.
            let t = type_var_type();

            Assert.is_true(t.is_value_type);
            Assert.is_true(t.is_type_variable);
        si

        decide__type_variable_lub_with_genuine_null__is_incompatible() is
            @test()

            // Even against a genuine null, a type-variable LUB must not widen:
            // NULLABLE[T] is the wrong carrier for it (an unconstrained T? is
            // MAYBE[T], a class-constrained one a reference optional). The
            // load-bearing !is_type_variable guard routes it to INCOMPATIBLE,
            // matching the pre-existing behaviour for a generic arm.
            Assert.are_equal(
                ArmNullJoinDecision.INCOMPATIBLE,
                ARM_NULL_JOIN().decide(type_var_type(), true, true)
            );
        si

        decide__value_lub_with_no_null_arm__is_plain() is
            @test()

            Assert.are_equal(
                ArmNullJoinDecision.PLAIN,
                ARM_NULL_JOIN().decide(val_type(), false, false)
            );
        si

        decide__no_lub_type__is_plain() is
            @test()

            // No non-null arm produced a type (every arm was null): there is
            // nothing to widen, so the all-arms-null diagnostic path runs.
            Assert.are_equal(
                ArmNullJoinDecision.PLAIN,
                ARM_NULL_JOIN().decide(null, true, true)
            );
        si
    si
si
