namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Types.Type;
    use Semantic.Types.INFERRED_RETURN_TYPE;
    use Semantic.Types.GenericArgument;

    use Syntax.Process.DIVERGING_VALUE_POSITION;

    // Pins the two decisions DIVERGING_VALUE_POSITION factors out of the
    // compile-expressions visitor for a value-requiring position whose
    // statement diverges (`throw`, or an `if`/`case` whose arms all
    // diverge): whether the absent value is worth reporting, and whether a
    // diverging `=>` body adopts void as its return type. The visitor
    // orchestration that supplies the flow / return-type state is covered
    // by the integration tests.
    class DIVERGING_VALUE_POSITION_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        settled_type() -> Type =>
            CLASS(loc(), loc(), null, "Settled", empty_names(), false, null).type;

        // --- is_missing_value_reportable ---------------------------------

        is_missing_value_reportable__when_value_wanted_absent_and_reachable__is_true() is
            @test()

            Assert.is_true(DIVERGING_VALUE_POSITION.is_missing_value_reportable(true, false, false));
        si

        is_missing_value_reportable__when_unreachable__is_false() is
            @test()

            // The diverging-statement case: the continuation never runs, so
            // the missing value is legitimate and nothing is reported.
            Assert.is_false(DIVERGING_VALUE_POSITION.is_missing_value_reportable(true, false, true));
        si

        is_missing_value_reportable__when_a_value_is_present__is_false() is
            @test()

            Assert.is_false(DIVERGING_VALUE_POSITION.is_missing_value_reportable(true, true, false));
        si

        is_missing_value_reportable__when_no_value_wanted__is_false() is
            @test()

            Assert.is_false(DIVERGING_VALUE_POSITION.is_missing_value_reportable(false, false, false));
        si

        // --- settles_inferred_return_to_void -----------------------------

        settles_inferred_return_to_void__for_absent_return_type__is_true() is
            @test()

            Assert.is_true(DIVERGING_VALUE_POSITION.settles_inferred_return_to_void(null));
        si

        settles_inferred_return_to_void__for_inferred_return_type__is_true() is
            @test()

            Assert.is_true(DIVERGING_VALUE_POSITION.settles_inferred_return_to_void(INFERRED_RETURN_TYPE()));
        si

        settles_inferred_return_to_void__for_wildcard_return_type__is_true() is
            @test()

            let wild: Type = GenericArgument(CLASS(loc(), loc(), null, "T", empty_names(), false, null));

            Assert.is_true(DIVERGING_VALUE_POSITION.settles_inferred_return_to_void(wild));
        si

        settles_inferred_return_to_void__for_settled_return_type__is_false() is
            @test()

            // A declared return type — `not_done() -> int => throw ...` —
            // is kept, so the stub satisfies the declared signature rather
            // than collapsing to void.
            Assert.is_false(DIVERGING_VALUE_POSITION.settles_inferred_return_to_void(settled_type()));
        si
    si
si
