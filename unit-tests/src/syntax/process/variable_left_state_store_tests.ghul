namespace Syntax.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Syntax.Process.STATE_STORE_REGISTRY;
    use Syntax.Process.VARIABLE_LEFT_STATE_STORE;

    use Trees.Identifiers.Identifier;
    use Trees.Variables.SIMPLE_VARIABLE_LEFT;

    // Pins the node-keyed state store contract: entries are created on
    // demand, keyed by node identity, forgettable per node and per file,
    // and evicted through the registry.
    class VARIABLE_LEFT_STATE_STORE_TESTS is
        @test()

        init() is si

        left_in(file_name: string) -> SIMPLE_VARIABLE_LEFT is
            let location = LOCATION(file_name, 1, 1, 1, 5);

            return SIMPLE_VARIABLE_LEFT(location, Identifier(location, "x"));
        si

        get_before_any_add_returns_null() is
            @test()

            let store = VARIABLE_LEFT_STATE_STORE(STATE_STORE_REGISTRY());

            Assert.is_null(store.get(left_in("a.ghul")));
        si

        get_or_add_creates_then_returns_same_instance() is
            @test()

            let store = VARIABLE_LEFT_STATE_STORE(STATE_STORE_REGISTRY());
            let left = left_in("a.ghul");

            let state = store.get_or_add(left);

            Assert.are_same(state, store.get_or_add(left));
            Assert.are_same(state, store.get(left));
        si

        entries_are_keyed_by_node_not_location() is
            @test()

            let store = VARIABLE_LEFT_STATE_STORE(STATE_STORE_REGISTRY());
            let first = left_in("a.ghul");
            let second = left_in("a.ghul");

            store.get_or_add(first);

            Assert.is_null(store.get(second));
        si

        remove_forgets_one_node() is
            @test()

            let store = VARIABLE_LEFT_STATE_STORE(STATE_STORE_REGISTRY());
            let kept = left_in("a.ghul");
            let removed = left_in("a.ghul");

            store.get_or_add(kept);
            store.get_or_add(removed);

            store.remove(removed);

            Assert.is_null(store.get(removed));
            Assert.is_true(store.get(kept)?);
            Assert.are_equal(1, store.entry_count);
        si

        drop_file_forgets_that_file_only() is
            @test()

            let store = VARIABLE_LEFT_STATE_STORE(STATE_STORE_REGISTRY());
            let dropped = left_in("a.ghul");
            let kept = left_in("b.ghul");

            store.get_or_add(dropped);
            store.get_or_add(kept);

            store.drop_file("a.ghul");

            Assert.is_null(store.get(dropped));
            Assert.is_true(store.get(kept)?);
            Assert.are_equal(1, store.entry_count);
        si

        clear_all_forgets_everything() is
            @test()

            let store = VARIABLE_LEFT_STATE_STORE(STATE_STORE_REGISTRY());

            store.get_or_add(left_in("a.ghul"));
            store.get_or_add(left_in("b.ghul"));

            store.clear_all();

            Assert.are_equal(0, store.entry_count);
        si

        registry_drop_file_reaches_registered_stores() is
            @test()

            let registry = STATE_STORE_REGISTRY();
            let store = VARIABLE_LEFT_STATE_STORE(registry);

            store.get_or_add(left_in("a.ghul"));

            registry.drop_file("a.ghul");

            Assert.are_equal(0, store.entry_count);
        si

        registry_clear_all_reaches_registered_stores() is
            @test()

            let registry = STATE_STORE_REGISTRY();
            let store = VARIABLE_LEFT_STATE_STORE(registry);

            store.get_or_add(left_in("a.ghul"));
            store.get_or_add(left_in("b.ghul"));

            registry.clear_all();

            Assert.are_equal(0, store.entry_count);
        si
    si
si
