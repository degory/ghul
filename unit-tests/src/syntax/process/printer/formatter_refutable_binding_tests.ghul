namespace Syntax.Process.Printer.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Syntax.Process.Printer.FORMATTER;

    // FORMATTER renders the REFUTABLE_BINDING that drives an `if let` arm
    // as `pattern[: T] = scrutinee[ /\ guard]`. Without an explicit visit
    // method the StrictVisitor base throws and FORMAT_HANDLER swallows
    // the exception — echoing the input back unchanged, which a canonical
    // round-trip cannot distinguish from a working format. Hitting the
    // FORMATTER directly here surfaces a regression as a thrown exception
    // or a mismatched string.
    class FORMATTER_REFUTABLE_BINDING_TESTS is
        @test()

        init() is si

        format(node: Trees.Node) -> string =>
            FORMATTER(Collections.LIST[Lexical.TRIVIA](), 100).format(node);

        identifier(name: string) -> Trees.Expressions.Expression =>
            Trees.Expressions.IDENTIFIER(
                Source.LOCATION("test.ghul", 1, 1, 1, 1),
                Trees.Identifiers.Identifier(Source.LOCATION("test.ghul", 1, 1, 1, 1), name)
            );

        simple_pattern(name: string) -> Trees.Variables.VariableLeft =>
            Trees.Variables.SIMPLE_VARIABLE_LEFT(
                Source.LOCATION("test.ghul", 1, 1, 1, 1),
                Trees.Identifiers.Identifier(Source.LOCATION("test.ghul", 1, 1, 1, 1), name)
            );

        named_type(name: string) -> Trees.TypeExpressions.TypeExpression =>
            Trees.TypeExpressions.NAMED(
                Source.LOCATION("test.ghul", 1, 1, 1, 1),
                Trees.Identifiers.Identifier(Source.LOCATION("test.ghul", 1, 1, 1, 1), name)
            );

        and_guard(
            left: Trees.Expressions.Expression,
            right: Trees.Expressions.Expression
        ) -> Trees.Expressions.Expression =>
            Trees.Expressions.BINARY(
                Source.LOCATION("test.ghul", 1, 1, 1, 1),
                Trees.Identifiers.Identifier(Source.LOCATION("test.ghul", 1, 1, 1, 1), "/\\"),
                "/\\",
                left,
                right
            );

        binding(
            pattern: Trees.Variables.VariableLeft,
            narrow_type_expression: Trees.TypeExpressions.TypeExpression?,
            scrutinee: Trees.Expressions.Expression,
            guard: Trees.Expressions.Expression?
        ) -> Trees.Statements.REFUTABLE_BINDING is
            let clauses = Collections.LIST[Trees.Statements.REFUTABLE_BINDING_CLAUSE]();

            clauses.add(
                Trees.Statements.REFUTABLE_BINDING_CLAUSE(
                    Source.LOCATION("test.ghul", 1, 1, 1, 1),
                    scrutinee,
                    narrow_type_expression,
                    pattern,
                    guard
                )
            );

            return Trees.Statements.REFUTABLE_BINDING(
                Source.LOCATION("test.ghul", 1, 1, 1, 1),
                clauses
            );
        si

        a_bare_pattern_renders_as_pattern_eq_scrutinee() is
            @test()

            Assert.are_equal(
                "x = e\n",
                format(binding(simple_pattern("x"), null, identifier("e"), null))
            );
        si

        a_narrow_type_renders_between_pattern_and_scrutinee() is
            @test()

            Assert.are_equal(
                "x: T = e\n",
                format(binding(simple_pattern("x"), named_type("T"), identifier("e"), null))
            );
        si

        a_guard_renders_after_scrutinee_with_an_and_separator() is
            @test()

            Assert.are_equal(
                "x = e /\\ g\n",
                format(binding(simple_pattern("x"), null, identifier("e"), identifier("g")))
            );
        si

        a_chained_guard_renders_as_a_left_associative_and_chain() is
            @test()

            Assert.are_equal(
                "x = e /\\ g1 /\\ g2\n",
                format(
                    binding(
                        simple_pattern("x"),
                        null,
                        identifier("e"),
                        and_guard(identifier("g1"), identifier("g2"))
                    )
                )
            );
        si

        a_narrow_type_and_guard_compose() is
            @test()

            Assert.are_equal(
                "x: T = e /\\ g\n",
                format(
                    binding(simple_pattern("x"), named_type("T"), identifier("e"), identifier("g"))
                )
            );
        si

        // Multi-clause renderings: clauses join with a comma. Each
        // clause renders the same way the single-clause case does;
        // the per-clause guard is local to its clause.
        clause(
            pattern: Trees.Variables.VariableLeft,
            narrow_type_expression: Trees.TypeExpressions.TypeExpression?,
            scrutinee: Trees.Expressions.Expression,
            guard: Trees.Expressions.Expression?
        ) -> Trees.Statements.REFUTABLE_BINDING_CLAUSE =>
            Trees.Statements.REFUTABLE_BINDING_CLAUSE(
                Source.LOCATION("test.ghul", 1, 1, 1, 1),
                scrutinee,
                narrow_type_expression,
                pattern,
                guard
            );

        multi_binding(clauses: Collections.Iterable[Trees.Statements.REFUTABLE_BINDING_CLAUSE]) -> Trees.Statements.REFUTABLE_BINDING =>
            Trees.Statements.REFUTABLE_BINDING(
                Source.LOCATION("test.ghul", 1, 1, 1, 1),
                clauses
            );

        two_clauses_render_with_a_comma_separator() is
            @test()

            let cs = Collections.LIST[Trees.Statements.REFUTABLE_BINDING_CLAUSE]();
            cs.add(clause(simple_pattern("x"), null, identifier("e"), null));
            cs.add(clause(simple_pattern("y"), null, identifier("f"), null));

            Assert.are_equal(
                "x = e, y = f\n",
                format(multi_binding(cs))
            );
        si

        per_clause_guards_render_inside_each_clause() is
            @test()

            let cs = Collections.LIST[Trees.Statements.REFUTABLE_BINDING_CLAUSE]();
            cs.add(clause(simple_pattern("x"), null, identifier("e"), identifier("g1")));
            cs.add(clause(simple_pattern("y"), null, identifier("f"), identifier("g2")));

            Assert.are_equal(
                "x = e /\\ g1, y = f /\\ g2\n",
                format(multi_binding(cs))
            );
        si

        per_clause_narrow_types_render_per_clause() is
            @test()

            let cs = Collections.LIST[Trees.Statements.REFUTABLE_BINDING_CLAUSE]();
            cs.add(clause(simple_pattern("x"), named_type("T"), identifier("e"), null));
            cs.add(clause(simple_pattern("y"), named_type("U"), identifier("f"), null));

            Assert.are_equal(
                "x: T = e, y: U = f\n",
                format(multi_binding(cs))
            );
        si
    si
si
