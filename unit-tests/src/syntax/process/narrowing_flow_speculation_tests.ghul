namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.LOCAL_VARIABLE;
    use Semantic.Types.Type;

    // Tests for NARROWING_FLOW's speculation stack — the primitive that
    // lets a speculative expression re-walk push a baseline, reset to it
    // between retry attempts, and either commit (keep the walked facts)
    // or roll back (discard them). `narrow_to_assigned_value` is used as
    // an observable env mutation: it narrows a local to a strict subtype,
    // mutating `Symbol.type` in place, so a restored baseline shows up as
    // the type reverting to the declared one.
    class NARROWING_FLOW_SPECULATION_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        logger() -> Logging.Logger => Logging.DIAGNOSTICS_STORE();
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_local(owner: CLASS, name: string) -> LOCAL_VARIABLE =>
            LOCAL_VARIABLE(loc(), owner, name);

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            return c.type!;
        si

        make_subclass_type(name: string, base: Type) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            c.add_ancestor(base);
            return c.type!;
        si

        roll_back_restores_the_pre_speculation_type() is
            @test()

            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let x = make_local(owner, "x");
            x.set_type(animal);

            let flow = NARROWING_FLOW(logger());

            flow.speculate();
            flow.narrow_to_assigned_value(x, cat);
            Assert.are_same(cat, x.type);

            flow.roll_back();

            Assert.are_same(animal, x.type);
            Assert.is_false(flow.current_env.narrowed_type_of(x)?);
        si

        commit_keeps_the_speculative_type() is
            @test()

            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let x = make_local(owner, "x");
            x.set_type(animal);

            let flow = NARROWING_FLOW(logger());

            flow.speculate();
            flow.narrow_to_assigned_value(x, cat);

            flow.commit();

            Assert.are_same(cat, x.type);
            Assert.are_same(cat, flow.current_env.narrowed_type_of(x));
        si

        restore_resets_to_the_baseline_but_keeps_the_frame() is
            @test()

            // The retry-re-walk shape: reset to the baseline, walk again,
            // then commit the second walk's facts.
            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let x = make_local(owner, "x");
            x.set_type(animal);

            let flow = NARROWING_FLOW(logger());

            flow.speculate();
            flow.narrow_to_assigned_value(x, cat);

            flow.restore();

            Assert.are_same(animal, x.type);

            flow.narrow_to_assigned_value(x, cat);

            flow.commit();

            Assert.are_same(cat, x.type);
        si

        nested_roll_back_leaves_the_outer_speculation_intact() is
            @test()

            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let x = make_local(owner, "x");
            let y = make_local(owner, "y");
            x.set_type(animal);
            y.set_type(animal);

            let flow = NARROWING_FLOW(logger());

            flow.speculate();
            flow.narrow_to_assigned_value(x, cat);

            flow.speculate();
            flow.narrow_to_assigned_value(y, cat);

            flow.roll_back();

            Assert.are_same(animal, y.type);
            Assert.are_same(cat, x.type);

            flow.commit();

            Assert.are_same(cat, x.type);
        si

        restore_is_a_no_op_when_no_speculation_is_active() is
            @test()

            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let x = make_local(owner, "x");
            x.set_type(animal);

            let flow = NARROWING_FLOW(logger());

            flow.narrow_to_assigned_value(x, cat);

            flow.restore();

            Assert.are_same(cat, x.type);
        si

        disposable_commits_on_scope_exit() is
            @test()

            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let x = make_local(owner, "x");
            x.set_type(animal);

            let flow = NARROWING_FLOW(logger());

            if true then
                let use speculation = flow.speculate_then_commit();
                flow.narrow_to_assigned_value(x, cat);
            fi

            Assert.are_same(cat, x.type);
        si

        disposable_rolls_back_on_scope_exit() is
            @test()

            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let x = make_local(owner, "x");
            x.set_type(animal);

            let flow = NARROWING_FLOW(logger());

            if true then
                let use speculation = flow.speculate_then_roll_back();
                flow.narrow_to_assigned_value(x, cat);
            fi

            Assert.are_same(animal, x.type);
        si
    si
si
