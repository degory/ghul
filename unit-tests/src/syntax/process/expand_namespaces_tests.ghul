namespace Syntax.Process.UnitTests is
    use Syntax.Process.EXPAND_NAMESPACES;

    // Direct tests for EXPAND_NAMESPACES.convert_file_name_to_identifier
    // — the helper that derives a namespace identifier fragment from a
    // file or directory name. It is called recursively when synthesising
    // a root namespace for a file that declares none, walking up parent
    // directories until a project marker is found.
    //
    // The dropped-input regression: a filesystem root name like "/" (or
    // any input whose characters are all stripped by the letter/digit/
    // underscore filter) reduces to the empty string. Pre-fix, the
    // method then indexed get_chars(0) on the empty string and threw
    // IndexOutOfRangeException; the exception escaped through the
    // rewrite-syntax-trees pass, leaving the AST half-rewritten so every
    // downstream pass (declare-symbols, resolve-*, compile-expressions)
    // cascaded into NullReferenceExceptions on the same file. The
    // user-visible symptom was HOVER, completion and definition all
    // returning nothing for that file.
    class EXPAND_NAMESPACES_TESTS is
        @test()

        init() is si

        // Construct the visitor with a real .NET FileSystem — the
        // tested method does not touch the filesystem, so any
        // IFileSystem implementation is fine here.
        make_subject() -> EXPAND_NAMESPACES =>
            EXPAND_NAMESPACES(System.IO.Abstractions.FileSystem());

        given_a_plain_letter_name__should_return_unchanged() is
            @test()

            let subject = make_subject();

            assert subject.convert_file_name_to_identifier("functional") =~ "functional";
        si

        given_a_name_with_a_dash__should_replace_with_underscore() is
            @test()

            let subject = make_subject();

            assert subject.convert_file_name_to_identifier("my-project") =~ "my_project";
        si

        given_a_name_with_a_dot__should_replace_with_underscore() is
            @test()

            let subject = make_subject();

            assert subject.convert_file_name_to_identifier("my.module") =~ "my_module";
        si

        given_a_name_starting_with_a_digit__should_prefix_a_backtick() is
            @test()

            let subject = make_subject();

            assert subject.convert_file_name_to_identifier("2024") =~ "`2024";
        si

        given_an_empty_name__should_return_empty() is
            @test()

            let subject = make_subject();

            assert subject.convert_file_name_to_identifier("") =~ "";
        si

        // Regression: the filesystem root "/" filters to the empty
        // string. Pre-fix, the method then read past the end of the
        // string and threw, taking the whole rewrite-syntax-trees pass
        // down with it on every file whose project root walk-up
        // reached "/". Cf. the file-level comment.
        given_a_filesystem_root_name__should_return_empty_instead_of_throwing() is
            @test()

            let subject = make_subject();

            assert subject.convert_file_name_to_identifier("/") =~ "";
        si

        // Any all-symbol name lands in the same path: the filter drops
        // every character, leaving an empty string. Holding the line
        // here keeps a future "smarter" version of the helper from
        // re-introducing the throw without us noticing.
        given_a_name_of_only_punctuation__should_return_empty_instead_of_throwing() is
            @test()

            let subject = make_subject();

            assert subject.convert_file_name_to_identifier("***") =~ "";
        si
    si
si
