namespace Semantic.DotNet.UnitTests is
    use Collections;
    use System.IO.Abstractions;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;
    use NSubstitute;
    use NSubstitute.SubstituteExtensions.returns;

    use Logging;
    use Syntax.Process;

    class EXPAND_NAMESPACES_TESTS is
        @test()

        init() is si

        get_mock_filesystem() -> IFileSystem is
            let arguments = System.Array.empty`[object]();

            return NSubstitute.Substitute.`for`[IFileSystem](arguments);
        si

        Calling__convert_file_name_to_identifier__with_name_containing_dashes__should_convert_dashes_to_underscores() is
            @test()

            let name = "some-file-name";

            let object_under_test = EXPAND_NAMESPACES(get_mock_filesystem());

            let result = object_under_test.convert_file_name_to_identifier(name);

            Assert.are_equal("some_file_name", result);
        si

        Calling__convert_file_name_to_identifier__with_name_containing_periods__should_convert_periods_to_underscores() is
            @test()

            let name = "some.file.name";

            let object_under_test = EXPAND_NAMESPACES(get_mock_filesystem());

            let result = object_under_test.convert_file_name_to_identifier(name);

            Assert.are_equal("some_file_name", result);
        si
        
        Calling__convert_file_name_to_identifier__with_name_containing_special_chars__should_omit_them() is
            @test()

            let name = "some-file-name!@#$%^&*()+{{}}|:\"<>?[];',/`~";

            let object_under_test = EXPAND_NAMESPACES(get_mock_filesystem());

            let result = object_under_test.convert_file_name_to_identifier(name);

            Assert.are_equal("some_file_name", result);
        si

        Calling__convert_file_name_to_identifier__with_name_containing_underscores__should_pass_them_through() is
            @test()

            let name = "some_file_name";

            let object_under_test = EXPAND_NAMESPACES(get_mock_filesystem());

            let result = object_under_test.convert_file_name_to_identifier(name);

            Assert.are_equal("some_file_name", result);
        si

        Calling__convert_file_name_to_identifier__with_empty_name__should_return_empty_name() is
            @test()

            let name = "";

            let object_under_test = EXPAND_NAMESPACES(get_mock_filesystem());

            let result = object_under_test.convert_file_name_to_identifier(name);

            Assert.are_equal("", result);
        si

        Calling__convert_file_name_to_identifier__with_name_containing_digits__should_pass_them_through() is
            @test()

            let name = "some_file_name_123";

            let object_under_test = EXPAND_NAMESPACES(get_mock_filesystem());

            let result = object_under_test.convert_file_name_to_identifier(name);

            Assert.are_equal("some_file_name_123", result);
        si

        Calling__convert_file_name_to_identifier__with_name_starting_with_digit__should_prefix_with_backtick() is
            @test()

            let name = "123_some_file_name";

            let object_under_test = EXPAND_NAMESPACES(get_mock_filesystem());

            let result = object_under_test.convert_file_name_to_identifier(name);

            Assert.are_equal("`123_some_file_name", result);
        si

        Calling_get_namespace_name__with_absolute_uri_and_no_config__should_return_expected_namespace_name() is
            @test()

            let path = "/some/path/to/some-file-name.ghul";
            let uri = "file://{path}";

            let arguments = System.Array.empty`[object]();

            let mock_file_system = NSubstitute.Substitute.`for`[IFileSystem](arguments);
            let mock_path = NSubstitute.Substitute.`for`[IPath](arguments);
            let mock_directory = NSubstitute.Substitute.`for`[IDirectory](arguments);
            let mock_directory_info_factory = NSubstitute.Substitute.`for`[IDirectoryInfoFactory](arguments);

            let mock_directory_info__some_path_to = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__some_path = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__some = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__root = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);

            mock_directory_info_factory.from_directory_name("/some/path/to") |> returns(mock_directory_info__some_path_to, null);
            mock_directory_info_factory.from_directory_name("/some/path") |> returns(mock_directory_info__some_path, null);
            mock_directory_info_factory.from_directory_name("/some") |> returns(mock_directory_info__some, null);
            mock_directory_info_factory.from_directory_name("/") |> returns(mock_directory_info__root, null);

            mock_directory_info__some_path_to.full_name |> returns("/some/path/to", null);
            mock_directory_info__some_path_to.name |> returns("to", null);
            mock_directory_info__some_path_to.parent |> returns(mock_directory_info__some_path, null);

            mock_directory_info__some_path.full_name |> returns("/some/path", null);
            mock_directory_info__some_path.name |> returns("path", null);
            mock_directory_info__some_path.parent |> returns(mock_directory_info__some, null);

            mock_directory_info__some.full_name |> returns("/some", null);
            mock_directory_info__some.name |> returns("some", null);
            mock_directory_info__some.parent |> returns(mock_directory_info__root, null);

            mock_directory_info__root.full_name |> returns("/", null);
            mock_directory_info__root.name |> returns("", null);
            mock_directory_info__root.parent |> returns(cast IDirectoryInfo(null), null);

            mock_file_system.path |> returns(mock_path, null);
            mock_file_system.directory |> returns(mock_directory, null);
            mock_file_system.directory_info |> returns(mock_directory_info_factory, null);

            mock_path.get_file_name_without_extension(path) |> returns("some-file-name", null);
            mock_path.get_directory_name(path) |> returns("/some/path/to", null);

            mock_path.combine("/some/path/to", "ghul.json") |> returns("/some/path/to/ghul.json", null);
            mock_path.combine("/some/path", "ghul.json") |> returns("/some/path/ghul.json", null);
            mock_path.combine("/some", "ghul.json") |> returns("/some/ghul.json", null);
            mock_path.combine("/", "ghul.json") |> returns("/ghul.json", null);
            mock_path.combine("", "ghul.json") |> returns("ghul.json", null); // why is this being called?

            mock_path.get_path_root("/some/path/to") |> returns("/", null);
            mock_path.get_path_root("/some/path") |> returns("/", null);
            mock_path.get_path_root("/some") |> returns("/", null);
            mock_path.get_path_root("/") |> returns("/", null);
            
            mock_directory.get_current_directory() |> returns("/some/path/to", null);

            let object_under_test = EXPAND_NAMESPACES(mock_file_system);

            let result = object_under_test.get_namespace_name(uri);

            Assert.are_equal("__some__path__to__some_file_name", result);
        si

        Calling_get_namespace_name__with_windows_uri_and_no_config__should_return_expected_namespace_name() is
            @test()

            let path = "C:\\some\\path\\to\\some-file-name.ghul";
            let uri = System.Uri(path).absolute_uri;

            let arguments = System.Array.empty`[object]();

            let mock_file_system = NSubstitute.Substitute.`for`[IFileSystem](arguments);
            let mock_path = NSubstitute.Substitute.`for`[IPath](arguments);
            let mock_directory = NSubstitute.Substitute.`for`[IDirectory](arguments);
            let mock_directory_info_factory = NSubstitute.Substitute.`for`[IDirectoryInfoFactory](arguments);

            let mock_directory_info__some_path_to = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__some_path = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__some = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__root = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);

            mock_directory_info_factory.from_directory_name("c:\\some\\path\\to") |> returns(mock_directory_info__some_path_to, null);
            mock_directory_info_factory.from_directory_name("c:\\some\\path") |> returns(mock_directory_info__some_path, null);
            mock_directory_info_factory.from_directory_name("c:\\some") |> returns(mock_directory_info__some, null);
            mock_directory_info_factory.from_directory_name("c:\\") |> returns(mock_directory_info__root, null);

            mock_directory_info__some_path_to.full_name |> returns("c:\\some\\path\\to", null);
            mock_directory_info__some_path_to.name |> returns("to", null);
            mock_directory_info__some_path_to.parent |> returns(mock_directory_info__some_path, null);

            mock_directory_info__some_path.full_name |> returns("c:\\some\\path", null);
            mock_directory_info__some_path.name |> returns("path", null);
            mock_directory_info__some_path.parent |> returns(mock_directory_info__some, null);

            mock_directory_info__some.full_name |> returns("c:\\some", null);
            mock_directory_info__some.name |> returns("some", null);
            mock_directory_info__some.parent |> returns(mock_directory_info__root, null);

            mock_directory_info__root.full_name |> returns("c:\\", null);
            mock_directory_info__root.name |> returns("", null);
            mock_directory_info__root.parent |> returns(cast IDirectoryInfo(null), null);

            mock_file_system.path |> returns(mock_path, null);
            mock_file_system.directory |> returns(mock_directory, null);
            mock_file_system.directory_info |> returns(mock_directory_info_factory, null);

            mock_path.get_file_name_without_extension(path) |> returns("some-file-name", null);
            mock_path.get_directory_name(path) |> returns("c:\\some\\path\\to", null);

            mock_path.combine("c:\\some\\path\\to", "ghul.json") |> returns("c:\\some\\path\\to\\ghul.json", null);
            mock_path.combine("c:\\some\\path", "ghul.json") |> returns("c:\\some\\path\\ghul.json", null);
            mock_path.combine("c:\\some", "ghul.json") |> returns("c:\\some\\ghul.json", null);
            mock_path.combine("c:\\", "ghul.json") |> returns("c:\\ghul.json", null);
            mock_path.combine("", "ghul.json") |> returns("ghul.json", null); // why is this being called?

            mock_path.get_path_root("c:\\some\\path\\to") |> returns("c:\\", null);
            mock_path.get_path_root("c:\\some\\path") |> returns("c:\\", null);
            mock_path.get_path_root("c:\\some") |> returns("c:\\", null);
            mock_path.get_path_root("c:\\") |> returns("c:\\", null);
            
            mock_directory.get_current_directory() |> returns("/some/path/to", null);

            let object_under_test = EXPAND_NAMESPACES(mock_file_system);

            let result = object_under_test.get_namespace_name(uri);

            Assert.are_equal("__some__path__to__some_file_name", result);
        si


