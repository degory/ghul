            mock_directory.get_current_directory() |> returns("/some/path/to", null);

            mock_file.exists("/some/path/ghul.json") |> returns(true, null);

            let object_under_test = EXPAND_NAMESPACES(mock_file_system);

            let result = object_under_test.get_namespace_name(path);

            Assert.are_equal("path__to__some_file_name", result);
        si

        Calling_get_namespace_name__with_ghulproj_below_root__should_return_expected_namespace_name() is
            @test()

            let path = "/some/path/to/some-file-name.ghul";

            let arguments = System.Array.empty`[object]();

            let mock_file_system = NSubstitute.Substitute.`for`[IFileSystem](arguments);
            let mock_file = NSubstitute.Substitute.`for`[IFile](arguments);
            let mock_path = NSubstitute.Substitute.`for`[IPath](arguments);
            let mock_directory = NSubstitute.Substitute.`for`[IDirectory](arguments);
            let mock_directory_info_factory = NSubstitute.Substitute.`for`[IDirectoryInfoFactory](arguments);

            let mock_directory_info__some_path_to = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__some_path = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__some = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);
            let mock_directory_info__root = NSubstitute.Substitute.`for`[IDirectoryInfo](arguments);

            mock_directory_info_factory.from_directory_name("/some/path/to") |> returns(mock_directory_info__some_path_to, null);
            mock_directory_info_factory.from_directory_name("/some/path") |> returns(mock_directory_info__some_path, null);
            mock_directory_info_factory.from_directory_name("/some") |> returns(mock_directory_info__some, null);
            mock_directory_info_factory.from_directory_name("/") |> returns(mock_directory_info__root, null);

            mock_directory_info__some_path_to.full_name |> returns("/some/path/to", null);
            mock_directory_info__some_path_to.name |> returns("to", null);
            mock_directory_info__some_path_to.parent |> returns(mock_directory_info__some_path, null);

            mock_directory_info__some_path.full_name |> returns("/some/path", null);
            mock_directory_info__some_path.name |> returns("path", null);
            mock_directory_info__some_path.parent |> returns(mock_directory_info__some, null);

            mock_directory_info__some.full_name |> returns("/some", null);
            mock_directory_info__some.name |> returns("some", null);
            mock_directory_info__some.parent |> returns(mock_directory_info__root, null);

            mock_directory_info__root.full_name |> returns("/", null);
            mock_directory_info__root.name |> returns("", null);
            mock_directory_info__root.parent |> returns(cast IDirectoryInfo(null), null);

            mock_file_system.path |> returns(mock_path, null);
            mock_file_system.file |> returns(mock_file, null);
            mock_file_system.directory |> returns(mock_directory, null);
            mock_file_system.directory_info |> returns(mock_directory_info_factory, null);

            mock_path.get_file_name_without_extension(path) |> returns("some-file-name", null);
            mock_path.get_directory_name(path) |> returns("/some/path/to", null);

            mock_directory.get_current_directory() |> returns("/some/path/to", null);

            mock_directory.get_files("/some/path", "*.ghulproj") |> returns(["test.ghulproj"], null);

            mock_path.combine("/some/path/to", "ghul.json") |> returns("/some/path/to/ghul.json", null);
            mock_path.combine("/some/path", "ghul.json") |> returns("/some/path/ghul.json", null);
            mock_path.combine("/some", "ghul.json") |> returns("/some/ghul.json", null);
            mock_path.combine("/", "ghul.json") |> returns("/ghul.json", null);
            mock_path.combine("", "ghul.json") |> returns("ghul.json", null); // why is this being called?

            mock_path.get_path_root("/some/path/to") |> returns("/", null);
            mock_path.get_path_root("/some/path") |> returns("/", null);
            mock_path.get_path_root("/some") |> returns("/", null);
            mock_path.get_path_root("/") |> returns("/", null);

            mock_file.exists("/some/path/ghul.json") |> returns(true, null);

            let object_under_test = EXPAND_NAMESPACES(mock_file_system);

            let result = object_under_test.get_namespace_name(path);

            Assert.are_equal("path__to__some_file_name", result);
        si
    si
