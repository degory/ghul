namespace Syntax.Process.UnitTests is
    use Collections.Iterable;
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Lookups.InnateSymbolLookup;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.STRUCT;

    use Semantic.Types.Type;
    use Semantic.Types.GENERIC;

    use Syntax.Process.PIPE_FUSION_RECOGNIZER;

    // Pins PIPE_FUSION_RECOGNIZER.classify_source_type - the guard / no-guard
    // decision the whole soundness argument rests on. The end-to-end fusion
    // is covered by the execution tests under
    // integration-tests/execution/pipe-fusion-*; this fixture pins the base
    // classification against stand-in types so the three outcomes (do not
    // fuse / fuse unconditionally / fuse behind the runtime guard) can't
    // silently drift.
    class PIPE_FUSION_RECOGNIZER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        names_for(values: Iterable[string]) -> LIST[string] is
            let result = LIST[string]();
            for v in values do result.add(v); od
            return result;
        si

        types(values: Iterable[Type]) -> LIST[Type] is
            let result = LIST[Type]();
            for v in values do result.add(v); od
            return result;
        si

        // classify_source_type takes the pipe type as a parameter and never
        // consults the lookup, but the recognizer ctor requires one.
        build_lookup() -> InnateSymbolLookup =>
            NSubstitute.Substitute.`for`[InnateSymbolLookup](System.Array.empty`[object]());

        recognizer() -> PIPE_FUSION_RECOGNIZER => PIPE_FUSION_RECOGNIZER(build_lookup());

        pipe_class() -> CLASS => CLASS(loc(), loc(), null, "Pipe", names_for(["T"]), false, null);
        int_class() -> CLASS => CLASS(loc(), loc(), null, "int", empty_names(), false, null);
        collection_class() -> CLASS => CLASS(loc(), loc(), null, "MyList", empty_names(), false, null);
        value_struct() -> STRUCT => STRUCT(loc(), loc(), null, "Point", empty_names(), false, null);

        // A statically-Pipe source: pipe() would short-circuit to it, so the
        // chain must not be fused at all.
        Calling__classify_source_type__with_pipe_source__does_not_fuse() is
            @test()

            let pipe = pipe_class();
            let pipe_type = pipe.type!;
            let source = GENERIC(loc(), pipe, types([int_class().type!]));

            Assert.is_null(recognizer().classify_source_type(source, pipe_type));
        si

        // A value-type source is sealed and cannot dynamically be a Pipe, so
        // it fuses unconditionally (no guard).
        Calling__classify_source_type__with_value_type_source__fuses_unguarded() is
            @test()

            let result = recognizer().classify_source_type(value_struct().type!, pipe_class().type!);

            Assert.is_true(result?);
            Assert.is_false(result!);
        si

        // A plain collection source is only statically not a Pipe, so it
        // fuses behind the runtime guard.
        Calling__classify_source_type__with_collection_source__fuses_guarded() is
            @test()

            let result = recognizer().classify_source_type(collection_class().type!, pipe_class().type!);

            Assert.is_true(result?);
            Assert.is_true(result!);
        si
    si
si
