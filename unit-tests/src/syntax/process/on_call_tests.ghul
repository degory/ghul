namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;
    use Logging.Logger;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.GLOBAL_FUNCTION;
    use Semantic.Symbols.LOCAL_VARIABLE;
    use Semantic.Symbols.Function;
    use Semantic.Symbols.PURITY;
    use Semantic.Symbols.Symbol;
    use Semantic.Symbols.Variable;
    use Semantic.Types.NAMED;
    use Semantic.Types.Type;

    use Syntax.Process.ACCESS_PATH;
    use Syntax.Process.NARROW_ENV;
    use Syntax.Process.NARROWING_FLOW;

    // Tests for NARROWING_FLOW.on_call — the call-site transfer
    // that drives path-presence invalidation off the callee's
    // tri-state purity × receiver shape. The contract is the
    // table:
    //
    //   purity \ receiver | LOCAL(v)              | NON_LOCAL | NONE
    //   ------------------+-----------------------+-----------+------
    //   PURE              | no-op                 | no-op     | no-op
    //   MUT               | drop_paths_rooted_at  | clear all | no-op
    //   IMPURE            | clear all             | clear all | clear
    //
    // Each row × column is a separate test below.
    class ON_CALL_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(NAMED(c));
            return c.type;
        si

        // Helper: build a `LOCAL_VARIABLE` named `name`.
        make_local(owner: CLASS, name: string) -> Variable is
            let v = LOCAL_VARIABLE(loc(), owner, name);
            v.set_type(make_class_type("T_{name}"));
            return v;
        si

        // Helper: build a `Function` symbol with the given
        // purity.
        make_function(purity: PURITY) -> Function is
            let owner = make_owner();
            let function = GLOBAL_FUNCTION(loc(), loc(), owner, "test_fn", owner);
            function.purity = purity;
            return function;
        si

        // Helper: build an ACCESS_PATH `root.member`.
        make_path(root: Variable, owner: CLASS, member_name: string) -> ACCESS_PATH is
            let member = LOCAL_VARIABLE(loc(), owner, member_name);
            let members = LIST[Symbol]();
            members.add(member);
            return ACCESS_PATH(root, members);
        si

        // Helper: NARROWING_FLOW seeded with a fresh env that
        // already has one path-presence fact recorded.
        make_flow_with_path(path: ACCESS_PATH) -> NARROWING_FLOW is
            let flow = NARROWING_FLOW();
            let env = NARROW_ENV();
            env.set_non_null_path(path);
            flow.set_env(env);
            return flow;
        si

        Pure_callee_with_local_receiver_should_preserve_paths() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            let flow = make_flow_with_path(path);
            let f = make_function(PURITY.PURE);

            flow.on_call(f, true, h);

            Assert.is_true(flow.is_non_null_path(path));
        si

        Pure_callee_with_non_local_receiver_should_preserve_paths() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            let flow = make_flow_with_path(path);
            let f = make_function(PURITY.PURE);

            flow.on_call(f, true, null);

            Assert.is_true(flow.is_non_null_path(path));
        si

        Pure_callee_with_no_receiver_should_preserve_paths() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            let flow = make_flow_with_path(path);
            let f = make_function(PURITY.PURE);

            flow.on_call(f, false, null);

            Assert.is_true(flow.is_non_null_path(path));
        si

        Mut_callee_with_known_local_receiver_should_drop_paths_rooted_there() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            let flow = make_flow_with_path(path);
            let f = make_function(PURITY.MUT);

            flow.on_call(f, true, h);

            Assert.is_false(flow.is_non_null_path(path));
        si

        Mut_callee_with_known_local_receiver_should_keep_sibling_paths() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let b = make_local(owner, "b");
            let h_path = make_path(h, owner, "name");

            let flow = make_flow_with_path(h_path);
            let f = make_function(PURITY.MUT);

            // Receiver is `b`; `h.name` is rooted at `h`, not
            // `b`, so it should survive.
            flow.on_call(f, true, b);

            Assert.is_true(flow.is_non_null_path(h_path));
        si

        Mut_callee_with_non_local_receiver_should_clear_all_paths() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            let flow = make_flow_with_path(path);
            let f = make_function(PURITY.MUT);

            // has_caller_receiver=true but receiver=null — the
            // call has a receiver expression that isn't a
            // known-local load (path expression, expression
            // result). Conservative: clear everything.
            flow.on_call(f, true, null);

            Assert.is_false(flow.is_non_null_path(path));
        si

        Mut_callee_with_no_receiver_expression_should_preserve_paths() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            let flow = make_flow_with_path(path);
            let f = make_function(PURITY.MUT);

            // Constructor / static / global call: no caller
            // receiver expression at all. Nothing in the
            // caller's narrowing env can alias what MUT would
            // mutate.
            flow.on_call(f, false, null);

            Assert.is_true(flow.is_non_null_path(path));
        si

        Impure_callee_should_clear_all_paths() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            let flow = make_flow_with_path(path);
            let f = make_function(PURITY.IMPURE);

            flow.on_call(f, true, h);

            Assert.is_false(flow.is_non_null_path(path));
        si

        Impure_callee_should_clear_paths_regardless_of_receiver_shape() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            // No receiver at all — IMPURE still clears.
            let flow = make_flow_with_path(path);
            let f = make_function(PURITY.IMPURE);

            flow.on_call(f, false, null);

            Assert.is_false(flow.is_non_null_path(path));
        si

        Null_callee_should_clear_all_paths() is
            @test()

            let owner = make_owner();
            let h = make_local(owner, "h");
            let path = make_path(h, owner, "name");

            let flow = make_flow_with_path(path);

            // Unresolvable callee (closure / delegate /
            // unresolved). Conservative: clear.
            flow.on_call(null, true, h);

            Assert.is_false(flow.is_non_null_path(path));
        si
    si
si
