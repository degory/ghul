namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.STRUCT;
    use Semantic.Types.Type;

    // Tests for PATTERN_CHECKER's value-type narrow gating logic. The
    // gate decides when `cannot narrow {T}` fires for a binding pattern
    // and is shared between `if let` (which requires the bare form be
    // refutable) and `case`-when patterns (which do not — a bare
    // destructure of a non-nullable value-type tuple is a valid arm
    // that simply always matches, not an error).
    //
    // The behaviour is also pinned end-to-end by
    // `integration-tests/semantic/case-when-pattern-errors` (target
    // ascription rejected) and
    // `integration-tests/execution/case-when-pattern-non-optional-destructure`
    // (bare destructure of non-nullable tuple accepted). These unit
    // tests pin the gate's contract directly so a future caller can
    // pick the right `bare_form_requires_refutability` value without
    // running the full pipeline.
    class PATTERN_CHECKER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_value_type() -> Type is
            // STRUCT.is_value_type = true; with no `has_value`/`value`
            // members it is the non-option-shape value type that the
            // gate is concerned with rejecting.
            let s = STRUCT(loc(), loc(), null, "TestStruct", empty_names(), false, null);
            return s.type;
        si

        make_reference_type() -> Type is
            let c = CLASS(loc(), loc(), null, "TestClass", empty_names(), false, null);
            return c.type;
        si

        Returns_false_when_effective_type_is_null() is
            @test()

            Assert.is_false(PATTERN_CHECKER.should_emit_value_type_narrow_error(null, null, true));
            Assert.is_false(PATTERN_CHECKER.should_emit_value_type_narrow_error(null, make_reference_type(), true));
        si

        Returns_false_when_effective_type_is_a_reference_type() is
            @test()

            let ref_type = make_reference_type();

            Assert.is_false(PATTERN_CHECKER.should_emit_value_type_narrow_error(ref_type, null, true));
            Assert.is_false(PATTERN_CHECKER.should_emit_value_type_narrow_error(ref_type, ref_type, true));
        si

        Returns_true_for_value_type_with_ascription_when_refutability_required() is
            @test()

            let v = make_value_type();

            Assert.is_true(PATTERN_CHECKER.should_emit_value_type_narrow_error(v, v, true));
        si

        Returns_true_for_value_type_with_ascription_when_refutability_not_required() is
            @test()

            // An explicit `: T` ascription always fires the rejection,
            // regardless of `bare_form_requires_refutability` — the
            // caller wrote a narrowing that has nothing to test.
            let v = make_value_type();

            Assert.is_true(PATTERN_CHECKER.should_emit_value_type_narrow_error(v, v, false));
        si

        Returns_true_for_bare_value_type_when_refutability_required() is
            @test()

            // `if let v = some_int` — no ascription but the caller (if-let)
            // requires the bare form be refutable on its own.
            let v = make_value_type();

            Assert.is_true(PATTERN_CHECKER.should_emit_value_type_narrow_error(v, null, true));
        si

        Returns_false_for_bare_value_type_when_refutability_not_required() is
            @test()

            // `case y when (a, b) then ...` on a non-nullable tuple —
            // no ascription, caller does not require refutability.
            // This is the new path the parameter enables.
            let v = make_value_type();

            Assert.is_false(PATTERN_CHECKER.should_emit_value_type_narrow_error(v, null, false));
        si
    si
si
