namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.ENUM_STRUCT;
    use Semantic.Symbols.ENUM_STRUCT_MEMBER;
    use Semantic.Symbols.UNION;
    use Semantic.Symbols.VARIANT;
    use Semantic.Symbols.Classy;

    use Syntax.Process.ARM_COVERAGE;
    use Syntax.Process.CASE_COVERAGE;
    use Syntax.Process.CASE_DOMAIN;

    // CASE_COVERAGE / ARM_COVERAGE / CASE_DOMAIN are the pure-logic
    // pieces of the case exhaustiveness checker. The visitor-side
    // pattern-to-coverage translation is exercised by the integration
    // suite; these tests pin the closed-domain bookkeeping in
    // isolation — is_complete, describe_missing, adds_to, absorb —
    // so future changes to those rules show up as test diffs rather
    // than spurious integration-test churn.
    class CASE_EXHAUSTIVENESS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        build_color_union() -> (root_symbol: UNION, red: VARIANT, green: VARIANT, blue: VARIANT) is
            let root_symbol = UNION(loc(), loc(), null, "Color", empty_names(), false, null);

            let red = VARIANT(loc(), loc(), root_symbol, "RED", empty_names(), false, null);
            let green = VARIANT(loc(), loc(), root_symbol, "GREEN", empty_names(), false, null);
            let blue = VARIANT(loc(), loc(), root_symbol, "BLUE", empty_names(), false, null);

            return (root_symbol, red, green, blue);
        si

        build_animal_closed_hierarchy() -> (root_symbol: CLASS, cat: CLASS, dog: CLASS) is
            let root_symbol = CLASS(loc(), loc(), null, "Animal", empty_names(), false, null);
            let cat = CLASS(loc(), loc(), null, "Cat", empty_names(), false, null);
            let dog = CLASS(loc(), loc(), null, "Dog", empty_names(), false, null);

            return (root_symbol, cat, dog);
        si

        build_color_enum() -> (root_symbol: ENUM_STRUCT, red: ENUM_STRUCT_MEMBER, green: ENUM_STRUCT_MEMBER, blue: ENUM_STRUCT_MEMBER) is
            let root_symbol = ENUM_STRUCT(loc(), loc(), null, "Color", false, null);
            let red = ENUM_STRUCT_MEMBER(loc(), root_symbol, "RED", "0");
            let green = ENUM_STRUCT_MEMBER(loc(), root_symbol, "GREEN", "1");
            let blue = ENUM_STRUCT_MEMBER(loc(), root_symbol, "BLUE", "2");

            return (root_symbol, red, green, blue);
        si

        list_of(alternatives: Collections.Iterable[Classy]) -> LIST[Classy] is
            let result = LIST[Classy]();
            for v in alternatives do
                result.add(v);
            od
            return result;
        si

        members_of(members: Collections.Iterable[ENUM_STRUCT_MEMBER]) -> LIST[ENUM_STRUCT_MEMBER] is
            let result = LIST[ENUM_STRUCT_MEMBER]();
            for m in members do
                result.add(m);
            od
            return result;
        si

        // === is_complete: bool ===

        Bool_domain_is_complete_when_both_branches_covered() is
            @test()

            let domain = CASE_DOMAIN.for_bool(false);
            let coverage = CASE_COVERAGE(domain);

            let arm = ARM_COVERAGE();
            arm.covers_true = true;
            arm.covers_false = true;

            coverage.absorb(arm);

            Assert.is_true(coverage.is_complete);
        si

        Bool_domain_is_not_complete_when_only_true_covered() is
            @test()

            let domain = CASE_DOMAIN.for_bool(false);
            let coverage = CASE_COVERAGE(domain);

            let arm = ARM_COVERAGE();
            arm.covers_true = true;

            coverage.absorb(arm);

            Assert.is_false(coverage.is_complete);
        si

        Optional_bool_domain_needs_null_to_be_complete() is
            @test()

            let domain = CASE_DOMAIN.for_bool(true);
            let coverage = CASE_COVERAGE(domain);

            let arm = ARM_COVERAGE();
            arm.covers_true = true;
            arm.covers_false = true;

            coverage.absorb(arm);

            Assert.is_false(coverage.is_complete);

            let null_arm = ARM_COVERAGE();
            null_arm.covers_null = true;
            coverage.absorb(null_arm);

            Assert.is_true(coverage.is_complete);
        si

        Universe_arm_makes_any_domain_complete() is
            @test()

            let h = build_color_union();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.red, h.green, h.blue]), false, false);
            let coverage = CASE_COVERAGE(domain);

            let arm = ARM_COVERAGE();
            arm.covers_universe = true;

            coverage.absorb(arm);

            Assert.is_true(coverage.is_complete);
        si

        // === is_complete: union ===

        Union_domain_complete_only_when_all_variants_covered() is
            @test()

            let h = build_color_union();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.red, h.green, h.blue]), false, false);
            let coverage = CASE_COVERAGE(domain);

            let red_arm = ARM_COVERAGE();
            red_arm.covered_alternatives.add(h.red);
            coverage.absorb(red_arm);

            Assert.is_false(coverage.is_complete);

            let green_arm = ARM_COVERAGE();
            green_arm.covered_alternatives.add(h.green);
            coverage.absorb(green_arm);

            Assert.is_false(coverage.is_complete);

            let blue_arm = ARM_COVERAGE();
            blue_arm.covered_alternatives.add(h.blue);
            coverage.absorb(blue_arm);

            Assert.is_true(coverage.is_complete);
        si

        Optional_union_needs_null_plus_all_variants() is
            @test()

            let h = build_color_union();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.red, h.green, h.blue]), false, true);
            let coverage = CASE_COVERAGE(domain);

            let all_variants = ARM_COVERAGE();
            all_variants.covered_alternatives.add(h.red);
            all_variants.covered_alternatives.add(h.green);
            all_variants.covered_alternatives.add(h.blue);
            coverage.absorb(all_variants);

            Assert.is_false(coverage.is_complete);

            let null_arm = ARM_COVERAGE();
            null_arm.covers_null = true;
            coverage.absorb(null_arm);

            Assert.is_true(coverage.is_complete);
        si

        // === is_complete: closed class ===

        Abstract_closed_class_domain_complete_when_all_subclasses_covered() is
            @test()

            let h = build_animal_closed_hierarchy();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.cat, h.dog]), false, false);
            let coverage = CASE_COVERAGE(domain);

            let cat_arm = ARM_COVERAGE();
            cat_arm.covered_alternatives.add(h.cat);
            coverage.absorb(cat_arm);

            Assert.is_false(coverage.is_complete);

            let dog_arm = ARM_COVERAGE();
            dog_arm.covered_alternatives.add(h.dog);
            coverage.absorb(dog_arm);

            Assert.is_true(coverage.is_complete);
        si

        Concrete_closed_class_domain_needs_root_arm_too() is
            @test()

            let h = build_animal_closed_hierarchy();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.cat, h.dog]), true, false);
            let coverage = CASE_COVERAGE(domain);

            let cat_arm = ARM_COVERAGE();
            cat_arm.covered_alternatives.add(h.cat);
            coverage.absorb(cat_arm);

            let dog_arm = ARM_COVERAGE();
            dog_arm.covered_alternatives.add(h.dog);
            coverage.absorb(dog_arm);

            Assert.is_false(coverage.is_complete);

            let root_arm = ARM_COVERAGE();
            root_arm.covers_root = true;
            coverage.absorb(root_arm);

            Assert.is_true(coverage.is_complete);
        si

        Concrete_closed_class_describe_missing_names_root() is
            @test()

            let h = build_animal_closed_hierarchy();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.cat, h.dog]), true, false);
            let coverage = CASE_COVERAGE(domain);

            let cat_arm = ARM_COVERAGE();
            cat_arm.covered_alternatives.add(h.cat);
            coverage.absorb(cat_arm);

            let dog_arm = ARM_COVERAGE();
            dog_arm.covered_alternatives.add(h.dog);
            coverage.absorb(dog_arm);

            Assert.are_equal("Animal", coverage.describe_missing());
        si

        // === is_complete: enum ===

        Enum_domain_complete_only_when_all_members_covered() is
            @test()

            let h = build_color_enum();
            let domain = CASE_DOMAIN.for_enum(h.root_symbol, members_of([h.red, h.green, h.blue]), false);
            let coverage = CASE_COVERAGE(domain);

            let red_arm = ARM_COVERAGE();
            red_arm.covered_enum_values.add("0");
            coverage.absorb(red_arm);

            Assert.is_false(coverage.is_complete);

            let green_arm = ARM_COVERAGE();
            green_arm.covered_enum_values.add("1");
            coverage.absorb(green_arm);

            Assert.is_false(coverage.is_complete);

            let blue_arm = ARM_COVERAGE();
            blue_arm.covered_enum_values.add("2");
            coverage.absorb(blue_arm);

            Assert.is_true(coverage.is_complete);
        si

        Optional_enum_needs_null_plus_all_members() is
            @test()

            let h = build_color_enum();
            let domain = CASE_DOMAIN.for_enum(h.root_symbol, members_of([h.red, h.green, h.blue]), true);
            let coverage = CASE_COVERAGE(domain);

            let all_members = ARM_COVERAGE();
            all_members.covered_enum_values.add("0");
            all_members.covered_enum_values.add("1");
            all_members.covered_enum_values.add("2");
            coverage.absorb(all_members);

            Assert.is_false(coverage.is_complete);

            let null_arm = ARM_COVERAGE();
            null_arm.covers_null = true;
            coverage.absorb(null_arm);

            Assert.is_true(coverage.is_complete);
        si

        // === describe_missing ===

        Describe_missing_names_uncovered_union_variants_in_order() is
            @test()

            let h = build_color_union();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.red, h.green, h.blue]), false, false);
            let coverage = CASE_COVERAGE(domain);

            let red_arm = ARM_COVERAGE();
            red_arm.covered_alternatives.add(h.red);
            coverage.absorb(red_arm);

            Assert.are_equal("GREEN, BLUE", coverage.describe_missing());
        si

        Describe_missing_names_uncovered_subclasses_in_order() is
            @test()

            let h = build_animal_closed_hierarchy();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.cat, h.dog]), false, false);
            let coverage = CASE_COVERAGE(domain);

            let cat_arm = ARM_COVERAGE();
            cat_arm.covered_alternatives.add(h.cat);
            coverage.absorb(cat_arm);

            Assert.are_equal("Dog", coverage.describe_missing());
        si

        Describe_missing_names_uncovered_enum_members_in_order() is
            @test()

            let h = build_color_enum();
            let domain = CASE_DOMAIN.for_enum(h.root_symbol, members_of([h.red, h.green, h.blue]), false);
            let coverage = CASE_COVERAGE(domain);

            let red_arm = ARM_COVERAGE();
            red_arm.covered_enum_values.add("0");
            coverage.absorb(red_arm);

            Assert.are_equal("GREEN, BLUE", coverage.describe_missing());
        si

        Describe_missing_lists_null_before_variants() is
            @test()

            let h = build_color_union();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.red, h.green, h.blue]), false, true);
            let coverage = CASE_COVERAGE(domain);

            Assert.are_equal("null, RED, GREEN, BLUE", coverage.describe_missing());
        si

        Describe_missing_for_bool_lists_uncovered_branches() is
            @test()

            let domain = CASE_DOMAIN.for_bool(false);
            let coverage = CASE_COVERAGE(domain);

            let true_arm = ARM_COVERAGE();
            true_arm.covers_true = true;
            coverage.absorb(true_arm);

            Assert.are_equal("false", coverage.describe_missing());
        si

        // === adds_to: redundancy ===

        Arm_covering_already_covered_variant_does_not_add_to() is
            @test()

            let h = build_color_union();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.red, h.green, h.blue]), false, false);
            let coverage = CASE_COVERAGE(domain);

            let first = ARM_COVERAGE();
            first.covered_alternatives.add(h.red);
            coverage.absorb(first);

            let duplicate = ARM_COVERAGE();
            duplicate.covered_alternatives.add(h.red);

            Assert.is_false(duplicate.adds_to(coverage));
        si

        Arm_covering_a_new_variant_adds_to() is
            @test()

            let h = build_color_union();
            let domain = CASE_DOMAIN.for_closed_root(h.root_symbol, list_of([h.red, h.green, h.blue]), false, false);
            let coverage = CASE_COVERAGE(domain);

            let first = ARM_COVERAGE();
            first.covered_alternatives.add(h.red);
            coverage.absorb(first);

            let second = ARM_COVERAGE();
            second.covered_alternatives.add(h.green);

            Assert.is_true(second.adds_to(coverage));
        si

        Arm_covering_already_covered_enum_value_does_not_add_to() is
            @test()

            let h = build_color_enum();
            let domain = CASE_DOMAIN.for_enum(h.root_symbol, members_of([h.red, h.green, h.blue]), false);
            let coverage = CASE_COVERAGE(domain);

            let first = ARM_COVERAGE();
            first.covered_enum_values.add("0");
            coverage.absorb(first);

            let duplicate = ARM_COVERAGE();
            duplicate.covered_enum_values.add("0");

            Assert.is_false(duplicate.adds_to(coverage));
        si

        Arm_covering_new_enum_value_adds_to() is
            @test()

            let h = build_color_enum();
            let domain = CASE_DOMAIN.for_enum(h.root_symbol, members_of([h.red, h.green, h.blue]), false);
            let coverage = CASE_COVERAGE(domain);

            let first = ARM_COVERAGE();
            first.covered_enum_values.add("0");
            coverage.absorb(first);

            let second = ARM_COVERAGE();
            second.covered_enum_values.add("1");

            Assert.is_true(second.adds_to(coverage));
        si

        Empty_arm_does_not_add_to() is
            @test()

            let domain = CASE_DOMAIN.for_bool(false);
            let coverage = CASE_COVERAGE(domain);

            let empty = ARM_COVERAGE();

            Assert.is_false(empty.adds_to(coverage));
        si

        Arm_covering_universe_after_universe_does_not_add_to() is
            @test()

            let domain = CASE_DOMAIN.for_bool(false);
            let coverage = CASE_COVERAGE(domain);

            let first = ARM_COVERAGE();
            first.covers_universe = true;
            coverage.absorb(first);

            let second = ARM_COVERAGE();
            second.covers_universe = true;

            Assert.is_false(second.adds_to(coverage));
        si
    si
si
