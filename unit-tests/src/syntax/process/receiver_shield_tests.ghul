namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Variable;
    use Semantic.Symbols.INSTANCE_FIELD;

    // Tests for RECEIVER_SHIELD — the stack of assignment-target
    // receivers exempt from the call transfer, and the per-frame record
    // of whether a call occurred while a receiver was shielded.
    class RECEIVER_SHIELD_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_field(owner: CLASS, name: string) -> INSTANCE_FIELD =>
            INSTANCE_FIELD(loc(), owner, name);

        @test()
        shielded_variable_is_marked_and_reports_a_hit() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let shield = RECEIVER_SHIELD();

            let frame = shield.push(f);

            Assert.is_true(shield.mark_if_shielded(f));
            Assert.is_true(shield.release(frame));
        si

        @test()
        release_reports_no_hit_without_a_mark() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let shield = RECEIVER_SHIELD();

            let frame = shield.push(f);

            Assert.is_false(shield.release(frame));
        si

        @test()
        an_unshielded_variable_is_not_marked() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let other = make_field(owner, "_g");
            let shield = RECEIVER_SHIELD();

            let frame = shield.push(f);

            Assert.is_false(shield.mark_if_shielded(other));
            Assert.is_true(shield.mark_if_shielded(f));
        si

        @test()
        nested_frames_are_independent() is
            let owner = make_owner();
            let outer = make_field(owner, "_a");
            let inner = make_field(owner, "_b");
            let shield = RECEIVER_SHIELD();

            let outer_frame = shield.push(outer);
            let inner_frame = shield.push(inner);

            // A call inside the inner assignment marks both receivers
            // shielded — each was captured before it.
            Assert.is_true(shield.mark_if_shielded(inner));
            Assert.is_true(shield.mark_if_shielded(outer));

            Assert.is_true(shield.release(inner_frame));
            Assert.is_true(shield.release(outer_frame));
        si

        @test()
        pushing_null_is_a_no_op() is
            let shield = RECEIVER_SHIELD();

            let frame = shield.push(null);

            Assert.is_false(shield.release(frame));
        si
    si
si
