namespace Syntax.Process.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Syntax.Process.TUPLE_ELEMENT_NAME;

    // Pin the corner cases of the underscore-strip rule for
    // bare-identifier tuple element names. The rule is intentionally
    // narrow: strip a single leading underscore only when the
    // identifier resolves to a field. Anything else passes through.
    class TUPLE_ELEMENT_NAME_TESTS is
        @test()

        init() is si

        // === Field loads: strip a single leading underscore ===

        Calling__infer__on_field_load_named_underscore_count__strips_to_count() is
            @test()

            Assert.are_equal("count", TUPLE_ELEMENT_NAME.infer("_count", true));
        si

        Calling__infer__on_field_load_named_underscore_a__strips_to_a() is
            @test()

            Assert.are_equal("a", TUPLE_ELEMENT_NAME.infer("_a", true));
        si

        // === Field loads: corner cases that do not strip ===

        // The private-member convention is a single leading
        // underscore. Stripping `__raw` to `_raw` would change the
        // semantics of the rule (now it strips one of N), so we hold
        // the line at exactly-one.
        Calling__infer__on_field_load_named_double_underscore__does_not_strip() is
            @test()

            Assert.are_equal("__raw", TUPLE_ELEMENT_NAME.infer("__raw", true));
        si

        // A bare single-underscore identifier has nothing to strip
        // down to. Stripping would produce an empty element name.
        Calling__infer__on_field_load_named_single_underscore__does_not_strip() is
            @test()

            Assert.are_equal("_", TUPLE_ELEMENT_NAME.infer("_", true));
        si

        Calling__infer__on_field_load_with_no_leading_underscore__returns_identifier_unchanged() is
            @test()

            Assert.are_equal("count", TUPLE_ELEMENT_NAME.infer("count", true));
        si

        // === Non-field identifiers: never strip ===

        // The convention only marks fields/properties as private. A
        // local variable that happens to be underscore-prefixed
        // keeps its full name in the inferred tuple shape.
        Calling__infer__on_non_field_identifier_with_leading_underscore__does_not_strip() is
            @test()

            Assert.are_equal("_scratch", TUPLE_ELEMENT_NAME.infer("_scratch", false));
        si

        Calling__infer__on_non_field_identifier_without_underscore__returns_identifier_unchanged() is
            @test()

            Assert.are_equal("count", TUPLE_ELEMENT_NAME.infer("count", false));
        si
    si
si
