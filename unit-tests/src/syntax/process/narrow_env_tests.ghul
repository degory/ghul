namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.INSTANCE_PROPERTY;
    use Semantic.Symbols.LOCAL_VARIABLE;
    use Semantic.Symbols.Symbol;
    use Semantic.Symbols.Variable;
    use Semantic.Types.Type;

    // Tests for NARROW_ENV — the narrowing-environment value type
    // and its `join`. Types are constructed directly; `join` needs
    // genuine subtype relationships, built via CLASS.add_ancestor
    // (see unit-test-fixtures.md).
    class NARROW_ENV_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_var(owner: CLASS, name: string, t: Type) -> Variable is
            let v = Semantic.Symbols.LOCAL_VARIABLE(loc(), owner, name);
            v.set_type(t);
            return v;
        si

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            return c.type!;
        si

        make_subclass_type(name: string, base: Type) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            c.add_ancestor(base);
            return c.type!;
        si

        Empty_env_should_report_empty() is
            @test()

            let e = NARROW_ENV();

            Assert.is_true(e.is_empty);
            Assert.is_false(e.is_bottom);
            Assert.are_equal(0, e.count);
        si

        Bottom_env_should_report_bottom() is
            @test()

            let e = NARROW_ENV.bottom();

            Assert.is_true(e.is_bottom);
            Assert.is_false(e.is_empty);
        si

        set_narrow_should_record_and_be_readable() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let e = NARROW_ENV();
            e.set_narrow(v, t);

            Assert.is_true(e.contains(v));
            Assert.are_same(t, e.narrowed_type_of(v));
            Assert.are_equal(1, e.count);
        si

        narrowed_type_of_should_return_null_for_unrecorded() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            Assert.is_false(NARROW_ENV().contains(v));
            Assert.is_null(NARROW_ENV().narrowed_type_of(v));
        si

        drop_narrow_should_remove_entry() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let e = NARROW_ENV();
            e.set_narrow(v, t);
            e.drop_narrow(v);

            Assert.is_false(e.contains(v));
            Assert.are_equal(0, e.count);
        si

        // Composing a subtype-refining narrow keeps the tighter type,
        // exercising the subtype branch of INTERSECTION.create.
        set_narrow_should_refine_to_subtype_on_compose() is
            @test()

            let owner = make_owner();
            let base = make_class_type("Base");
            let sub = make_subclass_type("Sub", base);
            let v = make_var(owner, "v", base);

            let e = NARROW_ENV();
            e.set_narrow(v, base);
            e.set_narrow(v, sub);

            Assert.are_same(sub, e.narrowed_type_of(v));
            Assert.are_equal(1, e.count);
        si

        // Composing the same narrow type twice must not grow the map
        // — the short-circuit skips when INTERSECTION.create(existing, t)
        // equals existing.
        set_narrow_should_skip_no_op_compose() is
            @test()

            let owner = make_owner();
            let base = make_class_type("Base");
            let sub = make_subclass_type("Sub", base);
            let v = make_var(owner, "v", base);

            let e = NARROW_ENV();
            e.set_narrow(v, sub);
            let first = e.narrowed_type_of(v);

            // Re-record the same narrow: no observable change.
            e.set_narrow(v, sub);
            Assert.are_same(first, e.narrowed_type_of(v));
            Assert.are_equal(1, e.count);
        si

        // Composing a weaker (supertype) narrow on top of a strict-subtype
        // narrow leaves the existing tighter type — the short-circuit
        // fires because INTERSECTION.create returns `existing`.
        set_narrow_should_skip_weaker_compose() is
            @test()

            let owner = make_owner();
            let base = make_class_type("Base");
            let sub = make_subclass_type("Sub", base);
            let v = make_var(owner, "v", base);

            let e = NARROW_ENV();
            e.set_narrow(v, sub);
            let before = e.narrowed_type_of(v);

            // Weakening to the supertype must not overwrite the tighter
            // narrow; the recorded type stays `sub`.
            e.set_narrow(v, base);
            Assert.are_same(before, e.narrowed_type_of(v));
            Assert.are_equal(1, e.count);
        si

        // Two unrelated concrete classes have no intersection — the
        // recording edge is statically impossible, and its code is
        // written against the newly tested type, so the new narrow
        // replaces the stale one.
        set_narrow_should_replace_on_unrelated_concrete_compose() is
            @test()

            let owner = make_owner();
            let cat = make_class_type("Cat");
            let dog = make_class_type("Dog");
            let v = make_var(owner, "v", make_class_type("Animal"));

            let e = NARROW_ENV();
            e.set_narrow(v, cat);
            e.set_narrow(v, dog);

            Assert.are_same(dog, e.narrowed_type_of(v));
            Assert.are_equal(1, e.count);
        si

        set_narrow_on_bottom_should_be_no_op() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let e = NARROW_ENV.bottom();
            e.set_narrow(v, t);

            Assert.is_false(e.contains(v));
            Assert.is_true(e.is_bottom);
        si

        copy_should_be_independent() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let a = make_var(owner, "a", t);
            let b = make_var(owner, "b", t);

            let original = NARROW_ENV();
            original.set_narrow(a, t);

            let clone = original.copy();
            clone.set_narrow(b, t);
            clone.drop_narrow(a);

            // original unchanged by clone mutations
            Assert.is_true(original.contains(a));
            Assert.is_false(original.contains(b));

            Assert.is_false(clone.contains(a));
            Assert.is_true(clone.contains(b));
        si

        join_with_bottom_should_return_the_other_side() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let a = NARROW_ENV();
            a.set_narrow(v, t);

            let left = NARROW_ENV.join(NARROW_ENV.bottom(), a);
            Assert.are_same(t, left.narrowed_type_of(v));

            let right = NARROW_ENV.join(a, NARROW_ENV.bottom());
            Assert.are_same(t, right.narrowed_type_of(v));
        si

        join_should_keep_variable_narrowed_in_both_sides() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let a = NARROW_ENV();
            a.set_narrow(v, t);
            let b = NARROW_ENV();
            b.set_narrow(v, t);

            let merged = NARROW_ENV.join(a, b);

            Assert.is_true(merged.contains(v));
            Assert.are_same(t, merged.narrowed_type_of(v));
        si

        join_should_drop_variable_narrowed_in_only_one_side() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let a = NARROW_ENV();
            a.set_narrow(v, t);
            let b = NARROW_ENV();

            Assert.is_false(NARROW_ENV.join(a, b).contains(v));
            Assert.is_false(NARROW_ENV.join(b, a).contains(v));
        si

        join_should_lub_when_both_sides_narrow_to_siblings() is
            @test()

            // a narrows v to Cat, b narrows v to Dog, both <: Animal.
            // The merge keeps v narrowed to a common supertype.
            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let dog = make_subclass_type("Dog", animal);

            let v = make_var(owner, "v", animal);

            let a = NARROW_ENV();
            a.set_narrow(v, cat);
            let b = NARROW_ENV();
            b.set_narrow(v, dog);

            let merged = NARROW_ENV.join(a, b).narrowed_type_of(v);

            Assert.is_true(merged?);
            Assert.is_true(merged.is_assignable_from(cat));
            Assert.is_true(merged.is_assignable_from(dog));
        si

        join_should_keep_independent_variables_only_when_in_both() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let x = make_var(owner, "x", t);
            let y = make_var(owner, "y", t);

            let a = NARROW_ENV();
            a.set_narrow(x, t);
            let b = NARROW_ENV();
            b.set_narrow(y, t);

            let merged = NARROW_ENV.join(a, b);

            Assert.is_false(merged.contains(x));
            Assert.is_false(merged.contains(y));
            Assert.is_true(merged.is_empty);
        si

        set_non_null_should_record_and_be_readable() is
            @test()

            let owner = make_owner();
            // Presence facts are filtered when v's type is already
            // non-optional (declaration says it always holds a value),
            // so the fixture uses `T?` — the shape a real caller
            // records against.
            let v = make_var(owner, "v", make_class_type("T").as_optional());

            let e = NARROW_ENV();
            e.set_non_null(v);

            Assert.is_true(e.is_non_null(v));
        si

        is_non_null_should_be_false_for_unrecorded() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            Assert.is_false(NARROW_ENV().is_non_null(v));
        si

        drop_non_null_should_remove_entry() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            let e = NARROW_ENV();
            e.set_non_null(v);
            e.drop_non_null(v);

            Assert.is_false(e.is_non_null(v));
        si

        set_non_null_on_bottom_should_be_no_op() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            let e = NARROW_ENV.bottom();
            e.set_non_null(v);

            Assert.is_false(e.is_non_null(v));
        si

        copy_should_carry_non_null_independently() is
            @test()

            let owner = make_owner();
            let a = make_var(owner, "a", make_class_type("T").as_optional());
            let b = make_var(owner, "b", make_class_type("T").as_optional());

            let original = NARROW_ENV();
            original.set_non_null(a);

            let clone = original.copy();
            clone.set_non_null(b);
            clone.drop_non_null(a);

            Assert.is_true(original.is_non_null(a));
            Assert.is_false(original.is_non_null(b));
            Assert.is_false(clone.is_non_null(a));
            Assert.is_true(clone.is_non_null(b));
        si

        join_should_keep_non_null_in_both_sides() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T").as_optional());

            let a = NARROW_ENV();
            a.set_non_null(v);
            let b = NARROW_ENV();
            b.set_non_null(v);

            Assert.is_true(NARROW_ENV.join(a, b).is_non_null(v));
        si

        join_should_drop_non_null_in_only_one_side() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            let a = NARROW_ENV();
            a.set_non_null(v);
            let b = NARROW_ENV();

            Assert.is_false(NARROW_ENV.join(a, b).is_non_null(v));
            Assert.is_false(NARROW_ENV.join(b, a).is_non_null(v));
        si

        make_root(name: string) -> LOCAL_VARIABLE => LOCAL_VARIABLE(loc(), null, name);
        make_field(owner: CLASS, name: string) -> INSTANCE_FIELD => INSTANCE_FIELD(loc(), owner, name);
        make_property(owner: CLASS, name: string) -> INSTANCE_PROPERTY => INSTANCE_PROPERTY(loc(), loc(), owner, name, false, false);

        make_path(root: LOCAL_VARIABLE, member: Symbol) -> ACCESS_PATH is
            let list = LIST[Symbol]();
            list.add(member);
            return ACCESS_PATH(root, list);
        si

        make_path2(root: LOCAL_VARIABLE, a: Symbol, b: Symbol) -> ACCESS_PATH is
            let list = LIST[Symbol]();
            list.add(a);
            list.add(b);
            return ACCESS_PATH(root, list);
        si

        set_path_narrow_should_record_and_be_readable() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let path = make_path(make_root("r"), make_field(owner, "f"));

            let e = NARROW_ENV();
            e.set_path_narrow(path, t);

            Assert.are_same(t, e.narrowed_type_of_path(path));
        si

        narrowed_type_of_path_should_return_null_for_unrecorded() is
            @test()

            let owner = make_owner();
            let path = make_path(make_root("r"), make_field(owner, "f"));

            Assert.is_null(NARROW_ENV().narrowed_type_of_path(path));
        si

        set_path_narrow_on_bottom_should_be_no_op() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let path = make_path(make_root("r"), make_field(owner, "f"));

            let e = NARROW_ENV.bottom();
            e.set_path_narrow(path, t);

            Assert.is_null(e.narrowed_type_of_path(path));
        si

        set_path_narrow_should_refine_when_stacked_with_subtype() is
            @test()

            // Stacked narrows on the same path compose via INTERSECTION,
            // which drops the wider member when one narrow strict-subtypes
            // another — mirrors set_narrow's Symbol-keyed behaviour.
            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let path = make_path(make_root("r"), make_field(owner, "f"));

            let e = NARROW_ENV();
            e.set_path_narrow(path, animal);
            e.set_path_narrow(path, cat);

            // Cat strict-subtypes Animal — INTERSECTION keeps the tighter.
            Assert.are_same(cat, e.narrowed_type_of_path(path));
        si

        set_path_narrow_should_stay_at_tighter_when_widened() is
            @test()

            // Narrowing to a supertype after a subtype is a no-op — the
            // wider member is dropped by INTERSECTION.
            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let path = make_path(make_root("r"), make_field(owner, "f"));

            let e = NARROW_ENV();
            e.set_path_narrow(path, cat);
            e.set_path_narrow(path, animal);

            Assert.are_same(cat, e.narrowed_type_of_path(path));
        si

        copy_should_carry_path_narrows_independently() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let a_path = make_path(make_root("a"), make_field(owner, "f"));
            let b_path = make_path(make_root("b"), make_field(owner, "f"));

            let original = NARROW_ENV();
            original.set_path_narrow(a_path, t);

            let clone = original.copy();
            clone.set_path_narrow(b_path, t);

            Assert.are_same(t, original.narrowed_type_of_path(a_path));
            Assert.is_null(original.narrowed_type_of_path(b_path));

            Assert.are_same(t, clone.narrowed_type_of_path(a_path));
            Assert.are_same(t, clone.narrowed_type_of_path(b_path));
        si

        drop_all_paths_should_clear_path_narrows() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let path = make_path(make_root("r"), make_field(owner, "f"));

            let e = NARROW_ENV();
            e.set_path_narrow(path, t);
            e.drop_all_paths();

            Assert.is_null(e.narrowed_type_of_path(path));
        si

        drop_getter_paths_should_kill_getter_narrows_but_not_field_only() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let field_path = make_path(make_root("r"), make_field(owner, "f"));
            let getter_path = make_path(make_root("r"), make_property(owner, "p"));

            let e = NARROW_ENV();
            e.set_path_narrow(field_path, t);
            e.set_path_narrow(getter_path, t);
            e.drop_getter_paths();

            Assert.are_same(t, e.narrowed_type_of_path(field_path));
            Assert.is_null(e.narrowed_type_of_path(getter_path));
        si

        drop_paths_through_should_kill_paths_reading_the_member() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let f = make_field(owner, "f");
            let g = make_field(owner, "g");
            let path_f = make_path(make_root("r"), f);
            let path_g = make_path(make_root("r"), g);

            let e = NARROW_ENV();
            e.set_path_narrow(path_f, t);
            e.set_path_narrow(path_g, t);
            e.drop_paths_through(f);

            Assert.is_null(e.narrowed_type_of_path(path_f));
            Assert.are_same(t, e.narrowed_type_of_path(path_g));
        si

        drop_paths_rooted_at_should_kill_paths_from_that_root() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let f = make_field(owner, "f");
            let root_a = make_root("a");
            let root_b = make_root("b");
            let path_a = make_path(root_a, f);
            let path_b = make_path(root_b, f);

            let e = NARROW_ENV();
            e.set_path_narrow(path_a, t);
            e.set_path_narrow(path_b, t);
            e.drop_paths_rooted_at(root_a);

            Assert.is_null(e.narrowed_type_of_path(path_a));
            Assert.are_same(t, e.narrowed_type_of_path(path_b));
        si

        drop_heap_facts_should_clear_path_narrows() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let path = make_path(make_root("r"), make_field(owner, "f"));

            let e = NARROW_ENV();
            e.set_path_narrow(path, t);
            e.drop_heap_facts();

            Assert.is_null(e.narrowed_type_of_path(path));
        si

        join_should_keep_path_narrows_in_both_sides() is
            @test()

            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let dog = make_subclass_type("Dog", animal);
            let path = make_path(make_root("r"), make_field(owner, "f"));

            let a = NARROW_ENV();
            a.set_path_narrow(path, cat);
            let b = NARROW_ENV();
            b.set_path_narrow(path, dog);

            let merged = NARROW_ENV.join(a, b).narrowed_type_of_path(path);

            Assert.is_true(merged?);
            Assert.is_true(merged.is_assignable_from(cat));
            Assert.is_true(merged.is_assignable_from(dog));
        si

        join_should_drop_path_narrow_present_in_only_one_side() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let path = make_path(make_root("r"), make_field(owner, "f"));

            let a = NARROW_ENV();
            a.set_path_narrow(path, t);
            let b = NARROW_ENV();

            Assert.is_null(NARROW_ENV.join(a, b).narrowed_type_of_path(path));
            Assert.is_null(NARROW_ENV.join(b, a).narrowed_type_of_path(path));
        si
    si
si
