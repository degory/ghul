namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Variable;
    use Semantic.Types.Type;

    // Tests for NARROW_ENV — the narrowing-environment value type
    // and its `join`. Types are constructed directly; `join` needs
    // genuine subtype relationships, built via CLASS.add_ancestor
    // (see unit-test-fixtures.md).
    class NARROW_ENV_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_var(owner: CLASS, name: string, t: Type) -> Variable is
            let v = Semantic.Symbols.LOCAL_VARIABLE(loc(), owner, name);
            v.set_type(t);
            return v;
        si

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            return c.type;
        si

        make_subclass_type(name: string, base: Type) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            c.add_ancestor(base);
            return c.type;
        si

        Empty_env_should_report_empty() is
            @test()

            let e = NARROW_ENV();

            Assert.is_true(e.is_empty);
            Assert.is_false(e.is_bottom);
            Assert.are_equal(0, e.count);
        si

        Bottom_env_should_report_bottom() is
            @test()

            let e = NARROW_ENV.bottom();

            Assert.is_true(e.is_bottom);
            Assert.is_false(e.is_empty);
        si

        set_narrow_should_record_and_be_readable() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let e = NARROW_ENV();
            e.set_narrow(v, t);

            Assert.is_true(e.contains(v));
            Assert.are_same(t, e.narrowed_type_of(v));
            Assert.are_equal(1, e.count);
        si

        narrowed_type_of_should_return_null_for_unrecorded() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            Assert.is_false(NARROW_ENV().contains(v));
            Assert.is_null(NARROW_ENV().narrowed_type_of(v));
        si

        drop_narrow_should_remove_entry() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let e = NARROW_ENV();
            e.set_narrow(v, t);
            e.drop_narrow(v);

            Assert.is_false(e.contains(v));
            Assert.are_equal(0, e.count);
        si

        set_narrow_on_bottom_should_be_no_op() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let e = NARROW_ENV.bottom();
            e.set_narrow(v, t);

            Assert.is_false(e.contains(v));
            Assert.is_true(e.is_bottom);
        si

        copy_should_be_independent() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let a = make_var(owner, "a", t);
            let b = make_var(owner, "b", t);

            let original = NARROW_ENV();
            original.set_narrow(a, t);

            let clone = original.copy();
            clone.set_narrow(b, t);
            clone.drop_narrow(a);

            // original unchanged by clone mutations
            Assert.is_true(original.contains(a));
            Assert.is_false(original.contains(b));

            Assert.is_false(clone.contains(a));
            Assert.is_true(clone.contains(b));
        si

        join_with_bottom_should_return_the_other_side() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let a = NARROW_ENV();
            a.set_narrow(v, t);

            let left = NARROW_ENV.join(NARROW_ENV.bottom(), a);
            Assert.are_same(t, left.narrowed_type_of(v));

            let right = NARROW_ENV.join(a, NARROW_ENV.bottom());
            Assert.are_same(t, right.narrowed_type_of(v));
        si

        join_should_keep_variable_narrowed_in_both_sides() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let a = NARROW_ENV();
            a.set_narrow(v, t);
            let b = NARROW_ENV();
            b.set_narrow(v, t);

            let merged = NARROW_ENV.join(a, b);

            Assert.is_true(merged.contains(v));
            Assert.are_same(t, merged.narrowed_type_of(v));
        si

        join_should_drop_variable_narrowed_in_only_one_side() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let a = NARROW_ENV();
            a.set_narrow(v, t);
            let b = NARROW_ENV();

            Assert.is_false(NARROW_ENV.join(a, b).contains(v));
            Assert.is_false(NARROW_ENV.join(b, a).contains(v));
        si

        join_should_lub_when_both_sides_narrow_to_siblings() is
            @test()

            // a narrows v to Cat, b narrows v to Dog, both <: Animal.
            // The merge keeps v narrowed to a common supertype.
            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let dog = make_subclass_type("Dog", animal);

            let v = make_var(owner, "v", animal);

            let a = NARROW_ENV();
            a.set_narrow(v, cat);
            let b = NARROW_ENV();
            b.set_narrow(v, dog);

            let merged = NARROW_ENV.join(a, b).narrowed_type_of(v);

            Assert.is_true(merged?);
            Assert.is_true(merged.is_assignable_from(cat));
            Assert.is_true(merged.is_assignable_from(dog));
        si

        join_should_keep_independent_variables_only_when_in_both() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let x = make_var(owner, "x", t);
            let y = make_var(owner, "y", t);

            let a = NARROW_ENV();
            a.set_narrow(x, t);
            let b = NARROW_ENV();
            b.set_narrow(y, t);

            let merged = NARROW_ENV.join(a, b);

            Assert.is_false(merged.contains(x));
            Assert.is_false(merged.contains(y));
            Assert.is_true(merged.is_empty);
        si

        set_non_null_should_record_and_be_readable() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            let e = NARROW_ENV();
            e.set_non_null(v);

            Assert.is_true(e.is_non_null(v));
        si

        is_non_null_should_be_false_for_unrecorded() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            Assert.is_false(NARROW_ENV().is_non_null(v));
        si

        drop_non_null_should_remove_entry() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            let e = NARROW_ENV();
            e.set_non_null(v);
            e.drop_non_null(v);

            Assert.is_false(e.is_non_null(v));
        si

        set_non_null_on_bottom_should_be_no_op() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            let e = NARROW_ENV.bottom();
            e.set_non_null(v);

            Assert.is_false(e.is_non_null(v));
        si

        copy_should_carry_non_null_independently() is
            @test()

            let owner = make_owner();
            let a = make_var(owner, "a", make_class_type("T"));
            let b = make_var(owner, "b", make_class_type("T"));

            let original = NARROW_ENV();
            original.set_non_null(a);

            let clone = original.copy();
            clone.set_non_null(b);
            clone.drop_non_null(a);

            Assert.is_true(original.is_non_null(a));
            Assert.is_false(original.is_non_null(b));
            Assert.is_false(clone.is_non_null(a));
            Assert.is_true(clone.is_non_null(b));
        si

        join_should_keep_non_null_in_both_sides() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            let a = NARROW_ENV();
            a.set_non_null(v);
            let b = NARROW_ENV();
            b.set_non_null(v);

            Assert.is_true(NARROW_ENV.join(a, b).is_non_null(v));
        si

        join_should_drop_non_null_in_only_one_side() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T"));

            let a = NARROW_ENV();
            a.set_non_null(v);
            let b = NARROW_ENV();

            Assert.is_false(NARROW_ENV.join(a, b).is_non_null(v));
            Assert.is_false(NARROW_ENV.join(b, a).is_non_null(v));
        si
    si
si
