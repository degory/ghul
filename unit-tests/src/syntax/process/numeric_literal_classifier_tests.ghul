namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use NSubstitute;
    use NSubstitute.SubstituteExtensions.returns;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    use Semantic.Lookups.InnateSymbolLookup;
    use Semantic.Symbols.CLASS;
    use Semantic.Types.Type;

    use Syntax.Process.NUMERIC_LITERAL_CLASSIFIER;

    class NUMERIC_LITERAL_CLASSIFIER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        // Numeric-primitive stand-ins for the classifier. Each
        // `get_*_type()` mock returns the same Type instance every
        // call so callers can identity-compare the classifier's
        // chosen type against the expected primitive. The methods
        // the classifier doesn't touch fall through to NSubstitute's
        // default (null) — none of its paths read them.
        build() -> (classifier: NUMERIC_LITERAL_CLASSIFIER, lookup: InnateSymbolLookup, logger: DIAGNOSTICS_STORE) is
            let logger = DIAGNOSTICS_STORE();
            let arguments = System.Array.empty`[object]();
            let lookup = NSubstitute.Substitute.`for`[InnateSymbolLookup](arguments);

            let bool_type = CLASS(loc(), loc(), null, "bool", LIST[string](), false, null).type!;
            let byte_type = CLASS(loc(), loc(), null, "byte", LIST[string](), false, null).type!;
            let ubyte_type = CLASS(loc(), loc(), null, "ubyte", LIST[string](), false, null).type!;
            let short_type = CLASS(loc(), loc(), null, "short", LIST[string](), false, null).type!;
            let int_type = CLASS(loc(), loc(), null, "int", LIST[string](), false, null).type!;
            let long_type = CLASS(loc(), loc(), null, "long", LIST[string](), false, null).type!;
            let ulong_type = CLASS(loc(), loc(), null, "ulong", LIST[string](), false, null).type!;
            let word_type = CLASS(loc(), loc(), null, "word", LIST[string](), false, null).type!;
            let uword_type = CLASS(loc(), loc(), null, "uword", LIST[string](), false, null).type!;

            returns(lookup.get_bool_type(), bool_type, null);
            returns(lookup.get_byte_type(), byte_type, null);
            returns(lookup.get_ubyte_type(), ubyte_type, null);
            returns(lookup.get_short_type(), short_type, null);
            returns(lookup.get_int_type(), int_type, null);
            returns(lookup.get_long_type(), long_type, null);
            returns(lookup.get_ulong_type(), ulong_type, null);
            returns(lookup.get_word_type(), word_type, null);
            returns(lookup.get_uword_type(), uword_type, null);

            let classifier = NUMERIC_LITERAL_CLASSIFIER(logger, lookup);
            return (classifier, lookup, logger);
        si

        // === classify_integer: suffix decoding ===

        Calling__classify_integer__with_no_suffix__picks_int_type() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "42");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_int_type(), result.type);
            Assert.are_equal("42", result.value);
            Assert.are_equal("i4", result.suffix);
        si

        Calling__classify_integer__with_b_suffix__picks_byte_type() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "42b");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_byte_type(), result.type);
            Assert.are_equal("42", result.value);
        si

        Calling__classify_integer__with_ub_suffix__picks_ubyte_type() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "200ub");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_ubyte_type(), result.type);
            Assert.are_equal("200", result.value);
        si

        Calling__classify_integer__with_l_suffix__picks_long_type_and_i8_suffix() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "42L");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_long_type(), result.type);
            Assert.are_equal("i8", result.suffix);
            Assert.are_equal("42", result.value);
        si

        Calling__classify_integer__with_w_suffix__picks_word_type_and_conv_i() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "42w");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_word_type(), result.type);
            Assert.are_equal("i8", result.suffix);
            Assert.are_equal("conv.i", result.conv);
        si

        Calling__classify_integer__with_uw_suffix__picks_uword_type_and_conv_u() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "42uw");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_uword_type(), result.type);
            Assert.are_equal("conv.u", result.conv);
        si

        Calling__classify_integer__with_s_suffix__picks_short_type() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "42s");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_short_type(), result.type);
        si

        Calling__classify_integer__with_uppercase_suffix__picks_correct_type() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "42I");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_int_type(), result.type);
        si

        // Structural error: 'c' (character literal) cannot be unsigned.
        // The classifier logs the error and the suffix-decode leaves
        // `type` null, so the entry point returns null.
        Calling__classify_integer__with_uc_suffix__logs_error_and_returns_null() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "65uc");

            Assert.is_null(result);
            Assert.is_true(b.logger.any_errors);
        si

        // === classify_integer: bounds ===

        Calling__classify_integer__with_value_at_byte_max__succeeds() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "127b");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_byte_type(), result.type);
        si

        Calling__classify_integer__with_value_over_byte_max__logs_error_and_returns_null() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "128b");

            Assert.is_null(result);
            Assert.is_true(b.logger.any_errors);
        si

        // 0xFF = 255, which exceeds signed-byte max 127 — classifier
        // logs the overflow error and returns null.
        Calling__classify_integer__with_hex_over_byte_max__returns_null() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "0xFFb");

            Assert.is_null(result);
            Assert.is_true(b.logger.any_errors);
        si

        Calling__classify_integer__with_hex_value_for_ubyte__succeeds() is
            @test()

            let b = build();
            let result = b.classifier.classify_integer(loc(), "0xFFub");

            Assert.is_not_null(result);
            Assert.are_same(b.lookup.get_ubyte_type(), result.type);
        si

        // === fits ===

        Calling__fits__with_value_inside_int_range__returns_true() is
            @test()

            let b = build();
            let ok = b.classifier.fits(loc(), "2147483647", b.lookup.get_int_type());

            Assert.is_true(ok);
        si

        Calling__fits__with_value_outside_int_range__returns_false_and_logs() is
            @test()

            let b = build();
            let ok = b.classifier.fits(loc(), "2147483648", b.lookup.get_int_type());

            Assert.is_false(ok);
            Assert.is_true(b.logger.any_errors);
        si

        Calling__fits__with_value_exceeding_ulong_parse__returns_false() is
            @test()

            // Larger than 2^64 — ulong.try_parse fails before we even
            // reach the max-unsigned check.
            let b = build();
            let ok = b.classifier.fits(loc(), "99999999999999999999", b.lookup.get_int_type());

            Assert.is_false(ok);
        si

        Calling__fits__with_unrecognised_type__skips_bound_check_and_returns_true() is
            @test()

            // Types not handled by max_unsigned_for (e.g. ulong / uword
            // / float types) return 0 from max_unsigned_for, which the
            // fits check reads as "no narrower bound", so any value
            // that parses as ulong succeeds.
            let b = build();
            let bool_type = b.lookup.get_bool_type();
            let ok = b.classifier.fits(loc(), "12345", bool_type);

            Assert.is_true(ok);
        si

        // === parse_hex ===

        Calling__parse_hex__with_valid_hex__returns_correct_value() is
            @test()

            let b = build();
            let (ok, value) = b.classifier.parse_hex("FF");

            Assert.is_true(ok);
            Assert.are_equal(255UL, value);
        si

        Calling__parse_hex__with_lowercase__returns_correct_value() is
            @test()

            let b = build();
            let (ok, value) = b.classifier.parse_hex("deadbeef");

            Assert.is_true(ok);
            Assert.are_equal(0xdeadbeefUL, value);
        si

        Calling__parse_hex__with_empty__returns_false() is
            @test()

            let b = build();
            let (ok, value) = b.classifier.parse_hex("");

            Assert.is_false(ok);
        si

        Calling__parse_hex__with_more_than_16_digits__returns_false() is
            @test()

            let b = build();
            let (ok, value) = b.classifier.parse_hex("00000000000000000");

            Assert.is_false(ok);
        si

        Calling__parse_hex__with_non_hex_char__returns_false() is
            @test()

            let b = build();
            let (ok, value) = b.classifier.parse_hex("123G");

            Assert.is_false(ok);
        si

        // === max_unsigned_for ===

        Calling__max_unsigned_for__on_byte__returns_127() is
            @test()

            let b = build();
            Assert.are_equal(127UL, b.classifier.max_unsigned_for(b.lookup.get_byte_type()));
        si

        Calling__max_unsigned_for__on_ubyte__returns_255() is
            @test()

            let b = build();
            Assert.are_equal(255UL, b.classifier.max_unsigned_for(b.lookup.get_ubyte_type()));
        si

        Calling__max_unsigned_for__on_int__returns_int_max() is
            @test()

            let b = build();
            Assert.are_equal(2147483647UL, b.classifier.max_unsigned_for(b.lookup.get_int_type()));
        si

        Calling__max_unsigned_for__on_unrecognised_type__returns_zero() is
            @test()

            // ulong / uword aren't in the map (ulong.try_parse already
            // caps them at 2^64-1), and the caller treats 0 as
            // "skip the narrower-bound check".
            let b = build();
            Assert.are_equal(0UL, b.classifier.max_unsigned_for(b.lookup.get_ulong_type()));
        si
    si
si
