namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Variable;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.LOCAL_VARIABLE;
    use Semantic.Types.INTERSECTION;
    use Semantic.Types.Type;

    // Tests for NARROWING_FLOW's call transfer and the assignment-receiver
    // shield. A field's presence fact is dropped on a call (a callee can
    // reassign it through an aliased receiver); a local's is not (a callee
    // cannot reach it); and a shielded receiver survives the call until
    // its frame is released.
    class NARROWING_FLOW_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        logger() -> Logging.Logger => Logging.DIAGNOSTICS_STORE();
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_field(owner: CLASS, name: string) -> INSTANCE_FIELD =>
            INSTANCE_FIELD(loc(), owner, name);

        make_local(owner: CLASS, name: string) -> LOCAL_VARIABLE =>
            LOCAL_VARIABLE(loc(), owner, name);

        @test()
        on_call_drops_field_presence() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let flow = NARROWING_FLOW(logger());

            flow.mark_non_null(f);
            Assert.is_true(flow.is_non_null(f));

            flow.on_call(loc());

            Assert.is_false(flow.is_non_null(f));
        si

        @test()
        on_call_keeps_local_presence() is
            let owner = make_owner();
            let x = make_local(owner, "x");
            let flow = NARROWING_FLOW(logger());

            flow.mark_non_null(x);

            flow.on_call(loc());

            Assert.is_true(flow.is_non_null(x));
        si

        @test()
        shielded_field_survives_call_then_is_forgotten() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let flow = NARROWING_FLOW(logger());

            flow.mark_non_null(f);

            let frame = flow.push_shield(f);

            flow.on_call(loc());

            Assert.is_true(flow.is_non_null(f));

            let hit = flow.release_shield(frame);

            Assert.is_true(hit);

            flow.forget(f);

            Assert.is_false(flow.is_non_null(f));
        si

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            return c.type;
        si

        make_subclass_type(name: string, base: Type) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            c.add_ancestor(base);
            return c.type;
        si

        // compose_path_narrow — the shared soundness gate consulted by
        // both `_apply_one` on symbols and the member-load site on
        // paths. Its accepting branches (subtype refine, sibling
        // INTERSECTION) are exercised by the integration fixtures;
        // these unit tests pin the reject / no-op branches so unsound
        // narrows stay out.

        compose_path_narrow_returns_target_when_target_strict_subtypes_loaded() is
            @test()

            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let flow = NARROWING_FLOW(logger());

            let composed = flow.compose_path_narrow(animal, cat);

            Assert.are_same(cat, composed);
        si

        compose_path_narrow_returns_null_when_target_supertypes_loaded() is
            @test()

            // Supertype broadening is never sound as a narrow — the
            // loaded value already satisfies the narrower type.
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let flow = NARROWING_FLOW(logger());

            Assert.is_null(flow.compose_path_narrow(cat, animal));
        si

        compose_path_narrow_returns_null_when_loaded_equals_effective_target() is
            @test()

            // No-op when the narrow adds nothing.
            let animal = make_class_type("Animal");
            let flow = NARROWING_FLOW(logger());

            Assert.is_null(flow.compose_path_narrow(animal, animal));
        si

        compose_path_narrow_returns_null_on_error_target() is
            @test()

            let animal = make_class_type("Animal");
            let flow = NARROWING_FLOW(logger());

            Assert.is_null(flow.compose_path_narrow(animal, Semantic.Types.ERROR()));
        si

        compose_path_narrow_returns_null_for_null_inputs() is
            @test()

            let animal = make_class_type("Animal");
            let flow = NARROWING_FLOW(logger());

            Assert.is_null(flow.compose_path_narrow(null, animal));
            Assert.is_null(flow.compose_path_narrow(animal, null));
            Assert.is_null(flow.compose_path_narrow(null, null));
        si

        compose_path_narrow_strips_optional_target_when_loaded_is_present() is
            @test()

            // If the loaded type is non-optional (path already known
            // present) and the target arrives optional, strip the
            // optional layer: the narrow is from a proven-present value
            // to a more specific type, never re-introducing optionality.
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let optional_cat = cat.as_optional();
            let flow = NARROWING_FLOW(logger());

            let composed = flow.compose_path_narrow(animal, optional_cat);

            Assert.is_true(composed?);
            Assert.is_false(composed.is_optional);
        si

        make_value_type(name: string) -> Type is
            let s = Semantic.Symbols.STRUCT(loc(), loc(), null, name, empty_names(), false, null);
            s.set_type(Semantic.Types.NAMED(s));
            return s.type;
        si

        compose_path_narrow_rejects_when_either_side_is_a_value_type() is
            @test()

            // The sibling / class+trait branch only fires when both
            // sides are reference types; a value-type mismatch is
            // rejected because value-type narrowing doesn't share
            // storage with a reference-type view.
            let animal = make_class_type("Animal");
            let a_struct = make_value_type("A");
            let b_struct = make_value_type("B");
            let flow = NARROWING_FLOW(logger());

            Assert.is_null(flow.compose_path_narrow(a_struct, animal));
            Assert.is_null(flow.compose_path_narrow(animal, a_struct));
            Assert.is_null(flow.compose_path_narrow(a_struct, b_struct));
        si
    si
si
