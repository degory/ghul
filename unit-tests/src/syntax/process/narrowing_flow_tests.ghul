namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Variable;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.LOCAL_VARIABLE;

    // Tests for NARROWING_FLOW's call transfer and the assignment-receiver
    // shield. A field's presence fact is dropped on a call (a callee can
    // reassign it through an aliased receiver); a local's is not (a callee
    // cannot reach it); and a shielded receiver survives the call until
    // its frame is released.
    class NARROWING_FLOW_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_field(owner: CLASS, name: string) -> INSTANCE_FIELD =>
            INSTANCE_FIELD(loc(), owner, name);

        make_local(owner: CLASS, name: string) -> LOCAL_VARIABLE =>
            LOCAL_VARIABLE(loc(), owner, name);

        @test()
        on_call_drops_field_presence() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let flow = NARROWING_FLOW();

            flow.mark_non_null(f);
            Assert.is_true(flow.is_non_null(f));

            flow.on_call();

            Assert.is_false(flow.is_non_null(f));
        si

        @test()
        on_call_keeps_local_presence() is
            let owner = make_owner();
            let x = make_local(owner, "x");
            let flow = NARROWING_FLOW();

            flow.mark_non_null(x);

            flow.on_call();

            Assert.is_true(flow.is_non_null(x));
        si

        @test()
        shielded_field_survives_call_then_is_forgotten() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let flow = NARROWING_FLOW();

            flow.mark_non_null(f);

            let frame = flow.push_shield(f);

            flow.on_call();

            Assert.is_true(flow.is_non_null(f));

            let hit = flow.release_shield(frame);

            Assert.is_true(hit);

            flow.forget(f);

            Assert.is_false(flow.is_non_null(f));
        si

        @test()
        release_shield_reports_no_hit_without_a_call() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let flow = NARROWING_FLOW();

            flow.mark_non_null(f);

            let frame = flow.push_shield(f);

            let hit = flow.release_shield(frame);

            Assert.is_false(hit);
            Assert.is_true(flow.is_non_null(f));
        si

        @test()
        nested_shields_each_protect_their_receiver() is
            let owner = make_owner();
            let outer = make_field(owner, "_a");
            let inner = make_field(owner, "_b");
            let flow = NARROWING_FLOW();

            flow.mark_non_null(outer);
            flow.mark_non_null(inner);

            let outer_frame = flow.push_shield(outer);
            let inner_frame = flow.push_shield(inner);

            flow.on_call();

            // A call inside the inner assignment leaves both receivers
            // present — the outer shield is not disturbed by the inner.
            Assert.is_true(flow.is_non_null(outer));
            Assert.is_true(flow.is_non_null(inner));

            Assert.is_true(flow.release_shield(inner_frame));
            Assert.is_true(flow.release_shield(outer_frame));
        si

        @test()
        push_shield_of_null_is_a_no_op() is
            let owner = make_owner();
            let f = make_field(owner, "_f");
            let flow = NARROWING_FLOW();

            flow.mark_non_null(f);

            let frame = flow.push_shield(null);

            flow.on_call();

            // No shield was pushed, so the field drops as usual.
            Assert.is_false(flow.is_non_null(f));
            Assert.is_false(flow.release_shield(frame));
        si
    si
si
