namespace Syntax.Process.UnitTests is
    use Collections.LIST;
    use Collections.MAP;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Variable;
    use Semantic.Types.Type;

    use Trees.Expressions.Expression;

    // Tests for CONDITION_ANALYZER.analyze_condition — focused on
    // the boolean combinator composition (/\, \/, !), which is the
    // new logic. ISA leaves are built directly; the narrowing-target
    // resolver is a per-test stub mapping the constructed `right`
    // expressions to constructed Variables. The is_<variant> MEMBER
    // leaf is exercised by integration tests, not here.
    class CONDITION_ANALYSIS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_var(owner: CLASS, name: string, t: Type) -> Variable is
            let v = Variable(loc(), owner, name);
            v.set_type(t);
            return v;
        si

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            return c.type;
        si

        make_subclass_type(name: string, base: Type) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            c.add_ancestor(base);
            return c.type;
        si

        id_expr(name: string) -> Trees.Expressions.IDENTIFIER =>
            Trees.Expressions.IDENTIFIER(loc(), Trees.Identifiers.Identifier(loc(), name));

        type_expr(t: Type) -> Trees.TypeExpressions.TypeExpression is
            let te = Trees.TypeExpressions.TypeExpression(loc());
            te.set_type(t);
            return te;
        si

        make_isa(right: Expression, t: Type) -> Trees.Expressions.ISA =>
            Trees.Expressions.ISA(loc(), type_expr(t), right);

        make_and(left: Expression, right: Expression) -> Trees.Expressions.BINARY =>
            Trees.Expressions.BINARY(loc(), Trees.Identifiers.Identifier(loc(), "/\\"), "/\\", left, right);

        make_or(left: Expression, right: Expression) -> Trees.Expressions.BINARY =>
            Trees.Expressions.BINARY(loc(), Trees.Identifiers.Identifier(loc(), "\\/"), "\\/", left, right);

        make_not(operand: Expression) -> Trees.Expressions.UNARY =>
            Trees.Expressions.UNARY(loc(), Trees.Identifiers.Identifier(loc(), "!"), operand);

        // A resolver backed by an explicit expression->variable map.
        make_analyzer(targets: MAP[Expression, Variable]) -> CONDITION_ANALYZER =>
            CONDITION_ANALYZER(
                (e: Expression) =>
                    let v: Variable in
                    if e? /\ targets.try_get_value(e, v ref) then v else null fi
            );

        analyze_null_condition_should_keep_incoming_on_both_edges() is
            @test()

            let analyzer = make_analyzer(MAP[Expression, Variable]());
            let facts = analyzer.analyze_condition(null, NARROW_ENV());

            Assert.is_true(facts.then_env.is_empty);
            Assert.is_true(facts.else_env.is_empty);
        si

        analyze_opaque_condition_should_keep_incoming_on_both_edges() is
            @test()

            // A bare identifier is not a narrowing predicate.
            let analyzer = make_analyzer(MAP[Expression, Variable]());
            let facts = analyzer.analyze_condition(id_expr("flag"), NARROW_ENV());

            Assert.is_true(facts.then_env.is_empty);
            Assert.is_true(facts.else_env.is_empty);
        si

        analyze_isa_should_narrow_then_edge_only() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let right = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            let facts = make_analyzer(targets).analyze_condition(make_isa(right, t), NARROW_ENV());

            Assert.are_same(t, facts.then_env.narrowed_type_of(v));
            Assert.is_false(facts.else_env.contains(v));
        si

        analyze_not_isa_should_narrow_else_edge_only() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let right = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            let facts = make_analyzer(targets).analyze_condition(make_not(make_isa(right, t)), NARROW_ENV());

            // `!` swaps the edges — the false edge carries the narrow.
            Assert.is_false(facts.then_env.contains(v));
            Assert.are_same(t, facts.else_env.narrowed_type_of(v));
        si

        analyze_and_should_narrow_both_targets_on_then_edge() is
            @test()

            let owner = make_owner();
            let tx = make_class_type("Tx");
            let ty = make_class_type("Ty");
            let x = make_var(owner, "x", tx);
            let y = make_var(owner, "y", ty);

            let rx = id_expr("x");
            let ry = id_expr("y");
            let targets = MAP[Expression, Variable]();
            targets[rx] = x;
            targets[ry] = y;

            let cond = make_and(make_isa(rx, tx), make_isa(ry, ty));
            let facts = make_analyzer(targets).analyze_condition(cond, NARROW_ENV());

            Assert.are_same(tx, facts.then_env.narrowed_type_of(x));
            Assert.are_same(ty, facts.then_env.narrowed_type_of(y));

            // The false edge of `a /\ b` cannot assume either leaf.
            Assert.is_false(facts.else_env.contains(x));
            Assert.is_false(facts.else_env.contains(y));
        si

        analyze_or_of_same_target_should_lub_on_then_edge() is
            @test()

            // `isa Cat(v) \/ isa Dog(v)` — the true edge knows `v` is
            // Cat-or-Dog, i.e. a common supertype.
            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let dog = make_subclass_type("Dog", animal);
            let v = make_var(owner, "v", animal);

            let rl = id_expr("v");
            let rr = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[rl] = v;
            targets[rr] = v;

            let cond = make_or(make_isa(rl, cat), make_isa(rr, dog));
            let facts = make_analyzer(targets).analyze_condition(cond, NARROW_ENV());

            let merged = facts.then_env.narrowed_type_of(v);
            Assert.is_true(merged?);
            Assert.is_true(merged.is_assignable_from(cat));
            Assert.is_true(merged.is_assignable_from(dog));
        si

        analyze_or_of_different_targets_should_narrow_neither_on_then_edge() is
            @test()

            // `isa T(x) \/ isa T(y)` — reaching the true edge means
            // one held, but not which, so neither narrows.
            let owner = make_owner();
            let t = make_class_type("T");
            let x = make_var(owner, "x", t);
            let y = make_var(owner, "y", t);

            let rx = id_expr("x");
            let ry = id_expr("y");
            let targets = MAP[Expression, Variable]();
            targets[rx] = x;
            targets[ry] = y;

            let cond = make_or(make_isa(rx, t), make_isa(ry, t));
            let facts = make_analyzer(targets).analyze_condition(cond, NARROW_ENV());

            Assert.is_false(facts.then_env.contains(x));
            Assert.is_false(facts.then_env.contains(y));
        si
    si
si
