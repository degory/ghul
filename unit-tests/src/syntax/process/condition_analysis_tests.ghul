namespace Syntax.Process.UnitTests is
    use Collections.LIST;
    use Collections.MAP;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Classy;
    use Semantic.Symbols.UNION;
    use Semantic.Symbols.VARIANT;
    use Semantic.Symbols.Variable;
    use Semantic.Types.GENERIC;
    use Semantic.Types.INTERSECTION;
    use Semantic.Types.NAMED;
    use Semantic.Types.ONE_OF;
    use Semantic.Types.Type;

    use Trees.Expressions.Expression;

    // Tests for CONDITION_ANALYZER.analyze_condition — focused on
    // the boolean combinator composition (/\, \/, !) and the
    // variant-aware ISA receiver shapes (wide union, ONE_OF, an
    // already-narrowed singleton variant, an INTERSECTION carrying
    // one). ISA leaves are built directly; the narrowing-target
    // resolver is a per-test stub mapping the constructed `right`
    // expressions to constructed Variables. Receiver-type-aware
    // tests attach an IR.DUMMY value to the right-operand so the
    // analyzer can read its type.
    class CONDITION_ANALYSIS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();

        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);

        make_var(owner: CLASS, name: string, t: Type) -> Variable is
            let v = Semantic.Symbols.LOCAL_VARIABLE(loc(), owner, name);
            v.set_type(t);
            return v;
        si

        make_class_type(name: string) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            return c.type!;
        si

        make_subclass_type(name: string, base: Type) -> Type is
            let c = CLASS(loc(), loc(), null, name, empty_names(), false, null);
            c.set_type(Semantic.Types.NAMED(c));
            c.add_ancestor(base);
            return c.type!;
        si

        id_expr(name: string) -> Trees.Expressions.IDENTIFIER =>
            Trees.Expressions.IDENTIFIER(loc(), Trees.Identifiers.Identifier(loc(), name));

        type_expr(t: Type) -> Trees.TypeExpressions.TypeExpression is
            let te = Trees.TypeExpressions.INFER(loc());
            te.type = t;
            return te;
        si

        make_isa(right: Expression, t: Type) -> Trees.Expressions.ISA =>
            Trees.Expressions.ISA(loc(), type_expr(t), right);

        make_and(left: Expression, right: Expression) -> Trees.Expressions.BINARY =>
            Trees.Expressions.BINARY(loc(), Trees.Identifiers.Identifier(loc(), "/\\"), "/\\", left, right);

        make_or(left: Expression, right: Expression) -> Trees.Expressions.BINARY =>
            Trees.Expressions.BINARY(loc(), Trees.Identifiers.Identifier(loc(), "\\/"), "\\/", left, right);

        make_not(operand: Expression) -> Trees.Expressions.UNARY =>
            Trees.Expressions.UNARY(loc(), Trees.Identifiers.Identifier(loc(), "!"), operand);

        make_has_value(operand: Expression) -> Trees.Expressions.HAS_VALUE =>
            Trees.Expressions.HAS_VALUE(loc(), operand);

        // A resolver backed by an explicit expression->variable map;
        // no expression resolves to an access path.
        make_analyzer(targets: MAP[Expression, Variable]) -> CONDITION_ANALYZER =>
            make_path_analyzer(targets, MAP[Expression, ACCESS_PATH]());

        // As make_analyzer, with an explicit expression->path map for
        // the path-presence leaves.
        make_path_analyzer(targets: MAP[Expression, Variable], paths: MAP[Expression, ACCESS_PATH]) -> CONDITION_ANALYZER =>
            CONDITION_ANALYZER(
                (e: Expression) =>
                    let v: Variable in
                    if e? /\ targets.try_get_value(e, v ref) then v else null fi,
                (e: Expression) =>
                    let p: ACCESS_PATH in
                    if e? /\ paths.try_get_value(e, p ref) then p else null fi
            );

        analyze_null_condition_should_keep_incoming_on_both_edges() is
            @test()

            let analyzer = make_analyzer(MAP[Expression, Variable]());
            let facts = analyzer.analyze_condition(null, NARROW_ENV());

            Assert.is_true(facts.then_env.is_empty);
            Assert.is_true(facts.else_env.is_empty);
        si

        analyze_opaque_condition_should_keep_incoming_on_both_edges() is
            @test()

            // A bare identifier is not a narrowing predicate.
            let analyzer = make_analyzer(MAP[Expression, Variable]());
            let facts = analyzer.analyze_condition(id_expr("flag"), NARROW_ENV());

            Assert.is_true(facts.then_env.is_empty);
            Assert.is_true(facts.else_env.is_empty);
        si

        analyze_isa_should_narrow_then_edge_only() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let right = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            let facts = make_analyzer(targets).analyze_condition(make_isa(right, t), NARROW_ENV());

            Assert.are_same(t, facts.then_env.narrowed_type_of(v));
            Assert.is_false(facts.else_env.contains(v));
        si

        analyze_not_isa_should_narrow_else_edge_only() is
            @test()

            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t);

            let right = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            let facts = make_analyzer(targets).analyze_condition(make_not(make_isa(right, t)), NARROW_ENV());

            // `!` swaps the edges — the false edge carries the narrow.
            Assert.is_false(facts.then_env.contains(v));
            Assert.are_same(t, facts.else_env.narrowed_type_of(v));
        si

        analyze_and_should_narrow_both_targets_on_then_edge() is
            @test()

            let owner = make_owner();
            let tx = make_class_type("Tx");
            let ty = make_class_type("Ty");
            let x = make_var(owner, "x", tx);
            let y = make_var(owner, "y", ty);

            let rx = id_expr("x");
            let ry = id_expr("y");
            let targets = MAP[Expression, Variable]();
            targets[rx] = x;
            targets[ry] = y;

            let cond = make_and(make_isa(rx, tx), make_isa(ry, ty));
            let facts = make_analyzer(targets).analyze_condition(cond, NARROW_ENV());

            Assert.are_same(tx, facts.then_env.narrowed_type_of(x));
            Assert.are_same(ty, facts.then_env.narrowed_type_of(y));

            // The false edge of `a /\ b` cannot assume either leaf.
            Assert.is_false(facts.else_env.contains(x));
            Assert.is_false(facts.else_env.contains(y));
        si

        analyze_or_of_same_target_should_lub_on_then_edge() is
            @test()

            // `isa Cat(v) \/ isa Dog(v)` — the true edge knows `v` is
            // Cat-or-Dog, i.e. a common supertype.
            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let dog = make_subclass_type("Dog", animal);
            let v = make_var(owner, "v", animal);

            let rl = id_expr("v");
            let rr = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[rl] = v;
            targets[rr] = v;

            let cond = make_or(make_isa(rl, cat), make_isa(rr, dog));
            let facts = make_analyzer(targets).analyze_condition(cond, NARROW_ENV());

            let merged = facts.then_env.narrowed_type_of(v);
            Assert.is_true(merged?);
            Assert.is_true(merged.is_assignable_from(cat));
            Assert.is_true(merged.is_assignable_from(dog));
        si

        analyze_or_of_different_targets_should_narrow_neither_on_then_edge() is
            @test()

            // `isa T(x) \/ isa T(y)` — reaching the true edge means
            // one held, but not which, so neither narrows.
            let owner = make_owner();
            let t = make_class_type("T");
            let x = make_var(owner, "x", t);
            let y = make_var(owner, "y", t);

            let rx = id_expr("x");
            let ry = id_expr("y");
            let targets = MAP[Expression, Variable]();
            targets[rx] = x;
            targets[ry] = y;

            let cond = make_or(make_isa(rx, t), make_isa(ry, t));
            let facts = make_analyzer(targets).analyze_condition(cond, NARROW_ENV());

            Assert.is_false(facts.then_env.contains(x));
            Assert.is_false(facts.then_env.contains(y));
        si

        analyze_has_value_should_mark_non_null_on_then_edge() is
            @test()

            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T").as_optional());

            let operand = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[operand] = v;

            let facts = make_analyzer(targets).analyze_condition(make_has_value(operand), NARROW_ENV());

            Assert.is_true(facts.then_env.is_non_null(v));
            Assert.is_false(facts.else_env.is_non_null(v));
        si

        analyze_not_has_value_should_mark_non_null_on_else_edge() is
            @test()

            // `!x?` — the false edge (x holds a value) carries the fact.
            let owner = make_owner();
            let v = make_var(owner, "v", make_class_type("T").as_optional());

            let operand = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[operand] = v;

            let facts = make_analyzer(targets).analyze_condition(make_not(make_has_value(operand)), NARROW_ENV());

            Assert.is_false(facts.then_env.is_non_null(v));
            Assert.is_true(facts.else_env.is_non_null(v));
        si

        analyze_isa_should_mark_target_non_null_on_then_edge() is
            @test()

            // `isa T(x)` is true only for a non-null `x`.
            let owner = make_owner();
            let t = make_class_type("T");
            let v = make_var(owner, "v", t.as_optional());

            let right = id_expr("v");
            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            let facts = make_analyzer(targets).analyze_condition(make_isa(right, t), NARROW_ENV());

            Assert.is_true(facts.then_env.is_non_null(v));
            Assert.is_false(facts.else_env.is_non_null(v));
        si

        analyze_and_of_has_value_should_mark_both_non_null_on_then_edge() is
            @test()

            let owner = make_owner();
            let x = make_var(owner, "x", make_class_type("Tx").as_optional());
            let y = make_var(owner, "y", make_class_type("Ty").as_optional());

            let rx = id_expr("x");
            let ry = id_expr("y");
            let targets = MAP[Expression, Variable]();
            targets[rx] = x;
            targets[ry] = y;

            let cond = make_and(make_has_value(rx), make_has_value(ry));
            let facts = make_analyzer(targets).analyze_condition(cond, NARROW_ENV());

            Assert.is_true(facts.then_env.is_non_null(x));
            Assert.is_true(facts.then_env.is_non_null(y));
            Assert.is_false(facts.else_env.is_non_null(x));
            Assert.is_false(facts.else_env.is_non_null(y));
        si

        // ---- Variant-receiver shapes for ISA narrowing ---------------

        // Build {object, U, A, B, C} mirroring how `declare_variant`
        // wires variants under a union scope. The variants are
        // declared through `the_union.declare_variant` so they show
        // up in `the_union.symbols` — `try_get_variant_type_for_classy`
        // walks that list to confirm membership.
        build_three_variant_union() -> (the_union: UNION, a: VARIANT, b: VARIANT, c: VARIANT) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let the_union = UNION(loc(), loc(), null, "U", empty_names(), false, null);
            the_union.add_ancestor(object_class.type!);

            let a = cast VARIANT(the_union.declare_variant(loc(), loc(), "A", false, null, null));
            let b = cast VARIANT(the_union.declare_variant(loc(), loc(), "B", false, null, null));
            let c = cast VARIANT(the_union.declare_variant(loc(), loc(), "C", false, null, null));

            return (the_union, a, b, c);
        si

        // As build_three_variant_union but the union carries one type
        // parameter; declare_variant propagates the parameter names to each
        // variant, so a GENERIC receiver over the union specialises them.
        build_generic_variant_union() -> (the_union: UNION, a: VARIANT, b: VARIANT, c: VARIANT) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let names = LIST[string]();
            names.add("T");

            let the_union = UNION(loc(), loc(), null, "U", names, false, null);
            the_union.add_ancestor(object_class.type!);

            let a = cast VARIANT(the_union.declare_variant(loc(), loc(), "A", false, null, null));
            let b = cast VARIANT(the_union.declare_variant(loc(), loc(), "B", false, null, null));
            let c = cast VARIANT(the_union.declare_variant(loc(), loc(), "C", false, null, null));

            return (the_union, a, b, c);
        si

        // An IDENTIFIER carrying a value whose type is `t`. Used to
        // exercise the receiver-aware branches of `_analyze_isa`,
        // which read the receiver type off `isa.right.value.type`.
        typed_id(name: string, t: Type) -> Trees.Expressions.IDENTIFIER is
            let id = id_expr(name);
            id.compile_expressions_state.value = IR.Values.DUMMY(t, loc());
            return id;
        si

        // get_classy_for_narrowing peels an INTERSECTION to the
        // first member with a Classy symbol. The INTERSECTION is
        // constructed via its raw `init` rather than the dedup-aware
        // `INTERSECTION.create` factory so the multi-member shape
        // survives — that is the shape the narrowing pipeline hands
        // in when a singleton-variant narrow stacks on an existing
        // ONE_OF narrow without dropping it.
        get_classy_for_narrowing_should_peel_intersection() is
            @test()

            let h = build_three_variant_union();
            let analyzer = make_analyzer(MAP[Expression, Variable]());

            let one_of = ONE_OF(cast NAMED(h.the_union.type!), list_of(h.a, h.b));
            let pair = INTERSECTION(types_of(cast NAMED(h.a.type!), one_of));

            let classy = analyzer.get_classy_for_narrowing(pair);

            Assert.is_not_null(classy);
            Assert.are_same(h.a, classy);
        si

        // pick_underlying_type peels an INTERSECTION to the first
        // NAMED member whose Classy is a union or variant.
        pick_underlying_type_should_peel_intersection() is
            @test()

            let h = build_three_variant_union();
            let analyzer = make_analyzer(MAP[Expression, Variable]());

            let one_of = ONE_OF(cast NAMED(h.the_union.type!), list_of(h.a, h.b));
            let pair = INTERSECTION(types_of(cast NAMED(h.a.type!), one_of));

            let underlying = analyzer.pick_underlying_type(pair);

            Assert.is_not_null(underlying);
        si

        // try_get_variant_type_for_classy resolves the parent union
        // via the receiver-variant's `owner`, then specialises the
        // target variant carrying the receiver's generic args.
        try_get_variant_type_for_classy_should_walk_variant_owner() is
            @test()

            let h = build_three_variant_union();
            let analyzer = make_analyzer(MAP[Expression, Variable]());

            // Receiver is the already-narrowed A variant; ask for B.
            let result = analyzer.try_get_variant_type_for_classy(h.a.type!, h.b);

            Assert.is_not_null(result);
            Assert.is_true(isa NAMED(result));
            Assert.are_same(h.b, (cast NAMED(result)).symbol);
        si

        // try_get_variant_type_for_classy returns null when the target
        // variant is not a member of the receiver's union.
        try_get_variant_type_for_classy_should_reject_foreign_variant() is
            @test()

            let h = build_three_variant_union();
            let other = build_three_variant_union();
            let analyzer = make_analyzer(MAP[Expression, Variable]());

            // Receiver A of union U; ask for A' of the *other* union.
            let result = analyzer.try_get_variant_type_for_classy(h.a.type!, other.a);

            Assert.is_null(result);
        si

        // specialize_variant_for_receiver lifts a bare variant narrow to
        // the closed-generic form carrying the receiver's type arguments.
        // This is what lets a `self`-narrow on a generic union
        // (`isa CONS(self)` for `self: List[T]`) resolve to a
        // CLR-loadable `CONS[T]` rather than the unloadable open variant.
        specialize_variant_for_receiver_should_specialize_bare_variant_to_closed_generic() is
            @test()

            let h = build_generic_variant_union();
            let analyzer = make_analyzer(MAP[Expression, Variable]());

            let arg = make_class_type("X");
            let receiver = GENERIC(loc(), h.the_union, LIST[Type]([arg]));

            // A bare (unspecialised) variant narrow, as an isa/if-let leaf produces.
            let result = analyzer.specialize_variant_for_receiver(receiver, NAMED(h.a));

            Assert.is_not_null(result);
            Assert.is_true(isa GENERIC(result));

            let specialized = cast GENERIC(result);
            Assert.are_same(h.a, analyzer.get_classy_for_narrowing(specialized));
            Assert.are_equal(1, specialized.arguments.count);
            Assert.are_same(arg, specialized.arguments[0]);
        si

        // A non-variant target is returned unchanged — the fallthrough
        // that leaves `self` at its declared type when no variant narrow
        // is in force.
        specialize_variant_for_receiver_should_return_non_variant_target_unchanged() is
            @test()

            let h = build_three_variant_union();
            let analyzer = make_analyzer(MAP[Expression, Variable]());

            let target = make_class_type("Plain");
            let result = analyzer.specialize_variant_for_receiver(h.the_union.type!, target);

            Assert.are_same(target, result);
        si

        // Within the receiver's ONE_OF the narrow is specialized to
        // the matched variant — the receiver-aware path in
        // `try_get_variant_type_for_classy`.
        analyze_isa_should_narrow_on_variant_inside_one_of() is
            @test()

            let h = build_three_variant_union();
            let v = make_var(make_owner(), "v", h.the_union.type!);

            let one_of = ONE_OF(cast NAMED(h.the_union.type!), list_of(h.b, h.c));
            let right = typed_id("v", one_of);

            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            // `isa U.B(v)` — B is in {B, C}.
            let facts = make_analyzer(targets).analyze_condition(make_isa(right, h.b.type!), NARROW_ENV());

            let narrowed = facts.then_env.narrowed_type_of(v);
            Assert.is_not_null(narrowed);
            Assert.is_true(isa NAMED(narrowed));
            Assert.are_same(h.b, (cast NAMED(narrowed)).symbol);
        si

        // `v?` on a union with a default variant narrows like
        // `isa Default(v)`: the then-edge to the default variant, the
        // else-edge to the complement of the remaining variants.
        analyze_has_value_should_narrow_default_variant_union_both_edges() is
            @test()

            let h = build_three_variant_union();
            h.the_union.default_variant = h.a;

            let v = make_var(make_owner(), "v", h.the_union.type!);
            let operand = typed_id("v", h.the_union.type!);

            let targets = MAP[Expression, Variable]();
            targets[operand] = v;

            let facts = make_analyzer(targets).analyze_condition(make_has_value(operand), NARROW_ENV());

            let then_narrow = facts.then_env.narrowed_type_of(v);
            Assert.is_not_null(then_narrow);
            Assert.is_true(isa NAMED(then_narrow));
            Assert.are_same(h.a, (cast NAMED(then_narrow)).symbol);

            let else_narrow = facts.else_env.narrowed_type_of(v);
            Assert.is_not_null(else_narrow);
            Assert.is_true(isa ONE_OF(else_narrow));

            let remaining = cast ONE_OF(else_narrow);
            Assert.is_true(remaining.contains_subtype(h.b));
            Assert.is_true(remaining.contains_subtype(h.c));
            Assert.is_false(remaining.contains_subtype(h.a));
        si

        // A statically-false `v?` — the receiver's ONE_OF excludes the
        // default variant — applies no type narrow on either edge.
        analyze_has_value_should_not_narrow_when_default_variant_out_of_set() is
            @test()

            let h = build_three_variant_union();
            h.the_union.default_variant = h.a;

            let v = make_var(make_owner(), "v", h.the_union.type!);
            let one_of = ONE_OF(cast NAMED(h.the_union.type!), list_of(h.b, h.c));
            let operand = typed_id("v", one_of);

            let targets = MAP[Expression, Variable]();
            targets[operand] = v;

            let facts = make_analyzer(targets).analyze_condition(make_has_value(operand), NARROW_ENV());

            Assert.is_null(facts.then_env.narrowed_type_of(v));
            Assert.is_null(facts.else_env.narrowed_type_of(v));
        si

        // Receiver is a singleton variant; targeting a sibling
        // variant of the same union also returns a specialised
        // NAMED. Pins the helper's IL-specialisation contract —
        // even when the test is statically false at runtime, the
        // returned type must reference the variant with the
        // receiver's generic args, never a bare open-generic one.
        try_get_variant_type_for_classy_should_specialize_even_for_out_of_set_variant() is
            @test()

            let h = build_three_variant_union();
            let analyzer = make_analyzer(MAP[Expression, Variable]());

            // Receiver narrowed to ONE_OF{B, C}; ask for A — outside
            // the set but still a member of the parent union.
            let one_of = ONE_OF(cast NAMED(h.the_union.type!), list_of(h.b, h.c));
            let result = analyzer.try_get_variant_type_for_classy(one_of, h.a);

            Assert.is_not_null(result);
            Assert.is_true(isa NAMED(result));
            Assert.are_same(h.a, (cast NAMED(result)).symbol);
        si

        list_of(a: Classy, b: Classy) -> LIST[Classy] is
            let l = LIST[Classy]();
            l.add(a);
            l.add(b);
            return l;
        si

        types_of(a: Type, b: Type) -> LIST[Type] is
            let l = LIST[Type]();
            l.add(a);
            l.add(b);
            return l;
        si

        // Build a single-clause REFUTABLE_BINDING carrying a
        // narrow-type expression and a typed scrutinee identifier.
        // Pattern is a placeholder SIMPLE_VARIABLE_LEFT — the
        // else-narrow doesn't read it.
        make_refutable_binding(
            scrutinee: Expression,
            narrow_type: Type
        ) -> Trees.Statements.REFUTABLE_BINDING =>
            make_refutable_binding(scrutinee, type_expr(narrow_type), null);

        make_refutable_binding(
            scrutinee: Expression,
            narrow_type_expression: Trees.TypeExpressions.TypeExpression?,
            guard: Expression?
        ) -> Trees.Statements.REFUTABLE_BINDING is
            let pattern =
                Trees.Variables.SIMPLE_VARIABLE_LEFT(
                    loc(),
                    Trees.Identifiers.Identifier(loc(), "p")
                );

            let clauses = Collections.LIST[Trees.Statements.REFUTABLE_BINDING_CLAUSE]();

            clauses.add(
                Trees.Statements.REFUTABLE_BINDING_CLAUSE(
                    loc(),
                    scrutinee,
                    narrow_type_expression,
                    pattern,
                    guard
                )
            );

            return Trees.Statements.REFUTABLE_BINDING(loc(), clauses);
        si

        // apply_refutable_binding_then_narrow on a variant target
        // against a wide-union receiver: the then edge gets the
        // variant-narrow on the scrutinee and the non-null flag.
        apply_refutable_binding_then_narrow_should_narrow_scrutinee_to_variant() is
            @test()

            let h = build_three_variant_union();
            // The scrutinee is declared at the optional-union type
            // so the then-edge presence fact records — a non-optional
            // v would already be known to hold a value and the
            // presence set-add is filtered.
            let v = make_var(make_owner(), "v", h.the_union.type!.as_optional());

            let scrutinee = typed_id("v", h.the_union.type!.as_optional());
            let targets = MAP[Expression, Variable]();
            targets[scrutinee] = v;

            let analyzer = make_analyzer(targets);
            let then_env = analyzer.apply_refutable_binding_then_narrow(scrutinee, h.a.type!, NARROW_ENV());

            Assert.is_true(then_env.is_non_null(v));

            let narrowed = then_env.narrowed_type_of(v);
            Assert.is_not_null(narrowed);
            Assert.is_true(isa NAMED(narrowed));
            Assert.are_same(h.a, (cast NAMED(narrowed)).symbol);
        si

        // The else-edge complement narrowing on a two-variant union:
        // narrowing to A leaves the else edge typed as the sole sibling
        // variant (B), so member access on the scrutinee in the else
        // arm can resolve against B's members.
        apply_refutable_binding_else_narrow_should_narrow_to_complement_singleton() is
            @test()

            let h = build_three_variant_union();
            let v = make_var(make_owner(), "v", h.the_union.type!);

            // Receiver narrowed to {A, B}; eliminating A leaves B as
            // the singleton complement.
            let two_variant = ONE_OF(cast NAMED(h.the_union.type!), list_of(h.a, h.b));
            let scrutinee = typed_id("v", two_variant);
            let targets = MAP[Expression, Variable]();
            targets[scrutinee] = v;

            let analyzer = make_analyzer(targets);
            let rb = make_refutable_binding(scrutinee, h.a.type!);
            let else_env = analyzer.apply_refutable_binding_else_narrow(rb, two_variant, NARROW_ENV());

            let narrowed = else_env.narrowed_type_of(v);
            Assert.is_not_null(narrowed);
            Assert.is_true(isa NAMED(narrowed));
            Assert.are_same(h.b, (cast NAMED(narrowed)).symbol);
        si

        // Else-narrow against a three-variant union: eliminating A
        // leaves ONE_OF{B, C} on the else edge.
        apply_refutable_binding_else_narrow_should_narrow_to_remaining_one_of() is
            @test()

            let h = build_three_variant_union();
            let v = make_var(make_owner(), "v", h.the_union.type!);

            let scrutinee = typed_id("v", h.the_union.type!);
            let targets = MAP[Expression, Variable]();
            targets[scrutinee] = v;

            let analyzer = make_analyzer(targets);
            let rb = make_refutable_binding(scrutinee, h.a.type!);
            let else_env = analyzer.apply_refutable_binding_else_narrow(rb, h.the_union.type!, NARROW_ENV());

            let narrowed = else_env.narrowed_type_of(v);
            Assert.is_not_null(narrowed);
            Assert.is_true(isa ONE_OF(narrowed));

            let remaining = cast ONE_OF(narrowed);
            Assert.is_true(remaining.contains_subtype(h.b));
            Assert.is_true(remaining.contains_subtype(h.c));
            Assert.is_false(remaining.contains_subtype(h.a));
        si

        // No narrow target → no flow change. Mirrors the bare
        // `if let c = e` form (no `: V` ascription).
        apply_refutable_binding_else_narrow_should_pass_through_without_narrow_type() is
            @test()

            let h = build_three_variant_union();
            let v = make_var(make_owner(), "v", h.the_union.type!);

            let scrutinee = typed_id("v", h.the_union.type!);
            let targets = MAP[Expression, Variable]();
            targets[scrutinee] = v;

            let rb = make_refutable_binding(scrutinee, null, null);

            let analyzer = make_analyzer(targets);
            let else_env = analyzer.apply_refutable_binding_else_narrow(rb, h.the_union.type!, NARROW_ENV());

            Assert.is_false(else_env.contains(v));
        si

        // Guarded if-let: the else arm is reached on two paths —
        // the type test rejected the scrutinee, OR the test
        // succeeded and the guard was false. On the second path the
        // scrutinee genuinely IS the narrow target, so narrowing
        // to the complement would be unsound. Mirrors the `/\` else-
        // join in `_analyze_isa` composition.
        apply_refutable_binding_else_narrow_should_pass_through_for_guarded_binding() is
            @test()

            let h = build_three_variant_union();
            let v = make_var(make_owner(), "v", h.the_union.type!);

            let scrutinee = typed_id("v", h.the_union.type!);
            let targets = MAP[Expression, Variable]();
            targets[scrutinee] = v;

            // The guard expression is just a stand-in — only its
            // presence matters for the else-narrow gate.
            let guard = id_expr("some_guard");

            let rb = make_refutable_binding(scrutinee, type_expr(h.a.type!), guard);

            let analyzer = make_analyzer(targets);
            let else_env = analyzer.apply_refutable_binding_else_narrow(rb, h.the_union.type!, NARROW_ENV());

            Assert.is_false(else_env.contains(v));
        si

        // Multi-clause if-let: the else edge can be reached because
        // a later clause's test failed, in which case the first
        // clause's scrutinee genuinely IS its narrow target — so
        // complement narrowing on it would be unsound. Same
        // reasoning as the guarded single-clause case above.
        apply_refutable_binding_else_narrow_should_pass_through_for_multi_clause_binding() is
            @test()

            let h = build_three_variant_union();
            let v = make_var(make_owner(), "v", h.the_union.type!);

            let scrutinee = typed_id("v", h.the_union.type!);
            let targets = MAP[Expression, Variable]();
            targets[scrutinee] = v;

            // Build a two-clause binding by hand; the second
            // clause's contents are placeholders — the gate only
            // cares about clauses.count.
            let pattern_a =
                Trees.Variables.SIMPLE_VARIABLE_LEFT(
                    loc(),
                    Trees.Identifiers.Identifier(loc(), "p")
                );
            let pattern_b =
                Trees.Variables.SIMPLE_VARIABLE_LEFT(
                    loc(),
                    Trees.Identifiers.Identifier(loc(), "q")
                );
            let second_scrutinee = id_expr("other");

            let clauses = Collections.LIST[Trees.Statements.REFUTABLE_BINDING_CLAUSE]();
            clauses.add(
                Trees.Statements.REFUTABLE_BINDING_CLAUSE(
                    loc(),
                    scrutinee,
                    type_expr(h.a.type!),
                    pattern_a,
                    null
                )
            );
            clauses.add(
                Trees.Statements.REFUTABLE_BINDING_CLAUSE(
                    loc(),
                    second_scrutinee,
                    null,
                    pattern_b,
                    null
                )
            );

            let rb = Trees.Statements.REFUTABLE_BINDING(loc(), clauses);

            let analyzer = make_analyzer(targets);
            let else_env = analyzer.apply_refutable_binding_else_narrow(rb, h.the_union.type!, NARROW_ENV());

            Assert.is_false(else_env.contains(v));
        si

        // Scrutinee that doesn't resolve to a Variable (member access,
        // call result, etc.) — no narrow target, no flow change.
        apply_refutable_binding_then_narrow_should_pass_through_for_non_identifier_scrutinee() is
            @test()

            let h = build_three_variant_union();

            // Scrutinee is a fresh identifier with no entry in the
            // resolver map — stands in for any non-resolvable
            // expression.
            let scrutinee = id_expr("untracked");

            let analyzer = make_analyzer(MAP[Expression, Variable]());
            let then_env = analyzer.apply_refutable_binding_then_narrow(scrutinee, h.a.type!, NARROW_ENV());

            Assert.is_true(then_env.is_empty);
        si

        // Closed-class fixture: an abstract `Animal` with two ghūl-
        // declared subclasses `Cat` and `Dog`. The subclasses register
        // themselves on the root via `add_implementor` (mirroring what
        // the resolve-ancestors pass does for real source). Returned
        // as a named tuple so callers spell the three CLASSes by name
        // rather than positionally.
        build_closed_class_fixture(abstract_root: bool) -> (animal: CLASS, cat: CLASS, dog: CLASS) is
            let animal = CLASS(loc(), loc(), null, "Animal", empty_names(), false, null);
            animal.set_type(Semantic.Types.NAMED(animal));
            if abstract_root then
                animal.mark_abstract();
            fi

            let cat = CLASS(loc(), loc(), null, "Cat", empty_names(), false, null);
            cat.set_type(Semantic.Types.NAMED(cat));
            cat.add_ancestor(animal.type!);
            animal.add_implementor(cat);

            let dog = CLASS(loc(), loc(), null, "Dog", empty_names(), false, null);
            dog.set_type(Semantic.Types.NAMED(dog));
            dog.add_ancestor(animal.type!);
            animal.add_implementor(dog);

            return (animal, cat, dog);
        si

        // Two-subclass abstract root: `isa Cat(a)` narrows the then
        // edge to `Cat` and collapses the else edge to the singleton
        // `Dog`. With the root excluded from the in-set (because it
        // is abstract), the complement is a plain `NAMED(Dog)` rather
        // than a `ONE_OF`.
        analyze_isa_closed_abstract_class_should_narrow_else_to_singleton_sibling() is
            @test()

            let owner = make_owner();
            let h = build_closed_class_fixture(true);

            let v = make_var(owner, "a", h.animal.type!);
            let right = id_expr("a");
            right.compile_expressions_state.value = IR.Values.DUMMY(h.animal.type!, loc());
            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            let facts = make_analyzer(targets).analyze_condition(make_isa(right, h.cat.type!), NARROW_ENV());

            let then_narrow = facts.then_env.narrowed_type_of(v);
            Assert.is_true(then_narrow?);
            Assert.are_same(h.cat, then_narrow.symbol);

            let else_narrow = facts.else_env.narrowed_type_of(v);
            Assert.is_true(else_narrow?);
            Assert.are_same(h.dog, else_narrow.symbol);
            Assert.is_false(isa ONE_OF(else_narrow));
        si

        // Same fixture, concrete root: the in-set includes `Animal`
        // itself (a caller can construct one), so the else complement
        // is the `ONE_OF{Animal, Dog}` — not a singleton, and a call
        // to a `Dog`-only method in the else arm would not resolve.
        analyze_isa_closed_concrete_class_should_include_root_in_else_complement() is
            @test()

            let owner = make_owner();
            let h = build_closed_class_fixture(false);

            let v = make_var(owner, "a", h.animal.type!);
            let right = id_expr("a");
            right.compile_expressions_state.value = IR.Values.DUMMY(h.animal.type!, loc());
            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            let facts = make_analyzer(targets).analyze_condition(make_isa(right, h.cat.type!), NARROW_ENV());

            let then_narrow = facts.then_env.narrowed_type_of(v);
            Assert.is_true(then_narrow?);
            Assert.are_same(h.cat, then_narrow.symbol);

            let else_narrow = facts.else_env.narrowed_type_of(v);
            Assert.is_true(else_narrow?);
            Assert.is_true(isa ONE_OF(else_narrow));

            let one_of = cast ONE_OF(else_narrow);
            Assert.is_true(one_of.contains_subtype(h.animal));
            Assert.is_true(one_of.contains_subtype(h.dog));
            Assert.is_false(one_of.contains_subtype(h.cat));
        si

        // Open root: the closed-narrowing path does not fire. The
        // then edge still narrows to `Cat` (the type-test fact) but
        // the else edge has no narrow — an open root can be extended
        // from another assembly so its subclass set is not
        // enumerable.
        analyze_isa_open_class_should_not_narrow_else_edge() is
            @test()

            let owner = make_owner();
            let h = build_closed_class_fixture(true);
            h.animal.mark_open();

            let v = make_var(owner, "a", h.animal.type!);
            let right = id_expr("a");
            right.compile_expressions_state.value = IR.Values.DUMMY(h.animal.type!, loc());
            let targets = MAP[Expression, Variable]();
            targets[right] = v;

            let facts = make_analyzer(targets).analyze_condition(make_isa(right, h.cat.type!), NARROW_ENV());

            let then_narrow = facts.then_env.narrowed_type_of(v);
            Assert.is_true(then_narrow?);
            Assert.are_same(h.cat, then_narrow.symbol);

            Assert.is_false(facts.else_env.contains(v));
        si

        make_path(root_name: string, member_name: string) -> ACCESS_PATH is
            let owner = make_owner();
            let root = Semantic.Symbols.LOCAL_VARIABLE(loc(), owner, root_name);
            let member = Semantic.Symbols.INSTANCE_FIELD(loc(), owner, member_name);
            let hops = LIST[Semantic.Symbols.Symbol]();
            hops.add(member);
            return ACCESS_PATH(root, hops);
        si

        // The path resolver only fires when the target resolver has
        // no answer — a symbol fact carries strictly more than a path
        // fact on the same expression would.
        analyze_has_value_on_path_should_mark_path_non_null_on_then_edge() is
            @test()

            let operand = id_expr("holder_prop");
            let p = make_path("holder", "prop");
            let paths = MAP[Expression, ACCESS_PATH]();
            paths[operand] = p;

            let facts = make_path_analyzer(MAP[Expression, Variable](), paths).analyze_condition(make_has_value(operand), NARROW_ENV());

            Assert.is_true(facts.then_env.is_non_null_path(p));
            Assert.is_false(facts.else_env.is_non_null_path(p));
        si

        analyze_not_has_value_on_path_should_mark_path_non_null_on_else_edge() is
            @test()

            let operand = id_expr("holder_prop");
            let p = make_path("holder", "prop");
            let paths = MAP[Expression, ACCESS_PATH]();
            paths[operand] = p;

            let facts = make_path_analyzer(MAP[Expression, Variable](), paths).analyze_condition(make_not(make_has_value(operand)), NARROW_ENV());

            Assert.is_false(facts.then_env.is_non_null_path(p));
            Assert.is_true(facts.else_env.is_non_null_path(p));
        si

        // `isa T(x.y)` — the isa target resolver returns null for a
        // member access, so the analyzer falls through to the path
        // resolver and records a type narrow on the path.
        analyze_isa_on_path_should_narrow_then_edge() is
            @test()

            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);

            let right = id_expr("holder_animal");
            let p = make_path("holder", "animal");
            let paths = MAP[Expression, ACCESS_PATH]();
            paths[right] = p;

            let facts = make_path_analyzer(MAP[Expression, Variable](), paths)
                .analyze_condition(make_isa(right, cat), NARROW_ENV());

            Assert.is_true(facts.then_env.is_non_null_path(p));
            Assert.are_same(cat, facts.then_env.narrowed_type_of_path(p));

            // Animal is an open receiver — no representable else-edge complement.
            Assert.is_null(facts.else_env.narrowed_type_of_path(p));
        si

        // `!isa T(x.y)` — the not-swap moves the then narrow to the
        // else edge on the path.
        analyze_not_isa_on_path_should_narrow_else_edge() is
            @test()

            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);

            let right = id_expr("holder_animal");
            let p = make_path("holder", "animal");
            let paths = MAP[Expression, ACCESS_PATH]();
            paths[right] = p;

            let facts = make_path_analyzer(MAP[Expression, Variable](), paths)
                .analyze_condition(make_not(make_isa(right, cat)), NARROW_ENV());

            Assert.is_null(facts.then_env.narrowed_type_of_path(p));
            Assert.are_same(cat, facts.else_env.narrowed_type_of_path(p));
            Assert.is_true(facts.else_env.is_non_null_path(p));
        si

        // A symbol resolver hit outranks the path resolver — a symbol
        // fact carries strictly more than a path fact on the same
        // expression would.
        analyze_isa_should_prefer_symbol_target_over_path() is
            @test()

            let owner = make_owner();
            let animal = make_class_type("Animal");
            let cat = make_subclass_type("Cat", animal);
            let v = make_var(owner, "v", animal);

            let right = id_expr("v");
            let p = make_path("holder", "animal");
            let targets = MAP[Expression, Variable]();
            targets[right] = v;
            let paths = MAP[Expression, ACCESS_PATH]();
            paths[right] = p;

            let facts = make_path_analyzer(targets, paths)
                .analyze_condition(make_isa(right, cat), NARROW_ENV());

            // Symbol narrow lands on the variable, not on the path.
            Assert.are_same(cat, facts.then_env.narrowed_type_of(v));
            Assert.is_null(facts.then_env.narrowed_type_of_path(p));
        si
    si
si
