namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Syntax.Process.COMPILE_CALLS;

    use Trees.Expressions.Expression;
    use Trees.Expressions.FUNCTION;
    use Trees.Expressions.IDENTIFIER;
    use Trees.Identifiers.Identifier;

    // Tests for COMPILE_CALLS.has_function_literal_argument — the static
    // gate that decides whether the constraint-push retry should fire
    // when an overload resolution returns null or PARTIAL. Pure
    // structural check over the actual argument expressions; no symbol
    // table or type system involved.
    class COMPILE_CALLS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        make_identifier(name: string) -> IDENTIFIER =>
            IDENTIFIER(loc(), Identifier(loc(), name));

        // FUNCTION needs an arguments list and a body. For this gate
        // the structural `isa FUNCTION` is all that matters — the
        // arguments list can be empty, body can be null.
        make_function_literal() -> FUNCTION =>
            FUNCTION(loc(), Trees.Expressions.LIST(loc(), LIST[Expression]()), null, null, false);

        Calling__has_function_literal_argument__with_null__returns_false() is
            @test()

            Assert.is_false(COMPILE_CALLS.has_function_literal_argument(null));
        si

        Calling__has_function_literal_argument__with_empty_list__returns_false() is
            @test()

            Assert.is_false(COMPILE_CALLS.has_function_literal_argument(LIST[Expression]()));
        si

        Calling__has_function_literal_argument__with_only_identifiers__returns_false() is
            @test()

            let args = LIST[Expression]();
            args.add(make_identifier("a"));
            args.add(make_identifier("b"));

            Assert.is_false(COMPILE_CALLS.has_function_literal_argument(args));
        si

        Calling__has_function_literal_argument__with_a_function_literal__returns_true() is
            @test()

            let args = LIST[Expression]();
            args.add(make_function_literal());

            Assert.is_true(COMPILE_CALLS.has_function_literal_argument(args));
        si

        // The mixed case is the operator-path gate: a concrete sibling
        // arg (e.g. the LHS of `$$`) plus a lambda RHS still triggers
        // the retry so the lambda can be re-walked under the
        // operator's formal.
        Calling__has_function_literal_argument__with_mixed_args__returns_true() is
            @test()

            let args = LIST[Expression]();
            args.add(make_identifier("concrete"));
            args.add(make_function_literal());

            Assert.is_true(COMPILE_CALLS.has_function_literal_argument(args));
        si

        // Null entries in the list are tolerated — callers may pass
        // partially-built argument lists.
        Calling__has_function_literal_argument__with_null_entries__skips_them() is
            @test()

            let args = LIST[Expression]();
            args.add(null);
            args.add(make_function_literal());
            args.add(null);

            Assert.is_true(COMPILE_CALLS.has_function_literal_argument(args));
        si

        Calling__has_function_literal_argument__with_only_null_entries__returns_false() is
            @test()

            let args = LIST[Expression]();
            args.add(null);
            args.add(null);

            Assert.is_false(COMPILE_CALLS.has_function_literal_argument(args));
        si
    si
si
