namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.Symbol;
    use Semantic.Symbols.Variable;

    // Tests for ACCESS_PATH — the member-access path key behind the
    // path-presence domain. Equality and hashing are by root + member
    // symbol identity; has_prefix drives the assignment-transfer
    // invalidation. Member symbols stand in as plain Variables here —
    // only their identity matters to the path.
    class ACCESS_PATH_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        empty_names() -> LIST[string] => LIST[string]();
        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", empty_names(), false, null);
        make_sym(owner: CLASS, name: string) -> Variable => Variable(loc(), owner, name);

        members(a: Symbol, b: Symbol) -> LIST[Symbol] is
            let result = LIST[Symbol]();
            if a? then result.add(a); fi
            if b? then result.add(b); fi
            return result;
        si

        Equal_paths_should_be_equal_and_share_hash() is
            @test()

            let owner = make_owner();
            let root = make_sym(owner, "root");
            let a = make_sym(owner, "a");
            let b = make_sym(owner, "b");

            let p = ACCESS_PATH(root, members(a, b));
            let q = ACCESS_PATH(root, members(a, b));

            Assert.is_true(p.equals(q));
            Assert.are_equal(p.get_hash_code(), q.get_hash_code());
        si

        Paths_with_different_roots_should_differ() is
            @test()

            let owner = make_owner();
            let r1 = make_sym(owner, "r1");
            let r2 = make_sym(owner, "r2");
            let a = make_sym(owner, "a");

            Assert.is_false(ACCESS_PATH(r1, members(a, null)).equals(ACCESS_PATH(r2, members(a, null))));
        si

        Paths_with_different_members_should_differ() is
            @test()

            let owner = make_owner();
            let root = make_sym(owner, "root");
            let a = make_sym(owner, "a");
            let b = make_sym(owner, "b");
            let c = make_sym(owner, "c");

            Assert.is_false(ACCESS_PATH(root, members(a, b)).equals(ACCESS_PATH(root, members(a, c))));
        si

        Shorter_path_should_not_equal_its_extension() is
            @test()

            let owner = make_owner();
            let root = make_sym(owner, "root");
            let a = make_sym(owner, "a");
            let b = make_sym(owner, "b");

            Assert.is_false(ACCESS_PATH(root, members(a, null)).equals(ACCESS_PATH(root, members(a, b))));
        si

        Prefix_should_be_recognised_including_self() is
            @test()

            let owner = make_owner();
            let root = make_sym(owner, "root");
            let a = make_sym(owner, "a");
            let b = make_sym(owner, "b");

            let one = ACCESS_PATH(root, members(a, null));
            let two = ACCESS_PATH(root, members(a, b));
            let bare = ACCESS_PATH(root, members(null, null));

            // root.a is a prefix of root.a.b; both are prefixes of
            // themselves; the bare root is a prefix of everything
            // rooted at it.
            Assert.is_true(two.has_prefix(one));
            Assert.is_true(two.has_prefix(two));
            Assert.is_true(two.has_prefix(bare));
            Assert.is_true(one.has_prefix(bare));
        si

        Non_prefix_should_be_rejected() is
            @test()

            let owner = make_owner();
            let root = make_sym(owner, "root");
            let a = make_sym(owner, "a");
            let b = make_sym(owner, "b");

            let one = ACCESS_PATH(root, members(a, null));
            let two = ACCESS_PATH(root, members(a, b));
            let other = ACCESS_PATH(root, members(b, null));

            // A longer path is not a prefix of a shorter one, and a
            // divergent first hop is not a prefix.
            Assert.is_false(one.has_prefix(two));
            Assert.is_false(two.has_prefix(other));
        si
    si
si
