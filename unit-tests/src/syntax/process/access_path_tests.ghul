namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.INSTANCE_PROPERTY;
    use Semantic.Symbols.LOCAL_VARIABLE;
    use Semantic.Symbols.Symbol;

    // Tests for ACCESS_PATH — the member-access path key behind the
    // path-presence domain. Equality and hashing are by root + member
    // symbol identity; contains_member drives the member-store
    // invalidation and has_getter_hop the heap-store invalidation.
    class ACCESS_PATH_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);
        make_owner() -> CLASS => CLASS(loc(), loc(), null, "TestOwner", LIST[string](), false, null);
        make_root(name: string) -> LOCAL_VARIABLE => LOCAL_VARIABLE(loc(), null, name);
        make_field(owner: CLASS, name: string) -> INSTANCE_FIELD => INSTANCE_FIELD(loc(), owner, name);
        make_property(owner: CLASS, name: string) -> INSTANCE_PROPERTY => INSTANCE_PROPERTY(loc(), loc(), owner, name, false, false);

        members(a: Symbol?, b: Symbol?) -> LIST[Symbol] is
            let result = LIST[Symbol]();
            if a? then result.add(a); fi
            if b? then result.add(b); fi
            return result;
        si

        Equal_paths_should_be_equal_and_share_hash() is
            @test()

            let owner = make_owner();
            let root = make_root("root");
            let a = make_field(owner, "a");
            let b = make_field(owner, "b");

            let p = ACCESS_PATH(root, members(a, b));
            let q = ACCESS_PATH(root, members(a, b));

            Assert.is_true(p.equals(q));
            Assert.are_equal(p.get_hash_code(), q.get_hash_code());
        si

        Paths_with_different_roots_should_differ() is
            @test()

            let owner = make_owner();
            let a = make_field(owner, "a");

            Assert.is_false(ACCESS_PATH(make_root("r1"), members(a, null)).equals(ACCESS_PATH(make_root("r2"), members(a, null))));
        si

        Paths_with_different_members_should_differ() is
            @test()

            let owner = make_owner();
            let root = make_root("root");
            let a = make_field(owner, "a");
            let b = make_field(owner, "b");
            let c = make_field(owner, "c");

            Assert.is_false(ACCESS_PATH(root, members(a, b)).equals(ACCESS_PATH(root, members(a, c))));
        si

        Shorter_path_should_not_equal_its_extension() is
            @test()

            let owner = make_owner();
            let root = make_root("root");
            let a = make_field(owner, "a");
            let b = make_field(owner, "b");

            Assert.is_false(ACCESS_PATH(root, members(a, null)).equals(ACCESS_PATH(root, members(a, b))));
        si

        Contains_member_should_hit_every_hop_and_nothing_else() is
            @test()

            let owner = make_owner();
            let root = make_root("root");
            let a = make_field(owner, "a");
            let b = make_field(owner, "b");
            let other = make_field(owner, "other");

            let path = ACCESS_PATH(root, members(a, b));

            Assert.is_true(path.contains_member(a));
            Assert.is_true(path.contains_member(b));
            Assert.is_false(path.contains_member(other));
            Assert.is_false(path.contains_member(null));
        si

        Getter_hop_should_be_detected_at_any_position() is
            @test()

            let owner = make_owner();
            let root = make_root("root");
            let f = make_field(owner, "f");
            let g = make_field(owner, "g");
            let p = make_property(owner, "p");

            Assert.is_false(ACCESS_PATH(root, members(f, g)).has_getter_hop);
            Assert.is_true(ACCESS_PATH(root, members(p, g)).has_getter_hop);
            Assert.is_true(ACCESS_PATH(root, members(f, p)).has_getter_hop);
        si
    si
si
