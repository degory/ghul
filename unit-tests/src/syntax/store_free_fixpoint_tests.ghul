namespace Syntax.UnitTests is
    use Collections.LIST;
    use Collections.MAP;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Syntax.Process.STORE_FREE_FACTS;
    use Syntax.Process.STORE_FREE_FIXPOINT;
    use Syntax.Process.STORE_FREE_INNATES;

    use Semantic.Symbols.STORE_FREE_IMPORTS;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.GLOBAL_FUNCTION;
    use Semantic.Symbols.INSTANCE_METHOD;
    use Semantic.Symbols.NAMESPACE;

    use Function = Semantic.Symbols.Function;

    // Pins the store-free fixpoint's graph behaviour: seeding from
    // disqualified bodies and open dispatch, propagation through
    // callee and overrider edges, and the mutual-recursion case that
    // must come out store-free.
    class STORE_FREE_FIXPOINT_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        global_function(name: string) -> GLOBAL_FUNCTION =>
            GLOBAL_FUNCTION(loc(), loc(), null, name, null);

        method(name: string, owner: CLASS) -> INSTANCE_METHOD =>
            INSTANCE_METHOD(loc(), loc(), owner, name, null);

        closed_class(name: string) -> CLASS is
            let result = CLASS(loc(), loc(), null, name, LIST[string](), false, null);
            result.mark_closed();
            return result;
        si

        open_class(name: string) -> CLASS is
            let result = CLASS(loc(), loc(), null, name, LIST[string](), false, null);
            result.mark_open();
            return result;
        si

        facts_for(functions: Collections.Iterable[Function]) -> MAP[Function, STORE_FREE_FACTS] is
            let result = MAP[Function, STORE_FREE_FACTS]();
            for f in functions do
                result[f] = STORE_FREE_FACTS();
            od
            return result;
        si

        // A reflected function whose owner renders the given ghūl
        // qualified name — the shape STORE_FREE_IMPORTS matches on.
        trusted_import(namespace_name: string, class_name: string, member_name: string) -> INSTANCE_METHOD is
            if !LOCATION.reflected? then
                LOCATION.init_static();
            fi

            let ns = NAMESPACE(loc(), namespace_name, null, ".{namespace_name}", false);
            let owner = CLASS(LOCATION.reflected, LOCATION.reflected, ns, class_name, LIST[string](), false, null);
            return INSTANCE_METHOD(LOCATION.reflected, LOCATION.reflected, owner, member_name, null);
        si

        Trusted_virtual_import_with_storing_overrider__poisons_the_caller() is
            @test()

            let to_string_import = trusted_import("Ghul", "object", "to_string");
            let overrider = method("to_string", closed_class("SHOUTY"));
            to_string_import.add_overrider(overrider);

            let caller = global_function("caller");
            let facts = facts_for([cast Function(caller), cast Function(overrider)]);
            facts[caller].add_callee(to_string_import);
            facts[overrider].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(caller.is_store_free);
            Assert.is_false(to_string_import.is_store_free);
        si

        Trusted_virtual_import_with_store_free_overrider__keeps_the_caller_safe() is
            @test()

            let to_string_import = trusted_import("Ghul", "object", "to_string");
            let overrider = method("to_string", closed_class("QUIET"));
            to_string_import.add_overrider(overrider);

            let caller = global_function("caller");
            let facts = facts_for([cast Function(caller), cast Function(overrider)]);
            facts[caller].add_callee(to_string_import);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(caller.is_store_free);
            Assert.is_true(to_string_import.is_store_free);
        si

        Untrusted_import__poisons_the_caller() is
            @test()

            let mystery = trusted_import("Ghul", "object", "mystery_method");
            let caller = global_function("caller");
            let facts = facts_for([cast Function(caller)]);
            facts[caller].add_callee(mystery);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(caller.is_store_free);
        si

        Trusted_import_reached_without_a_fixpoint_edge__reads_store_free() is
            @test()

            // A call in a function-literal body never becomes a fixpoint
            // callee edge, so the import's trust has to hold when
            // is_store_free is queried directly, with no mark() run.
            let import_fn = trusted_import("Ghul", "string", "to_upper");

            Assert.is_true(import_fn.is_store_free);
        si

        Trusted_import_with_an_overrider__is_not_store_free_without_a_fixpoint_edge() is
            @test()

            // The query-time gate withdraws trust from a virtual import
            // that carries an overrider, deferring to the fixpoint's
            // dispatch-shadow check. With no mark() run no bit is set,
            // so it reads not-store-free.
            let import_fn = trusted_import("Ghul", "object", "to_string");
            import_fn.add_overrider(method("to_string", closed_class("SHOUTY")));

            Assert.is_false(import_fn.is_store_free);
        si

        Clean_leaf_function__is_marked_store_free() is
            @test()

            let f = global_function("leaf");
            let facts = facts_for([f]);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(f.is_store_free);
        si

        Disqualified_function__is_not_store_free() is
            @test()

            let f = global_function("storer");
            let facts = facts_for([f]);
            facts[f].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(f.is_store_free);
        si

        constructor(name: string) -> INSTANCE_METHOD is
            let result = method(name, closed_class(name));
            result.il_name_override = "'.ctor'";
            return result;
        si

        Constructor_writing_only_its_own_fields__constructs_store_free() is
            @test()

            // its own-field writes disqualify the strict bit but leave
            // is_construction_disqualified clear, so `NEW` trusts it
            let ctor = constructor("BOX");
            let facts = facts_for([cast Function(ctor)]);
            facts[ctor].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(ctor.is_store_free);
            Assert.is_true(ctor.constructs_store_free);
        si

        Constructor_writing_a_foreign_slot__does_not_construct_store_free() is
            @test()

            // a write to something other than the fresh object sets
            // is_construction_disqualified, so construction is not trusted
            let ctor = constructor("LEAK");
            let facts = facts_for([cast Function(ctor)]);
            facts[ctor].is_disqualified = true;
            facts[ctor].is_construction_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(ctor.constructs_store_free);
        si

        // mark reports whether it moved any bit — the signal the
        // debounced compile uses to tell that an incremental edit
        // flipped a function's store-free bit out from under callers.
        Mark__reports_a_bit_flip_and_a_stable_run() is
            @test()

            let f = global_function("leaf");

            // default(false) -> store-free(true) moves the bit
            Assert.is_true(STORE_FREE_FIXPOINT().mark(facts_for([f])));

            // re-run over the same clean facts moves nothing
            Assert.is_false(STORE_FREE_FIXPOINT().mark(facts_for([f])));

            // a body that now stores drops store-free(true) -> false
            let storing = facts_for([f]);
            storing[f].is_disqualified = true;
            Assert.is_true(STORE_FREE_FIXPOINT().mark(storing));
        si

        Mark__collects_exactly_the_flipped_functions() is
            @test()

            let moving = global_function("moving");
            let stable = global_function("stable");

            // settle both bits at store-free
            STORE_FREE_FIXPOINT().mark(facts_for([moving, stable]));

            // a stable re-run flips nothing
            let unchanged = STORE_FREE_FIXPOINT();
            unchanged.mark(facts_for([moving, stable]));
            Assert.are_equal(0, unchanged.flipped.count);

            // disqualifying one body flips that function alone
            let storing = facts_for([moving, stable]);
            storing[moving].is_disqualified = true;

            let fixpoint = STORE_FREE_FIXPOINT();
            fixpoint.mark(storing);

            Assert.are_equal(1, fixpoint.flipped.count);
            Assert.are_same(moving, fixpoint.flipped[0]);
        si

        Mark__collects_the_transitively_flipped_caller() is
            @test()

            let callee = global_function("callee");
            let caller = global_function("caller");

            let clean = facts_for([callee, caller]);
            clean[caller].add_callee(callee);
            STORE_FREE_FIXPOINT().mark(clean);

            // the callee turning storing flips the caller with it
            let storing = facts_for([callee, caller]);
            storing[callee].is_disqualified = true;
            storing[caller].add_callee(callee);

            let fixpoint = STORE_FREE_FIXPOINT();
            fixpoint.mark(storing);

            Assert.are_equal(2, fixpoint.flipped.count);
            Assert.is_true(fixpoint.flipped | .any(f => f == cast Function(callee)));
            Assert.is_true(fixpoint.flipped | .any(f => f == cast Function(caller)));
        si

        Caller_of_clean_callee__is_store_free() is
            @test()

            let callee = global_function("callee");
            let caller = global_function("caller");
            let facts = facts_for([callee, caller]);
            facts[caller].add_callee(callee);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(caller.is_store_free);
        si

        Caller_of_disqualified_callee__is_not_store_free() is
            @test()

            let callee = global_function("storer");
            let caller = global_function("caller");
            let facts = facts_for([callee, caller]);
            facts[callee].is_disqualified = true;
            facts[caller].add_callee(callee);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(caller.is_store_free);
        si

        Unsafety_propagates_through_call_chains() is
            @test()

            let a = global_function("a");
            let b = global_function("b");
            let c = global_function("c");
            let facts = facts_for([a, b, c]);
            facts[a].add_callee(b);
            facts[b].add_callee(c);
            facts[c].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(a.is_store_free);
            Assert.is_false(b.is_store_free);
        si

        Caller_of_unwalked_callee__is_not_store_free() is
            @test()

            let external = global_function("imported");
            let caller = global_function("caller");
            let facts = facts_for([caller]);
            facts[caller].add_callee(external);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(caller.is_store_free);
        si

        Mutually_recursive_clean_functions__are_store_free() is
            @test()

            let ping = global_function("ping");
            let pong = global_function("pong");
            let facts = facts_for([ping, pong]);
            facts[ping].add_callee(pong);
            facts[pong].add_callee(ping);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(ping.is_store_free);
            Assert.is_true(pong.is_store_free);
        si

        Clean_method_with_storing_override__is_not_store_free() is
            @test()

            let base_owner = closed_class("QUIET");
            let derived_owner = closed_class("NOISY");
            let base_method = method("calm", base_owner);
            let override_method = method("calm", derived_owner);
            base_method.add_overrider(override_method);

            let facts = facts_for([base_method, override_method]);
            facts[override_method].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(base_method.is_store_free);
            Assert.is_false(override_method.is_store_free);
        si

        Clean_method_with_clean_override__is_store_free() is
            @test()

            let base_owner = closed_class("QUIET");
            let derived_owner = closed_class("CALM");
            let base_method = method("calm", base_owner);
            let override_method = method("calm", derived_owner);
            base_method.add_overrider(override_method);

            let facts = facts_for([base_method, override_method]);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(base_method.is_store_free);
            Assert.is_true(override_method.is_store_free);
        si

        Clean_method_on_open_class__is_not_store_free() is
            @test()

            let owner = open_class("LOUD");
            let m = method("shout", owner);

            let facts = facts_for([m]);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(m.is_store_free);
        si

        Clean_method_on_closed_class__is_store_free() is
            @test()

            let owner = closed_class("QUIET");
            let m = method("calm", owner);

            let facts = facts_for([m]);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(m.is_store_free);
        si

        Rerun_after_body_becomes_disqualified__clears_the_bit() is
            @test()

            let f = global_function("was_clean");
            let facts = facts_for([f]);

            STORE_FREE_FIXPOINT().mark(facts);
            Assert.is_true(f.is_store_free);

            let facts_after_edit = facts_for([f]);
            facts_after_edit[f].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts_after_edit);
            Assert.is_false(f.is_store_free);
        si
    si

    // Pins the innate allowlist: value arithmetic, comparisons,
    // boolean logic and reads are store-free; assignment through a
    // reference or pointer, unqualified names and unknown families
    // are not.
    class STORE_FREE_INNATES_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        qualified(family: string, leaf: string) -> Syntax.Trees.Identifiers.Identifier =>
            Syntax.Trees.Identifiers.QUALIFIED(
                loc(),
                Syntax.Trees.Identifiers.Identifier(loc(), family),
                leaf,
                loc(),
                loc()
            );

        Arithmetic_add__is_store_free() is
            @test()
            Assert.is_true(STORE_FREE_INNATES.is_store_free(qualified("arithmetic", "add")));
        si

        Compare_order__is_store_free() is
            @test()
            Assert.is_true(STORE_FREE_INNATES.is_store_free(qualified("compare", "order")));
        si

        Reference_read__is_store_free() is
            @test()
            Assert.is_true(STORE_FREE_INNATES.is_store_free(qualified("reference", "read")));
        si

        Reference_assign__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(qualified("reference", "assign")));
        si

        Pointer_assign__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(qualified("pointer", "assign")));
        si

        Unknown_family__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(qualified("mystery", "op")));
        si

        Unqualified_name__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(Syntax.Trees.Identifiers.Identifier(loc(), "add")));
        si

        Null_name__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(null));
        si
    si

    // Pins the trusted-import matcher: entries key on the owner's
    // ghūl-side qualified name plus the member name, and only
    // reflected functions can match.
    class STORE_FREE_IMPORTS_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        import_named(namespace_name: string, class_name: string, member_name: string, reflected: bool) -> INSTANCE_METHOD is
            if !LOCATION.reflected? then
                LOCATION.init_static();
            fi

            let ns = NAMESPACE(loc(), namespace_name, null, ".{namespace_name}", false);
            let location = if reflected then LOCATION.reflected else loc() fi;
            let owner = CLASS(location, location, ns, class_name, LIST[string](), false, null);
            return INSTANCE_METHOD(location, location, owner, member_name, null);
        si

        Listed_reflected_member__is_trusted() is
            @test()
            let f = import_named("Ghul", "string", "index_of", true);
            Assert.is_true(
                STORE_FREE_IMPORTS.is_store_free(f),
                "key='{f.owner.qualified_name}.{f.name}' reflected={f.is_reflected}"
            );
        si

        Listed_collection_read__is_trusted() is
            @test()
            Assert.is_true(STORE_FREE_IMPORTS.is_store_free(import_named("Collections", "STACK", "peek", true)));
        si

        Listed_char_classifier__is_trusted() is
            @test()
            Assert.is_true(STORE_FREE_IMPORTS.is_store_free(import_named("Ghul", "char", "is_digit", true)));
        si

        Listed_string_transform__is_trusted() is
            @test()
            Assert.is_true(STORE_FREE_IMPORTS.is_store_free(import_named("Ghul", "string", "trim", true)));
        si

        Listed_path_op__is_trusted() is
            @test()
            Assert.is_true(STORE_FREE_IMPORTS.is_store_free(import_named("IO", "Path", "combine", true)));
        si

        Listed_object_get_type__is_trusted() is
            @test()
            Assert.is_true(STORE_FREE_IMPORTS.is_store_free(import_named("Ghul", "object", "get_type", true)));
        si

        Listed_string_builder_read__is_trusted() is
            @test()
            Assert.is_true(STORE_FREE_IMPORTS.is_store_free(import_named("System.Text", "StringBuilder", "to_string", true)));
        si

        Listed_reflected_type_name_getter__is_trusted() is
            @test()
            Assert.is_true(STORE_FREE_IMPORTS.is_store_free(import_named("System", "Type", "$get_full_name", true)));
        si

        Listed_keyvaluepair_constructor__is_trusted() is
            @test()
            Assert.is_true(STORE_FREE_IMPORTS.is_store_free(import_named("Collections", "KeyValuePair", "init", true)));
        si

        Unlisted_member__is_not_trusted() is
            @test()
            Assert.is_false(STORE_FREE_IMPORTS.is_store_free(import_named("Ghul", "string", "normalize", true)));
        si

        // Convert.to_int32 is JetBrains-Pure and looks like a value
        // conversion, but its object overload dispatches through
        // IConvertible on a user-typed argument, which can store. It
        // stays off the list by name.
        Convert_conversion__is_not_trusted() is
            @test()
            Assert.is_false(STORE_FREE_IMPORTS.is_store_free(import_named("System", "Convert", "to_int32", true)));
        si

        Listed_name_on_unreflected_function__is_not_trusted() is
            @test()
            Assert.is_false(STORE_FREE_IMPORTS.is_store_free(import_named("Ghul", "string", "index_of", false)));
        si

        Null_function__is_not_trusted() is
            @test()
            Assert.is_false(STORE_FREE_IMPORTS.is_store_free(null));
        si
    si
si
