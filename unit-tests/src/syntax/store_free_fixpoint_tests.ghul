namespace Syntax.UnitTests is
    use Collections.LIST;
    use Collections.MAP;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Syntax.Process.STORE_FREE_FACTS;
    use Syntax.Process.STORE_FREE_FIXPOINT;
    use Syntax.Process.STORE_FREE_INNATES;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.GLOBAL_FUNCTION;
    use Semantic.Symbols.INSTANCE_METHOD;

    use Function = Semantic.Symbols.Function;

    // Pins the store-free fixpoint's graph behaviour: seeding from
    // disqualified bodies and open dispatch, propagation through
    // callee and overrider edges, and the mutual-recursion case that
    // must come out store-free.
    class STORE_FREE_FIXPOINT_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        global_function(name: string) -> GLOBAL_FUNCTION =>
            GLOBAL_FUNCTION(loc(), loc(), null, name, null);

        method(name: string, owner: CLASS) -> INSTANCE_METHOD =>
            INSTANCE_METHOD(loc(), loc(), owner, name, null);

        closed_class(name: string) -> CLASS is
            let result = CLASS(loc(), loc(), null, name, LIST[string](), false, null);
            result.mark_closed();
            return result;
        si

        open_class(name: string) -> CLASS is
            let result = CLASS(loc(), loc(), null, name, LIST[string](), false, null);
            result.mark_open();
            return result;
        si

        facts_for(functions: Collections.Iterable[Function]) -> MAP[Function, STORE_FREE_FACTS] is
            let result = MAP[Function, STORE_FREE_FACTS]();
            for f in functions do
                result[f] = STORE_FREE_FACTS();
            od
            return result;
        si

        Clean_leaf_function__is_marked_store_free() is
            @test()

            let f = global_function("leaf");
            let facts = facts_for([f]);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(f.is_store_free);
        si

        Disqualified_function__is_not_store_free() is
            @test()

            let f = global_function("storer");
            let facts = facts_for([f]);
            facts[f].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(f.is_store_free);
        si

        Caller_of_clean_callee__is_store_free() is
            @test()

            let callee = global_function("callee");
            let caller = global_function("caller");
            let facts = facts_for([callee, caller]);
            facts[caller].add_callee(callee);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(caller.is_store_free);
        si

        Caller_of_disqualified_callee__is_not_store_free() is
            @test()

            let callee = global_function("storer");
            let caller = global_function("caller");
            let facts = facts_for([callee, caller]);
            facts[callee].is_disqualified = true;
            facts[caller].add_callee(callee);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(caller.is_store_free);
        si

        Unsafety_propagates_through_call_chains() is
            @test()

            let a = global_function("a");
            let b = global_function("b");
            let c = global_function("c");
            let facts = facts_for([a, b, c]);
            facts[a].add_callee(b);
            facts[b].add_callee(c);
            facts[c].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(a.is_store_free);
            Assert.is_false(b.is_store_free);
        si

        Caller_of_unwalked_callee__is_not_store_free() is
            @test()

            let external = global_function("imported");
            let caller = global_function("caller");
            let facts = facts_for([caller]);
            facts[caller].add_callee(external);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(caller.is_store_free);
        si

        Mutually_recursive_clean_functions__are_store_free() is
            @test()

            let ping = global_function("ping");
            let pong = global_function("pong");
            let facts = facts_for([ping, pong]);
            facts[ping].add_callee(pong);
            facts[pong].add_callee(ping);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(ping.is_store_free);
            Assert.is_true(pong.is_store_free);
        si

        Clean_method_with_storing_override__is_not_store_free() is
            @test()

            let base_owner = closed_class("QUIET");
            let derived_owner = closed_class("NOISY");
            let base_method = method("calm", base_owner);
            let override_method = method("calm", derived_owner);
            base_method.add_overrider(override_method);

            let facts = facts_for([base_method, override_method]);
            facts[override_method].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(base_method.is_store_free);
            Assert.is_false(override_method.is_store_free);
        si

        Clean_method_with_clean_override__is_store_free() is
            @test()

            let base_owner = closed_class("QUIET");
            let derived_owner = closed_class("CALM");
            let base_method = method("calm", base_owner);
            let override_method = method("calm", derived_owner);
            base_method.add_overrider(override_method);

            let facts = facts_for([base_method, override_method]);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(base_method.is_store_free);
            Assert.is_true(override_method.is_store_free);
        si

        Clean_method_on_open_class__is_not_store_free() is
            @test()

            let owner = open_class("LOUD");
            let m = method("shout", owner);

            let facts = facts_for([m]);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(m.is_store_free);
        si

        Clean_method_on_closed_class__is_store_free() is
            @test()

            let owner = closed_class("QUIET");
            let m = method("calm", owner);

            let facts = facts_for([m]);

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(m.is_store_free);
        si

        Rerun_after_body_becomes_disqualified__clears_the_bit() is
            @test()

            let f = global_function("was_clean");
            let facts = facts_for([f]);

            STORE_FREE_FIXPOINT().mark(facts);
            Assert.is_true(f.is_store_free);

            let facts_after_edit = facts_for([f]);
            facts_after_edit[f].is_disqualified = true;

            STORE_FREE_FIXPOINT().mark(facts_after_edit);
            Assert.is_false(f.is_store_free);
        si
    si

    // Pins the innate allowlist: value arithmetic, comparisons,
    // boolean logic and reads are store-free; assignment through a
    // reference or pointer, unqualified names and unknown families
    // are not.
    class STORE_FREE_INNATES_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        qualified(family: string, leaf: string) -> Syntax.Trees.Identifiers.Identifier =>
            Syntax.Trees.Identifiers.QUALIFIED(
                loc(),
                Syntax.Trees.Identifiers.Identifier(loc(), family),
                leaf,
                loc(),
                loc()
            );

        Arithmetic_add__is_store_free() is
            @test()
            Assert.is_true(STORE_FREE_INNATES.is_store_free(qualified("arithmetic", "add")));
        si

        Compare_order__is_store_free() is
            @test()
            Assert.is_true(STORE_FREE_INNATES.is_store_free(qualified("compare", "order")));
        si

        Reference_read__is_store_free() is
            @test()
            Assert.is_true(STORE_FREE_INNATES.is_store_free(qualified("reference", "read")));
        si

        Reference_assign__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(qualified("reference", "assign")));
        si

        Pointer_assign__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(qualified("pointer", "assign")));
        si

        Unknown_family__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(qualified("mystery", "op")));
        si

        Unqualified_name__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(Syntax.Trees.Identifiers.Identifier(loc(), "add")));
        si

        Null_name__is_not_store_free() is
            @test()
            Assert.is_false(STORE_FREE_INNATES.is_store_free(null));
        si
    si
si
