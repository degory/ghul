namespace Syntax.UnitTests is
    use Collections.MAP;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Syntax.Process.NARROWING_FLOW;
    use Syntax.Process.STORE_FREE_FACTS;
    use Syntax.Process.STORE_FREE_FIXPOINT;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.GLOBAL_FUNCTION;
    use Semantic.Symbols.INSTANCE_FIELD;

    use Function = Semantic.Symbols.Function;

    // Pins the declared-pure trust rules: the flag feeds the
    // store-free bit without proof, the fixpoint accepts a
    // declared-pure callee that would otherwise demote its caller,
    // and the literal-purity frames record exactly the innermost
    // literal's heap-visible operations.
    class DECLARED_PURE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        global_function(name: string) -> GLOBAL_FUNCTION =>
            GLOBAL_FUNCTION(loc(), loc(), null, name, null);

        Declared_pure_should_read_as_store_free_without_proof() is
            @test()

            let f = global_function("f");

            Assert.is_false(f.is_store_free);

            f.mark_declared_pure();

            Assert.is_true(f.is_declared_pure);
            Assert.is_true(f.is_store_free);

            // the fixpoint's demotion write-back must not defeat the
            // declaration
            f.set_store_free(false);

            Assert.is_true(f.is_store_free);
        si

        Fixpoint_should_trust_a_declared_pure_callee_with_an_unsafe_body() is
            @test()

            let callee = global_function("callee");
            let caller = global_function("caller");

            callee.mark_declared_pure();

            let callee_facts = STORE_FREE_FACTS();
            callee_facts.is_disqualified = true;

            let caller_facts = STORE_FREE_FACTS();
            caller_facts.callees.add(callee);

            let facts = MAP[Function, STORE_FREE_FACTS]();
            facts[callee] = callee_facts;
            facts[caller] = caller_facts;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_true(caller.is_store_free);
        si

        Fixpoint_should_still_demote_a_caller_of_an_undeclared_unsafe_callee() is
            @test()

            let callee = global_function("callee");
            let caller = global_function("caller");

            let callee_facts = STORE_FREE_FACTS();
            callee_facts.is_disqualified = true;

            let caller_facts = STORE_FREE_FACTS();
            caller_facts.callees.add(callee);

            let facts = MAP[Function, STORE_FREE_FACTS]();
            facts[callee] = callee_facts;
            facts[caller] = caller_facts;

            STORE_FREE_FIXPOINT().mark(facts);

            Assert.is_false(caller.is_store_free);
        si

        Literal_frame_should_record_a_call_and_a_heap_store() is
            @test()

            let flow = NARROWING_FLOW();

            flow.push_literal_frame();
            Assert.is_false(flow.pop_literal_frame());

            flow.push_literal_frame();
            flow.on_call();
            Assert.is_true(flow.pop_literal_frame());

            flow.push_literal_frame();
            flow.on_heap_store();
            Assert.is_true(flow.pop_literal_frame());
        si

        Literal_frame_should_charge_only_the_innermost_literal() is
            @test()

            let owner = CLASS(loc(), loc(), null, "OWNER", Collections.LIST[string](), false, null);
            let f = INSTANCE_FIELD(loc(), owner, "f");

            let flow = NARROWING_FLOW();

            flow.push_literal_frame();
            flow.push_literal_frame();

            flow.on_member_store(f);

            Assert.is_true(flow.pop_literal_frame());
            Assert.is_false(flow.pop_literal_frame());
        si
    si
si
