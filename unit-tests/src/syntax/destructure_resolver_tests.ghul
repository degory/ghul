namespace Syntax.Process.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INSTANCE_METHOD;
    use Semantic.Symbols.STATIC_METHOD;
    use Semantic.Symbols.Symbol;

    use Semantic.Types.Type;
    use Semantic.Types.REFERENCE;

    use Syntax.Process.DESTRUCTURE_RESOLVER;
    use Syntax.Process.DESTRUCTURE_STRATEGY;

    // Tests for the DESTRUCTURE_RESOLVER strategy selectors and the
    // viable-deconstruct predicate. End-to-end coverage of the two
    // entry points — `resolve_strategy` (positional: value-tuple →
    // deconstruct → `N positional) and `resolve_strategy_by_name`
    // (named-element lookup via find_member) — is exercised by
    // integration tests under
    // integration-tests/{execution,semantic}/destructure-*.
    class DESTRUCTURE_RESOLVER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        bare_class(name: string) -> CLASS =>
            CLASS(loc(), loc(), null, name, LIST[string](), false, null);

        // A `T ref` type wrapping `element_type`. The Reference
        // host class is constructed with a single formal type
        // parameter so the Symbols.GENERIC base accepts it.
        ref_type(element_type: Type) -> Type is
            let names = LIST[string]();
            names.add("T");
            let ref_classy = CLASS(loc(), loc(), null, "Reference", names, false, null);
            let arguments = LIST[Type]();
            arguments.add(element_type);
            return REFERENCE(loc(), ref_classy, arguments);
        si

        int_type() -> Type => bare_class("int").type;
        string_type() -> Type => bare_class("string").type;

        instance_method(name: string, arg_types: LIST[Type]) -> INSTANCE_METHOD is
            let method = INSTANCE_METHOD(loc(), loc(), null, name, null);
            method.arguments = arg_types;
            return method;
        si

        static_method(name: string, arg_types: LIST[Type]) -> STATIC_METHOD is
            let method = STATIC_METHOD(loc(), loc(), null, name, null);
            method.arguments = arg_types;
            return method;
        si

        // === DESTRUCTURE_STRATEGY ===

        Constructing_DESTRUCTURE_STRATEGY_from_members__sets_is_deconstruct_false() is
            @test()

            let members = LIST[Symbol]();
            members.add(null);
            members.add(null);
            let strategy = DESTRUCTURE_STRATEGY(members);

            Assert.is_false(strategy.is_deconstruct);
            Assert.are_same(members, strategy.members);
        si

        Constructing_DESTRUCTURE_STRATEGY_from_function__sets_is_deconstruct_true() is
            @test()

            let method = instance_method("deconstruct", LIST[Type]([ref_type(int_type()), ref_type(int_type())]));
            let strategy = DESTRUCTURE_STRATEGY(method);

            Assert.is_true(strategy.is_deconstruct);
            Assert.are_same(method, strategy.deconstruct_function);
        si

        // === is_viable_deconstruct ===

        Calling__is_viable_deconstruct__with_null_function__returns_false() is
            @test()

            Assert.is_false(DESTRUCTURE_RESOLVER.is_viable_deconstruct(null, 2));
        si

        Calling__is_viable_deconstruct__with_static_method__returns_false() is
            @test()

            let method = static_method("deconstruct", LIST[Type]([ref_type(int_type()), ref_type(int_type())]));

            Assert.is_false(DESTRUCTURE_RESOLVER.is_viable_deconstruct(method, 2));
        si

        Calling__is_viable_deconstruct__with_wrong_arity__returns_false() is
            @test()

            let method = instance_method("deconstruct", LIST[Type]([ref_type(int_type()), ref_type(int_type())]));

            Assert.is_false(DESTRUCTURE_RESOLVER.is_viable_deconstruct(method, 3));
        si

        Calling__is_viable_deconstruct__with_non_ref_param__returns_false() is
            @test()

            let method = instance_method("deconstruct", LIST[Type]([ref_type(int_type()), int_type()]));

            Assert.is_false(DESTRUCTURE_RESOLVER.is_viable_deconstruct(method, 2));
        si

        Calling__is_viable_deconstruct__with_all_ref_params__returns_true() is
            @test()

            let method = instance_method("deconstruct", LIST[Type]([ref_type(int_type()), ref_type(string_type())]));

            Assert.is_true(DESTRUCTURE_RESOLVER.is_viable_deconstruct(method, 2));
        si

        Calling__is_viable_deconstruct__on_zero_arg_instance_method__returns_true_only_when_element_count_zero() is
            @test()

            let method = instance_method("deconstruct", LIST[Type]());

            Assert.is_true(DESTRUCTURE_RESOLVER.is_viable_deconstruct(method, 0));
            Assert.is_false(DESTRUCTURE_RESOLVER.is_viable_deconstruct(method, 1));
        si

        // === try_resolve_deconstruct ===

        Calling__try_resolve_deconstruct__with_null_type__returns_null() is
            @test()

            Assert.is_null(DESTRUCTURE_RESOLVER.try_resolve_deconstruct(null, 2));
        si

        // === resolve_strategy (positional) ===

        Calling__resolve_strategy__with_null_type__returns_strategy_of_nulls() is
            @test()

            let strategy = DESTRUCTURE_RESOLVER.resolve_strategy(null, 2);

            Assert.is_false(strategy.is_deconstruct);
            Assert.are_equal(2, strategy.members.count);
            Assert.is_null(strategy.members[0]);
            Assert.is_null(strategy.members[1]);
        si

        Calling__resolve_strategy__with_bare_class__returns_nulls_no_by_name_fallback() is
            @test()

            // The bare class exposes no value-tuple shape, no
            // deconstruct method, and no `N positional members.
            // Without the dropped rank-4 fallback, every element
            // resolves to null.
            let from_type = bare_class("POINT").type;

            let strategy = DESTRUCTURE_RESOLVER.resolve_strategy(from_type, 2);

            Assert.is_false(strategy.is_deconstruct);
            Assert.are_equal(2, strategy.members.count);
            Assert.is_null(strategy.members[0]);
            Assert.is_null(strategy.members[1]);
        si

        Calling__resolve_strategy__with_element_count_zero__returns_empty_strategy() is
            @test()

            let strategy = DESTRUCTURE_RESOLVER.resolve_strategy(bare_class("POINT").type, 0);

            Assert.is_false(strategy.is_deconstruct);
            Assert.are_equal(0, strategy.members.count);
        si

        // === resolve_strategy_by_name ===

        Calling__resolve_strategy_by_name__with_null_type__returns_strategy_of_nulls() is
            @test()

            let names = LIST[string]();
            names.add("x");
            names.add("y");

            let strategy = DESTRUCTURE_RESOLVER.resolve_strategy_by_name(null, names);

            Assert.is_false(strategy.is_deconstruct);
            Assert.are_equal(2, strategy.members.count);
            Assert.is_null(strategy.members[0]);
            Assert.is_null(strategy.members[1]);
        si

        Calling__resolve_strategy_by_name__with_unknown_members__returns_nulls() is
            @test()

            let names = LIST[string]();
            names.add("x");
            names.add("y");

            let strategy = DESTRUCTURE_RESOLVER.resolve_strategy_by_name(bare_class("POINT").type, names);

            Assert.is_false(strategy.is_deconstruct);
            Assert.are_equal(2, strategy.members.count);
            // The bare class has no `x` or `y` member, so both
            // entries are null — the caller (compile_expressions)
            // reports the missed names individually.
            Assert.is_null(strategy.members[0]);
            Assert.is_null(strategy.members[1]);
        si

        Calling__resolve_strategy_by_name__with_null_name_entry__returns_null_for_that_position() is
            @test()

            // A null entry in field_names marks a nested
            // destructuring group whose own resolver call handles
            // it — the by-name lookup skips that slot.
            let names = LIST[string]();
            names.add(null);
            names.add("y");

            let strategy = DESTRUCTURE_RESOLVER.resolve_strategy_by_name(bare_class("POINT").type, names);

            Assert.is_false(strategy.is_deconstruct);
            Assert.are_equal(2, strategy.members.count);
            Assert.is_null(strategy.members[0]);
            Assert.is_null(strategy.members[1]);
        si
    si
si
