namespace Syntax.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use NSubstitute.SubstituteExtensions.returns;

    use Source.LOCATION;

    use Logging.DIAGNOSTICS_STORE;

    use Syntax.Process.TRIVIAL_EXPRESSION_TYPER;

    use Semantic.BLOCK_SCOPE;
    use Semantic.SYMBOL_TABLE;
    use Semantic.Lookups.InnateSymbolLookup;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.FUNCTION_GROUP;
    use Semantic.Symbols.GLOBAL_FUNCTION;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.LOCAL_VARIABLE;

    use Semantic.Types.Type;

    // Pins TRIVIAL_EXPRESSION_TYPER's contract: declared types of
    // scope-resolvable symbols, the local-initializer record taking
    // precedence, member lookup over declared receiver types, literal
    // and presence-test typing, operator result types only when every
    // candidate agrees, and null for everything undecidable.
    class TRIVIAL_EXPRESSION_TYPER_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        named_class(name: string) -> CLASS => CLASS(loc(), loc(), null, name, LIST[string](), false, null);

        build_lookup(int_type: Type?, bool_type: Type?, string_type: Type?) -> InnateSymbolLookup is
            let arguments = System.Array.empty`[object]();
            let lookup = NSubstitute.Substitute.`for`[InnateSymbolLookup](arguments);
            returns(lookup.get_int_type(), int_type, null);
            returns(lookup.get_bool_type(), bool_type, null);
            returns(lookup.get_string_type(), string_type, null);
            return lookup;
        si

        identifier(name: string) -> Trees.Expressions.IDENTIFIER =>
            Trees.Expressions.IDENTIFIER(loc(), Trees.Identifiers.Identifier(loc(), name));

        member(left: Trees.Expressions.Expression, name: string) -> Trees.Expressions.MEMBER =>
            Trees.Expressions.MEMBER(loc(), left, Trees.Identifiers.Identifier(loc(), name), loc());

        integer_literal() -> Trees.Expressions.Literals.INTEGER =>
            Trees.Expressions.Literals.INTEGER(loc(), "1");

        binary(operation: string, left: Trees.Expressions.Expression, right: Trees.Expressions.Expression) -> Trees.Expressions.BINARY =>
            Trees.Expressions.BINARY(loc(), Trees.Identifiers.Identifier(loc(), operation), operation, left, right);

        // One scope entered on a fresh symbol table; tests declare
        // what they need into it.
        _scope: BLOCK_SCOPE;
        _typer: TRIVIAL_EXPRESSION_TYPER;
        _int_type: Type;
        _bool_type: Type;
        _string_type: Type;

        build() is
            let symbol_table = SYMBOL_TABLE(DIAGNOSTICS_STORE());

            _scope = BLOCK_SCOPE(null);
            symbol_table.enter_scope(_scope);

            _int_type = named_class("int").type;
            _bool_type = named_class("bool").type;
            _string_type = named_class("string").type;

            _typer = TRIVIAL_EXPRESSION_TYPER(
                symbol_table,
                build_lookup(_int_type, _bool_type, _string_type)
            );
        si

        declare_local(name: string, type: Type?) -> LOCAL_VARIABLE is
            let local = LOCAL_VARIABLE(loc(), _scope, name);

            if type? then
                local.set_type(type);
            fi

            _scope.declare(loc(), local, null);

            return local;
        si

        Integer_literal__types_as_int() is
            @test()

            build();

            Assert.are_same(_int_type, _typer.try_type(integer_literal()));
        si

        Has_value_test__types_as_bool() is
            @test()

            build();

            Assert.are_same(_bool_type, _typer.try_type(Trees.Expressions.HAS_VALUE(loc(), identifier("x"))));
        si

        Declared_local__types_as_declared() is
            @test()

            build();
            declare_local("x", _int_type);

            Assert.are_same(_int_type, _typer.try_type(identifier("x")));
        si

        Unresolvable_identifier__types_as_null() is
            @test()

            build();

            Assert.is_null(_typer.try_type(identifier("missing")));
        si

        Local_record__takes_precedence_over_declared_type() is
            @test()

            build();
            let local = declare_local("x", _int_type);

            _typer.set_local_type(local, _string_type);

            Assert.are_same(_string_type, _typer.try_type(identifier("x")));
        si

        Reset__drops_the_local_record() is
            @test()

            build();
            let local = declare_local("x", _int_type);

            _typer.set_local_type(local, _string_type);
            _typer.reset();

            Assert.are_same(_int_type, _typer.try_type(identifier("x")));
        si

        Member_over_declared_receiver__types_as_member() is
            @test()

            build();

            let box = named_class("BOX");
            let member_field = INSTANCE_FIELD(loc(), box, "v");
            member_field.set_type(_int_type);
            box.declare(loc(), member_field, null);

            declare_local("b", box.type);

            Assert.are_same(_int_type, _typer.try_type(member(identifier("b"), "v")));
        si

        Member_over_untyped_receiver__types_as_null() is
            @test()

            build();
            declare_local("b", null);

            Assert.is_null(_typer.try_type(member(identifier("b"), "v")));
        si

        Operator_with_agreeing_candidates__types_as_their_return_type() is
            @test()

            build();

            let group = FUNCTION_GROUP(loc(), _scope, "+");
            let first = GLOBAL_FUNCTION(loc(), loc(), null, "+", null);
            first.return_type = _int_type;
            let second = GLOBAL_FUNCTION(loc(), loc(), null, "+", null);
            second.return_type = _int_type;
            group.add(first);
            group.add(second);
            _scope.declare(loc(), group, null);

            Assert.are_same(_int_type, _typer.try_type(binary("+", integer_literal(), integer_literal())));
        si

        Operator_with_disagreeing_candidates__types_as_null() is
            @test()

            build();

            let group = FUNCTION_GROUP(loc(), _scope, "+");
            let first = GLOBAL_FUNCTION(loc(), loc(), null, "+", null);
            first.return_type = _int_type;
            let second = GLOBAL_FUNCTION(loc(), loc(), null, "+", null);
            second.return_type = _string_type;
            group.add(first);
            group.add(second);
            _scope.declare(loc(), group, null);

            Assert.is_null(_typer.try_type(binary("+", integer_literal(), integer_literal())));
        si

        Operator_with_untyped_operand__types_as_null() is
            @test()

            build();

            let group = FUNCTION_GROUP(loc(), _scope, "+");
            let first = GLOBAL_FUNCTION(loc(), loc(), null, "+", null);
            first.return_type = _int_type;
            group.add(first);
            _scope.declare(loc(), group, null);

            Assert.is_null(_typer.try_type(binary("+", integer_literal(), identifier("missing"))));
        si

        Collecting_candidates__from_a_non_function_symbol__is_undecidable() is
            @test()

            build();

            let candidates = LIST[Semantic.Symbols.Function]();

            Assert.is_false(_typer.try_collect_operator_candidates(named_class("BOX"), candidates));
        si

        Collecting_candidates__from_null__is_decidable_and_empty() is
            @test()

            build();

            let candidates = LIST[Semantic.Symbols.Function]();

            Assert.is_true(_typer.try_collect_operator_candidates(null, candidates));
            Assert.are_equal(0, candidates.count);
        si
    si
si
