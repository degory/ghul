namespace Syntax.Parsers.Expressions.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Syntax.Parsers.Expressions.ASSOCIATIVITY;
    use Syntax.Parsers.Expressions.EXPRESSION;

    class AUTO_ASSOCIATIVITY_TESTS is
        @test()

        init() is si

        Question_first_char_should_be_RIGHT() is
            @test()

            Assert.are_equal(ASSOCIATIVITY.RIGHT, EXPRESSION.auto_associativity_for("??"));
            Assert.are_equal(ASSOCIATIVITY.RIGHT, EXPRESSION.auto_associativity_for("?>"));
            Assert.are_equal(ASSOCIATIVITY.RIGHT, EXPRESSION.auto_associativity_for("?."));
        si

        Other_first_chars_should_be_LEFT() is
            @test()

            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("+"));
            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("-"));
            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("*"));
            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("=="));
            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("/\\"));
            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("\\/"));
            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("::"));
            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("^"));
            Assert.are_equal(ASSOCIATIVITY.LEFT, EXPRESSION.auto_associativity_for("##"));
        si
    si
si
