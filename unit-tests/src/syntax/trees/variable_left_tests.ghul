namespace Syntax.Trees.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Syntax.Trees.Variables;

    // Tests pin two contracts on the variable-left tree:
    //
    // 1. A `LITERAL_VARIABLE_LEFT` is a leaf with no binding: its
    //    `names` iterator is empty, `is_simple_name` is false, and
    //    `elements` is empty. A `for name in left.names` walker
    //    over a destructure containing a literal leaf must therefore
    //    skip the leaf cleanly rather than try to bind a non-name.
    //
    // 2. `mark_refutable_recursive` propagates `is_refutable` to every
    //    leaf of a destructure tree — `if let (a, (b, 1)) = …` needs
    //    every node, including the nested literal leaf, to know it
    //    sits in a refutable context so the refutability-required
    //    plain-`let` rejection at `visit(LITERAL_VARIABLE_LEFT)` doesn't
    //    misfire on it.
    class VARIABLE_LEFT_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        make_int_literal() -> Trees.Expressions.Expression =>
            Trees.Expressions.Literals.INTEGER(loc(), "1");

        make_name(name: string) -> Trees.Identifiers.Identifier =>
            Trees.Identifiers.Identifier(loc(), name);

        LITERAL_VARIABLE_LEFT_has_no_names() is
            @test()

            let leaf = LITERAL_VARIABLE_LEFT(loc(), make_int_literal());

            let names = leaf.names;
            Assert.is_true(names? /\ !names.move_next());
        si

        LITERAL_VARIABLE_LEFT_is_not_a_simple_name() is
            @test()

            let leaf = LITERAL_VARIABLE_LEFT(loc(), make_int_literal());

            Assert.is_false(leaf.is_simple_name);
        si

        LITERAL_VARIABLE_LEFT_get_names_into_adds_nothing() is
            @test()

            let leaf = LITERAL_VARIABLE_LEFT(loc(), make_int_literal());
            let names = Collections.LIST[Trees.Identifiers.Identifier]();

            leaf.get_names_into(names);

            Assert.are_equal(0, names.count);
        si

        mark_refutable_recursive_on_simple_left_sets_only_itself() is
            @test()

            let leaf = SIMPLE_VARIABLE_LEFT(loc(), make_name("v"));

            Assert.is_false(leaf.is_refutable);

            leaf.mark_refutable_recursive();

            Assert.is_true(leaf.is_refutable);
        si

        mark_refutable_recursive_on_destructure_propagates_to_all_leaves() is
            @test()

            // `(a, 1, (b, c))` — two simple bindings, one literal, one
            // nested destructure with two simple bindings.
            let inner = DESTRUCTURING_VARIABLE_LEFT(
                loc(),
                LIST[VariableLeft]([
                    SIMPLE_VARIABLE_LEFT(loc(), make_name("b")),
                    SIMPLE_VARIABLE_LEFT(loc(), make_name("c"))
                ]:VariableLeft)
            );

            let outer = DESTRUCTURING_VARIABLE_LEFT(
                loc(),
                LIST[VariableLeft]([
                    SIMPLE_VARIABLE_LEFT(loc(), make_name("a")),
                    LITERAL_VARIABLE_LEFT(loc(), make_int_literal()),
                    inner
                ]:VariableLeft)
            );

            outer.mark_refutable_recursive();

            Assert.is_true(outer.is_refutable);
            for e in outer.elements do
                Assert.is_true(e.is_refutable);
            od

            for e in inner.elements do
                Assert.is_true(e.is_refutable);
            od
        si
    si
si
