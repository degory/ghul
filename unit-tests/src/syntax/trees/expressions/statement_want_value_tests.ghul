namespace Syntax.Trees.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Trees.Expressions.STATEMENT;
    use Trees.Statements.Statement;
    use StatementList = Trees.Statements.LIST;

    // Pin the AST-level contract of Expressions.STATEMENT.want_value:
    // an `if`/`case` constructed in expression position (the
    // STATEMENT-wrap shape) must demand a value from its inner by
    // default, so a wrapping context that doesn't override it gets
    // the existing behaviour. A `val ... lav` block goes through the
    // same node; the wrapping context (Statements.EXPRESSION.pre or
    // Bodies.EXPRESSION.pre on a void-returning function) is what
    // downgrades to void-tolerant via this field.
    class STATEMENT_WANT_VALUE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_list() -> StatementList
            => StatementList(loc(), LIST[Statement]());

        new_statement() -> STATEMENT
            => STATEMENT(loc(), empty_list());

        STATEMENT__want_value__defaults_to_true_so_value_required_paths_keep_working() is
            @test()

            Assert.is_true(new_statement().want_value);
        si

        STATEMENT__want_value__honours_explicit_downgrade_to_void() is
            @test()

            // A wrapping void-tolerant context (expression-statement
            // position or void-returning `=> body`) writes `false`
            // through the field; the visitor reads that to skip the
            // "expected a value" check and synthesise a void block.
            let s = new_statement();
            s.want_value = false;

            Assert.is_false(s.want_value);
        si

        STATEMENT__clear__resets_want_value_so_repeat_walks_start_clean() is
            @test()

            // clear() is the analysis-mode reset hook; if want_value
            // sticks across walks, a subsequent EDIT compile inherits
            // the downgrade from the previous walk and quietly accepts
            // a value-required misuse.
            let s = new_statement();
            s.want_value = false;
            s.clear();

            Assert.is_true(s.want_value);
        si
    si
si
