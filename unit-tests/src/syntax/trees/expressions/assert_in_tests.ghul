namespace Syntax.Trees.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;

    use Trees.Expressions.ASSERT_IN;
    use Trees.Expressions.SEQUENCE;
    use ExpressionList = Trees.Expressions.LIST;
    use Trees.Expressions.Expression;

    // Pin the AST-level contract of ASSERT_IN: it forwards expected-type
    // shaping to the inner expression (so a constraint pushed onto an
    // assert-in flows into the value it yields), inherits the inner's
    // is_tuple_literal classification, and must_be_consumed is true so a
    // dropped assert-in result is flagged the same way a dropped let-in is.
    class ASSERT_IN_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        empty_elements() -> ExpressionList
            => ExpressionList(loc(), LIST[Expression]());

        new_sequence() -> SEQUENCE
            => SEQUENCE(loc(), empty_elements(), null);

        new_assert_in(inner: Expression) -> ASSERT_IN
            => ASSERT_IN(loc(), new_sequence(), new_sequence(), inner);

        build_animal_class() -> CLASS is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let animal = CLASS(loc(), loc(), null, "animal", empty_names(), false, null);
            animal.add_ancestor(object_class.type);

            return animal;
        si

        ASSERT_IN__must_be_consumed__should_be_true() is
            @test()

            Assert.is_true(new_assert_in(new_sequence()).must_be_consumed);
        si

        ASSERT_IN__description__should_identify_the_form() is
            @test()

            Assert.are_equal("assert in expression", new_assert_in(new_sequence()).description);
        si

        ASSERT_IN__set_expected_type__should_forward_to_inner() is
            @test()

            let animal = build_animal_class();
            let inner = new_sequence();
            let node = new_assert_in(inner);

            node.set_expected_type(animal.type, "expected animal");

            Assert.are_same(animal.type, inner.expected_type);
        si

        ASSERT_IN__clear_expected_type__should_clear_inner() is
            @test()

            let animal = build_animal_class();
            let inner = new_sequence();
            let node = new_assert_in(inner);

            node.set_expected_type(animal.type, "expected animal");
            node.clear_expected_type();

            Assert.is_null(inner.expected_type);
        si

        ASSERT_IN__is_tuple_literal__should_track_inner() is
            @test()

            let inner = new_sequence();
            let node = new_assert_in(inner);

            Assert.are_equal(inner.is_tuple_literal, node.is_tuple_literal);
        si
    si
si
