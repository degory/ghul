namespace Syntax.Trees.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Semantic.Symbols.CLASS;

    use Trees.Expressions.SEQUENCE;
    use ExpressionList = Trees.Expressions.LIST;
    use Trees.Expressions.Expression;

    // Tests for the TypeConstrained contract on Expression subclasses.
    // Constraint storage and the polymorphic `set_constraint` /
    // `clear_constraint` overrides live on concrete subclasses
    // (SEQUENCE, TUPLE, ...). Expression itself ships a default
    // `upgrade_constraint` that calls back through the polymorphic
    // set, so subclasses with real storage get upgrade semantics for
    // free. These tests pin both halves of that arrangement.
    class EXPRESSION_EXPECTED_TYPE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        empty_names() -> LIST[string] => LIST[string]();

        empty_elements() -> ExpressionList
            => ExpressionList(loc(), LIST[Expression]());

        // Build a tiny class hierarchy:
        //
        //   object
        //     └── animal
        //           ├── cat
        //           └── dog
        //
        // Returned as a tuple so each test can pull the single level
        // it needs.
        build_types() -> (animal: CLASS, cat: CLASS, dog: CLASS) is
            let object_class = CLASS(loc(), loc(), null, "object", empty_names(), false, null);
            object_class.mark_is_object();

            let animal = CLASS(loc(), loc(), null, "animal", empty_names(), false, null);
            animal.add_ancestor(object_class.type);

            let cat = CLASS(loc(), loc(), null, "cat", empty_names(), false, null);
            cat.add_ancestor(animal.type);

            let dog = CLASS(loc(), loc(), null, "dog", empty_names(), false, null);
            dog.add_ancestor(animal.type);

            return (animal, cat, dog);
        si

        new_sequence() -> SEQUENCE
            => SEQUENCE(loc(), empty_elements(), null);

        Calling__constraint__on_a_freshly_created_SEQUENCE__should_return_null() is
            @test()

            Assert.is_null(new_sequence().expected_type);
        si

        Calling__set_constraint__should_install_the_supplied_type() is
            @test()

            let h = build_types();
            let seq = new_sequence();

            seq.set_expected_type(h.animal.type, "expected animal");

            Assert.are_same(h.animal.type, seq.expected_type);
        si

        Calling__clear_constraint__after_set__should_drop_the_constraint() is
            @test()

            let h = build_types();
            let seq = new_sequence();

            seq.set_expected_type(h.animal.type, "expected animal");
            seq.clear_expected_type();

            Assert.is_null(seq.expected_type);
        si

        Calling__upgrade_constraint__on_a_clean_node__should_install() is
            @test()

            let h = build_types();
            let seq = new_sequence();

            seq.upgrade_expected_type(h.animal.type, "expected animal");

            Assert.are_same(h.animal.type, seq.expected_type);
        si

        Calling__upgrade_constraint__with_a_narrower_type__should_install() is
            @test()

            let h = build_types();
            let seq = new_sequence();

            seq.set_expected_type(h.animal.type, "expected animal");
            seq.upgrade_expected_type(h.cat.type, "expected cat");

            Assert.are_same(h.cat.type, seq.expected_type);
        si

        Calling__upgrade_constraint__with_a_wider_type__should_be_a_no_op() is
            @test()

            let h = build_types();
            let seq = new_sequence();

            seq.set_expected_type(h.cat.type, "expected cat");
            seq.upgrade_expected_type(h.animal.type, "expected animal");

            Assert.are_same(h.cat.type, seq.expected_type);
        si

        Calling__upgrade_constraint__with_a_sibling_type__should_be_a_no_op() is
            @test()

            // Cat and Dog are unrelated under Animal — neither is
            // assignable from the other — so upgrade should reject
            // the swap.
            let h = build_types();
            let seq = new_sequence();

            seq.set_expected_type(h.cat.type, "expected cat");
            seq.upgrade_expected_type(h.dog.type, "expected dog");

            Assert.are_same(h.cat.type, seq.expected_type);
        si

        Calling__upgrade_constraint__with_null__should_be_a_no_op() is
            @test()

            let h = build_types();
            let seq = new_sequence();

            seq.set_expected_type(h.cat.type, "expected cat");
            seq.upgrade_expected_type(null, null);

            Assert.are_same(h.cat.type, seq.expected_type);
        si
    si
si
