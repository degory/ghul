namespace Syntax.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Expressions = Trees.Expressions;
    use Statements = Trees.Statements;

    use DUMMY = IR.Values.DUMMY;
    use ERROR = Semantic.Types.ERROR;
    use LOCAL_VARIABLE = Semantic.Symbols.LOCAL_VARIABLE;

    // Pins the per-build statement state contract: compile output
    // recorded on statement nodes resets through clear() between
    // builds, and clear_expected_type() keeps its narrower semantics.
    class STATEMENT_STATE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        list() -> Statements.LIST =>
            Statements.LIST(loc(), Collections.LIST[Statements.Statement]());

        if_statement() -> Statements.IF =>
            Statements.IF(loc(), Collections.LIST[Statements.IF_BRANCH]());

        case_statement() -> Statements.CASE =>
            Statements.CASE(loc(), Expressions.NULL(loc()), Collections.LIST[Statements.CASE_MATCH]());

        clear_resets_statement_compile_expressions_state() is
            @test()

            let statement = list();

            statement.compile_expressions_state.value = DUMMY(ERROR(), loc());
            statement.compile_expressions_state.want_value = true;

            Assert.is_true(statement.value?);
            Assert.is_true(statement.want_value);

            statement.clear();

            Assert.is_false(statement.value?);
            Assert.is_false(statement.want_value);
        si

        clear_resets_list_disposal_state() is
            @test()

            let statement = list();

            statement.add_variable_to_dispose(LOCAL_VARIABLE(loc(), null, "v"));

            Assert.is_true(statement.want_dispose);
            Assert.are_equal(1, statement.variables_to_dispose.count);

            statement.clear();

            Assert.is_false(statement.want_dispose);
        si

        if_clear_resets_expected_type_and_chains_to_base() is
            @test()

            let statement = if_statement();

            statement.set_expected_type(ERROR(), "message");
            statement.compile_expressions_state.value = DUMMY(ERROR(), loc());

            Assert.is_true(statement.expected_type?);
            Assert.is_true(statement.expected_type_error_message?);

            statement.clear();

            Assert.is_false(statement.expected_type?);
            Assert.is_false(statement.expected_type_error_message?);
            Assert.is_false(statement.value?);
        si

        case_clear_expected_type_keeps_exhaustiveness_flags() is
            @test()

            let statement = case_statement();

            statement.set_expected_type(ERROR(), "message");
            statement.case_state.is_exhaustive = true;
            statement.case_state.requires_default_fallthrough = true;

            statement.clear_expected_type();

            Assert.is_false(statement.expected_type?);
            Assert.is_false(statement.expected_type_error_message?);
            Assert.is_true(statement.is_exhaustive);
            Assert.is_true(statement.requires_default_fallthrough);
        si

        case_clear_resets_everything() is
            @test()

            let statement = case_statement();

            statement.set_expected_type(ERROR(), "message");
            statement.case_state.is_exhaustive = true;
            statement.case_state.requires_default_fallthrough = true;
            statement.compile_expressions_state.value = DUMMY(ERROR(), loc());

            statement.clear();

            Assert.is_false(statement.expected_type?);
            Assert.is_false(statement.expected_type_error_message?);
            Assert.is_false(statement.is_exhaustive);
            Assert.is_false(statement.requires_default_fallthrough);
            Assert.is_false(statement.value?);
        si
    si
si
