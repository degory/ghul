namespace Syntax.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Expressions = Trees.Expressions;

    use DUMMY = IR.Values.DUMMY;
    use ERROR = Semantic.Types.ERROR;

    // Pins the per-build expression state contract: compile output on
    // expression nodes resets through clear(), expected-type storage is
    // written only by node kinds whose set_expected_type override
    // stores, and every other kind keeps dropping the constraint.
    class EXPRESSION_STATE_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        clear_resets_value_and_call_target() is
            @test()

            let expression = Expressions.NULL(loc());

            expression.compile_expressions_state.value = DUMMY(ERROR(), loc());
            expression.mark_call_target();

            Assert.is_true(expression.value?);
            Assert.is_true(expression.is_call_target);

            expression.clear();

            Assert.is_false(expression.value?);
            Assert.is_false(expression.is_call_target);
        si

        storing_kind_stores_and_clears_expected_type() is
            @test()

            let expression = Expressions.NULL(loc());

            expression.set_expected_type(ERROR(), "message");

            Assert.is_true(expression.expected_type?);
            Assert.is_true(expression.expected_type_error_message?);

            expression.clear_expected_type();

            Assert.is_false(expression.expected_type?);
            Assert.is_false(expression.expected_type_error_message?);
        si

        non_storing_kind_still_drops_the_constraint() is
            @test()

            let expression = Expressions.SELF(loc());

            expression.set_expected_type(ERROR(), "message");

            Assert.is_false(expression.expected_type?);
        si

        clear_expected_type_keeps_value() is
            @test()

            let expression = Expressions.NULL(loc());

            expression.compile_expressions_state.value = DUMMY(ERROR(), loc());
            expression.set_expected_type(ERROR(), "message");

            expression.clear_expected_type();

            Assert.is_true(expression.value?);
            Assert.is_false(expression.expected_type?);
        si
    si
si
