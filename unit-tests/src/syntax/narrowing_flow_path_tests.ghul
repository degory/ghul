namespace Syntax.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Syntax.Process.ACCESS_PATH;
    use Syntax.Process.NARROW_ENV;
    use Syntax.Process.NARROWING_FLOW;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.INSTANCE_PROPERTY;
    use Semantic.Symbols.LOCAL_VARIABLE;
    use Semantic.Symbols.Symbol;

    // Pins the path-fact lifetime rules: every path dies on a
    // possibly-storing call; getter-bearing paths die on any heap
    // store while fields-only paths survive; a member store kills
    // the paths that read through or are rooted at the stored member
    // — receiver-independent, so aliased receivers are covered — and
    // the member's own symbol fact; reassigning a root kills its
    // paths. Also pins the heap epoch the controlled walks consult.
    class NARROWING_FLOW_PATH_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        logger() -> Logging.Logger => Logging.DIAGNOSTICS_STORE();

        owner() -> CLASS => CLASS(loc(), loc(), null, "OWNER", LIST[string](), false, null);

        local_symbol(name: string) -> LOCAL_VARIABLE => LOCAL_VARIABLE(loc(), null, name);

        field_symbol(name: string) -> INSTANCE_FIELD => INSTANCE_FIELD(loc(), owner(), name);

        property_symbol(name: string) -> INSTANCE_PROPERTY =>
            INSTANCE_PROPERTY(loc(), loc(), owner(), name, false, false);

        path(root: Semantic.Symbols.Variable, hops: LIST[Symbol]) -> ACCESS_PATH =>
            ACCESS_PATH(root, hops);

        hops(a: Symbol?, b: Symbol?) -> LIST[Symbol] is
            let result = LIST[Symbol]();
            if a? then result.add(a); fi
            if b? then result.add(b); fi
            return result;
        si

        flow_with_paths(paths: Collections.Iterable[ACCESS_PATH]) -> NARROWING_FLOW is
            let flow = NARROWING_FLOW(logger());
            let env = NARROW_ENV();

            for p in paths do
                env.set_non_null_path(p);
            od

            flow.set_env(env);

            return flow;
        si

        Call_transfer__forgets_every_path() is
            @test()

            let x = local_symbol("x");
            let f = field_symbol("f");
            let p = property_symbol("p");

            let fields_only = path(x, hops(f, null));
            let getter_bearing = path(x, hops(p, null));

            let flow = flow_with_paths([fields_only, getter_bearing]);

            flow.on_call(loc());

            Assert.is_false(flow.is_non_null_path(fields_only));
            Assert.is_false(flow.is_non_null_path(getter_bearing));
        si

        Heap_store_transfer__forgets_getter_bearing_paths_only() is
            @test()

            let x = local_symbol("x");
            let f = field_symbol("f");
            let g = field_symbol("g");
            let p = property_symbol("p");

            let fields_only = path(x, hops(f, g));
            let getter_bearing = path(x, hops(f, p));

            let flow = flow_with_paths([fields_only, getter_bearing]);

            flow.on_heap_store(loc());

            Assert.is_true(flow.is_non_null_path(fields_only));
            Assert.is_false(flow.is_non_null_path(getter_bearing));
        si

        Member_store_transfer__forgets_paths_through_the_member_on_any_receiver() is
            @test()

            let x = local_symbol("x");
            let y = local_symbol("y");
            let f = field_symbol("f");
            let g = field_symbol("g");
            let other = field_symbol("other");

            let through_f = path(x, hops(f, g));
            let also_through_f = path(y, hops(g, f));
            let unrelated = path(x, hops(g, other));

            let flow = flow_with_paths([through_f, also_through_f, unrelated]);

            flow.on_member_store(f);

            Assert.is_false(flow.is_non_null_path(through_f));
            Assert.is_false(flow.is_non_null_path(also_through_f));
            Assert.is_true(flow.is_non_null_path(unrelated));
        si

        Member_store_transfer__forgets_the_members_own_symbol_fact() is
            @test()

            let f = field_symbol("f");

            let flow = NARROWING_FLOW(logger());
            let env = NARROW_ENV();
            env.set_non_null(f);
            flow.set_env(env);

            flow.on_member_store(f);

            Assert.is_false(flow.is_non_null(f));
        si

        Member_store_transfer__forgets_paths_rooted_at_a_field_root() is
            @test()

            let f = field_symbol("f");
            let g = field_symbol("g");

            let rooted_at_f = path(f, hops(g, null));

            let flow = flow_with_paths([rooted_at_f]);

            flow.on_member_store(f);

            Assert.is_false(flow.is_non_null_path(rooted_at_f));
        si

        Assignment_transfer__forgets_paths_rooted_at_the_target() is
            @test()

            let x = local_symbol("x");
            let y = local_symbol("y");
            let f = field_symbol("f");

            let rooted_at_x = path(x, hops(f, null));
            let rooted_at_y = path(y, hops(f, null));

            let flow = flow_with_paths([rooted_at_x, rooted_at_y]);

            flow.on_assignment(x, loc(), null);

            Assert.is_false(flow.is_non_null_path(rooted_at_x));
            Assert.is_true(flow.is_non_null_path(rooted_at_y));
        si

        Assignment_transfer__to_a_field_forgets_paths_through_it() is
            @test()

            let x = local_symbol("x");
            let f = field_symbol("f");
            let g = field_symbol("g");

            let through_f = path(x, hops(g, f));

            let flow = flow_with_paths([through_f]);

            flow.on_assignment(f, loc(), null);

            Assert.is_false(flow.is_non_null_path(through_f));
        si

        Env_copy_and_join__paths_survive_copy_and_join_by_intersection() is
            @test()

            let x = local_symbol("x");
            let f = field_symbol("f");
            let g = field_symbol("g");

            let common = path(x, hops(f, null));
            let only_a = path(x, hops(g, null));

            let a = NARROW_ENV();
            a.set_non_null_path(common);
            a.set_non_null_path(only_a);

            let b = a.copy();
            Assert.is_true(b.is_non_null_path(common));
            Assert.is_true(b.is_non_null_path(only_a));

            let c = NARROW_ENV();
            c.set_non_null_path(common);

            let joined = NARROW_ENV.join(a, c);
            Assert.is_true(joined.is_non_null_path(common));
            Assert.is_false(joined.is_non_null_path(only_a));
        si

        Drop_heap_facts__spares_local_facts_only() is
            @test()

            let x = local_symbol("x");
            let f = field_symbol("f");
            let p = property_symbol("p");

            let env = NARROW_ENV();
            env.set_non_null(x);
            env.set_non_null(f);
            env.set_non_null(p);
            env.set_non_null_path(path(x, hops(f, null)));

            env.drop_heap_facts();

            Assert.is_true(env.is_non_null(x));
            Assert.is_false(env.is_non_null(f));
            Assert.is_false(env.is_non_null(p));
            Assert.is_false(env.is_non_null_path(path(x, hops(f, null))));
        si

        Heap_epoch__bumps_on_every_kill_transfer() is
            @test()

            let flow = NARROWING_FLOW(logger());
            let start = flow.heap_epoch;

            Assert.is_false(flow.heap_killed_since(start));

            flow.on_call(loc());
            Assert.is_true(flow.heap_killed_since(start));

            let after_call = flow.heap_epoch;
            flow.on_heap_store(loc());
            Assert.is_true(flow.heap_killed_since(after_call));

            let after_store = flow.heap_epoch;
            flow.on_member_store(field_symbol("f"));
            Assert.is_true(flow.heap_killed_since(after_store));
        si
    si
si
