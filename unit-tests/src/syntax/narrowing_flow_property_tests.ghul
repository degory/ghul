namespace Syntax.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;

    use Syntax.Process.NARROW_ENV;
    use Syntax.Process.NARROWING_FLOW;

    use Semantic.Symbols.CLASS;
    use Semantic.Symbols.INSTANCE_FIELD;
    use Semantic.Symbols.INSTANCE_PROPERTY;
    use Semantic.Symbols.LOCAL_VARIABLE;

    // Pins the flow transfers' kill asymmetry across the three
    // narrowing subject kinds: locals survive everything short of
    // their own reassignment, fields die on calls but survive stores
    // to other slots, properties die on both calls and heap stores.
    class NARROWING_FLOW_PROPERTY_TESTS is
        @test()

        init() is si

        loc() -> LOCATION => LOCATION("test.ghul", 1, 1, 1, 1);

        owner() -> CLASS => CLASS(loc(), loc(), null, "OWNER", LIST[string](), false, null);

        local_symbol() -> LOCAL_VARIABLE => LOCAL_VARIABLE(loc(), null, "l");

        field_symbol() -> INSTANCE_FIELD => INSTANCE_FIELD(loc(), owner(), "f");

        property_symbol() -> INSTANCE_PROPERTY =>
            INSTANCE_PROPERTY(loc(), loc(), owner(), "p", false, false);

        flow_with_non_null(symbols: Collections.Iterable[Semantic.Symbols.Symbol]) -> NARROWING_FLOW is
            let flow = NARROWING_FLOW();
            let env = NARROW_ENV();

            for s in symbols do
                env.set_non_null(s);
            od

            flow.set_env(env);

            return flow;
        si

        Call_transfer__forgets_fields_and_properties_but_not_locals() is
            @test()

            let l = local_symbol();
            let f = field_symbol();
            let p = property_symbol();

            let flow = flow_with_non_null([cast Semantic.Symbols.Symbol(l), cast Semantic.Symbols.Symbol(f), cast Semantic.Symbols.Symbol(p)]);

            flow.on_call();

            Assert.is_true(flow.is_non_null(l));
            Assert.is_false(flow.is_non_null(f));
            Assert.is_false(flow.is_non_null(p));
        si

        Heap_store_transfer__forgets_properties_only() is
            @test()

            let l = local_symbol();
            let f = field_symbol();
            let p = property_symbol();

            let flow = flow_with_non_null([cast Semantic.Symbols.Symbol(l), cast Semantic.Symbols.Symbol(f), cast Semantic.Symbols.Symbol(p)]);

            flow.on_heap_store();

            Assert.is_true(flow.is_non_null(l));
            Assert.is_true(flow.is_non_null(f));
            Assert.is_false(flow.is_non_null(p));
        si

        Assignment_transfer__forgets_only_the_target() is
            @test()

            let f = field_symbol();
            let p = property_symbol();

            let flow = flow_with_non_null([cast Semantic.Symbols.Symbol(f), cast Semantic.Symbols.Symbol(p)]);

            flow.on_assignment(p);

            Assert.is_true(flow.is_non_null(f));
            Assert.is_false(flow.is_non_null(p));
        si
    si
si
