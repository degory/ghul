namespace Source.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    class LOCATION_CONTAINS_TESTS is
        @test()

        init() is si

        location(file_name: string, start_line: int, start_column: int, end_line: int, end_column: int) -> Source.LOCATION =>
            Source.LOCATION(file_name, start_line, start_column, end_line, end_column);

        same_file_outer_strictly_contains_inner__contains__should_be_true() is
            @test()

            let outer = location("a.ghul", 1, 5, 1, 20);
            let inner = location("a.ghul", 1, 8, 1, 12);

            Assert.is_true(outer.contains(inner));
        si

        same_file_equal_extent__contains__should_be_true__contains_is_non_strict() is
            @test()

            let outer = location("a.ghul", 1, 5, 1, 20);
            let inner = location("a.ghul", 1, 5, 1, 20);

            Assert.is_true(outer.contains(inner));
        si

        inner_starts_before_outer__contains__should_be_false() is
            @test()

            let outer = location("a.ghul", 1, 5, 1, 20);
            let inner = location("a.ghul", 1, 3, 1, 10);

            Assert.is_false(outer.contains(inner));
        si

        inner_ends_after_outer__contains__should_be_false() is
            @test()

            let outer = location("a.ghul", 1, 5, 1, 20);
            let inner = location("a.ghul", 1, 10, 1, 25);

            Assert.is_false(outer.contains(inner));
        si

        spans_cross_lines_outer_contains_inner__contains__should_be_true() is
            @test()

            // outer spans lines 1-3, inner is on line 2 within
            let outer = location("a.ghul", 1, 1, 3, 30);
            let inner = location("a.ghul", 2, 5, 2, 10);

            Assert.is_true(outer.contains(inner));
        si

        spans_cross_lines_inner_outside__contains__should_be_false() is
            @test()

            let outer = location("a.ghul", 2, 1, 2, 30);
            let inner = location("a.ghul", 3, 5, 3, 10);

            Assert.is_false(outer.contains(inner));
        si

        different_files__contains__should_be_false() is
            @test()

            let outer = location("a.ghul", 1, 1, 100, 100);
            let inner = location("b.ghul", 1, 10, 1, 20);

            Assert.is_false(outer.contains(inner));
        si

        same_file_outer_wider_on_both_sides__strictly_contains__should_be_true() is
            @test()

            let outer = location("a.ghul", 1, 5, 1, 20);
            let inner = location("a.ghul", 1, 8, 1, 12);

            Assert.is_true(outer.strictly_contains(inner));
        si

        same_file_equal_extent__strictly_contains__should_be_false() is
            @test()

            let outer = location("a.ghul", 1, 5, 1, 20);
            let inner = location("a.ghul", 1, 5, 1, 20);

            Assert.is_false(outer.strictly_contains(inner));
        si

        same_start_but_outer_extends_further__strictly_contains__should_be_true() is
            @test()

            let outer = location("a.ghul", 1, 5, 1, 20);
            let inner = location("a.ghul", 1, 5, 1, 15);

            Assert.is_true(outer.strictly_contains(inner));
        si

        same_end_but_outer_starts_earlier__strictly_contains__should_be_true() is
            @test()

            let outer = location("a.ghul", 1, 5, 1, 20);
            let inner = location("a.ghul", 1, 10, 1, 20);

            Assert.is_true(outer.strictly_contains(inner));
        si

        spans_cross_lines_outer_wider__strictly_contains__should_be_true() is
            @test()

            let outer = location("a.ghul", 1, 1, 3, 30);
            let inner = location("a.ghul", 2, 5, 2, 10);

            Assert.is_true(outer.strictly_contains(inner));
        si

        different_files__strictly_contains__should_be_false() is
            @test()

            let outer = location("a.ghul", 1, 1, 100, 100);
            let inner = location("b.ghul", 1, 10, 1, 20);

            Assert.is_false(outer.strictly_contains(inner));
        si
    si
si
