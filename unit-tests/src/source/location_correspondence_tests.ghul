namespace Source.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;
    use Source.LOCATION_CORRESPONDENCE;

    // LOCATION_CORRESPONDENCE is the exact pre-edit -> post-edit location
    // map an incremental EDIT's reconciliation walk produces. It is keyed
    // on the pre-edit location's (start, end) pair, so a query with a
    // distinct LOCATION object that is value-equal to a recorded one still
    // resolves — which is how a stale side-table entry is translated.
    class LOCATION_CORRESPONDENCE_TESTS is
        @test()

        init() is si

        loc(start_line: int, start_column: int, end_line: int, end_column: int) -> LOCATION =>
            LOCATION("test.ghul", start_line, start_column, end_line, end_column);

        translate_returns_the_new_location_for_a_recorded_old_location() is
            @test()

            let correspondence = LOCATION_CORRESPONDENCE();
            correspondence.add(loc(5, 4, 5, 9), loc(8, 4, 8, 9));

            // a distinct LOCATION object, value-equal to the recorded one
            let result = correspondence.translate(loc(5, 4, 5, 9));

            Assert.is_not_null(result);
            Assert.are_equal(8, result.start_line);
            Assert.are_equal(8, result.end_line);
        si

        translate_returns_null_for_an_unrecorded_location() is
            @test()

            let correspondence = LOCATION_CORRESPONDENCE();
            correspondence.add(loc(5, 4, 5, 9), loc(8, 4, 8, 9));

            Assert.is_null(correspondence.translate(loc(6, 4, 6, 9)));
        si

        // Two entries that share a start but end differently — a node and
        // a child node can begin at the same column — are kept apart; the
        // end is part of the key.
        entries_sharing_a_start_are_distinguished_by_end() is
            @test()

            let correspondence = LOCATION_CORRESPONDENCE();
            correspondence.add(loc(5, 4, 5, 9), loc(8, 4, 8, 9));
            correspondence.add(loc(5, 4, 5, 20), loc(8, 4, 8, 25));

            let shorter = correspondence.translate(loc(5, 4, 5, 9));
            let longer = correspondence.translate(loc(5, 4, 5, 20));

            Assert.is_not_null(shorter);
            Assert.is_not_null(longer);
            Assert.are_equal(9, shorter.end_column);
            Assert.are_equal(25, longer.end_column);
        si

        empty_correspondence_translates_nothing() is
            @test()

            let correspondence = LOCATION_CORRESPONDENCE();

            Assert.is_null(correspondence.translate(loc(1, 1, 1, 1)));
        si
    si
si
