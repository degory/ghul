namespace Source.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;
    use Source.BODY_SPANS;

    // BODY_SPANS holds the pre-edit spans of the function bodies an
    // incremental EDIT re-walks. `contains` answers whether a recorded
    // symbol-use / definition position falls inside one — such an entry is
    // re-recorded by the re-walk, so reconciliation drops it.
    class BODY_SPANS_TESTS is
        @test()

        init() is si

        // A body spanning the given lines, full-width.
        span(start_line: int, end_line: int) -> LOCATION =>
            LOCATION("test.ghul", start_line, 0, end_line, 80);

        // A packed position at the given line, column 4.
        at(line: int) -> int => LOCATION.pair(line, 4);

        position_inside_a_span_is_contained() is
            @test()

            let spans = BODY_SPANS();
            spans.add(span(5, 8));

            Assert.is_true(spans.contains(at(5)), "body start line");
            Assert.is_true(spans.contains(at(7)), "line within body");
            Assert.is_true(spans.contains(at(8)), "body end line");
        si

        position_outside_every_span_is_not_contained() is
            @test()

            let spans = BODY_SPANS();
            spans.add(span(5, 8));

            Assert.is_false(spans.contains(at(3)), "line above the body");
            Assert.is_false(spans.contains(at(12)), "line below the body");
        si

        // Spans may be registered out of source order; the set sorts them
        // before answering.
        spans_registered_out_of_order_are_still_found() is
            @test()

            let spans = BODY_SPANS();
            spans.add(span(20, 25));
            spans.add(span(5, 8));

            Assert.is_true(spans.contains(at(6)), "first body by line, added second");
            Assert.is_true(spans.contains(at(22)), "second body by line, added first");
            Assert.is_false(spans.contains(at(15)), "the gap between the two bodies");
        si

        empty_spans_contain_nothing() is
            @test()

            let spans = BODY_SPANS();

            Assert.is_false(spans.contains(at(5)));
        si
    si
si
