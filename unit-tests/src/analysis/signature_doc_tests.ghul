namespace Analysis.UnitTests is
    use Collections.LIST;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // SIGNATURE_DOC walks the structured parts of a Function-like or
    // Variant symbol and lays them out against a column budget. The
    // parts-based entries (`build_function`, `build_variant`) let these
    // tests supply the pieces as plain strings — the symbol-walking
    // entry composes them with the same layout code.
    class SIGNATURE_DOC_TESTS is
        @test()

        init() is si

        list(items: string[]) -> LIST[string] is
            let result = LIST[string]();
            for i in items do
                result.add(i);
            od
            return result;
        si

        empty_list() -> LIST[string] => LIST[string]();

        // No arguments — the signature stays on one line even at very
        // narrow budgets. Nothing to break.
        function_with_no_arguments_stays_flat() is
            @test()

            let result = SIGNATURE_DOC.build_function(
                "Namespace.HELPER.reset",
                empty_list(),
                empty_list(),
                empty_list(),
                "Ghul.void",
                20
            );

            Assert.are_equal("Namespace.HELPER.reset() -> Ghul.void", result);
        si

        // Arguments fit within the budget — group renders flat.
        function_with_arguments_that_fit_stays_flat() is
            @test()

            let result = SIGNATURE_DOC.build_function(
                "Foo.bar",
                empty_list(),
                list(["x", "y"]),
                list(["Ghul.int", "Ghul.int"]),
                "Ghul.int",
                60
            );

            Assert.are_equal("Foo.bar(x: Ghul.int, y: Ghul.int) -> Ghul.int", result);
        si

        // Arguments overflow the budget — group breaks; each argument
        // sits on its own indented line, the return type follows the
        // closing paren on the outer indent.
        function_with_long_arguments_breaks_onto_multiple_lines() is
            @test()

            let result = SIGNATURE_DOC.build_function(
                "Foo.compile_expression_with_context",
                empty_list(),
                list(["context", "expected_type", "previous", "budget"]),
                list(["CONTEXT", "Type?", "LIST[Value]?", "Ghul.int"]),
                "Value?",
                60
            );

            let expected =
                "Foo.compile_expression_with_context(\n"
                "    context: CONTEXT,\n"
                "    expected_type: Type?,\n"
                "    previous: LIST[Value]?,\n"
                "    budget: Ghul.int\n"
                ") -> Value?";

            Assert.are_equal(expected, result);
        si

        // Generic argument brackets emit inline before the paren list.
        // Their contents are single-token; no per-slot wrapping.
        generic_arguments_render_inline() is
            @test()

            let result = SIGNATURE_DOC.build_function(
                "Namespace.HELPER.map",
                list(["T", "U", "V"]),
                list(["xs", "f", "g"]),
                list(["Iterable[T]", "T -> U", "U -> V"]),
                "Iterable[V]",
                60
            );

            let expected =
                "Namespace.HELPER.map[T,U,V](\n"
                "    xs: Iterable[T],\n"
                "    f: T -> U,\n"
                "    g: U -> V\n"
                ") -> Iterable[V]";

            Assert.are_equal(expected, result);
        si

        // A constructor has no return type: `build_function` is called
        // with `return_type: null`. The trailing ` -> …` is omitted.
        function_with_null_return_type_omits_the_arrow() is
            @test()

            let result = SIGNATURE_DOC.build_function(
                "Foo.init",
                empty_list(),
                list(["first", "second"]),
                list(["Ghul.int", "Ghul.string"]),
                null,
                60
            );

            Assert.are_equal("Foo.init(first: Ghul.int, second: Ghul.string)", result);
        si

        // Variant fields render like arguments: `variant qname(...)`.
        variant_with_fields_uses_the_same_layout_as_a_call() is
            @test()

            let result = SIGNATURE_DOC.build_variant(
                "Namespace.SHAPE.RECTANGLE",
                list(["width", "height", "label"]),
                list(["Ghul.double", "Ghul.double", "Ghul.string?"]),
                60
            );

            let expected =
                "variant Namespace.SHAPE.RECTANGLE(\n"
                "    width: Ghul.double,\n"
                "    height: Ghul.double,\n"
                "    label: Ghul.string?\n"
                ")";

            Assert.are_equal(expected, result);
        si

        // A member whose type is a multi-argument function type is
        // never reachable through `build_function` — the symbol-dispatch
        // entry routes properties/variables to their pre-computed
        // single-line signature, so no risk of mis-treating the type's
        // parens as an argument list.
    si
si
