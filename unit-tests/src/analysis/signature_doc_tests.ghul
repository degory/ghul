namespace Analysis.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // SIGNATURE_DOC lays out a single-line hover signature against a
    // column budget, breaking the outer argument list onto per-argument
    // lines when the whole line does not fit. Signatures that fit or
    // that have no top-level argument list pass through unchanged.
    class SIGNATURE_DOC_TESTS is
        @test()

        init() is si

        signature_that_fits_the_budget_is_returned_unchanged() is
            @test()

            let signature = "Foo.bar(x: int, y: int) -> int";

            Assert.are_equal(signature, SIGNATURE_DOC.build(signature, 60));
        si

        signature_that_exceeds_the_budget_breaks_the_argument_list() is
            @test()

            let signature = "Foo.compile_expression_with_context(context: CONTEXT, expected_type: Type?, previous: LIST[Value]?) -> Value?";

            let expected =
                "Foo.compile_expression_with_context(\n"
                "    context: CONTEXT,\n"
                "    expected_type: Type?,\n"
                "    previous: LIST[Value]?\n"
                ") -> Value?";

            Assert.are_equal(expected, SIGNATURE_DOC.build(signature, 60));
        si

        // Generic type arguments in the head must not be mistaken for
        // the argument list even though they contain commas.
        generic_argument_brackets_do_not_split_the_head() is
            @test()

            let signature = "Namespace.HELPER.map[T, U, V](xs: Iterable[T], f: T -> U, g: U -> V) -> Iterable[V]";

            let expected =
                "Namespace.HELPER.map[T, U, V](\n"
                "    xs: Iterable[T],\n"
                "    f: T -> U,\n"
                "    g: U -> V\n"
                ") -> Iterable[V]";

            Assert.are_equal(expected, SIGNATURE_DOC.build(signature, 60));
        si

        // Tuple types inside an argument (nested parens) stay flat —
        // only the outermost `(...)` breaks.
        nested_parens_in_arguments_stay_flat() is
            @test()

            let signature = "Foo.process(pair: (int, string), lookup: LIST[(int, string)]) -> void";

            let expected =
                "Foo.process(\n"
                "    pair: (int, string),\n"
                "    lookup: LIST[(int, string)]\n"
                ") -> void";

            Assert.are_equal(expected, SIGNATURE_DOC.build(signature, 60));
        si

        // A property has no `(...)` — even if it overflows, nothing to
        // wrap, return unchanged.
        signature_without_parens_is_returned_unchanged() is
            @test()

            let signature = "Namespace.LONG_CLASS.some_very_long_property_name: SomeReallyLongTypeName";

            Assert.are_equal(signature, SIGNATURE_DOC.build(signature, 40));
        si

        // A class header has no `(...)` either.
        class_header_is_returned_unchanged() is
            @test()

            Assert.are_equal("class Foo", SIGNATURE_DOC.build("class Foo", 60));
        si

        // A zero-argument call still fits — no wrap needed even if the
        // signature exceeds the budget on the head alone (nothing to
        // wrap; the outer `(...)` is empty).
        zero_argument_call_with_long_head_returns_unchanged() is
            @test()

            let signature = "Very.Long.Namespace.Path.With.Many.Segments.leaf() -> Result";

            Assert.are_equal(signature, SIGNATURE_DOC.build(signature, 40));
        si

        // A member whose type is a multi-argument function type
        // renders as `name: (A, B) -> C` — the `(A, B)` belongs to the
        // type, not to the member. Wrapping it would print a
        // non-callable member as if it took two arguments, so the
        // signature passes through unchanged even when it overflows.
        function_typed_member_is_not_mis_wrapped_as_a_call() is
            @test()

            let signature = "Ghul.Symbols.GENERIC_ARGUMENT.override: (Symbol, StringBuilder) -> void";

            Assert.are_equal(signature, SIGNATURE_DOC.build(signature, 40));
        si

        // A variant with fields uses the same shape as a function call.
        variant_with_fields_breaks_the_field_list() is
            @test()

            let signature = "variant Namespace.SHAPE.RECTANGLE(width: double, height: double, label: string?)";

            let expected =
                "variant Namespace.SHAPE.RECTANGLE(\n"
                "    width: double,\n"
                "    height: double,\n"
                "    label: string?\n"
                ")";

            Assert.are_equal(expected, SIGNATURE_DOC.build(signature, 60));
        si
    si
si
