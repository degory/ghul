namespace Analysis.UnitTests is
    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    use Source.LOCATION;
    use Collections.LIST;
    use Collections.Iterable;

    use Logging.DIAGNOSTIC_MESSAGE;
    use Logging.DiagnosticSeverity;

    use Analysis.NARROWING_INLAY_MERGER;

    class NARROWING_INLAY_MERGER_TESTS is
        @test()

        init() is si

        loc(line: int, column: int) -> LOCATION => LOCATION("test.ghul", line, column, line, column + 1);

        inlay(line: int, column: int, code: string, detail: string) -> DIAGNOSTIC_MESSAGE =>
            DIAGNOSTIC_MESSAGE(true, true, DiagnosticSeverity.INLAY, loc(line, column), code, "►", detail);

        kill(line: int, column: int, detail: string) -> DIAGNOSTIC_MESSAGE =>
            DIAGNOSTIC_MESSAGE(true, true, DiagnosticSeverity.INLAY, loc(line, column), "narrowing-killed", "◄", detail);

        merge(carriers: Iterable[DIAGNOSTIC_MESSAGE]) -> LIST[DIAGNOSTIC_MESSAGE] =>
            NARROWING_INLAY_MERGER().merge(carriers);

        isa_pair_at_one_site_merges_into_one_hint() is
            @test()

            let merged = merge([
                inlay(3, 5, "narrowing-isa", "CONS[int]"),
                inlay(3, 5, "narrowing-isa-complement", "NIL")
            ]);

            Assert.are_equal(1, merged.count, "the true/false edge pair should collapse to one hint");
            Assert.are_equal("narrowing-isa", merged[0].code, "the merged hint keeps the base slug");
            Assert.are_equal("► CONS[int]\n> NIL", merged[0].detail);
            Assert.are_equal("►", merged[0].text, "the ghost-text label stays the sigil");
        si

        single_edge_renders_the_type_alone() is
            @test()

            let merged = merge([inlay(1, 1, "narrowing-presence", "Cat")]);

            Assert.are_equal(1, merged.count);
            Assert.are_equal("► Cat", merged[0].detail);
        si

        if_let_pair_merges_on_the_base_slug() is
            @test()

            let merged = merge([
                inlay(2, 2, "narrowing-if-let", "CONS[int]"),
                inlay(2, 2, "narrowing-if-let-complement", "NIL")
            ]);

            Assert.are_equal(1, merged.count);
            Assert.are_equal("► CONS[int]\n> NIL", merged[0].detail);
        si

        default_variant_pair_merges_on_the_base_slug() is
            @test()

            let merged = merge([
                inlay(4, 3, "narrowing-default-variant", "SOME[int]"),
                inlay(4, 3, "narrowing-default-variant-complement", "NONE")
            ]);

            Assert.are_equal(1, merged.count);
            Assert.are_equal("► SOME[int]\n> NONE", merged[0].detail);
        si

        edges_pair_regardless_of_emission_order() is
            @test()

            // The if-let complement is emitted after the then-body walk, so
            // the false edge can arrive first relative to unrelated inlays;
            // pairing keys on location and slug, not adjacency.
            let merged = merge([
                inlay(7, 1, "narrowing-isa-complement", "NIL"),
                inlay(7, 1, "narrowing-isa", "CONS[int]")
            ]);

            Assert.are_equal(1, merged.count);
            Assert.are_equal("► CONS[int]\n> NIL", merged[0].detail);
        si

        distinct_locations_stay_separate() is
            @test()

            let merged = merge([
                inlay(1, 1, "narrowing-isa", "CAT"),
                inlay(2, 1, "narrowing-isa", "DOG")
            ]);

            Assert.are_equal(2, merged.count, "same slug at different sites must not merge");
        si

        distinct_constructs_at_one_site_stay_separate() is
            @test()

            // `x?` on a default-variant union emits both a presence strip
            // and a default-variant narrow at the same column; they narrow
            // to different things, so they stay two markers.
            let merged = merge([
                inlay(5, 4, "narrowing-presence", "Cat"),
                inlay(5, 4, "narrowing-default-variant", "SOME[int]")
            ]);

            Assert.are_equal(2, merged.count);
        si

        kill_hints_pass_through_unchanged() is
            @test()

            let merged = merge([kill(9, 2, "a no longer narrowed to CAT: reassigned")]);

            Assert.are_equal(1, merged.count);
            Assert.are_equal("◄", merged[0].text, "kill hints keep their own sigil");
            Assert.are_equal("a no longer narrowed to CAT: reassigned", merged[0].detail, "kill hints are not reshaped");
        si
    si
si
