namespace Semantic.DotNet is
    use IO.Std;

    use Collections.SET;

    class REFERENCED_ASSEMBLIES(boilerplate_generator: IR.BOILERPLATE_GENERATOR, assemblies: ASSEMBLIES) is
        _boilerplate_generator;
        _assemblies;

        _references: SET[REFERENCED_ASSEMBLY];

        init(..) is
            _references = SET();
        si

        add(name: string, version: string) is
            _references.add(REFERENCED_ASSEMBLY(name, version));
        si

        gen() is            
            for reference in _references | .filter(reference => !_assemblies.blocked_assemblies.contains(reference.name)) do
                _boilerplate_generator.gen("assembly-reference", [reference.name, reference.version]);
            od
        si        
    si
    
    struct REFERENCED_ASSEMBLY(name: string, version: string) is
        name;
        version;

        to_string() -> string =>
            "[{name} {version}]";
    si
si
