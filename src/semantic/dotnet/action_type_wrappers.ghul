namespace Semantic.DotNet is
    use IO.Std;

    use TYPE = System.Type;
    use Collections.List;
    use Collections.LIST;

    use Source.LOCATION;

    use Types.Type;

    class ACTION_0_TYPE_WRAPPER(
        symbol_table: SYMBOL_TABLE,
        dotnet_type: TYPE
    ): TYPE_WRAPPER is
        is_action: bool => true;
        is_function: bool => true;

        short_description: string  => "() -> void";

        super(symbol_table, dotnet_type);

        to_string() -> string => short_description;
    si

    class ACTION_TYPE_WRAPPER(
        symbol_table: SYMBOL_TABLE,
        type_mapper: TYPE_MAPPER,
        dotnet_type: TYPE
    ): GENERIC_TYPE_WRAPPER is
        is_action: bool => true;
        is_function: bool => true;

        short_description: string => Types.ACTION.get_short_description(self);

        super(symbol_table, type_mapper, dotnet_type);

        create(
            location: LOCATION,
            symbol: Symbols.Classy,
            arguments: Collections.List[Type]
        ) -> Types.GENERIC =>
             Types.ACTION(location, symbol, arguments);

        to_string() -> string => Types.ACTION.get_short_description(self);
    si

    class HYBRID_ACTION_TYPE_WRAPPER: HYBRID_GENERIC_TYPE_WRAPPER is
        is_action: bool => true;
        is_function: bool => true;
        short_description: string => Types.ACTION.get_short_description(self);

        init(
            symbol_table: SYMBOL_TABLE,
            dotnet_type: TYPE,
            arguments: List[Type]
        ) is
            super.init(
                symbol_table,
                dotnet_type,
                arguments
            );
        si

        init(
            symbol_table: SYMBOL_TABLE,
            dotnet_type: TYPE,
            argument: Type
        ) is
            super.init(
                symbol_table,
                dotnet_type,
                argument
            );
        si

        to_string() -> string => Types.ACTION.get_short_description(self);
    si
si
