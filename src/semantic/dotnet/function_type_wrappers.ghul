namespace Semantic.DotNet is
    use IO.Std;

    use TYPE = System.Type;
    use Collections.List;

    use Source.LOCATION;

    use Types.Type;
    
    class FUNCTION_TYPE_WRAPPER(
        symbol_table: SYMBOL_TABLE,
        type_mapper: TYPE_MAPPER,
        dotnet_type: TYPE
    ): GENERIC_TYPE_WRAPPER is
        is_function: bool => true;

        short_description: string => Types.FUNCTION.get_short_description(self);

        super(symbol_table, type_mapper, dotnet_type);

        get_argument_type_variance(index: int) -> Types.TypeVariance =>
            // FIXME almost certainly never called

            if index == arguments.count - 1 then
                Types.TypeVariance.COVARIANT;
            else
                Types.TypeVariance.CONTRAVARIANT;
            fi;
        
        create(
            location: LOCATION,
            symbol: Symbols.Classy,
            arguments: Collections.List[Type]
        ) -> Types.GENERIC =>
            Types.FUNCTION(location, symbol, arguments);
            
        to_string() -> string => Types.FUNCTION.get_short_description(self);
    si

    class HYBRID_FUNCTION_TYPE_WRAPPER: HYBRID_GENERIC_TYPE_WRAPPER is
        is_function: bool => true;

        short_description: string => Types.FUNCTION.get_short_description(self);
        
        init(
            symbol_table: SYMBOL_TABLE,
            dotnet_type: TYPE,
            arguments: List[Type]
        ) is
            super.init(
                symbol_table,
                dotnet_type,
                arguments
            );
        si

        init(
            symbol_table: SYMBOL_TABLE,
            dotnet_type: TYPE,
            argument: Type
        ) is
            super.init(
                symbol_table,
                dotnet_type,
                argument
            );
        si

        get_argument_type_variance(index: int) -> Types.TypeVariance =>
            if index == arguments.count - 1 then
                Types.TypeVariance.COVARIANT;
            else
                Types.TypeVariance.CONTRAVARIANT;
            fi;
        
        create(
            location: LOCATION,
            symbol: Symbols.Classy,
            arguments: Collections.List[Type]
        ) -> Types.GENERIC =>
            Types.FUNCTION(location, symbol, arguments);

        to_string() -> string => Types.FUNCTION.get_short_description(self);
    si

    // The `pure`-marked shape of HYBRID_FUNCTION_TYPE_WRAPPER; see
    // Types.PURE_FUNCTION for the semantics. `create` reproduces the
    // pure kind so the flag survives generic specialization.
    class PURE_HYBRID_FUNCTION_TYPE_WRAPPER: HYBRID_FUNCTION_TYPE_WRAPPER is
        is_pure_function: bool => true;

        short_description: string => "{Types.FUNCTION.get_short_description(self)} pure";

        init(
            symbol_table: SYMBOL_TABLE,
            dotnet_type: TYPE,
            arguments: List[Type]
        ) is
            super.init(symbol_table, dotnet_type, arguments);
        si

        create(
            location: LOCATION,
            symbol: Symbols.Classy,
            arguments: Collections.List[Type]
        ) -> Types.GENERIC =>
            Types.PURE_FUNCTION(location, symbol, arguments);

        to_string() -> string => short_description;
    si
si
