namespace Semantic is
    use IO.Std;

    use System.Text.StringBuilder;

    use Collections.Iterable;
    use Collections.Iterator;

    use Collections.MAP;
    use Collections.SET;

    use Symbols.Symbol;
    use Symbols.Function;
    
    class METHOD_OVERRIDE_MAP(name: string): Iterable[METHOD_OVERRIDE_SET] is
        _symbols: SET[SYMBOL_WRAPPER];
        _symbols_list: Collections.LIST[Symbol]?;

        methods: MAP[METHOD_OVERRIDE_CLASS,METHOD_OVERRIDE_SET];

        // Read several times per class during override resolution, so the
        // projected list is built once and reused; `add` resets it.
        symbols: Iterable[Symbol] is
            if _symbols_list? then
                return _symbols_list;
            fi

            let list = Collections.LIST[Symbol]();

            for w in _symbols do
                list.add(w.symbol);
            od

            _symbols_list = list;

            return list;
        si

        // Avoids building and piping `symbols` when only the first element
        // is wanted.
        first_symbol: Symbol? is
            for w in _symbols do
                return w.symbol;
            od

            return null;
        si

        iterator: Iterator[METHOD_OVERRIDE_SET] => methods.values.iterator;

        contains_any_methods: bool => methods.count > 0;
        contains_any_symbols: bool => _symbols.count > 0;

        _empty: METHOD_OVERRIDE_MAP? static;

        // Shared, read-only empty map for the common case where a class
        // declares no member of a given name. Only ever read, never added to.
        empty: METHOD_OVERRIDE_MAP static is
            if _empty? then
                return _empty;
            fi

            let empty = METHOD_OVERRIDE_MAP("");

            _empty = empty;

            return empty;
        si

        [method_class: METHOD_OVERRIDE_CLASS]: METHOD_OVERRIDE_SET? is
            let result: METHOD_OVERRIDE_SET mut;

            if methods.try_get_value(method_class, result ref) then
                return result;
            fi

            return null;
        si

        init(..) is
            methods = MAP();
            _symbols = SET();
        si

        contains(override_class: METHOD_OVERRIDE_CLASS) -> bool => methods.contains_key(override_class);

        add(symbol: Symbol) is
            if isa Function(symbol) then
                add(symbol);

                return;
            fi

            let wrapper = SYMBOL_WRAPPER(symbol);

            if !_symbols.contains(wrapper) then
                _symbols.add(wrapper);
                _symbols_list = null;
            fi
        si

        add(group: Symbols.FUNCTION_GROUP) is
            for f in group.functions do
                add(f);
            od            
        si

        add(functions: Iterable[Function]) is
            for f in functions do
                add(f);
            od
        si

        add(method: Function) is
            let c = method.override_class;

            let method_set: METHOD_OVERRIDE_SET mut;

            if !methods.try_get_value(c, method_set ref) then
                method_set = METHOD_OVERRIDE_SET(c);
                methods[c] = method_set;
            fi

            assert method_set? else "no method set for {method.qualified_name}";

            method_set.add(method);
        si

        to_string() -> string is
            let result = StringBuilder();

            for s in methods do
                result.append("{name}: [{s.key}: {s.value}]");
            od

            result.append(" others: ").append(symbols|);
            
            return result.to_string();
        si
    si
si
