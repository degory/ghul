namespace Semantic is
    use Source.LOCATION;
    use Types.Type;
    use IR.Values.Value;

    // Lowers a bare reference to a unit variant — `RED`, `COLOR.RED`,
    // `Option.NONE`, `Many.EMPTY`, `Option.NONE[int]` — to a NEW value
    // that points at the variant's interned singleton.
    // `gen_unit_variant_singleton` and `IR.Values.NEW.gen` cooperate to
    // emit `ldsfld` for that path.
    //
    // For a generic union the variant only constructs once every type
    // parameter is fixed. When the caller has an expected type pushed
    // in by the parent context — assignment LHS, function-argument
    // slot, return slot, explicit type arguments via `Option.NONE[int]`
    // — `try_load` borrows the OWNER_CONSTRAINT_SPECIALIZER to derive
    // the type arguments from it, the same way `Option.NONE()` does
    // today via resolve_constructor. When the variant is generic and
    // the constraint can't fill every owner slot, `try_load` returns
    // null and the caller falls back to a TYPE_EXPRESSION; any
    // enclosing `()` then drives the regular constructor-resolution
    // path.
    class UNIT_VARIANT_CONSTRUCTOR is
        _owner_constraint_specializer: OWNER_CONSTRAINT_SPECIALIZER;
        _type_arg_placeholder_registry: TYPE_ARG_PLACEHOLDER_REGISTRY;
        _function_caller: FUNCTION_CALLER;

        init(
            owner_constraint_specializer: OWNER_CONSTRAINT_SPECIALIZER,
            type_arg_placeholder_registry: TYPE_ARG_PLACEHOLDER_REGISTRY,
            function_caller: FUNCTION_CALLER
        ) is
            super.init();

            _owner_constraint_specializer = owner_constraint_specializer;
            _type_arg_placeholder_registry = type_arg_placeholder_registry;
            _function_caller = function_caller;
        si

        try_load(
            location: LOCATION,
            variant: Symbols.VARIANT,
            constraint: Type?,
            cache_key: Syntax.Trees.Node
        ) -> UNIT_VARIANT_LOAD? is
            if !variant? \/ !variant.is_unit_variant then
                return null;
            fi

            let init_group = cast Symbols.FUNCTION_GROUP?(variant.find_direct("init"));

            if !init_group? \/ init_group.functions.count == 0 then
                return null;
            fi

            let init mut = init_group.functions[0];

            if variant.is_generic then
                if constraint? then
                    init = _owner_constraint_specializer.specialize_from_constraint(location, init, constraint);
                fi

                // Any owner-generic slot the constraint didn't fix
                // (or every slot when no constraint reached us) is
                // covered by a phantom origin keyed off `cache_key`.
                // The enclosing call's overload resolver back-feeds
                // each phantom from the argument slot it lands in,
                // matching the path taken by resolve_constructor for
                // the parenthesised form.
                init = _type_arg_placeholder_registry.specialize_with_placeholders(location, init, cache_key);
            fi

            let owner_type = init.owner.type;
            assert owner_type? else "variant constructor owner has no type";
            let value = _function_caller.call_constructor(init, Collections.LIST[Value](), owner_type);

            return UNIT_VARIANT_LOAD(value, init);
        si
    si

    class UNIT_VARIANT_LOAD is
        value: Value;
        constructor: Symbols.Function;

        init(value: Value, constructor: Symbols.Function) is
            super.init();
            self.value = value;
            self.constructor = constructor;
        si
    si
si
