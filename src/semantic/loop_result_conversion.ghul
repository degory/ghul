namespace Semantic is
    use Source;
    use Trees = Syntax.Trees;

    // Sibling of TASK_CONVERSION. Concentrates AST builders and
    // walk-and-rewrite helpers for the implicit `T → LOOP_RESULT[T]`
    // / `void → LOOP_RESULT` conversion that the async-loop desugar
    // applies to synthesised body lambdas.
    //
    // Used by `DESUGAR_AWAIT`'s async-loop rewrite (see
    // `docs/claude/async-loops.md`). All operations are syntactic
    // and run pre-resolution; nothing here queries the symbol table.
    //
    // AST builders (static):
    //   `build_continue_expression(loc, t_ret?)`
    //       — `Ghul.Async.LOOP_RESULT[T_ret]()` (struct default-init,
    //         lands on type=CONTINUE since CONTINUE is the first enum
    //         value) or `Ghul.Async.LOOP_RESULT()` for void.
    //   `build_return_expression(loc, t_ret?, value)`
    //       — `Ghul.Async.LOOP_RESULT[T_ret](LOOP_RESULT_TYPE.RETURN, value)`
    //         or `Ghul.Async.LOOP_RESULT(LOOP_RESULT_TYPE.RETURN)`.
    //   `build_break_expression(loc, t_ret?)`
    //       — future-proof for v2; unused in v1 surface.
    //
    // Body-rewrite methods:
    //   `wrap_returns_in_body(body, t_ret?)`
    //       — walks a synthesised body lambda's statement list,
    //         rewriting each `return X;` / `return;` to the matching
    //         LOOP_RESULT form, and appending a trailing CONTINUE
    //         return at end-of-body.
    class LOOP_RESULT_CONVERSION is
        init() is
        si

        // Extract `T_ret` syntactically from an enclosing function's
        // return-type AST. Returns the inner type argument when the
        // expression is `Tasks.TASK[T]` (a GENERIC node whose name
        // ends in "TASK"); null otherwise (non-generic Tasks.TASK,
        // any non-Task return, or a type alias like
        // `use TaskInt = Tasks.TASK[int]` — the latter is a known
        // limitation accepted in v1; users alias at their own risk).
        try_extract_t_ret(
            enclosing_return_type: Trees.TypeExpressions.TypeExpression?
        ) -> Trees.TypeExpressions.TypeExpression? static is
            if !enclosing_return_type? then
                return null;
            fi

            if let g: Trees.TypeExpressions.GENERIC = enclosing_return_type then
                if g.name? /\ g.name.name =~ "TASK" /\ g.arguments? /\ g.arguments.count == 1 then
                    let arg = g.arguments.elements[0];
                    if arg? then
                        return arg;
                    fi
                fi
            fi

            return null;
        si

        // True iff the enclosing return type is the non-generic
        // `Tasks.TASK` (void async). Used to pick `LOOP_RESULT` vs
        // `LOOP_RESULT[T_ret]` when synthesising body returns.
        is_void_async_return_type(
            enclosing_return_type: Trees.TypeExpressions.TypeExpression?
        ) -> bool static is
            if !enclosing_return_type? then
                return false;
            fi

            if isa Trees.TypeExpressions.GENERIC(enclosing_return_type) then
                return false;
            fi

            if let n: Trees.TypeExpressions.NAMED = enclosing_return_type then
                return n.name? /\ n.name.name =~ "TASK";
            fi

            return false;
        si

        // Build `Ghul.Async.LOOP_RESULT[t_ret]()` (or `Ghul.Async.LOOP_RESULT()`
        // when t_ret is null, for void-async enclosing). The struct's
        // no-arg init zero-initialises: type lands on CONTINUE (first
        // enum value), value gets default[T_ret] semantics. No explicit
        // `default[T_ret]` is written in synthesised source.
        build_continue_expression(
            loc: LOCATION,
            t_ret: Trees.TypeExpressions.TypeExpression?
        ) -> Trees.Expressions.Expression static =>
            _build_loop_result_call(loc, t_ret, Collections.LIST[Trees.Expressions.Expression]());

        // Build `Ghul.Async.LOOP_RESULT[t_ret](LOOP_RESULT_TYPE.RETURN, value)`
        // (or `Ghul.Async.LOOP_RESULT(LOOP_RESULT_TYPE.RETURN)` when
        // t_ret is null and value is null).
        build_return_expression(
            loc: LOCATION,
            t_ret: Trees.TypeExpressions.TypeExpression?,
            value: Trees.Expressions.Expression?
        ) -> Trees.Expressions.Expression static is
            let args = Collections.LIST[Trees.Expressions.Expression]();
            args.add(_build_loop_result_type_value(loc, "RETURN"));
            if value? then
                args.add(value);
            fi
            return _build_loop_result_call(loc, t_ret, args);
        si

        // Future-proof — v1 does not emit BREAK from any desugar path,
        // but the helper class exposes the builder so the v2 desugar
        // for break-inside-async-loop can call it without further
        // plumbing.
        build_break_expression(
            loc: LOCATION,
            t_ret: Trees.TypeExpressions.TypeExpression?
        ) -> Trees.Expressions.Expression static is
            let args = Collections.LIST[Trees.Expressions.Expression]();
            args.add(_build_loop_result_type_value(loc, "BREAK"));
            return _build_loop_result_call(loc, t_ret, args);
        si

        // Walk `body` (a synthesised loop-body lambda's statement
        // list), rewriting each user-written RETURN statement to the
        // matching LOOP_RESULT form, then append a trailing CONTINUE
        // return at end-of-body. After this, the body lambda is an
        // ordinary value-async lambda returning `Tasks.TASK[LOOP_RESULT[t_ret]]`
        // (or `Tasks.TASK[LOOP_RESULT]` for void) and existing
        // Conversions 1/2/3/4 fire on it unchanged.
        wrap_returns_in_body(
            body: Trees.Statements.LIST,
            t_ret: Trees.TypeExpressions.TypeExpression?
        ) is
            assert body? else "body cannot be null";

            // Rewrite returns in place via a focused visitor that
            // does not descend into nested closures (those belong to
            // *their* enclosing function, not ours).
            let rewriter = LOOP_RESULT_RETURN_REWRITER(t_ret);
            body.walk(rewriter);

            // Append the trailing CONTINUE return — needed so the
            // body lambda always produces a LOOP_RESULT value, never
            // falls off the end.
            let continue_return =
                Trees.Statements.RETURN(
                    body.location,
                    build_continue_expression(body.location, t_ret)
                );

            let new_statements = Collections.LIST[Trees.Statements.Statement]();
            for s in body.statements do
                new_statements.add(s);
            od
            new_statements.add(continue_return);
            body.replace_all(new_statements);
        si

        // ---- internal AST builders ----

        // `Ghul.Async.LOOP_RESULT[t_ret](args...)` when t_ret is not
        // null; `Ghul.Async.LOOP_RESULT(args...)` when t_ret is null.
        _build_loop_result_call(
            loc: LOCATION,
            t_ret: Trees.TypeExpressions.TypeExpression?,
            args: Collections.LIST[Trees.Expressions.Expression]
        ) -> Trees.Expressions.Expression static is
            let callable: Trees.Expressions.Expression mut =
                _build_loop_result_reference(loc, t_ret);

            let arg_list =
                Trees.Expressions.LIST(loc, args);

            return Trees.Expressions.CALL(loc, callable, arg_list);
        si

        // Build the callable part: either
        //   `Ghul.Async.LOOP_RESULT[t_ret]`  (GENERIC_APPLICATION)
        // or `Ghul.Async.LOOP_RESULT`        (MEMBER chain).
        _build_loop_result_reference(
            loc: LOCATION,
            t_ret: Trees.TypeExpressions.TypeExpression?
        ) -> Trees.Expressions.Expression static is
            let internal_loc = LOCATION.internal;
            let ghul_async = _build_ghul_async(loc);

            if t_ret? then
                let type_args =
                    Trees.TypeExpressions.LIST(
                        loc,
                        Collections.LIST[Trees.TypeExpressions.TypeExpression]([t_ret.copy()]: Trees.TypeExpressions.TypeExpression)
                    );

                return
                    Trees.Expressions.GENERIC_APPLICATION(
                        loc,
                        ghul_async,
                        Trees.Identifiers.Identifier(internal_loc, "LOOP_RESULT"),
                        type_args
                    );
            else
                return
                    Trees.Expressions.MEMBER(
                        loc,
                        ghul_async,
                        Trees.Identifiers.Identifier(internal_loc, "LOOP_RESULT"),
                        loc
                    );
            fi
        si

        // `Ghul.Async.LOOP_RESULT_TYPE.<variant>` member-access chain.
        _build_loop_result_type_value(
            loc: LOCATION,
            variant_name: string
        ) -> Trees.Expressions.Expression static is
            let internal_loc = LOCATION.internal;
            let ghul_async = _build_ghul_async(loc);

            let type_member =
                Trees.Expressions.MEMBER(
                    loc,
                    ghul_async,
                    Trees.Identifiers.Identifier(internal_loc, "LOOP_RESULT_TYPE"),
                    loc
                );

            return
                Trees.Expressions.MEMBER(
                    loc,
                    type_member,
                    Trees.Identifiers.Identifier(internal_loc, variant_name),
                    loc
                );
        si

        // `Ghul.Async` two-level identifier chain.
        _build_ghul_async(loc: LOCATION) -> Trees.Expressions.Expression static is
            let internal_loc = LOCATION.internal;
            let ghul_id =
                Trees.Expressions.IDENTIFIER(
                    loc,
                    Trees.Identifiers.Identifier(internal_loc, "Ghul")
                );
            return
                Trees.Expressions.MEMBER(
                    loc,
                    ghul_id,
                    Trees.Identifiers.Identifier(internal_loc, "Async"),
                    loc
                );
        si
    si

    // Visitor that rewrites RETURN statements in a loop body lambda.
    // Does NOT descend into nested functions / lambdas — those have
    // their own enclosing context — nor into nested FOR / DO loops,
    // which will themselves be expanded by the async-loop desugar
    // recursively (and their own wrap_returns_in_body will handle
    // their interior returns, so a single rewrite is correct).
    class LOOP_RESULT_RETURN_REWRITER: Syntax.Visitor is
        _t_ret: Trees.TypeExpressions.TypeExpression?;

        init(t_ret: Trees.TypeExpressions.TypeExpression?) is
            super.init();
            _t_ret = t_ret;
        si

        // Block descent into nested closures — their own returns
        // belong to *them*, not to the enclosing loop body.
        pre(function: Trees.Definitions.FUNCTION) -> bool => true;
        pre(function: Trees.Expressions.FUNCTION) -> bool => true;

        // Block descent into nested FOR / DO loops too — when the
        // desugar walks into them they get their own
        // wrap_returns_in_body call.
        pre(for_stmt: Trees.Statements.FOR) -> bool => true;
        pre(do_stmt: Trees.Statements.DO) -> bool => true;

        visit(r: Trees.Statements.RETURN) is
            if r.expression? then
                // `return X;` → `return LOOP_RESULT[T_ret](RETURN, X);`
                r.expression = LOOP_RESULT_CONVERSION.build_return_expression(
                    r.location, _t_ret, r.expression
                );
            else
                // `return;` → `return LOOP_RESULT(RETURN);`
                // (or LOOP_RESULT[T_ret](RETURN) if t_ret was supplied —
                //  void-async loops have _t_ret = null though).
                r.expression = LOOP_RESULT_CONVERSION.build_return_expression(
                    r.location, _t_ret, null
                );
            fi
        si
    si
si
