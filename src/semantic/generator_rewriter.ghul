namespace Semantic is
    use Source;
    use Logging;
    use Trees = Syntax.Trees;

    // One entry on the GENERATOR_REWRITER's loop-context stack.
    // Pushed on entry to a state-split loop, popped on exit.
    // `break;` TRANSITIONs to `exit_state`; `continue;` TRANSITIONs
    // to `header_state`.
    struct GENERATOR_LOOP_FRAME is
        header_state: int;
        exit_state: int;

        init(header_state: int, exit_state: int) is
            self.header_state = header_state;
            self.exit_state = exit_state;
        si
    si

    // Rewrites a generator-function body into a list of state-handler
    // lambdas + a final `Ghul.Generators._gen_pipe(states)` return.
    // Invoked by DESUGAR_YIELD on every function whose
    // `is_generator_function` flag is true.
    //
    // Algorithm:
    //   1. Split body.statements at the first state-affecting
    //      statement (yield, return, or if/while/for whose body
    //      contains one of those). Everything before is "prelude"
    //      — it stays at function scope and runs once when the
    //      generator is constructed. Function-scope `let`s captured
    //      by state lambdas get the usual BOX[T] treatment from the
    //      `mark-boxed-locals` pass.
    //   2. Walk statements from the first state-affecting point,
    //      slicing into states per the design's D3 rules:
    //        yield X;   →  close state with `return YIELD(X, next);`
    //        return;    →  close state with `return DONE;`
    //        return X;  →  diagnostic
    //        if/then/else (with yield inside any branch) →
    //                       allocate first-states for each branch +
    //                       a join state; close dispatch state with
    //                       `if cond then TRANSITION(A_first) else
    //                       TRANSITION(B_first) fi`; recursively
    //                       process branches; each branch's tail
    //                       TRANSITIONs to the join state.
    //        anything else → append to current state's body.
    //   3. Close trailing state with DONE.
    //   4. Replace body with:
    //        <prelude>
    //        let __gen_states = Collections.LIST[() -> _GEN_STEP[T]]();
    //        __gen_states.add(state_0); __gen_states.add(state_1); ...
    //        return Ghul.Generators._gen_pipe(__gen_states);
    //
    // State-index allocation. States receive indices via
    // `_allocate_state()` in dependency order (a TRANSITION must
    // reference an index that's already allocated, but the state at
    // that index may not yet have a body). The `_states` map is
    // keyed by index; lambdas are emitted as states close. Final
    // assembly walks `0..._next_state_index`.
    //
    // Not handled yet:
    //   - while / for with yields inside
    //   - break / continue
    //   - try/catch across yields
    //   - yield inside nested lambdas
    //
    // See `docs/claude/generators-yield.md`.
    class GENERATOR_REWRITER is
        _logger: Logger;
        _t: Trees.TypeExpressions.TypeExpression;

        _states: Collections.MAP[int, Trees.Expressions.Expression];
        _current_body: Collections.LIST[Trees.Statements.Statement];
        _current_state_index: int;
        _next_state_index: int;

        // Stack of (header_state, exit_state) frames — one entry
        // per enclosing state-split loop. Top of stack is the
        // innermost loop. `break;` / `continue;` read from the top.
        _loop_context: Collections.LIST[GENERATOR_LOOP_FRAME];

        // Extra statements that need to live at function scope
        // alongside the user-written prelude — currently used for
        // `let __iter_N = xs.iterator;` injected when expanding a
        // state-splitting `for x in xs do BODY od`. Appended after
        // the user-written prelude and before the state-list
        // construction.
        _extra_prelude: Collections.LIST[Trees.Statements.Statement];

        // Counter for synthesised names (__iter_N, etc).
        _synth_counter: int;

        init(logger: Logger, t: Trees.TypeExpressions.TypeExpression) is
            _logger = logger;
            _t = t;
            _states = Collections.MAP[int, Trees.Expressions.Expression]();
            _current_body = Collections.LIST[Trees.Statements.Statement]();
            _current_state_index = 0;
            _next_state_index = 1;
            _loop_context = Collections.LIST[GENERATOR_LOOP_FRAME]();
            _extra_prelude = Collections.LIST[Trees.Statements.Statement]();
            _synth_counter = 0;
        si

        // Rewrite the body in place.
        rewrite(body: Trees.Statements.LIST) is
            assert body? else "body cannot be null";

            let original = Collections.LIST[Trees.Statements.Statement]();
            for s in body do
                original.add(s);
            od

            let prelude = Collections.LIST[Trees.Statements.Statement]();
            let split_index = _find_first_state_affecting_index(original);

            let i mut = 0;
            while i < split_index do
                prelude.add(original[i]);
                i = i + 1;
            od

            while i < original.count do
                _process_statement(original[i]);
                i = i + 1;
            od

            // Trailing state — fall-through, DONE.
            _close_state_with_done(body.location);

            // Build the new body.
            let new_statements = Collections.LIST[Trees.Statements.Statement]();

            for s in prelude do
                new_statements.add(s);
            od

            for s in _extra_prelude do
                new_statements.add(s);
            od

            let internal_loc = LOCATION.internal;
            let loc = body.location;

            new_statements.add(_build_states_declaration(loc, internal_loc));

            let k mut = 0;
            while k < _next_state_index do
                let lambda = _states[k];
                assert lambda? else "generator state {k} was never closed — internal rewriter bug";
                new_statements.add(_build_states_add_call(loc, internal_loc, lambda));
                k = k + 1;
            od

            new_statements.add(_build_gen_pipe_return(loc, internal_loc));

            body.replace_all(new_statements);
        si

        // ---- statement processing ----

        _process_statement(s: Trees.Statements.Statement) is
            if isa Trees.Statements.YIELD(s) then
                _process_yield(cast Trees.Statements.YIELD(s));
            elif isa Trees.Statements.RETURN(s) then
                _process_return(cast Trees.Statements.RETURN(s));
            elif isa Trees.Statements.IF(s) then
                _process_if(cast Trees.Statements.IF(s));
            elif isa Trees.Statements.DO(s) then
                _process_do(cast Trees.Statements.DO(s));
            elif isa Trees.Statements.FOR(s) then
                _process_for(cast Trees.Statements.FOR(s));
            elif isa Trees.Statements.BREAK(s) then
                _process_break(cast Trees.Statements.BREAK(s));
            elif isa Trees.Statements.CONTINUE(s) then
                _process_continue(cast Trees.Statements.CONTINUE(s));
            else
                _current_body.add(s);
            fi
        si

        _process_statement_list(stmt_list: Trees.Statements.LIST) is
            for s in stmt_list do
                _process_statement(s);
            od
        si

        _process_yield(y: Trees.Statements.YIELD) is
            let loc = y.location;
            let next_idx = _allocate_state();
            let yield_expr =
                GEN_STEP_CONVERSION.build_yield(
                    loc, _t.copy(), y.expression, next_idx
                );
            _close_current_with(loc, yield_expr);
            _start_new_state(next_idx);
        si

        _process_return(r: Trees.Statements.RETURN) is
            if r.expression? then
                _logger.error(
                    r.location,
                    "return with a value is not allowed in a generator function — use `yield` to emit values"
                );
                return;
            fi
            let loc = r.location;
            let done_expr = GEN_STEP_CONVERSION.build_done(loc, _t.copy());
            _close_current_with(loc, done_expr);
            // Subsequent statements collect into a fresh state but
            // are dead — the state machine never reaches them. We
            // still allocate the index so subsequent yields produce
            // a contiguous state list.
            _start_new_state(_allocate_state());
        si

        _process_if(if_stmt: Trees.Statements.IF) is
            if !_if_needs_split(if_stmt) then
                _current_body.add(if_stmt);
                return;
            fi

            let loc = if_stmt.location;

            // Save the dispatch state's accumulator. We'll close it
            // last (after we know branch-first indices and state_J).
            let dispatch_state_index = _current_state_index;
            let dispatch_body = _current_body;

            // Allocate a first-state index for each branch and
            // process the branches. After each branch's recursive
            // walk, save the trailing (open) state for the
            // post-loop TRANSITION-to-J patch.
            let branch_first_indices = Collections.LIST[int]();
            let branch_last_indices = Collections.LIST[int]();
            let branch_last_bodies =
                Collections.LIST[Collections.LIST[Trees.Statements.Statement]]();

            let has_else mut = false;

            for branch in if_stmt.branches do
                if !branch.condition? then
                    has_else = true;
                fi

                let branch_first = _allocate_state();
                branch_first_indices.add(branch_first);
                _start_new_state(branch_first);
                _process_statement_list(branch.body);
                branch_last_indices.add(_current_state_index);
                branch_last_bodies.add(_current_body);
            od

            // Join state.
            let state_J = _allocate_state();

            // Build and emit the dispatch if.
            let new_branches = Collections.LIST[Trees.Statements.IF_BRANCH]();
            let branches_iter = if_stmt.branches.iterator;
            let bf_i mut = 0;
            while branches_iter.move_next() do
                let original_branch = branches_iter.current;
                let target = branch_first_indices[bf_i];
                let transition_body =
                    _build_single_statement_list(
                        original_branch.location,
                        Trees.Statements.RETURN(
                            original_branch.location,
                            GEN_STEP_CONVERSION.build_transition(
                                original_branch.location, _t.copy(), target
                            )
                        )
                    );
                new_branches.add(
                    Trees.Statements.IF_BRANCH(
                        original_branch.location,
                        original_branch.condition,
                        original_branch.binding,
                        transition_body
                    )
                );
                bf_i = bf_i + 1;
            od

            // If the original if has no else, add one that
            // TRANSITIONs directly to state_J — control fell through
            // the if without entering any branch.
            if !has_else then
                let else_body =
                    _build_single_statement_list(
                        loc,
                        Trees.Statements.RETURN(
                            loc,
                            GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), state_J)
                        )
                    );
                new_branches.add(
                    Trees.Statements.IF_BRANCH(loc, null, else_body)
                );
            fi

            dispatch_body.add(Trees.Statements.IF(loc, new_branches));
            _emit_state(dispatch_state_index, dispatch_body);

            // Close each branch's trailing state with
            // TRANSITION(state_J).
            let bl_i mut = 0;
            while bl_i < branch_last_indices.count do
                let last_idx = branch_last_indices[bl_i];
                let last_body = branch_last_bodies[bl_i];
                last_body.add(
                    Trees.Statements.RETURN(
                        loc,
                        GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), state_J)
                    )
                );
                _emit_state(last_idx, last_body);
                bl_i = bl_i + 1;
            od

            // Continue at the join state.
            _start_new_state(state_J);
        si

        _process_do(do_stmt: Trees.Statements.DO) is
            if !_do_needs_split(do_stmt) then
                _current_body.add(do_stmt);
                return;
            fi

            if !do_stmt.condition? then
                // Infinite loop (`do BODY od`) with a yield inside.
                // The natural rewrite is "header state has no
                // condition — always TRANSITION to body". Same shape
                // as while-true; handled below by treating a null
                // condition as "always true" when synthesising the
                // header.
                _process_infinite_do(do_stmt);
                return;
            fi

            let loc = do_stmt.location;

            // The state currently being built TRANSITIONs to the
            // loop header. Allocate header + exit before processing
            // the body so break/continue targets are known.
            let state_H = _allocate_state();
            let state_E = _allocate_state();

            // Close current state with TRANSITION(state_H).
            _close_current_with(
                loc,
                GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), state_H)
            );

            // Body's first state.
            let state_body_first = _allocate_state();

            // Header: if cond then TRANSITION(body_first) else TRANSITION(exit) fi.
            _start_new_state(state_H);
            let header_if = _build_dispatch_if(
                loc,
                do_stmt.condition,
                state_body_first,
                state_E
            );
            _current_body.add(header_if);
            _emit_state(state_H, _current_body);

            // Process body — yields/transitions inside refer to
            // state_H (continue) and state_E (break) via the loop
            // context.
            _loop_context.add(GENERATOR_LOOP_FRAME(state_H, state_E));
            _start_new_state(state_body_first);
            _process_statement_list(do_stmt.body);
            // Body's trailing state TRANSITIONs back to header.
            _close_current_with(
                loc,
                GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), state_H)
            );
            _loop_context.remove_at(_loop_context.count - 1);

            // Continue after the loop.
            _start_new_state(state_E);
        si

        _process_infinite_do(do_stmt: Trees.Statements.DO) is
            let loc = do_stmt.location;

            let state_H = _allocate_state();
            let state_E = _allocate_state();

            _close_current_with(
                loc,
                GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), state_H)
            );

            let state_body_first = _allocate_state();

            // Header state for an infinite loop: just TRANSITION
            // straight into the body. (state_E is only reachable
            // via break — and break inside an infinite loop is the
            // only way for the loop to terminate.)
            _start_new_state(state_H);
            _current_body.add(
                Trees.Statements.RETURN(
                    loc,
                    GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), state_body_first)
                )
            );
            _emit_state(state_H, _current_body);

            _loop_context.add(GENERATOR_LOOP_FRAME(state_H, state_E));
            _start_new_state(state_body_first);
            _process_statement_list(do_stmt.body);
            _close_current_with(
                loc,
                GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), state_H)
            );
            _loop_context.remove_at(_loop_context.count - 1);

            _start_new_state(state_E);
        si

        _process_for(for_stmt: Trees.Statements.FOR) is
            if !_for_needs_split(for_stmt) then
                _current_body.add(for_stmt);
                return;
            fi

            // for-each with yields inside isn't supported by the
            // rewriter yet — the loop variable's element type isn't
            // available at this pass, so we can't safely hoist it
            // to function scope (needed for cross-state visibility
            // after a yield). Workaround: write the equivalent
            // explicit while-loop.
            _logger.error(
                for_stmt.location,
                "for-each with `yield` inside the body is not supported yet — rewrite as `let __iter = xs.iterator; while __iter.move_next() do let x = __iter.current; ... od`"
            );
            // Still slot a placeholder state so subsequent code
            // doesn't read uninitialised state indices.
            _current_body.add(for_stmt);
        si

        _process_break(b: Trees.Statements.BREAK) is
            if _loop_context.count == 0 then
                _logger.error(
                    b.location,
                    "break outside a loop is not allowed in a generator function"
                );
                return;
            fi
            let exit_state = _loop_context[_loop_context.count - 1].exit_state;
            _close_current_with(
                b.location,
                GEN_STEP_CONVERSION.build_transition(b.location, _t.copy(), exit_state)
            );
            _start_new_state(_allocate_state());
        si

        _process_continue(c: Trees.Statements.CONTINUE) is
            if _loop_context.count == 0 then
                _logger.error(
                    c.location,
                    "continue outside a loop is not allowed in a generator function"
                );
                return;
            fi
            let header_state = _loop_context[_loop_context.count - 1].header_state;
            _close_current_with(
                c.location,
                GEN_STEP_CONVERSION.build_transition(c.location, _t.copy(), header_state)
            );
            _start_new_state(_allocate_state());
        si

        // Single-branch `if cond then return TRANSITION(a) else return TRANSITION(b) fi`.
        _build_dispatch_if(
            loc: LOCATION,
            condition: Trees.Expressions.Expression,
            target_then: int,
            target_else: int
        ) -> Trees.Statements.Statement is
            let then_body =
                _build_single_statement_list(
                    loc,
                    Trees.Statements.RETURN(
                        loc,
                        GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), target_then)
                    )
                );
            let else_body =
                _build_single_statement_list(
                    loc,
                    Trees.Statements.RETURN(
                        loc,
                        GEN_STEP_CONVERSION.build_transition(loc, _t.copy(), target_else)
                    )
                );
            let branches = Collections.LIST[Trees.Statements.IF_BRANCH]();
            branches.add(Trees.Statements.IF_BRANCH(loc, condition, then_body));
            branches.add(Trees.Statements.IF_BRANCH(loc, null, else_body));
            return Trees.Statements.IF(loc, branches);
        si

        // ---- state-machine bookkeeping ----

        _allocate_state() -> int is
            let i = _next_state_index;
            _next_state_index = i + 1;
            return i;
        si

        _start_new_state(index: int) is
            _current_state_index = index;
            _current_body = Collections.LIST[Trees.Statements.Statement]();
        si

        _close_current_with(loc: LOCATION, final_expr: Trees.Expressions.Expression) is
            _current_body.add(Trees.Statements.RETURN(loc, final_expr));
            _emit_state(_current_state_index, _current_body);
        si

        _close_state_with_done(loc: LOCATION) is
            let done_expr = GEN_STEP_CONVERSION.build_done(loc, _t.copy());
            _close_current_with(loc, done_expr);
        si

        _emit_state(
            index: int,
            body_statements: Collections.LIST[Trees.Statements.Statement]
        ) is
            let lambda = _build_state_lambda(body_statements);
            _states[index] = lambda;
        si

        // ---- classification helpers ----

        _find_first_state_affecting_index(stmts: Collections.LIST[Trees.Statements.Statement]) -> int is
            let i mut = 0;
            while i < stmts.count do
                if _is_state_affecting(stmts[i]) then
                    return i;
                fi
                i = i + 1;
            od
            return stmts.count;
        si

        _is_state_affecting(s: Trees.Statements.Statement) -> bool is
            if
                isa Trees.Statements.YIELD(s) \/
                isa Trees.Statements.RETURN(s) \/
                isa Trees.Statements.BREAK(s) \/
                isa Trees.Statements.CONTINUE(s)
            then
                return true;
            fi
            if isa Trees.Statements.IF(s) then
                return _if_needs_split(cast Trees.Statements.IF(s));
            fi
            if isa Trees.Statements.DO(s) then
                return _do_needs_split(cast Trees.Statements.DO(s));
            fi
            if isa Trees.Statements.FOR(s) then
                return _for_needs_split(cast Trees.Statements.FOR(s));
            fi
            return false;
        si

        _if_needs_split(if_stmt: Trees.Statements.IF) -> bool is
            for branch in if_stmt.branches do
                if _stmt_list_contains_state_affecting(branch.body) then
                    return true;
                fi
            od
            return false;
        si

        _do_needs_split(do_stmt: Trees.Statements.DO) -> bool is
            return _stmt_list_contains_state_affecting(do_stmt.body);
        si

        _for_needs_split(for_stmt: Trees.Statements.FOR) -> bool is
            return _stmt_list_contains_state_affecting(for_stmt.body);
        si

        _stmt_list_contains_state_affecting(stmt_list: Trees.Statements.LIST) -> bool is
            if !stmt_list? then
                return false;
            fi
            for s in stmt_list do
                if _is_state_affecting(s) then
                    return true;
                fi
            od
            return false;
        si

        // ---- AST builders ----

        _build_single_statement_list(
            loc: LOCATION,
            s: Trees.Statements.Statement
        ) -> Trees.Statements.LIST is
            let list = Collections.LIST[Trees.Statements.Statement]();
            list.add(s);
            return Trees.Statements.LIST(loc, list);
        si

        // `() -> _GEN_STEP[T] is <body> si` lambda.
        _build_state_lambda(
            body_statements: Collections.LIST[Trees.Statements.Statement]
        ) -> Trees.Expressions.Expression is
            let internal_loc = LOCATION.internal;
            let loc =
                if body_statements.count > 0 then
                    body_statements[0].location
                else
                    internal_loc
                fi;

            let body_list = Trees.Statements.LIST(loc, body_statements);
            let body_block = Trees.Bodies.BLOCK(loc, body_list);

            let arg_list =
                Trees.Expressions.LIST(
                    loc,
                    Collections.LIST[Trees.Expressions.Expression]()
                );

            let gen_step_id =
                Trees.Identifiers.QUALIFIED(
                    internal_loc,
                    Trees.Identifiers.QUALIFIED(
                        internal_loc,
                        Trees.Identifiers.Identifier(internal_loc, "Ghul"),
                        "Generators",
                        internal_loc,
                        internal_loc
                    ),
                    "_GEN_STEP",
                    internal_loc,
                    internal_loc
                );
            let type_args =
                Trees.TypeExpressions.LIST(
                    loc,
                    Collections.LIST[Trees.TypeExpressions.TypeExpression]([_t.copy()]: Trees.TypeExpressions.TypeExpression)
                );
            let return_type =
                Trees.TypeExpressions.GENERIC(loc, gen_step_id, type_args);

            return
                Trees.Expressions.FUNCTION(
                    loc,
                    arg_list,
                    return_type,
                    body_block,
                    false
                );
        si

        // `let __gen_states = Collections.LIST[() -> _GEN_STEP[T]]();`
        _build_states_declaration(
            loc: LOCATION,
            internal_loc: LOCATION
        ) -> Trees.Statements.Statement is
            let element_type = _build_state_function_type(loc, internal_loc);

            let list_ctor_callable =
                _build_list_constructor_callable(loc, internal_loc, element_type);

            let ctor_args =
                Trees.Expressions.LIST(
                    loc,
                    Collections.LIST[Trees.Expressions.Expression]()
                );
            let ctor_call =
                Trees.Expressions.CALL(loc, list_ctor_callable, ctor_args);

            let var_id =
                Trees.Identifiers.Identifier(internal_loc, "__gen_states");
            return _build_let(loc, var_id, ctor_call);
        si

        _build_list_constructor_callable(
            loc: LOCATION,
            internal_loc: LOCATION,
            element_type: Trees.TypeExpressions.TypeExpression
        ) -> Trees.Expressions.Expression is
            let collections_id =
                Trees.Expressions.IDENTIFIER(
                    loc,
                    Trees.Identifiers.Identifier(internal_loc, "Collections")
                );

            let type_args =
                Trees.TypeExpressions.LIST(
                    loc,
                    Collections.LIST[Trees.TypeExpressions.TypeExpression]([element_type.copy()]: Trees.TypeExpressions.TypeExpression)
                );

            return
                Trees.Expressions.GENERIC_APPLICATION(
                    loc,
                    collections_id,
                    Trees.Identifiers.Identifier(internal_loc, "LIST"),
                    type_args
                );
        si

        _build_state_function_type(
            loc: LOCATION,
            internal_loc: LOCATION
        ) -> Trees.TypeExpressions.TypeExpression is
            let gen_step_id =
                Trees.Identifiers.QUALIFIED(
                    internal_loc,
                    Trees.Identifiers.QUALIFIED(
                        internal_loc,
                        Trees.Identifiers.Identifier(internal_loc, "Ghul"),
                        "Generators",
                        internal_loc,
                        internal_loc
                    ),
                    "_GEN_STEP",
                    internal_loc,
                    internal_loc
                );
            let gen_step_type_args =
                Trees.TypeExpressions.LIST(
                    loc,
                    Collections.LIST[Trees.TypeExpressions.TypeExpression]([_t.copy()]: Trees.TypeExpressions.TypeExpression)
                );
            let gen_step_type =
                Trees.TypeExpressions.GENERIC(loc, gen_step_id, gen_step_type_args);

            let empty_args =
                Trees.TypeExpressions.LIST(
                    loc,
                    Collections.LIST[Trees.TypeExpressions.TypeExpression]()
                );

            return Trees.TypeExpressions.FUNCTION(loc, empty_args, gen_step_type);
        si

        _build_states_add_call(
            loc: LOCATION,
            internal_loc: LOCATION,
            state_lambda: Trees.Expressions.Expression
        ) -> Trees.Statements.Statement is
            let states_id =
                Trees.Expressions.IDENTIFIER(
                    loc,
                    Trees.Identifiers.Identifier(internal_loc, "__gen_states")
                );
            let add_member =
                Trees.Expressions.MEMBER(
                    loc,
                    states_id,
                    Trees.Identifiers.Identifier(internal_loc, "add"),
                    loc
                );
            let args =
                Trees.Expressions.LIST(
                    loc,
                    Collections.LIST[Trees.Expressions.Expression]([state_lambda]: Trees.Expressions.Expression)
                );
            let call = Trees.Expressions.CALL(loc, add_member, args);
            return Trees.Statements.EXPRESSION(loc, call);
        si

        _build_gen_pipe_return(
            loc: LOCATION,
            internal_loc: LOCATION
        ) -> Trees.Statements.Statement is
            let gen_pipe_member =
                GEN_STEP_CONVERSION.build_ghul_generators_member(loc, "_gen_pipe");
            let states_id =
                Trees.Expressions.IDENTIFIER(
                    loc,
                    Trees.Identifiers.Identifier(internal_loc, "__gen_states")
                );
            let args =
                Trees.Expressions.LIST(
                    loc,
                    Collections.LIST[Trees.Expressions.Expression]([states_id]: Trees.Expressions.Expression)
                );
            let call = Trees.Expressions.CALL(loc, gen_pipe_member, args);
            return Trees.Statements.RETURN(loc, call);
        si

        _build_let(
            loc: LOCATION,
            var_id: Trees.Identifiers.Identifier,
            value: Trees.Expressions.Expression
        ) -> Trees.Statements.Statement is
            let variable =
                Trees.Variables.VARIABLE(
                    loc,
                    var_id,
                    Trees.TypeExpressions.INFER(loc),
                    false,
                    false,
                    value
                );
            let variable_list =
                Trees.Variables.LIST(
                    loc,
                    Collections.LIST[Trees.Variables.VARIABLE](
                        [variable]: Trees.Variables.VARIABLE
                    )
                );
            return Trees.Statements.LET(loc, false, variable_list);
        si

        _build_let_mut(
            loc: LOCATION,
            var_id: Trees.Identifiers.Identifier,
            value: Trees.Expressions.Expression
        ) -> Trees.Statements.Statement is
            let variable =
                Trees.Variables.VARIABLE(
                    loc,
                    var_id,
                    Trees.TypeExpressions.INFER(loc),
                    false,
                    false,
                    value
                );
            variable.mark_mutable();
            let variable_list =
                Trees.Variables.LIST(
                    loc,
                    Collections.LIST[Trees.Variables.VARIABLE](
                        [variable]: Trees.Variables.VARIABLE
                    )
                );
            variable_list.mark_mutable();
            return Trees.Statements.LET(loc, false, variable_list);
        si
    si
si
