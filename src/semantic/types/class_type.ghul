namespace Semantic.Types is
    use Source.LOCATION;
    use System.Text.StringBuilder;

    // Phase 2 of the type/symbol rationalisation
    // (docs/claude/type-symbol-rationalisation.md).
    //
    // Represents an application of a class declaration to a list of
    // type arguments. Owns its arguments directly — no per-instance
    // Symbols.GENERIC allocation.
    //
    // Coexists with Types.GENERIC during the migration. Phase 3 will
    // migrate construction sites to CLASS_TYPE. Phase 5 deletes
    // Types.GENERIC and Symbols.GENERIC.
    //
    // Extends NAMED so existing readers that cast(NAMED) keep working
    // — a CLASS_TYPE is a "named class type" with the underlying Classy
    // as its symbol (matching the open-generic NAMED shape used today).
    // Does NOT extend GENERIC: the per-Type Symbols.GENERIC allocation
    // is what we're eliminating.
    //
    // Member resolution (`find_member`) is intentionally not
    // implemented here — the specialised-member path needs an "owner"
    // for the result, which today is a Symbols.GENERIC. Designing the
    // post-Symbols.GENERIC owner is part of Phase 3+ work. Until then
    // CLASS_TYPE has no production constructors and find_member will
    // throw if called.
    class CLASS_TYPE: NAMED is
        _classy: Symbols.Classy;
        _arguments: Collections.List[Type];
        _is_wild: byte;
        _type_map: Collections.Map[string, Type];

        classy: Symbols.Classy => _classy;
        arguments: Collections.List[Type] => _arguments;

        is_named: bool => true;
        is_class: bool => _classy? /\ _classy.is_class;
        is_trait: bool => _classy? /\ _classy.is_trait;
        is_value_type: bool => _classy? /\ _classy.is_value_type;
        is_object: bool => _classy? /\ _classy.is_object;
        is_inheritable: bool => _classy? /\ _classy.is_inheritable;
        is_root_value_type: bool => _classy? /\ _classy.is_root_value_type;
        is_void: bool => _classy? /\ _classy.is_void;

        is_wild: bool is
            if _is_wild == 0b then
                let i = 0;

                while i < _arguments.count do
                    if _arguments[i]? /\ _arguments[i].is_wild then
                        _is_wild = 1b;
                        return true;
                    fi

                    i = i + 1;
                od

                _is_wild = 2b;
                return false;
            fi

            return _is_wild == 1b;
        si

        is_any_any: bool => _arguments | .any(a => a? /\ a.is_any_any);

        is_error: bool => _arguments | .any(a => a? /\ a.is_error);

        // Lazily-built type-arg map keyed by classy.argument_names[i].
        type_map: Collections.Map[string, Type] is
            if !_type_map? then
                let map = Collections.MAP[string, Type]();
                let names = _classy.argument_names;
                let limit =
                    if _arguments.count < names.count then
                        _arguments.count;
                    else
                        names.count;
                    fi;

                for i in 0..limit do
                    map[names[i]] = _arguments[i];
                od

                _type_map = map;
            fi

            return _type_map;
        si

        short_description: string is
            let result = StringBuilder();

            result.append(_classy.name);

            if _arguments.count > 0 then
                result.append('[');

                let seen = false;

                for a in _arguments do
                    if seen then
                        result.append(',');
                    fi

                    if a? then
                        result.append(a.short_description);
                    fi

                    seen = true;
                od

                result.append(']');
            fi

            return result.to_string();
        si

        init(classy: Symbols.Classy, arguments: Collections.List[Type]) is
            super.init(classy);

            assert classy? else "CLASS_TYPE classy is null";
            assert arguments? else "CLASS_TYPE arguments is null";

            _classy = classy;
            _arguments = arguments;
        si

        get_argument_type_variance(index: int) -> TYPE_VARIANCE is
            if !_classy? then
                return TYPE_VARIANCE.INVARIANT;
            fi

            let declared = _classy.get_argument_variance(index);

            if declared == TYPE_VARIANCE.INVARIANT then
                return TYPE_VARIANCE.INVARIANT;
            fi

            // CLR rule: declared variance applies only when the actual
            // type argument is a reference type.
            if index >= 0 /\ index < _arguments.count
                /\ _arguments[index]? /\ _arguments[index].is_value_type then
                return TYPE_VARIANCE.INVARIANT;
            fi

            return declared;
        si

        find_member(name: string) -> Symbols.Symbol is
            // See class header. Member resolution with substitution
            // requires designing the post-Symbols.GENERIC owner shape;
            // tracked as Phase 3+ work in
            // docs/claude/type-symbol-rationalisation.md. CLASS_TYPE has
            // no production constructors during Phase 2, so this path
            // is not yet reached.
            throw System.NotImplementedException(
                "CLASS_TYPE.find_member: needs Phase 3 design for specialised-member owner");
        si

        =~(other: Type) -> bool is
            if !other? then
                return false;
            fi

            if other.is_any then
                return true;
            fi

            let other_classy = TYPE_OPERATIONS.try_get_classy(other);

            if !other_classy? \/ !(other_classy =~ _classy) then
                return false;
            fi

            let other_arguments = TYPE_OPERATIONS.try_get_arguments(other);

            if !other_arguments? \/ other_arguments.count != _arguments.count then
                return false;
            fi

            for i in 0.._arguments.count do
                if _arguments[i] !~ other_arguments[i] then
                    return false;
                fi
            od

            return true;
        si

        compare_direct(other: Type) -> Types.MATCH is
            if other.is_any then
                return Types.MATCH.SAME;
            fi

            let other_classy = TYPE_OPERATIONS.try_get_classy(other);

            if !other_classy? \/ !(other_classy =~ _classy) then
                return Types.MATCH.DIFFERENT;
            fi

            let other_arguments = TYPE_OPERATIONS.try_get_arguments(other);

            if !other_arguments? \/ other_arguments.count != _arguments.count then
                return Types.MATCH.DIFFERENT;
            fi

            let result = Types.MATCH.SAME;

            for i in 0.._arguments.count do
                let variance = get_argument_type_variance(i);

                let arg_score: Types.MATCH;

                if variance == TYPE_VARIANCE.COVARIANT then
                    arg_score = _arguments[i].compare(other_arguments[i]);
                elif variance == TYPE_VARIANCE.CONTRAVARIANT then
                    arg_score = other_arguments[i].compare(_arguments[i]);
                elif _arguments[i] =~ other_arguments[i] then
                    arg_score = Types.MATCH.SAME;
                else
                    return Types.MATCH.DIFFERENT;
                fi

                if cast int(arg_score) > cast int(result) then
                    result = arg_score;
                fi
            od

            return result;
        si

        compare(other: Type) -> Types.MATCH is
            if !other? then
                return Types.MATCH.DIFFERENT;
            fi

            if other.is_null then
                return Types.MATCH.ASSIGNABLE;
            fi

            if other.is_named then
                let direct_score = compare_direct(other);

                if cast int(direct_score) <= cast int(Types.MATCH.ASSIGNABLE) then
                    return direct_score;
                fi

                if other.symbol? /\ other.symbol.ancestors? then
                    for i in 0..other.symbol.ancestors.count do
                        let a = other.symbol.get_ancestor(i);

                        let match = self.compare(a);

                        if cast int(match) <= cast int(Types.MATCH.ASSIGNABLE) then
                            return Types.MATCH.ASSIGNABLE;
                        elif match == Types.MATCH.CONVERTABLE then
                            return Types.MATCH.CONVERTABLE;
                        fi
                    od
                fi
            fi

            if is_wild \/ other.is_wild then
                return Types.MATCH.WILD;
            fi

            return Types.MATCH.DIFFERENT;
        si

        specialize(type_map: Collections.Map[string, Type]) -> Type is
            let new_args = Collections.LIST[Type](_arguments.count);

            let any_changed = false;

            for a in _arguments do
                let na = a.specialize(type_map);

                new_args.add(na);

                if a != na then
                    any_changed = true;
                fi
            od

            if !any_changed then
                return self;
            fi

            return CLASS_TYPE(_classy, new_args);
        si

        bind_type_variables(other: Type, results: GENERIC_ARGUMENT_BIND_RESULTS) -> bool is
            if !other? \/ other.is_null then
                return true;
            fi

            let other_classy = TYPE_OPERATIONS.try_get_classy(other);
            let other_arguments = TYPE_OPERATIONS.try_get_arguments(other);

            if other_classy? /\ other_classy =~ _classy
                /\ other_arguments? /\ other_arguments.count == _arguments.count then
                let result = true;

                for i in 0.._arguments.count do
                    result = _arguments[i].bind_type_variables(other_arguments[i], results)
                        /\ result;
                od

                return result;
            fi

            // Try ancestors of `other`.
            if other.symbol? /\ other.symbol.ancestors? then
                for a in other.symbol.ancestors do
                    if bind_type_variables(a, results) then
                        return true;
                    fi
                od
            fi

            return false;
        si

        get_type_arguments_into(results: Collections.LIST[GenericArgument]) is
            for a in _arguments do
                if a? then
                    a.get_type_arguments_into(results);
                fi
            od
        si

        walk(action: (Type) -> void) is
            for a in _arguments do
                if a? then
                    a.walk(action);
                fi
            od

            action(self);
        si

        gen_type(buffer: StringBuilder) is
            _classy.gen_type(buffer);

            buffer.append('<');

            let seen = false;

            for a in _arguments do
                if seen then
                    buffer.append(',');
                fi

                a.gen_type(buffer);

                seen = true;
            od

            buffer.append("> ");
        si

        gen_class_name(buffer: StringBuilder) is
            // class-name and type representations are the same for
            // generic instantiations — both must be prefixed with
            // 'class' / 'valuetype' at the call site.
            gen_type(buffer);
        si

        to_string() -> string is
            let result = StringBuilder();

            result.append(_classy.qualified_name);

            if _arguments.count > 0 then
                result.append('[');

                let seen = false;

                for a in _arguments do
                    if seen then
                        result.append(',');
                    fi

                    if a? then
                        result.append(a);
                    fi

                    seen = true;
                od

                result.append(']');
            fi

            return result.to_string();
        si
    si
si
