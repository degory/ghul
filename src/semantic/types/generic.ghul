namespace Semantic.Types is
    use IO.Std;

    use Source.LOCATION;

    use Logging;

    enum TYPE_VARIANCE is
        INVARIANT,
        COVARIANT,
        CONTRAVARIANT
    si

    class GENERIC: NAMED is
        _is_wild: byte;
        _own_arguments: Collections.List[Type];
        _own_classy: Symbols.Classy;
        _lazy_owner: Symbols.GENERIC;

        arguments: Collections.List[Type] =>
            if _own_arguments? then
                _own_arguments;
            else
                symbol.arguments;
            fi;

        // Direct accessor for the underlying Classy. Falls back to
        // unwrapping the wrapped Symbols.GENERIC for the same
        // timing-edge-case reason that `arguments` does.
        classy: Symbols.Classy =>
            if _own_classy? then
                _own_classy;
            else
                let g = cast Symbols.GENERIC(symbol);
                if g? then g.symbol else null fi;
            fi;

        // Type-arg map keyed by classy.argument_names[i]. During the
        // transition we forward to the wrapped Symbols.GENERIC's
        // pre-built `type_map` (lazy — constructed on first access if
        // the LOCATION-form init didn't allocate one eagerly).
        type_map: Collections.Map[string, Type] =>
            let g = specialised_owner in
            if g? then g.type_map else null fi;

        // Override `.symbol` so consumers that go through it (including
        // NAMED.find_member, NAMED.scope, and external readers that
        // cast to Symbols.GENERIC) always see the wrapped/specialised
        // owner — even when β-5c flips the LOCATION-form init to pass
        // a bare Classy through super.init. Routes through
        // `specialised_owner` which lazy-constructs on first access.
        symbol: Symbols.Symbol => specialised_owner;

        // The wrapped Symbols.GENERIC. When the inherited NAMED._symbol
        // is already a Symbols.GENERIC (LOCATION-form init that still
        // eagerly constructs one, or GENERIC-form init that takes one
        // pre-built), return it. Otherwise — once β-5c flips the
        // LOCATION-form init to pass the Classy through `super.init`
        // — lazily construct + cache a Symbols.GENERIC matching this
        // type's classy + args.
        //
        // Reads `_symbol` directly (not via `.symbol`) to avoid
        // recursion through this class's `.symbol` override.
        specialised_owner: Symbols.GENERIC is
            if _lazy_owner? then
                return _lazy_owner;
            fi

            let s = cast Symbols.GENERIC(_symbol);

            if s? then
                _lazy_owner = s;

                return s;
            fi

            if _own_classy? /\ _own_arguments? then
                _lazy_owner = Symbols.GENERIC(_own_classy.location, _own_classy, _own_arguments);

                return _lazy_owner;
            fi

            return null;
        si

        // Hot NAMED getters that go through `.symbol` are overridden
        // here to read `_own_classy` directly. Same answer (since the
        // wrapped Symbols.GENERIC's symbol IS the Classy), but
        // independent of `.symbol`'s lazy construction in β-5c. Stops
        // every is_* check from triggering allocation once the
        // lazy-symbol switch flips.
        name: string =>
            if _own_classy? then
                _own_classy.name;
            else
                symbol.name;
            fi;

        is_value_type: bool =>
            if _own_classy? then
                _own_classy.is_value_type;
            else
                symbol? /\ symbol.is_value_type;
            fi;

        is_trait: bool =>
            if _own_classy? then
                _own_classy.is_trait;
            else
                symbol? /\ symbol.is_trait;
            fi;

        is_inheritable: bool =>
            if _own_classy? then
                _own_classy.is_inheritable;
            else
                symbol? /\ symbol.is_inheritable;
            fi;

        is_class: bool =>
            if _own_classy? then
                _own_classy.is_class;
            else
                symbol? /\ symbol.is_class;
            fi;

        is_object: bool =>
            if _own_classy? then
                _own_classy.is_object;
            else
                symbol? /\ symbol.is_object;
            fi;

        is_root_value_type: bool =>
            if _own_classy? then
                _own_classy.is_root_value_type;
            else
                symbol? /\ symbol.is_root_value_type;
            fi;

        is_void: bool =>
            if _own_classy? then
                _own_classy.is_void;
            else
                symbol? /\ symbol.is_void;
            fi;

        is_error: bool => arguments | .any(a => a.is_error);

        // should be
        // is_wild: bool => arguments | .any(a => a.is_wild)
        // but the following shaves about 10% off compiler build time
        is_wild: bool is
            if _is_wild == 0b then
                let a = symbol.arguments;
                let c = a.count;

                let i = 0;

                while i < c do
                    if a[i].is_wild then
                        _is_wild = 1b;
                        return true;
                    fi

                    i = i + 1;
                od

                _is_wild = 2b;
                return false;
            fi

            return _is_wild == 1b;  
        si

        is_any_any: bool => arguments | .any(a => a? /\ a.is_any_any);        

        short_description: string is
            assert self? else "self is null";
            assert symbol? else "symbol is null";
            assert symbol.name? else "symbol.name is null";
            assert arguments? else "arguments is null";

            let result = System.Text.StringBuilder();

            result
                .append(symbol.name)
                .append('[');

            let seen_any = false;

            for a in arguments do
                assert a? else "argument is null";

                if seen_any then
                    result.append(',');
                fi

                if a? then
                    result.append(a.short_description);
                fi

                seen_any = true;
            od

            result.append(']');

            return result.to_string();
        si

        is_function_with_any_implicit_argument_types: bool is
            if !is_function then
                return false;
            fi

            for i in 0..arguments.count -1 do
                if arguments[i].is_any then
                    return true;
                fi
            od
        si       

        init(
            symbol: Symbols.GENERIC
        ) is
            super.init(symbol);

            _own_arguments = symbol.arguments;
            _own_classy = symbol.symbol;
        si

        init(
            location: LOCATION,
            symbol: Symbols.Classy,
            args: Collections.List[Type]
        ) is
            // β-5c: drop the eager Symbols.GENERIC allocation. NAMED's
            // _symbol becomes the bare Classy; the lazy
            // `specialised_owner` constructs a Symbols.GENERIC only
            // when something explicitly needs it (member resolution,
            // Function.specialize_function owner, etc.).
            super.init(symbol);

            // Symbols.GENERIC's init eagerly reports an error when the
            // arg count doesn't match argument_names.count. Now that
            // the wrapped GENERIC is lazy, we'd lose that error
            // (callers might never trigger lazy construction). Mirror
            // the check here so the error fires at type-expression
            // resolution time.
            if symbol? /\ symbol.argument_names?
                /\ args? /\ args.count != symbol.argument_names.count then
                IoC.CONTAINER.instance.logger.error(
                    location,
                    "expected {symbol.argument_names.count} type arguments");
            fi

            _own_arguments = args;
            _own_classy = symbol;
        si

        create(
            location: LOCATION,
            symbol: Symbols.Classy,
            arguments: Collections.List[Type]
        ) -> GENERIC =>
            GENERIC(location, symbol, arguments);

        is_same_symbol(other: Type) -> bool is
            if !isa GENERIC(other) then
                return false;
            fi

            let other_generic = cast GENERIC(other);

            return classy == other_generic.classy;
        si

        get_argument_type_variance(index: int) -> TYPE_VARIANCE is
            let c = classy;

            if !c? then
                return TYPE_VARIANCE.INVARIANT;
            fi

            let declared = c.get_argument_variance(index);

            if declared == TYPE_VARIANCE.INVARIANT then
                return TYPE_VARIANCE.INVARIANT;
            fi

            // CLR rule: declared variance only applies when the actual type
            // argument is a reference type. Value-typed arguments are
            // invariant even on covariant/contravariant parameters.
            if index >= 0 /\ index < arguments.count /\ arguments[index]? /\ arguments[index].is_value_type then
                return TYPE_VARIANCE.INVARIANT;
            fi

            return declared;
        si

        get_element_type() -> Type => arguments[0];

        specialize_generic(type_map: Collections.Map[string,Type]) -> Types.GENERIC is
            let context = IoC.CONTAINER.instance.symbol_table.current_instance_context;

            let we_are_generic = context? /\ context.arguments.count > 0;

            let seen_any_new = false;

            let c = classy;
            let args = arguments;

            let new_arguments = Collections.LIST[Type](args.count);

            for i in 0..args.count do
                let argument_name = c.argument_names[i];

                let mapped_type: Type;

                // FIXME: this seems to fix #118 but don't think this is the correct place to put this check:
                if we_are_generic /\ type_map.try_get_value(argument_name, mapped_type ref) then
                    new_arguments.add(mapped_type);

                    seen_any_new = true;
                else
                    let oa = args[i];
                    let na = oa.specialize(type_map);

                    new_arguments.add(na);

                    if oa != na then
                        seen_any_new = true;
                    fi
                fi
            od

            if seen_any_new then
                let result = create(c.location, c, new_arguments);

                return result;
            else
                return self;
            fi
        si

        specialize(type_map: Collections.Map[string,Type]) -> Type =>
            specialize_generic(type_map);

        =~(other: Type) -> bool is
            if other.is_any then
                return true;
            fi

            // Fast path: same wrapped Symbols.GENERIC instance.
            if isa GENERIC(other) /\ symbol == (cast GENERIC(other)).symbol then
                return true;
            fi

            // Structural compare via TYPE_OPERATIONS so old (Types.GENERIC)
            // and new (Types.CLASS_TYPE) shapes are interchangeable.
            let other_classy = TYPE_OPERATIONS.try_get_classy(other);

            if !other_classy? \/ classy != other_classy then
                return false;
            fi

            let other_arguments = TYPE_OPERATIONS.try_get_arguments(other);
            let my_arguments = arguments;

            if !other_arguments? \/ other_arguments.count != my_arguments.count then
                return false;
            fi

            for i in 0..my_arguments.count do
                if my_arguments[i] !~ other_arguments[i] then
                    return false;
                fi
            od

            return true;
        si

        compare_direct(other: Type) -> Types.MATCH is
            if other.is_any then
                return Types.MATCH.SAME;
            fi

            // Fast path: same wrapped Symbols.GENERIC instance.
            if isa GENERIC(other) /\ symbol == (cast GENERIC(other)).symbol then
                return Types.MATCH.SAME;
            fi

            // Structural compare via TYPE_OPERATIONS — recognises both
            // Types.GENERIC (old shape) and Types.CLASS_TYPE (new shape).
            let other_classy = TYPE_OPERATIONS.try_get_classy(other);

            if !other_classy? \/ classy != other_classy then
                return Types.MATCH.DIFFERENT;
            fi

            let other_arguments = TYPE_OPERATIONS.try_get_arguments(other);
            let my_arguments = arguments;

            if !other_arguments? \/ other_arguments.count != my_arguments.count then
                return Types.MATCH.DIFFERENT;
            fi

            let result = Types.MATCH.SAME;

            // Use the other side's variance, matching the original
            // compare_direct (the value-type-suppresses-variance check
            // is keyed on the actual argument-side type).
            let other_generic = cast GENERIC(other);

            for i in 0..my_arguments.count do
                let variance =
                    if other_generic? then
                        other_generic.get_argument_type_variance(i);
                    else
                        get_argument_type_variance(i);
                    fi;

                let argument_score: Types.MATCH;

                if variance == TYPE_VARIANCE.COVARIANT then
                    argument_score = my_arguments[i].compare(other_arguments[i]);
                elif variance == TYPE_VARIANCE.CONTRAVARIANT then
                    argument_score = other_arguments[i].compare(my_arguments[i]);
                elif my_arguments[i] =~ other_arguments[i] then
                    argument_score = Types.MATCH.SAME;
                else
                    return Types.MATCH.DIFFERENT;
                fi

                if cast int(argument_score) > cast int(result) then
                    result = argument_score;
                fi
            od

            return result;
        si

        compare(other: Type) -> Types.MATCH is
            if other.is_null then
                return Types.MATCH.ASSIGNABLE;                
            elif symbol == null \/ other == null then
                return Types.MATCH.DIFFERENT;
            elif other.is_named then                    
                let direct_score = compare_direct(other);

                if cast int(direct_score) <= cast int(Types.MATCH.ASSIGNABLE) then
                    return direct_score;
                fi

                for i in 0..other.symbol.ancestors.count do
                    let a = other.symbol.get_ancestor(i);

                    let match = self.compare(a);

                    if cast int(match) <= cast int(Types.MATCH.ASSIGNABLE) then
                        return Types.MATCH.ASSIGNABLE;
                    elif match == Types.MATCH.CONVERTABLE then
                        return Types.MATCH.CONVERTABLE;
                    fi
                od
            fi

            if is_wild \/ other.is_wild then
                return Types.MATCH.WILD;
            fi

            return Types.MATCH.DIFFERENT;
        si

        // attempt to bind type variables in this generic against concrete types in 
        // other by pattern matching
        bind_type_variables(other: Type, results: GENERIC_ARGUMENT_BIND_RESULTS) -> bool is
            if other.is_null then
                return true;
            fi

            // Recognises both Types.GENERIC (old shape) and
            // Types.CLASS_TYPE (new shape) as applications via
            // TYPE_OPERATIONS.
            let other_classy = TYPE_OPERATIONS.try_get_classy(other);
            let other_arguments = TYPE_OPERATIONS.try_get_arguments(other);

            if other_classy? /\ other_arguments? /\ classy == other_classy then
                let my_arguments = arguments;
                let result = true;

                for i in 0..my_arguments.count do
                    result = my_arguments[i].bind_type_variables(other_arguments[i], results) /\ result;
                od

                return result;
            fi

            // Walk other's specialised ancestors. get_ancestor(i)
            // applies other's type-arg map to the unspec ancestor
            // type — needed so we can recurse from LIST[int] into
            // Iterable[int] (not Iterable[T]).
            if other.symbol? /\ other.symbol.ancestors? then
                for i in 0..other.symbol.ancestors.count do
                    let a = other.symbol.get_ancestor(i);

                    if bind_type_variables(a, results) then
                        return true;
                    fi
                od
            fi

            return false;
        si

        get_type_arguments_into(results: Collections.LIST[GenericArgument]) is
            for a in arguments do
                a.get_type_arguments_into(results);
            od
        si

        walk(action: (Type) -> void) is
            for a in arguments do
                a.walk(action);
            od

            super.walk(action);
        si

        to_string() -> string => symbol.to_string();
    si
si
