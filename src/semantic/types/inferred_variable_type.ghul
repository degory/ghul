namespace Semantic.Types is
    use System.Text.StringBuilder;

    use Source;

    // Per-instance deferred-inference placeholder for a Variable
    // (lambda argument symbol or local). Carries a back-pointer to
    // its origin symbol so that overload resolution and other
    // walks can call origin.add_constraint(matched_type) when this
    // placeholder participates in a slot whose other side is
    // concrete.
    //
    // Distinct from INFERRED_RETURN_TYPE: that one is a singleton
    // sentinel for return-type inference (no origin needed). This
    // one stands in for a specific symbol's not-yet-known type and
    // must keep instance identity so the match propagation reaches the
    // right symbol.
    //
    // is_wild = false (deliberately, mirroring INFERRED_RETURN_TYPE's
    // 1362faef fix). The 2024 abandoned attempt at this had
    // is_wild = true and hit ambiguous-overload false-positives
    // where shape-mismatching formals won the WILD fallback.
    class INFERRED_VARIABLE_TYPE(origin: Symbols.Variable): Type is
        is_null: bool => true;
        is_any: bool => true;
        is_any_any: bool => true;
        is_wild: bool => false;
        is_inferred: bool => true;
        is_sentinel: bool => true;

        init(..) is
            assert origin? else "INFERRED_VARIABLE_TYPE origin symbol cannot be null";
        si

        specialize(type_map: Collections.Map[string,Type]) -> Type => self;

        =~(other: Type) -> bool => true;

        compare(other: Type) -> Types.MATCH => MATCH.ASSIGNABLE;

        // Same safe-placeholder rationale as INFERRED_RETURN_TYPE:
        // the eager closure-freeze on the first walk of an
        // unresolved lambda may emit IL referencing this type.
        // Final IL never contains the comment — the next iteration
        // re-walks with the resolved type and re-freezes.
        //
        // Resolution-at-emit fallback: when the origin has settled
        // through the body-retry loop / default-fill pass, but the
        // outer Variable's type field still holds a composite
        // referencing self, forward emission to the resolved type.
        // Without this, a chain like `let v3 = LIST(); v3.add("x");
        // let v5; v5 = v3;` leaves v5.type = LIST[self] even after
        // v3's T phantom resolves, and IL emits a non-loadable
        // `List`1 <comment>` reference. Gate on is_settled so a
        // still-provisional origin doesn't risk further recursion.
        gen_type(buffer: StringBuilder) is
            let resolved = origin.try_get_inferred_type();

            if resolved? /\ resolved.is_settled then
                resolved.gen_type(buffer);
            else
                buffer.append("/* inferred variable type placeholder */");
            fi
        si

        gen_class_name(buffer: StringBuilder) is
            let resolved = origin.try_get_inferred_type();

            if resolved? /\ resolved.is_settled then
                resolved.gen_class_name(buffer);
            else
                buffer.append("/* inferred variable type placeholder */");
            fi
        si

        // Treated as a leaf type for walk-based analyses. The
        // default Type.walk(action) throws to catch genuine bugs
        // where compound types forget to override; placeholders
        // have no children to recurse into and aren't bugs to
        // catch — they're an expected first-walk transient state.
        // is_type_variable returns false on this type, so callers
        // like Closure._get_actual_arguments that check it for
        // type-variable references see a no-op visit, which is
        // correct: the placeholder isn't a generic-argument
        // reference, just an unresolved local type.
        walk(action: (Type) -> void) is
            action(self);
        si

        // Mirror gen_type / gen_class_name: when the origin's
        // body-retry / match propagation has settled the phantom to a concrete
        // type, render that — otherwise return the bare placeholder.
        // Without this, analysis-mode HOVER on a specialised symbol
        // whose owner type-arg was resolved by sibling match propagation (LUB
        // merge, overload resolver) still renders `***` because the
        // owner's type_map points at this still-named placeholder
        // instance whose to_string was hard-coded to the marker.
        to_string() -> string is
            let resolved = origin.try_get_inferred_type();

            if resolved? /\ resolved.is_settled then
                return resolved.to_string();
            fi

            return "***";
        si
    si
si
