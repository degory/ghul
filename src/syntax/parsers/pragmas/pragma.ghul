namespace Syntax.Parsers.Pragmas is

    use Source;

    use Logging;

    class PRAGMA(
        qualified_identifier_parser: Parser[Trees.Identifiers.Identifier],
        expression_parser: Parser[Trees.Expressions.Expression]
    ): Base[Trees.Pragmas.PRAGMA] is
        qualified_identifier_parser;
        expression_parser;

        super();

        parse(context: CONTEXT) -> Trees.Pragmas.PRAGMA? is
            let start = context.location;

            if !context.next_token(Lexical.TOKEN.AT) then
                return null;
            fi

            let name = qualified_identifier_parser.parse(context);

            if !name? then
                return null;
            fi

            let positional = Collections.LIST[Trees.Expressions.Expression]();
            let named: Collections.LIST[Trees.Pragmas.NAMED_ARGUMENT] mut = default;

            if context.next_token(Lexical.TOKEN.PAREN_OPEN) then
                if context.current.token != Lexical.TOKEN.PAREN_CLOSE then
                    do
                        let expression = expression_parser.parse(context);

                        let identifier_expression = cast Trees.Expressions.IDENTIFIER(expression);

                        if
                            identifier_expression? /\
                            identifier_expression.is_unqualified_identifier /\
                            context.current.token == Lexical.TOKEN.ASSIGN
                        then
                            context.next_token();

                            let value = expression_parser.parse(context);

                            if !named? then
                                named = Collections.LIST[Trees.Pragmas.NAMED_ARGUMENT]();
                            fi

                            named.add(
                                Trees.Pragmas.NAMED_ARGUMENT(identifier_expression.identifier, value)
                            );
                        else
                            positional.add(expression);
                        fi

                        if context.current.token != Lexical.TOKEN.COMMA then
                            break;
                        fi

                        context.next_token();

                        // Trailing comma before the closing parenthesis.
                        if context.current.token == Lexical.TOKEN.PAREN_CLOSE then
                            break;
                        fi
                    od
                fi

                context.next_token(Lexical.TOKEN.PAREN_CLOSE);
            fi

            return Trees.Pragmas.PRAGMA(
                start::context.location,
                name,
                Trees.Expressions.LIST(start::context.location, positional),
                named
            );
        si
    si
si
