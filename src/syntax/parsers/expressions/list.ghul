namespace Syntax.Parsers.Expressions is
    use IO.Std;

    use Source;

    class LIST(expression_parser: Parser[Trees.Expressions.Expression]): Base[Trees.Expressions.LIST] is
        super();

        description: string => "expression list";

        parse(context: CONTEXT) -> Trees.Expressions.LIST is
            let start = context.location;
            let expressions = Collections.LIST[Trees.Expressions.Expression]();

            do
                context.allow_tuple_element = true;
                let expression = expression_parser.parse(context);
                context.allow_tuple_element = false;

                // The expression parser chain bottoms out at a poisoned
                // placeholder rather than null, but that's an invariant of
                // the current wiring, not a contract: guard here so a
                // future element parser without that override can't put
                // a null in the list.
                if !expression? then
                    break;
                fi

                expressions.add(expression);

                if context.current.token != Lexical.TOKEN.COMMA then
                    return Trees.Expressions.LIST(start::expression.location, expressions);
                fi

                context.next_token();

                // Trailing comma: stop when a closing bracket follows.
                // The same parser drives list literals (`[a, b,]`),
                // tuple literals (`(a, b,)`) and call argument lists
                // (`f(a, b,)`), so one check covers all three.
                if
                    context.current.token == Lexical.TOKEN.SQUARE_CLOSE \/
                    context.current.token == Lexical.TOKEN.PAREN_CLOSE
                then
                    return Trees.Expressions.LIST(start::context.location, expressions);
                fi
            od

            return Trees.Expressions.LIST(start::context.location, expressions);
        si
    si
si
