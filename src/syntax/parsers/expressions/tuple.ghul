namespace Syntax.Parsers.Expressions is
    use IO.Std;

    use Source;

    class TUPLE(
        expression_list_parser: Parser[Trees.Expressions.LIST],
        statement_parser: Parser[Trees.Statements.Statement],
        variable_list_parser: Parser[Trees.Variables.LIST]
    ): Base[Trees.Expressions.Expression] is
        description: string => "tuple";

        super();

        parse(context: CONTEXT) -> Trees.Expressions.Expression? is
            let start = context.location;

            if context.next_token(Lexical.TOKEN.PAREN_OPEN, syntax_error_message) then
                if context.current.token == Lexical.TOKEN.PAREN_CLOSE then
                    let empty = Trees.Expressions.LIST(context.location, Collections.LIST[Trees.Expressions.Expression]());
                    empty.rewrite_as_tuple_elements();
                    context.next_token(Lexical.TOKEN.PAREN_CLOSE, syntax_error_message);
                    return Trees.Expressions.TUPLE(start::context.location, empty, false);
                fi

                // `let` in expression position requires `in body`, but inside
                // `(...)` it may instead be a block expression's first binding
                // statement (`(let x = e; rest)`). The two are distinguished
                // by what follows the variable list — `;` is a block, `in`
                // is a parenthesised let-in expression. Decide by peeking.
                if context.current_token == Lexical.TOKEN.LET /\ is_let_starting_block(context) then
                    return parse_statement_starting_block(context, start);
                fi

                // Tokens that unambiguously start a statement that is not also
                // an expression (`assert`, `return`, `for`, …) route straight
                // into the block path — no peek needed.
                if _starts_statement_only_block(context.current_token) then
                    return parse_statement_starting_block(context, start);
                fi

                // Speculate as an expression list. The token sequence after
                // `(` falls into one of four shapes:
                //
                //   `(expression)`           — parenthesised expression
                //   `(stmt; …)` / `(stmt)`   — block expression
                //   `(elem, elem, …)`        — tuple (named elements allowed)
                //   `(formals) =>/is/rec …`  — lambda formal list
                //
                // The expression-list parse with tuple-element naming on
                // succeeds for the first, third, and fourth shapes, but it
                // also silently succeeds for `(name = value)` and similar
                // single-element named-tuple-element shapes that don't have
                // a valid 1-tuple reading. Disambiguate after the probe:
                //
                //   - Expression list didn't end at `;` or `)`         → not
                //     a valid expression-list parse (e.g. `=` after a
                //     qualified-name LHS). Backtrack to the statement parser.
                //
                //   - Single VARIABLE without an initialiser + closing `)`
                //     followed by `=>` / `is` / `arrow_thin` / `rec`   →
                //     lambda formal list (`(n: int) => body`, etc.). Keep
                //     the TUPLE wrapper so the secondary parser can pick
                //     the formals up. A VARIABLE *with* an initialiser is
                //     never a valid formal — ghūl has no default formal
                //     values — so the initialiser form falls through to
                //     the statement-parser path even when a lambda token
                //     follows.
                //
                //   - Other single VARIABLE element + closing `)`      → not
                //     a valid expression (no 1-tuples and the only sensible
                //     statement interpretation is assignment, or — for
                //     `(n: int)` outside lambda position — a syntactically
                //     dead form that the statement parser will reject).
                //     Backtrack to the statement parser.
                //
                //   - Single element + closing `)`, non-VARIABLE       →
                //     `(expression)`. Collapse to the bare inner expression.
                //
                //   - Single element + closing `;`, non-VARIABLE       →
                //     block whose first item is an expression-statement.
                //
                //   - Single element + closing `;`, VARIABLE           →
                //     backtrack to the statement parser (block whose first
                //     statement is an assignment).
                //
                //   - 2+ elements + closing `)` or `;`                 →
                //     tuple or mixed-block (the existing block path raises
                //     the `,`/`;` mix error).
                let use tokenizer_snapshot = context.tokenizer_speculate_then_commit();
                let use logger_snapshot = context.logger_speculate_then_commit();

                let expressions = expression_list_parser.parse(context);
                let inner = context.current_token;

                let single_variable_without_initializer =
                    expressions.count == 1 /\
                    if let v: Trees.Expressions.VARIABLE = expressions.expressions[0] then
                        !v.initializer?
                    else
                        false
                    fi;

                let single_variable =
                    expressions.count == 1 /\
                    isa Trees.Expressions.VARIABLE(expressions.expressions[0]);

                let lambda_position =
                    single_variable_without_initializer /\
                    inner == Lexical.TOKEN.PAREN_CLOSE /\
                    _peek_lambda_token_after_close(context);

                let ends_cleanly =
                    inner == Lexical.TOKEN.PAREN_CLOSE \/
                    inner == Lexical.TOKEN.SEMICOLON;

                if !ends_cleanly \/ (single_variable /\ !lambda_position) then
                    tokenizer_snapshot.backtrack();
                    logger_snapshot.backtrack();
                    return parse_statement_starting_block(context, start);
                fi

                if inner == Lexical.TOKEN.SEMICOLON then
                    return parse_block_after_expressions(context, start, expressions);
                fi

                if expressions.count == 1 /\ !lambda_position then
                    // Single-element `(...)` is a parenthesised expression,
                    // not a 1-tuple: collapse to the inner expression here
                    // rather than wrapping in a TUPLE node that downstream
                    // passes would unwrap anyway.
                    context.next_token(Lexical.TOKEN.PAREN_CLOSE, syntax_error_message);
                    return expressions.expressions[0];
                fi

                expressions.rewrite_as_tuple_elements();

                context.next_token(Lexical.TOKEN.PAREN_CLOSE, syntax_error_message);

                return Trees.Expressions.TUPLE(start::context.location, expressions, false);
            fi
            return null;
        si

        // Peek past the current `)` to see whether one of the lambda-body
        // intro tokens follows. Used to keep `(formals) => body` (and the
        // `is` / `arrow_thin` / `rec` variants) on the TUPLE-wrapped
        // expression path so the secondary parser can pick the formals up,
        // including the named-tuple-element shape `(name = value) => body`
        // that would otherwise look like a stray 1-tuple to the
        // disambiguator. The current token is required to be `)`.
        _peek_lambda_token_after_close(context: CONTEXT) -> bool is
            let use tokenizer_snapshot = context.tokenizer_speculate_then_backtrack();
            let use logger_snapshot = context.logger_speculate_then_backtrack();

            context.next_token();

            let beyond = context.current_token;

            return
                beyond == Lexical.TOKEN.ARROW_FAT \/
                beyond == Lexical.TOKEN.ARROW_THIN \/
                beyond == Lexical.TOKEN.IS \/
                beyond == Lexical.TOKEN.REC;
        si

        // Speculatively parse `let [use] variable_list` and report whether
        // a `;` follows — i.e. whether this is a block expression starting
        // with a `let` binding statement rather than a `let ... in body`
        // expression. Cheap because it only runs when the first token is
        // `LET`, which is rare relative to all `(` occurrences.
        is_let_starting_block(context: CONTEXT) -> bool is
            let use logger_snapshot = context.logger_speculate_then_backtrack();
            let use tokenizer_snapshot = context.tokenizer_speculate_then_backtrack();

            context.next_token();

            if context.current_token == Lexical.TOKEN.USE then
                context.next_token();
            fi

            let probe = variable_list_parser.parse(context);

            return probe? /\ context.current_token == Lexical.TOKEN.SEMICOLON;
        si

        // Block expression starting with a statement (rather than an
        // expression). The first item is parsed via the statement parser so
        // a leading `let` scopes its bindings over the rest of the block,
        // and statement-only forms (`assert`, `for`, `while`, …) compose
        // with the same block machinery as expressions.
        parse_statement_starting_block(
            context: CONTEXT,
            start: LOCATION
        ) -> Trees.Expressions.Expression is
            let statements = Collections.LIST[Trees.Statements.Statement]();

            let first = statement_parser.parse(context);

            if first? then
                statements.add(first);
            fi

            return parse_block_continuation(context, start, statements);
        si

        _starts_statement_only_block(token: Lexical.TOKEN) -> bool =>
            token == Lexical.TOKEN.ASSERT \/
            token == Lexical.TOKEN.RETURN \/
            token == Lexical.TOKEN.YIELD \/
            token == Lexical.TOKEN.THROW \/
            token == Lexical.TOKEN.TRY \/
            token == Lexical.TOKEN.WHILE \/
            token == Lexical.TOKEN.DO \/
            token == Lexical.TOKEN.FOR \/
            token == Lexical.TOKEN.BREAK \/
            token == Lexical.TOKEN.CONTINUE \/
            token == Lexical.TOKEN.AT;

        // Block expression continuation after the first item(s) parsed as
        // expressions. Each expression becomes an EXPRESSION statement.
        // If `,` had been consumed earlier (so multiple expressions are in
        // `first`), report the mixed-separator error.
        parse_block_after_expressions(
            context: CONTEXT,
            start: LOCATION,
            first: Trees.Expressions.LIST
        ) -> Trees.Expressions.Expression is
            let statements = Collections.LIST[Trees.Statements.Statement]();

            if first.count > 1 then
                context.error(
                    first.location,
                    "cannot mix `,` and `;` inside `(...)` — use `,` for a tuple or `;` for a block expression"
                );
            fi

            for e in first do
                statements.add(Trees.Statements.EXPRESSION(e.location, e));
            od

            return parse_block_continuation(context, start, statements);
        si

        // Common tail: consume `;`-separated trailing statements until `)`.
        // The block's value comes from the last value-providing statement
        // in the resulting `Statements.LIST`, via the same mechanism
        // `if`/`case` arms already use.
        parse_block_continuation(
            context: CONTEXT,
            start: LOCATION,
            statements: Collections.LIST[Trees.Statements.Statement]
        ) -> Trees.Expressions.Expression is
            while context.current_token == Lexical.TOKEN.SEMICOLON do
                context.next_token();

                // Trailing `;` immediately before the close paren is allowed.
                if context.current_token == Lexical.TOKEN.PAREN_CLOSE then
                    break;
                fi

                let next = statement_parser.parse(context);

                if next? then
                    statements.add(next);
                fi
            od

            let end = context.location;
            context.next_token(Lexical.TOKEN.PAREN_CLOSE, syntax_error_message);

            let list = Trees.Statements.LIST(start::end, statements);

            return Trees.Expressions.STATEMENT(start::end, list);
        si
    si
si
