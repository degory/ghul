namespace Syntax.Parsers.Expressions is
    use IO.Std;

    use Source;
    use Logging;

    class SECONDARY(
        identifier_parser: Parser[Trees.Identifiers.Identifier],
        type_parser: Parser[Trees.TypeExpressions.TypeExpression],
        type_list_parser: Parser[Trees.TypeExpressions.LIST],
        expression_parser: Parser[Trees.Expressions.Expression],
        expression_primary_parser: Parser[Trees.Expressions.Expression],
        expression_list_parser: Parser[Trees.Expressions.LIST],
        body_parser: Parser[Trees.Bodies.Body]
    ): Base[Trees.Expressions.Expression] is
        description: string => "secondary expression";

        super();

        // A token sits in identifier position after a `.` if it
        // looks like a word (its `value_string` opens with a letter
        // or underscore) and it shares a line with the dot. The
        // line guard matters: a `.` at the end of a line followed
        // by a structural keyword on the next (`namespace Foo.\n is`)
        // must not eat that keyword.
        looks_like_partial_member_keyword(context: CONTEXT, dot_location: LOCATION) -> bool is
            if context.current.token == Lexical.TOKEN.IDENTIFIER then
                return false;
            fi

            let s = context.current.value_string;

            if !s? \/ s.length == 0 then
                return false;
            fi

            let first = s.get_chars(0);

            if !((first >= 'a' /\ first <= 'z') \/ (first >= 'A' /\ first <= 'Z') \/ first == '_') then
                return false;
            fi

            return context.current.location.start_line == dot_location.start_line;
        si

        // `|` is overloaded postfix pipe-wrap (`Ghul.Pipes.pipe(...)`)
        // vs infix bitwise OR. It defaults to the infix reading; the
        // postfix reading wins only when the next token cannot start
        // an infix right-hand side. The "cannot start" set is
        // bounded: expression terminators, postfix-only tokens, and
        // block-structure keywords. Anything else (a primary start,
        // an `OPERATOR` token that might be a prefix unary, `await`,
        // `if`, `case`, …) leaves the operator as infix and the
        // precedence climber takes it from there. Wrap the LHS in
        // parentheses to force the postfix reading when the operand
        // would otherwise look infix-shaped: `(xs|)` as a bare
        // pipe-wrap.
        token_blocks_infix_rhs(token: Lexical.TOKEN) -> bool static is
            case token
            when
                Lexical.TOKEN.SEMICOLON,
                Lexical.TOKEN.COMMA,
                Lexical.TOKEN.PAREN_CLOSE,
                Lexical.TOKEN.SQUARE_CLOSE,
                Lexical.TOKEN.END_OF_INPUT,

                Lexical.TOKEN.DOT,
                Lexical.TOKEN.ASSIGN,
                Lexical.TOKEN.QUESTION,
                Lexical.TOKEN.REF,

                Lexical.TOKEN.IS,
                Lexical.TOKEN.SI,
                Lexical.TOKEN.FI,
                Lexical.TOKEN.OD,
                Lexical.TOKEN.YRT,
                Lexical.TOKEN.ESAC,
                Lexical.TOKEN.ELSE,
                Lexical.TOKEN.ELIF,
                Lexical.TOKEN.THEN,
                Lexical.TOKEN.DO,
                Lexical.TOKEN.UNTIL,
                Lexical.TOKEN.WHEN,
                Lexical.TOKEN.IN,
                Lexical.TOKEN.ARROW_THIN,
                Lexical.TOKEN.ARROW_FAT,
                Lexical.TOKEN.CATCH,
                Lexical.TOKEN.FINALLY,

                Lexical.TOKEN.CONTINUE_STRING,
                Lexical.TOKEN.EXIT_STRING,
                Lexical.TOKEN.CANCEL_STRING,
                Lexical.TOKEN.FORMAT_STRING
            then
                return true;
            else
                return false;
            esac
        si

        // Peek the token after the current one and report whether it
        // sits in the `token_blocks_infix_rhs` set. The speculate /
        // backtrack pair rolls the tokenizer back before returning.
        next_token_blocks_infix_rhs(context: CONTEXT) -> bool is
            let use snapshot = context.tokenizer_speculate_then_backtrack();

            context.next_token();

            return token_blocks_infix_rhs(context.current.token);
        si

        parse(context: CONTEXT) -> Trees.Expressions.Expression is
            let use tokenizer_state = context.tokenizer_speculate_then_commit();

            let start = context.location;
            let result: Trees.Expressions.Expression mut = expression_primary_parser.parse(context)!;

            let previous_left: Trees.Expressions.Expression? mut = default;
            let previous_identifier: Trees.Identifiers.Identifier? mut = default;

            do
                case context.current.token
                when Lexical.TOKEN.PAREN_OPEN then
                    context.next_token();
                    let arguments: Trees.Expressions.LIST mut;
                    if context.current.token != Lexical.TOKEN.PAREN_CLOSE then
                        arguments = expression_list_parser.parse(context)!;
                    else
                        arguments = Trees.Expressions.LIST(context.location, Collections.LIST[Trees.Expressions.Expression]());
                    fi
                    let call_expression = Trees.Expressions.CALL(start::context.location, result, arguments);
                    call_expression.rewrite_named_arguments(context.logger);
                    result = call_expression;
                    context.next_token(Lexical.TOKEN.PAREN_CLOSE, syntax_error_message);

                when Lexical.TOKEN.SQUARE_OPEN then
                    context.next_token();

                    let done mut = false;

                    let left: Trees.Expressions.Expression? mut = default;
                    let identifier: Trees.Identifiers.Identifier? mut = default;

                    if result.is_member then
                        left = previous_left;
                        identifier = previous_identifier;

                    elif result.is_identifier then
                        left = null;
                        identifier = result.try_copy_as_identifer();
                    fi

                    if identifier? then
                        let use tokenizer_state = context.tokenizer_speculate_then_commit();
                        let use logger_state = context.logger_speculate_then_commit();
    
                        let type_arguments = type_list_parser.parse(context);

                        if type_arguments? /\ !type_arguments.is_poisoned /\ context.next_token(Lexical.TOKEN.SQUARE_CLOSE) then
                            let index_expression: Trees.Expressions.Expression? mut = default;

                            if type_arguments.count == 1 then
                                let index = type_arguments.elements[0].try_copy_as_value_expression();
                                if index? then
                                    index_expression = Trees.Expressions.INDEX(start::context.location, result, index);
                                fi
                            fi;

                            done = true;

                            if index_expression? then
                                result = Trees.Expressions.AMBIGUOUS_EXPRESSION(
                                    start::context.location,
                                    index_expression,
                                    left,
                                    identifier,
                                    type_arguments
                                );
                            else
                                result = Trees.Expressions.GENERIC_APPLICATION(
                                    start::context.location,
                                    left,
                                    identifier,
                                    type_arguments
                                );
                            fi

                            tokenizer_state.commit();
                            logger_state.commit();

                            // FIXME: continue generates incorrect code here
                            // continue;
                        fi

                        tokenizer_state.backtrack_if_speculating();
                        logger_state.backtrack_if_speculating();
                    fi

                    if !done then
                        let index = expression_parser.parse(context)!;

                        result = Trees.Expressions.INDEX(start::context.location, result, index);

                        context.next_token(Lexical.TOKEN.SQUARE_CLOSE, syntax_error_message);
                    fi

                when Lexical.TOKEN.DOT then
                    let completion_target_start = context.location;

                    context.next_token();

                    if
                        context.current.token == Lexical.TOKEN.IDENTIFIER
                    then
                        let member = identifier_parser.parse(context)!;

                        previous_left = result;
                        previous_identifier = member;

                        result = Trees.Expressions.MEMBER(start::member.location, result, member, completion_target_start::member.location);
                    elif looks_like_partial_member_keyword(context, completion_target_start) then
                        // Mid-typing case like `value.is` (en route to
                        // `value.is_empty`). The token is a reserved
                        // word the tokenizer has already classified,
                        // but it sits in identifier position after a
                        // `.`; treat it as a partial member name so
                        // the completer has a MEMBER node with a
                        // populated `right` to anchor suggestions on.
                        // The same-line guard prevents this consuming
                        // a structural keyword on the next line
                        // (`namespace Test.\n is`).
                        let name = context.current.value_string;
                        let member = Trees.Identifiers.Identifier(context.location, name);
                        context.next_token();

                        previous_left = result;
                        previous_identifier = member;

                        result = Trees.Expressions.MEMBER(start::member.location, result, member, completion_target_start::member.location);
                    elif
                        context.current.token == Lexical.TOKEN.INT_LITERAL \/
                        context.current.token == Lexical.TOKEN.FLOAT_LITERAL \/
                        context.current.token == Lexical.TOKEN.DOUBLE_LITERAL
                    then
                        // `.` followed by a numeric literal, e.g. `p.0`.
                        // Positional tuple members are named by their
                        // index, but a bare number is not an identifier, so
                        // the index must be backtick-escaped (`p.` followed
                        // by a backtick and the number). Point at that, then
                        // consume the number so it doesn't linger and
                        // cascade into a spurious "expected ;" on the rest of
                        // the statement. Recover with a poisoned placeholder
                        // identifier so later passes that assume
                        // MEMBER.identifier is non-null don't crash.
                        context.error(context.location, "a numeric member name must be escaped with a leading backtick");
                        let member_location = context.location;
                        context.next_token();
                        result = Trees.Expressions.MEMBER(start::member_location, result, Trees.Identifiers.Identifier(completion_target_start, null), completion_target_start::member_location);
                    else
                        // `.` not followed by a member name: expect_token
                        // reports it. Recover with a poisoned placeholder
                        // identifier rather than null — later passes assume
                        // MEMBER.identifier is non-null and would otherwise
                        // crash dereferencing it. The offending token is left
                        // for the enclosing context to resynchronise on.
                        context.expect_token(Lexical.TOKEN.IDENTIFIER);
                        result = Trees.Expressions.MEMBER(start..context.location, result, Trees.Identifiers.Identifier(completion_target_start, null), completion_target_start::context.location);
                    fi

                when Lexical.TOKEN.ARROW_THIN, Lexical.TOKEN.ARROW_FAT, Lexical.TOKEN.IS, Lexical.TOKEN.REC then
                    // we could be in a global function or in a method. If the left part looks like it could be a function or method definition
                    // then it's an error and we need to recover. 

                    // we'll need a heuristic to try to decide if the user is trying to define a nested function or if they've missed off a closing `si`
                    // and actually this is a method definition (if we're in a classy context) or a global function definition (if we're not in a classy context)

                    let is_nested_function_definition mut = false;

                    if result.could_be_nested_function_definition /\ tokenizer_state.is_speculating then
                        // TODO need same logic but for nested within a global function
                        if context.in_member then
                            if result.location.start_column > context.member_indent then
                                // probably an attempt at nesting a named function definition
                                is_nested_function_definition = true;
                            elif 
                                result.location.start_column <= context.member_indent /\
                                result.location.start_column > context.global_indent    
                            then
                                // probably a missing `si` in a preceding member definition
                                context.error(result.location, "expected 'si' after member definition");

                                tokenizer_state.backtrack();

                                throw UNWIND_TO_MEMBER_EXCEPTION(null);
                            fi
                        elif context.in_global_function then
                            if result.location.start_column > context.global_indent then
                                // probably an attempt at nesting a named function definition
                                is_nested_function_definition = true;
                            else
                                // probably a missing `si` in a preceding member definition
                                context.error(result.location, "expected 'si' after member definition");

                                tokenizer_state.backtrack();

                                throw UNWIND_TO_GLOBAL_EXCEPTION(null);
                            fi
                        elif context.in_classy then
                            // not clear how we might have ended up here
                            tokenizer_state.backtrack();

                            throw UNWIND_TO_GLOBAL_EXCEPTION(null);
                        fi
                    fi

                    // it's unlikely to be member or global function definition, so we should
                    // parse it as a function literal, even if it has a name or is otherwise garbled.
                    // In particular, if has a block body delimited with with is / si, then we want to
                    // consume that block, otherwise our view of the block structure will get out of sync
                    // and we'll think we've let the enclosing function or method when we reach the closing
                    // `si` of the function literal

                    let should_poison mut = false;
                    
                    if result.could_be_nested_function_definition then
                        should_poison = true;
                        context.error(result.location, "nested function definition");
                    elif !result.could_be_formal_argument then
                        should_poison = true;
                        context.error(result.location, "expected function literal formal arguments");
                    fi
    
                    let type_expression: Trees.TypeExpressions.TypeExpression mut;
                    let arguments: Trees.Expressions.LIST mut;

                    if context.current.token == Lexical.TOKEN.ARROW_THIN then
                        context.next_token();
                        type_expression = type_parser.parse(context)!;
                        type_expression.check_is_not_reference(context.logger, "function cannot return a reference");
                    else
                        type_expression = Trees.TypeExpressions.INFER(start::result.location);
                    fi

                    if context.expect_token([Lexical.TOKEN.ARROW_FAT, Lexical.TOKEN.IS, Lexical.TOKEN.REC]) then
                        if should_poison then
                            // error already reported
                            arguments = Trees.Expressions.LIST(start::result.location, Collections.LIST[Trees.Expressions.Expression]());                                
                        elif isa Trees.Expressions.TUPLE(result) then
                            arguments = result.elements;
                            arguments.rewrite_as_variables();
                        else
                            let elements = Collections.LIST[Trees.Expressions.Expression]();
                            elements.add(result);
                            arguments = Trees.Expressions.LIST(start::result.location, elements);
                        fi

                        let is_recursive =
                            if context.current.token == Lexical.TOKEN.REC then
                                context.next_token();
                                true;
                            else
                                false;
                            fi;

                        // A lambda body is a fresh statement context. The
                        // enclosing argument list leaves allow_tuple_element
                        // set while an argument expression parses, so without
                        // this reset the body's leading `x = e` statement is
                        // consumed as a formal-argument-style variable
                        // declaration rather than an assignment.
                        context.allow_tuple_element = false;

                        let body = body_parser.parse(context)!;

                        result = 
                            Trees.Expressions.FUNCTION(
                                start::body.location,
                                arguments,
                                type_expression,
                                body,
                                is_recursive
                            );

                        if should_poison then
                            result.poison();
                        fi

                        return result;
                    else
                        // TODO: is this possible?
                        return Trees.Expressions.Literals.NONE(start::context.location);
                    fi

                when Lexical.TOKEN.QUESTION then
                    let question_location = context.location;
                    tokenizer_state.commit_if_speculating();

                    context.next_token();

                    if context.current.token == Lexical.TOKEN.DOT then
                        // `?.` coalescing member access. Tokenizer
                        // breaks `?.` into two adjacent tokens (per
                        // the `?`/`!` followed-by-`.` rule in
                        // read_operator), so we recognise the
                        // sequence here.
                        let completion_target_start = question_location;
                        context.next_token();

                        if context.current.token == Lexical.TOKEN.IDENTIFIER then
                            let member = identifier_parser.parse(context)!;

                            previous_left = result;
                            previous_identifier = member;

                            let member_node =
                                Trees.Expressions.MEMBER(
                                    start::member.location,
                                    result,
                                    member,
                                    completion_target_start::member.location
                                );

                            member_node.is_coalesce = true;
                            result = member_node;
                        else
                            // `?.` not followed by a member name: recover
                            // with a poisoned placeholder identifier, not
                            // null, so passes assuming MEMBER.identifier is
                            // non-null don't crash.
                            context.expect_token(Lexical.TOKEN.IDENTIFIER);

                            let member_node =
                                Trees.Expressions.MEMBER(
                                    start..context.location,
                                    result,
                                    Trees.Identifiers.Identifier(completion_target_start, null),
                                    completion_target_start::context.location
                                );

                            member_node.is_coalesce = true;
                            result = member_node;
                        fi
                    else
                        result = Trees.Expressions.HAS_VALUE(start::question_location, result);
                    fi

                when Lexical.TOKEN.REF then
                    result = Trees.Expressions.REFERENCE(start::context.location, result);
                    tokenizer_state.commit_if_speculating();

                    context.next_token();

                when Lexical.TOKEN.OPERATOR then
                    tokenizer_state.commit_if_speculating();

                    if context.current_string =~ "|" then
                        if !next_token_blocks_infix_rhs(context) then
                            return result;
                        fi

                        let location = context.location;

                        let ghul = Trees.Identifiers.Identifier(location, "Ghul");
                        let pipes = Trees.Identifiers.QUALIFIED(location, ghul, "Pipes", location, location);
                        let pipe = Trees.Identifiers.QUALIFIED(location, pipes, "pipe", location, location);

                        let function = Trees.Expressions.IDENTIFIER(location, pipe);

                        let arguments = Trees.Expressions.LIST(
                            result.location,
                            [result]
                        );

                        let pipe_call =
                            Trees.Expressions.CALL(
                                start::location,
                                function,
                                arguments
                            );

                        pipe_call.is_pipe_wrap = true;

                        result = pipe_call;

                        context.next_token();
                    elif context.current_string =~ "!" then
                        result = Trees.Expressions.UNWRAP(start::context.location, result);

                        context.next_token();
                    else
                        return result;
                    fi

                when Lexical.TOKEN.SQUARE_OPEN_TICK then
                    tokenizer_state.commit_if_speculating();
                    
                    context.next_token();
                    
                    let type_arguments = type_list_parser.parse(context)!;

                    let left: Trees.Expressions.Expression? mut = default;
                    let identifier: Trees.Identifiers.Identifier? mut = default;

                    if result.is_member then
                        left = previous_left;
                        identifier = previous_identifier;

                    elif result.is_identifier then
                        left = null;
                        identifier = result.try_copy_as_identifer();
                    fi

                    if identifier? then
                        result = Trees.Expressions.GENERIC_APPLICATION(
                            start::context.location,
                            left,
                            identifier!,
                            type_arguments
                        );
                    else
                        result.poison();
                        context.error(result.location, "cannot apply type arguments to this");
                    fi

                    context.next_token(Lexical.TOKEN.SQUARE_CLOSE);
                else
                    return result;
                esac
            od
        si
    si
si
