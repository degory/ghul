namespace Syntax.Parsers.Definitions is
    use IO.Std;

    use Source;

    class DEFINITION(
        definition_namespace_parser: Parser[Trees.Definitions.NAMESPACE],
        definition_use_parser: Parser[Trees.Definitions.USE],
        definition_class_parser: Parser[Trees.Definitions.CLASS],
        definition_trait_parser: Parser[Trees.Definitions.TRAIT],
        definition_struct_parser: Parser[Trees.Definitions.STRUCT],
        definition_union_parser: Parser[Trees.Definitions.UNION],
        definition_enum_parser: Parser[Trees.Definitions.ENUM],
        definition_member_parser: Parser[Trees.Definitions.Definition],
        definition_pragma_parser: Parser[Trees.Definitions.PRAGMA]
    ): Base[Trees.Definitions.Definition] is
        definition_namespace_parser;
        definition_use_parser;
        definition_class_parser;
        definition_trait_parser;
        definition_struct_parser;
        definition_union_parser;
        definition_enum_parser;
        definition_member_parser;
        definition_pragma_parser;

        description: string => "definition";

        super();

        init(..) is
            add_parsers();
        si

        add_parsers() is
            add_parser(
                context => definition_namespace_parser.parse(context),
                Lexical.TOKEN.NAMESPACE
            );

            add_parser(
                context => definition_use_parser.parse(context),
                Lexical.TOKEN.USE
            );

            add_parser(
                context => definition_class_parser.parse(context),
                Lexical.TOKEN.CLASS
            );

            add_parser(
                context => definition_trait_parser.parse(context),
                Lexical.TOKEN.TRAIT
            );

            add_parser(
                context => definition_struct_parser.parse(context),
                Lexical.TOKEN.STRUCT
            );

            add_parser(
                context => definition_union_parser.parse(context),
                Lexical.TOKEN.UNION
            );

            add_parser(
                context => definition_enum_parser.parse(context),
                Lexical.TOKEN.ENUM
            );

            add_parser(
                context => definition_member_parser.parse(context),
                Collections.LIST[Lexical.TOKEN]([Lexical.TOKEN.IDENTIFIER, Lexical.TOKEN.OPERATOR, Lexical.TOKEN.SQUARE_OPEN])
            );

            add_parser(
                context => definition_pragma_parser.parse(context),
                Lexical.TOKEN.AT
            );
        si
    si
si
