namespace Syntax.Trees.Expressions is

    use Source;

    class UNARY(location: LOCATION, operation: Identifiers.Identifier, right: Expression): Expression is
        operation;
        right;

        super(location);

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                right.walk(visitor);
            fi
            accept(visitor);
        si
    si
si
