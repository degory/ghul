namespace Syntax.Trees.Expressions is

    use Source;
    use Logging;

    class CALL(location: LOCATION, function: Expression, arguments: LIST): Expression is
        right_location: LOCATION => function.right_location;
        could_be_nested_function_definition: bool => function.is_unqualified_identifier;

        // Constraint pushed in by the parent context. For a constructor
        // call (e.g. `Box()` against `let b: Box[int]`) the visitor uses
        // it to bind the owner generic arguments when they can't be
        // inferred from the supplied constructor arguments alone.
        expected_type: Semantic.Types.Type?;
        expected_type_error_message: string?;

        // Parallel to `arguments` when the call uses named-argument
        // syntax (`f(width = 800, height = 600)`); null for a
        // positional call. Set by `rewrite_named_arguments`, which
        // also unwraps each argument to its value expression so the
        // rest of the pipeline sees an ordinary positional list.
        argument_names: Collections.List[Identifiers.Identifier]?;

        // True for the `Ghul.Pipes.pipe(x)` call synthesised by the
        // postfix `|` operator. When the operand is already a Pipe[T],
        // compile-expressions short-circuits the wrap to the operand —
        // `x |` is then a no-op (a compile-time decision on x's type).
        is_pipe_wrap: bool public;

        super(location);

        set_expected_type(expected_type: Semantic.Types.Type, error_message: string) is
            self.expected_type = expected_type;
            self.expected_type_error_message = error_message;
        si

        clear_expected_type() is
            self.expected_type = null;
            self.expected_type_error_message = null;
        si

        // `f(a = 1, b = 2)` parses with each argument as a `VARIABLE`:
        // the shared list parser treats `name = value` like a
        // tuple-element precursor. Detect that shape, record the
        // names, and unwrap each argument to its value expression so
        // every later pass sees an ordinary positional list. A call
        // must be all-named or all-positional.
        rewrite_named_arguments(logger: Logger) is
            let elements = arguments.expressions;

            if elements.count == 0 then
                return;
            fi

            let named_count = elements | .filter(e => _is_named_argument(e)).count();

            if named_count == 0 then
                return;
            fi

            if named_count < elements.count then
                logger.error(location, "cannot mix named and positional arguments");

                for index in 0..elements.count do
                    if _is_named_argument(elements[index]) then
                        elements[index] = (cast VARIABLE(elements[index])).initializer;
                    fi
                od

                return;
            fi

            let names = Collections.LIST[Identifiers.Identifier]();

            for index in 0..elements.count do
                let variable = cast VARIABLE(elements[index]);

                if names | .any(seen => seen.name =~ variable.name.name) then
                    logger.error(variable.name.location, "named argument {variable.name.name} supplied more than once");
                fi

                names.add(variable.name);
                elements[index] = variable.initializer;
            od

            argument_names = names;
        si

        // A named argument is `name = value`: a VARIABLE node carrying
        // an initializer. A bare `name: type` (a VARIABLE with no
        // initializer) is not a named argument - it only arises from
        // parser error recovery, and is left for the normal error
        // paths rather than reported here.
        _is_named_argument(e: Expression) -> bool =>
            isa VARIABLE(e) /\ (cast VARIABLE(e)).initializer?;

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                visitor.enter_node(self);
                try
                    arguments.walk(visitor);
                    function.walk(visitor);
                finally
                    visitor.leave_node(self);
                yrt
            fi

            accept(visitor);
        si

        replace_child(old: Expression, replacement: Expression) is
            if function == old then
                function = replacement;
            fi
            // Argument elements are replaced via arguments.replace_element
            // by callers that have the index — no parent-driven lookup
            // here (it would require a linear scan; the SPILL_AWAITS
            // pass already has the index).
        si
    si
si
