namespace Syntax.Trees.Expressions is

    use Source;

    // Compiler-internal wrapper around a source expression intended
    // as the source of an async for-loop. Emitted by the async-loop
    // desugar (see `docs/claude/async-loops.md`) and lowered during
    // compile-expressions:
    //
    //   - If `source` has type `Collections.Iterator[T]` → unwrap
    //     directly, use `source` itself.
    //   - If `source` has type `Collections.Iterable[T]` → emit
    //     `source.iterator` (calls the `iterator` member to obtain
    //     the iterator).
    //   - Otherwise → compile error "for-loop source must be
    //     Iterable[T] or Iterator[T]".
    //
    // Not parseable from user source. The node exists so the desugar
    // can stay pre-resolution (the source-type decision happens later)
    // and so we keep a single helper signature
    // (`_for_each_async(iter: Iterator[T], ...)`) rather than overloading
    // on Iterable vs Iterator.
    class INTERNAL_ENSURE_ITERATOR: Expression is
        source: Expression;

        init(location: LOCATION, source: Expression) is
            super.init(location);

            assert source? else "source cannot be null";
            self.source = source;
        si

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                source.walk(visitor);
            fi
            accept(visitor);
        si
    si
si
