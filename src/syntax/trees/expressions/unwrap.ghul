namespace Syntax.Trees.Expressions is

    use Source;

    class UNWRAP(location: LOCATION, left: Expression): Expression is
        super(location);

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                left.walk(visitor);
            fi

            accept(visitor);
        si
    si
si
