namespace Syntax.Trees.Expressions is
    
    use Source;

    class NEW: Expression is
        type_expression: TypeExpressions.TypeExpression?;
        arguments: LIST;

        // Constraint pushed in by the parent context. For an explicit
        // `new T(args)` against `let b: T[Concrete]`, the visitor uses
        // the expected_type to bind owner generic arguments when they
        // can't be inferred from the supplied constructor arguments
        // alone.

        init(location: LOCATION, type_expression: TypeExpressions.TypeExpression?, arguments: LIST) is
            super.init(location);

            self.type_expression = type_expression;
            self.arguments = arguments;
        si

        set_expected_type(expected_type: Semantic.Types.Type, error_message: string?) is
            compile_expressions_state.set_expected_type(expected_type, error_message);
        si

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                if type_expression? then
                    type_expression.walk(visitor);
                fi
                arguments.walk(visitor);
            fi

            accept(visitor);
        si
    si
si
