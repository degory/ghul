namespace Syntax.Trees.Expressions is

    use Source;

    class CAST(location: LOCATION, type_expression: TypeExpressions.TypeExpression, right: Expression): Expression is
        super(location);

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                type_expression.walk(visitor);
                right.walk(visitor);
            fi
            accept(visitor);
        si
    si
si
