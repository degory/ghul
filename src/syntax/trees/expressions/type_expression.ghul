namespace Syntax.Trees.Expressions is
    use Source;

    enum AmbiguousExpressionResult is
        UNKNOWN,
        INDEX,
        FUNCTION,
        TYPE
    si

    class AMBIGUOUS_EXPRESSION: Expression is
        result: AmbiguousExpressionResult public;

        index: Expression;
        left: Expression?;
        identifier: Identifiers.Identifier;
        type_arguments: TypeExpressions.LIST;

        // Pushed in by the parent context. Used to lower a bare
        // unit-variant reference like `Option.NONE[int]` to a
        // singleton load, where the explicit type arguments fix
        // every owner-generic slot. Other shapes ignore the field.

        // The identifier token, not the whole `Foo[X]` span. Used as
        // the call-site location when this expression is a constructor
        // callee — keeps the constructor's recorded use narrow so
        // HOVER and SEMANTICTOKENS land on `Foo`, matching bare `Foo(...)`.
        right_location: LOCATION => identifier.right_location;

        init(
            location: LOCATION,
            index: Expression,
            left: Expression?,
            identifier: Identifiers.Identifier,
            type_arguments: TypeExpressions.LIST
        ) is
            super.init(location);

            assert !left? \/ !identifier.is_qualified else "identifier cannot be qualfied if left expression supplied";

            self.index = index;
            self.left = left;
            self.identifier = identifier;
            self.type_arguments = type_arguments;
        si

        set_expected_type(expected_type: Semantic.Types.Type?, error_message: string?) is
            compile_expressions_state.set_expected_type(expected_type, error_message);
        si

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                if result != AmbiguousExpressionResult.UNKNOWN then
                    if result == AmbiguousExpressionResult.INDEX then
                        index.walk(visitor);
                    else
                        if let self.left? then
                            left.walk(visitor);
                        fi

                        type_arguments.walk(visitor);
                    fi
                fi
            fi

            accept(visitor);
        si
    si

    class GENERIC_APPLICATION: Expression is
        result: AmbiguousExpressionResult public;

        left: Expression?;
        identifier: Identifiers.Identifier;

        // actual type arguments to apply to the generic type or function:
        type_arguments: TypeExpressions.LIST;

        // could_be_type_expression: bool => type_expression?;

        // Pushed in by the parent context. Used to lower a bare
        // unit-variant reference like `Option.NONE[int]` to a
        // singleton load. Other shapes ignore the field.

        // The identifier token, not the whole `Foo[T]` span. Used as
        // the call-site location when this expression is a constructor
        // callee — keeps the constructor's recorded use narrow so
        // HOVER and SEMANTICTOKENS land on `Foo`, matching bare `Foo(...)`.
        right_location: LOCATION => identifier.right_location;

        init(
            location: LOCATION,
            left: Expression?,
            identifier: Identifiers.Identifier,
            type_arguments: TypeExpressions.LIST
        ) is
            super.init(location);

            assert !left? \/ !identifier.is_qualified else "identifier cannot be qualfied if left expression supplied";

            self.left = left;
            self.identifier = identifier;
            self.type_arguments = type_arguments;
        si

        set_expected_type(expected_type: Semantic.Types.Type?, error_message: string?) is
            compile_expressions_state.set_expected_type(expected_type, error_message);
        si

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                if result != AmbiguousExpressionResult.UNKNOWN then
                    if let self.left? then
                        left.walk(visitor);
                    fi

                    type_arguments.walk(visitor);
                fi
            fi

            accept(visitor);
        si
    si
si