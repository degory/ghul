namespace Syntax.Trees.Modifiers is
    use System.NotImplementedException;

    use IO.Std;

    use Source;

    class Modifier(location: LOCATION): Trees.Node is
        is_public: bool => false;
        is_protected: bool => false;
        is_private: bool => false;
        is_static: bool => false;
        is_field: bool => false;
        is_init: bool => false;
        is_open: bool => false;
        is_abstract: bool => false;
        is_hide_in_derived: bool => false;
        is_pure: bool => false;
        is_mut: bool => false;
        is_impure: bool => false;

        super(location);

        name: string => throw NotImplementedException("{self} does not implement name");
        accept(visitor: Visitor) is
            visitor.visit(self);
        si
    si

    class AccessModifier(location: LOCATION): Modifier is
        super(location);

        copy() -> AccessModifier =>
            cast AccessModifier(clone());
    si

    class StorageClass(location: LOCATION): Modifier is
        super(location);

        copy() -> StorageClass =>
            cast StorageClass(clone());
    si

    class PUBLIC(location: LOCATION): AccessModifier is
        is_public: bool => true;
        name: string => "public";

        super(location);
    si

    class PROTECTED(location: LOCATION): AccessModifier is
        is_protected: bool => true;
        name: string => "protected";

        super(location);
    si

    class PRIVATE(location: LOCATION): AccessModifier is
        is_private: bool => true;
        name: string => "private";

        super(location);
    si

    class STATIC(location: LOCATION): StorageClass is
        is_static: bool => true;
        name: string => "static";

        super(location);
    si

    class FIELD(location: LOCATION): StorageClass is
        is_field: bool => true;
        name: string => "field";

        super(location);
    si

    class HIDE_IN_DERIVED(location: LOCATION): StorageClass is
        is_hide_in_derived: bool => true;
        name: string => "hide_in_derived";

        super(location);
    si

    // Marks a primary-ctor parameter as init-scoped: no field auto-generates;
    // the param is in scope inside the synthesised primary init only. Rejected
    // anywhere else by `REWRITE_PRIMARY_CONSTRUCTORS`. Not a reserved keyword;
    // recognised contextually by the modifier list parser via name match on
    // the IDENTIFIER token.
    class INIT(location: LOCATION): StorageClass is
        is_init: bool => true;
        name: string => "init";

        super(location);
    si

    // Opts a class out of the default closed-to-assembly hierarchy rule.
    // Without `open`, subclassing from another assembly is rejected and the
    // type system treats the root's subclass set as enumerable for narrowing.
    // Not a reserved keyword; recognised contextually by the modifier list
    // parser via name match on the IDENTIFIER token. Shares the storage-class
    // slot with FIELD/STATIC/INIT — none of those apply to classes anyway.
    class OPEN(location: LOCATION): StorageClass is
        is_open: bool => true;
        name: string => "open";

        super(location);
    si

    // Marks a class as abstract. Calling its constructor directly is
    // rejected at compile time; subclasses can still call `super.init()`
    // to share base initialisation. The closed-narrowing path treats an
    // abstract root as not-itself-a-runtime-type, so the complement
    // universe is just the direct subclasses (no widening to include
    // the root). Independent of `open` — abstract+open is the
    // open-hierarchy abstract base; abstract alone is the closed
    // abstract base. Not a reserved keyword; contextually recognised
    // by the modifier list parser.
    class ABSTRACT(location: LOCATION): Modifier is
        is_abstract: bool => true;
        name: string => "abstract";

        super(location);
    si

    // Declares a function's contract as pure: calling it cannot mutate
    // state observable to the caller. Consumed by flow-sensitive
    // narrowing — a pure call leaves path-presence facts intact.
    // Not a reserved keyword; recognised contextually by the modifier
    // list parser via name match on the IDENTIFIER token in modifier
    // position.
    class PURE(location: LOCATION): Modifier is
        is_pure: bool => true;
        name: string => "pure";

        super(location);
    si

    // Declares a function's contract as receiver-mutating: may
    // mutate the receiver object but no other caller-observable
    // state. At call sites with a known-local receiver this drops
    // path narrowings rooted at that local; narrowings of other
    // paths survive. Mutually exclusive with PURE / IMPURE in the
    // modifier list. Keyword form is `mut`, matching `let mut`.
    class MUT(location: LOCATION): Modifier is
        is_mut: bool => true;
        name: string => "mut";

        super(location);
    si

    // Declares a function's contract as impure: may mutate anything
    // reachable. Suppresses any pure-by-inference treatment. A call
    // clears all path narrowings. Mutually exclusive with PURE /
    // MUTATING in the modifier list.
    class IMPURE(location: LOCATION): Modifier is
        is_impure: bool => true;
        name: string => "impure";

        super(location);
    si
si
