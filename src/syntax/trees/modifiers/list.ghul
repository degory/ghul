namespace Syntax.Trees.Modifiers is
    use Source;

    class LIST(location: LOCATION, access_modifier: AccessModifier, storage_class: StorageClass): Trees.Node is
        access_modifier: AccessModifier?;
        storage_class: StorageClass?;

        // Stand-alone class-level modifiers that don't fit either of
        // the conventional slots. `abstract` lives here so it can
        // coexist with `open` (which currently borrows the storage-
        // class slot, since FIELD/STATIC/INIT don't apply to classes).
        is_abstract: bool public;

        is_empty: bool => !(access_modifier?) /\ !(storage_class?) /\ !is_abstract;

        is_field: bool => storage_class? /\ storage_class.is_field;

        is_init: bool => storage_class? /\ storage_class.is_init;

        is_open: bool => storage_class? /\ storage_class.is_open;

        is_static: bool => storage_class? /\ storage_class.is_static;

        is_public: bool => access_modifier? /\ access_modifier.is_public;

        is_private: bool => access_modifier? /\ access_modifier.is_private;

        is_explicit_access: bool => access_modifier?;

        super(location);

        clear_storage_class() is
            self.storage_class = null;
        si

        copy() -> LIST is
            let nam: AccessModifier mut = default;
            let nsc: StorageClass mut = default;

            if access_modifier? then
                nam = access_modifier.copy();
            fi

            if storage_class? then
                nsc = storage_class.copy();
            fi

            let result = LIST(
                location,
                nam,
                nsc
            );
            result.is_abstract = is_abstract;
            return result;
        si

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                if access_modifier? then
                    access_modifier.walk(visitor);
                fi

                if storage_class? then
                    storage_class.walk(visitor);
                fi
            fi

            accept(visitor);
        si
    si
si
