namespace Syntax.Trees.TypeExpressions is

    use Source;

    class NAMED_TUPLE_ELEMENT(location: LOCATION, name: Identifiers.Identifier, type_expression: TypeExpression): TypeExpression is
        // Declared variance, when this element is a generic type
        // parameter declared `[T: ... out]` / `[T: ... in]`. INVARIANT
        // for every other use of NAMED_TUPLE_ELEMENT (tuple elements,
        // function parameters) and for an unannotated type parameter.
        variance: Semantic.Types.TYPE_VARIANCE public;

        // True when this generic type parameter carries a `new`
        // constraint — `[T: new]` standalone or compound with a kind /
        // type bound (`[T: class new]`, `[T: A new]`, `[T: A class new]`).
        has_constructor: bool public;

        // A trailing kind constraint after a type bound — `[T: A class]`.
        // NONE when no trailing kind keyword is present. When the
        // NAMED_TUPLE_ELEMENT *is* a pure kind constraint (`[T: class]`),
        // the kind is carried inside the `type_expression` slot as a
        // TYPE_PARAMETER_CONSTRAINT, and `combined_kind` stays NONE.
        combined_kind: Semantic.Symbols.TYPE_PARAMETER_CONSTRAINT_KIND public;

        is_named: bool => true;
        is_reference: bool => type_expression.is_reference;
        is_void: bool => type_expression? /\ type_expression.is_void;

        super(location);

        copy() -> TypeExpression is
            let result =
                NAMED_TUPLE_ELEMENT(
                    location,
                    name.copy(),
                    type_expression.copy()
                );

            result.variance = variance;
            result.has_constructor = has_constructor;
            result.combined_kind = combined_kind;

            return result;
        si

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                name.walk(visitor);
                type_expression.walk(visitor);
            fi

            accept(visitor);
        si
    si
si
