namespace Syntax.Trees.TypeExpressions is

    use Source;

    class Structured(location: LOCATION, element: TypeExpression): TypeExpression abstract is
        is_void: bool => element? /\ element.is_void;

        super(location);

        copy() -> TypeExpression is
            let result = cast Structured?(clone())!;

            result.element = element.copy();

            return result;
        si

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                element.walk(visitor);
            fi
            accept(visitor);
        si
    si
si
