namespace Syntax.Trees.TypeExpressions is
    use Source;

    use Semantic.Symbols.TYPE_PARAMETER_CONSTRAINT_KIND;

    // The constraint of a kind-constrained type parameter — the `class`,
    // `struct` or `optional` in `[T: class]`. Carried as the
    // `type_expression` of the enclosing NAMED_TUPLE_ELEMENT; a leaf, it
    // resolves to no type.
    class TYPE_PARAMETER_CONSTRAINT: TypeExpression is
        kind: TYPE_PARAMETER_CONSTRAINT_KIND;

        keyword: string =>
            if kind == TYPE_PARAMETER_CONSTRAINT_KIND.REFERENCE then
                "class";
            elif kind == TYPE_PARAMETER_CONSTRAINT_KIND.VALUE then
                "struct";
            elif kind == TYPE_PARAMETER_CONSTRAINT_KIND.OPTIONAL then
                "optional";
            else
                "?";
            fi;

        init(location: LOCATION, kind: TYPE_PARAMETER_CONSTRAINT_KIND) is
            super.init(location);

            self.kind = kind;
        si

        copy() -> TypeExpression => cast TYPE_PARAMETER_CONSTRAINT(clone());

        accept(visitor: Visitor) is
            visitor.visit(self);
        si
    si
si
