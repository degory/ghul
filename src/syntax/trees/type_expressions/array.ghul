namespace Syntax.Trees.TypeExpressions is
    use Source;

    class ARRAY_(location: LOCATION, element: TypeExpression): Structured is
        super(location, element);

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                element.walk(visitor);
            fi

            accept(visitor);
        si
    si
si
