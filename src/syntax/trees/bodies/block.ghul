namespace Syntax.Trees.Bodies is
    use Source;

    class BLOCK(location: LOCATION, statements: Statements.LIST): Body is
        is_block: bool => true;

        super(location);

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                statements.walk(visitor);
            fi

            accept(visitor);
        si
    si
si
