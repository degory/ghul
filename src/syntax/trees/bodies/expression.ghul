namespace Syntax.Trees.Bodies is
    use Source;

    class EXPRESSION(location: LOCATION, expression: Expressions.Expression): Body is
        expression: Expressions.Expression public;

        super(location);

        init(..) is
            assert expression?;
        si

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                expression.walk(visitor);
            fi

            accept(visitor);
        si
    si
si
