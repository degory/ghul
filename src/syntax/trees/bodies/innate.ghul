namespace Syntax.Trees.Bodies is
    use Source;

    class INNATE(location: LOCATION, name: Identifiers.Identifier): Body is
        super(location);

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if visitor.pre(self) then
                name.walk(visitor);
            fi

            accept(visitor);
        si
    si
si
