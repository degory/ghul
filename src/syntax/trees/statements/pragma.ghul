namespace Syntax.Trees.Statements is

    use Source;

    class PRAGMA(location: LOCATION, pragma: Pragmas.PRAGMA, statement: Statement): Statement is
        pragma;
        statement: Statement? public;

        super(location);

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                if pragma? then
                    pragma.walk(visitor);
                fi

                if statement? then
                    statement.walk(visitor);
                fi
            fi

            accept(visitor);
        si
    si
si
