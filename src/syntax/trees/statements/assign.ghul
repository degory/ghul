namespace Syntax.Trees.Statements is
    use Source;

    class ASSIGNMENT(location: LOCATION, left: Expressions.AssignmentLeftExpression, right: Expressions.Expression): Statement is
        expects_semicolon: bool => true;

        super(location);

        accept(visitor: Visitor) is
            visitor.visit(self);
        si

        walk(visitor: Visitor) is
            if !visitor.pre(self) then
                left.walk(visitor);
                right.walk(visitor);
            fi

            accept(visitor);
        si
    si
si
