namespace Syntax is
    use System.Text.StringBuilder;

    use Trees;

    // Walks a parsed file's AST and accumulates a digest string of its
    // declaration layer — every node except the contents of method /
    // function / accessor bodies. Two parses of a file with the same digest
    // have the same interface: anything another file could resolve against
    // (a name, a type, a modifier, the declaration structure) is folded in,
    // while statement bodies are skipped. The analyser compares digests
    // across an EDIT to decide whether the edit can affect other files —
    // see docs/claude/edit-interface-classification.md.
    class INTERFACE_DIGEST: StrictVisitor is
        _builder: StringBuilder;

        init() is
            super.init();

            _builder = StringBuilder();
        si

        digest: string => _builder.to_string();

        // StrictVisitor routes every node it has no specific handler for to
        // throwNotImplemented; nothing here overrides a visit, so every node
        // arrives here. Fold the node kind, plus the salient text of the
        // content-bearing leaves (identifiers, modifiers, literals) — node
        // kind alone would miss a rename or a changed literal.
        throwNotImplemented(name: string, node: Node) is
            _builder.append(name);

            let identifier = cast Identifiers.Identifier(node);
            let modifier = cast Modifiers.Modifier(node);
            let literal = cast Expressions.Literals.Literal(node);

            if identifier? then
                for part in identifier.names do
                    _builder.append(':').append(part);
                od
            elif modifier? then
                _builder.append(':').append(modifier.name);
            elif literal? then
                _builder.append(':').append(literal.value_string);
            fi

            _builder.append(';');
        si

        // Reached only by a node type with no visit handler at all — fold its
        // kind so structure is still captured rather than throwing.
        visit(node: Node) is
            _builder.append("node;");
        si

        // Skip the contents of statement bodies: a body-only edit must not
        // change the digest. The pre/accept split means the body node itself
        // is still visited (its kind folded), so making a method abstract
        // vs concrete is still caught — only the body interior is excluded.
        pre(block: Bodies.BLOCK) -> bool => true;
        pre(expression: Bodies.EXPRESSION) -> bool => true;
        pre(innate_body: Bodies.INNATE) -> bool => true;
        pre(null_body: Bodies.NULL) -> bool => true;
    si
si
