namespace Syntax.Process is
    use Logging;
    use Source;

    use Semantic.Types.Type;

    use IR.Values;

    // Compiles the member-access family of expressions: member access,
    // identifier resolution, `?` (has-value), `!` (unwrap) and `ref`.
    // Split out of COMPILE_EXPRESSIONS, which delegates the matching
    // visit methods here. The exception-handling wrapper of
    // visit(identifier) stays on the visitor; visit_identifier is the
    // enclosed logic.
    class COMPILE_ACCESS is
        _logger: Logger;
        _symbol_table: Semantic.SYMBOL_TABLE;
        _symbol_loader: Semantic.SYMBOL_LOADER;
        _symbol_use_locations: Semantic.SYMBOL_USE_LOCATIONS;
        _innate_symbol_lookup: Semantic.Lookups.InnateSymbolLookup;
        _overload_resolver: Semantic.OVERLOAD_RESOLVER;
        _function_caller: Semantic.FUNCTION_CALLER;
        _unit_variant_constructor: Semantic.UNIT_VARIANT_CONSTRUCTOR;
        _flow: NARROWING_FLOW;
        _condition_analyzer: CONDITION_ANALYZER;
        _build_flags: Compiler.GLOBAL_BUILD_FLAGS;
        _visitor: COMPILE_EXPRESSIONS;

        init(
            logger: Logger,
            symbol_table: Semantic.SYMBOL_TABLE,
            symbol_loader: Semantic.SYMBOL_LOADER,
            symbol_use_locations: Semantic.SYMBOL_USE_LOCATIONS,
            innate_symbol_lookup: Semantic.Lookups.InnateSymbolLookup,
            overload_resolver: Semantic.OVERLOAD_RESOLVER,
            function_caller: Semantic.FUNCTION_CALLER,
            unit_variant_constructor: Semantic.UNIT_VARIANT_CONSTRUCTOR,
            flow: NARROWING_FLOW,
            condition_analyzer: CONDITION_ANALYZER,
            build_flags: Compiler.GLOBAL_BUILD_FLAGS,
            visitor: COMPILE_EXPRESSIONS
        ) is
            super.init();

            _logger = logger;
            _symbol_table = symbol_table;
            _symbol_loader = symbol_loader;
            _symbol_use_locations = symbol_use_locations;
            _innate_symbol_lookup = innate_symbol_lookup;
            _overload_resolver = overload_resolver;
            _function_caller = function_caller;
            _unit_variant_constructor = unit_variant_constructor;
            _flow = flow;
            _condition_analyzer = condition_analyzer;
            _build_flags = build_flags;
            _visitor = visitor;
        si

        visit_member(member: Trees.Expressions.MEMBER) is
            let need_store = member.value? /\ isa Need.STORE(member.value);
            let need_deref mut = false;

            if member.identifier == null \/ member.identifier.is_poisoned then
                member.value = DUMMY(Semantic.Types.ERROR(), member.location);
                return;
            fi

            if member.left? /\ member.left.value? then
                let left_value mut = member.left.value;
                let type mut = left_value.type;

                if type == null then
                    _logger.poison(member.left.location, "member left has no type");

                    member.value = DUMMY(Semantic.Types.ERROR(), member.location);
                    return;
                fi

                // `x?.y` never dereferences a null receiver, and
                // `x.has_value` is the optional protocol's presence
                // query — asking is not dereferencing.
                if !member.is_coalesce /\ !(member.identifier.name =~ "has_value") then
                    _check_possible_null_dereference(member.left);
                fi

                // TODO we could loop here to handle multiple levels of dereferencing
                if type.is_ref then
                    need_deref = true;
                    // is_ref implies an element type; the runtime
                    // invariant guarantees get_element_type() non-null.
                    type = type.get_element_type()!;

                    left_value = DEREF(left_value, type);
                    member.left.value = left_value;
                fi

                // Operation-constraint inference: when the receiver
                // is an INFERRED_VARIABLE_TYPE placeholder, record a
                // MEMBER_CONSTRAINT on the placeholder's origin so
                // the constraint-aware LUB can later filter candidate
                // types to those that actually expose this member.
                // mark_consumed_any drives the retry loop to re-walk
                // the body with the resolved type (if any).
                if isa Semantic.Types.INFERRED_VARIABLE_TYPE(type) then
                    let placeholder = type;

                    _logger.mark_consumed_any_if(placeholder.origin.add_constraint(Semantic.MEMBER_CONSTRAINT(member.identifier.name)));

                    member.value = DUMMY(Semantic.Types.ERROR(), member.location);
                    return;
                fi

                if !isa Semantic.Types.NAMED(type) then
                    if !isa Semantic.Types.ERROR(type) /\ !type.is_inferred then
                        // Suppress for ERROR (existing — error already
                        // reported, the contract says don't pile on)
                        // and for is_inferred placeholders (deferred-
                        // inference: the lambda's arg type is awaiting
                        // the call-site second-pass to fill it in,
                        // and emitting a fatal "type has no members"
                        // here breaks that flow). Both share the
                        // intent of "don't surface a member-resolution
                        // failure on a stand-in type".
                        _logger.poison(member.left.location, "type has no members: {type}");
                    fi

                    member.value = DUMMY(Semantic.Types.ERROR(), member.location);
                    return;
                fi

                let named_type mut = type;

                // For coalescing access against any optional, look
                // up the member on the unwrapped (inner) type so
                // `a?.b` consistently means "if a is present, access
                // b on the unwrapped a". A value-type optional like
                // NULLABLE[T] / MAYBE[T] otherwise resolves `value`
                // / `has_value` against the wrapper rather than the
                // payload, surprising the user and producing IL that
                // mixes wrapper-thissed calls with payload-typed
                // stack values.
                if member.is_coalesce /\ named_type.is_optional then
                    let inner = named_type.optional_inner_type;

                    if inner? /\ isa Semantic.Types.NAMED(inner) then
                        named_type = inner;
                    fi
                fi

                if named_type.scope == null then
                    _logger.poison(member.left.location, "member left type has no type: {type}");

                    member.value = DUMMY(Semantic.Types.ERROR(), member.location);
                    return;
                fi

                let symbol mut = named_type.find_member(member.identifier.name);

                // A member that resolves to same-name types at several
                // generic arities comes back as a TYPE_GROUP. In value
                // position (`Foo.bar` with no `[...]`) collapse to the
                // arity-0 member; `Foo[T].bar` is handled earlier by
                // GENERIC_APPLICATION before reaching here.
                let member_group = cast Semantic.Symbols.TYPE_GROUP?(symbol);

                if member_group? then
                    let arity_zero = member_group.find_by_generic_arguments_count(0);

                    // A constructor call on the qualified name resolves to the
                    // group's generic member when there is no constructible
                    // arity-0 member (a static factory class shares the name
                    // with a generic type, `Collections.KeyValuePair`); when
                    // the arity-0 member is itself constructible, or this is a
                    // plain value-position access, collapse to it.
                    let for_call =
                        if member.is_call_target /\ (!arity_zero? \/ arity_zero.is_abstract) then
                            member_group.sole_generic_member()
                        else
                            null
                        fi;

                    if for_call? then
                        symbol = for_call;
                    elif arity_zero? then
                        symbol = arity_zero;
                    else
                        let counts = member_group.generic_arguments_counts | .map(a -> string => "{a}").join(" or ");
                        _logger.error(member.identifier.location, "type {member.identifier.name} requires {counts} type arguments");
                        member.value = DUMMY(Semantic.Types.ERROR(), member.location);
                        return;
                    fi
                fi

                if !symbol? then
                    let hint = try_describe_intersection_miss(named_type, member.identifier.name);

                    if hint? then
                        _logger.error(member.identifier.location, hint);
                    else
                        _logger.error(member.identifier.location, "member {member.identifier.name} not found in {named_type}");
                    fi

                    member.value = DUMMY(Semantic.Types.ERROR(), member.location);
                    return;
                fi

                _symbol_use_locations.add_symbol_use(member.identifier.right_location, symbol);

                if symbol.is_instance /\ !left_value.is_consumable then
                    _logger.error(member.identifier.location, "cannot access instance member {member.identifier.name} in {named_type}");
                fi

                _symbol_loader.find_symbol =
                    (name: string) is
                        let result = named_type.find_member(name);

                        return result;
                    si;

                let value: Value? mut = default;

                if need_store then
                    if member.is_coalesce then
                        _logger.error(member.location, "cannot assign through coalescing member access");
                    fi

                    let store_value = cast Need.STORE?(member.value)!.value;

                    if check_store_access(member.location, left_value, symbol, named_type) then
                        value = symbol.store(member.location, left_value, store_value, _symbol_loader, false);
                    fi

                    // The written receiver may alias any receiver a
                    // fact was proven on, so the stored member's own
                    // facts and every path reading through it die —
                    // keyed on the member symbol, not the receiver.
                    _flow.on_member_store(symbol);
                else
                    let variant = cast Semantic.Symbols.VARIANT?(symbol);

                    if variant? /\ variant.is_unit_variant then
                        if member.is_coalesce then
                            _logger.error(member.location, "coalescing member access does not apply to a unit-variant constructor");
                        fi

                        let lowered = _unit_variant_constructor.try_load(member.location, variant, member.expected_type, member);

                        if lowered? then
                            _symbol_use_locations.add_symbol_use(member.identifier.right_location, lowered.constructor);
                            member.value = lowered.value;
                            return;
                        fi
                    fi

                    if check_load_access(member.location, left_value, symbol, named_type) then
                        if member.is_coalesce then
                            value = _build_coalesce_load(member, symbol);

                            if value? then
                                member.value = value;
                                return;
                            fi

                            // Fallthrough on a build failure (e.g.
                            // unsupported receiver shape): proceed with
                            // a plain access so the user gets at most
                            // one diagnostic instead of a cascade.
                            value = symbol.load(member.location, left_value, _symbol_loader);
                        else
                            value = symbol.load(member.location, left_value, _symbol_loader);
                        fi
                    fi
                fi

                member.value = value;

                // Path narrowing: when the flow analysis has recorded
                // facts for this member-access path, surface the
                // access at the narrower view type so
                // `if isa Cat(x.y) then x.y.meow() fi` and
                // `if x.y? then x.y.z fi` both type-check. Mirrors the
                // local-variable path in visit_identifier. A reference
                // optional shares IL with its non-optional form (a type
                // view); NULLABLE[T] / MAYBE[T] get a `.value`
                // projection.
                if !need_store /\ member.value? then
                    let path = _visitor.try_build_access_path(member);

                    if path? then
                        // Step 1: type narrow (isa T on x.y). Wraps the
                        // loaded value at the recorded static subtype
                        // when the composition is sound.
                        if let recorded = _flow.narrowed_type_of_path(path) then
                            let loaded = member.value!;

                            if loaded.type? then
                                if let composed = _flow.compose_path_narrow(loaded.type, recorded) then
                                    member.value = IR.Values.NARROW_VIEW(loaded, composed);
                                fi
                            fi
                        fi

                        // Step 2: presence narrow (if x.y? then x.y).
                        // Reads member.value again in case step 1
                        // already wrapped it.
                        let loaded = member.value!;

                          if loaded.type? /\ loaded.type!.is_optional /\ _flow.is_non_null_path(path) then
                              let loaded_type = loaded.type!;
                            let narrowed = loaded_type.as_non_optional();

                            if narrowed? /\ !narrowed.is_optional then
                                member.value = IR.Values.NARROW_VIEW(loaded, narrowed);
                                // Overwrite the earlier symbol-use entry so
                                // HOVER on the member surfaces the narrowed
                                // type — mirroring what visit_identifier does
                                // for a narrowed local. Same location; put
                                // wins for the last write.
                                _symbol_use_locations.replace_with_variable_use(member.identifier.right_location, symbol, member.value!);
                            elif loaded_type.is_value_type then
                                let value_member = loaded_type.find_member("value");

                                if value_member? then
                                    let projected = value_member.load(member.location, loaded, _symbol_loader);

                                    if projected? then
                                        member.value = IR.Values.NARROW_PROJECT(loaded, projected);
                                        _symbol_use_locations.replace_with_variable_use(member.identifier.right_location, symbol, member.value!);
                                    fi
                                fi
                            fi
                        fi
                    fi
                fi
            fi
        si

        // True iff any receiver in `expr`'s member-access chain has
        // been wrapped in a NARROW_VIEW by path narrowing. Used to
        // recognise loads whose result type reflects a narrowed
        // receiver — the declared receiver type is still optional at
        // this position, so an `!` against the narrowed type is
        // redundant rather than an error.
        _has_narrowed_receiver(expr: Trees.Expressions.Expression) -> bool is
            let cursor mut = expr;

            while isa Trees.Expressions.MEMBER(cursor) do
                let member = cast Trees.Expressions.MEMBER(cursor);

                if !member.left? then
                    return false;
                fi

                if member.left.value? /\ isa IR.Values.NARROW_VIEW(member.left.value) then
                    return true;
                fi

                cursor = member.left;
            od

            return false;
        si

        check_load_access(location: LOCATION, from: Value?, symbol: Semantic.Symbols.Symbol, type: Type) -> bool is
            if symbol.is_public_readable then
                return true;
            fi

            if from? /\ from.is_self then
                return true;
            fi

            let instance_context = _symbol_table.current_instance_context;
            let instance_context_type = if instance_context? then instance_context.type else null fi;

            if instance_context_type? /\ instance_context_type.is_assignable_from(type) then
                return true;
            fi

            _logger.error(location, "{symbol} is not publicly readable");

            return false;
        si

        check_store_access(location: LOCATION, from: Value?, symbol: Semantic.Symbols.Symbol, type: Type) -> bool is
            if !symbol.is_private /\ !symbol.is_field then
                return true;
            fi

            if from? /\ from.is_self then
                return true;
            fi

            let instance_context = _symbol_table.current_instance_context;
            let instance_context_type = if instance_context? then instance_context.type else null fi;

            if instance_context_type? /\ instance_context_type.is_assignable_from(type) then
                return true;
            fi

            _logger.error(location, "{symbol} is not publicly assignable");

            return false;
        si

        visit_identifier(identifier: Trees.Expressions.IDENTIFIER) is
            let need_store = identifier.value? /\ isa Need.STORE(identifier.value);

            let symbol mut = _visitor.find(identifier.identifier);

            let group = cast Semantic.Symbols.TYPE_GROUP?(symbol);

            if group? then
                let bare = group.find_by_generic_arguments_count(0);

                // A constructor call on the bare name resolves to the group's
                // generic member when there is no constructible arity-0
                // member — the reflected shape where a static factory class
                // (abstract, so not constructible) shares a name with a
                // generic type (`KeyValuePair` + `KeyValuePair[K,V]`). When
                // the arity-0 member *is* constructible (a plain non-generic
                // class overloaded with a generic one, `FOO` + `FOO[T]`), or
                // this is a plain value-position reference, collapse to it.
                let for_call =
                    if identifier.is_call_target /\ (!bare? \/ bare.is_abstract) then
                        group.sole_generic_member()
                    else
                        null
                    fi;

                if for_call? then
                    symbol = for_call;
                elif bare? then
                    symbol = bare;
                else
                    let counts = group.generic_arguments_counts | .map(a -> string => "{a}").join(" or ");
                    _logger.error(identifier.location, "type {identifier.identifier} requires {counts} type arguments");
                    identifier.value = DUMMY(Semantic.Types.ERROR(), identifier.location);
                    return;
                fi
            fi

            if symbol? then
                if symbol.is_type then
                    _symbol_use_locations.add_symbol_use(identifier.right_location, symbol);

                    let variant = cast Semantic.Symbols.VARIANT?(symbol);

                    if variant? /\ variant.is_unit_variant then
                        let lowered = _unit_variant_constructor.try_load(identifier.location, variant, identifier.expected_type, identifier);

                        if lowered? then
                            // Anchor HOVER and find-references to the
                            // specialised init so the rendered owner
                            // carries the resolved type arguments —
                            // matching the parenthesised path's
                            // bookkeeping in resolve_constructor.
                            _symbol_use_locations.add_symbol_use(identifier.right_location, lowered.constructor);
                            identifier.value = lowered.value;
                            return;
                        fi
                    fi

                    let symbol_type = symbol.type;

                    if symbol_type? then
                        identifier.value = TYPE_EXPRESSION(symbol_type, identifier.location);
                    else
                        identifier.value = DUMMY(Semantic.Types.ERROR(), identifier.location);
                    fi
                else
                    _symbol_loader.find_symbol = (name: string) => _visitor.find(name);

                    if need_store then
                        let store_value = cast Need.STORE?(identifier.value)!.value;
                        identifier.value = symbol.store(identifier.location, null, store_value, _symbol_loader, false);

                        // Optional-narrowing, write side: a
                        // non-optional right-hand side leaves a
                        // declared-optional target known to hold a
                        // value, so HOVER on the target describes
                        // the state the assignment leaves behind —
                        // agreeing with what a subsequent read
                        // reports rather than with the declared
                        // type. Gated on the same target shape the
                        // flow analysis narrows, so hover never
                        // claims a narrow that isn't applied.
                        let narrowed: Semantic.Types.Type? mut = null;

                        let target = _visitor.try_get_narrowing_target(identifier);

                        if target? /\ _visitor.is_non_optional_value(store_value) then
                            let declared = _flow.declared_type_of(target);

                            if declared? /\ declared.is_optional then
                                let inner = declared.optional_inner_type;

                                if inner? /\ !inner.is_optional then
                                    narrowed = inner;
                                fi
                            fi
                        fi

                        if narrowed? then
                            _symbol_use_locations.add_variable_use(identifier.right_location, symbol, narrowed);
                        else
                            _symbol_use_locations.add_symbol_use(identifier.right_location, symbol);
                        fi
                    else
                        identifier.value = symbol.load(identifier.location, null, _symbol_loader);

                        // Optional-narrowing: when flow analysis has
                        // established this variable is non-null here,
                        // surface the use as the non-optional type.
                        // Reference `T?` is a NAMED-with-flag — IL
                        // representation matches `T`, so the load gets
                        // a type-view snapshot (mirrors how `isa`-
                        // narrowing reaches the load via a mutated
                        // `symbol.type`). The value-type lowerings
                        // (`NULLABLE[T]` / `MAYBE[T]`) are wrapper
                        // structs, so the load gets wrapped in
                        // `NARROW_PROJECT` — emits `.value` at gen
                        // time, but `visit_has_value` and
                        // `visit_unwrap` can peel back to the
                        // underlying wrapper for their own IR.
                        let loaded = identifier.value;

                        if
                            isa Semantic.Symbols.Variable(symbol) /\
                            isa IR.Values.Load.SYMBOL(loaded) /\
                            loaded.type? /\
                            loaded.type.is_optional
                        then
                            let variable = symbol;

                            if _flow.is_non_null(variable) then
                                let loaded_type = loaded.type;
                                let narrowed = loaded_type.as_non_optional();

                                if narrowed? /\ !narrowed.is_optional then
                                    (cast IR.Values.Load.SYMBOL(loaded)).narrow_snapshot_type(narrowed);
                                elif loaded_type.is_value_type then
                                    let value_member = loaded_type.find_member("value");

                                    if value_member? then
                                        let projected = value_member.load(identifier.location, loaded, _symbol_loader);

                                        if projected? then
                                            identifier.value = IR.Values.NARROW_PROJECT(loaded, projected);
                                        fi
                                    fi
                                fi
                            fi
                        fi

                        // HOVER reads a narrowed local's type off
                        // this use-site node, not the symbol — the
                        // symbol's `type` is restored after the walk.
                        _symbol_use_locations.add_variable_use(identifier.right_location, symbol, identifier.value!);

                        // Definite assignment: reading a tracked
                        // deferred-init local before it is assigned
                        // on every path reaching here. An address-of
                        // operand of `ref` is not a value read — its
                        // read-or-write is decided by the resolved call.
                        if
                            !_build_flags.no_warn_definite_assignment /\
                            isa Semantic.Symbols.Variable(symbol) /\
                            !_visitor.is_reference_operand_target(symbol)
                        then
                            let variable = symbol;

                            if _flow.is_tracked(variable) /\ !_flow.is_assigned(variable) then
                                _logger.warn(identifier.location, "definite-assignment", "{variable.name} may be used before it is assigned");
                            fi
                        fi
                    fi
                fi

            else
                identifier.value = DUMMY(Semantic.Types.ERROR(), identifier.location);
            fi
        si

        visit_has_value(has_value: Trees.Expressions.HAS_VALUE) is

            if !has_value.left? then
                _logger.poison(has_value.location, "has value expression has no left expression");
                has_value.value = DUMMY(_innate_symbol_lookup.get_bool_type(), has_value.location);
                return;
            elif !has_value.left.value? then
                _logger.poison(has_value.left.location, "has value expression has no value");
                has_value.value = DUMMY(_innate_symbol_lookup.get_bool_type(), has_value.location);
                return;
            fi

            if
                !has_value.left.value.check_is_consumable(_logger, has_value.left.location)
            then
                _logger.error(has_value.left.location, "cannot use this here");
                has_value.value = DUMMY(_innate_symbol_lookup.get_bool_type(), has_value.location);
                return;
            fi

            // Peel a flow-narrowing projection back to its wrapper so
            // `has_value` lookup hits the wrapper's bool field.
            has_value.left.value = IR.Values.NARROW_PROJECT.peel(has_value.left.value!);

            let left_value = has_value.left.value!;
            let bool_type = _innate_symbol_lookup.get_bool_type();

            // Union `u?` → `isa Default(u)`. Both source-defined
            // and cross-asm unions carry the default variant on the
            // symbol; cross-asm unions get it via the
            // `DEFAULT_VARIANT_ATTRIBUTE` marker read in
            // `SYMBOL_FACTORY.materialize_variant`. A union without
            // a default variant short-circuits to a bare null check
            // — `value`/`has_value` are no longer the convention
            // for unions.
            if !left_value.type!.is_value_type then
                let classy = _condition_analyzer.get_classy_for_narrowing(left_value.type);

                if classy? /\ (classy.is_union \/ classy.is_variant) then
                    let default_variant = _get_default_variant_for_operand(classy);

                    if default_variant? then
                        has_value.value =
                            _build_default_variant_isa(
                                has_value.location,
                                left_value,
                                default_variant,
                                bool_type
                            );
                    else
                        has_value.value = HAS_VALUE(left_value, bool_type);
                    fi

                    return;
                fi
            fi

            let has_value_member =
                left_value.type!.find_member("has_value");
            let has_value_valid mut = false;

            if has_value_member? then
                if !isa Semantic.Symbols.Property(has_value_member) then
                    _logger.error(
                        has_value.left.location,
                        "has_value member must be a bool property"
                    );
                elif has_value_member.type !~ bool_type then
                    _logger.error(
                        has_value.left.location,
                        "has_value property must be bool"
                    );
                else
                    has_value_valid = true;
                fi
            fi

            let target = _visitor.try_get_narrowing_target(has_value.left);

            if left_value.type!.is_optional then
                // the test that itself proves presence is not
                // redundant; one on an operand already proven to
                // hold a value is
                if target? /\ _flow.is_non_null(target) then
                    _logger.warn(
                        has_value.location,
                        "redundant-presence-test",
                        "'?' is redundant here"
                    );
                fi
            elif !has_value_member? then
                // no live has_value layer to consult: a non-optional
                // operand narrowed from optional gets the flow-specific
                // "redundant here"; a never-optional value type is an
                // error; a never-optional reference is redundant by its
                // static type and gets the plain "redundant" - the type
                // guarantees presence everywhere, not just here.
                let declared = if target? then _flow.declared_type_of(target) else null fi;

                if declared? /\ declared.is_optional then
                    _logger.warn(
                        has_value.location,
                        "redundant-presence-test",
                        "'?' is redundant here"
                    );
                elif left_value.type!.is_value_type then
                    _logger.error(has_value.left.location, "not optional");
                    has_value.value = DUMMY(bool_type, has_value.location);
                    return;
                else
                    _logger.warn(
                        has_value.location,
                        "presence-test-non-optional",
                        "'?' is redundant"
                    );
                fi
            fi

            if !left_value.type!.is_value_type then
                has_value.value =
                    get_reference_has_value(
                        has_value.location,
                        left_value,
                        if has_value_valid then has_value_member else null fi,
                        bool_type
                    );
            elif has_value_member? then
                if has_value_valid then
                    has_value.value =
                        has_value_member.load(
                            has_value.location,
                            left_value,
                            _symbol_loader
                        );
                else
                    has_value.value = DUMMY(bool_type, has_value.location);
                fi
            fi
        si

        visit_unwrap(unwrap: Trees.Expressions.UNWRAP) is
            let need_store = unwrap.value? /\ isa Need.STORE(unwrap.value);

            if !unwrap.left? then
                _logger.poison(unwrap.location, "unwrap expression has no left expression");
                unwrap.value = DUMMY(Semantic.Types.ERROR(), unwrap.location);
                return;
            fi

            // Peel a flow-narrowing projection back to its wrapper so
            // `!` runs against the optional shape it was designed for
            // (avoids "no value member" on the already-projected `T`).
            unwrap.left.value = IR.Values.NARROW_PROJECT.peel(unwrap.left.value);

            let unwrap_left_value = unwrap.left.value;

            if !unwrap_left_value? \/ !unwrap_left_value.type? then
                _logger.poison(unwrap.left.location, "unwrap expression has no value");
                unwrap.value = DUMMY(Semantic.Types.ERROR(), unwrap.location);
                return;
            fi

            if
                !unwrap_left_value.check_is_consumable(_logger, unwrap.left.location)
            then
                _logger.error(unwrap.left.location, "cannot use this here");
                unwrap.value = DUMMY(Semantic.Types.ERROR(), unwrap.location);
                return;
            fi

            if unwrap_left_value.type!.is_ref then
                // is_ref implies element type per the runtime invariant
                let element_type = unwrap_left_value.type!.get_element_type()!;

                if need_store then
                    let store_value = cast Need.STORE?(unwrap.value)!.value;
                    unwrap.value = IR.Values.Store.INDIRECT(unwrap_left_value, store_value, element_type);
                else
                    unwrap.value = DEREF(unwrap_left_value, element_type);
                fi

                return;
            fi

            let value_member = unwrap_left_value.type!.find_member("value");

            if !unwrap_left_value.type!.is_value_type then
                let classy = _condition_analyzer.get_classy_for_narrowing(unwrap_left_value.type);
                let default_variant = _get_default_variant_for_operand(classy);

                if classy? /\ default_variant? then
                    // Union `u!` → cast to the default variant (no
                    // IL cast when the operand is already narrowed
                    // to that variant), with single-field projection
                    // so the canonical "unwrap to the sole field"
                    // rule is preserved.
                    unwrap.value =
                        _build_default_variant_unwrap(
                            unwrap.location,
                            unwrap_left_value,
                            classy,
                            default_variant
                        );
                else
                    // a plain reference type: `!` only asserts non-null.
                    // The result type drops the `?` so an inferred `let`
                    // binding or a non-optional slot downstream sees a
                    // present value rather than a may-be-null one.
                    // TODO we could do an explicit null check here:
                    let left_value = unwrap_left_value;

                    if left_value.type!.is_optional then
                        unwrap.value = TYPE_WRAPPER(left_value.type!.as_non_optional(), left_value);
                    elif value_member? /\ left_value.type!.find_member("has_value")? then
                        // an option-shaped reference type: flow
                        // analysis does not track its has_value
                        // layer, so `!` re-asserts it and is never
                        // redundant.
                        unwrap.value = left_value;
                    else
                        let target = _visitor.try_get_narrowing_target(unwrap.left);
                        let declared = if target? then _flow.declared_type_of(target) else null fi;

                        // A NARROW_VIEW is a member-access path read
                        // at its non-optional type because a path
                        // fact holds here — the declared member is
                        // optional, so the unwrap is redundant, not
                        // an error. A load whose receiver chain
                        // contains a NARROW_VIEW is the same case one
                        // hop deeper: the load resolved a member on a
                        // narrowed receiver, so its result type
                        // reflects the narrow rather than the
                        // declared receiver type.
                        if declared? /\ declared.is_optional \/ isa IR.Values.NARROW_VIEW(left_value) \/ _has_narrowed_receiver(unwrap.left) then
                            // non-optional only because flow analysis
                            // has narrowed it at this point
                            if !_build_flags.no_warn_redundant_unwrap then
                                _logger.warn(
                                    unwrap.location,
                                    "redundant-unwrap",
                                    "'!' is redundant here"
                                );
                            fi

                            unwrap.value = left_value;
                        else
                            _logger.error(unwrap.left.location, "cannot unwrap this");
                            unwrap.value = DUMMY(Semantic.Types.ERROR(), unwrap.location);
                        fi
                    fi
                fi
            elif value_member? then
                // TODO we could do an explicit has-value check here:
                if
                    !_build_flags.no_warn_redundant_unwrap /\
                    unwrap_left_value.type!.is_optional
                then
                    let unwrap_target = _visitor.try_get_narrowing_target(unwrap.left);

                    if unwrap_target? /\ _flow.is_non_null(unwrap_target) then
                        _logger.warn(
                            unwrap.location,
                            "redundant-unwrap",
                            "'!' is redundant here"
                        );
                    fi
                fi

                unwrap.value = value_member.load(unwrap.location, unwrap_left_value, _symbol_loader);
            else
                _logger.error(unwrap.left.location, "cannot unwrap this");
                unwrap.value = DUMMY(Semantic.Types.ERROR(), unwrap.location);
            fi

            // `x!` asserts `x` holds a value — record it, so a
            // subsequent dereference of `x` is not flagged. Skipped
            // when the target's current type is already non-optional
            // (the redundant-unwrap warning fires separately at that
            // site; recording the presence bit only grows every
            // downstream env for nothing).
            let target = _visitor.try_get_narrowing_target(unwrap.left);
            let target_type = if target? then target.type else null fi;

            if target? /\ target_type? /\ target_type.is_optional then
                _flow.mark_non_null(target);
                _flow.report_narrowing_site(
                    unwrap.location,
                    "narrowing-unwrap",
                    "►",
                    INLAY_TYPE.render(target_type.as_non_optional())
                );
            fi

            // TODO, we could handle ref and ptr here as well
        si

        visit_reference(reference: Trees.Expressions.REFERENCE) is
            if !reference.left? then
                _logger.poison(reference.location, "reference expression has no left expression");
                reference.value = DUMMY(Semantic.Types.ERROR(), reference.location);
                return;
            fi

            let left_value = reference.left.value;

            if !left_value? \/ !left_value.type? then
                _logger.poison(reference.left.location, "reference expression has no value");
                reference.value = DUMMY(Semantic.Types.ERROR(), reference.location);
                return;
            elif !left_value.has_address then
                _logger.warn(reference.left.location, "reference-to-expression", "reference to an expression");
            fi

            left_value.check_is_consumable(_logger, reference.left.location);

            reference.value = ADDRESS(left_value, _innate_symbol_lookup.get_reference_type(left_value.type!));
        si

        get_reference_has_value(
            location: LOCATION,
            value: Value,
            member: Semantic.Symbols.Symbol?,
            bool_type: Type
        ) -> Value is
            let null_check = HAS_VALUE(value, bool_type);

            if member? then
                let member_check = member.load(location, value, _symbol_loader);

                let and_identifier = Trees.Identifiers.Identifier(location, "/\\");
                let and_symbol = _visitor.find(and_identifier);

                if and_symbol? /\ isa Semantic.Symbols.FUNCTION_GROUP(and_symbol) then
                    _symbol_loader.find_symbol = (name: string) => _visitor.find(name);

                    let argument_types = Collections.LIST[Type]();
                    argument_types.add(bool_type);
                    argument_types.add(bool_type);

                    let overload_result =
                        _overload_resolver.resolve(
                            location,
                            and_symbol,
                            argument_types,
                            false,
                            false,
                            false
                        );

                    if overload_result? then
                        let function = overload_result.function;
                        if function.is_unsafe_constraints then
                            _logger.warn(location, "unchecked-constraints", "call to {function} has unchecked constraints");
                        fi

                        let arguments = Collections.LIST[Value]();
                        arguments.add(null_check);
                        arguments.add(member_check);

                        return function.call(
                            location,
                            null,
                            arguments,
                            bool_type,
                            _function_caller
                        );
                    fi
                fi
            fi

            return null_check;
        si

        // For a `?` / `!` operand, identify the default variant to
        // dispatch against. Returns the union's `default_variant`
        // when the operand is the union (null when the union has
        // no default — a source union without one, or an older
        // cross-asm union compiled before the
        // `DEFAULT_VARIANT_ATTRIBUTE` marker existed); returns the
        // variant itself when the operand is already narrowed to
        // its parent union's default variant so the caller can
        // skip an extra cast. Null for any other shape — the
        // caller's branch then short-circuits `?` to a bare null
        // check and `!` to a non-null assert on the operand.
        _get_default_variant_for_operand(
            classy: Semantic.Symbols.Classy?
        ) -> Semantic.Symbols.VARIANT? is
            if !classy? then
                return null;
            fi

            if classy.is_union then
                let union_classy = cast Semantic.Symbols.UNION?(classy)!;
                return union_classy.default_variant;
            fi

            if classy.is_variant then
                let variant_classy = cast Semantic.Symbols.VARIANT?(classy)!;

                if !variant_classy.owner? \/ !isa Semantic.Symbols.UNION(variant_classy.owner) then
                    return null;
                fi

                let owner_union = cast Semantic.Symbols.UNION(variant_classy.owner);

                if owner_union.default_variant == variant_classy then
                    return variant_classy;
                fi
            fi

            return null;
        si

        // `u?` lowers to `isa Default(u)`. The receiver's type
        // (often a generic instantiation of the union) drives
        // specialisation of the variant target type so the emitted
        // `isinst` references a loadable closed-generic class.
        _build_default_variant_isa(
            location: LOCATION,
            operand: Value,
            default_variant: Semantic.Symbols.VARIANT,
            bool_type: Type
        ) -> Value is
            let variant_type =
                _condition_analyzer.try_get_variant_type_for_classy(
                    operand.type!,
                    default_variant
                );

            if !variant_type? then
                return DUMMY(bool_type, location);
            fi

            return IR.Values.ISA(bool_type, variant_type, operand);
        si

        // `u!` lowers to `cast Default(u)`, with single-field
        // projection so the existing rule "default variant with one
        // field unwraps to that field" rides on the new lowering.
        // When the operand is already narrowed to the default
        // variant the cast is elided — the CLR accepts loading the
        // field directly off the variant-shaped receiver.
        _build_default_variant_unwrap(
            location: LOCATION,
            operand: Value,
            classy: Semantic.Symbols.Classy,
            default_variant: Semantic.Symbols.VARIANT
        ) -> Value is
            let variant_type =
                _condition_analyzer.try_get_variant_type_for_classy(
                    operand.type!,
                    default_variant
                );

            if !variant_type? then
                return DUMMY(Semantic.Types.ERROR(), location);
            fi

            let variant_value: Value mut = operand;

            if !classy.is_variant then
                variant_value = IR.Values.CAST(variant_type, operand);
            fi

            // Single-field unwrap rides on the cast: a default
            // variant declaring exactly one field — own or inherited
            // from the union's primary header — projects to that
            // field. Multi-field defaults return the variant itself
            // so callers can read every field via member access.
            if default_variant.field_count == 1 then
                let field_name = default_variant.get_destructure_member_name(0);

                if field_name? then
                    let field_member = variant_type.find_member(field_name);

                    if field_member? then
                        return field_member.load(location, variant_value, _symbol_loader);
                    fi
                fi
            fi

            return variant_value;
        si

        // Warn when a value is dereferenced through an optional receiver
        // (a `T?` reference or a NULLABLE[T]) not proven to hold a value
        // here. A receiver proven present by flow narrowing is safe —
        // a local, field or store-free property by its symbol fact, a
        // member-access path by its path fact (the path-narrowed load
        // reaches here already viewed at its non-optional type). Every
        // other optional receiver — un-narrowed, a call result, a path
        // through a getter that isn't store-free — may be null and must
        // be unwrapped (`!`), guarded (`?.`), or read into a local
        // before use. On by default; `--no-warn-null-deref` opts out.
        _check_possible_null_dereference(receiver: Trees.Expressions.Expression) is
            if _build_flags.no_warn_null_deref \/ !receiver? then
                return;
            fi

            let value = receiver.value;

            if !value? then
                return;
            fi

            let type = value.type;

            if !type? \/ !type.is_optional then
                return;
            fi

            let target = _visitor.try_get_narrowing_target(receiver);

            if target? /\ _flow.is_non_null(target) then
                return;
            fi

            let subject = if target? then target.name else "receiver" fi;

            _logger.warn(receiver.location, "null-deref", "{subject} may not hold a value here");
        si

        // Build a hinted "narrow further" message when a member
        // access on a ONE_OF fails to find the member on the root
        // but every in-set subtype has a same-named member. Returns
        // null when the hint doesn't apply (receiver isn't a ONE_OF,
        // or the name is missing on at least one in-set subtype).
        // Subtype-private fields can't be accessed through ONE_OF
        // without IL-side subtype-dispatching support — for now we
        // just direct the user to narrow further. Applies uniformly
        // to a union's variants and a closed class's subclasses.
        try_describe_intersection_miss(
            receiver_type: Type,
            member_name: string
        ) -> string? is
            if !isa Semantic.Types.ONE_OF(receiver_type) then
                return null;
            fi

            let one_of = receiver_type;

            let any_subtype mut = false;
            for subtype in one_of.subtypes do
                if !subtype? \/ !subtype.find_member(member_name)? then
                    return null;
                fi
                any_subtype = true;
            od

            if !any_subtype then
                return null;
            fi

            let names = System.Text.StringBuilder();
            let seen_any mut = false;
            for subtype in one_of.subtypes do
                if seen_any then
                    names.append(" | ");
                fi
                names.append(subtype.name);
                seen_any = true;
            od

            return "member {member_name} is ambiguous in {names}";
        si

        // Build the IR value for an `a?.b` access. Returns the
        // COALESCE_LOAD wrap when the receiver is a reference-typed
        // optional and the member is a readable field or property;
        // returns null (so the caller falls back to a plain access)
        // on shapes that aren't supported in this lowering. Emits a
        // diagnostic for each unsupported shape so the user learns
        // why the `?.` had no effect.
        _build_coalesce_load(
            member: Trees.Expressions.MEMBER,
            symbol: Semantic.Symbols.Symbol
        ) -> Value? is
            let receiver = member.left.value;

            if !receiver? \/ !receiver.type? then
                return null;
            fi

            let receiver_type = receiver.type!;

            // v1 scope: fields and properties only. A method
            // selection through `?.` would need to compose with the
            // surrounding CALL (the call itself must short-circuit),
            // which is a separate lowering.
            if
                !isa Semantic.Symbols.Field(symbol) /\
                !isa Semantic.Symbols.Property(symbol)
            then
                _logger.error(
                    member.location,
                    "coalescing member access supports fields and properties only"
                );
                return null;
            fi

            // A non-optional receiver (declared so, or flow-narrowed
            // from `T?` to `T`) is statically present, so the null
            // test can never fail. One flow-narrowed from optional
            // gets a redundancy warning; a never-optional value type
            // is an error (a struct is never null, so the test has
            // no defensive value); a never-optional reference stays
            // legal with no diagnostic, as the null-defense idiom at
            // unsound boundaries (reflected APIs, staged tree
            // construction) where null can arrive despite the static
            // type. The access is emitted directly — the conditional
            // path is unsound for a value-type receiver (`dup;
            // brfalse` rejects a struct on the stack) and unnecessary
            // work for a reference receiver. The result is still
            // widened to the optional shape the user asked for with
            // `?.`.
            if !receiver_type.is_optional then
                let target = _visitor.try_get_narrowing_target(member.left);
                let declared = if target? then _flow.declared_type_of(target) else null fi;

                if declared? /\ declared.is_optional then
                    _logger.warn(
                        member.location,
                        "redundant-coalesce",
                        "'?.' is redundant here"
                    );
                elif receiver_type.is_value_type then
                    _logger.error(member.left.location, "receiver is not optional");
                    return null;
                fi

                let direct_load = symbol.load(member.location, receiver, _symbol_loader);

                if !direct_load? \/ !direct_load.type? then
                    return null;
                fi

                let direct_type = direct_load.type;
                let direct_result = build_optional_type(direct_type!, _innate_symbol_lookup);

                if !direct_type.is_optional /\ direct_result.is_value_type then
                    return IR.Values.WRAP_OPTIONAL(direct_result, direct_load);
                fi

                // Reference T and T? share IL — re-type the load.
                if direct_type !~ direct_result then
                    return IR.Values.TYPE_WRAPPER(direct_result, direct_load);
                fi

                return direct_load;
            fi

            let receiver_is_value_optional = receiver_type.is_value_type;

            // The member symbol lives on the receiver's underlying
            // type regardless of the `?` flag, so `symbol.load`
            // against a STACK_TOP of the non-optional type emits the
            // expected access op with no preceding receiver gen.
            let inner_type =
                if receiver_is_value_optional then
                    receiver_type.optional_inner_type;
                else
                    receiver_type.as_non_optional();
                fi;

            if !inner_type? then
                return null;
            fi

            // STACK_TOP (has_address=false): the inner-receiver
            // value is on the stack, not its address. A struct
            // member access reads the value off the top, and the
            // existing call_struct_method path's `ADDRESS(from)`
            // spill takes its address as needed. A STACK_TOP_ADDRESS
            // here would tell that spill the address is already
            // present and skip it — producing a `call instance` on a
            // bare value, which segfaults at the JIT.
            let stack_top: IR.Values.Value = IR.Values.STACK_TOP(inner_type);

            let raw_load = symbol.load(member.location, stack_top, _symbol_loader);

            if !raw_load? \/ !raw_load.type? then
                return null;
            fi

            let raw_type = raw_load.type;
            let result_type = build_optional_type(raw_type!, _innate_symbol_lookup);

            // Make the present arm push a value of the result type:
            //   - reference T → T flagged optional, IL identity.
            //   - value T   → NULLABLE[T] via WRAP_OPTIONAL (newobj
            //                 Nullable<T>::.ctor(T)).
            //   - already-optional U → identity.
            let member_value: Value mut = raw_load;
            if
                !raw_type.is_optional /\
                result_type.is_value_type
            then
                member_value = IR.Values.WRAP_OPTIONAL(result_type, raw_load);
            fi

            let null_value = _build_null_sentinel(result_type);

            if !null_value? then
                return null;
            fi

            if receiver_is_value_optional then
                // Build presence test (get_has_value) and value
                // extract (get_value) against a STACK_TOP_ADDRESS so
                // both consume the address dup'd by COALESCE_LOAD.
                let address_stand_in = IR.Values.STACK_TOP_ADDRESS(receiver_type);
                let has_value_member = receiver_type.find_member("has_value");
                let value_member = receiver_type.find_member("value");

                if !has_value_member? \/ !value_member? then
                    _logger.poison(
                        member.location,
                        "coalescing member access receiver {receiver_type} missing has_value or value member"
                    );
                    return null;
                fi

                let presence_test = has_value_member.load(member.location, address_stand_in, _symbol_loader);
                let value_extract = value_member.load(member.location, address_stand_in, _symbol_loader);

                if !presence_test? \/ !value_extract? then
                    return null;
                fi

                return IR.Values.COALESCE_LOAD(
                    receiver,
                    presence_test,
                    value_extract,
                    member_value,
                    null_value,
                    result_type
                );
            fi

            return IR.Values.COALESCE_LOAD(receiver, member_value, null_value, result_type);
        si

        // The null-arm sentinel for a coalescing access of result
        // type `result_type`: `ldnull` for a reference type, a fresh
        // DEFAULT (which hoists a `.locals init` and pushes the zero
        // value) for a value-type optional like NULLABLE[T] or
        // MAYBE[T].
        _build_null_sentinel(result_type: Type) -> Value? is
            if !result_type? then
                return null;
            fi

            if result_type.is_value_type then
                return IR.Values.DEFAULT(result_type);
            fi

            return IR.RAW(result_type, "ldnull");
        si

        // The `T?` form of `t`: NULLABLE[T] for a value type, the
        // flagged reference for a reference type. `as_optional()`
        // alone returns the receiver for a value type — leaving the
        // result mistyped as `T` — so this dispatches the way
        // `resolve_type_expressions` does for a written `T?`. Static
        // so the rule can be pinned without standing up a full
        // COMPILE_ACCESS instance.
        build_optional_type(t: Type, lookup: Semantic.Lookups.InnateSymbolLookup) -> Type static is
            if !t? then
                return t;
            fi

            if t.is_optional then
                return t;
            fi

            if t.is_value_type then
                return lookup.get_optional_type(t);
            fi

            return t.as_optional();
        si
    si
si
