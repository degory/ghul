namespace Syntax.Process is
    use Collections;

    use Semantic;

    // One stage of a recognised pipe chain. `is_filter` false means a
    // `map`. `argument` is the stage's function-typed argument (the
    // `map`/`filter` lambda or delegate).
    //
    // When the argument is an inlinable literal lambda, compile-
    // expressions fills `param_local` (a synthetic enclosing-method
    // local the loop assigns the incoming element to) and `inline_body`
    // (the lambda body re-walked in the enclosing scope, so its
    // parameter loads that local and its captures load ordinary
    // enclosing locals - no delegate, no closure frame). When both are
    // set the loop emits the body inline; otherwise it invokes the
    // argument's compiled delegate value.
    class PIPE_FUSION_STAGE(is_filter: bool, argument: Trees.Expressions.Expression) is
        is_filter: bool public;
        argument: Trees.Expressions.Expression public;

        param_local: Semantic.Symbols.Variable? public;
        inline_body: IR.Values.Value? public;

        is_inlined: bool => param_local? /\ inline_body?;
    si

    // A recognised, provably-sound fusible pipe chain rooted at a `for`
    // loop. `source` is the pinned iterable fed to the base `pipe(...)`
    // wrap (see the soundness gate in PIPE_FUSION_RECOGNIZER); the fused
    // loop iterates it directly - so the wrapping ADAPTOR_PIPE is never
    // built either - and applies `stages` inline per element. `stages`
    // are outermost-first (the order they wrap the source), so inline
    // application walks them in reverse.
    class PIPE_FUSION(source: Trees.Expressions.Expression, stages_outermost_first: LIST[PIPE_FUSION_STAGE]) is
        source: Trees.Expressions.Expression public;
        stages_outermost_first: LIST[PIPE_FUSION_STAGE] public;

        // The source's own iterator members, resolved against its type
        // exactly as a plain `for x in source` would. read_iterator is
        // null when the source is directly an iterator (e.g. a range);
        // otherwise it yields the iterator that move_next / read_current
        // drive. Filled by compile-expressions after recognition.
        source_read_iterator: Semantic.Symbols.Function? public;
        source_move_next: Semantic.Symbols.Function? public;
        source_read_current: Semantic.Symbols.Function? public;
    si

    // Decides whether a `for x in <chain>` loop's expression is a
    // fusible pipe chain, and if so returns the plan the IL pass
    // consumes. Pure recognition — no compilation side effects.
    //
    // Soundness: Pipe[T] is a trait with virtual `map`/`filter`, so a
    // user type implementing Pipe may override them. Static resolution
    // to Pipe.map is not enough — the `callvirt` dispatches on the
    // receiver's dynamic type. The chain is only fused when its BASE is
    // pinned to a type that provably uses the default `map`/`filter`;
    // an induction over the closed-to-assembly built-in pipe classes
    // then secures every downstream stage (each stage's receiver is a
    // value freshly produced by an already-pinned default op returning
    // a closed built-in pipe). See docs/claude/pipe-fusion.md.
    //
    // The base must be a `pipe(SOURCE)` wrap (the postfix `|` operator,
    // carrying `is_pipe_wrap`) whose SOURCE is pinned: a value type or
    // an array that does not itself implement Pipe. Such a source has a
    // sealed dynamic type that is exactly its static type, so it cannot
    // be a user pipe with an override, and `pipe()` cannot short-circuit
    // to it - it wraps it in the built-in (closed) ADAPTOR_PIPE (which
    // the fused loop then skips by iterating SOURCE directly). Closed
    // ghūl-class sources could pin similarly but need a closed-subclass
    // Pipe check and are not admitted yet.
    class PIPE_FUSION_RECOGNIZER(_innate_symbol_lookup: Semantic.Lookups.InnateSymbolLookup) is
        recognize(`for: Trees.Statements.FOR) -> PIPE_FUSION? is
            let pipe_type = _innate_symbol_lookup.get_unspecialized_pipe_type();

            if !pipe_type? then
                return null;
            fi

            let expression = `for.expression;

            if !expression? then
                return null;
            fi

            let stages = LIST[PIPE_FUSION_STAGE]();

            let current mut = expression;

            // Peel `map`/`filter` layers off the outside of the chain.
            while isa Trees.Expressions.CALL(current) do
                let call = cast Trees.Expressions.CALL(current);

                if !isa Trees.Expressions.MEMBER(call.function) then
                    break;
                fi

                let member = cast Trees.Expressions.MEMBER(call.function);
                let name = member.identifier.name;

                let is_filter = name =~ "filter";
                let is_map = name =~ "map";

                if !(is_filter \/ is_map) then
                    break;
                fi

                if call.arguments.expressions.count != 1 then
                    break;
                fi

                // The receiver must be statically a Pipe[T]. On a trait
                // static type overload resolution binds the default
                // `map`/`filter`, so this identifies the default op.
                if !_is_pipe_expression(member.left, pipe_type) then
                    break;
                fi

                stages.add(PIPE_FUSION_STAGE(is_filter, call.arguments.expressions[0]));

                current = member.left;
            od

            if stages.count == 0 then
                return null;
            fi

            let source = _pinned_source(current, pipe_type);

            if !source? then
                return null;
            fi

            return PIPE_FUSION(source, stages);
        si

        // If `expression` is a `pipe(SOURCE)` wrap whose SOURCE is
        // pinned (a value type or an array that is not itself a Pipe),
        // return SOURCE; otherwise null.
        _pinned_source(expression: Trees.Expressions.Expression, pipe_type: Types.Type) -> Trees.Expressions.Expression? is
            if !isa Trees.Expressions.CALL(expression) then
                return null;
            fi

            let call = cast Trees.Expressions.CALL(expression);

            if !call.is_pipe_wrap then
                return null;
            fi

            if call.arguments.expressions.count != 1 then
                return null;
            fi

            let source = call.arguments.expressions[0];
            let source_value = source.value;

            if !source_value? \/ !source_value.type? then
                return null;
            fi

            let source_type = source_value.type!;

            if !(source_type.is_value_type \/ isa Semantic.Types.ARRAY(source_type)) then
                return null;
            fi

            if _is_pipe_type(source_type, pipe_type) then
                return null;
            fi

            return source;
        si

        _is_pipe_expression(expression: Trees.Expressions.Expression, pipe_type: Types.Type) -> bool is
            let value = expression.value;

            if !value? \/ !value.type? then
                return false;
            fi

            return _is_pipe_type(value.type!, pipe_type);
        si

        _is_pipe_type(type: Types.Type, pipe_type: Types.Type) -> bool =>
            Semantic.Symbols.TYPE_ARGUMENT_EXTRACTOR.extract(type, pipe_type)?;
    si
si
