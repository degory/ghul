namespace Syntax.Process is
    use Collections;

    use Semantic;

    // One inlinable stage of a recognised pipe chain. `is_filter`
    // false means a `map`. `argument` is the stage's function-typed
    // argument (the `map`/`filter` lambda or delegate); its compiled
    // value is what the fused loop invokes per element.
    class PIPE_FUSION_STAGE(is_filter: bool, argument: Trees.Expressions.Expression) is
        is_filter: bool public;
        argument: Trees.Expressions.Expression public;
    si

    // A recognised, provably-sound fusible pipe chain rooted at a `for`
    // loop. `base` is a Pipe[T] whose dynamic type is pinned to the
    // default `map`/`filter` (see the soundness gate in
    // PIPE_FUSION_RECOGNIZER); the fused loop iterates it and applies
    // `stages` inline per element. `stages` are outermost-first (the
    // order they wrap the base), so inline application walks them in
    // reverse.
    class PIPE_FUSION(base: Trees.Expressions.Expression, stages_outermost_first: LIST[PIPE_FUSION_STAGE]) is
        base: Trees.Expressions.Expression public;
        stages_outermost_first: LIST[PIPE_FUSION_STAGE] public;

        // The base's own iterator members, resolved against its Pipe[T]
        // type (the base is a Pipe, hence directly an Iterator[T]). The
        // fused loop drives these instead of the whole chain's, because
        // a `map` stage changes the element type — the FOR node's own
        // resolved slots describe the post-stage element, not the base
        // element. Filled by compile-expressions after recognition.
        base_move_next: Semantic.Symbols.Function? public;
        base_read_current: Semantic.Symbols.Function? public;
    si

    // Decides whether a `for x in <chain>` loop's expression is a
    // fusible pipe chain, and if so returns the plan the IL pass
    // consumes. Pure recognition — no compilation side effects.
    //
    // Soundness: Pipe[T] is a trait with virtual `map`/`filter`, so a
    // user type implementing Pipe may override them. Static resolution
    // to Pipe.map is not enough — the `callvirt` dispatches on the
    // receiver's dynamic type. The chain is only fused when its BASE is
    // pinned to a type that provably uses the default `map`/`filter`;
    // an induction over the closed-to-assembly built-in pipe classes
    // then secures every downstream stage (each stage's receiver is a
    // value freshly produced by an already-pinned default op returning
    // a closed built-in pipe). See docs/claude/pipe-fusion.md.
    //
    // First slice: the base must be a `pipe(SOURCE)` wrap (the postfix
    // `|` operator, carrying `is_pipe_wrap`) whose SOURCE is a value
    // type that does not itself implement Pipe. A value type is sealed
    // and its dynamic type is exactly its static type, so it cannot be
    // a user pipe with an override, and `pipe()` cannot short-circuit
    // to it — it wraps it in the built-in (closed) ADAPTOR_PIPE.
    // Array and closed-class sources come later.
    class PIPE_FUSION_RECOGNIZER(_innate_symbol_lookup: Semantic.Lookups.InnateSymbolLookup) is
        recognize(`for: Trees.Statements.FOR) -> PIPE_FUSION? is
            let pipe_type = _innate_symbol_lookup.get_unspecialized_pipe_type();

            if !pipe_type? then
                return null;
            fi

            let expression = `for.expression;

            if !expression? then
                return null;
            fi

            let stages = LIST[PIPE_FUSION_STAGE]();

            let current mut = expression;

            // Peel `map`/`filter` layers off the outside of the chain.
            while isa Trees.Expressions.CALL(current) do
                let call = cast Trees.Expressions.CALL(current);

                if !isa Trees.Expressions.MEMBER(call.function) then
                    break;
                fi

                let member = cast Trees.Expressions.MEMBER(call.function);
                let name = member.identifier.name;

                let is_filter = name =~ "filter";
                let is_map = name =~ "map";

                if !(is_filter \/ is_map) then
                    break;
                fi

                if call.arguments.expressions.count != 1 then
                    break;
                fi

                // The receiver must be statically a Pipe[T]. On a trait
                // static type overload resolution binds the default
                // `map`/`filter`, so this identifies the default op.
                if !_is_pipe_expression(member.left, pipe_type) then
                    break;
                fi

                stages.add(PIPE_FUSION_STAGE(is_filter, call.arguments.expressions[0]));

                current = member.left;
            od

            if stages.count == 0 then
                return null;
            fi

            if !_is_pinned_base(current, pipe_type) then
                return null;
            fi

            return PIPE_FUSION(current, stages);
        si

        // The base is pinned when it is a `pipe(SOURCE)` wrap whose
        // SOURCE is a value type that is not itself a Pipe.
        _is_pinned_base(expression: Trees.Expressions.Expression, pipe_type: Types.Type) -> bool is
            if !isa Trees.Expressions.CALL(expression) then
                return false;
            fi

            let call = cast Trees.Expressions.CALL(expression);

            if !call.is_pipe_wrap then
                return false;
            fi

            if call.arguments.expressions.count != 1 then
                return false;
            fi

            let source = call.arguments.expressions[0];
            let source_value = source.value;

            if !source_value? \/ !source_value.type? then
                return false;
            fi

            let source_type = source_value.type!;

            if !source_type.is_value_type then
                return false;
            fi

            return !_is_pipe_type(source_type, pipe_type);
        si

        _is_pipe_expression(expression: Trees.Expressions.Expression, pipe_type: Types.Type) -> bool is
            let value = expression.value;

            if !value? \/ !value.type? then
                return false;
            fi

            return _is_pipe_type(value.type!, pipe_type);
        si

        _is_pipe_type(type: Types.Type, pipe_type: Types.Type) -> bool =>
            Semantic.Symbols.TYPE_ARGUMENT_EXTRACTOR.extract(type, pipe_type)?;
    si
si
