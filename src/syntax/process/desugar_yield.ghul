namespace Syntax.Process is
    use Source;
    use Trees;
    use Logging;

    // Detects generator functions and (eventually) rewrites their
    // bodies into a list of state-handler lambdas plus a call to
    // `Ghul.Generators._gen_pipe(states)`.
    //
    // A generator is a function/lambda whose body contains a
    // `yield X;` statement AND whose return type is `Iterable[T]`
    // or `Iterator[T]`. Both conditions are checked syntactically
    // before resolution — the return-type predicate matches the
    // trailing identifier of the return type's generic name
    // (handles unqualified and `Collections.`-qualified forms).
    //
    // Phase 2b-ii: detection only. The pass sets the `contains_yield`
    // and `is_generator_function` flags on each FUNCTION node it
    // visits; the recursive AST rewriter lands in Phase 2b-iii.
    //
    // See `docs/claude/generators-yield.md`.
    class DESUGAR_YIELD: Visitor is
        _logger: Logger;

        init(logger: Logger) is
            super.init();
            _logger = logger;
        si

        apply(root: Node) is
            root.walk(self);
        si

        pre(function: Definitions.FUNCTION) -> bool is
            let scan = _scan_body(function.body);
            function.contains_yield = function.contains_yield \/ scan.found;
            function.is_generator_function =
                function.contains_yield /\
                Semantic.GEN_STEP_CONVERSION.is_generator_return_type(function.type_expression);
            if function.is_generator_function then
                _rewrite_generator_body(function.body, function.type_expression);
            fi
            return false;
        si

        pre(function: Expressions.FUNCTION) -> bool is
            let scan = _scan_body(function.body);
            function.contains_yield = function.contains_yield \/ scan.found;
            function.is_generator_function =
                function.contains_yield /\
                Semantic.GEN_STEP_CONVERSION.is_generator_return_type(function.type_expression);
            if function.is_generator_function then
                _rewrite_generator_body(function.body, function.type_expression);
            fi
            return false;
        si

        _rewrite_generator_body(
            body: Bodies.Body,
            return_type: TypeExpressions.TypeExpression
        ) is
            if !body? then
                return;
            fi
            let t = Semantic.GEN_STEP_CONVERSION.try_extract_generator_t(return_type);
            if !t? then
                return;
            fi
            // The function-level body wraps a Statements.LIST; the
            // rewriter operates on that list directly.
            if let block: Bodies.BLOCK = body then
                if block.statements? then
                    Semantic.GENERATOR_REWRITER(_logger, t).rewrite(block.statements);
                fi
            fi
        si

        _scan_body(body: Bodies.Body) -> YIELD_SCANNER is
            let scanner = YIELD_SCANNER();

            if !body? then
                return scanner;
            fi

            body.walk(scanner);
            return scanner;
        si
    si

    // Walks a function/lambda body looking for any `yield X;`
    // statement. Stops descending into nested functions / lambdas —
    // a yield inside a nested closure belongs to *that* closure,
    // not the enclosing one. Mirrors LET_AWAIT_SCANNER in shape.
    class YIELD_SCANNER: Visitor is
        found: bool public;

        init() is
            super.init();
        si

        pre(yield_stmt: Statements.YIELD) -> bool is
            found = true;
            return true;
        si

        pre(function: Definitions.FUNCTION) -> bool is
            return true;
        si

        pre(function: Expressions.FUNCTION) -> bool is
            return true;
        si
    si
si
