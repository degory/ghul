namespace IR is
    use IO.Std;

    use Semantic.Types.Type;
    use NAMED_TYPE = Semantic.Types.NAMED;

    class VALUE_CONVERTER(
        _logger: Logging.Logger,
        _innate_symbol_lookup: Semantic.Lookups.InnateSymbolLookup
    ) is
        _instructions: Collections.MAP[string, string]?;

        // System.Decimal has no `conv.*` IL opcode. Conversion to or
        // from decimal is a static call to `op_Implicit` / `op_Explicit`
        // on the Decimal type; the overload is keyed by the other type.
        // Populated by complete_initialization alongside _instructions.
        _decimal_to_il: Collections.MAP[string, string];
        _decimal_implicit_sources: Collections.SET[string];

        super();

        complete_initialization() is
            if _instructions? then
                return;
            fi

            _instructions = Collections.MAP[string, string]();

            add_instruction(_innate_symbol_lookup.get_bool_type(), "conv.u1");

            add_instruction(_innate_symbol_lookup.get_ubyte_type(), "conv.u1");
            add_instruction(_innate_symbol_lookup.get_byte_type(), "conv.i1");

            add_instruction(_innate_symbol_lookup.get_char_type(), "conv.u2");

            add_instruction(_innate_symbol_lookup.get_ushort_type(), "conv.u2");
            add_instruction(_innate_symbol_lookup.get_short_type(), "conv.i2");

            add_instruction(_innate_symbol_lookup.get_uint_type(), "conv.u4");
            add_instruction(_innate_symbol_lookup.get_int_type(), "conv.i4");

            add_instruction(_innate_symbol_lookup.get_ulong_type(), "conv.u8");
            add_instruction(_innate_symbol_lookup.get_long_type(), "conv.i8");

            add_instruction(_innate_symbol_lookup.get_single_type(), "conv.r4");
            add_instruction(_innate_symbol_lookup.get_double_type(), "conv.r8");

            _decimal_to_il = Collections.MAP[string, string]();
            _decimal_implicit_sources = Collections.SET[string]();

            // char is omitted intentionally — System.Decimal has no
            // op_Implicit(char) or op_Explicit returning char; .NET
            // routes char <-> decimal through int. A registration here
            // would emit `call ... op_Implicit(char)` / `op_Explicit`
            // returning `char`, both unresolvable methodrefs that the
            // JIT rejects. Users wanting char <-> decimal must go via
            // int explicitly.
            register_decimal_neighbour(_innate_symbol_lookup.get_byte_type(), "int8", true);
            register_decimal_neighbour(_innate_symbol_lookup.get_ubyte_type(), "unsigned int8", true);
            register_decimal_neighbour(_innate_symbol_lookup.get_short_type(), "int16", true);
            register_decimal_neighbour(_innate_symbol_lookup.get_ushort_type(), "unsigned int16", true);
            register_decimal_neighbour(_innate_symbol_lookup.get_int_type(), "int32", true);
            register_decimal_neighbour(_innate_symbol_lookup.get_uint_type(), "unsigned int32", true);
            register_decimal_neighbour(_innate_symbol_lookup.get_long_type(), "int64", true);
            register_decimal_neighbour(_innate_symbol_lookup.get_ulong_type(), "unsigned int64", true);
            register_decimal_neighbour(_innate_symbol_lookup.get_single_type(), "float32", false);
            register_decimal_neighbour(_innate_symbol_lookup.get_double_type(), "float64", false);
        si

        add_instruction(type: Type, instruction: string) is
            _instructions[type.symbol.qualified_name] = instruction;
        si

        register_decimal_neighbour(type: Type, il_name: string, is_implicit_to_decimal: bool) is
            let qn = type.symbol.qualified_name;
            _decimal_to_il[qn] = il_name;
            if is_implicit_to_decimal then
                _decimal_implicit_sources.add(qn);
            fi
        si

        get_instruction(type: Type?) -> string? is
            complete_initialization();

            if !type? then
                return null;
            fi

            let name = type.symbol.qualified_name;

            let instructions = _instructions;

            if instructions? /\ instructions.contains_key(name) then
                return instructions[name];
            fi
            return null;
        si

        // Returns the IL line that converts a value of `source` on the
        // stack to `target`, when at least one of them is decimal.
        // Returns null if neither is decimal, or if the requested
        // conversion has no Decimal::op_Implicit/op_Explicit overload.
        // Returns "nop" for the decimal -> decimal identity case so
        // callers can still emit a non-empty CONVERT (the stack stays
        // typed as decimal either way).
        get_decimal_conversion_instruction(source: Type?, target: Type?) -> string? is
            complete_initialization();

            if !source? \/ !target? then
                return null;
            fi

            let decimal_type = _innate_symbol_lookup.get_decimal_type();

            let source_is_decimal = source =~ decimal_type;
            let target_is_decimal = target =~ decimal_type;

            if !source_is_decimal /\ !target_is_decimal then
                return null;
            fi

            if source_is_decimal /\ target_is_decimal then
                return "nop";
            fi

            let decimal_il = "valuetype ['System.Runtime']'System'.'Decimal'";

            if target_is_decimal then
                if !_decimal_to_il.contains_key(source.symbol.qualified_name) then
                    return null;
                fi

                let source_il = _decimal_to_il[source.symbol.qualified_name];

                let method_name =
                    if _decimal_implicit_sources.contains(source.symbol.qualified_name) then
                        "op_Implicit"
                    else
                        "op_Explicit"
                    fi;

                return "call {decimal_il} {decimal_il}::{method_name}({source_il})";
            fi

            if !_decimal_to_il.contains_key(target.symbol.qualified_name) then
                return null;
            fi

            let target_il = _decimal_to_il[target.symbol.qualified_name];

            return "call {target_il} {decimal_il}::op_Explicit({decimal_il})";
        si
    si
si
