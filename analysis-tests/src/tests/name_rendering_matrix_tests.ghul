namespace Analysis.Tests is
    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Names render relative to where the cursor sits. This fixture declares
    // every nameable kind in namespace `Def`, then references them from a
    // sibling namespace with no import, a namespace that `use`s the whole of
    // `Def`, and a namespace that `use`s specific members. Each assertion
    // pins the exact rendered signature for one (kind, context) cell.
    class NAME_RENDERING_MATRIX_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace Def is\n"
            "    class FOO is\n"
            "        fld: int;\n"
            "        prp: int => fld;\n"
            "        meth() is si\n"
            "    si\n"
            "    class BOX[T] is si\n"
            "    trait TR is si\n"
            "    struct ST is si\n"
            "    union UN is\n"
            "        UVA\n"
            "        UVB(x: int)\n"
            "    si\n"
            "    enum EN is\n"
            "        EA\n"
            "        EB\n"
            "    si\n"
            "    gfn() is si\n"
            "si\n"
            "namespace Sib is\n"
            "    class NoImp is\n"
            "        uf(a: Def.FOO, b: Def.BOX[int]) is si\n"
            "        ue() -> Def.EN => Def.EN.EA\n"
            "        uv() -> Def.UN => Def.UN.UVA\n"
            "    si\n"
            "si\n"
            "namespace Imp is\n"
            "    use Def;\n"
            "    class WithNs is\n"
            "        uf(a: FOO, b: BOX[int]) is si\n"
            "        ue() -> EN => EN.EA\n"
            "    si\n"
            "si\n"
            "namespace SymImp is\n"
            "    use Def.EN.EA;\n"
            "    use Def.UN.UVA;\n"
            "    class WithSym is\n"
            "        ue() -> Def.EN => EA\n"
            "        uv() -> Def.UN => UVA\n"
            "    si\n"
            "si\n";

        // Hover the `occurrence`-th (1-based) appearance of `needle` and
        // return the rendered signature. Line/column are derived from the
        // fixture so cells read as (token, occurrence).
        hover_at(analyser: ANALYSER_PROCESS, needle: string, occurrence: int) -> string is
            let text = source();

            let index mut = -1;

            for i in 0..occurrence do
                index = text.index_of(needle, index + 1);
                assert index >= 0 else "occurrence {occurrence} of '{needle}' not found";
            od

            let line mut = 1;
            let last_newline mut = -1;
            let newline mut = text.index_of("\n", 0);

            while newline >= 0 /\ newline < index do
                line = line + 1;
                last_newline = newline;
                newline = text.index_of("\n", newline + 1);
            od

            let column = index - last_newline;

            analyser.send_hover("m.ghul", line, column);

            let response = analyser.read_query_response();

            assert isa Response.HOVER(response) else "expected HOVER response";

            if !response.signature? then
                return "<none>";
            fi

            if response.kind_label? then
                return "{response.signature} // {response.kind_label}";
            fi

            return response.signature;
        si

        check(analyser: ANALYSER_PROCESS, cell: string, needle: string, occurrence: int, expected: string) is
            Assert.are_equal(
                expected,
                hover_at(analyser, needle, occurrence),
                "{cell}\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        matrix() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            analyser.send_edit("m.ghul", source());

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            // === Declarations: relative to the enclosing namespace ===
            // A top-level type or global is bare; a member keeps the type
            // (or union / enum) it belongs to, since it is not spellable
            // bare from the namespace.
            check(analyser, "decl class",     "FOO",  1, "class FOO");
            check(analyser, "decl generic",   "BOX",  1, "class BOX");
            check(analyser, "decl trait",     "TR",   1, "trait TR");
            check(analyser, "decl struct",    "ST",   1, "struct ST");
            check(analyser, "decl union",     "UN",   1, "union UN");
            check(analyser, "decl enum",      "EN",   1, "enum EN");
            check(analyser, "decl enum-member","EA",  1, "EN.EA = 0 // enum member");
            check(analyser, "decl variant",   "UVA",  1, "variant UN.UVA");
            check(analyser, "decl method",    "meth", 1, "FOO.meth() -> void // pure method");
            check(analyser, "decl property",  "prp",  1, "FOO.prp: int // pure instance property");
            check(analyser, "decl field",     "fld",  1, "FOO.fld: int // pure instance property");
            // Known oddity: a global function declaration renders its built-in
            // return type qualified (Ghul.void) where an instance method
            // renders it bare (void). Pinned here to track; see PR notes.
            check(analyser, "decl global",    "gfn",  1, "gfn() -> Ghul.void // pure global function");

            // === Sibling namespace, no import: fully qualified ===
            check(analyser, "sibling type",        "FOO", 2, "class Def.FOO");
            check(analyser, "sibling generic",     "BOX", 2, "class Def.BOX");
            check(analyser, "sibling enum-member", "EA",  2, "Def.EN.EA = 0 // enum member");
            check(analyser, "sibling variant",     "UVA", 2, "Def.UN.UVA.init() // constructor");

            // === `use Def`: type bare, member keeps its type ===
            check(analyser, "ns-import type",        "FOO", 3, "class FOO");
            check(analyser, "ns-import enum-member", "EA",  3, "EN.EA = 0 // enum member");

            // === specific member `use`: bare ===
            check(analyser, "sym-import enum-member", "EA",  5, "EA = 0 // enum member");
            check(analyser, "sym-import variant",     "UVA", 4, "UVA.init() // constructor");
        si
    si
si
