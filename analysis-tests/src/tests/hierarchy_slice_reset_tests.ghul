namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.Response;
    use Analysis.Protocol.user_diagnostics_of;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // A signature edit to a member of a class with ghul-declared
    // subclasses takes the incremental interface path: the reconcile
    // resets and re-pulls the whole implementor closure, so subclasses'
    // pulled-down copies and override bookkeeping stay consistent, and
    // the reference-scanned dependent recompile re-binds callers that
    // reach the member through a subclass. A member that a subclass
    // overrides still falls back to the whole-project rebuild.
    class HIERARCHY_SLICE_RESET_TESTS is
        @test()

        init() is si

        INTERFACE_INCREMENTAL: string => "edit-path-interface-incremental";
        FULL_REBUILD: string => "edit-path-full-rebuild";

        base_probe_int() -> string =>
            "namespace HSlice is\n"
            "    class BASE is\n"
            "        init() is si\n"
            "\n"
            "        probe(a: int) -> int => a;\n"
            "    si\n"
            "si\n";

        base_probe_string() -> string =>
            "namespace HSlice is\n"
            "    class BASE is\n"
            "        init() is si\n"
            "\n"
            "        probe(a: string) -> int => 0;\n"
            "    si\n"
            "si\n";

        // SUB inherits probe; check reaches it through SUB, so its
        // validity follows BASE.probe's signature.
        sub_source() -> string =>
            "namespace HSlice is\n"
            "    class SUB: BASE is\n"
            "        init() is si\n"
            "    si\n"
            "\n"
            "    check(s: SUB) -> int => s.probe(0);\n"
            "si\n";

        // SUB overrides probe: the edited member has a ghul-declared
        // overrider, which the incremental path must reject.
        sub_overriding_source() -> string =>
            "namespace HSlice is\n"
            "    class SUB: BASE is\n"
            "        init() is si\n"
            "\n"
            "        probe(a: int) -> int => 1;\n"
            "    si\n"
            "\n"
            "    check(s: SUB) -> int => s.probe(0);\n"
            "si\n";

        prime(analyser: ANALYSER_PROCESS, sub: string) -> LIST[DIAGNOSTIC] is
            analyser.send_edit_files([
                EDIT_FILE("hs-base.ghul", base_probe_int()),
                EDIT_FILE("hs-sub.ghul", sub)
            ]);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response after EDIT";

            return LIST[DIAGNOSTIC](user_diagnostics_of(diagnostics));
        si

        edit_base(analyser: ANALYSER_PROCESS, source: string) -> LIST[DIAGNOSTIC] is
            analyser.send_edit("hs-base.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response after EDIT";

            return LIST[DIAGNOSTIC](user_diagnostics_of(diagnostics));
        si

        compile(analyser: ANALYSER_PROCESS) -> LIST[DIAGNOSTIC] is
            analyser.send_compile();

            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response after COMPILE";

            return LIST[DIAGNOSTIC](user_diagnostics_of(response));
        si

        summary(diagnostics: LIST[DIAGNOSTIC]) -> string is
            let result = System.Text.StringBuilder();
            for d in diagnostics do
                result.append("\n  ").append(d.to_string());
            od
            return result.to_string();
        si

        signature_edit_under_a_subclass_stays_incremental() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let baseline = prime(analyser, sub_source());
            Assert.are_equal(
                0,
                baseline.count,
                "baseline should be clean; got:{summary(baseline)}\n--- stderr ---\n{analyser.stderr_capture}"
            );

            let incremental_before = analyser.stat_count(INTERFACE_INCREMENTAL);
            let full_before = analyser.stat_count(FULL_REBUILD);

            // int -> string: check's probe(0) through SUB becomes invalid.
            let after = edit_base(analyser, base_probe_string());

            Assert.is_true(
                after.count > 0,
                "after narrowing probe to take string, check's probe(0) through SUB should error\n--- stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(
                incremental_before + 1,
                analyser.stat_count(INTERFACE_INCREMENTAL),
                "the subclassed base's member edit should take the incremental interface path\n--- stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(
                full_before,
                analyser.stat_count(FULL_REBUILD),
                "the subclass must not force the whole-project rebuild\n--- stderr ---\n{analyser.stderr_capture}"
            );

            // string -> int: valid again, still incrementally. The
            // caller's failed call recorded no reference, so the cure
            // arrives at the debounced COMPILE, which re-checks files
            // holding errors.
            edit_base(analyser, base_probe_int());

            let restored = compile(analyser);

            Assert.are_equal(
                0,
                restored.count,
                "widening probe back to int + COMPILE should clear the error; got:{summary(restored)}\n--- stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(
                incremental_before + 2,
                analyser.stat_count(INTERFACE_INCREMENTAL),
                "the restoring edit should also stay incremental\n--- stderr ---\n{analyser.stderr_capture}"
            );
        si

        signature_edit_of_an_overridden_member_falls_back() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let baseline = prime(analyser, sub_overriding_source());
            Assert.are_equal(
                0,
                baseline.count,
                "baseline should be clean; got:{summary(baseline)}\n--- stderr ---\n{analyser.stderr_capture}"
            );

            let full_before = analyser.stat_count(FULL_REBUILD);

            edit_base(analyser, base_probe_string());

            Assert.are_equal(
                full_before + 1,
                analyser.stat_count(FULL_REBUILD),
                "editing a member a subclass overrides must fall back to the whole-project rebuild\n--- stderr ---\n{analyser.stderr_capture}"
            );

            // check's call resolves SUB's own int overload either way;
            // whatever override diagnostics the rebuild reports are the
            // rebuild's business - the invariant pinned here is the
            // fallback itself.
        si
    si
si
