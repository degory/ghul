namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.QUICK_FIX;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // The wire DIAGNOSTIC DTO carries ready-to-apply quick fixes so the
    // IDE client can offer them without any per-code knowledge: a
    // preferred removal fix for the redundant-operator warnings, and a
    // `@suppress("<code>")` insertion per enclosing scope for every coded
    // diagnostic.
    class QUICK_FIX_TESTS is
        @test()

        init() is si

        _find_by_code(diagnostics: Collections.Iterable[DIAGNOSTIC], code: string) -> DIAGNOSTIC? static is
            for d in diagnostics do
                if d.code? /\ d.code =~ code then
                    return d;
                fi
            od

            return null;
        si

        redundant_operator_warnings_carry_removal_then_suppress_fixes() is
            @test()

            let source = File.read_all_text(fixture_path("quick-fixes/quick-fixes.ghul"));

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("quick-fixes.ghul", source);

            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response";

            let user = LIST[DIAGNOSTIC](user_diagnostics_of(response));

            // `b!` on line 18: the removal fix comes first, marked
            // preferred, deleting the last character of the diagnostic
            // range.
            let unwrap = _find_by_code(user, "redundant-unwrap");
            assert unwrap? else "expected a redundant-unwrap diagnostic\n{diagnostics_summary("got", user)}";

            let fixes = unwrap.fixes;
            assert fixes? /\ fixes.count == 4 else "expected 4 fixes on redundant-unwrap, got {if fixes? then fixes.count.to_string() else "none" fi}";

            let removal = fixes[0];
            Assert.are_equal("Remove redundant '!'", removal.title);
            Assert.is_true(removal.is_preferred);
            Assert.are_equal(1, removal.edits.count);

            let removal_edit = removal.edits[0];
            Assert.are_equal(unwrap.end_line, removal_edit.start_line);
            Assert.are_equal(unwrap.end_column - 1, removal_edit.start_column);
            Assert.are_equal(unwrap.end_column, removal_edit.end_column);
            Assert.are_equal("!", removal_edit.replaces);
            Assert.are_equal("", removal_edit.new_text);

            // Suppress fixes walk outward: the statement, the enclosing
            // if, the enclosing function — each an insertion at column 1
            // of the anchor's line, indented to match the anchor.
            Assert.are_equal("Suppress here: @suppress(\"redundant-unwrap\")", fixes[1].title);
            Assert.are_equal("Suppress for enclosing block: @suppress(\"redundant-unwrap\")", fixes[2].title);
            Assert.are_equal("Suppress for enclosing method: @suppress(\"redundant-unwrap\")", fixes[3].title);

            Assert.is_false(fixes[1].is_preferred);

            let here_edit = fixes[1].edits[0];
            Assert.are_equal(18, here_edit.start_line);
            Assert.are_equal(1, here_edit.start_column);
            Assert.are_equal(18, here_edit.end_line);
            Assert.are_equal(1, here_edit.end_column);
            Assert.is_false(here_edit.replaces?);
            Assert.are_equal("            @suppress(\"redundant-unwrap\")\n", here_edit.new_text);

            Assert.are_equal(17, fixes[2].edits[0].start_line);
            Assert.are_equal("        @suppress(\"redundant-unwrap\")\n", fixes[2].edits[0].new_text);

            Assert.are_equal(14, fixes[3].edits[0].start_line);
            Assert.are_equal("    @suppress(\"redundant-unwrap\")\n", fixes[3].edits[0].new_text);

            // `b?` on line 19 gets the same shape with the '?' operator.
            let presence = _find_by_code(user, "redundant-presence-test");
            assert presence? else "expected a redundant-presence-test diagnostic\n{diagnostics_summary("got", user)}";

            let presence_fixes = presence.fixes;
            assert presence_fixes? else "expected fixes on redundant-presence-test";

            Assert.are_equal("Remove redundant '?'", presence_fixes[0].title);
            Assert.are_equal("?", presence_fixes[0].edits[0].replaces);

            // `b?.label` on line 20: the fix deletes the '?' that follows
            // the receiver `b`, leaving a plain member access.
            let coalesce = _find_by_code(user, "redundant-coalesce");
            assert coalesce? else "expected a redundant-coalesce diagnostic\n{diagnostics_summary("got", user)}";

            let coalesce_fixes = coalesce.fixes;
            assert coalesce_fixes? else "expected fixes on redundant-coalesce";

            let coalesce_removal = coalesce_fixes[0];
            Assert.are_equal("Replace '?.' with '.'", coalesce_removal.title);
            Assert.is_true(coalesce_removal.is_preferred);

            let coalesce_edit = coalesce_removal.edits[0];
            Assert.are_equal(20, coalesce_edit.start_line);
            Assert.are_equal(33, coalesce_edit.start_column);
            Assert.are_equal(20, coalesce_edit.end_line);
            Assert.are_equal(34, coalesce_edit.end_column);
            Assert.are_equal("?", coalesce_edit.replaces);
            Assert.are_equal("", coalesce_edit.new_text);
        si

        coded_diagnostic_without_removal_gets_suppress_fixes_only() is
            @test()

            let source = File.read_all_text(fixture_path("diagnostic-code/diagnostic-code.ghul"));

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("diagnostic-code.ghul", source);

            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response";

            let user = LIST[DIAGNOSTIC](user_diagnostics_of(response));

            let coded = _find_by_code(user, "non-exception-throw");
            assert coded? else "expected a non-exception-throw diagnostic\n{diagnostics_summary("got", user)}";

            let fixes = coded.fixes;
            assert fixes? /\ fixes.count > 0 else "expected suppress fixes on non-exception-throw";

            for fix in fixes do
                Assert.is_false(fix.is_preferred);
            od

            Assert.is_true(
                fixes[0].title =~ "Suppress here: @suppress(\"non-exception-throw\")",
                "unexpected first fix title: {fixes[0].title}"
            );
        si
    si
si
