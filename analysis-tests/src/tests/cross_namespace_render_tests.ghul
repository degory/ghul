namespace Analysis.Tests is
    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // A type from a namespace the source does not `use` must stay
    // qualified in hover: `IO.TextWriter` here, since the fixture uses
    // `IO.Std` but not `IO`, so bare `TextWriter` would not resolve.
    class CROSS_NAMESPACE_RENDER_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace Test is\n"
            "    use IO.Std;\n"
            "\n"
            "    class C is\n"
            "        f(writer: IO.TextWriter) is\n"
            "        si\n"
            "    si\n"
            "si\n";

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("test.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.signature? then
                return "";
            fi
            if response.kind_label? then
                return "{response.signature} // {response.kind_label}";
            fi
            return response.signature;
        si

        hover_on_param_of_unimported_namespace_type__stays_qualified() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            analyser.send_edit("test.ghul", source());
            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            // `writer` parameter is at line 5, column 11.
            let description = hover_description(analyser, 5, 11);

            Assert.is_true(
                description? /\ description.contains("IO.TextWriter"),
                "expected hover to keep IO.TextWriter qualified, got '{description}'\n--- stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
