namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.RESPONSE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // SIGNATURE coverage for callees that are anonymous functions: a
    // let-bound lambda, a function-typed parameter, an inline-invoked
    // lambda. These resolve to a value of function type rather than to
    // a FUNCTION_GROUP symbol, so signature help is derived from the
    // function type. The named-function case is kept as a regression
    // guard that the function-group path still works.
    //
    // The response carries best_signature_index, current_parameter_index,
    // and a list of signatures (each a label plus a list of parameter
    // strings) — see SIGNATURE_HANDLER and response-handler.ts.
    class LAMBDA_SIGNATURE_TESTS is
        @test()

        init() is si

        load() -> string is
            let path = Path.combine(fixture_dir("lambda-signature"), "main.ghul");
            assert File.exists(path) else "fixture missing: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit_files([EDIT_FILE("main.ghul", source)]);
            analyser.read_response();
            analyser.send_edit("main.ghul", source);
            analyser.read_response();
        si

        // Query SIGNATURE at a position and return the typed response.
        signature_at(analyser: ANALYSER_PROCESS, line: int, column: int) -> RESPONSE is
            analyser.send_signature("main.ghul", line, column);

            let response = analyser.read_query_response();
            Assert.are_equal("signature", response.kind);

            return response;
        si

        named_function_with_lambda_argument_shows_function_group_signature() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            // inside the lambda argument of `apply(n => n + 1, 10)`
            let inside_lambda = signature_at(analyser, 11, 28);
            Assert.is_true(inside_lambda.signatures.count >= 1, "no signature returned: {inside_lambda.signatures.count} signatures");
            Assert.is_true(
                inside_lambda.signatures[0].label.starts_with("apply("),
                "expected apply(...) signature, got: {inside_lambda.signatures[0].label}"
            );
            Assert.are_equal(0, inside_lambda.current_parameter_index, "expected current parameter 0");

            // at the second argument `10`
            let second_argument = signature_at(analyser, 11, 40);
            Assert.are_equal(1, second_argument.current_parameter_index, "expected current parameter 1");
        si

        call_of_let_bound_lambda_shows_function_type_signature() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            // `stored(7)` — stored is a local bound to `(n: int) -> int => n * 2`
            let response = signature_at(analyser, 13, 29);

            Assert.is_true(response.signatures.count >= 1, "no signature returned: {response.signatures.count} signatures");

            let signature = response.signatures[0];
            Assert.are_equal("(int) -> int", signature.label);
            Assert.are_equal(1, signature.parameters.count, "expected one parameter");
            Assert.are_equal("int", signature.parameters[0]);
        si

        call_of_function_typed_parameter_shows_function_type_signature() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            // `act(value)` inside run() — act is a parameter of type (int) -> void
            let response = signature_at(analyser, 5, 13);

            Assert.is_true(response.signatures.count >= 1, "no signature returned: {response.signatures.count} signatures");

            let signature = response.signatures[0];
            Assert.are_equal("(int) -> void", signature.label);
            Assert.are_equal("int", signature.parameters[0]);
        si

        call_of_multi_argument_function_value_tracks_parameter() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            // `pick(value, "x")` — pick is a parameter of type (int, string) -> bool
            let first = signature_at(analyser, 8, 70);
            Assert.is_true(first.signatures.count >= 1, "no signature returned: {first.signatures.count} signatures");

            let signature = first.signatures[0];
            Assert.are_equal("(int, string) -> bool", signature.label);
            Assert.are_equal("int", signature.parameters[0]);
            Assert.are_equal("string", signature.parameters[1]);
            Assert.are_equal(0, first.current_parameter_index, "expected current parameter 0");

            // at the second argument `"x"`
            let second = signature_at(analyser, 8, 77);
            Assert.are_equal(1, second.current_parameter_index, "expected current parameter 1");
        si

        inline_invoked_anonymous_function_shows_function_type_signature() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            // `((n: int) -> int => n + 1)(3)` — the callee is the lambda itself
            let response = signature_at(analyser, 14, 49);

            Assert.is_true(response.signatures.count >= 1, "no signature returned: {response.signatures.count} signatures");

            let signature = response.signatures[0];
            Assert.are_equal("(int) -> int", signature.label);
            Assert.are_equal("int", signature.parameters[0]);
        si
    si
si
