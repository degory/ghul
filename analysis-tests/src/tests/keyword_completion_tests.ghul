namespace Analysis.Tests is
    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Issue #76: code completion should suggest context-appropriate
    // keywords. COMPLETER.add_keyword_matches classifies the innermost
    // enclosing scope; the COMPLETION_HANDLER emits the keywords with
    // CompletionItemKind.Keyword (14).
    class KEYWORD_COMPLETION_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("keyword-completion/keyword-completion.ghul");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS) is
            analyser.send_edit("keyword-completion.ghul", load_fixture());

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
        si

        // A keyword completion carries CompletionItemKind.Keyword == 14.
        has_keyword(response: Response.COMPLETION, keyword: string) -> bool is
            for item in response.items do
                if item.name =~ keyword /\ item.kind == 14 then
                    return true;
                fi
            od

            return false;
        si

        get_insert_text(response: Response.COMPLETION, keyword: string) -> string is
            for item in response.items do
                if item.name =~ keyword /\ item.kind == 14 then
                    return item.insert_text;
                fi
            od

            return null;
        si

        // Line 7 is blank, inside run()'s body — a statement position.
        completion_in_statement_context_offers_statement_keywords() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_completion("keyword-completion.ghul", 7, 13);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            Assert.is_true(
                has_keyword(response, "while"),
                "expected `while` among statement-context keyword completions.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.is_true(
                has_keyword(response, "return"),
                "expected `return` among statement-context keyword completions"
            );
        si

        // Line 9 is blank, inside WIDGET's body but outside run() — a
        // member-definition position.
        completion_in_type_body_offers_member_keywords() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_completion("keyword-completion.ghul", 9, 9);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            Assert.is_true(
                has_keyword(response, "static"),
                "expected `static` among type-body keyword completions.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.is_false(
                has_keyword(response, "while"),
                "`while` is a statement keyword and should not appear in a type body"
            );
        si

        // Multi-line constructs carry an LSP-tabstop snippet body so
        // the VSCE can expand them; plain keywords (verbatim insert)
        // come back with an empty body. `if` and `assert` both belong
        // in statement position; only `if` should be a snippet.
        statement_keywords_carry_snippet_bodies_for_multiline_constructs() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_completion("keyword-completion.ghul", 7, 13);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            // `$1` sits on the condition so the cursor lands there ready
            // for the user to type; tab moves to `$0` (the body).
            let if_body = get_insert_text(response, "if");
            Assert.is_true(
                if_body? /\ if_body =~ "if ${1:condition} then\n\t$0\nfi",
                "expected `if` keyword to carry the tabbable snippet body, got: {if_body}"
            );

            let assert_body = get_insert_text(response, "assert");
            Assert.are_equal(
                "",
                assert_body,
                "expected `assert` to come back as a verbatim keyword (no snippet body)"
            );

            // ghūl `when` clauses end with `then`, never a colon
            // (`:` only introduces a type ascription). Pin the
            // `case` body so a future edit can't reintroduce the
            // malformed `when ... :` shape.
            let case_body = get_insert_text(response, "case");
            Assert.is_true(
                case_body? /\ case_body =~ "case ${1:expression}\n\twhen ${2:pattern} then\n\t\t$0\nesac",
                "expected canonical `case` snippet body, got: {case_body}"
            );
        si
    si
si
