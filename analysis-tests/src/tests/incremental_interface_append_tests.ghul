namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Guards the append-only incremental interface edit: when a
    // single-file EDIT's new interface signature strictly extends the
    // retained one, the appended declarations are declared, resolved and
    // compiled against the retained symbol table instead of triggering
    // the whole-project rebuild. Runs meaningfully in both suite modes -
    // without --incremental-analysis the same edits take the full
    // rebuild, so the mode-sensitive assertions branch on the flag.
    class INCREMENTAL_INTERFACE_APPEND_TESTS is
        @test()

        init() is si

        is_incremental_mode() -> bool is
            let extra = System.Environment.get_environment_variable("ANALYSER_EXTRA_ARGS");

            return extra? /\ extra.contains("--incremental-analysis");
        si

        helper_source() -> string =>
            "namespace AppendTarget is\n"
            "    class HELPER is\n"
            "        init() is si\n"
            "\n"
            "        value() -> int => 1;\n"
            "    si\n"
            "si\n";

        // The appended block mirrors the analysis profiler's
        // interface-edit shape: a new namespace with a global function
        // appended at the end of the file. Its body references the
        // retained HELPER class, so a clean compile proves the appended
        // subtree resolved against the retained tables.
        helper_source_with_appended_probe() -> string =>
            "{helper_source()}"
            "namespace AppendProbe is\n"
            "    probe() -> int => AppendTarget.HELPER().value();\n"
            "si\n";

        helper_source_with_appended_error() -> string =>
            "{helper_source()}"
            "namespace AppendProbe is\n"
            "    probe() -> int => AppendTarget.HELPER().no_such_member();\n"
            "si\n";

        watcher_source() -> string =>
            "namespace AppendTarget is\n"
            "    class WATCHER is\n"
            "        init() is si\n"
            "\n"
            "        watch() -> int is\n"
            "            let h = HELPER();\n"
            "            return h.value();\n"
            "        si\n"
            "    si\n"
            "si\n";

        prime(analyser: ANALYSER_PROCESS) is
            analyser.send_edit_files([
                EDIT_FILE("helper.ghul", helper_source()),
                EDIT_FILE("watcher.ghul", watcher_source())
            ]);

            assert_clean(analyser, "priming EDIT");
        si

        assert_clean(analyser: ANALYSER_PROCESS, context: string) is
            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS on {context}, got '{response.get_type().name}'";

            let user_diagnostics = LIST[DIAGNOSTIC](user_diagnostics_of(response));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                "{diagnostics_summary("{context} surfaced unexpected diagnostics", user_diagnostics)}\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        appended_declarations_compile_against_retained_tables() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_edit("helper.ghul", helper_source_with_appended_probe());

            assert_clean(analyser, "append EDIT");

            // `value` in the appended probe's body - present in the hover
            // map only if the appended subtree went through
            // compile-expressions.
            analyser.send_hover("helper.ghul", 9, 46);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER, got '{response.get_type().name}'";

            Assert.is_true(
                response.signature? /\ response.signature.contains("value"),
                "HOVER on the appended probe's call should describe `value`, got: {response.signature}"
            );
        si

        errors_in_appended_declarations_are_reported() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_edit("helper.ghul", helper_source_with_appended_error());

            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS, got '{response.get_type().name}'";

            let user_diagnostics = LIST[DIAGNOSTIC](user_diagnostics_of(response));

            Assert.is_true(
                user_diagnostics | .any(d => d.message.contains("no_such_member")),
                "{diagnostics_summary("expected a diagnostic about no_such_member in the appended code, got", user_diagnostics)}"
            );
        si

        // The discriminator: after an append edit, the other file's
        // expression-level state should be untouched - a hover into its
        // body answers directly. Without the flag the same edit takes the
        // whole-project rebuild, which leaves the other file not compiled
        // through expressions, so the hover pays a recompile and its
        // diagnostics frame arrives first.
        append_edit_keeps_other_files_compiled_through() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            // Baseline: the position resolves directly before the edit,
            // pinning that a later miss is the edit's doing rather than a
            // wrong fixture position.
            analyser.send_hover("watcher.ghul", 7, 23);

            let baseline = analyser.read_response();
            assert isa Response.HOVER(baseline)
                else "expected HOVER directly on the primed file before any edit, got '{baseline.get_type().name}'";
            Assert.is_true(
                baseline.signature? /\ baseline.signature.contains("value"),
                "baseline HOVER should describe `value`, got: {baseline.signature}"
            );

            analyser.send_edit("helper.ghul", helper_source_with_appended_probe());

            assert_clean(analyser, "append EDIT");

            // `value` in WATCHER.watch's body.
            analyser.send_hover("watcher.ghul", 7, 23);

            if is_incremental_mode() then
                let response = analyser.read_response();
                assert isa Response.HOVER(response)
                    else "expected HOVER directly (append path retains other files' compiled state), got '{response.get_type().name}'"
                        "\n--- analyser stderr ---\n{analyser.stderr_capture}";

                Assert.is_true(
                    response.signature? /\ response.signature.contains("value"),
                    "HOVER on watcher's call should describe `value`, got: {response.signature}"
                );
            else
                let response = analyser.read_query_response();
                assert isa Response.HOVER(response) else "expected HOVER, got '{response.get_type().name}'";
            fi
        si
    si
si
