namespace Analysis.Tests is
    use Collections.Iterable;
    use Collections.LIST;
    use Collections.SET;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.RESPONSE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // REFERENCES and IMPLEMENTATION queries targeting members declared on a
    // trait — an abstract method, a default method, and a property — across
    // multiple implementing classes and call sites that use both trait-typed
    // and class-typed receivers.
    //
    // The fixture `trait-members-references` declares trait GREETER with
    // abstract `greet()`, default `polite_greet()`, and abstract property
    // `name`. FORMAL_GREETER and CASUAL_GREETER both implement; only
    // CASUAL_GREETER overrides the default `polite_greet`. `uses.ghul`
    // calls each member four ways: via trait-typed g1/g2 and via class-typed
    // f/c. The full whole-symbol REFERENCES result therefore covers both
    // dispatch paths.
    class TRAIT_MEMBER_REFERENCES_TESTS is
        @test()

        init() is si

        load(file: string) -> string is
            let path = fixture_path(Path.combine("trait-members-references", file));

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        fixture_files() -> Iterable[EDIT_FILE] is
            return [
                EDIT_FILE("greeters.ghul", load("greeters.ghul")),
                EDIT_FILE("uses.ghul", load("uses.ghul"))
            ];
        si

        // Mimic IDE startup: one multi-file EDIT that names every source
        // file. Drains DIAGNOSTICS + PARTIAL DONE. No subsequent full
        // COMPILE — same shape that drives rename_tests / completeness
        // tests and the IDE's first interaction window.
        prime(analyser: ANALYSER_PROCESS) is
            analyser.send_edit_files(fixture_files());

            let diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", diagnostics.header);

            let user_diagnostics = LIST(diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("priming EDIT had unexpected diagnostics", user_diagnostics)
            );

            let partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", partial_done.header);
        si

        // REFERENCES / IMPLEMENTATION format a location line as five
        // tab-separated fields: file, start_line, start_col, end_line,
        // end_col. See command_handlers.ghul `format_location`.
        parse_locations(response: RESPONSE) -> LIST[LOCATION_LINE] is
            let result = LIST[LOCATION_LINE]();

            for line in response.lines do
                let fields = line.split(['\t']);

                if fields.count != 5 then
                    continue;
                fi

                try
                    result.add(
                        LOCATION_LINE(
                            fields[0],
                            System.Convert.to_int32(fields[1]),
                            System.Convert.to_int32(fields[2]),
                            System.Convert.to_int32(fields[3]),
                            System.Convert.to_int32(fields[4])
                        )
                    );
                catch ex: System.FormatException
                yrt
            od

            return result;
        si

        summary(label: string, locations: Iterable[LOCATION_LINE]) -> string is
            let result = System.Text.StringBuilder();

            result.append("{label} ({locations | .count()} locations):\n");

            for location in locations do
                result.append("  {location}\n");
            od

            return result.to_string();
        si

        references(
            analyser: ANALYSER_PROCESS,
            path: string, line: int, column: int
        ) -> LIST[LOCATION_LINE] is
            analyser.send_references(path, line, column);

            let response = analyser.read_query_response();
            Assert.are_equal(
                "REFERENCES",
                response.header,
                "expected REFERENCES response, got '{response.header}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            return parse_locations(response);
        si

        implementations(
            analyser: ANALYSER_PROCESS,
            path: string, line: int, column: int
        ) -> LIST[LOCATION_LINE] is
            analyser.send_implementation(path, line, column);

            let response = analyser.read_query_response();
            Assert.are_equal(
                "IMPLEMENTATION",
                response.header,
                "expected IMPLEMENTATION response, got '{response.header}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            return parse_locations(response);
        si

        // True if `locations` contains an entry whose span starts on the
        // given file and line. The column is not checked — call sites land
        // on the identifier inside the source line and the line is unique
        // enough for the fixture.
        contains_use_on(locations: Iterable[LOCATION_LINE], file: string, line: int) -> bool is
            for location in locations do
                if location.file =~ file /\ location.start_line == line then
                    return true;
                fi
            od

            return false;
        si

        // --- find-references on a trait abstract method --------------------

        // REFERENCES on trait GREETER's abstract `greet` declaration must
        // cover every call site, whether the receiver is statically typed
        // as the trait or as an implementing class.
        // uses.ghul:
        //   line 6:  g1.greet()  (g1: GREETER, FORMAL_GREETER)
        //   line 11: g2.greet()  (g2: GREETER, CASUAL_GREETER)
        //   line 16: f.greet()   (f: FORMAL_GREETER)
        //   line 21: c.greet()   (c: CASUAL_GREETER)
        references_on_trait_abstract_method_covers_trait_and_class_call_sites() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // trait GREETER's `greet()` declaration is greeters.ghul:3.
            let locations = references(analyser, "greeters.ghul", 3, 9);

            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 6),
                summary("trait-typed call g1.greet() (uses.ghul:6) missing from REFERENCES on trait abstract method", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 11),
                summary("trait-typed call g2.greet() (uses.ghul:11) missing from REFERENCES on trait abstract method", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 16),
                summary("class-typed call f.greet() (uses.ghul:16) missing from REFERENCES on trait abstract method", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 21),
                summary("class-typed call c.greet() (uses.ghul:21) missing from REFERENCES on trait abstract method", locations)
            );
        si

        // --- find-references on a trait default method ---------------------

        // REFERENCES on trait GREETER's default `polite_greet` declaration
        // must cover every call site, whether the receiver is statically
        // typed as the trait or as an implementing class. CASUAL_GREETER
        // overrides the default — its call sites must also be included.
        // uses.ghul:
        //   line 7:  g1.polite_greet()  (g1: GREETER, FORMAL_GREETER — inherits default)
        //   line 12: g2.polite_greet()  (g2: GREETER, CASUAL_GREETER — overrides)
        //   line 17: f.polite_greet()   (f: FORMAL_GREETER — inherits default)
        //   line 22: c.polite_greet()   (c: CASUAL_GREETER — overrides)
        references_on_trait_default_method_covers_trait_and_class_call_sites() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // trait GREETER's `polite_greet()` declaration is greeters.ghul:5.
            let locations = references(analyser, "greeters.ghul", 5, 9);

            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 7),
                summary("trait-typed call g1.polite_greet() (uses.ghul:7) missing from REFERENCES on trait default method", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 12),
                summary("trait-typed call g2.polite_greet() (uses.ghul:12) missing from REFERENCES on trait default method", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 17),
                summary("class-typed call f.polite_greet() (uses.ghul:17) missing from REFERENCES on trait default method", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 22),
                summary("class-typed call c.polite_greet() (uses.ghul:22) missing from REFERENCES on trait default method", locations)
            );
        si

        // --- find-references on a trait property ---------------------------

        // REFERENCES on trait GREETER's abstract `name` property must cover
        // every read of the property, regardless of receiver static type.
        // uses.ghul:
        //   line 8:  g1.name   (g1: GREETER, FORMAL_GREETER)
        //   line 13: g2.name   (g2: GREETER, CASUAL_GREETER)
        //   line 18: f.name    (f: FORMAL_GREETER)
        //   line 23: c.name    (c: CASUAL_GREETER)
        references_on_trait_property_covers_trait_and_class_uses() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // trait GREETER's `name` declaration is greeters.ghul:7.
            let locations = references(analyser, "greeters.ghul", 7, 9);

            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 8),
                summary("trait-typed use g1.name (uses.ghul:8) missing from REFERENCES on trait property", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 13),
                summary("trait-typed use g2.name (uses.ghul:13) missing from REFERENCES on trait property", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 18),
                summary("class-typed use f.name (uses.ghul:18) missing from REFERENCES on trait property", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 23),
                summary("class-typed use c.name (uses.ghul:23) missing from REFERENCES on trait property", locations)
            );
        si

        // --- find-references from a call site --------------------------

        // REFERENCES requested on a call site (rather than the trait
        // declaration) must resolve to the same root symbol and return the
        // same complete set of call sites. The trait-typed call at
        // uses.ghul:6 (`g1.greet()`) is the request anchor.
        references_from_trait_typed_call_site_covers_all_call_sites() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // uses.ghul:6 — `Std.write_line(g1.greet());`
            //                                   ^ greet at col 27.
            let locations = references(analyser, "uses.ghul", 6, 27);

            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 6),
                summary("trait-typed call g1.greet() (uses.ghul:6) missing from REFERENCES from trait-typed call site", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 11),
                summary("trait-typed call g2.greet() (uses.ghul:11) missing from REFERENCES from trait-typed call site", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 16),
                summary("class-typed call f.greet() (uses.ghul:16) missing from REFERENCES from trait-typed call site", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 21),
                summary("class-typed call c.greet() (uses.ghul:21) missing from REFERENCES from trait-typed call site", locations)
            );
        si

        // REFERENCES from a class-typed call site must also cover the
        // trait-dispatched call sites — the analyser walks up to the
        // root overridee and back down to every override.
        references_from_class_typed_call_site_covers_all_call_sites() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // uses.ghul:16 — `Std.write_line(f.greet());`
            //                                  ^ greet at col 26.
            let locations = references(analyser, "uses.ghul", 16, 26);

            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 6),
                summary("trait-typed call g1.greet() (uses.ghul:6) missing from REFERENCES from class-typed call site", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 11),
                summary("trait-typed call g2.greet() (uses.ghul:11) missing from REFERENCES from class-typed call site", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 16),
                summary("class-typed call f.greet() (uses.ghul:16) missing from REFERENCES from class-typed call site", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "uses.ghul", 21),
                summary("class-typed call c.greet() (uses.ghul:21) missing from REFERENCES from class-typed call site", locations)
            );
        si

        // --- find-implementations on a trait abstract method ---------------

        // IMPLEMENTATION on trait GREETER's abstract `greet` declaration
        // must return both class implementations.
        // greeters.ghul:
        //   line 13: FORMAL_GREETER.greet
        //   line 21: CASUAL_GREETER.greet
        implementations_on_trait_abstract_method_returns_class_overrides() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            let locations = implementations(analyser, "greeters.ghul", 3, 9);

            Assert.is_true(
                contains_use_on(locations, "greeters.ghul", 13),
                summary("FORMAL_GREETER.greet (greeters.ghul:13) missing from IMPLEMENTATION on trait abstract method", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "greeters.ghul", 21),
                summary("CASUAL_GREETER.greet (greeters.ghul:21) missing from IMPLEMENTATION on trait abstract method", locations)
            );
        si

        // IMPLEMENTATION on a trait default method must return any class
        // override of that default. CASUAL_GREETER overrides
        // `polite_greet`; FORMAL_GREETER inherits the default.
        implementations_on_trait_default_method_returns_class_overrides() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            let locations = implementations(analyser, "greeters.ghul", 5, 9);

            Assert.is_true(
                contains_use_on(locations, "greeters.ghul", 25),
                summary("CASUAL_GREETER.polite_greet (greeters.ghul:25) missing from IMPLEMENTATION on trait default method", locations)
            );
        si

        // IMPLEMENTATION on a trait abstract property must return the
        // class property implementations.
        implementations_on_trait_property_returns_class_overrides() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            let locations = implementations(analyser, "greeters.ghul", 7, 9);

            Assert.is_true(
                contains_use_on(locations, "greeters.ghul", 15),
                summary("FORMAL_GREETER.name (greeters.ghul:15) missing from IMPLEMENTATION on trait property", locations)
            );
            Assert.is_true(
                contains_use_on(locations, "greeters.ghul", 23),
                summary("CASUAL_GREETER.name (greeters.ghul:23) missing from IMPLEMENTATION on trait property", locations)
            );
        si
    si

    struct LOCATION_LINE is
        file: string public;
        start_line: int public;
        start_col: int public;
        end_line: int public;
        end_col: int public;

        init(
            file: string,
            start_line: int, start_col: int,
            end_line: int, end_col: int
        ) is
            self.file = file;
            self.start_line = start_line;
            self.start_col = start_col;
            self.end_line = end_line;
            self.end_col = end_col;
        si

        to_string() -> string =>
            "{file}:{start_line}:{start_col}-{end_line}:{end_col}";
    si
si
