namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Tests state-transitions between the incremental and full-rebuild
    // EDIT paths: interface-preserving → interface-affecting →
    // interface-preserving.
    //
    // The two paths share neither code nor data layout (the incremental
    // path mutates the retained AST and reconciles the location tables;
    // the full-rebuild path calls clear_symbols and rebuilds everything
    // from scratch). Each transition is a chance for leftover state from
    // the previous path to corrupt the next: e.g. a body-spans buffer
    // not cleared on full-rebuild, or a location-correspondence row not
    // dropped, or symbol-definition entries from a now-removed method
    // surviving the recompile.
    //
    // The fixture drives the same file through four versions:
    //
    //   v0 — baseline
    //   v1 — interface-preserving body grow (incremental path)
    //   v2 — interface-affecting: adds a NEW method (full-rebuild path)
    //   v3 — interface-preserving body grow again (incremental path,
    //        but now the retained AST is the one v2 just rebuilt)
    //
    // After each transition we run the full query battery and assert
    // diagnostics-clean + result correctness.
    class INCREMENTAL_MIXED_EDIT_SEQUENCE_TESTS is
        @test()

        init() is si

        // v0 baseline.
        //
        //   1 namespace MixSeq is
        //   2     use Collections.LIST;
        //   3
        //   4     class STORE is
        //   5         _items: LIST[int];
        //   6
        //   7         init() is
        //   8             _items = LIST[int]();
        //   9         si
        //  10
        //  11         size() -> int => _items.count;
        //  12
        //  13         add(n: int) is
        //  14             _items.add(n);
        //  15         si
        //  16
        //  17         clear() is
        //  18             _items = LIST[int]();
        //  19         si
        //  20     si
        //  21
        //  22     use_size(s: STORE) -> int => s.size();
        //  23 si
        v0() -> string =>
            "namespace MixSeq is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    class STORE is\n"
            "        _items: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "\n"
            "        size() -> int => _items.count;\n"
            "\n"
            "        add(n: int) is\n"
            "            _items.add(n);\n"
            "        si\n"
            "\n"
            "        clear() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "    si\n"
            "\n"
            "    use_size(s: STORE) -> int => s.size();\n"
            "si\n";

        // v1 — IP edit: grow `add`'s body by +2 lines. Everything from
        // `clear` onward shifts by +2.
        //
        //   add        line 13 (no shift — its declaration is the edit anchor)
        //   clear       17 → 19
        //   class si    20 → 22
        //   use_size    22 → 24
        v1() -> string =>
            "namespace MixSeq is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    class STORE is\n"
            "        _items: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "\n"
            "        size() -> int => _items.count;\n"
            "\n"
            "        add(n: int) is\n"
            "            let count = _items.count;\n"
            "            let next = count + 1;\n"
            "            _items.add(n);\n"
            "        si\n"
            "\n"
            "        clear() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "    si\n"
            "\n"
            "    use_size(s: STORE) -> int => s.size();\n"
            "si\n";

        // v2 — IA edit: insert a brand-new `peek` method after `add`.
        // This is interface-affecting (a new public member) so the
        // signature classifier forces the full-rebuild path. Lines
        // shift by +2 again because of `peek`:
        //
        //   peek        NEW at line 19
        //   clear       19 → 21
        //   class si    22 → 24
        //   use_size    24 → 26
        v2() -> string =>
            "namespace MixSeq is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    class STORE is\n"
            "        _items: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "\n"
            "        size() -> int => _items.count;\n"
            "\n"
            "        add(n: int) is\n"
            "            let count = _items.count;\n"
            "            let next = count + 1;\n"
            "            _items.add(n);\n"
            "        si\n"
            "\n"
            "        peek() -> int => _items[0];\n"
            "\n"
            "        clear() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "    si\n"
            "\n"
            "    use_size(s: STORE) -> int => s.size();\n"
            "si\n";

        // v3 — IP edit again: grow `clear`'s body by +1. The retained
        // AST being edited is the one v2's full rebuild produced, so
        // this exercises re-entering the incremental path from a
        // freshly-cleared symbol table.
        //
        //   clear      line 21 (no shift)
        //   class si    24 → 25
        //   use_size   26 → 27
        v3() -> string =>
            "namespace MixSeq is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    class STORE is\n"
            "        _items: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "\n"
            "        size() -> int => _items.count;\n"
            "\n"
            "        add(n: int) is\n"
            "            let count = _items.count;\n"
            "            let next = count + 1;\n"
            "            _items.add(n);\n"
            "        si\n"
            "\n"
            "        peek() -> int => _items[0];\n"
            "\n"
            "        clear() is\n"
            "            let was = _items.count;\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "    si\n"
            "\n"
            "    use_size(s: STORE) -> int => s.size();\n"
            "si\n";

        // Diagnostics must stay clean across every transition.
        diagnostics_clean_after_every_edit_in_sequence() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("mix.ghul", v0());
            drain_edit_assert_clean(analyser, "v0 baseline (cold)");

            analyser.send_edit("mix.ghul", v1());
            drain_edit_assert_clean(analyser, "v1 interface-preserving (incremental)");

            analyser.send_edit("mix.ghul", v2());
            drain_edit_assert_clean(analyser, "v2 interface-affecting (full rebuild)");

            analyser.send_edit("mix.ghul", v3());
            drain_edit_assert_clean(analyser, "v3 interface-preserving (incremental again)");
        si

        // DEFINITION on the post-v3 `use_size` body's `s.size()` call.
        // `size` is declared on line 11 in every version (unchanged
        // — above every edit). The query is anchored at v3's
        // `use_size` line 27 col 41 inside `s.size()`. After the full
        // cycle, DEFINITION still returns line 11.
        definition_on_unshifted_target_works_after_full_cycle() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("mix.ghul", v0());
            drain_edit_assert_clean(analyser, "v0");
            analyser.send_edit("mix.ghul", v1());
            drain_edit_assert_clean(analyser, "v1");
            analyser.send_edit("mix.ghul", v2());
            drain_edit_assert_clean(analyser, "v2");
            analyser.send_edit("mix.ghul", v3());
            drain_edit_assert_clean(analyser, "v3");

            // v3 line 27: `    use_size(s: STORE) -> int => s.size();`
            // 4 spaces, `use_size` cols 5-12, `(s: STORE) -> int =>`
            // ends at col 32, ` ` col 33, `s` col 34, `.` col 35,
            // `size` cols 36-39.
            analyser.send_definition("mix.ghul", 27, 37);

            let response = analyser.read_query_response();
            assert isa Response.DEFINITION(response) else "expected DEFINITION response";

            let lines = location_start_lines(response.locations, "mix.ghul");
            Assert.is_true(
                lines.count >= 1,
                "DEFINITION on s.size() returned no locations\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
            Assert.are_equal(
                11,
                lines[0],
                "`size` declared at line 11 throughout the cycle. Got "
                "{lines[0]}.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        // DEFINITION on a target that *did* shift across the cycle.
        // `clear` was line 17 in v0, line 19 in v1, line 21 in v2, line
        // 21 still in v3. We don't query `clear` from a use site (there
        // isn't one) — instead query DEFINITION on `clear` from its own
        // name at v3 line 21 (it returns itself, so the test is really
        // "the symbol's stored location is post-cycle current").
        symbol_self_location_correct_after_full_cycle() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("mix.ghul", v0());
            drain_edit_assert_clean(analyser, "v0");
            analyser.send_edit("mix.ghul", v1());
            drain_edit_assert_clean(analyser, "v1");
            analyser.send_edit("mix.ghul", v2());
            drain_edit_assert_clean(analyser, "v2");
            analyser.send_edit("mix.ghul", v3());
            drain_edit_assert_clean(analyser, "v3");

            // v3 line 21: `        clear() is`
            // 8 spaces, `clear` at cols 9-13.
            analyser.send_definition("mix.ghul", 21, 11);

            let response = analyser.read_query_response();
            assert isa Response.DEFINITION(response) else "expected DEFINITION response";

            let lines = location_start_lines(response.locations, "mix.ghul");
            Assert.is_true(
                lines.count >= 1,
                "DEFINITION on `clear` returned no locations\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
            Assert.are_equal(
                21,
                lines[0],
                "`clear` is at v3 line 21 (after the full cycle). Got "
                "{lines[0]}.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        // SYMBOLS outline after the full cycle: must list each member
        // exactly once at its post-cycle line. After v2 (full rebuild)
        // the outline rebuilds from scratch, so v3's incremental
        // reconciliation operates on a clean baseline — if the v2/v3
        // transition leaked, we'd see duplicates or stale lines.
        symbols_outline_clean_and_current_after_full_cycle() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("mix.ghul", v0());
            drain_edit_assert_clean(analyser, "v0");
            analyser.send_edit("mix.ghul", v1());
            drain_edit_assert_clean(analyser, "v1");
            analyser.send_edit("mix.ghul", v2());
            drain_edit_assert_clean(analyser, "v2");
            analyser.send_edit("mix.ghul", v3());
            drain_edit_assert_clean(analyser, "v3");

            analyser.send_symbols("mix.ghul");

            let response = analyser.read_query_response();
            assert isa Response.SYMBOLS(response) else "expected SYMBOLS response";

            let rows = symbol_rows(response);

            // Distinct check first — duplicates would indicate
            // accumulation across the cycle.
            let distinct = Collections.SET[string]();
            for r in rows do
                distinct.add(symbol_row_key(r));
            od

            Assert.are_equal(
                rows.count,
                distinct.count,
                "outline accumulated duplicate rows across the cycle. "
                "rows:\n{format_rows(rows)}--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );

            // `peek` was added in v2; it must be present (with kind
            // and span correct) after v3.
            assert_row_line(rows, "peek", 19, "peek added in v2 should be on line 19 post-v3", analyser);

            // `clear` is at v3 line 21.
            assert_row_line(rows, "clear", 21, "clear is at v3 line 21", analyser);

            // `use_size` shifted across the cycle to v3 line 27.
            assert_row_line(rows, "use_size", 27, "use_size at v3 line 27", analyser);
        si

        // REFERENCES on a symbol whose call site moved across the
        // cycle. `use_size`'s body has `s.size()` — REFERENCES on
        // `size` (the declaration at line 11, unchanged) should
        // return the one call site at v3 line 27.
        references_correct_after_full_cycle() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("mix.ghul", v0());
            drain_edit_assert_clean(analyser, "v0");
            analyser.send_edit("mix.ghul", v1());
            drain_edit_assert_clean(analyser, "v1");
            analyser.send_edit("mix.ghul", v2());
            drain_edit_assert_clean(analyser, "v2");
            analyser.send_edit("mix.ghul", v3());
            drain_edit_assert_clean(analyser, "v3");

            // line 11 col 11 on `        size() -> int => _items.count;`
            analyser.send_references("mix.ghul", 11, 11);

            let response = analyser.read_query_response();
            assert isa Response.REFERENCES(response) else "expected REFERENCES response";

            let lines = location_start_lines(response.locations, "mix.ghul");

            // Expect exactly one use site, at v3 line 27. The body
            // `=> _items.count` of `size` is *not* a use of `size`
            // itself (recursion-free).
            let on_27 mut = 0;
            for l in lines do
                if l == 27 then on_27 = on_27 + 1; fi
            od
            Assert.are_equal(
                1,
                on_27,
                "REFERENCES should return exactly one use of `size` at "
                "v3 line 27 ({on_27} matches in {line_list_to_string(lines)})\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // ─────────────────────────────────────────────────────────────────
        //   Helpers
        // ─────────────────────────────────────────────────────────────────

        drain_edit_assert_clean(analyser: ANALYSER_PROCESS, label: string) is
            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                "{label}: fixture expected clean — got "
                "{user_diagnostics.count} diagnostics. fixture bug.\n"
                "{diagnostics_summary(label, user_diagnostics)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

        si

        symbol_rows(response: Response.SYMBOLS) -> LIST[Analysis.Protocol.SYMBOL_DTO] is
            let rows = LIST[Analysis.Protocol.SYMBOL_DTO]();
            for file in response.files do
                for s in file.symbols do
                    rows.add(s);
                od
            od
            return rows;
        si

        assert_row_line(rows: LIST[Analysis.Protocol.SYMBOL_DTO], name: string, expected_line: int, label: string, analyser: ANALYSER_PROCESS) is
            for row in rows do
                if row.search_description.contains(name) /\ row.start_line == expected_line then
                    return;
                fi
            od

            Assert.is_true(
                false,
                "no row for '{name}' at line {expected_line} ({label}). rows:\n"
                "{format_rows(rows)}--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        symbol_row_key(s: Analysis.Protocol.SYMBOL_DTO) -> string =>
            "{s.search_description}|{s.kind}|{s.start_line}|{s.start_column}|{s.end_line}|{s.end_column}|{s.qualifier}";

        format_rows(rows: LIST[Analysis.Protocol.SYMBOL_DTO]) -> string is
            let result = System.Text.StringBuilder();
            for r in rows do
                result.append("  ");
                result.append(symbol_row_key(r));
                result.append('\n');
            od
            return result.to_string();
        si

        location_start_lines(locations: Collections.LIST[Analysis.Protocol.LOCATION_DTO], file_name: string) -> LIST[int] is
            let result = LIST[int]();

            for loc in locations do
                if loc.file.ends_with(file_name) then
                    result.add(loc.start_line);
                fi
            od

            return LIST[int](result | .sort((a, b) => a - b));
        si

        line_list_to_string(lines: LIST[int]) -> string is
            let result = System.Text.StringBuilder();
            result.append("[");

            let first mut = true;
            for l in lines do
                if !first then result.append(", "); fi
                result.append("{l}");
                first = false;
            od

            result.append("]");
            return result.to_string();
        si
    si
si
