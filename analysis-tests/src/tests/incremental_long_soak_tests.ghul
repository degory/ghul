namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.RESPONSE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Long-soak coverage for the incremental EDIT path: drive the same
    // file through many successive interface-preserving edits, cycling
    // through variants of different body heights, and assert that
    // semantic-query results don't drift.
    //
    // The shapes this catches that short fixtures miss:
    //
    //   * Slow accumulation — every keystroke adds a stale entry that
    //     the bounded `incremental_query_tests` (≤ 4 edits) doesn't
    //     get up to. After 20+ edits a leak of even one entry per edit
    //     would push counts above the expected total.
    //
    //   * Coordinate drift — if the reconciliation translates by a
    //     wrong delta (rather than reading the donor's real
    //     locations) the error compounds over a long cycle and the
    //     post-cycle line wouldn't match the donor's.
    //
    //   * #SYMBOLS# outline growth — the definition list dedup is
    //     supposed to be O(uses) per edit. If a row leaks every cycle
    //     the outline grows monotonically.
    class INCREMENTAL_LONG_SOAK_TESTS is
        @test()

        init() is si

        // Each variant has identical *interface*: the namespace, the
        // `helper`, the class `WORK` with its members, the
        // namespace-level `use_helper`. Bodies differ only in
        // height. helper() is called exactly 2 times inside `run`'s
        // body and exactly once in `use_helper` — so REFERENCES on
        // helper always returns 3 use sites, regardless of variant.
        //
        // The "above-edit" reference site (`helper` on line 4) is
        // line-stable; below-edit references shift with the variant.

        // 3-line `run` body.
        v_short() -> string =>
            "namespace Soak is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    helper() -> int => 7;\n"
            "\n"
            "    class WORK is\n"
            "        _items: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "\n"
            "        run() -> int is\n"
            "            let a = helper();\n"
            "            let b = helper();\n"
            "            return a + b;\n"
            "        si\n"
            "    si\n"
            "\n"
            "    use_helper() -> int => helper();\n"
            "si\n";

        // 5-line `run` body (+2 vs v_short).
        v_med() -> string =>
            "namespace Soak is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    helper() -> int => 7;\n"
            "\n"
            "    class WORK is\n"
            "        _items: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "\n"
            "        run() -> int is\n"
            "            let a = helper();\n"
            "            let b = helper();\n"
            "            let extra mut = 0;\n"
            "            extra = extra + a;\n"
            "            return extra + b;\n"
            "        si\n"
            "    si\n"
            "\n"
            "    use_helper() -> int => helper();\n"
            "si\n";

        // 7-line `run` body (+4 vs v_short).
        v_long() -> string =>
            "namespace Soak is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    helper() -> int => 7;\n"
            "\n"
            "    class WORK is\n"
            "        _items: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "\n"
            "        run() -> int is\n"
            "            let a = helper();\n"
            "            let b = helper();\n"
            "            let c mut = 0;\n"
            "            let d mut = 0;\n"
            "            c = c + a;\n"
            "            d = d + b;\n"
            "            return c + d;\n"
            "        si\n"
            "    si\n"
            "\n"
            "    use_helper() -> int => helper();\n"
            "si\n";

        // 2-line `run` body (-1 vs v_short). Goes back down so cycle
        // doesn't monotonically grow.
        v_xshort() -> string =>
            "namespace Soak is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    helper() -> int => 7;\n"
            "\n"
            "    class WORK is\n"
            "        _items: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _items = LIST[int]();\n"
            "        si\n"
            "\n"
            "        run() -> int is\n"
            "            let a = helper();\n"
            "            return a + helper();\n"
            "        si\n"
            "    si\n"
            "\n"
            "    use_helper() -> int => helper();\n"
            "si\n";

        // Pick the i'th variant in cycle order.
        variant_at(i: int) -> string is
            let mod = i - (i / 4) * 4;
            if mod == 0 then return v_short(); fi
            if mod == 1 then return v_med(); fi
            if mod == 2 then return v_long(); fi
            return v_xshort();
        si

        // Run the cycle 24 times; every 6th iteration assert
        // REFERENCES on `helper` still returns exactly 3 distinct
        // use-site lines. The above-edit use is line-stable; the two
        // below-edit uses move with the body — they must end up at
        // the variant's coordinates, not at a stale earlier
        // variant's.
        references_count_and_lines_stable_across_24_edits() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            // Cold start.
            analyser.send_edit("soak.ghul", v_short());
            drain_edit_assert_clean(analyser, "v_short cold");

            for i in 1..25 do
                analyser.send_edit("soak.ghul", variant_at(i));
                drain_edit_assert_clean(analyser, "iteration {i}");

                if i - (i / 6) * 6 == 0 then
                    assert_helper_references_correct(analyser, i, variant_at(i));
                fi
            od
        si

        // SYMBOLS outline must not accumulate duplicates across the
        // cycle, and the interface-symbol count (namespace + class +
        // members + namespace-level functions; everything except
        // body locals) must stay constant. Body local count varies
        // by variant — v_short has 2, v_med has 5, v_long has 6,
        // v_xshort has 1 — so total row count varies too, but the
        // interface portion is invariant.
        symbols_outline_no_dupes_and_stable_interface_count_across_24_edits() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("soak.ghul", v_short());
            drain_edit_assert_clean(analyser, "v_short cold");

            analyser.send_symbols("soak.ghul");
            let cold_response = analyser.read_query_response();
            Assert.are_equal("SYMBOLS", cold_response.header);
            let cold_rows = symbol_rows(cold_response);
            let cold_interface = interface_row_count(cold_rows);
            Assert.is_true(cold_interface > 0, "cold SYMBOLS returned no interface rows");

            for i in 1..25 do
                analyser.send_edit("soak.ghul", variant_at(i));
                drain_edit_assert_clean(analyser, "iteration {i}");

                if i - (i / 6) * 6 == 0 then
                    analyser.send_symbols("soak.ghul");
                    let response = analyser.read_query_response();
                    Assert.are_equal("SYMBOLS", response.header);

                    let rows = symbol_rows(response);

                    // Distinct check — duplicates anywhere are bad.
                    let distinct = Collections.SET[string]();
                    for r in rows do distinct.add(r); od
                    Assert.are_equal(
                        rows.count,
                        distinct.count,
                        "iteration {i}: outline accumulated duplicate "
                        "rows. rows:\n{format_rows(rows)}"
                        "--- analyser stderr ---\n{analyser.stderr_capture}"
                    );

                    // Interface count must match cold.
                    let interface_count = interface_row_count(rows);
                    Assert.are_equal(
                        cold_interface,
                        interface_count,
                        "iteration {i}: interface row count drifted "
                        "from cold {cold_interface} to {interface_count}.\n"
                        "rows:\n{format_rows(rows)}"
                        "--- analyser stderr ---\n{analyser.stderr_capture}"
                    );
                fi
            od
        si

        // Count rows that are not body locals. The qualifier column
        // (field 6) of a body local contains the enclosing method
        // — i.e. ends with `.run` for our fixture. Interface symbols
        // have a qualifier that is the namespace, the namespace +
        // class, or empty (the namespace itself).
        interface_row_count(rows: LIST[string]) -> int is
            let count mut = 0;
            for row in rows do
                let fields = LIST[string](row.split(['\t']));
                if fields.count >= 7 /\ !fields[6].ends_with(".run") then
                    count = count + 1;
                fi
            od
            return count;
        si

        // HOVER on `helper` at its declaration site (line 4) — stable
        // across the cycle. Verifies that the line-stable C-region
        // entry survives many reconciliation passes without going
        // stale.
        hover_on_unshifted_declaration_resolves_after_24_edits() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("soak.ghul", v_short());
            drain_edit_assert_clean(analyser, "v_short cold");

            for i in 1..25 do
                analyser.send_edit("soak.ghul", variant_at(i));
                drain_edit_assert_clean(analyser, "iteration {i}");
            od

            // line 4: `    helper() -> int => 7;`
            // 4 spaces, `helper` at cols 5-10.
            analyser.send_hover("soak.ghul", 4, 7);

            let response = analyser.read_query_response();
            Assert.are_equal("HOVER", response.header);

            Assert.is_false(
                hover_body_is_empty(response),
                "HOVER on `helper` declaration returned empty after 24 "
                "edits — the C-region entry was lost or coordinate-"
                "drifted.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        // ─────────────────────────────────────────────────────────────────
        //   Helpers
        // ─────────────────────────────────────────────────────────────────

        // Expected `helper` reference lines for each variant. The
        // helper *declaration* on line 4 is not a use; REFERENCES
        // returns the three call sites.
        expected_helper_lines_for(variant: string) -> LIST[int] is
            // Find the variant by content rather than by parameter
            // tagging — keeps the variant builders self-contained.
            // The two in-body uses are on the two `let a = helper();`
            // / `let b = helper();` lines (cols don't matter here); the
            // third use is in `use_helper`, always on the variant's
            // last namespace line minus 1 (we hard-code it per
            // variant for clarity).
            //
            // Layout per variant (run body starts on line 13):
            //   v_short  : run body 14-16  →  helper uses 14, 15, use_helper 20
            //   v_med    : run body 14-18  →  helper uses 14, 15, use_helper 22
            //   v_long   : run body 14-20  →  helper uses 14, 15, use_helper 24
            //   v_xshort : run body 14-15  →  helper uses 14, 15, use_helper 19

            if variant =~ v_short() then return LIST[int]([14, 15, 20]); fi
            if variant =~ v_med()   then return LIST[int]([14, 15, 22]); fi
            if variant =~ v_long()  then return LIST[int]([14, 15, 24]); fi
            return LIST[int]([14, 15, 19]);
        si

        assert_helper_references_correct(analyser: ANALYSER_PROCESS, iteration: int, variant: string) is
            // Query at line 4 col 7 — the `helper` declaration. The
            // analyser returns the call sites.
            analyser.send_references("soak.ghul", 4, 7);

            let response = analyser.read_query_response();
            Assert.are_equal("REFERENCES", response.header);

            let lines = location_start_lines(response, "soak.ghul");

            Assert.are_equal(
                3,
                lines.count,
                "iteration {iteration}: expected 3 references to "
                "`helper`, got {lines.count}: "
                "{line_list_to_string(lines)}\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let expected = expected_helper_lines_for(variant);
            for line in expected do
                let found mut = false;
                for l in lines do
                    if l == line then
                        found = true;
                    fi
                od
                Assert.is_true(
                    found,
                    "iteration {iteration}: expected reference at line "
                    "{line} not in {line_list_to_string(lines)}\n"
                    "--- analyser stderr ---\n{analyser.stderr_capture}"
                );
            od
        si

        drain_edit_assert_clean(analyser: ANALYSER_PROCESS, label: string) is
            let diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", diagnostics.header);

            let user_diagnostics = LIST(diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                user_diagnostics.count,
                "{label}: fixture expected clean — got "
                "{user_diagnostics.count} diagnostics. fixture bug.\n"
                "{diagnostics_summary(label, user_diagnostics)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", partial_done.header);
        si

        symbol_rows(response: RESPONSE) -> LIST[string] is
            let rows = LIST[string]();
            let seen_path mut = false;

            for line in response.lines do
                if !seen_path then
                    seen_path = true;
                    continue;
                fi
                if string.is_null_or_white_space(line) then
                    continue;
                fi
                rows.add(line);
            od

            return rows;
        si

        format_rows(rows: LIST[string]) -> string is
            let result = System.Text.StringBuilder();
            for r in rows do
                result.append("  ");
                result.append(r);
                result.append('\n');
            od
            return result.to_string();
        si

        hover_body_is_empty(response: RESPONSE) -> bool is
            for line in response.lines do
                if !string.is_null_or_white_space(line) then
                    return false;
                fi
            od
            return true;
        si

        location_start_lines(response: RESPONSE, file_name: string) -> LIST[int] is
            let result = LIST[int]();

            for line in response.lines do
                if string.is_null_or_white_space(line) then
                    continue;
                fi

                let fields = LIST[string](line.split(['\t']));

                if fields.count >= 2 /\ fields[0].ends_with(file_name) then
                    result.add(System.Convert.to_int32(fields[1]));
                fi
            od

            return LIST[int](result | .sort((a, b) => a - b));
        si

        line_list_to_string(lines: LIST[int]) -> string is
            let result = System.Text.StringBuilder();
            result.append("[");

            let first mut = true;
            for l in lines do
                if !first then result.append(", "); fi
                result.append("{l}");
                first = false;
            od

            result.append("]");
            return result.to_string();
        si
    si
si
