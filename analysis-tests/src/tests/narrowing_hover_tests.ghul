namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // HOVER on a local whose type is refined by flow-sensitive
    // narrowing. The narrowed type is observed at the use-site AST
    // node; the symbol's own `type` is restored once the compile
    // walk finishes, so HOVER must read the node, not the symbol.
    // Each test asserts the narrowed type shows at a narrowed use
    // site, and the declared type still shows where unnarrowed.
    class NARROWING_HOVER_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("narrowing-hover/narrowing-hover.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("narrowing-hover.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("narrowing-hover.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.signature? then
                return "";
            fi
            if response.kind_label? then
                return "{response.signature} // {response.kind_label}";
            fi
            return response.signature;
        si

        assert_hover_contains(actual: string, expected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ actual.contains(expected_substring),
                "{where}: expected HOVER to contain '{expected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        assert_hover_excludes(actual: string, forbidden_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_false(
                actual? /\ actual.contains(forbidden_substring),
                "{where}: expected HOVER to exclude '{forbidden_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // `describe(x: object)` — HOVER on the parameter declaration
        // shows the declared type; nothing is narrowed here.
        hover_on_param_decl__shows_declared_object() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 6, 14);
            assert_hover_contains(description, "x: object", "hover on `x` parameter decl", analyser);
        si

        // `return x.length;` inside `if isa string(x)` — HOVER on the
        // narrowed use of `x` shows `string`, not the declared
        // `object`. In-branch narrowing.
        hover_on_narrowed_use_in_isa_branch__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 8, 20);
            assert_hover_contains(description, "► string", "hover on narrowed `x` in isa branch", analyser);
        si

        // `return y.length;` after `if !isa string(y) then return fi`
        // — HOVER on `y` shows `string`. Divergent-guard narrowing.
        hover_on_narrowed_use_after_divergent_guard__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 19, 16);
            assert_hover_contains(description, "► string", "hover on narrowed `y` after divergent guard", analyser);
        si

        // Narrowing a union to a wide complement one-of: the narrowed line
        // is a long `ASSEMBLY_OUTPUT{a|b|c}`, so the pretty printer breaks
        // it one alternative per line under the `►` sigil.
        hover_on_narrowed_union_complement__wraps_the_one_of() is
            @test()

            let source =
                "namespace W is\n"
                "    union AssemblyOutput is\n"
                "        INVALID_ASSEMBLER_OUTPUT;\n"
                "        FILE_ASSEMBLER_OUTPUT;\n"
                "        BUFFER_ASSEMBLER_OUTPUT;\n"
                "        STREAM_ASSEMBLER_OUTPUT;\n"
                "    si\n"
                "    class USER is\n"
                "        init() is si\n"
                "        sink(o: AssemblyOutput) is si\n"
                "        run(x: AssemblyOutput) is\n"
                "            if isa AssemblyOutput.INVALID_ASSEMBLER_OUTPUT(x) then\n"
                "                sink(x);\n"
                "            else\n"
                "                sink(x);\n"
                "            fi\n"
                "        si\n"
                "    si\n"
                "si\n";

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            // Line 15 `                sink(x);` — `x` at column 22, in the
            // else branch where it is narrowed to the 3-variant complement.
            let description = hover_description(analyser, 15, 22);

            assert_hover_contains(description, "► ", "narrowed sigil on the complement line", analyser);
            assert_hover_contains(description, "|\n", "one-of alternatives wrapped one per line", analyser);
        si

        // Concrete-root closed class over an `if let` / `elif let` /
        // `else` chain: the concrete root joins the complement's
        // universe, so the first arm's else narrow is `ANIMAL{ANIMAL|DOG}`.
        // The second arm must eliminate `DOG` from that, leaving the
        // root alone in the final `else` — the earlier narrow must not
        // survive to falsely offer `DOG`.
        hover_on_concrete_root_else__excludes_eliminated_subclass() is
            @test()

            let source =
                "namespace N is\n"
                "    class ANIMAL(name: string);\n"
                "    class CAT(name: string): ANIMAL is\n"
                "        super(name);\n"
                "    si\n"
                "    class DOG(name: string): ANIMAL is\n"
                "        super(name);\n"
                "    si\n"
                "    class USER is\n"
                "        init() is si\n"
                "        describe(a: ANIMAL) -> string =>\n"
                "            if let cat: CAT = a then\n"
                "                \"cat\";\n"
                "            elif let dog: DOG = a then\n"
                "                \"dog\";\n"
                "            else\n"
                "                a.name;\n"
                "            fi;\n"
                "    si\n"
                "si\n";

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            // Line 17 `                a.name;` — `a` at column 17, in the
            // final `else` where both `CAT` and `DOG` are eliminated.
            let description = hover_description(analyser, 17, 17);

            assert_hover_contains(description, "ANIMAL", "hover on `a` in concrete-root else", analyser);
            assert_hover_excludes(description, "DOG", "eliminated subclass in concrete-root else", analyser);
        si

        // Three-arm chain: eliminations accumulate across every arm.
        // Each arm's else complement is computed against the running
        // narrow, so the final `else` must exclude `DOG`, `CAT` and
        // `FISH` together, leaving only the un-eliminated `GECKO`
        // alongside the concrete root.
        hover_on_concrete_root_else__accumulates_every_elimination() is
            @test()

            let source =
                "namespace N is\n"
                "    class ANIMAL(name: string);\n"
                "    class DOG(name: string): ANIMAL is super(name); si\n"
                "    class CAT(name: string): ANIMAL is super(name); si\n"
                "    class FISH(name: string): ANIMAL is super(name); si\n"
                "    class GECKO(name: string): ANIMAL is super(name); si\n"
                "    class USER is\n"
                "        init() is si\n"
                "        describe(a: ANIMAL) -> string =>\n"
                "            if let d: DOG = a then\n"
                "                \"dog\";\n"
                "            elif let c: CAT = a then\n"
                "                \"cat\";\n"
                "            elif let f: FISH = a then\n"
                "                \"fish\";\n"
                "            else\n"
                "                a.name;\n"
                "            fi;\n"
                "    si\n"
                "si\n";

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            // Line 17 `                a.name;` — `a` at column 17, in the
            // final `else` where `DOG`, `CAT` and `FISH` are all gone.
            let description = hover_description(analyser, 17, 17);

            assert_hover_contains(description, "GECKO", "surviving subclass in three-arm else", analyser);
            assert_hover_excludes(description, "DOG", "first eliminated subclass survives to else", analyser);
            assert_hover_excludes(description, "CAT", "second eliminated subclass survives to else", analyser);
            assert_hover_excludes(description, "FISH", "third eliminated subclass survives to else", analyser);
        si
    si
si
