namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // HOVER on positions exercising type inference: inferred local
    // variables, lambda parameters, generic constructor calls, generic
    // global function calls, generic static method calls. Each test
    // asserts that the HOVER description contains the resolved type
    // (BOX[int], string, etc.) rather than a placeholder or the
    // unspecialized generic form.
    //
    // Some of these may surface cases where HOVER doesn't yet show
    // what one would expect. Assertion messages include the actual
    // HOVER response so the gap is visible.
    class INFERENCE_HOVER_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("inference-hover/inference-hover.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            // Multi-file EDIT primes the IDE startup flow, then a
            // single-file EDIT for the active file (the same file).
            // After this both the multi-file walk and the active-file
            // re-parse have completed; HOVER queries land on the
            // freshly-parsed AST.
            analyser.send_edit("inference-hover.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        // Read a HOVER response and return its description. Empty if
        // HOVER had nothing to say.
        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("inference-hover.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.description? then
                return "";
            fi
            return response.description;
        si

        assert_hover_contains(actual: string, expected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ actual.contains(expected_substring),
                "{where}: expected HOVER to contain '{expected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // === Inferred-local variable types ===

        // `let ints = [1, 2, 3]` — HOVER on `ints` should show an
        // array-of-int type. The exact representation may be `int[]`
        // or some equivalent.
        hover_on_inferred_list_var__shows_int_element_type() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 21, 13);
            assert_hover_contains(description, "ints: Ghul.int[]", "hover on `ints`", analyser);
        si

        // `let b = BOX(42)` — HOVER on `b` should show `BOX[int]`
        // (or equivalent) — the constructor's owner type-arg should
        // be inferred from the actual `42`.
        hover_on_inferred_box_int_var__shows_BOX_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 22, 13);
            assert_hover_contains(description, "BOX[Ghul.int]", "hover on `b`", analyser);
        si

        // `let id_str = identity("hello")` — HOVER on `id_str`
        // should show the function-level T inferred to `string`.
        hover_on_generic_function_result_var__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 23, 13);
            assert_hover_contains(description, "id_str: Ghul.string", "hover on `id_str`", analyser);
        si

        // `let pair = make_pair(1, "two")` — HOVER on `pair` should
        // show the named-tuple type with `int` and `string` slots.
        hover_on_generic_function_pair_var__shows_named_tuple() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            // Note: types inside tuple are stringified UNQUALIFIED
            // (`int`, not `Ghul.int`) — diverges from `BOX[Ghul.int]`
            // where the generic-class arg type IS qualified. Probably
            // intentional readability choice for tuple display.
            let description = hover_description(analyser, 24, 13);
            assert_hover_contains(description, "(left: int, right: string)", "hover on `pair`", analyser);
        si

        // `let wrapped = FACTORY.wrap(99)` — HOVER on `wrapped`
        // should show `BOX[int]` — the static method's method-level
        // T inferred from `99`, then its `BOX[T]` return reified.
        hover_on_static_method_result_var__shows_BOX_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 25, 13);
            assert_hover_contains(description, "BOX[Ghul.int]", "hover on `wrapped`", analyser);
        si

        // `let doubled = ints | .map(n => n * 2) .collect();` —
        // HOVER on the lambda parameter `n` (col 35, the parameter
        // declaration) should show `n: int`. The lambda's parameter
        // type is inferred from the `.map`'s formal `(T) -> U`
        // applied to a `Pipe[int]`.
        hover_on_lambda_param_decl__shows_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 26, 35);
            assert_hover_contains(description, "n: Ghul.int", "hover on lambda param `n` decl", analyser);
        si

        // Same lambda — HOVER on the parameter USE in the body
        // (col 40, the `n` in `n * 2`). Same expectation.
        hover_on_lambda_param_use__shows_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 26, 40);
            assert_hover_contains(description, "n: Ghul.int", "hover on lambda param `n` use", analyser);
        si

        // `let nested = BOX(BOX("inner"))` — HOVER on `nested` should
        // show `BOX[BOX[string]]` (or equivalent). Tests that the
        // inner constructor's type-arg propagates up.
        hover_on_nested_generic_var__shows_box_of_box_of_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 27, 13);
            assert_hover_contains(description, "BOX[InferenceHover.BOX[Ghul.string]]", "hover on `nested`", analyser);
        si

        // === HOVER on the constructor/method call sites themselves ===

        // `let b = BOX(42)` — HOVER on `BOX` (col 17, the constructor
        // name at the call site). Expectation: the description shows
        // the specialized form `BOX[int]` (or with `Ghul.int`), since
        // the user is asking "what was this call resolved to?".
        hover_on_constructor_call_BOX__shows_inferred_type_arg() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 22, 17);
            assert_hover_contains(description, "BOX[Ghul.int]", "hover on `BOX` constructor call (T=int)", analyser);
        si

        // `let id_str = identity("hello")` — HOVER on `identity`
        // (col 22). Expectation: shows T=string inferred — either
        // in the signature `identity(x: Ghul.string) -> Ghul.string`
        // or as an explicit `[Ghul.string]` type-arg annotation.
        hover_on_generic_function_call_identity__shows_inferred_type_arg() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 23, 22);
            assert_hover_contains(description, "Ghul.string", "hover on `identity` call (T=string inferred)", analyser);
        si

        // `let wrapped = FACTORY.wrap(99)` — HOVER on `wrap` (col 31,
        // the static method). Expectation: shows T=int inferred —
        // either in the return type `BOX[Ghul.int]` or the argument
        // type `Ghul.int`.
        hover_on_static_method_call_wrap__shows_inferred_type_arg() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 25, 31);
            assert_hover_contains(description, "Ghul.int", "hover on `FACTORY.wrap` static method call (T=int inferred)", analyser);
        si

        // === Let-bound lambda + for-loop variable + destructure ===

        // `let lam = (s: string) => s.length;` — HOVER on `lam` (col
        // 13). Expectation: shows the function type — at minimum
        // both `string` (the param type) and `int` (the body's `.length`
        // return) should appear.
        hover_on_let_bound_lambda__shows_function_type() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 28, 13);
            assert_hover_contains(description, "Ghul.string", "hover on let-bound lambda `lam` (param type)", analyser);
            assert_hover_contains(description, "Ghul.int", "hover on let-bound lambda `lam` (return type)", analyser);
        si

        // `for x in ints do` — HOVER on `x` (col 13). The for-loop
        // variable's type should be inferred from the iterable's
        // element type (Ghul.int from int[]).
        hover_on_for_loop_var__shows_element_type() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 30, 13);
            assert_hover_contains(description, "x: Ghul.int", "hover on for-loop var `x`", analyser);
        si

        // `let two_tuple = (7, "seven");` — HOVER on `two_tuple` (col 13).
        // Expectation: shows the inferred tuple type.
        hover_on_inferred_tuple_var__shows_tuple_type() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 34, 13);
            assert_hover_contains(description, "int", "hover on `two_tuple` (int slot)", analyser);
            assert_hover_contains(description, "string", "hover on `two_tuple` (string slot)", analyser);
        si

        // `let (first_el, second_el) = two_tuple;` — HOVER on
        // `first_el` (col 14). Expectation: type pulled from the
        // tuple's first slot — `Ghul.int`.
        hover_on_destructured_first_element__shows_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 35, 14);
            assert_hover_contains(description, "first_el: Ghul.int", "hover on destructured `first_el`", analyser);
        si

        // Same destructure — HOVER on `second_el` (col 24).
        // Expectation: `Ghul.string` from the tuple's second slot.
        hover_on_destructured_second_element__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 35, 24);
            assert_hover_contains(description, "second_el: Ghul.string", "hover on destructured `second_el`", analyser);
        si

        // === Operators ===

        // `ints | .map(...)` — HOVER on the `|` operator (line 26,
        // col 28). The pipe operator resolves to the namespace-level
        // `pipe[T]` function. Expectation: HOVER shows the resolved
        // `pipe` function qualified under its namespace, tagged as a
        // global function (matching first-party globals), with the
        // synthetic `$globals` IL container hidden.
        hover_on_pipe_operator__shows_resolved_pipe_with_type_arg() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 26, 28);
            assert_hover_contains(description, "Ghul.Pipes.pipe[Ghul.int]", "hover on `|` pipe operator", analyser);
            assert_hover_contains(description, "// global function", "hover on `|` pipe operator", analyser);
            Assert.is_false(
                description.contains("$globals"),
                "hover on `|` pipe operator: expected no `$globals` in HOVER, got '{description}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // `n * 2` inside the lambda — HOVER on `*` (line 26, col 42).
        // Expectation: int multiplication operator description.
        hover_on_multiply_operator__includes_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 26, 42);
            Assert.is_true(
                description? /\ description.length > 0,
                "hover on `*` operator: expected non-empty HOVER, got '{description}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
            assert_hover_contains(description, "int", "hover on `*` int-multiplication", analyser);
        si
    si

    // HOVER over identifiers whose type only resolves through
    // iterative inference — `LIST()` / `MAP()` constructors with no
    // initial type-arg, lambda params constrained from body
    // operations rather than from a formal. The variable's type
    // starts as a placeholder and converges across multiple body
    // walks. HOVER should show the resolved type.
    class INFERENCE_HOVER_ITERATIVE_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("inference-hover-iterative/inference-hover-iterative.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("inference-hover-iterative.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("inference-hover-iterative.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.description? then
                return "";
            fi
            return response.description;
        si

        assert_hover_contains(actual: string, expected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ actual.contains(expected_substring),
                "{where}: expected HOVER to contain '{expected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // `let xs = LIST();` followed by `xs.add(10)` ... — HOVER on
        // `xs` at the declaration should show `LIST[Ghul.int]`,
        // resolved by the later `.add(int)` calls. The classic
        // iterative-inference shape.
        hover_on_iterative_LIST__shows_LIST_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 19, 13);
            assert_hover_contains(description, "LIST[Ghul.int]", "hover on iterative `xs = LIST()`", analyser);
        si

        // `let m = MAP();` followed by `m["alpha"] = 1` ... — HOVER on
        // `m` should show `MAP[Ghul.string, Ghul.int]` resolved from
        // the later indexer-assignment usage.
        hover_on_iterative_MAP__shows_MAP_string_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 24, 13);
            assert_hover_contains(description, "MAP[Ghul.string,Ghul.int]", "hover on iterative `m = MAP()`", analyser);
        si

        // `let big = xs | .filter(p => p > 15) .collect();` —
        // HOVER on the filter's lambda param `p` (col 32 — decl).
        // The param's type resolves from the body's `> 15`
        // (int-comparison binds p to int), not from a formal
        // (filter's formal is `(T) -> bool` where T is the pipe
        // element).
        hover_on_filter_lambda_param_decl__shows_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 28, 32);
            assert_hover_contains(description, "p: Ghul.int", "hover on filter lambda param `p` decl", analyser);
        si

        // Same lambda — `p` used in body (col 37). Same expectation.
        hover_on_filter_lambda_param_use__shows_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 28, 37);
            assert_hover_contains(description, "p: Ghul.int", "hover on filter lambda param `p` use", analyser);
        si

        // `let mapped = xs | .map(n => "{n}!") .collect();` —
        // HOVER on `mapped` should show `Collections.List[Ghul.string]`
        // — the .map's U inferred from the lambda body's string-
        // interpolation result, .collect returning `List[T]` (trait).
        // (`.collect()` returns `List[T]`; `.collect_list()` returns
        // the concrete `LIST[T]`.)
        hover_on_map_to_string_result__shows_List_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 30, 13);
            assert_hover_contains(description, "List[Ghul.string]", "hover on `mapped` (Pipe[U] -> List[U] via .collect)", analyser);
        si

        // `xs | .filter(...)` — HOVER on `xs` at this use site (col 19).
        // The variable's type was inferred from `xs.add(int)` calls
        // (iterative). At HOVER time, that resolution should be
        // complete and shown.
        hover_on_iteratively_typed_var_at_use_site__shows_LIST_int() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 28, 19);
            assert_hover_contains(description, "LIST[Ghul.int]", "hover on `xs` at use site (post-iteration)", analyser);
        si
    si
si
