namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.HOVER_ENTRY;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // The synthesised entry that wraps a file's top-level statements has no
    // user-visible declaration site: its identifier carries an internal
    // location so it records no hover use spanning the statement region.
    // Without that, a hover on any non-symbol position between the
    // statements fell through to the entry's whole-file span and reported
    // `entry() -> void` — cosmetically wrong for a function the source
    // never names.
    class TOP_LEVEL_ENTRY_HOVER_TESTS is
        @test()

        init() is si

        load_source() -> string is
            let path = fixture_path("top-level-entry-hover/top-level-entry-hover.ghul");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("top-level-entry-hover.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        // A blank line sits inside the statement region the entry wraps.
        // Hovering there must not surface the synthesised entry.
        hover_on_blank_line_does_not_surface_entry() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load_source());

            analyser.send_hover("top-level-entry-hover.ghul", 5, 1);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";

            let hover = cast Response.HOVER(response);

            // The synthesised entry is the only symbol whose span covers a
            // blank line, so before the fix this reported it as a global
            // function. Any real symbol here would be a different kind.
            Assert.is_false(
                hover.kind_label? /\ hover.kind_label.contains("global function"),
                "hover on a blank line surfaced the synthesised entry: '{hover.signature}' // {hover.kind_label}"
            );
        si

        // The whole-file hover dump carries one entry per real symbol and
        // none for the synthesised entry function.
        hover_map_has_no_entry_for_synthesised_entry() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load_source());

            analyser.send_hover_map("top-level-entry-hover.ghul");

            let response = analyser.read_query_response();
            assert isa Response.HOVER_MAP(response) else "expected HOVER_MAP response";

            let entries = LIST[HOVER_ENTRY]((cast Response.HOVER_MAP(response)).entries);

            for entry in entries do
                Assert.is_false(
                    entry.kind_label? /\ entry.kind_label.contains("global function"),
                    "hover map carried a global-function entry for the synthesised top-level entry: [{entry.start_line},{entry.start_column}..{entry.end_line},{entry.end_column}] {entry.description}"
                );
            od
        si
    si
si
