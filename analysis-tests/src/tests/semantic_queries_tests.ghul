namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Probes that VSCE semantic queries (HOVER, DEFINITION) work on the
    // canonical IDE flow: initial multi-file EDIT primes both files, then
    // a single-file EDIT for the file the user is "active in", then the
    // semantic query on that same active file targeting a symbol whose
    // definition lives in the *other* (retained-AST) file.
    //
    // For the test to be fair, the most-recent EDIT must be for the same
    // file as the HOVER / DEFINITION — that's what the IDE actually does.
    class SEMANTIC_QUERIES_TESTS is
        @test()

        init() is si

        load_fixture() -> (main_source: string, greeter_source: string) is
            let dir = fixture_dir("cross-file-greeter");
            let main_path = Path.combine(dir, "main.ghul");
            let greeter_path = Path.combine(dir, "greeter.ghul");

            assert File.exists(main_path) else "fixture missing: {main_path}";
            assert File.exists(greeter_path) else "fixture missing: {greeter_path}";

            return (
                File.read_all_text(main_path),
                File.read_all_text(greeter_path)
            );
        si

        prime_and_edit(analyser: ANALYSER_PROCESS, main_source: string, greeter_source: string) is
            // Mimic IDE startup: one multi-file EDIT for every discovered
            // source file. Drain the response (DIAGNOSTICS, PARTIAL DONE).
            analyser.send_edit_files([
                EDIT_FILE("main.ghul", main_source),
                EDIT_FILE("greeter.ghul", greeter_source)
            ]);

            let initial_diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", initial_diagnostics.header);

            let initial_user_diagnostics = LIST(initial_diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                initial_user_diagnostics.count,
                diagnostics_summary("initial multi-file EDIT had unexpected diagnostics", initial_user_diagnostics)
            );

            let initial_partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", initial_partial_done.header);

            // Mimic the user typing in main.ghul: single-file EDIT for that
            // file alone. This re-parses main.ghul; greeter.ghul's AST is
            // retained. The subsequent HOVER / DEFINITION targets main.ghul
            // (the active file).
            analyser.send_edit("main.ghul", main_source);

            let edit_diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", edit_diagnostics.header);

            let edit_user_diagnostics = LIST(edit_diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                edit_user_diagnostics.count,
                diagnostics_summary("single-file EDIT after initial had unexpected diagnostics", edit_user_diagnostics)
            );

            let edit_partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", edit_partial_done.header);
        si

        // main.ghul:
        //   line 5: `        let g = GREETER();`
        //                            ^ GREETER starts at col 17 (1-based)
        //   line 6: `        Std.write_line(g.greet());`
        //                                     ^ greet starts at col 27 (1-based)
        hover_on_greeter_class_use_in_main_should_return_description() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime_and_edit(analyser, main_source, greeter_source);

            // HOVER on GREETER (column inside the identifier — col 18, in the
            // middle of GREETER which spans cols 17–23 of line 5).
            analyser.send_hover("main.ghul", 5, 18);

            let hover_response = analyser.read_query_response();
            Assert.are_equal("HOVER", hover_response.header);

            let hover_lines = LIST[string](hover_response.lines);
            Assert.is_true(
                hover_lines.count > 0 /\ !string.is_null_or_white_space(hover_lines[0]),
                "HOVER on GREETER returned empty body. lines: {hover_lines.count}, first: '{if hover_lines.count > 0 then hover_lines[0] else "(none)" fi}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        definition_on_greeter_class_use_in_main_should_point_at_greeter_file() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime_and_edit(analyser, main_source, greeter_source);

            // DEFINITION on GREETER (line 5, col 18 of main.ghul).
            analyser.send_definition("main.ghul", 5, 18);

            let definition_response = analyser.read_query_response();
            Assert.are_equal("DEFINITION", definition_response.header);

            let definition_lines = LIST[string](definition_response.lines);
            Assert.are_equal(
                1,
                definition_lines.count,
                "DEFINITION on GREETER expected exactly one location, got {definition_lines.count}.\nlines: {definition_lines}\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            // Location format: <uri>\t<startLine>\t<startCol>\t<endLine>\t<endCol>
            // We expect the URI to end with greeter.ghul (the file with the
            // class definition).
            let location = definition_lines[0];
            Assert.is_true(
                location.contains("greeter.ghul"),
                "DEFINITION on GREETER expected to point at greeter.ghul, got: '{location}'"
            );
        si

        hover_on_greet_method_call_in_main_should_work_after_compile() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime_and_edit(analyser, main_source, greeter_source);

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", compile_diagnostics.header);

            let compile_full_done = analyser.read_response();
            Assert.are_equal("FULL DONE", compile_full_done.header);

            analyser.send_hover("main.ghul", 6, 27);

            let hover_response = analyser.read_query_response();
            Assert.are_equal("HOVER", hover_response.header);

            let hover_lines = LIST[string](hover_response.lines);
            Assert.is_true(
                hover_lines.count > 0 /\ !string.is_null_or_white_space(hover_lines[0]),
                "HOVER on greet after COMPILE returned empty body — CLEAR_AST_STATE may be over-clearing state HOVER needs.\nlines: {hover_lines.count}, first: '{if hover_lines.count > 0 then hover_lines[0] else "(none)" fi}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        hover_on_greet_method_call_in_main_should_return_description() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime_and_edit(analyser, main_source, greeter_source);

            // HOVER on greet (line 6, cols 26–30 of main.ghul; targeting
            // col 27 — inside the identifier).
            analyser.send_hover("main.ghul", 6, 27);

            let hover_response = analyser.read_query_response();
            Assert.are_equal("HOVER", hover_response.header);

            let hover_lines = LIST[string](hover_response.lines);
            Assert.is_true(
                hover_lines.count > 0 /\ !string.is_null_or_white_space(hover_lines[0]),
                "HOVER on greet method call returned empty body. lines: {hover_lines.count}, first: '{if hover_lines.count > 0 then hover_lines[0] else "(none)" fi}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
