namespace Analysis.Tests is
    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Cross-file semantic queries: HOVER and DEFINITION spanning two files.
    // The fixture is a `main.ghul` that uses a `GREETER` class from
    // `greeter.ghul`; both are sent in one multi-file EDIT.
    class SEMANTIC_QUERIES_TESTS is
        @test()

        init() is si

        load(name: string) -> string is
            let path = Path.combine(fixture_dir("cross-file-greeter"), name);
            assert File.exists(path) else "fixture missing: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS) is
            let main_source = load("main.ghul");
            let greeter_source = load("greeter.ghul");

            analyser.send_edit_files([
                EDIT_FILE("main.ghul", main_source),
                EDIT_FILE("greeter.ghul", greeter_source)
            ]);

            let initial = analyser.read_response();
            assert isa Response.DIAGNOSTICS(initial) else "expected diagnostics on prime";
        si

        hover_on_cross_file_class_use_returns_description() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_hover("main.ghul", 5, 18);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";

            Assert.is_true(
                response.description? /\ response.description.length > 0,
                "HOVER on GREETER use returned nothing"
            );

            Assert.is_true(
                response.description.contains("GREETER"),
                "HOVER on GREETER use should mention GREETER, got: {response.description}"
            );
        si

        definition_on_cross_file_class_use_points_at_greeter() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_definition("main.ghul", 5, 18);

            let response = analyser.read_query_response();
            assert isa Response.DEFINITION(response) else "expected DEFINITION response";

            Assert.is_true(
                response.locations.count > 0,
                "DEFINITION on GREETER use returned no location"
            );

            Assert.is_true(
                response.locations[0].file.contains("greeter.ghul"),
                "DEFINITION should point at greeter.ghul, got: {response.locations[0].file}"
            );
        si

        hover_on_local_in_main_returns_type() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_hover("main.ghul", 5, 13);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";

            Assert.is_true(
                response.description? /\ response.description.length > 0,
                "HOVER on local returned nothing"
            );
        si

        definition_within_same_file_resolves() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_definition("main.ghul", 6, 28);

            let response = analyser.read_query_response();
            assert isa Response.DEFINITION(response) else "expected DEFINITION response";

            Assert.is_true(
                response.locations.count > 0,
                "DEFINITION within same file returned no location"
            );
        si

        hover_on_method_call_returns_signature() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_hover("main.ghul", 6, 30);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";

            Assert.is_true(
                response.description? /\ response.description.length > 0,
                "HOVER on method call returned nothing"
            );
        si

        symbols_for_file_lists_top_level_definitions() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser);

            analyser.send_symbols("greeter.ghul");

            let response = analyser.read_query_response();
            assert isa Response.SYMBOLS(response) else "expected SYMBOLS response";

            Assert.is_true(
                response.files.count > 0,
                "SYMBOLS for greeter.ghul returned nothing"
            );
        si
    si
si
