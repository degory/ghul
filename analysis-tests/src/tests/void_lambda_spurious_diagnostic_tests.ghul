namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Regression for the spurious "cannot use void value here" diagnostic
    // analysis mode reports on a void-returning expression-bodied lambda
    // whose body is itself a void call (e.g. `t => on_complete(t);`).
    //
    // The compile path masks it: when want_assembler is true,
    // compile_lambdas.ghul:278 re-walks the lambda body after
    // closure.convert_to_delegate(), with a _logger.roll_back() between
    // walks that discards the first walk's diagnostic. Analysis mode runs
    // with want_assembler false so the first-walk diagnostic survives.
    class VOID_LAMBDA_SPURIOUS_DIAGNOSTIC_TESTS is
        @test()

        init() is si

        load_source() -> string is
            let path = fixture_path("void-lambda-spurious-diagnostic/void-lambda-spurious-diagnostic.ghul");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        edit_should_not_report_void_diagnostic_on_void_returning_lambda() is
            @test()

            let source = load_source();
            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("void-lambda-spurious-diagnostic.ghul", source);

            let edit_diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit_diagnostics) else "expected DIAGNOSTICS response";

            let edit_user = LIST[DIAGNOSTIC](user_diagnostics_of(edit_diagnostics));
            Assert.are_equal(
                0,
                edit_user.count,
                "{diagnostics_summary(
                    "EDIT response had spurious diagnostics — void-returning "
                    "expression-bodied lambda whose body is a void call should "
                    "not produce \"cannot use void value here\"",
                    edit_user
                )}\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
