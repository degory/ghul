namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Smoke / happy-path coverage for the analyser's protocol commands beyond
    // HOVER/DEFINITION (which are exercised by SEMANTIC_QUERIES_TESTS).
    //
    // For each command, prime the analyser with the cross-file-greeter fixture
    // (initial multi-file EDIT + single-file EDIT for main.ghul), send the
    // command at a known-good position, and assert the response kind is correct
    // and the body looks plausible. These are smoke tests: they catch
    // regressions where a command stops responding, returns the wrong response
    // kind, or returns nothing at all.
    class COMMAND_HAPPY_PATH_TESTS is
        @test()

        init() is si

        load_fixture() -> (main_source: string, greeter_source: string) is
            let dir = fixture_dir("cross-file-greeter");
            let main_path = Path.combine(dir, "main.ghul");
            let greeter_path = Path.combine(dir, "greeter.ghul");

            assert File.exists(main_path) else "fixture missing: {main_path}";
            assert File.exists(greeter_path) else "fixture missing: {greeter_path}";

            return (
                File.read_all_text(main_path),
                File.read_all_text(greeter_path)
            );
        si

        prime(analyser: ANALYSER_PROCESS, main_source: string, greeter_source: string) is
            analyser.send_edit_files([
                EDIT_FILE("main.ghul", main_source),
                EDIT_FILE("greeter.ghul", greeter_source)
            ]);

            let initial_diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", initial_diagnostics.kind);

            let initial_user_diagnostics = LIST(initial_diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                initial_user_diagnostics.count,
                diagnostics_summary("initial multi-file EDIT had unexpected diagnostics", initial_user_diagnostics)
            );

            analyser.send_edit("main.ghul", main_source);

            let edit_diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", edit_diagnostics.kind);
        si

        // DECLARATION on a use of GREETER (main.ghul:5:18) should return a
        // location pointing at greeter.ghul.
        declaration_on_greeter_use_should_return_definition_location() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_declaration("main.ghul", 5, 18);

            let response = analyser.read_query_response();
            Assert.are_equal("declaration", response.kind);

            Assert.is_true(
                response.locations.count > 0,
                "DECLARATION on GREETER returned no locations\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // REFERENCES on the GREETER class definition (greeter.ghul:2:11)
        // should return at least the use site in main.ghul.
        references_on_greeter_class_definition_should_return_uses() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", compile_diagnostics.kind);

            // REFERENCES on GREETER class definition (greeter.ghul:2:11).
            analyser.send_references("greeter.ghul", 2, 11);

            let response = analyser.read_query_response();
            Assert.are_equal("references", response.kind);

            Assert.is_true(
                response.locations.count > 0,
                "REFERENCES on GREETER class returned no locations\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // TYPEDEFINITION on a value of class type should return the class
        // definition's location. `g` on main.ghul:5:13 is the binding of
        // a `GREETER` value; the type's definition is in greeter.ghul.
        type_definition_on_greeter_variable_should_return_class_location() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", compile_diagnostics.kind);

            analyser.send_type_definition("main.ghul", 5, 13);

            let response = analyser.read_query_response();
            Assert.are_equal("type_definition", response.kind);

            Assert.is_true(
                response.locations.count > 0,
                "TYPEDEFINITION on g returned no locations\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.is_true(
                response.locations[0].file.contains("greeter.ghul"),
                "TYPEDEFINITION on g should point at greeter.ghul, got: {response.locations[0].file}\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // IMPLEMENTATION on a class definition should return at least its
        // own location.
        implementation_on_greeter_class_definition_should_respond() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", compile_diagnostics.kind);

            analyser.send_implementation("greeter.ghul", 2, 11);

            let response = analyser.read_query_response();
            Assert.are_equal("implementation", response.kind);
        si

        // SYMBOLS on a file path returns its top-level symbols.
        symbols_on_greeter_file_should_return_class_entry() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_symbols("greeter.ghul");

            let response = analyser.read_query_response();
            Assert.are_equal("symbols", response.kind);

            Assert.is_true(
                response.files.count > 0,
                "SYMBOLS on greeter.ghul returned no files\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // COMPLETE at a member-access position should return at least one
        // candidate. main.ghul:6:28 is just after `g.` on the call site.
        completion_at_member_access_should_return_candidates() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_completion("main.ghul", 6, 28);

            let response = analyser.read_query_response();
            Assert.are_equal("completion", response.kind);
        si

        // SIGNATURE at a position inside a call should respond with the
        // signature response. The call site `g.greet(` ends at main.ghul:6,33;
        // we point at col 33 (between `(` and `)`).
        signature_at_call_site_should_respond() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_signature("main.ghul", 6, 33);

            let response = analyser.read_query_response();
            Assert.are_equal("signature", response.kind);
        si

        // RENAME checks whether a symbol can be renamed at a given position.
        // Sending a request on the GREETER use should produce a rename response.
        rename_request_on_greeter_use_should_respond() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", compile_diagnostics.kind);

            analyser.send_rename_request("main.ghul", 5, 18, "RENAMED_GREETER");

            let response = analyser.read_query_response();
            Assert.are_equal("rename", response.kind);
        si

        // heap_check asks the analyser to sample the heap. A small clean
        // fixture is nowhere near the recycle threshold, so the analyser
        // answers with a heap_check response rather than recycling.
        heap_check_should_respond() is
            @test()

            let (main_source, greeter_source) = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, main_source, greeter_source);

            analyser.send_heap_check();

            let response = analyser.read_response();
            Assert.are_equal("heap_check", response.kind);
        si
    si
si
