namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // HOVER on a local whose right-hand side has a no-arg generic
    // variant constructor (NIL/DONE-style) nested inside a concrete-
    // sibling-binding generic constructor (CONS-style). Pin that the
    // phantom origin for the no-arg variant's owner type-arg is
    // resolved by the LUB merge through the union ancestor and that
    // analysis-mode HOVER renders the resolved type rather than the
    // placeholder marker.
    class NOARG_VARIANT_INFERENCE_HOVER_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("noarg-variant-inference-hover/noarg-variant-inference-hover.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("noarg-variant-inference-hover.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("noarg-variant-inference-hover.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.description? then
                return "";
            fi
            return response.description;
        si

        assert_hover_contains(actual: string, expected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ actual.contains(expected_substring),
                "{where}: expected HOVER to contain '{expected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // line 22:         let list = CONS(elements[0], CONS(elements[1], CONS(elements[2], NIL())));
        //                      ^col 13 (the `list` identifier)
        hover_on_list_in_generic_function__shows_resolved_cons_t() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 22, 13);
            assert_hover_contains(description, "List.CONS[T]", "hover on `list`", analyser);
        si

        // Hover on the no-arg variant constructor (NIL) inside the
        // nested CONS chain — its owner type-arg should render as `T`
        // (the surrounding function's type parameter), not the `***`
        // placeholder marker.
        //
        // line 22: ...CONS(elements[2], NIL())));
        //                                ^col 74 (the NIL identifier)
        hover_on_nil_in_cons_chain__shows_resolved_t() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 22, 74);

            // The HOVER for the NIL call site renders as the variant
            // constructor's init with its specialised owner. With the
            // LUB back-feed fix, the owner type-arg resolves to T
            // rather than rendering `***`.
            assert_hover_contains(description, "List.NIL[T]", "hover on NIL() call site", analyser);
            Assert.is_false(
                description.contains("***"),
                "hover description should not contain the `***` placeholder marker; got: '{description}'"
            );
        si
    si
si
