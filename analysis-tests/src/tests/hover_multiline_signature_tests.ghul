namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Long-parameter signatures wrap in the hover response: the
    // arg list breaks onto per-argument lines instead of one wide
    // line, using the compiler's DOC layout engine.
    class HOVER_MULTILINE_SIGNATURE_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("hover-multiline-signature/hover-multiline-signature.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("hover-multiline-signature.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        hover_on_long_signature_call__is_broken_onto_multiple_lines() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            // Line 15 col 13: the `compile_expression_with_context` call site
            // inside `driver`. Both fixture and this constant use the same
            // 1-based coordinates the wire protocol carries.
            analyser.send_hover("hover-multiline-signature.ghul", 15, 13);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";

            let signature = response.signature ?? "";

            Assert.is_true(
                signature.contains("\n"),
                "hover on the long-parameter call site should wrap: "
                "signature contains no newline. got:\n---\n{signature}\n---"
            );
            Assert.is_true(
                signature.contains("context: string,\n"),
                "expected each parameter on its own line; got:\n---\n{signature}\n---"
            );
            Assert.is_true(
                signature.contains("\n) -> int"),
                "expected the return type to sit after the closing paren; "
                "got:\n---\n{signature}\n---"
            );

            // The classifier travels out-of-band. Instance methods
            // classify as `method`; the store-free analysis may have
            // promoted this one to `pure method`. Either is fine — the
            // point is that the label survived the split.
            let label = response.kind_label ?? "";
            Assert.is_true(
                label =~ "method" \/ label =~ "pure method",
                "expected the classifier to travel out-of-band as "
                "kind_label; got: '{label}'"
            );
        si
    si
si
