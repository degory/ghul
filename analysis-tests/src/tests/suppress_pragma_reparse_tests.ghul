namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // `@suppress("<code>")` regions are collected per source file by
    // COLLECT_SUPPRESS_PRAGMAS, which clears the file's prior regions
    // before re-walking. On an analyse-mode EDIT the pass clears the
    // bucket keyed by the actual file path, so adding *and* removing a
    // suppression must both take effect on the next response. Pinning
    // that here as a three-step EDIT sequence — warn / suppressed /
    // warn-restored — over a `throw 12345` which raises the
    // `non-exception-throw` warning.
    class SUPPRESS_PRAGMA_REPARSE_TESTS is
        @test()

        init() is si

        without_pragma: string =>
            "namespace SuppressReparse is\n"
            "    entry() is\n"
            "        throw 12345;\n"
            "    si\n"
            "si\n";

        with_pragma: string =>
            "namespace SuppressReparse is\n"
            "    @suppress(\"non-exception-throw\")\n"
            "    entry() is\n"
            "        throw 12345;\n"
            "    si\n"
            "si\n";

        has_non_exception_throw(response: Response) -> bool is
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response";

            let user = LIST[DIAGNOSTIC](user_diagnostics_of(cast Response.DIAGNOSTICS(response)));

            for d in user do
                if d.code? /\ d.code =~ "non-exception-throw" then
                    return true;
                fi
            od

            return false;
        si

        suppress_then_unsuppress_restores_warning() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("suppress-reparse.ghul", without_pragma);
            Assert.is_true(
                has_non_exception_throw(analyser.read_response()),
                "warning missing on first EDIT without @suppress"
            );

            analyser.send_edit("suppress-reparse.ghul", with_pragma);
            Assert.is_false(
                has_non_exception_throw(analyser.read_response()),
                "warning not suppressed after EDIT adds @suppress"
            );

            analyser.send_edit("suppress-reparse.ghul", without_pragma);
            Assert.is_true(
                has_non_exception_throw(analyser.read_response()),
                "warning stayed suppressed after EDIT removed @suppress"
            );
        si
    si
si
