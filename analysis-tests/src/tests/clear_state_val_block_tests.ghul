namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Regression marker for the CLEAR_STATE_VISITOR coverage hole on
    // Expressions.VAL_BLOCK. StrictVisitor.pre(VAL_BLOCK) throws by
    // design; without an explicit override on CLEAR_STATE_VISITOR the
    // re-walk of any retained AST containing a `val ... lav` block
    // blows up on the second compile. The exception is caught and
    // logged as `FULL_COMPILE caught: ...` on analyser stderr; the
    // downstream HOVER / completion / definition responses come back
    // without the data they should have. Same shape as the AWAIT /
    // SPILL regression #1408 introduced.
    class CLEAR_STATE_VAL_BLOCK_TESTS is
        @test()

        init() is si

        load_source() -> string is
            let path = fixture_path("clear-state-val-block/clear-state-val-block.ghul");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("clear-state-val-block.ghul", source);

            let edit_diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit_diagnostics) else "expected DIAGNOSTICS response";
        si

        // HOVER on a no-symbol position (column 1 of `namespace`) falls
        // through to FULL_COMPILER.compile_all, which runs
        // CLEAR_STATE_VISITOR over every source file's AST. On a file
        // with a VAL_BLOCK node that visit throws unless an explicit
        // pre override is in place.
        hover_after_edit_should_not_choke_on_val_block() is
            @test()

            let source = load_source();
            let use analyser = ANALYSER_PROCESS();

            prime(analyser, source);

            analyser.send_hover("clear-state-val-block.ghul", 1, 1);

            let hover_response = analyser.read_query_response();
            assert isa Response.HOVER(hover_response) else "expected hover response after HOVER's compile_all, got '{hover_response.get_type().name}'";

            let stderr = analyser.stderr_capture;
            Assert.is_false(
                stderr.contains("does not define a visit method"),
                "analyser stderr surfaced a missing StrictVisitor override across HOVER's compile_all on a file with a val ... lav block:\n--- analyser stderr ---\n{stderr}"
            );
        si
    si
si
