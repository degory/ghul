namespace Analysis.Tests is
    use System.Exception;

    use IO.Directory;
    use IO.Path;

    use Collections.LIST;
    use Collections.SET;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.CORPUS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.RENAME_EDIT;
    use Analysis.Protocol.RESPONSE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Semantic-lookup regression guards for the incremental body re-walk.
    //
    // The rest of the analysis suite queries HOVER / DEFINITION /
    // REFERENCES / etc. only after a *single cold* EDIT — a full rebuild.
    // The incremental path runs on the *second and later* EDIT, and the
    // #1347 regression lived exactly there: the location side-tables
    // accumulated stale entries and the retained interface kept pre-edit
    // coordinates, so find-references returned duplicates and DEFINITION
    // landed on the wrong line. No test exercised a lookup after an
    // incremental edit, so nothing caught it.
    //
    // These tests do cold-EDIT -> incremental-EDIT(s) -> query, and assert
    // the query result is correct: exact, current-coordinate, duplicate-
    // free. Each fails against the unfixed incremental path.
    class INCREMENTAL_QUERY_TESTS is
        @test()

        init() is si

        // --- core fixture: `helper` defined among methods, called twice -----
        //
        // `alpha`'s body is grown / shrunk across editions; `helper` and
        // its two call sites (in `beta` and `gamma`) shift with it. Every
        // edition has the identical interface, so each edit is
        // interface-preserving and takes the incremental path.

        // alpha body 1 line — helper at line 6, calls at 9 and 13.
        q_v0() -> string =>
            "namespace IQ is\n"
            "    alpha() -> int is\n"
            "        return 1;\n"
            "    si\n"
            "\n"
            "    helper() -> int => 2;\n"
            "\n"
            "    beta() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "\n"
            "    gamma() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "si\n";

        // alpha body 3 lines — helper at line 8, calls at 11 and 15.
        q_v1() -> string =>
            "namespace IQ is\n"
            "    alpha() -> int is\n"
            "        let a = 1;\n"
            "        let b = 2;\n"
            "        return a + b;\n"
            "    si\n"
            "\n"
            "    helper() -> int => 2;\n"
            "\n"
            "    beta() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "\n"
            "    gamma() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "si\n";

        // alpha body 5 lines — helper at line 10, calls at 13 and 17.
        q_v2() -> string =>
            "namespace IQ is\n"
            "    alpha() -> int is\n"
            "        let a = 1;\n"
            "        let b = 2;\n"
            "        let c = 3;\n"
            "        let d = 4;\n"
            "        return a + b + c + d;\n"
            "    si\n"
            "\n"
            "    helper() -> int => 2;\n"
            "\n"
            "    beta() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "\n"
            "    gamma() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "si\n";

        // alpha body 2 lines — helper at line 7, calls at 10 and 14.
        q_v3() -> string =>
            "namespace IQ is\n"
            "    alpha() -> int is\n"
            "        let a = 1;\n"
            "        return a;\n"
            "    si\n"
            "\n"
            "    helper() -> int => 2;\n"
            "\n"
            "    beta() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "\n"
            "    gamma() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "si\n";

        // alpha body content changed but line count unchanged — nothing
        // shifts. The re-walk still re-records every body; on the unfixed
        // path the re-recorded entries land at the *same* coordinates as
        // the stale ones, so a duplicate-free check still catches it.
        q_v0_changed() -> string =>
            "namespace IQ is\n"
            "    alpha() -> int is\n"
            "        return 9;\n"
            "    si\n"
            "\n"
            "    helper() -> int => 2;\n"
            "\n"
            "    beta() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "\n"
            "    gamma() -> int is\n"
            "        return helper();\n"
            "    si\n"
            "si\n";

        // find-references after three successive line-shifting incremental
        // edits. The unfixed path re-records `helper`'s body call sites on
        // every edit without dropping the previous recording, so the
        // reference set accumulates; here it must hold exactly the two
        // current call sites.
        find_references_survives_repeated_line_shifting_edits() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            apply_edit(analyser, "q.ghul", q_v0());
            apply_edit(analyser, "q.ghul", q_v1());
            apply_edit(analyser, "q.ghul", q_v2());
            apply_edit(analyser, "q.ghul", q_v3());

            // q_v3 — `        return helper();` in `gamma`, line 14;
            // `helper` spans columns 16-21.
            analyser.send_references("q.ghul", 14, 18);

            let response = analyser.read_query_response();
            Assert.are_equal("REFERENCES", response.header);

            let lines = location_start_lines(response, "q.ghul");

            Assert.are_equal(
                2,
                lines.count,
                "find-references on `helper` should return its two current "
                "call sites; got {lines.count} ({lines}) — stale references "
                "accumulated across the edits.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
            Assert.are_equal(10, lines[0], "first call site (beta), q_v3 line 10");
            Assert.are_equal(14, lines[1], "second call site (gamma), q_v3 line 14");
        si

        // DEFINITION must keep landing on `helper`'s current declaration
        // line as repeated edits move it. `helper` is a retained interface
        // symbol below an edited body — its definition location is
        // reconciled each edit, and must stay correct, not drift.
        definition_target_stays_current_across_repeated_edits() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            apply_edit(analyser, "q.ghul", q_v0());
            apply_edit(analyser, "q.ghul", q_v1());
            apply_edit(analyser, "q.ghul", q_v2());
            apply_edit(analyser, "q.ghul", q_v3());

            analyser.send_definition("q.ghul", 14, 18);

            let response = analyser.read_query_response();
            Assert.are_equal("DEFINITION", response.header);

            let lines = location_start_lines(response, "q.ghul");

            Assert.are_equal(
                1,
                lines.count,
                "DEFINITION on the `helper()` call expected one location, "
                "got {lines.count}.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
            Assert.are_equal(
                7,
                lines[0],
                "DEFINITION should land on `helper`'s q_v3 declaration "
                "line 7 — the retained interface symbol kept a stale "
                "location across the edits.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        // #SYMBOLS# (document outline) after incremental edits. The
        // definition list is rebuilt body-locals-only by the re-walk; on
        // the unfixed path it keeps the pre-edit definitions too, so the
        // outline shows every symbol several times over.
        document_symbols_have_no_duplicate_rows_after_edits() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            apply_edit(analyser, "q.ghul", q_v0());
            apply_edit(analyser, "q.ghul", q_v1());
            apply_edit(analyser, "q.ghul", q_v2());

            analyser.send_symbols("q.ghul");

            let response = analyser.read_query_response();
            Assert.are_equal("SYMBOLS", response.header);

            // first line is the file path; the rest are symbol rows
            let rows = LIST[string]();
            let seen_path mut = false;
            for line in response.lines do
                if !seen_path then
                    seen_path = true;
                elif !string.is_null_or_white_space(line) then
                    rows.add(line);
                fi
            od

            let distinct = SET[string]();
            for row in rows do
                distinct.add(row);
            od

            Assert.are_equal(
                rows.count,
                distinct.count,
                "#SYMBOLS# returned {rows.count} rows but only "
                "{distinct.count} are distinct — the definition list "
                "accumulated pre-edit symbols.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );

            // `helper` (a retained interface symbol below the edited body)
            // must be reported once, at its q_v2 line 10.
            let helper_lines = symbol_row_start_lines(rows, "helper");
            Assert.are_equal(
                1,
                helper_lines.count,
                "#SYMBOLS# should list `helper` exactly once, got "
                "{helper_lines.count} ({helper_lines})."
            );
            Assert.are_equal(
                10,
                helper_lines[0],
                "`helper`'s outline entry should be at its q_v2 line 10, "
                "got {helper_lines[0]} — a stale symbol location.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // #HOVERMAP# after a non-shifting edit. No line moves, but the
        // re-walk still re-records every body's hovers; the unfixed path
        // keeps the pre-edit hovers, producing duplicate rows at identical
        // spans.
        hover_map_has_no_duplicate_rows_after_a_non_shifting_edit() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            apply_edit(analyser, "q.ghul", q_v0());
            apply_edit(analyser, "q.ghul", q_v0_changed());

            analyser.send_hover_map("q.ghul");

            let response = analyser.read_query_response();
            Assert.are_equal("HOVERMAP", response.header);

            let rows = LIST[string]();
            for line in response.lines do
                if !string.is_null_or_white_space(line) then
                    rows.add(line);
                fi
            od

            let distinct = SET[string]();
            for row in rows do
                distinct.add(row);
            od

            Assert.is_true(rows.count > 0, "#HOVERMAP# returned no rows");
            Assert.are_equal(
                rows.count,
                distinct.count,
                "#HOVERMAP# returned {rows.count} rows but only "
                "{distinct.count} are distinct — stale hover entries were "
                "not dropped before the re-walk re-recorded them.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // RENAME after an incremental edit. The rename collects every
        // reference to `helper`; on the unfixed path the accumulated
        // reference set yields duplicate / stale edits.
        rename_after_an_incremental_edit_covers_every_use_once() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            apply_edit(analyser, "q.ghul", q_v0());
            apply_edit(analyser, "q.ghul", q_v1());

            // q_v1 — `    helper() -> int => 2;`, line 8, `helper` at
            // columns 5-10.
            analyser.send_rename_request("q.ghul", 8, 7, "helper2");

            let response = analyser.read_query_response();
            Assert.are_equal("RENAMEREQUEST", response.header);

            let edits = LIST[RENAME_EDIT](response.parse_rename_edits());

            Assert.are_equal(
                3,
                edits.count,
                "renaming `helper` should produce three edits — its "
                "declaration and its two call sites; got {edits.count}. "
                "Stale references would inflate this.\n--- analyser stderr "
                "---\n{analyser.stderr_capture}"
            );

            let start_lines = SET[int]();
            for e in edits do
                Assert.is_true(e.file.ends_with("q.ghul"), "edit outside q.ghul: {e}");
                Assert.are_equal("helper2", e.new_name, "edit carried wrong new name: {e}");
                start_lines.add(e.start_line);
            od

            // declaration line 8, call sites lines 11 and 15 — all distinct.
            Assert.are_equal(
                3,
                start_lines.count,
                "the three rename edits should be on three distinct lines "
                "(8, 11, 15); got {start_lines.count} distinct."
            );
        si

        // --- cross-file fixture ---------------------------------------------

        // `core.ghul` declares `shared` and uses it; `grow`'s body is the
        // one that gets edited.
        core_v0() -> string =>
            "namespace IQX is\n"
            "    grow() -> int is\n"
            "        return 1;\n"
            "    si\n"
            "\n"
            "    shared() -> int => 5;\n"
            "\n"
            "    in_core() -> int is\n"
            "        return shared();\n"
            "    si\n"
            "si\n";

        // grow body 3 lines — shared at line 8, the in_core call at 11.
        core_v1() -> string =>
            "namespace IQX is\n"
            "    grow() -> int is\n"
            "        let a = 1;\n"
            "        let b = 2;\n"
            "        return a + b;\n"
            "    si\n"
            "\n"
            "    shared() -> int => 5;\n"
            "\n"
            "    in_core() -> int is\n"
            "        return shared();\n"
            "    si\n"
            "si\n";

        client_src() -> string =>
            "namespace IQX is\n"
            "    in_client() -> int is\n"
            "        return shared();\n"
            "    si\n"
            "si\n";

        // find-references on a symbol used in both an edited and an
        // unedited file. Editing `core.ghul` must not lose the unedited
        // `client.ghul` reference, nor accumulate the `core.ghul` one.
        find_references_spans_an_edited_and_an_unedited_file() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit_files([
                EDIT_FILE("core.ghul", core_v0()),
                EDIT_FILE("client.ghul", client_src())
            ]);
            drain_edit(analyser);

            // interface-preserving edit to core.ghul only — incremental.
            apply_edit(analyser, "core.ghul", core_v1());

            // query from the unedited file: `        return shared();`
            // in client.ghul line 3, `shared` at columns 16-21.
            analyser.send_references("client.ghul", 3, 18);

            let response = analyser.read_query_response();
            Assert.are_equal("REFERENCES", response.header);

            let core_lines = location_start_lines(response, "core.ghul");
            let client_lines = location_start_lines(response, "client.ghul");

            Assert.are_equal(
                1,
                core_lines.count,
                "find-references should report `shared`'s single use in "
                "core.ghul; got {core_lines.count} ({core_lines}) — the "
                "edited file's reference accumulated.\n--- analyser stderr "
                "---\n{analyser.stderr_capture}"
            );
            Assert.are_equal(
                11,
                core_lines[0],
                "the core.ghul use should be at its post-edit line 11."
            );
            Assert.are_equal(
                1,
                client_lines.count,
                "find-references should still report the unedited "
                "client.ghul use; got {client_lines.count}.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // --- real-source repro: space-only interface edit in compile_expressions

        // Drive the analyser against the compiler's own `src/` corpus —
        // exactly what the user's VS Code session does — and assert a
        // single-space edit inside an interface signature line of
        // `compile_expressions.ghul` introduces no new diagnostics.
        //
        // Synthetic small fixtures do not catch the double-body-walk class
        // of bug — compile-expressions' iterative body retry only kicks in
        // on real code with inference / placeholder consumption. This test
        // therefore loads the whole compiler `src/` (~380 files, ~58 k
        // lines) and is slower than other tests; the speed is the price of
        // catching a regression class that synthetic fixtures cannot.
        space_only_interface_edit_in_compile_expressions_introduces_no_new_diagnostics() is
            @test()

            let src_dir = locate_compiler_src();
            let corpus = CORPUS(src_dir);

            Assert.is_true(
                corpus.file_count > 100,
                "compiler src corpus should be sizeable, got {corpus.file_count} "
                "files from {src_dir}"
            );

            let target_suffix = "compile_expressions.ghul";
            let target = corpus.find_by_suffix(target_suffix);

            Assert.is_not_null(
                target,
                "expected the corpus to contain {target_suffix} under {src_dir}"
            );

            // The signature we'll add one space to. Picked because the
            // surrounding method body has the narrowing /
            // INFERRED_VARIABLE_TYPE pattern that exercises the iterative
            // body retry — the path that surfaces the double-body-walk
            // failure.
            let anchor = "visit(left: Trees.Variables.SIMPLE_VARIABLE_LEFT) is";
            let edited_anchor = "visit(left:  Trees.Variables.SIMPLE_VARIABLE_LEFT) is";

            Assert.is_true(
                target.source.contains(anchor),
                "expected to find signature anchor in {target.path}"
            );

            let use analyser = ANALYSER_PROCESS();

            // Cold multi-file EDIT — the analyser's normal startup path.
            analyser.send_edit_files(corpus.files);

            let cold_response = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", cold_response.header);
            let cold_diags = diagnostics_set(cold_response);
            let cold_partial = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", cold_partial.header);

            // Single-file EDIT with one extra space in the interface.
            let edited_source = replace_first(target.source, anchor, edited_anchor);

            Assert.is_true(
                edited_source !~ target.source,
                "the space-only edit should change the source"
            );

            analyser.send_edit(target.path, edited_source);

            let after_response = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", after_response.header);
            let after_diags = diagnostics_set(after_response);
            let after_partial = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", after_partial.header);

            // What the edit introduced (post-edit minus cold) — should be
            // empty. Anything here is a diagnostic the body re-walk
            // produced that a full rebuild would not.
            let introduced = LIST[string]();
            for d in after_diags do
                if !cold_diags.contains(d) then
                    introduced.add(d);
                fi
            od

            Assert.are_equal(
                0,
                introduced.count,
                "a space-only edit in the interface portion of "
                "compile_expressions.ghul must not introduce new "
                "diagnostics; got {introduced.count}:\n"
                "{describe(introduced)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // Walk up from the running assembly to the compiler `src/`
        // directory. The first ancestor with a .ghulproj is this test
        // project; its parent (the compiler's project root) has src/ next
        // to its own ghul.ghulproj.
        locate_compiler_src() -> string static is
            let dir mut = Path.get_directory_name(System.Reflection.Assembly.get_executing_assembly().location);

            do
                if !dir? then
                    throw Exception("could not locate compiler src — walked off the filesystem");
                fi

                if Directory.get_files(dir, "*.ghulproj").count > 0 then
                    let parent = Path.get_directory_name(dir);

                    if !parent? then
                        throw Exception("the test project directory has no parent: {dir}");
                    fi

                    let src = Path.combine(parent, "src");

                    if !Directory.exists(src) then
                        throw Exception("expected compiler src at {src}, but it does not exist");
                    fi

                    return src;
                fi

                dir = Path.get_directory_name(dir);
            od
        si

        // Collect a DIAGNOSTICS response's user diagnostics into a set of
        // formatted strings (`path:startLine:startCol severity message`)
        // for cheap, order-independent set comparison.
        diagnostics_set(response: RESPONSE) -> SET[string] is
            let result = SET[string]();

            for d in response.user_diagnostics do
                result.add("{d.path}:{d.start_line}:{d.start_col} sev={d.severity} {d.message}");
            od

            return result;
        si

        describe(diagnostics: LIST[string]) -> string is
            let result = System.Text.StringBuilder();

            let shown mut = 0;
            for d in diagnostics do
                if shown < 30 then
                    result.append("  ");
                    result.append(d);
                    result.append('\n');
                fi
                shown = shown + 1;
            od

            if diagnostics.count > 30 then
                result.append("  ... and {diagnostics.count - 30} more\n");
            fi

            return result.to_string();
        si

        // Replace the first occurrence of `needle` in `source` with
        // `replacement`. `string.replace` substitutes every occurrence; we
        // only want the one signature to change.
        replace_first(source: string, needle: string, replacement: string) -> string static is
            let index = source.index_of(needle);

            if index < 0 then
                return source;
            fi

            let before = source.substring(0, index);
            let after = source.substring(index + needle.length);

            return "{before}{replacement}{after}";
        si

        // --- helpers --------------------------------------------------------

        // Send a single-file EDIT and discard its DIAGNOSTICS + PARTIAL
        // DONE frames.
        apply_edit(analyser: ANALYSER_PROCESS, path: string, source: string) is
            analyser.send_edit(path, source);
            drain_edit(analyser);
        si

        // Read an EDIT's DIAGNOSTICS + PARTIAL DONE, discarding both.
        drain_edit(analyser: ANALYSER_PROCESS) is
            let diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", diagnostics.header);

            let partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", partial_done.header);
        si

        // Sorted start lines of a location-list response (DEFINITION /
        // REFERENCES — `uri TAB startLine TAB startCol TAB endLine TAB
        // endCol`) whose uri ends with `file_name`.
        location_start_lines(response: RESPONSE, file_name: string) -> LIST[int] is
            let result = LIST[int]();

            for line in response.lines do
                if string.is_null_or_white_space(line) then
                    continue;
                fi

                let fields = LIST[string](line.split(['\t']));

                if fields.count >= 2 /\ fields[0].ends_with(file_name) then
                    result.add(System.Convert.to_int32(fields[1]));
                fi
            od

            return LIST[int](result | .sort((a, b) => a - b));
        si

        // Start lines of every #SYMBOLS# row whose description mentions
        // `name`. A row is `description TAB kind TAB startLine TAB
        // startCol TAB endLine TAB endCol TAB qualifier`.
        symbol_row_start_lines(rows: LIST[string], name: string) -> LIST[int] is
            let result = LIST[int]();

            for row in rows do
                let fields = LIST[string](row.split(['\t']));

                if fields.count >= 3 /\ fields[0].contains(name) then
                    result.add(System.Convert.to_int32(fields[2]));
                fi
            od

            return LIST[int](result | .sort((a, b) => a - b));
        si
    si
si
