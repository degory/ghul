namespace Analysis.Tests is
    use Collections.Iterable;
    use Collections.LIST;
    use Collections.SET;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.RENAME_EDIT;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Coverage for the RENAMEREQUEST analysis command — the symbol rename
    // the VS Code extension drives. The analyser locates the symbol at the
    // requested position and returns one edit per occurrence (definitions
    // and uses) as `file \t sl \t sc \t el \t ec \t new_name` lines.
    //
    // Three things this exercises:
    //   1. rename of every symbol class, including across file boundaries;
    //   2. rename of an overriding / overridden method or property — the
    //      whole override family must move together;
    //   3. rename that would collide with an existing symbol.
    // Plus a flow-narrowing case: a local narrowed in one branch must
    // still rename at the narrowed use site, not just the unnarrowed ones.
    class RENAME_TESTS is
        @test()

        init() is si

        load(group: string, file: string) -> string is
            let path = fixture_path(Path.combine(group, file));

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        // 1-based column of the first character of `needle` on `line` of
        // `source`. The request only needs to land somewhere inside the
        // target identifier; `needle` should start with that identifier.
        column_of(source: string, line: int, needle: string) -> int is
            let lines = LIST[string](source.split(['\n']));

            assert line >= 1 /\ line <= lines.count
                else "line {line} out of range (1..{lines.count})";

            let text = lines[line - 1];
            let index = text.index_of(needle);

            assert index >= 0
                else "'{needle}' not found on line {line}: '{text}'";

            return index + 1;
        si

        prime(analyser: ANALYSER_PROCESS, files: Iterable[EDIT_FILE]) is
            analyser.send_edit_files(files);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
            Assert.are_equal("partial", diagnostics.phase);

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("priming EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        rename(
            analyser: ANALYSER_PROCESS,
            path: string, line: int, column: int, new_name: string
        ) -> LIST[RENAME_EDIT] is
            analyser.send_rename_request(path, line, column, new_name);

            let response = analyser.read_query_response();
            assert isa Response.RENAME(response) else "expected rename response, got '{response.get_type().name}'.\n--- analyser stderr ---\n{analyser.stderr_capture}";

            return LIST[RENAME_EDIT](response.edits);
        si

        summary(label: string, edits: Iterable[RENAME_EDIT]) -> string is
            let result = System.Text.StringBuilder();

            result.append("{label} ({edits | .count()} edits):\n");

            for e in edits do
                result.append("  {e}\n");
            od

            return result.to_string();
        si

        files_of(edits: Iterable[RENAME_EDIT]) -> SET[string] is
            let result = SET[string]();

            for e in edits do
                result.add(e.file);
            od

            return result;
        si

        // Every returned edit must carry the requested new name — the
        // analyser substitutes it verbatim into each occurrence's span.
        assert_new_name(edits: Iterable[RENAME_EDIT], expected: string) is
            for e in edits do
                Assert.are_equal(expected, e.new_name, "edit carried wrong new name: {e}");
            od
        si

        // --- 1. all symbol classes, across file boundaries -----------------

        // The `rename-symbol-classes` fixture is two files in one
        // namespace: `library.ghul` declares class WIDGET (field, ctor,
        // property, method) and the namespace function make_widget;
        // `consumer.ghul` constructs and uses them.
        symbol_classes_files() -> Iterable[EDIT_FILE] is
            return [
                EDIT_FILE("library.ghul", load("rename-symbol-classes", "library.ghul")),
                EDIT_FILE("consumer.ghul", load("rename-symbol-classes", "consumer.ghul"))
            ];
        si

        rename_class_renames_declaration_and_uses_across_files() is
            @test()

            let library = load("rename-symbol-classes", "library.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, symbol_classes_files());

            // class WIDGET is — declaration on line 2.
            let edits = rename(analyser, "library.ghul", 2, column_of(library, 2, "WIDGET"), "GADGET");

            assert_new_name(edits, "GADGET");

            let files = files_of(edits);
            Assert.is_true(
                files.contains("library.ghul") /\ files.contains("consumer.ghul"),
                summary("renaming class WIDGET should touch both files", edits)
            );
            Assert.are_equal(4, edits.count, summary("renaming class WIDGET", edits));
        si

        rename_method_renames_declaration_and_call_across_files() is
            @test()

            let consumer = load("rename-symbol-classes", "consumer.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, symbol_classes_files());

            // w.grow(5) — a use on line 6 of consumer.ghul.
            let edits = rename(analyser, "consumer.ghul", 6, column_of(consumer, 6, "grow"), "expand");

            assert_new_name(edits, "expand");

            let files = files_of(edits);
            Assert.is_true(
                files.contains("library.ghul") /\ files.contains("consumer.ghul"),
                summary("renaming method grow should touch both files", edits)
            );
            Assert.are_equal(2, edits.count, summary("renaming method grow", edits));
        si

        rename_property_renames_declaration_and_uses_across_files() is
            @test()

            let consumer = load("rename-symbol-classes", "consumer.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, symbol_classes_files());

            // "{w.size}" — a use on line 7 of consumer.ghul.
            let edits = rename(analyser, "consumer.ghul", 7, column_of(consumer, 7, "size"), "extent");

            assert_new_name(edits, "extent");

            let files = files_of(edits);
            Assert.is_true(
                files.contains("library.ghul") /\ files.contains("consumer.ghul"),
                summary("renaming property size should touch both files", edits)
            );
            Assert.are_equal(3, edits.count, summary("renaming property size", edits));
        si

        rename_field_renames_all_uses_in_class() is
            @test()

            let library = load("rename-symbol-classes", "library.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, symbol_classes_files());

            // _size: int; — field declaration on line 3.
            let edits = rename(analyser, "library.ghul", 3, column_of(library, 3, "_size"), "_extent");

            assert_new_name(edits, "_extent");

            let files = files_of(edits);
            Assert.are_equal(1, files.count, summary("renaming field _size should stay in library.ghul", edits));
            Assert.is_true(files.contains("library.ghul"), summary("renaming field _size", edits));
            Assert.are_equal(5, edits.count, summary("renaming field _size", edits));
        si

        rename_namespace_function_renames_declaration_and_calls() is
            @test()

            let consumer = load("rename-symbol-classes", "consumer.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, symbol_classes_files());

            // make_widget(3) — a call on line 8 of consumer.ghul.
            let edits = rename(analyser, "consumer.ghul", 8, column_of(consumer, 8, "make_widget"), "build_widget");

            assert_new_name(edits, "build_widget");

            let files = files_of(edits);
            Assert.is_true(
                files.contains("library.ghul") /\ files.contains("consumer.ghul"),
                summary("renaming function make_widget should touch both files", edits)
            );
            Assert.are_equal(2, edits.count, summary("renaming function make_widget", edits));
        si

        // make_widget and WIDGET.init both declare a parameter named
        // `size`; renaming one must leave the other untouched.
        rename_parameter_renames_only_that_parameter() is
            @test()

            let library = load("rename-symbol-classes", "library.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, symbol_classes_files());

            // make_widget(size: int) — the parameter declaration on line 16.
            let edits = rename(analyser, "library.ghul", 16, column_of(library, 16, "size"), "amount");

            assert_new_name(edits, "amount");

            for e in edits do
                Assert.are_equal(
                    16,
                    e.start_line,
                    summary("renaming make_widget's `size` must not touch init's `size`", edits)
                );
            od
            Assert.are_equal(2, edits.count, summary("renaming parameter size", edits));
        si

        rename_local_variable_renames_declaration_and_uses() is
            @test()

            let consumer = load("rename-symbol-classes", "consumer.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, symbol_classes_files());

            // let w = WIDGET(10); — local declaration on line 5.
            let edits = rename(analyser, "consumer.ghul", 5, column_of(consumer, 5, "w ="), "widget");

            assert_new_name(edits, "widget");

            let files = files_of(edits);
            Assert.are_equal(1, files.count, summary("renaming local w should stay in consumer.ghul", edits));
            Assert.is_true(files.contains("consumer.ghul"), summary("renaming local w", edits));
            Assert.are_equal(3, edits.count, summary("renaming local w", edits));
        si

        // --- 2. overriding / overridden methods and properties ------------

        // The `rename-inheritance` fixture: ANIMAL with an overridable
        // method `speak` and property `name`; DOG overrides both;
        // `zoo.ghul` calls them through both static types.
        inheritance_files() -> Iterable[EDIT_FILE] is
            return [
                EDIT_FILE("animals.ghul", load("rename-inheritance", "animals.ghul")),
                EDIT_FILE("zoo.ghul", load("rename-inheritance", "zoo.ghul"))
            ];
        si

        // Renaming from the base declaration must carry the override and
        // every call site with it.
        rename_overridden_method_from_base_covers_override() is
            @test()

            let animals = load("rename-inheritance", "animals.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, inheritance_files());

            // ANIMAL.speak() — base declaration on line 5.
            let edits = rename(analyser, "animals.ghul", 5, column_of(animals, 5, "speak"), "vocalise");

            assert_new_name(edits, "vocalise");

            let files = files_of(edits);
            Assert.is_true(
                files.contains("animals.ghul") /\ files.contains("zoo.ghul"),
                summary("renaming speak from the base should touch both files", edits)
            );
            Assert.are_equal(4, edits.count, summary("renaming overridden method speak from base", edits));
        si

        // Renaming from the override must carry the base declaration too —
        // the analyser walks up to the root overridee.
        rename_overriding_method_from_derived_covers_base() is
            @test()

            let animals = load("rename-inheritance", "animals.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, inheritance_files());

            // DOG.speak() — the override declaration on line 13.
            let edits = rename(analyser, "animals.ghul", 13, column_of(animals, 13, "speak"), "vocalise");

            assert_new_name(edits, "vocalise");

            let files = files_of(edits);
            Assert.is_true(
                files.contains("animals.ghul") /\ files.contains("zoo.ghul"),
                summary("renaming speak from the override should touch both files", edits)
            );
            Assert.are_equal(4, edits.count, summary("renaming overriding method speak from derived", edits));
        si

        rename_overridden_property_covers_override() is
            @test()

            let animals = load("rename-inheritance", "animals.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, inheritance_files());

            // ANIMAL.name — base property declaration on line 7.
            let edits = rename(analyser, "animals.ghul", 7, column_of(animals, 7, "name"), "label");

            assert_new_name(edits, "label");

            let files = files_of(edits);
            Assert.is_true(
                files.contains("animals.ghul") /\ files.contains("zoo.ghul"),
                summary("renaming property name should touch both files", edits)
            );
            Assert.are_equal(4, edits.count, summary("renaming overridden property name", edits));
        si

        // --- 3. rename that would introduce a duplicate symbol -----------

        // BOX declares methods `width` and `height`. Renaming `width` to
        // `height` would put two `height` members on one class. A correct
        // rename should refuse and return no edits.
        //
        // It currently does NOT — the RENAMEREQUEST handler has no
        // collision check; it returns the edit for `width` regardless,
        // which would produce a duplicate member. This test pins that
        // behaviour so the gap is visible; when the handler learns to
        // refuse colliding renames, the expectation below flips to zero.
        rename_to_existing_member_name_is_not_yet_refused() is
            @test()

            let box = load("rename-duplicate", "box.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, [EDIT_FILE("box.ghul", box)]);

            // BOX.width() — declaration on line 5; rename onto sibling `height`.
            let edits = rename(analyser, "box.ghul", 5, column_of(box, 5, "width"), "height");

            Assert.are_equal(
                1,
                edits.count,
                summary("renaming width->height currently returns edits instead of refusing the collision", edits)
            );
        si

        // --- 4. local narrowed by flow-sensitive analysis ----------------

        // In `describe`, the local `item` is declared `object` and
        // narrowed to `string` inside the `isa` branch. Every occurrence
        // — the declaration, the `isa` test, the narrowed `item.length`
        // use, and the unnarrowed `{item}` use — must rename together.
        narrowed_files() -> Iterable[EDIT_FILE] is
            return [EDIT_FILE("narrowed.ghul", load("rename-narrowed", "narrowed.ghul"))];
        si

        assert_narrowed_rename(edits: LIST[RENAME_EDIT]) is
            assert_new_name(edits, "thing");

            // Line 8 is `return "len {item.length}";` — the narrowed use.
            let has_narrowed_use = edits | .any(e => e.start_line == 8);
            Assert.is_true(
                has_narrowed_use,
                summary("rename of narrowed local must include the narrowed use on line 8", edits)
            );

            // Line 11 is `return "{item}";` — the unnarrowed use.
            let has_unnarrowed_use = edits | .any(e => e.start_line == 11);
            Assert.is_true(
                has_unnarrowed_use,
                summary("rename of narrowed local must include the unnarrowed use on line 11", edits)
            );

            Assert.are_equal(4, edits.count, summary("renaming narrowed local item", edits));
        si

        rename_narrowed_local_from_declaration_covers_narrowed_use() is
            @test()

            let narrowed = load("rename-narrowed", "narrowed.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, narrowed_files());

            // let item = value; — declaration on line 5.
            let edits = rename(analyser, "narrowed.ghul", 5, column_of(narrowed, 5, "item"), "thing");

            assert_narrowed_rename(edits);
        si

        rename_narrowed_local_from_narrowed_use_covers_all() is
            @test()

            let narrowed = load("rename-narrowed", "narrowed.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, narrowed_files());

            // {item.length} — the narrowed use on line 8.
            let edits = rename(analyser, "narrowed.ghul", 8, column_of(narrowed, 8, "item"), "thing");

            assert_narrowed_rename(edits);
        si

        // --- 5. override families three levels deep ----------------------

        // The `rename-hierarchy` fixture is a three-level family: trait
        // SHAPE declares `area` (method) and `kind` (property) with no
        // body; POLYGON implements both; SQUARE and TRIANGLE each extend
        // POLYGON and override both again. `usage.ghul` calls them through
        // each static type (SHAPE, POLYGON, SQUARE, TRIANGLE). Renaming a
        // member of such a family from any level must move the whole
        // family — every declaration and every call site — together, so
        // that all four declarations and all four call sites are rewritten.
        hierarchy_files() -> Iterable[EDIT_FILE] is
            return [
                EDIT_FILE("shapes.ghul", load("rename-hierarchy", "shapes.ghul")),
                EDIT_FILE("usage.ghul", load("rename-hierarchy", "usage.ghul"))
            ];
        si

        assert_line_present(edits: Iterable[RENAME_EDIT], file: string, line: int, label: string) is
            let found = edits | .any(e => e.file =~ file /\ e.start_line == line);
            Assert.is_true(found, summary("{label}: expected an edit at {file}:{line}", edits));
        si

        // Every declaration in the `area` family (trait, middle class,
        // both leaf classes) and every call site, regardless of which
        // declaration the rename was requested from.
        assert_area_family(edits: LIST[RENAME_EDIT]) is
            assert_new_name(edits, "extent");

            assert_line_present(edits, "shapes.ghul", 3, "trait SHAPE.area declaration");
            assert_line_present(edits, "shapes.ghul", 11, "POLYGON.area declaration");
            assert_line_present(edits, "shapes.ghul", 24, "SQUARE.area declaration");
            assert_line_present(edits, "shapes.ghul", 39, "TRIANGLE.area declaration");

            assert_line_present(edits, "usage.ghul", 6, "area call through SHAPE");
            assert_line_present(edits, "usage.ghul", 9, "area call through POLYGON");
            assert_line_present(edits, "usage.ghul", 12, "area call through SQUARE");
            assert_line_present(edits, "usage.ghul", 15, "area call through TRIANGLE");

            Assert.are_equal(8, edits.count, summary("renaming the area family", edits));
        si

        assert_kind_family(edits: LIST[RENAME_EDIT]) is
            assert_new_name(edits, "label");

            assert_line_present(edits, "shapes.ghul", 5, "trait SHAPE.kind declaration");
            assert_line_present(edits, "shapes.ghul", 13, "POLYGON.kind declaration");
            assert_line_present(edits, "shapes.ghul", 26, "SQUARE.kind declaration");
            assert_line_present(edits, "shapes.ghul", 41, "TRIANGLE.kind declaration");

            Assert.are_equal(8, edits.count, summary("renaming the kind family", edits));
        si

        rename_method_from_trait_top_covers_whole_family() is
            @test()

            let shapes = load("rename-hierarchy", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // SHAPE.area() — the abstract declaration at the top, line 3.
            let edits = rename(analyser, "shapes.ghul", 3, column_of(shapes, 3, "area"), "extent");

            assert_area_family(edits);
        si

        rename_method_from_middle_class_covers_whole_family() is
            @test()

            let shapes = load("rename-hierarchy", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // POLYGON.area() — the middle override, line 11.
            let edits = rename(analyser, "shapes.ghul", 11, column_of(shapes, 11, "area"), "extent");

            assert_area_family(edits);
        si

        rename_method_from_leaf_class_covers_whole_family() is
            @test()

            let shapes = load("rename-hierarchy", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // SQUARE.area() — a leaf override, line 24.
            let edits = rename(analyser, "shapes.ghul", 24, column_of(shapes, 24, "area"), "extent");

            assert_area_family(edits);
        si

        rename_method_from_call_site_covers_whole_family() is
            @test()

            let usage = load("rename-hierarchy", "usage.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // sh.area() — a call through the trait static type, usage line 6.
            let edits = rename(analyser, "usage.ghul", 6, column_of(usage, 6, "area"), "extent");

            assert_area_family(edits);
        si

        rename_property_from_trait_top_covers_whole_family() is
            @test()

            let shapes = load("rename-hierarchy", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // SHAPE.kind — the abstract property at the top, line 5.
            let edits = rename(analyser, "shapes.ghul", 5, column_of(shapes, 5, "kind"), "label");

            assert_kind_family(edits);
        si

        rename_property_from_middle_class_covers_whole_family() is
            @test()

            let shapes = load("rename-hierarchy", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // POLYGON.kind — the middle override, line 13.
            let edits = rename(analyser, "shapes.ghul", 13, column_of(shapes, 13, "kind"), "label");

            assert_kind_family(edits);
        si

        rename_property_from_leaf_class_covers_whole_family() is
            @test()

            let shapes = load("rename-hierarchy", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // SQUARE.kind — a leaf override, line 26.
            let edits = rename(analyser, "shapes.ghul", 26, column_of(shapes, 26, "kind"), "label");

            assert_kind_family(edits);
        si

        // The trait type name itself: declaration, the `: SHAPE` in
        // POLYGON's header, and the `let sh: SHAPE` annotation in usage.
        rename_trait_name_covers_declaration_and_implementers() is
            @test()

            let shapes = load("rename-hierarchy", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // trait SHAPE — declaration on line 2.
            let edits = rename(analyser, "shapes.ghul", 2, column_of(shapes, 2, "SHAPE"), "FIGURE");

            assert_new_name(edits, "FIGURE");

            let files = files_of(edits);
            Assert.is_true(
                files.contains("shapes.ghul") /\ files.contains("usage.ghul"),
                summary("renaming trait SHAPE should touch both files", edits)
            );
            Assert.are_equal(3, edits.count, summary("renaming trait SHAPE", edits));
        si

        // A class in the middle of the hierarchy is both a subclass of a
        // trait and the superclass of two leaves: declaration, the
        // `: POLYGON` in SQUARE and TRIANGLE, and the `let po: POLYGON`
        // annotation in usage.
        rename_mid_hierarchy_class_covers_sub_and_superclass_uses() is
            @test()

            let shapes = load("rename-hierarchy", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, hierarchy_files());

            // class POLYGON — declaration on line 8.
            let edits = rename(analyser, "shapes.ghul", 8, column_of(shapes, 8, "POLYGON"), "SHAPE_BASE");

            assert_new_name(edits, "SHAPE_BASE");
            Assert.are_equal(4, edits.count, summary("renaming mid-hierarchy class POLYGON", edits));
        si

        // --- 6. unions and variants --------------------------------------

        // The `rename-union` fixture: union TREE with field variants NODE
        // and LEAF and a unit variant EMPTY; `describe` pattern-matches
        // them and `entry` constructs each one.
        union_files() -> Iterable[EDIT_FILE] is
            return [EDIT_FILE("tree.ghul", load("rename-union", "tree.ghul"))];
        si

        // Renaming the union type rewrites every reference to it: the
        // declaration name, the `t: TREE` parameter, the three
        // `let .: TREE` annotations, and the `TREE.` qualifier on every
        // construction and pattern — including the `if let` / `elif let`
        // patterns on lines 11 and 13 — for ten edits in all.
        rename_union_name_from_declaration() is
            @test()

            let tree = load("rename-union", "tree.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, union_files());

            // union TREE — declaration on line 4.
            let edits = rename(analyser, "tree.ghul", 4, column_of(tree, 4, "TREE"), "FOREST");

            assert_new_name(edits, "FOREST");
            assert_line_present(edits, "tree.ghul", 11, "TREE qualifier in if-let pattern");
            assert_line_present(edits, "tree.ghul", 13, "TREE qualifier in elif-let pattern");
            Assert.are_equal(10, edits.count, summary("renaming union TREE from declaration", edits));
        si

        // The same union rename requested from a use site — the `t: TREE`
        // annotation on line 21 — returns the same set as renaming from the
        // declaration.
        rename_union_name_from_use_site() is
            @test()

            let tree = load("rename-union", "tree.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, union_files());

            // let t: TREE — type annotation on line 21.
            let edits = rename(analyser, "tree.ghul", 21, column_of(tree, 21, "TREE"), "FOREST");

            assert_new_name(edits, "FOREST");
            assert_line_present(edits, "tree.ghul", 11, "TREE qualifier in if-let pattern");
            Assert.are_equal(10, edits.count, summary("renaming union TREE from a use site", edits));
        si

        // A field-carrying variant renamed from its declaration covers its
        // three occurrences: the declaration (line 5), the `if let` pattern
        // (line 11), and the construction (line 21).
        rename_variant_from_declaration() is
            @test()

            let tree = load("rename-union", "tree.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, union_files());

            // NODE — variant declaration on line 5.
            let edits = rename(analyser, "tree.ghul", 5, column_of(tree, 5, "NODE"), "BRANCH");

            assert_new_name(edits, "BRANCH");
            assert_line_present(edits, "tree.ghul", 5, "NODE declaration");
            assert_line_present(edits, "tree.ghul", 11, "NODE in if-let pattern");
            assert_line_present(edits, "tree.ghul", 21, "NODE in construction");
            Assert.are_equal(3, edits.count, summary("renaming variant NODE from declaration", edits));
        si

        // The same variant renamed from a construction use site rather than
        // the declaration returns the same family — a variant resolves and
        // renames from a construction reference, not only its declaration.
        rename_variant_from_construction_site() is
            @test()

            let tree = load("rename-union", "tree.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, union_files());

            // TREE.NODE(1, 2) — construction on line 21.
            let edits = rename(analyser, "tree.ghul", 21, column_of(tree, 21, "NODE"), "BRANCH");

            assert_new_name(edits, "BRANCH");
            assert_line_present(edits, "tree.ghul", 5, "NODE declaration");
            assert_line_present(edits, "tree.ghul", 11, "NODE in if-let pattern");
            assert_line_present(edits, "tree.ghul", 21, "NODE in construction");
            Assert.are_equal(3, edits.count, summary("renaming variant NODE from a construction site", edits));
        si

        // And from a pattern use site — the `NODE` in `if let node:
        // TREE.NODE` on line 11 — again the same three-edit family.
        rename_variant_from_pattern_site() is
            @test()

            let tree = load("rename-union", "tree.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, union_files());

            // TREE.NODE — pattern on line 11.
            let edits = rename(analyser, "tree.ghul", 11, column_of(tree, 11, "NODE"), "BRANCH");

            assert_new_name(edits, "BRANCH");
            assert_line_present(edits, "tree.ghul", 5, "NODE declaration");
            assert_line_present(edits, "tree.ghul", 11, "NODE in if-let pattern");
            assert_line_present(edits, "tree.ghul", 21, "NODE in construction");
            Assert.are_equal(3, edits.count, summary("renaming variant NODE from a pattern site", edits));
        si

        // A unit variant renamed from its declaration: the declaration name
        // and the parenthesis-free reference, two edits.
        rename_unit_variant_from_declaration() is
            @test()

            let tree = load("rename-union", "tree.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, union_files());

            // EMPTY — unit variant declaration on line 7.
            let edits = rename(analyser, "tree.ghul", 7, column_of(tree, 7, "EMPTY"), "NOTHING");

            assert_new_name(edits, "NOTHING");
            assert_line_present(edits, "tree.ghul", 7, "EMPTY declaration");
            assert_line_present(edits, "tree.ghul", 23, "EMPTY reference");
            Assert.are_equal(2, edits.count, summary("renaming unit variant EMPTY", edits));
        si

        // --- 7. primary constructor parameters ---------------------------

        // The `rename-primary-ctor` fixture exercises the three primary-
        // parameter shapes: an auto-generated public property (POINT.x),
        // a capture into a differently-named private field (BOX `value`
        // captured by `_value`), and the leading-`_` private-field form
        // (COUNTER._count).
        primary_ctor_files() -> Iterable[EDIT_FILE] is
            return [EDIT_FILE("shapes.ghul", load("rename-primary-ctor", "shapes.ghul"))];
        si

        // An auto-property primary parameter: header, the `{x}`
        // interpolation in `show`, and the `p.x` read in `entry`.
        rename_primary_ctor_auto_property() is
            @test()

            let shapes = load("rename-primary-ctor", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, primary_ctor_files());

            // class POINT(x: int, ...) — primary parameter on line 6.
            let edits = rename(analyser, "shapes.ghul", 6, column_of(shapes, 6, "x"), "across");

            assert_new_name(edits, "across");
            assert_line_present(edits, "shapes.ghul", 6, "POINT primary parameter x");
            assert_line_present(edits, "shapes.ghul", 7, "x read in show()");
            assert_line_present(edits, "shapes.ghul", 27, "p.x read in entry");
            Assert.are_equal(3, edits.count, summary("renaming auto-property primary parameter x", edits));
        si

        // Capture form, renamed from the field name `_value`. Only the
        // field declaration and its `{_value}` use rename; the capturing
        // primary parameter `value` on line 13 is left untouched.
        //
        // That result is incomplete: the primary parameter and the field
        // it is captured by under the `_foo` / `foo` rule are two halves of
        // one declaration, so renaming `_value` to `_contents` without also
        // renaming the parameter breaks the capture — `_contents` no longer
        // matches `value`, orphaning the field. The corrected behaviour
        // would rename the parameter and its captured field together; this
        // pins the current partial result so that fix flips the test
        // deliberately. The mirror case is rename_captured_primary_param_-
        // from_header below.
        rename_captured_field_from_field_name() is
            @test()

            let shapes = load("rename-primary-ctor", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, primary_ctor_files());

            // _value; — capture field declaration on line 14.
            let edits = rename(analyser, "shapes.ghul", 14, column_of(shapes, 14, "_value"), "_contents");

            assert_new_name(edits, "_contents");
            assert_line_present(edits, "shapes.ghul", 14, "_value field declaration");
            assert_line_present(edits, "shapes.ghul", 16, "_value read in peek()");
            Assert.are_equal(2, edits.count, summary("renaming captured field _value", edits));
        si

        // Capture form, renamed from the primary parameter `value`. Only
        // the header occurrence renames; the capturing field `_value` and
        // its `{_value}` use are left untouched.
        //
        // As with rename_captured_field_from_field_name above, that result
        // is incomplete — renaming the parameter without its captured field
        // breaks the `_foo` / `foo` capture and orphans the field. The
        // corrected behaviour would rename the parameter and its captured
        // field together; this pins the current partial result so that fix
        // flips the test deliberately.
        rename_captured_primary_param_from_header() is
            @test()

            let shapes = load("rename-primary-ctor", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, primary_ctor_files());

            // class BOX(value: int) — primary parameter on line 13.
            let edits = rename(analyser, "shapes.ghul", 13, column_of(shapes, 13, "value"), "contents");

            assert_new_name(edits, "contents");
            assert_line_present(edits, "shapes.ghul", 13, "BOX primary parameter value");
            Assert.are_equal(1, edits.count, summary("renaming captured primary parameter value", edits));
        si

        // Leading-`_` modifier form: the parameter and the private field
        // share the one name `_count` — header plus the `_count` use.
        rename_underscore_modifier_field() is
            @test()

            let shapes = load("rename-primary-ctor", "shapes.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, primary_ctor_files());

            // class COUNTER(_count: int) — primary parameter on line 21.
            let edits = rename(analyser, "shapes.ghul", 21, column_of(shapes, 21, "_count"), "_total");

            assert_new_name(edits, "_total");
            assert_line_present(edits, "shapes.ghul", 21, "COUNTER primary parameter _count");
            assert_line_present(edits, "shapes.ghul", 22, "_count use in bump()");
            Assert.are_equal(2, edits.count, summary("renaming underscore-modifier field _count", edits));
        si

        // --- 8. mutable local and anonymous-function argument ------------

        // The `rename-locals` fixture: a `mut` local `total` reassigned
        // twice, and a lambda whose explicitly-typed parameter `value` is
        // used twice in its body.
        locals_files() -> Iterable[EDIT_FILE] is
            return [EDIT_FILE("locals.ghul", load("rename-locals", "locals.ghul"))];
        si

        // The `total` family: the declaration (line 6), both reassignment
        // sites (lines 7 and 8, two occurrences each), and the read in the
        // interpolation (line 9) — six edits. The next three tests rename
        // it from the declaration, from a write site, and from a read site;
        // a correct rename returns this same set whichever position it
        // starts from, so the asymmetry between use and definition sites
        // (if any) shows up as a count or coverage difference.
        assert_total_family(edits: LIST[RENAME_EDIT]) is
            assert_new_name(edits, "running");
            assert_line_present(edits, "locals.ghul", 6, "total declaration");
            assert_line_present(edits, "locals.ghul", 7, "total first reassignment");
            assert_line_present(edits, "locals.ghul", 8, "total second reassignment");
            assert_line_present(edits, "locals.ghul", 9, "total read in interpolation");
            Assert.are_equal(6, edits.count, summary("renaming mutable local total", edits));
        si

        rename_mutable_local_from_declaration() is
            @test()

            let locals = load("rename-locals", "locals.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, locals_files());

            // let total mut = 0; — declaration on line 6.
            let edits = rename(analyser, "locals.ghul", 6, column_of(locals, 6, "total"), "running");

            assert_total_family(edits);
        si

        rename_mutable_local_from_reassignment() is
            @test()

            let locals = load("rename-locals", "locals.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, locals_files());

            // total = total + 1; — a write site on line 7.
            let edits = rename(analyser, "locals.ghul", 7, column_of(locals, 7, "total"), "running");

            assert_total_family(edits);
        si

        rename_mutable_local_from_read() is
            @test()

            let locals = load("rename-locals", "locals.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, locals_files());

            // Std.write_line("{total}"); — a read site on line 9.
            let edits = rename(analyser, "locals.ghul", 9, column_of(locals, 9, "total"), "running");

            assert_total_family(edits);
        si

        // An anonymous-function parameter renames only within the lambda —
        // the declaration and both uses, all on the lambda's line.
        rename_anonymous_function_argument() is
            @test()

            let locals = load("rename-locals", "locals.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, locals_files());

            // (value: int) => value * value — lambda parameter on line 15.
            let edits = rename(analyser, "locals.ghul", 15, column_of(locals, 15, "value"), "element");

            assert_new_name(edits, "element");

            for e in edits do
                Assert.are_equal(
                    15,
                    e.start_line,
                    summary("renaming the lambda parameter must stay on its line", edits)
                );
            od
            Assert.are_equal(3, edits.count, summary("renaming anonymous-function argument value", edits));
        si

        // The immutable local `w` in `rename-symbol-classes/consumer.ghul`
        // is renamed from its declaration by an earlier test; this renames
        // it from a use site (`w.grow(5)`) instead. A correct rename
        // returns the same three-edit set — declaration plus the two uses —
        // regardless of which occurrence it starts from.
        rename_immutable_local_from_use_site() is
            @test()

            let consumer = load("rename-symbol-classes", "consumer.ghul");
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, symbol_classes_files());

            // w.grow(5) — a use of the local on line 6.
            let edits = rename(analyser, "consumer.ghul", 6, column_of(consumer, 6, "w"), "widget");

            assert_new_name(edits, "widget");

            let files = files_of(edits);
            Assert.are_equal(1, files.count, summary("renaming local w should stay in consumer.ghul", edits));
            assert_line_present(edits, "consumer.ghul", 5, "w declaration");
            Assert.are_equal(3, edits.count, summary("renaming local w from a use site", edits));
        si

        // --- 9. cross-file uses after an interface-affecting rebuild -------

        // The `rename-enum` fixture: `severity.ghul` declares enum SEVERITY
        // and a class using it as a field type; `store.ghul` refers to the
        // enum by type annotation *and* by member access (SEVERITY.HIGH etc).
        // `severity_changed.ghul` is `severity.ghul` plus one extra method —
        // an interface-affecting change.
        //
        // A single-file EDIT that changes an interface forces a whole-project
        // rebuild in which only the edited file is walked through expressions;
        // every other file stops at up-to-expressions, where type-annotation
        // uses are recorded but member-access uses are not. Renaming the enum
        // must still cover the member-access occurrences in the non-edited
        // store.ghul — the handler recompiles when the use map is incomplete,
        // not only when it comes back empty.
        rename_enum_covers_member_uses_in_non_edited_file() is
            @test()

            let severity = load("rename-enum", "severity.ghul");
            let severity_changed = load("rename-enum", "severity_changed.ghul");
            let store = load("rename-enum", "store.ghul");

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, [
                EDIT_FILE("severity.ghul", severity),
                EDIT_FILE("store.ghul", store)
            ]);

            // Interface-affecting edit of severity.ghul, so the rebuild drops
            // store.ghul to up-to-expressions.
            analyser.send_edit_files([EDIT_FILE("severity.ghul", severity_changed)]);
            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            // enum SEVERITY is — declaration on line 2.
            let edits = rename(analyser, "severity.ghul", 2, column_of(severity, 2, "SEVERITY"), "URGENCY");

            assert_new_name(edits, "URGENCY");

            // The member-access uses in the non-edited file must be covered.
            assert_line_present(edits, "store.ghul", 6, "SEVERITY.HIGH in classify");
            assert_line_present(edits, "store.ghul", 8, "SEVERITY.MEDIUM in classify");
            assert_line_present(edits, "store.ghul", 15, "SEVERITY.HIGH in worst");

            Assert.are_equal(9, edits.count, summary("renaming enum across an interface-affecting rebuild", edits));
        si
    si
si
