namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Regression coverage for the bug where SET_OPEN_FILES did not
    // invalidate the compile cache: after EDIT + COMPILE with the file
    // closed (hints suppressed), the next SET_OPEN_FILES + COMPILE cycle
    // returned the cached "no-hints" diagnostics from the previous run
    // rather than re-computing under the new open-file set.
    class SET_OPEN_FILES_INVALIDATES_COMPILE_CACHE_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace OpenFileHint is\n"
            "    class WIDGET is\n"
            "        init() is si\n"
            "        make() -> WIDGET? => WIDGET();\n"
            "        run() is\n"
            "            let w mut = make();\n"
            "            if w? then\n"
            "                w = make();\n"
            "            fi\n"
            "        si\n"
            "    si\n"
            "si\n";

        // severity 4 == HINT
        has_kill_hint(diagnostics: Collections.Iterable[DIAGNOSTIC]) -> bool is
            for d in diagnostics do
                if d.severity == 4 /\ d.message.contains("reassigned") then
                    return true;
                fi
            od

            return false;
        si

        // Read one DIAGNOSTICS response off `analyser`; return its user
        // diagnostics as a materialised list.
        user_diagnostics_from_compile(analyser: ANALYSER_PROCESS) -> LIST[DIAGNOSTIC] is
            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response";

            return LIST[DIAGNOSTIC](user_diagnostics_of(response));
        si

        open_files_added_after_edit__compile_reruns() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            // File closed at EDIT time — first COMPILE produces no hint.
            analyser.send_open_files(Collections.LIST[string]());

            analyser.send_edit("openfilehint.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            let first = user_diagnostics_from_compile(analyser);

            Assert.is_false(
                has_kill_hint(first),
                "with the file closed the first COMPILE must produce no kill hint\n{diagnostics_summary("first", first)}"
            );

            // Client re-opens the file. Without cache invalidation the
            // next COMPILE would short-circuit and re-emit `first`; with
            // it, COMPILE reruns and the kill hint appears.
            analyser.send_open_files(["openfilehint.ghul"]);

            analyser.send_compile();
            let second = user_diagnostics_from_compile(analyser);

            Assert.is_true(
                has_kill_hint(second),
                "opening a file after a full compile must invalidate the cache so the next COMPILE re-emits hints\n{diagnostics_summary("second", second)}"
            );
        si

        open_files_removed_after_edit__compile_reruns() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            // File open at EDIT time — first COMPILE produces a hint.
            analyser.send_open_files(["openfilehint.ghul"]);

            analyser.send_edit("openfilehint.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            let first = user_diagnostics_from_compile(analyser);

            Assert.is_true(
                has_kill_hint(first),
                "with the file open the first COMPILE must produce a kill hint\n{diagnostics_summary("first", first)}"
            );

            // Client closes the file. The next COMPILE must rerun and drop
            // the hint rather than re-emit the cached hint from before.
            analyser.send_open_files(Collections.LIST[string]());

            analyser.send_compile();
            let second = user_diagnostics_from_compile(analyser);

            Assert.is_false(
                has_kill_hint(second),
                "closing a file after a full compile must invalidate the cache so the next COMPILE drops the hint\n{diagnostics_summary("second", second)}"
            );
        si

        open_files_reasserted_after_edit__compile_is_skipped() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_open_files(["openfilehint.ghul"]);

            analyser.send_edit("openfilehint.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            let first = user_diagnostics_from_compile(analyser);

            // Reassert the same open-file set. Cache invalidation must
            // treat this as a no-op so the compile-skipped fast path
            // remains available.
            analyser.send_open_files(["openfilehint.ghul"]);

            analyser.send_compile();
            let second = user_diagnostics_from_compile(analyser);

            Assert.are_equal(
                first.count,
                second.count,
                "reasserting the same open-file set must not change the diagnostics count\nfirst={first.count}, second={second.count}"
            );
        si
    si
si
