namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.INLAY_HINT;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Regression coverage for the bug where SET_OPEN_FILES did not
    // invalidate the compile cache: after EDIT + COMPILE with the file
    // closed (inlays suppressed), the next SET_OPEN_FILES + COMPILE cycle
    // returned the cached state from the previous run rather than
    // re-computing under the new open-file set. The signal we look for
    // is a narrowing-killed inlay, which is only recorded when a file is
    // in the open-files set.
    class SET_OPEN_FILES_INVALIDATES_COMPILE_CACHE_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace OpenFileHint is\n"
            "    class WIDGET is\n"
            "        init() is si\n"
            "        make() -> WIDGET? => WIDGET();\n"
            "        run() is\n"
            "            let w mut = make();\n"
            "            if w? then\n"
            "                w = make();\n"
            "            fi\n"
            "        si\n"
            "    si\n"
            "si\n";

        has_kill_inlay(hints: Collections.Iterable[INLAY_HINT]) -> bool is
            for h in hints do
                if h.code =~ "narrowing-killed" then
                    return true;
                fi
            od

            return false;
        si

        // Ask for the inlays currently recorded for `path`. INLAY_HINTS is
        // a pure read from the store — it does not itself recompute — so
        // it reports the state left behind by the most recent COMPILE.
        fetch_inlays(analyser: ANALYSER_PROCESS, path: string) -> LIST[INLAY_HINT] is
            analyser.send_inlay_hints(path);
            let response = analyser.read_response();
            assert isa Response.INLAY_HINTS(response) else "expected INLAY_HINTS response";
            return LIST[INLAY_HINT](response.hints);
        si

        // Read one DIAGNOSTICS response off `analyser`; return its user
        // diagnostics as a materialised list.
        user_diagnostics_from_compile(analyser: ANALYSER_PROCESS) -> LIST[DIAGNOSTIC] is
            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response";

            return LIST[DIAGNOSTIC](user_diagnostics_of(response));
        si

        open_files_added_after_edit__compile_reruns() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            // File closed at EDIT time — first COMPILE produces no inlay.
            analyser.send_open_files(Collections.LIST[string]());

            analyser.send_edit("openfilehint.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            user_diagnostics_from_compile(analyser);

            let first = fetch_inlays(analyser, "openfilehint.ghul");

            Assert.is_false(
                has_kill_inlay(first),
                "with the file closed the first COMPILE must produce no kill inlay"
            );

            // Client re-opens the file. Without cache invalidation the
            // next COMPILE would short-circuit and the store would still
            // hold no inlay; with it, COMPILE reruns and the kill inlay
            // appears.
            analyser.send_open_files(["openfilehint.ghul"]);

            analyser.send_compile();
            user_diagnostics_from_compile(analyser);

            let second = fetch_inlays(analyser, "openfilehint.ghul");

            Assert.is_true(
                has_kill_inlay(second),
                "opening a file after a full compile must invalidate the cache so the next COMPILE re-records inlays"
            );
        si

        open_files_removed_after_edit__compile_reruns() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            // File open at EDIT time — first COMPILE produces a kill inlay.
            analyser.send_open_files(["openfilehint.ghul"]);

            analyser.send_edit("openfilehint.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            user_diagnostics_from_compile(analyser);

            let first = fetch_inlays(analyser, "openfilehint.ghul");

            Assert.is_true(
                has_kill_inlay(first),
                "with the file open the first COMPILE must produce a kill inlay"
            );

            // Client closes the file. The next COMPILE must rerun and drop
            // the inlay rather than leaving the cached one from before.
            analyser.send_open_files(Collections.LIST[string]());

            analyser.send_compile();
            user_diagnostics_from_compile(analyser);

            let second = fetch_inlays(analyser, "openfilehint.ghul");

            Assert.is_false(
                has_kill_inlay(second),
                "closing a file after a full compile must invalidate the cache so the next COMPILE drops the inlay"
            );
        si

        open_files_reasserted_after_edit__compile_is_skipped() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.send_open_files(["openfilehint.ghul"]);

            analyser.send_edit("openfilehint.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            let first = user_diagnostics_from_compile(analyser);

            // Reassert the same open-file set. Cache invalidation must
            // treat this as a no-op so the compile-skipped fast path
            // remains available.
            analyser.send_open_files(["openfilehint.ghul"]);

            analyser.send_compile();
            let second = user_diagnostics_from_compile(analyser);

            Assert.are_equal(
                first.count,
                second.count,
                "reasserting the same open-file set must not change the diagnostics count\nfirst={first.count}, second={second.count}"
            );
        si
    si
si
