namespace Analysis.Tests is
    use Collections.Iterable;

    use IO.Path;

    use Analysis.Protocol.DIAGNOSTIC;

    // Absolute path to a single fixture file. Fixtures live at
    // fixtures/<group>/<file> under the project root and are copied to the
    // test runner's bin/ via <None Include="fixtures/**/*" CopyToOutputDirectory>
    // in analysis-tests.ghulproj.
    fixture_path(relative_path: string) -> string =>
        Path.combine(
            Path.get_directory_name(System.Reflection.Assembly.get_executing_assembly().location),
            "fixtures",
            relative_path
        );

    // Absolute path to a fixture directory (one level under fixtures/),
    // for multi-file fixtures where the test enumerates / reads several
    // peer files by name.
    fixture_dir(group: string) -> string =>
        Path.combine(
            Path.get_directory_name(System.Reflection.Assembly.get_executing_assembly().location),
            "fixtures",
            group
        );

    // Format a diagnostics list for inclusion in an assertion-failure message.
    diagnostics_summary(label: string, diagnostics: Iterable[DIAGNOSTIC]) -> string is
        let result = System.Text.StringBuilder();

        result.append("{label} ({diagnostics| .count()} diagnostics):\n");

        for d in diagnostics do
            result.append("  {d}\n");
        od

        return result.to_string();
    si
si
