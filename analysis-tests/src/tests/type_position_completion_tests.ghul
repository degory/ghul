namespace Analysis.Tests is
    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Issue #1363: completion in type-expression position must
    // only suggest type-like symbols (classes, traits, structs,
    // enums, namespaces, generic type parameters) and not values
    // (locals, fields, functions, properties, constants) or
    // statement keywords. Value-position completion is unchanged.
    class TYPE_POSITION_COMPLETION_TESTS is
        @test()

        init() is si

        load(name: string) -> string is
            let path = fixture_path("type-position-completion/{name}");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, name: string) is
            analyser.send_edit(name, load(name));

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
        si

        has_completion(response: Response.COMPLETION, name: string) -> bool is
            for item in response.items do
                if item.name =~ name then
                    return true;
                fi
            od

            return false;
        si

        summarize(response: Response.COMPLETION) -> string is
            let names = Collections.LIST[string]();
            for item in response.items do
                names.add("{item.name} (kind={item.kind})");
            od
            return string.join("\n  ", names);
        si

        assert_not_present(
            response: Response.COMPLETION,
            name: string,
            description: string,
            summary: string
        ) is
            Assert.is_false(
                has_completion(response, name),
                "completion in type position should not include "
                "`{name}` ({description}).\nall returned items:\n  {summary}"
            );
        si

        // Cursor sits right after `let x:` on line 17 of
        // let-positions.ghul. The user is about to type a type;
        // only types and namespaces should appear.
        completion_in_let_after_colon_filters_to_types() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "let-positions.ghul");

            // `:` at col 14, cursor at col 15.
            analyser.send_completion("let-positions.ghul", 17, 15);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "WIDGET"),
                "expected sibling class `WIDGET` among type-position "
                "completions.\nall returned items:\n  {summary}"
            );
            Assert.is_true(
                has_completion(response, "LetPositions"),
                "expected enclosing namespace `LetPositions` among type-"
                "position completions.\nall returned items:\n  {summary}"
            );

            assert_not_present(response, "local_variable",     "local variable",     summary);
            assert_not_present(response, "x",                  "local variable",     summary);
            assert_not_present(response, "unrelated_function", "global function",    summary);
            assert_not_present(response, "unrelated_constant", "global property",    summary);
            assert_not_present(response, "in_let_after_colon", "sibling function",   summary);
            assert_not_present(response, "if",                 "statement keyword",  summary);
            assert_not_present(response, "while",              "statement keyword",  summary);
            assert_not_present(response, "return",             "statement keyword",  summary);
            assert_not_present(response, "==",                 "operator",           summary);
            assert_not_present(response, "+",                  "operator",           summary);
        si

        // `let x: Wid` — cursor inside the partial type name. Same
        // rules; partial-name matching happens client-side, the
        // server returns all type-like symbols.
        completion_in_let_partial_name_filters_to_types() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "let-positions.ghul");

            // `Wid` ends at col 18, cursor at col 19 (right after).
            analyser.send_completion("let-positions.ghul", 22, 19);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "WIDGET"),
                "expected sibling class `WIDGET` among type-position "
                "completions for partial `Wid`.\n"
                "all returned items:\n  {summary}"
            );

            assert_not_present(response, "local_variable",     "local variable",    summary);
            assert_not_present(response, "unrelated_function", "global function",   summary);
            assert_not_present(response, "if",                 "statement keyword", summary);
        si

        // `let x: LetPositions.` — namespace member completion in
        // type position. Members of the namespace must be filtered
        // to type-like kinds (no `unrelated_function`).
        completion_in_let_after_dot_filters_namespace_members() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "let-positions.ghul");

            // `LetPositions` ends at col 27, dot at col 28, cursor
            // at col 29 (right after dot).
            analyser.send_completion("let-positions.ghul", 27, 29);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "WIDGET"),
                "expected member class `WIDGET` among namespace members.\n"
                "all returned items:\n  {summary}"
            );

            assert_not_present(response, "unrelated_function", "namespace's global function",   summary);
            assert_not_present(response, "unrelated_constant", "namespace's global property",   summary);
            assert_not_present(response, "in_let_after_colon", "namespace's sibling function",  summary);
        si

        // Function parameter type — `take_param_after_colon(value: )`.
        // Cursor sits in the parameter's type slot.
        completion_in_function_param_type_filters_to_types() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "signature-positions.ghul");

            // Line 10 is `    take_param_after_colon(value: ) -> int => 0;`.
            // `value` ends at col 32, `:` at col 33, cursor at col 34
            // (right after colon).
            analyser.send_completion("signature-positions.ghul", 10, 34);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "WIDGET"),
                "expected `WIDGET` among parameter-type completions.\n"
                "all returned items:\n  {summary}"
            );

            assert_not_present(response, "unrelated_function", "global function",   summary);
            assert_not_present(response, "value",              "parameter name",    summary);
            assert_not_present(response, "if",                 "statement keyword", summary);
        si

        // Partial function parameter type — `take_param_partial(value: Wid)`.
        completion_in_function_param_partial_filters_to_types() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "signature-positions.ghul");

            // Line 12 is `    take_param_partial(value: Wid) -> int => 0;`.
            // 4 spaces + `take_param_partial(` (cols 5-23) + `value`
            // (cols 24-28) + `:` (col 29) + ` ` (col 30) + `Wid`
            // (cols 31-33). Cursor at col 34 (right after `d`).
            analyser.send_completion("signature-positions.ghul", 12, 34);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "WIDGET"),
                "expected `WIDGET` among partial parameter-type completions.\n"
                "all returned items:\n  {summary}"
            );

            assert_not_present(response, "unrelated_function", "global function",  summary);
            assert_not_present(response, "value",              "parameter name",   summary);
        si

        // Function return-type position — `return_after_arrow() -> ;`.
        // The space between `->` and `;` is where the return type
        // would go.
        completion_in_function_return_type_filters_to_types() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "signature-positions.ghul");

            // Line 14 is `    return_after_arrow() -> ;`.
            // 4 spaces + `return_after_arrow()` cols 5-24, ` ` 25,
            // `->` cols 26-27, ` ` col 28, `;` col 29. Cursor at
            // col 28 (the space after `->`).
            analyser.send_completion("signature-positions.ghul", 14, 28);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "WIDGET"),
                "expected `WIDGET` among return-type completions.\n"
                "all returned items:\n  {summary}"
            );

            assert_not_present(response, "unrelated_function", "global function",   summary);
            assert_not_present(response, "if",                 "statement keyword", summary);
        si

        // Generic argument list — `generic_arg_partial(value:
        // Collections.LIST[])`. Cursor inside the `[]` is a
        // generic-type-argument position; only types and namespaces
        // should appear.
        completion_in_generic_arg_list_filters_to_types() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "signature-positions.ghul");

            // Line 16 is `    generic_arg_partial(value: Collections.LIST[]) -> int => 0;`.
            // 4 spaces + `generic_arg_partial(value: Collections.LIST`
            // cols 5-47 + `[` col 48. Cursor at col 49 (right after
            // `[`, inside the brackets).
            analyser.send_completion("signature-positions.ghul", 16, 49);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "WIDGET"),
                "expected sibling class `WIDGET` among generic-argument "
                "completions.\nall returned items:\n  {summary}"
            );

            assert_not_present(response, "unrelated_function", "global function",   summary);
            assert_not_present(response, "value",              "parameter name",    summary);
            assert_not_present(response, "if",                 "statement keyword", summary);
        si

        // Class ancestor list — `class C: A,  is ...`. After the
        // comma the user is naming another ancestor; only types
        // and namespaces should appear.
        completion_in_class_ancestor_list_filters_to_types() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "class-positions.ghul");

            // Line 9 is `    class C: A,  is`.
            // 4 spaces + `class C: A,` cols 5-15 + ` ` 16 + ` ` 17
            // + `is` cols 18-19. Cursor at col 16 (the space right
            // after the comma).
            analyser.send_completion("class-positions.ghul", 9, 16);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "B"),
                "expected sibling trait `B` among ancestor-list completions.\n"
                "all returned items:\n  {summary}"
            );

            assert_not_present(response, "if",                 "statement keyword", summary);
        si

        // Value position — `let y = loc`. Locals must still appear
        // (value-position completion is unchanged from today).
        completion_in_initializer_keeps_values() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "value-positions.ghul");

            // Line 12 is `        let y = loc`. `loc` ends at col 19,
            // cursor at col 20.
            analyser.send_completion("value-positions.ghul", 12, 20);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            Assert.is_true(
                has_completion(response, "local_variable"),
                "value-position completion should still suggest in-scope "
                "locals.\nall returned items:\n  {summary}"
            );
            Assert.is_true(
                has_completion(response, "unrelated_function"),
                "value-position completion should still suggest sibling "
                "functions.\nall returned items:\n  {summary}"
            );
            Assert.is_true(
                has_completion(response, "WIDGET"),
                "value-position completion should still suggest types (a "
                "type can be the receiver of static-member access or a "
                "constructor call).\nall returned items:\n  {summary}"
            );
        si

        // `let pair: (first: int, second: int)` — cursor inside
        // the `second` identifier. The name slot of a
        // NAMED_TUPLE_ELEMENT is where the user is *introducing*
        // a new name, not selecting an existing symbol, so no
        // completion should fire — empty result set.
        completion_in_tuple_element_name_slot_is_empty() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "name-slots.ghul");

            // Line 9 is `        let pair: (first: int, second: int);`.
            // 8 spaces + `let pair: (` cols 9-19, `first` cols 20-24,
            // `: int, ` cols 25-31, `second` cols 32-37. Cursor at
            // col 36 (inside `second`, right after `con`).
            analyser.send_completion("name-slots.ghul", 9, 36);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            assert_not_present(response, "WIDGET",             "type",              summary);
            assert_not_present(response, "unrelated_function", "global function",   summary);
            assert_not_present(response, "first",              "sibling name",      summary);
            assert_not_present(response, "if",                 "statement keyword", summary);
        si

        // `let fn: (arg: int) -> int` — cursor inside the function
        // literal parameter name `arg`. Same rule as tuple element
        // names — no completion at the introducing name.
        completion_in_function_literal_arg_name_slot_is_empty() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, "name-slots.ghul");

            // Line 13 is `        let fn: (arg: int) -> int;`.
            // 8 spaces + `let fn: (` cols 9-17, `arg` cols 18-20.
            // Cursor at col 19 (right after `r` of `arg`).
            analyser.send_completion("name-slots.ghul", 13, 19);
            let response = analyser.read_query_response();
            assert isa Response.COMPLETION(response) else "expected COMPLETION";

            let summary = summarize(response);

            assert_not_present(response, "WIDGET",             "type",              summary);
            assert_not_present(response, "unrelated_function", "global function",   summary);
            assert_not_present(response, "if",                 "statement keyword", summary);
        si
    si
si
