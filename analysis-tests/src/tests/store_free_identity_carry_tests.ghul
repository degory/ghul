namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;
    use Analysis.Protocol.user_diagnostics_of;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // A signature edit re-creates the edited member's symbol. The
    // replacement adopts the outgoing symbol's identity, carrying the
    // id-keyed store-free bit, so the debounced COMPILE's store-free
    // refresh compares its re-derived bits against the value callers
    // were compiled with instead of a default — and does not escalate
    // to a whole-project rebuild when nothing store-free-relevant
    // changed. When the edit also changes the body, the carried bit is
    // reset to the conservative default instead of trusted.
    class STORE_FREE_IDENTITY_CARRY_TESTS is
        @test()

        init() is si

        STORE_FREE_FLIP: string => "store-free-flip";
        COMPILE_RUN: string => "compile-run";
        INTERFACE_INCREMENTAL: string => "edit-path-interface-incremental";
        FULL_REBUILD: string => "edit-path-full-rebuild";

        // `typed` is store-free; `caller` references it, so a signature
        // edit to `typed` is a referenced-declaration replace.
        source_int_param() -> string =>
            "namespace SFCarry is\n"
            "    class PROBE is\n"
            "        v: int public;\n"
            "        init() is si\n"
            "\n"
            "        typed(a: int) -> int => 2;\n"
            "\n"
            "        caller() -> int is\n"
            "            return typed(0);\n"
            "        si\n"
            "    si\n"
            "si\n";

        // Same body (`=> 2;`), renamed parameter: parameter names fold
        // into the interface signature, so this is an interface edit —
        // while the call site's validity is untouched and the store-free
        // character is unchanged.
        source_renamed_param() -> string =>
            "namespace SFCarry is\n"
            "    class PROBE is\n"
            "        v: int public;\n"
            "        init() is si\n"
            "\n"
            "        typed(renamed: int) -> int => 2;\n"
            "\n"
            "        caller() -> int is\n"
            "            return typed(0);\n"
            "        si\n"
            "    si\n"
            "si\n";

        // Signature AND body changed: the parameter is renamed and
        // `typed` now stores to a field. `caller`'s call sits at line 12.
        source_renamed_param_storing() -> string =>
            "namespace SFCarry is\n"
            "    class PROBE is\n"
            "        v: int public;\n"
            "        init() is si\n"
            "\n"
            "        typed(renamed: int) -> int is\n"
            "            v = 7;\n"
            "            return v;\n"
            "        si\n"
            "\n"
            "        caller() -> int is\n"
            "            return typed(0);\n"
            "        si\n"
            "    si\n"
            "si\n";

        edit(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("sf-carry.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response after EDIT";

            let user_diagnostics = LIST[DIAGNOSTIC](user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        compile(analyser: ANALYSER_PROCESS) is
            analyser.send_compile();

            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response after COMPILE";
        si

        // Hover the `typed(0)` call inside `caller` — the kind label
        // renders `pure` exactly when the store-free bit is set.
        typed_hover_label(analyser: ANALYSER_PROCESS, line: int) -> string is
            analyser.send_hover("sf-carry.ghul", line, 22);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";

            if response.kind_label? then
                return response.kind_label;
            fi

            return "";
        si

        // The win this pins: a parameter retype with an unchanged body
        // keeps the carried bit, so the debounced COMPILE sees no flip
        // and skips the whole-project rebuild — while the bit stays
        // correct and visible.
        signature_edit_with_unchanged_body_compiles_without_a_rebuild() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            edit(analyser, source_int_param());
            compile(analyser);

            let baseline = typed_hover_label(analyser, 9);
            Assert.is_true(
                baseline.contains("pure"),
                "baseline: expected `typed` to render as pure, got '{baseline}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let flips_before = analyser.stat_count(STORE_FREE_FLIP);
            let runs_before = analyser.stat_count(COMPILE_RUN);
            let incremental_before = analyser.stat_count(INTERFACE_INCREMENTAL);
            let full_before = analyser.stat_count(FULL_REBUILD);

            edit(analyser, source_renamed_param());
            compile(analyser);

            Assert.are_equal(
                incremental_before + 1,
                analyser.stat_count(INTERFACE_INCREMENTAL),
                "the signature edit should take the incremental interface path\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(
                full_before,
                analyser.stat_count(FULL_REBUILD),
                "the signature edit must not fall back to the whole-project rebuild\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(
                flips_before,
                analyser.stat_count(STORE_FREE_FLIP),
                "an unchanged body must not flip the carried store-free bit\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(
                runs_before,
                analyser.stat_count(COMPILE_RUN),
                "no flip - the debounced COMPILE must not escalate to the full rebuild branch\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let after = typed_hover_label(analyser, 9);
            Assert.is_true(
                after.contains("pure"),
                "after the signature edit `typed` should still render as pure, got '{after}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // The guard this pins: when the edit also changes the body, the
        // carried bit is reset rather than trusted — the hover stops
        // rendering pure immediately after the COMPILE. The refresh then
        // still escalates, correctly: `caller` is a retained symbol whose
        // own store-free bit was derived while `typed` was pure, so
        // `typed` turning storing flips `caller`'s bit transitively, and
        // that flip is exactly what the rebuild must true up.
        signature_edit_with_changed_body_resets_the_carried_bit() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            edit(analyser, source_int_param());
            compile(analyser);

            let baseline = typed_hover_label(analyser, 9);
            Assert.is_true(
                baseline.contains("pure"),
                "baseline: expected `typed` to render as pure, got '{baseline}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let flips_before = analyser.stat_count(STORE_FREE_FLIP);

            edit(analyser, source_renamed_param_storing());
            compile(analyser);

            let after = typed_hover_label(analyser, 12);
            Assert.is_true(
                !after.contains("pure"),
                "after the storing edit `typed` must not render as pure, got '{after}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(
                flips_before + 1,
                analyser.stat_count(STORE_FREE_FLIP),
                "callers' bits derived against the previously-pure callee must flip and escalate\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // The conservative direction: an edit that changes both the
        // signature and the body to something newly store-free resets
        // the bit, so the refresh derives true against a false baseline
        // and escalates — the rebuild that trues callers up.
        signature_edit_turning_body_store_free_escalates() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            edit(analyser, source_renamed_param_storing());
            compile(analyser);

            let baseline = typed_hover_label(analyser, 12);
            Assert.is_true(
                !baseline.contains("pure"),
                "baseline: expected storing `typed` to not render as pure, got '{baseline}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let flips_before = analyser.stat_count(STORE_FREE_FLIP);

            edit(analyser, source_int_param());
            compile(analyser);

            Assert.are_equal(
                flips_before + 1,
                analyser.stat_count(STORE_FREE_FLIP),
                "the newly store-free body must be detected by the refresh and escalate\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let after = typed_hover_label(analyser, 9);
            Assert.is_true(
                after.contains("pure"),
                "after the rebuild `typed` should render as pure, got '{after}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
