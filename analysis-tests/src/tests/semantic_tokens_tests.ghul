namespace Analysis.Tests is
    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Drives the semantic_tokens command: prime the analyser with a fixture,
    // request semantic tokens, and assert the token output is plausible.
    //
    // Each token carries 1-based start/end line and column, an LSP token-type
    // string, and a comma-separated (possibly empty) modifiers string.
    class SEMANTIC_TOKENS_TESTS is
        @test()

        init() is si

        load_fixture(name: string) -> string is
            let path = fixture_path(name);
            assert File.exists(path) else "fixture missing: {path}";
            return File.read_all_text(path);
        si

        send_edit_and_compile(analyser: ANALYSER_PROCESS, path: string, source: string) is
            analyser.send_edit(path, source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(compile_diagnostics) else "expected DIAGNOSTICS response";
        si

        // After priming, semantic_tokens for the file returns at least one
        // token, and every token carries a non-empty token type.
        semantic_tokens_returns_tokens_for_fixture() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("object-oriented/object-oriented.ghul");

            send_edit_and_compile(analyser, "object-oriented.ghul", source);

            analyser.send_semantic_tokens("object-oriented.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            Assert.is_true(
                response.tokens.count > 0,
                "semantic_tokens returned no tokens for object-oriented fixture"
            );

            for token in response.tokens do
                Assert.is_true(
                    token.token_type? /\ token.token_type.length > 0,
                    "semantic_tokens token has no type"
                );
            od
        si

        // The fixture has a class named CALCULATOR; at least one token should
        // carry the `class` token type.
        semantic_tokens_include_class_token() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("object-oriented/object-oriented.ghul");

            send_edit_and_compile(analyser, "object-oriented.ghul", source);

            analyser.send_semantic_tokens("object-oriented.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let saw_class mut = false;

            for token in response.tokens do
                if token.token_type =~ "class" then
                    saw_class = true;
                fi
            od

            Assert.is_true(
                saw_class,
                "expected a class token in semantic_tokens output"
            );
        si

        // semantic_tokens works without a prior explicit COMPILE — the handler
        // falls back to compiling when the hover map is empty.
        semantic_tokens_without_compile_falls_back() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("object-oriented/object-oriented.ghul");

            analyser.send_edit("object-oriented.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            analyser.send_semantic_tokens("object-oriented.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            Assert.is_true(
                response.tokens.count > 0,
                "semantic_tokens without prior COMPILE returned no tokens"
            );
        si

        // Constructor-call positions: the fixture constructs objects; tokens
        // should include at least one class/struct token at a construction.
        semantic_tokens_cover_constructor_calls() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("constructor-call-tokens/constructor-call-tokens.ghul");

            send_edit_and_compile(analyser, "constructor-call-tokens.ghul", source);

            analyser.send_semantic_tokens("constructor-call-tokens.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let saw_constructor_type mut = false;

            for token in response.tokens do
                if token.token_type =~ "class" \/ token.token_type =~ "struct" then
                    saw_constructor_type = true;
                fi
            od

            Assert.is_true(
                saw_constructor_type,
                "expected a class/struct token at a constructor call"
            );
        si

        // Variable / parameter tokens: the fixture has locals and parameters;
        // at least one variable or parameter token should appear.
        semantic_tokens_include_variable_or_parameter() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("object-oriented/object-oriented.ghul");

            send_edit_and_compile(analyser, "object-oriented.ghul", source);

            analyser.send_semantic_tokens("object-oriented.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let saw_variable mut = false;

            for token in response.tokens do
                if token.token_type =~ "variable" \/ token.token_type =~ "parameter" then
                    saw_variable = true;
                fi
            od

            Assert.is_true(
                saw_variable,
                "expected a variable or parameter token"
            );
        si

        // The inference-hover fixture declares `FACTORY.wrap` as a static
        // method, so at least one method token should carry the `static`
        // modifier. Pins SEMANTIC_TOKEN_CLASSIFIER's static detection.
        semantic_tokens_marks_static_modifier() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("inference-hover/inference-hover.ghul");

            send_edit_and_compile(analyser, "inference-hover.ghul", source);

            analyser.send_semantic_tokens("inference-hover.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let saw_static_method mut = false;

            for token in response.tokens do
                if token.token_type =~ "method" /\ token.modifiers.contains("static") then
                    saw_static_method = true;
                fi
            od

            Assert.is_true(
                saw_static_method,
                "expected a method token with the static modifier"
            );
        si

        // The inference-hover fixture declares many `let x = ...` immutable
        // locals (no `mut`). An immutable local cannot be reassigned, so it
        // carries the `readonly` modifier. Pins the immutable-locals mark.
        semantic_tokens_mark_immutable_locals_readonly() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("inference-hover/inference-hover.ghul");

            send_edit_and_compile(analyser, "inference-hover.ghul", source);

            analyser.send_semantic_tokens("inference-hover.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let saw_readonly_variable mut = false;

            for token in response.tokens do
                if token.token_type =~ "variable" /\ token.modifiers? /\ token.modifiers.contains("readonly") then
                    saw_readonly_variable = true;
                fi
            od

            Assert.is_true(
                saw_readonly_variable,
                "expected a variable token with the readonly modifier"
            );
        si

        // Pack a 1-based (line, column) into a single int for lexicographic
        // comparison. Values fit comfortably in 32 bits for any source we
        // analyse.
        pack(line: int, column: int) -> int => line * 100000 + column;

        // Strict-containment filter (`_filter_outer_spans` in
        // SEMANTICTOKENS_HANDLER): the let-await desugar produces a wide
        // synthetic span that strictly covers the user identifier, so the
        // filter should drop the outer span. Assert no semantic token
        // strictly contains another, single-line or across lines.
        semantic_tokens_filters_wide_outer_spans() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("let-await-tokens/let-await-tokens.ghul");

            analyser.send_edit("let-await-tokens.ghul", source);
            // Drain the EDIT diagnostics without asserting them — Tasks
            // references may not resolve without full assembly context,
            // but the parser still registers hover uses.
            analyser.read_response();

            analyser.send_semantic_tokens("let-await-tokens.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            for outer in response.tokens do
                let outer_start = pack(outer.start_line, outer.start_column);
                let outer_end = pack(outer.end_line, outer.end_column);

                for inner in response.tokens do
                    let inner_start = pack(inner.start_line, inner.start_column);
                    let inner_end = pack(inner.end_line, inner.end_column);

                    // When outer and inner share a span (incl. the
                    // diagonal of the cross product), the disjunction
                    // below is false — no skip-self check needed.
                    let strictly_contains =
                        outer_start <= inner_start /\
                        outer_end >= inner_end /\
                        (outer_start < inner_start \/ outer_end > inner_end);

                    Assert.is_false(
                        strictly_contains,
                        "semantic-token span strictly contains another:\n  outer: ({outer.start_line},{outer.start_column})-({outer.end_line},{outer.end_column}) {outer.token_type}\n  inner: ({inner.start_line},{inner.start_column})-({inner.end_line},{inner.end_column}) {inner.token_type}"
                    );
                od
            od
        si

        // Pins the #1400 fix: `BOX(1)` and `BOX[int](2)` both resolve to
        // the BOX constructor, so the BOX identifier should carry a
        // `method` token at its exact 1-based source position and width
        // (three characters wide → inclusive end_column == start_column +
        // 2). Without the fix the explicit-generic form coloured BOX as a
        // `class` token; the assertion catches a regression in either
        // direction by also pinning the width, so a chance `method` row
        // from `.get()` etc. on the same line can't pass the check.
        semantic_tokens_color_constructor_calls_consistently() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("constructor-call-tokens/constructor-call-tokens.ghul");

            analyser.send_edit("constructor-call-tokens.ghul", source);
            analyser.read_response();

            analyser.send_semantic_tokens("constructor-call-tokens.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            // The fixture sits `let bare = BOX(1);` on line 9 with `BOX`
            // starting at column 20, and `let explicit = BOX[int](2);` on
            // line 10 with `BOX` starting at column 24.
            let bare_line = 9;
            let bare_column = 20;
            let explicit_line = 10;
            let explicit_column = 24;

            let found_bare mut = false;
            let found_explicit mut = false;

            for token in response.tokens do
                if token.token_type !~ "method" \/ token.end_column - token.start_column != 2 then
                    continue;
                fi

                if token.start_line == bare_line /\ token.start_column == bare_column then
                    found_bare = true;
                elif token.start_line == explicit_line /\ token.start_column == explicit_column then
                    found_explicit = true;
                fi
            od

            Assert.is_true(
                found_bare,
                "expected a 3-char method token for BOX at line {bare_line}, column {bare_column}"
            );
            Assert.is_true(
                found_explicit,
                "expected a 3-char method token for BOX at line {explicit_line}, column {explicit_column}"
            );
        si

        // An innate operator (`+` on int) classifies as `operator`, not
        // `method` — the built-in operators read as operators even though
        // they resolve to functions underneath.
        semantic_tokens_classify_innate_operator_as_operator() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("operator-tokens/operator-tokens.ghul");

            send_edit_and_compile(analyser, "operator-tokens.ghul", source);

            analyser.send_semantic_tokens("operator-tokens.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let plus_line = 5;
            let plus_column = 18;

            let found_operator mut = false;

            for token in response.tokens do
                if
                    token.token_type =~ "operator" /\
                    token.start_line == plus_line /\
                    token.start_column == plus_column
                then
                    found_operator = true;
                fi
            od

            Assert.is_true(
                found_operator,
                "expected an `operator` token for `+` at line {plus_line}, column {plus_column}"
            );
        si

        // User-defined operators — both an overload of a standard
        // operator (`+` on a user type) and a novel operator (`##`) —
        // are ordinary functions, so they keep the `function` type,
        // not `operator`. Only the built-in innate operators read as
        // operators.
        semantic_tokens_classify_user_operators_as_functions() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("user-operator-tokens/user-operator-tokens.ghul");

            send_edit_and_compile(analyser, "user-operator-tokens.ghul", source);

            analyser.send_semantic_tokens("user-operator-tokens.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            assert_operator_token_type(response, 18, 29, "function", "user overload of `+`");
            assert_operator_token_type(response, 19, 19, "function", "novel operator `##`");
        si

        // Contextual modifier keywords (`init`, `open`) look like
        // identifiers to the tokenizer, so tmLanguage can't safely colour
        // them. The compiler emits a `keyword` semantic token at each
        // location where the parser accepted one as a modifier.
        semantic_tokens_emit_keyword_at_contextual_modifiers() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("modifier-keyword-tokens/modifier-keyword-tokens.ghul");

            send_edit_and_compile(analyser, "modifier-keyword-tokens.ghul", source);

            analyser.send_semantic_tokens("modifier-keyword-tokens.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            assert_operator_token_type(response, 2, 17, "keyword", "`open` on Shape");
            assert_operator_token_type(response, 8, 24, "keyword", "`init` on _label");
        si

        assert_operator_token_type(
            response: Response.SEMANTIC_TOKENS,
            line: int,
            column: int,
            expected_type: string,
            where: string
        ) is
            let actual_type: string mut = "";

            for token in response.tokens do
                if token.start_line == line /\ token.start_column == column then
                    actual_type = token.token_type;
                fi
            od

            Assert.are_equal(
                expected_type,
                actual_type,
                "{where}: expected token type '{expected_type}' at line {line}, column {column}, got '{actual_type}'"
            );
        si

        // An immutable local or argument cannot be reassigned, so it carries
        // `readonly`; a `mut` one does not. Fields and properties are plain
        // `property` (freely assignable, no modifier); an immutable local is
        // a `variable` with `readonly`; a `mut` local is a plain `variable`.
        semantic_tokens_mark_readonly_on_immutable_locals_not_mutable() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("field-property-tokens/field-property-tokens.ghul");

            send_edit_and_compile(analyser, "field-property-tokens.ghul", source);

            analyser.send_semantic_tokens("field-property-tokens.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            assert_token(response, 5, 9, "property", false, "field `count`");
            assert_token(response, 6, 9, "property", false, "property `label`");
            assert_token(response, 14, 13, "variable", true, "immutable local `b`");
            assert_token(response, 15, 13, "variable", false, "mutable local `total`");
        si

        // Arguments mirror locals: an immutable argument is a `variable`
        // (not `parameter`) with `readonly`; a `mut` argument is a plain
        // `variable`. Classifying arguments as `variable` lets them share a
        // local's colouring rather than diverging as `parameter`.
        semantic_tokens_mark_readonly_on_immutable_arguments_not_mutable() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("parameter-tokens/parameter-tokens.ghul");

            send_edit_and_compile(analyser, "parameter-tokens.ghul", source);

            analyser.send_semantic_tokens("parameter-tokens.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            assert_token(response, 4, 14, "variable", true, "immutable argument `text`");
            assert_token(response, 4, 28, "variable", false, "mutable argument `n`");
        si

        assert_token(
            response: Response.SEMANTIC_TOKENS,
            line: int,
            column: int,
            expected_type: string,
            expected_readonly: bool,
            where: string
        ) is
            let found mut = false;
            let actual_type: string mut = "";
            let actual_readonly mut = false;

            for token in response.tokens do
                if token.start_line == line /\ token.start_column == column then
                    found = true;
                    actual_type = token.token_type;
                    actual_readonly = token.modifiers? /\ token.modifiers.contains("readonly");
                fi
            od

            Assert.is_true(found, "{where}: no token at line {line}, column {column}");

            Assert.are_equal(
                expected_type,
                actual_type,
                "{where}: expected token type '{expected_type}' at line {line}, column {column}, got '{actual_type}'"
            );

            Assert.are_equal(
                expected_readonly,
                actual_readonly,
                "{where}: expected readonly={expected_readonly} at line {line}, column {column}"
            );
        si
    si
si
