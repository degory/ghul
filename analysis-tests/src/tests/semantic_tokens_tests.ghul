namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // #SEMANTICTOKENS# dumps every recorded symbol use for a file as
    // tab-separated `startLine startColumn endLine endColumn tokenType
    // modifiers` rows. It is the data source for VS Code's semantic-token
    // provider for ghūl. These tests drive an EDIT over the inference-hover
    // fixture, then assert the framing and that representative kinds are
    // emitted.
    class SEMANTIC_TOKENS_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("inference-hover/inference-hover.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("inference-hover.ghul", source);

            let diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", diagnostics.header);

            let user_diagnostics = LIST(diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );

            let partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", partial_done.header);
        si

        semantic_tokens_rows(analyser: ANALYSER_PROCESS) -> LIST[string] is
            analyser.send_semantic_tokens("inference-hover.ghul");

            let response = analyser.read_query_response();
            Assert.are_equal("SEMANTICTOKENS", response.header);

            return LIST[string](response.lines);
        si

        // The frame arrives as a SEMANTICTOKENS header with many rows for
        // a non-trivial file.
        semantic_tokens_returns_rows_for_file() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let rows = semantic_tokens_rows(analyser);

            Assert.is_true(
                rows.count > 0,
                "SEMANTICTOKENS returned no rows\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // Every row is `startLine startColumn endLine endColumn tokenType
        // modifiers` — four non-negative integer coordinates then a non-
        // empty token-type string then a (possibly empty) modifiers string.
        semantic_tokens_rows_are_well_formed() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let rows = semantic_tokens_rows(analyser);

            for row in rows do
                let fields = LIST[string](row.split(['\t']));

                Assert.are_equal(
                    6,
                    fields.count,
                    "expected 6 tab-separated fields, got {fields.count}: '{row}'"
                );

                for i in 0..4 do
                    let coordinate = System.Convert.to_int32(fields[i]);
                    Assert.is_true(
                        coordinate >= 0,
                        "coordinate field {i} not a non-negative integer: '{row}'"
                    );
                od

                Assert.is_true(
                    fields[4].length > 0,
                    "empty token type: '{row}'"
                );
            od
        si

        // The fixture exercises classes, methods, fields, variables, type
        // parameters and namespaces. Each of these LSP-mappable kinds must
        // appear in the frame.
        semantic_tokens_carries_representative_kinds() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let rows = semantic_tokens_rows(analyser);

            assert_kind_present(rows, "class");
            assert_kind_present(rows, "method");
            assert_kind_present(rows, "variable");
            assert_kind_present(rows, "typeParameter");
            assert_kind_present(rows, "namespace");
            assert_kind_present(rows, "parameter");
        si

        // FACTORY.wrap is declared `static`, so the resolved use of `wrap`
        // must carry the `static` modifier.
        semantic_tokens_marks_static_modifier() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let rows = semantic_tokens_rows(analyser);

            let found mut = false;

            for row in rows do
                if row.contains("\tmethod\tstatic") then
                    found = true;
                    break;
                fi
            od

            Assert.is_true(
                found,
                "SEMANTICTOKENS carried no method row with static modifier\n--- rows ---\n{rows | .to_string("\n")}"
            );
        si

        // Bare `let` is immutable, so locals (variables/parameters) on
        // the inference-hover fixture — none of which use `mut` — must
        // carry the `readonly` modifier.
        semantic_tokens_marks_readonly_on_immutable_locals() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let rows = semantic_tokens_rows(analyser);

            let found_readonly_variable mut = false;

            for row in rows do
                if row.contains("\tvariable\t") /\ row.contains("readonly") then
                    found_readonly_variable = true;
                    break;
                fi
            od

            Assert.is_true(
                found_readonly_variable,
                "SEMANTICTOKENS carried no readonly variable row\n--- rows ---\n{rows | .to_string("\n")}"
            );
        si

        // A SEMANTICTOKENS request on a freshly-edited file must return
        // tokens immediately — unlike HOVERMAP, the handler falls back
        // to a full compile when the hover map is empty so the IDE
        // doesn't show TextMate-only coloring until the first edit.
        semantic_tokens_after_edit_only_returns_tokens() is
            @test()

            // EDIT followed directly by SEMANTICTOKENS — no separate
            // #COMPILE# in between. The handler must internally drive
            // compile_all on cold cache.
            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let rows = semantic_tokens_rows(analyser);

            // After the cold-cache fallback we still expect a class
            // row for BOX — the fixture's most prominent type.
            assert_kind_present(rows, "class");
        si

        // The `let await` desugar synthesizes a continuation lambda
        // and an `unwrap(...)` call whose AST nodes would, without
        // intervention, register hover uses spanning the whole
        // statement. Two layers of defense keep these out of the
        // semantic-tokens frame: (1) the desugar gives every
        // synthesized Identifier a LOCATION.internal so `_add_use`
        // drops them at registration time; (2) the SEMANTICTOKENS
        // handler also filters any hover use whose span strictly
        // contains another, as defense-in-depth for any future
        // desugar that doesn't (or can't) hide its scaffolding.
        // Either layer alone satisfies the "no row strictly
        // contains another" invariant asserted below.
        semantic_tokens_filters_wide_desugar_spans() is
            @test()

            let path = fixture_path("let-await-tokens/let-await-tokens.ghul");
            let source = IO.File.read_all_text(path);
            assert source? else "fixture missing: {path}";

            let use analyser = ANALYSER_PROCESS();
            analyser.send_edit("let-await-tokens.ghul", source);

            // Drain the EDIT response shape without failing on
            // diagnostics — Tasks references may not be resolvable
            // without the full assembly context, but the parser
            // and rewrite still register hover uses.
            analyser.read_response();
            analyser.read_response();

            analyser.send_semantic_tokens("let-await-tokens.ghul");
            let response = analyser.read_query_response();
            Assert.are_equal("SEMANTICTOKENS", response.header);

            let rows = LIST[string](response.lines);

            // No row may strictly contain another, regardless of whether
            // they sit on the same line or span across lines. (line, col)
            // pairs are compared lexicographically.
            for outer in rows do
                let outer_fields = LIST[string](outer.split(['\t']));

                if outer_fields.count < 6 then
                    continue;
                fi

                let outer_start = pack(outer_fields[0], outer_fields[1]);
                let outer_end   = pack(outer_fields[2], outer_fields[3]);

                for inner in rows do
                    if inner =~ outer then
                        continue;
                    fi

                    let inner_fields = LIST[string](inner.split(['\t']));

                    if inner_fields.count < 6 then
                        continue;
                    fi

                    let inner_start = pack(inner_fields[0], inner_fields[1]);
                    let inner_end   = pack(inner_fields[2], inner_fields[3]);

                    let strictly_contains =
                        outer_start <= inner_start /\
                        outer_end >= inner_end /\
                        (outer_start < inner_start \/ outer_end > inner_end);

                    Assert.is_false(
                        strictly_contains,
                        "SEMANTICTOKENS row strictly contains another:\n  outer: '{outer}'\n  inner: '{inner}'"
                    );
                od
            od
        si

        // Same filter, exercised against a desugared expression whose
        // synthesized AST node spans MULTIPLE lines. The earlier line-
        // based filter let those through unfiltered (the VSCE happened
        // to drop multi-line tokens at decode time, but the compiler
        // shouldn't depend on that). The lex-ordered filter handles
        // them uniformly.
        semantic_tokens_filters_wide_desugar_spans_across_lines() is
            @test()

            let path = fixture_path("let-await-multiline/let-await-multiline.ghul");
            let source = IO.File.read_all_text(path);
            assert source? else "fixture missing: {path}";

            let use analyser = ANALYSER_PROCESS();
            analyser.send_edit("let-await-multiline.ghul", source);

            analyser.read_response();
            analyser.read_response();

            analyser.send_semantic_tokens("let-await-multiline.ghul");
            let response = analyser.read_query_response();
            Assert.are_equal("SEMANTICTOKENS", response.header);

            let rows = LIST[string](response.lines);

            for outer in rows do
                let outer_fields = LIST[string](outer.split(['\t']));

                if outer_fields.count < 6 then
                    continue;
                fi

                let outer_start = pack(outer_fields[0], outer_fields[1]);
                let outer_end   = pack(outer_fields[2], outer_fields[3]);

                for inner in rows do
                    if inner =~ outer then
                        continue;
                    fi

                    let inner_fields = LIST[string](inner.split(['\t']));

                    if inner_fields.count < 6 then
                        continue;
                    fi

                    let inner_start = pack(inner_fields[0], inner_fields[1]);
                    let inner_end   = pack(inner_fields[2], inner_fields[3]);

                    let strictly_contains =
                        outer_start <= inner_start /\
                        outer_end >= inner_end /\
                        (outer_start < inner_start \/ outer_end > inner_end);

                    Assert.is_false(
                        strictly_contains,
                        "SEMANTICTOKENS row strictly contains another:\n  outer: '{outer}'\n  inner: '{inner}'"
                    );
                od
            od
        si

        // The desugar marks its synthesized identifiers as
        // LOCATION.internal so the scaffolding is invisible to HOVER
        // and SEMANTICTOKENS, but the user's actual identifiers
        // (`bound_name`, `e`, post-body statements) must still
        // register hover info as normal. HOVERMAP — which dumps every
        // recorded hover for a file — is the direct check.
        hover_map_still_has_user_identifiers_in_let_await() is
            @test()

            let path = fixture_path("let-await-tokens/let-await-tokens.ghul");
            let source = IO.File.read_all_text(path);
            assert source? else "fixture missing: {path}";

            let use analyser = ANALYSER_PROCESS();
            analyser.send_edit("let-await-tokens.ghul", source);

            analyser.read_response();
            analyser.read_response();

            analyser.send_hover_map("let-await-tokens.ghul");
            let response = analyser.read_query_response();
            Assert.are_equal("HOVERMAP", response.header);

            let rows = LIST[string](response.lines);

            // The user's binding `x` must have a HOVER row whose
            // description mentions `x` typed (e.g. "x: Ghul.int //
            // local value"). Without that, hovering on `x` in the
            // editor would show nothing.
            let found_x mut = false;

            // The user's free-function call `fetch_int()` must also
            // surface in the hover map.
            let found_fetch_int mut = false;

            // And the scaffolding must NOT — searching for telltale
            // synthesized names that would only appear if the
            // desugar's hover suppression broke.
            let found_unwrap mut = false;
            let found_continue_with mut = false;
            let found_task_extensions mut = false;

            for row in rows do
                if row.contains("\tx:") then
                    found_x = true;
                fi
                if row.contains("fetch_int") then
                    found_fetch_int = true;
                fi
                if row.contains("unwrap") then
                    found_unwrap = true;
                fi
                if row.contains("continue_with") then
                    found_continue_with = true;
                fi
                if row.contains("TaskExtensions") then
                    found_task_extensions = true;
                fi
            od

            Assert.is_true(
                found_x,
                "HOVERMAP missing user binding `x`\n--- rows ---\n{rows | .to_string("\n")}"
            );

            Assert.is_true(
                found_fetch_int,
                "HOVERMAP missing user call `fetch_int`\n--- rows ---\n{rows | .to_string("\n")}"
            );

            Assert.is_false(
                found_unwrap,
                "HOVERMAP leaked synthesized `unwrap`\n--- rows ---\n{rows | .to_string("\n")}"
            );

            Assert.is_false(
                found_continue_with,
                "HOVERMAP leaked synthesized `continue_with`\n--- rows ---\n{rows | .to_string("\n")}"
            );

            Assert.is_false(
                found_task_extensions,
                "HOVERMAP leaked synthesized `TaskExtensions`\n--- rows ---\n{rows | .to_string("\n")}"
            );
        si

        // Pack (line, column) as the compiler does — line in high 20
        // bits, column in low 12 — so the result is lex-comparable as
        // an int. Mirrors Source.LOCATION.pair.
        pack(line_str: string, column_str: string) -> long is
            let line: long = cast long(System.Convert.to_int32(line_str));
            let column: long = cast long(System.Convert.to_int32(column_str));

            return (line << 12L) | column;
        si

        // A constructor call colors the type identifier as the
        // constructor function regardless of whether the call site
        // wrote the type arguments explicitly. `BOX(1)` and
        // `BOX[int](2)` must both produce a `method` row whose start
        // column lands on the `BOX` token. Before #1400 the
        // explicit-generic form recorded its constructor use at the
        // whole `BOX[int]` span; the containment filter then dropped
        // that wider row, leaving only the narrow `class` use
        // registered by `compile_generic_application` — which
        // coloured `BOX` as a class only when the user wrote out the
        // type arguments. The narrow `right_location` on
        // `GENERIC_APPLICATION` / `AMBIGUOUS_EXPRESSION` puts both
        // forms on the same single-token span, the
        // function-over-class tie-break in `hover_uses_in_file` then
        // picks the constructor for both.
        semantic_tokens_color_constructor_calls_consistently() is
            @test()

            let path = fixture_path("constructor-call-tokens/constructor-call-tokens.ghul");
            let source = IO.File.read_all_text(path);
            assert source? else "fixture missing: {path}";

            let use analyser = ANALYSER_PROCESS();
            analyser.send_edit("constructor-call-tokens.ghul", source);
            analyser.read_response();
            analyser.read_response();

            analyser.send_semantic_tokens("constructor-call-tokens.ghul");
            let response = analyser.read_query_response();
            Assert.are_equal("SEMANTICTOKENS", response.header);

            let rows = LIST[string](response.lines);

            // `BOX(1)` sits on line 9 of the fixture (1-based) at
            // column 20; `BOX[int](2)` on line 10 at column 24. Both
            // identifiers are three characters wide. The compiler
            // emits end_column 1-based inclusive, so end - start = 2
            // for a `BOX` token — assert the width too so a chance
            // `method` row from `.get()` etc. on the same line can't
            // pass the check.
            let bare_line = 9;
            let bare_column = 20;
            let explicit_line = 10;
            let explicit_column = 24;

            let found_bare mut = false;
            let found_explicit mut = false;

            for row in rows do
                let fields = LIST[string](row.split(['\t']));
                if fields.count < 5 then
                    continue;
                fi

                let start_line = System.Convert.to_int32(fields[0]);
                let start_column = System.Convert.to_int32(fields[1]);
                let end_column = System.Convert.to_int32(fields[3]);
                let kind = fields[4];

                if !(kind =~ "method") \/ end_column - start_column != 2 then
                    continue;
                fi

                if start_line == bare_line /\ start_column == bare_column then
                    found_bare = true;
                elif start_line == explicit_line /\ start_column == explicit_column then
                    found_explicit = true;
                fi
            od

            Assert.is_true(
                found_bare,
                "bare BOX(1) did not produce a method row at {bare_line}:{bare_column}\n--- rows ---\n{rows | .to_string("\n")}"
            );

            Assert.is_true(
                found_explicit,
                "explicit BOX[int](2) did not produce a method row at {explicit_line}:{explicit_column}\n--- rows ---\n{rows | .to_string("\n")}"
            );
        si

        assert_kind_present(rows: LIST[string], kind: string) is
            let needle_with_modifiers = "\t{kind}\t";
            let needle_no_modifiers = "\t{kind}";

            let found mut = false;

            for row in rows do
                if row.contains(needle_with_modifiers) \/ row.ends_with(needle_no_modifiers) then
                    found = true;
                    break;
                fi
            od

            Assert.is_true(
                found,
                "SEMANTICTOKENS missing kind {kind}\n--- rows ---\n{rows | .to_string("\n")}"
            );
        si
    si
si
