namespace Analysis.Tests is
    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Drives the semantic_tokens command: prime the analyser with a fixture,
    // request semantic tokens, and assert the token output is plausible.
    //
    // Each token carries 1-based start/end line and column, an LSP token-type
    // string, and a comma-separated (possibly empty) modifiers string.
    class SEMANTIC_TOKENS_TESTS is
        @test()

        init() is si

        load_fixture(name: string) -> string is
            let path = fixture_path(name);
            assert File.exists(path) else "fixture missing: {path}";
            return File.read_all_text(path);
        si

        send_edit_and_compile(analyser: ANALYSER_PROCESS, path: string, source: string) is
            analyser.send_edit(path, source);

            let diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", diagnostics.kind);

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", compile_diagnostics.kind);
        si

        // After priming, semantic_tokens for the file returns at least one
        // token, and every token carries a non-empty token type.
        semantic_tokens_returns_tokens_for_fixture() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("object-oriented/object-oriented.ghul");

            send_edit_and_compile(analyser, "object-oriented.ghul", source);

            analyser.send_semantic_tokens("object-oriented.ghul");

            let response = analyser.read_response();
            Assert.are_equal("semantic_tokens", response.kind);

            Assert.is_true(
                response.tokens.count > 0,
                "semantic_tokens returned no tokens for object-oriented fixture"
            );

            for token in response.tokens do
                Assert.is_true(
                    token.token_type? /\ token.token_type.length > 0,
                    "semantic_tokens token has no type"
                );
            od
        si

        // The fixture has a class named CALCULATOR; at least one token should
        // carry the `class` token type.
        semantic_tokens_include_class_token() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("object-oriented/object-oriented.ghul");

            send_edit_and_compile(analyser, "object-oriented.ghul", source);

            analyser.send_semantic_tokens("object-oriented.ghul");

            let response = analyser.read_response();
            Assert.are_equal("semantic_tokens", response.kind);

            let saw_class mut = false;

            for token in response.tokens do
                if token.token_type =~ "class" then
                    saw_class = true;
                fi
            od

            Assert.is_true(
                saw_class,
                "expected a class token in semantic_tokens output"
            );
        si

        // semantic_tokens works without a prior explicit COMPILE — the handler
        // falls back to compiling when the hover map is empty.
        semantic_tokens_without_compile_falls_back() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("object-oriented/object-oriented.ghul");

            analyser.send_edit("object-oriented.ghul", source);

            let diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", diagnostics.kind);

            analyser.send_semantic_tokens("object-oriented.ghul");

            let response = analyser.read_response();
            Assert.are_equal("semantic_tokens", response.kind);

            Assert.is_true(
                response.tokens.count > 0,
                "semantic_tokens without prior COMPILE returned no tokens"
            );
        si

        // Constructor-call positions: the fixture constructs objects; tokens
        // should include at least one class/struct token at a construction.
        semantic_tokens_cover_constructor_calls() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("constructor-call-tokens/constructor-call-tokens.ghul");

            send_edit_and_compile(analyser, "constructor-call-tokens.ghul", source);

            analyser.send_semantic_tokens("constructor-call-tokens.ghul");

            let response = analyser.read_response();
            Assert.are_equal("semantic_tokens", response.kind);

            let saw_constructor_type mut = false;

            for token in response.tokens do
                if token.token_type =~ "class" \/ token.token_type =~ "struct" then
                    saw_constructor_type = true;
                fi
            od

            Assert.is_true(
                saw_constructor_type,
                "expected a class/struct token at a constructor call"
            );
        si

        // Variable / parameter tokens: the fixture has locals and parameters;
        // at least one variable or parameter token should appear.
        semantic_tokens_include_variable_or_parameter() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let source = load_fixture("object-oriented/object-oriented.ghul");

            send_edit_and_compile(analyser, "object-oriented.ghul", source);

            analyser.send_semantic_tokens("object-oriented.ghul");

            let response = analyser.read_response();
            Assert.are_equal("semantic_tokens", response.kind);

            let saw_variable mut = false;

            for token in response.tokens do
                if token.token_type =~ "variable" \/ token.token_type =~ "parameter" then
                    saw_variable = true;
                fi
            od

            Assert.is_true(
                saw_variable,
                "expected a variable or parameter token"
            );
        si
    si
si
