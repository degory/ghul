namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.RESPONSE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    class COMPILE_AFTER_EDIT_TESTS is
        @test()

        init() is si

        // Smoking-gun reproducer for the analysis-mode false-positive on the
        // object-oriented example: a clean EDIT response is followed by a
        // COMPILE response containing two false errors about `Operation[T]`
        // generic argument identity. The build-mode compiler reports zero
        // errors on the same source. The bug manifests after `clear_symbols()`
        // rebinds class type parameters but AST nodes still reference the
        // pre-clear instances.
        //
        // This test is expected to FAIL today and PASS once the
        // identity-loss-on-clear bug is fixed.
        object_oriented_example_should_compile_clean_after_edit_then_compile() is
            @test()

            let source_path = fixture_path("object-oriented/object-oriented.ghul");
            assert File.exists(source_path)
                else "fixture not copied to test output: {source_path}";

            let source = File.read_all_text(source_path);

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("object-oriented.ghul", source);

            let edit_diagnostics = analyser.read_response();

            Assert.are_equal(
                "DIAGNOSTICS",
                edit_diagnostics.header,
                "expected DIAGNOSTICS as first frame after EDIT, got '{edit_diagnostics.header}'"
            );

            let edit_user_diagnostics = LIST[DIAGNOSTIC](edit_diagnostics.user_diagnostics);

            Assert.are_equal(
                0,
                edit_user_diagnostics.count,
                diagnostics_summary("EDIT response had unexpected user diagnostics", edit_user_diagnostics)
            );

            let edit_partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", edit_partial_done.header);

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();

            Assert.are_equal(
                "DIAGNOSTICS",
                compile_diagnostics.header,
                "expected DIAGNOSTICS as first frame after COMPILE, got '{compile_diagnostics.header}'"
            );

            let compile_user_diagnostics = LIST[DIAGNOSTIC](compile_diagnostics.user_diagnostics);

            // SMOKING GUN: today this assertion fails with two false-positive
            // errors about `Collections.MAP` and `Operation[T]` identity. Build
            // mode produces zero diagnostics on the same source.
            Assert.are_equal(
                0,
                compile_user_diagnostics.count,
                "{diagnostics_summary("COMPILE response had unexpected user diagnostics", compile_user_diagnostics)}\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let compile_full_done = analyser.read_response();
            Assert.are_equal("FULL DONE", compile_full_done.header);
        si

        // Mimic the typical IDE editing rhythm: user types something that
        // produces an error, then fixes it. Three EDITs on the same logical
        // path: clean → broken → clean.
        //
        // Catches a bug class where error state from the broken EDIT leaks
        // into the subsequent clean EDIT (the third call), causing the
        // diagnostics to remain non-empty even though the source is now
        // clean. Per-build state cached on retained AST nodes is a common
        // source of leaks here — see #1219 / CLEAR_STATE_VISITOR.
        edit_clean_then_broken_then_clean_should_clear_diagnostics() is
            @test()

            let dir = fixture_dir("edit-error-cycle");
            let clean_path = Path.combine(dir, "clean.ghul");
            let broken_path = Path.combine(dir, "broken.ghul");

            assert File.exists(clean_path) else "fixture missing: {clean_path}";
            assert File.exists(broken_path) else "fixture missing: {broken_path}";

            let clean_source = File.read_all_text(clean_path);
            let broken_source = File.read_all_text(broken_path);

            let use analyser = ANALYSER_PROCESS();

            // Step 1: EDIT clean. Expect zero user diagnostics.
            analyser.send_edit("source.ghul", clean_source);

            let first_clean_diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", first_clean_diagnostics.header);

            let first_clean_user = LIST[DIAGNOSTIC](first_clean_diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                first_clean_user.count,
                diagnostics_summary("first EDIT (clean) had unexpected diagnostics", first_clean_user)
            );

            let first_clean_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", first_clean_done.header);

            // Step 2: EDIT broken. Expect at least one user diagnostic
            // referencing `undefined_identifier`.
            analyser.send_edit("source.ghul", broken_source);

            let broken_diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", broken_diagnostics.header);

            let broken_user = LIST[DIAGNOSTIC](broken_diagnostics.user_diagnostics);
            Assert.is_true(
                broken_user.count > 0,
                "second EDIT (broken) expected to surface an error but got 0 diagnostics\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let broken_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", broken_done.header);

            // Step 3: EDIT clean again. The error from step 2 must NOT
            // leak into this response — diagnostics should be empty.
            analyser.send_edit("source.ghul", clean_source);

            let final_clean_diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", final_clean_diagnostics.header);

            let final_clean_user = LIST[DIAGNOSTIC](final_clean_diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                final_clean_user.count,
                "{diagnostics_summary("third EDIT (clean) had leaked diagnostics from broken EDIT", final_clean_user)}\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let final_clean_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", final_clean_done.header);
        si

        // A standing resolve-phase error in a file that is never re-edited
        // must appear exactly once per EDIT, not accumulate. The EDIT path
        // re-runs resolve-* for every file; before the per-phase diagnostic
        // clear was added, a non-edited file's resolve diagnostics were
        // re-raised without clearing the previous run's, doubling on every
        // keystroke until a COMPILE wiped them.
        edited_file_must_not_double_a_standing_error_in_an_untouched_file() is
            @test()

            let dir = fixture_dir("edit-doubling");
            let caller_path = Path.combine(dir, "caller.ghul");
            let flawed_path = Path.combine(dir, "flawed.ghul");

            assert File.exists(caller_path) else "fixture missing: {caller_path}";
            assert File.exists(flawed_path) else "fixture missing: {flawed_path}";

            let caller_source = File.read_all_text(caller_path);
            let flawed_source = File.read_all_text(flawed_path);

            let use analyser = ANALYSER_PROCESS();

            // Multi-file EDIT: load both files (the IDE's startup shape).
            analyser.send_edit_files([
                EDIT_FILE("caller.ghul", caller_source),
                EDIT_FILE("flawed.ghul", flawed_source)
            ]);

            let baseline = count_diagnostics_for(analyser, "flawed.ghul");

            Assert.is_true(
                baseline > 0,
                "expected the flawed fixture to surface at least one diagnostic"
                "\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            // Edit the *other* file repeatedly. flawed.ghul is never re-edited,
            // so its diagnostic count must stay at the baseline.
            for i in 0..3 do
                analyser.send_edit("caller.ghul", caller_source);

                let count = count_diagnostics_for(analyser, "flawed.ghul");

                Assert.are_equal(
                    baseline,
                    count,
                    "flawed.ghul diagnostics changed after editing an unrelated "
                    "file (EDIT #{i+1}): expected {baseline}, got {count} — "
                    "resolve-phase doubling\n--- analyser stderr ---\n{analyser.stderr_capture}"
                );
            od
        si

        // Read an EDIT's DIAGNOSTICS + PARTIAL DONE frames; return the number
        // of user diagnostics whose path ends with `file_name`.
        count_diagnostics_for(analyser: ANALYSER_PROCESS, file_name: string) -> int is
            let diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", diagnostics.header);

            let count mut = 0;

            for d in diagnostics.user_diagnostics do
                if d.path.ends_with(file_name) then
                    count = count + 1;
                fi
            od

            let partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", partial_done.header);

            return count;
        si

        // The "COMPILE needed" bit on the PARTIAL DONE frame: an EDIT that
        // changes only a method body must report 0 — no other file's
        // diagnostics can have changed — while an EDIT that changes a
        // signature must report 1.
        edit_classifier_reports_compile_needed_only_for_interface_changes() is
            @test()

            let helper_source =
                "namespace EditClass is\n"
                "    helper() is\n"
                "    si\n"
                "si\n";

            let baseline =
                "namespace EditClass is\n"
                "    run(x: int) -> int is\n"
                "        return x;\n"
                "    si\n"
                "si\n";

            let body_only =
                "namespace EditClass is\n"
                "    run(x: int) -> int is\n"
                "        return x + 1;\n"
                "    si\n"
                "si\n";

            let signature =
                "namespace EditClass is\n"
                "    run(x: int, y: int) -> int is\n"
                "        return x + 1;\n"
                "    si\n"
                "si\n";

            let use analyser = ANALYSER_PROCESS();

            // Cold multi-file EDIT loads both files.
            analyser.send_edit_files([
                EDIT_FILE("a.ghul", baseline),
                EDIT_FILE("helper.ghul", helper_source)
            ]);
            drain_edit(analyser);

            // Body-only edit of a.ghul: helper.ghul cannot be affected.
            analyser.send_edit("a.ghul", body_only);
            Assert.are_equal(
                "0",
                read_compile_needed(analyser),
                "body-only edit should report COMPILE not needed"
                "\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            // Signature edit of a.ghul: a caller in another file could be
            // affected.
            analyser.send_edit("a.ghul", signature);
            Assert.are_equal(
                "1",
                read_compile_needed(analyser),
                "signature edit should report COMPILE needed"
                "\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // Read an EDIT's DIAGNOSTICS + PARTIAL DONE frames, discarding both.
        drain_edit(analyser: ANALYSER_PROCESS) is
            let diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", diagnostics.header);

            let partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", partial_done.header);
        si

        // Read DIAGNOSTICS + PARTIAL DONE; return the COMPILE-needed bit —
        // the second body line of PARTIAL DONE, after the timing line.
        read_compile_needed(analyser: ANALYSER_PROCESS) -> string is
            let diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", diagnostics.header);

            let partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", partial_done.header);

            let lines = LIST[string](partial_done.lines);

            Assert.is_true(
                lines.count >= 2,
                "PARTIAL DONE frame missing the COMPILE-needed line: "
                "got {lines.count} body line(s)"
            );

            return lines[1];
        si
    si
si
