namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.INLAY_HINT;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Editor-only inlays announced at each narrowing-introduction site.
    // One fixture covers most syntactic forms so the analyser walks
    // them all in a single COMPILE; each assertion filters the resulting
    // inlays for its slug. Every narrowing-introduction inlay carries a
    // `narrowing-*` slug in `code` and the direction sigil `▶` in
    // `text`; the narrowed-to type and the reason live in `detail`.
    class NARROWING_SITE_HINT_SMOKE_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace SiteHint is\n"
            "    trait ANIMAL is\n"
            "    si\n"
            "    class CAT: ANIMAL is\n"
            "        init() is si\n"
            "        meow() is si\n"
            "    si\n"
            "    class DOG: ANIMAL is\n"
            "        init() is si\n"
            "        bark() is si\n"
            "    si\n"
            "    class HOLDER is\n"
            "        pet: ANIMAL?;\n"
            "        init(pet: ANIMAL?) is\n"
            "            self.pet = pet;\n"
            "        si\n"
            "    si\n"
            "    class HINTS is\n"
            "        init() is si\n"
            "        maybe() -> ANIMAL? => CAT();\n"
            "        presence(a: ANIMAL?) is\n"
            "            if a? then\n"
            "                a.meow();\n"
            "            fi\n"
            "        si\n"
            "        null_compare(a: ANIMAL?) is\n"
            "            if a != null then\n"
            "                a.meow();\n"
            "            fi\n"
            "        si\n"
            "        isa_check(a: ANIMAL) is\n"
            "            if isa CAT(a) then\n"
            "                a.meow();\n"
            "            fi\n"
            "        si\n"
            "        if_let(a: ANIMAL) is\n"
            "            if let c: CAT = a then\n"
            "                c.meow();\n"
            "            fi\n"
            "        si\n"
            "        unwrap() is\n"
            "            let a = maybe();\n"
            "            a!.meow();\n"
            "        si\n"
            "        assign_non_optional() is\n"
            "            let a: ANIMAL? mut = null;\n"
            "            a = CAT();\n"
            "        si\n"
            "        init_non_optional() is\n"
            "            let a: ANIMAL? = CAT();\n"
            "            a.meow();\n"
            "        si\n"
            "    si\n"
            "si\n";

        // Drive EDIT, COMPILE, INLAY_HINTS. `open_paths` is declared before
        // the edit, per the open-files contract.
        compile_inlays(path: string, open_paths: Collections.Iterable[string], text: string) -> LIST[INLAY_HINT] is
            let use analyser = ANALYSER_PROCESS();

            analyser.send_open_files(open_paths);

            analyser.send_edit(path, text);
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            let compile = analyser.read_response();
            assert isa Response.DIAGNOSTICS(compile) else "expected DIAGNOSTICS after COMPILE";

            analyser.send_inlay_hints(path);
            let inlays = analyser.read_response();
            assert isa Response.INLAY_HINTS(inlays) else "expected INLAY_HINTS response";

            return LIST[INLAY_HINT](inlays.hints);
        si

        has_inlay(hints: Collections.Iterable[INLAY_HINT], code: string) -> bool is
            for h in hints do
                if h.code =~ code then
                    return true;
                fi
            od

            return false;
        si

        // Every site inlay carries a `narrowing-*` slug, so a common-prefix
        // check confirms the umbrella scheme even before the per-slug tests
        // pick out the individual sites.
        all_slugs_share_prefix() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["sitehint.ghul"], source());

            let seen_any mut = false;

            for h in inlays do
                if h.code? /\ h.code.starts_with("narrowing-") then
                    seen_any = true;
                fi
            od

            Assert.is_true(seen_any, "expected at least one narrowing-* inlay");
        si

        presence_hint_present() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["sitehint.ghul"], source());

            Assert.is_true(
                has_inlay(inlays, "narrowing-presence"),
                "expected a narrowing-presence inlay for `if a?`"
            );
        si

        null_compare_hint_present() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["sitehint.ghul"], source());

            Assert.is_true(
                has_inlay(inlays, "narrowing-null-compare"),
                "expected a narrowing-null-compare inlay for `if a != null`"
            );
        si

        isa_hint_present() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["sitehint.ghul"], source());

            Assert.is_true(
                has_inlay(inlays, "narrowing-isa"),
                "expected a narrowing-isa inlay for `if isa CAT(a)`"
            );
        si

        if_let_hint_present() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["sitehint.ghul"], source());

            Assert.is_true(
                has_inlay(inlays, "narrowing-if-let"),
                "expected a narrowing-if-let inlay for `if let c: CAT = a`"
            );
        si

        unwrap_hint_present() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["sitehint.ghul"], source());

            Assert.is_true(
                has_inlay(inlays, "narrowing-unwrap"),
                "expected a narrowing-unwrap inlay for `a!`"
            );
        si

        assign_hint_present() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["sitehint.ghul"], source());

            Assert.is_true(
                has_inlay(inlays, "narrowing-assign"),
                "expected a narrowing-assign inlay for a non-optional assign / init"
            );
        si

        // Every introduction inlay's label is the direction sigil `▶`;
        // the narrowed-to type sits in `detail` so hover surfaces it.
        introduction_labels_carry_direction_sigil() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["sitehint.ghul"], source());

            for h in inlays do
                if h.code? /\ h.code.starts_with("narrowing-") /\ h.code !~ "narrowing-killed" then
                    Assert.are_equal(
                        "▶",
                        h.label,
                        "narrowing-introduction inlay label should be ▶, got: {h.label} (code={h.code})"
                    );
                fi
            od
        si

        // A `x? /\ x.prop` condition analyses its left operand twice
        // by construction — once in `compile_operators.pre_binary` to
        // thread the right's narrowing env, once when the enclosing
        // if analyses the whole condition. Both walks must not both
        // emit inlays or the editor sees the marker duplicated at
        // exactly the same character position.
        conjunction_left_narrow_emits_single_inlay() is
            @test()

            let conjunction_source =
                "namespace Probe is\n"
                "    class CAT is\n"
                "        init() is si\n"
                "        alive: bool => true;\n"
                "    si\n"
                "    class HOST is\n"
                "        init() is si\n"
                "        find() -> CAT? => CAT();\n"
                "        exercise() is\n"
                "            let a = find();\n"
                "            if a? /\\ a.alive then\n"
                "                Std.output.write_line(\"seen\");\n"
                "            fi\n"
                "        si\n"
                "    si\n"
                "si\n";

            let inlays = compile_inlays("conjunction.ghul", ["conjunction.ghul"], conjunction_source);

            let presence_count mut = 0;

            for h in inlays do
                if h.code =~ "narrowing-presence" then
                    presence_count = presence_count + 1;
                fi
            od

            Assert.are_equal(
                1,
                presence_count,
                "expected exactly one narrowing-presence inlay for `if a? /\\ a.alive`, got {presence_count}"
            );
        si

        site_hints_absent_when_file_is_not_open() is
            @test()

            let inlays = compile_inlays("sitehint.ghul", ["other.ghul"], source());

            let seen_any mut = false;

            for h in inlays do
                if h.code? /\ h.code.starts_with("narrowing-") then
                    seen_any = true;
                fi
            od

            Assert.is_false(seen_any, "expected no narrowing-* inlays for a file that is not open");
        si

        // A file that only exercises narrowing shapes on non-optional
        // declared targets should produce zero presence-shape inlays — the
        // underlying narrowings are no-ops that NARROW_ENV filters at set
        // time.
        non_optional_targets_produce_no_presence_hints() is
            @test()

            let non_optional_source =
                "namespace Probe is\n"
                "    class CAT is\n"
                "        init() is si\n"
                "        meow() is si\n"
                "    si\n"
                "    class NN is\n"
                "        init() is si\n"
                "        presence(a: CAT) is\n"
                "            if a? then\n"
                "                a.meow();\n"
                "            fi\n"
                "        si\n"
                "        null_compare(a: CAT) is\n"
                "            if a != null then\n"
                "                a.meow();\n"
                "            fi\n"
                "        si\n"
                "        unwrap(a: CAT) is\n"
                "            a!.meow();\n"
                "        si\n"
                "        init_local() is\n"
                "            let a: CAT = CAT();\n"
                "            a.meow();\n"
                "        si\n"
                "    si\n"
                "si\n";

            let inlays = compile_inlays("nnprobe.ghul", ["nnprobe.ghul"], non_optional_source);

            let redundant = System.Text.StringBuilder();

            for h in inlays do
                if
                    h.code? /\
                    (h.code =~ "narrowing-presence" \/
                     h.code =~ "narrowing-null-compare" \/
                     h.code =~ "narrowing-unwrap" \/
                     h.code =~ "narrowing-assign")
                then
                    redundant.append("  {h.code}\t{h.label}\t{h.detail}\n");
                fi
            od

            Assert.are_equal(
                "",
                redundant.to_string(),
                "expected no presence-shape inlays on non-optional-declared targets;\ngot:\n{redundant.to_string()}"
            );
        si
    si
si
