namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Editor-only hints announced at each narrowing-introduction site.
    // One fixture covers most syntactic forms so the analyser walks
    // them all in a single COMPILE — each assertion just filters the
    // resulting diagnostics for its slug and target name.
    class NARROWING_SITE_HINT_SMOKE_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace SiteHint is\n"
            "    trait ANIMAL is\n"
            "    si\n"
            "    class CAT: ANIMAL is\n"
            "        init() is si\n"
            "        meow() is si\n"
            "    si\n"
            "    class DOG: ANIMAL is\n"
            "        init() is si\n"
            "        bark() is si\n"
            "    si\n"
            "    class HOLDER is\n"
            "        pet: ANIMAL?;\n"
            "        init(pet: ANIMAL?) is\n"
            "            self.pet = pet;\n"
            "        si\n"
            "    si\n"
            "    class HINTS is\n"
            "        init() is si\n"
            "        maybe() -> ANIMAL? => CAT();\n"
            "        presence(a: ANIMAL?) is\n"
            "            if a? then\n"
            "                a.meow();\n"
            "            fi\n"
            "        si\n"
            "        null_compare(a: ANIMAL?) is\n"
            "            if a != null then\n"
            "                a.meow();\n"
            "            fi\n"
            "        si\n"
            "        isa_check(a: ANIMAL) is\n"
            "            if isa CAT(a) then\n"
            "                a.meow();\n"
            "            fi\n"
            "        si\n"
            "        if_let(a: ANIMAL) is\n"
            "            if let c: CAT = a then\n"
            "                c.meow();\n"
            "            fi\n"
            "        si\n"
            "        unwrap() is\n"
            "            let a = maybe();\n"
            "            a!.meow();\n"
            "        si\n"
            "        assign_non_optional() is\n"
            "            let a: ANIMAL? mut = null;\n"
            "            a = CAT();\n"
            "        si\n"
            "        init_non_optional() is\n"
            "            let a: ANIMAL? = CAT();\n"
            "            a.meow();\n"
            "        si\n"
            "    si\n"
            "si\n";

        // Drive an EDIT then COMPILE and return the COMPILE response's user
        // diagnostics. `open_paths` is declared before the edit, per the
        // open-files contract.
        compile_diagnostics(open_paths: Collections.Iterable[string]) -> LIST[DIAGNOSTIC] is
            let use analyser = ANALYSER_PROCESS();

            analyser.send_open_files(open_paths);

            analyser.send_edit("sitehint.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            let compile = analyser.read_response();
            assert isa Response.DIAGNOSTICS(compile) else "expected DIAGNOSTICS after COMPILE";

            return LIST[DIAGNOSTIC](user_diagnostics_of(compile));
        si

        // severity 4 == HINT. Match on code alone — the message wording
        // isn't part of the wire contract.
        has_hint(diagnostics: Collections.Iterable[DIAGNOSTIC], code: string) -> bool is
            for d in diagnostics do
                if d.severity == 4 /\ d.code =~ code then
                    return true;
                fi
            od

            return false;
        si

        // Every site hint carries a `narrowing-*` slug, so a common-prefix
        // check confirms the umbrella scheme even before the per-slug tests
        // pick out the individual sites.
        all_slugs_share_prefix() is
            @test()

            let diagnostics = compile_diagnostics(["sitehint.ghul"]);

            let seen_any mut = false;

            for d in diagnostics do
                if d.severity == 4 /\ d.code? /\ d.code!.starts_with("narrowing-") then
                    seen_any = true;
                fi
            od

            Assert.is_true(
                seen_any,
                "expected at least one narrowing-* hint\n{diagnostics_summary("got", diagnostics)}"
            );
        si

        presence_hint_present() is
            @test()

            let diagnostics = compile_diagnostics(["sitehint.ghul"]);

            Assert.is_true(
                has_hint(diagnostics, "narrowing-presence"),
                "expected a narrowing-presence hint for `if a?`\n{diagnostics_summary("got", diagnostics)}"
            );
        si

        null_compare_hint_present() is
            @test()

            let diagnostics = compile_diagnostics(["sitehint.ghul"]);

            Assert.is_true(
                has_hint(diagnostics, "narrowing-null-compare"),
                "expected a narrowing-null-compare hint for `if a != null`\n{diagnostics_summary("got", diagnostics)}"
            );
        si

        isa_hint_present() is
            @test()

            let diagnostics = compile_diagnostics(["sitehint.ghul"]);

            Assert.is_true(
                has_hint(diagnostics, "narrowing-isa"),
                "expected a narrowing-isa hint for `if isa CAT(a)`\n{diagnostics_summary("got", diagnostics)}"
            );
        si

        if_let_hint_present() is
            @test()

            let diagnostics = compile_diagnostics(["sitehint.ghul"]);

            Assert.is_true(
                has_hint(diagnostics, "narrowing-if-let"),
                "expected a narrowing-if-let hint for `if let c: CAT = a`\n{diagnostics_summary("got", diagnostics)}"
            );
        si

        unwrap_hint_present() is
            @test()

            let diagnostics = compile_diagnostics(["sitehint.ghul"]);

            Assert.is_true(
                has_hint(diagnostics, "narrowing-unwrap"),
                "expected a narrowing-unwrap hint for `a!`\n{diagnostics_summary("got", diagnostics)}"
            );
        si

        assign_hint_present() is
            @test()

            let diagnostics = compile_diagnostics(["sitehint.ghul"]);

            Assert.is_true(
                has_hint(diagnostics, "narrowing-assign"),
                "expected a narrowing-assign hint for a non-optional assign / init\n{diagnostics_summary("got", diagnostics)}"
            );
        si

        site_hints_absent_when_file_is_not_open() is
            @test()

            let diagnostics = compile_diagnostics(["other.ghul"]);

            let seen_any mut = false;

            for d in diagnostics do
                if d.severity == 4 /\ d.code? /\ d.code!.starts_with("narrowing-") then
                    seen_any = true;
                fi
            od

            Assert.is_false(
                seen_any,
                "expected no narrowing-* hints for a file that is not open\n{diagnostics_summary("got", diagnostics)}"
            );
        si
    si
si
