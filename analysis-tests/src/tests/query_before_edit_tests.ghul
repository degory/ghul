namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // A document query can reach the analyser before the first EDIT has
    // registered any source files: the IDE fires the focused editor's
    // outline request as soon as the process is listening. The query-miss
    // recompile must not build the empty project. Building it clears the
    // symbol table and runs the pass barriers with no files queued, so a
    // barrier hook that touches a reflected type materializes it against
    // a symbol table missing the source-declared innate stubs, and the
    // half-built symbol is cached for the life of the process: bool ends
    // up permanently without get_type / to_string.
    class QUERY_BEFORE_EDIT_TESTS is
        @test()

        init() is si

        symbols_query_before_first_edit_should_not_poison_reflected_types() is
            @test()

            let source = File.read_all_text(Path.combine(fixture_dir("query-before-edit"), "main.ghul"));

            let use analyser = ANALYSER_PROCESS();

            // The outline query lands before any EDIT.
            analyser.send_symbols("main.ghul");

            let symbols_response = analyser.read_query_response();
            assert isa Response.SYMBOLS(symbols_response) else "expected SYMBOLS response";

            // The project arrives afterwards; its bool member accesses
            // must resolve against a fully-materialized reflected bool.
            analyser.send_edit("main.ghul", source);

            let edit_diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit_diagnostics) else "expected DIAGNOSTICS response";

            analyser.send_compile();

            let compile_diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(compile_diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(compile_diagnostics));

            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary(
                    "compile after an early SYMBOLS query had unexpected diagnostics",
                    user_diagnostics
                )
            );
        si
    si
si
