namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // An error from a semantic pass must not be dropped just because the
    // project also carries standing warnings from a post-parse pass.
    //
    // The diagnostics store's error-cascade filter fires when any file has a
    // pre-analysis diagnostic and the project's total diagnostic count
    // exceeds 30 — and in that mode it writes only the pre-analysis
    // diagnostics, silently dropping every semantic-pass diagnostic. The
    // name-convention warnings are logged by a post-parse pass, before
    // start_analysis, so a project with more than 30 of them permanently
    // trips the filter: every type error the expression compiler reports is
    // swallowed while the warnings themselves still come through.
    class DIAGNOSTIC_CASCADE_FILTER_TESTS is
        @test()

        init() is si

        semantic_error_survives_a_project_with_many_standing_warnings() is
            @test()

            let dir = fixture_dir("diag-cascade");
            let broken_path = Path.combine(dir, "broken.ghul");

            assert File.exists(broken_path) else "fixture missing: {broken_path}";

            // The warnings are spread across three files because the
            // filtered writer also caps pre-analysis diagnostics at 15 per
            // file — a single noisy file could never show more than 15, and
            // the sanity check below needs to see the full warning count to
            // prove the filter's arming threshold was crossed.
            let edit_files = LIST[EDIT_FILE]();

            for n in 0..3 do
                let noisy_path = Path.combine(dir, "noisy{n}.ghul");

                assert File.exists(noisy_path) else "fixture missing: {noisy_path}";

                edit_files.add(EDIT_FILE("noisy{n}.ghul", File.read_all_text(noisy_path)));
            od

            edit_files.add(EDIT_FILE("broken.ghul", File.read_all_text(broken_path)));

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit_files(edit_files);

            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response";
            Assert.are_equal("partial", response.phase);

            let diagnostics = LIST[DIAGNOSTIC](user_diagnostics_of(response));

            let warnings = diagnostics | .filter(d => d.severity == 2).count();

            Assert.is_true(
                warnings > 30,
                "expected the noisy fixture to surface more than 30 warnings "
                "(got {warnings}) — the fixture no longer arms the cascade "
                "filter and this test is not exercising it"
                "\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let errors =
                LIST[DIAGNOSTIC](
                    diagnostics
                    | .filter(d => d.severity == 1 /\ d.path.ends_with("broken.ghul")));

            Assert.is_true(
                errors.count > 0,
                "{diagnostics_summary(
                    "the type error in broken.ghul was dropped from a "
                    "response that still carries the standing warnings",
                    diagnostics)}"
                "\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
