namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Cross-file query matrix after an incremental EDIT of one file.
    //
    // The fixture has two files, both registered in the initial
    // multi-file EDIT:
    //
    //   `core.ghul`     — declares trait `Greeter`, a namespace function
    //                     `shared_helper` declared above the class,
    //                     class `HOST: Greeter`, then `farewell_helper`
    //                     and `make_host` declared below the class. A
    //                     body inside `HOST` (`process`) is the one
    //                     incrementally edited.
    //
    //   `client.ghul`   — never edited after initial load. Derives a
    //                     class from `HOST`, calls `HOST`, `greet`,
    //                     `shared_helper`, `farewell_helper`, and
    //                     `make_host`; also independently implements
    //                     `Greeter` via `FORMAL_GREETER`.
    //
    // After an interface-preserving body edit grows `process` by three
    // lines, every declaration in `core.ghul` below `process` shifts
    // (`introduce`, `farewell_helper`, `make_host`). `core.ghul`'s own
    // re-walk handles its bodies; `client.ghul` is untouched — none of
    // its symbols, uses, or lines change. The reconciliation must:
    //
    //   F — leave `client.ghul`'s uses untouched (their entries are in
    //       the "other-file, kept" bucket).
    //   G — keep cross-file identity stable so a query anchored in
    //       `client.ghul` still finds `core.ghul` symbols, AND lands
    //       on their *post-shift* coordinates when they shifted.
    class INCREMENTAL_CROSS_FILE_QUERY_TESTS is
        @test()

        init() is si

        // Baseline core.ghul:
        //
        //  1  namespace IqxCore is
        //  2      trait Greeter is
        //  3          greet() -> string;
        //  4      si
        //  5
        //  6      shared_helper() -> int => 42;
        //  7
        //  8      class HOST: Greeter is
        //  9          _name: string;
        // 10
        // 11          init(name: string) is
        // 12              _name = name;
        // 13          si
        // 14
        // 15          greet() -> string => "hello, {_name}";
        // 16
        // 17          process() -> int is
        // 18              let total mut = 0;
        // 19              for n in 1..10 do
        // 20                  total = total + n;
        // 21              od
        // 22              return total;
        // 23          si
        // 24
        // 25          introduce() -> string is
        // 26              let prefix = "I am ";
        // 27              let suffix = greet();
        // 28              return prefix + suffix;
        // 29          si
        // 30      si
        // 31
        // 32      farewell_helper() -> string => "bye";
        // 33
        // 34      make_host(name: string) -> HOST => HOST(name);
        // 35  si
        core_baseline() -> string =>
            "namespace IqxCore is\n"
            "    trait Greeter is\n"
            "        greet() -> string;\n"
            "    si\n"
            "\n"
            "    shared_helper() -> int => 42;\n"
            "\n"
            "    class HOST: Greeter is\n"
            "        _name: string;\n"
            "\n"
            "        init(name: string) is\n"
            "            _name = name;\n"
            "        si\n"
            "\n"
            "        greet() -> string => \"hello, {{_name}}\";\n"
            "\n"
            "        process() -> int is\n"
            "            let total mut = 0;\n"
            "            for n in 1..10 do\n"
            "                total = total + n;\n"
            "            od\n"
            "            return total;\n"
            "        si\n"
            "\n"
            "        introduce() -> string is\n"
            "            let suffix = greet();\n"
            "            return suffix;\n"
            "        si\n"
            "    si\n"
            "\n"
            "    farewell_helper() -> string => \"bye\";\n"
            "\n"
            "    make_host(name: string) -> HOST => HOST(name);\n"
            "si\n";

        // Edited core.ghul: `process`'s body grows by three lines. Lines
        // 25..end shift by +3:
        //   `introduce`        25 → 28
        //   class `si`         29 → 32
        //   `farewell_helper`  31 → 34
        //   `make_host`        33 → 36
        core_edited() -> string =>
            "namespace IqxCore is\n"
            "    trait Greeter is\n"
            "        greet() -> string;\n"
            "    si\n"
            "\n"
            "    shared_helper() -> int => 42;\n"
            "\n"
            "    class HOST: Greeter is\n"
            "        _name: string;\n"
            "\n"
            "        init(name: string) is\n"
            "            _name = name;\n"
            "        si\n"
            "\n"
            "        greet() -> string => \"hello, {{_name}}\";\n"
            "\n"
            "        process() -> int is\n"
            "            let a = 1;\n"
            "            let b = 2;\n"
            "            let c = 3;\n"
            "            let total mut = a + b + c;\n"
            "            for n in 1..10 do\n"
            "                total = total + n;\n"
            "            od\n"
            "            return total;\n"
            "        si\n"
            "\n"
            "        introduce() -> string is\n"
            "            let suffix = greet();\n"
            "            return suffix;\n"
            "        si\n"
            "    si\n"
            "\n"
            "    farewell_helper() -> string => \"bye\";\n"
            "\n"
            "    make_host(name: string) -> HOST => HOST(name);\n"
            "si\n";

        // Client — never edited after initial load. Lines:
        //
        //  1  namespace IqxCore is
        //  2      class POLITE_HOST: HOST is
        //  3          init(name: string) is
        //  4              super.init(name);
        //  5          si
        //  6
        //  7          announce() -> string is
        //  8              let g = HOST("guest");
        //  9              let n = shared_helper();
        // 10              return g.greet();
        // 11          si
        // 12      si
        // 13
        // 14      class FORMAL_GREETER: Greeter is
        // 15          greet() -> string => "Good day.";
        // 16      si
        // 17
        // 18      use_farewell() -> string => farewell_helper();
        // 19
        // 20      make_two() -> HOST => make_host("bob");
        // 21  si
        client_source() -> string =>
            "namespace IqxCore is\n"
            "    class POLITE_HOST: HOST is\n"
            "        init(name: string) is\n"
            "            super.init(name);\n"
            "        si\n"
            "\n"
            "        announce() -> string is\n"
            "            let g = HOST(\"guest\");\n"
            "            let n = shared_helper();\n"
            "            return g.greet();\n"
            "        si\n"
            "    si\n"
            "\n"
            "    class FORMAL_GREETER: Greeter is\n"
            "        greet() -> string => \"Good day.\";\n"
            "    si\n"
            "\n"
            "    use_farewell() -> string => farewell_helper();\n"
            "\n"
            "    make_two() -> HOST => make_host(\"bob\");\n"
            "si\n";

        // ─────────────────────────────────────────────────────────────────
        //   HOVER tests (queries anchored in the unedited file)
        // ─────────────────────────────────────────────────────────────────

        // F·θ — HOVER on a local-use inside an unedited file's body.
        // `g` on client line 10 col 20 — the `return g.greet();` use.
        // Symbol-use-locations record uses, so HOVER on a use site is
        // the natural query position. (The declaration `let g = ...`
        // on line 8 is *not* a use, so HOVER there returns nothing.)
        hover_on_local_in_unedited_file_body_resolves() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_hover("client.ghul", 10, 20);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            assert_hover_non_empty(response, "`g` local-use in untouched file", analyser);
        si

        // G·δ — HOVER on a use of a namespace function declared in the
        // edited file ABOVE the edit (line-stable). `shared_helper()`
        // call on client line 9 col 21 (`            let n = shared_helper();`).
        // 8 spaces, `let n = ` (cols 9-16), `shared_helper` at cols 17-29.
        hover_on_use_of_cross_file_function_declared_above_edit() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_hover("client.ghul", 9, 21);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            assert_hover_non_empty(
                response,
                "`shared_helper` from core (declared core:6, above edit)",
                analyser
            );
        si

        // G·δ shifted — HOVER on a use of a namespace function declared
        // in the edited file BELOW the edit (line shifted by +3).
        // `farewell_helper()` on client line 18 col 36
        // (`    use_farewell() -> string => farewell_helper();`).
        // 4 spaces + `use_farewell() -> string => ` = 32 chars, then
        // `farewell_helper` at cols 33-47.
        hover_on_use_of_cross_file_function_declared_below_edit() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_hover("client.ghul", 18, 36);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            assert_hover_non_empty(
                response,
                "`farewell_helper` from core (declared core:31 → 34 post-shift)",
                analyser
            );
        si

        // G·α — HOVER on a type declared in the edited file (above
        // edit), used in an unedited file's interface signature.
        // `HOST` on client line 2 col 25 (`    class POLITE_HOST: HOST is`).
        // 4 + `class POLITE_HOST: ` (19 chars) = cols 24, then `HOST` at 24-27.
        hover_on_use_of_cross_file_type_in_unedited_file_interface() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_hover("client.ghul", 2, 25);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            assert_hover_non_empty(
                response,
                "`HOST` type use in unedited file (declared core:8)",
                analyser
            );
        si

        // ─────────────────────────────────────────────────────────────────
        //   DEFINITION tests — cross-file targets
        // ─────────────────────────────────────────────────────────────────

        // DEFINITION on a use in client targeting a core symbol declared
        // ABOVE the edit. `shared_helper()` use on client line 9 col 21
        // → core line 6, unchanged.
        definition_from_unedited_file_lands_on_unshifted_target() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_definition("client.ghul", 9, 21);

            let response = analyser.read_query_response();
            assert isa Response.DEFINITION(response) else "expected DEFINITION response";

            let locations = parse_locations(response.locations);
            Assert.is_true(
                locations.count >= 1,
                "DEFINITION on shared_helper use returned no locations\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            assert_location_ends_with(locations[0], "core.ghul", "shared_helper target file", analyser);
            Assert.are_equal(
                6,
                locations[0].start_line,
                "shared_helper is declared at core.ghul:6 (above edit, "
                "line-stable); DEFINITION should land there. Got line "
                "{locations[0].start_line}.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        // DEFINITION on a use in client targeting a core symbol declared
        // BELOW the edit. `farewell_helper()` use on client line 18
        // col 36 → core post-edit line 34 (was line 31, shifted by +3).
        // This is the cross-file equivalent of the line-shifted DEFINITION
        // test in fixture 1.
        definition_from_unedited_file_lands_on_shifted_target() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_definition("client.ghul", 18, 36);

            let response = analyser.read_query_response();
            assert isa Response.DEFINITION(response) else "expected DEFINITION response";

            let locations = parse_locations(response.locations);
            Assert.is_true(
                locations.count >= 1,
                "DEFINITION on farewell_helper use returned no locations\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            assert_location_ends_with(locations[0], "core.ghul", "farewell_helper target file", analyser);
            Assert.are_equal(
                34,
                locations[0].start_line,
                "farewell_helper moved from core.ghul:31 → 34 across the "
                "edit; DEFINITION from the untouched file must land on "
                "post-shift coordinates. Got line {locations[0].start_line} — "
                "the retained interface symbol's Symbol.set_location did "
                "not run on the editing file, OR the lookup used a stale "
                "key.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // DEFINITION on the `HOST` type use in client (class inheritance,
        // line 2) → core line 8 (above edit, unchanged).
        definition_on_cross_file_type_use_unchanged_line() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_definition("client.ghul", 2, 25);

            let response = analyser.read_query_response();
            assert isa Response.DEFINITION(response) else "expected DEFINITION response";

            let locations = parse_locations(response.locations);
            Assert.is_true(locations.count >= 1, "DEFINITION on HOST returned no locations");

            assert_location_ends_with(locations[0], "core.ghul", "HOST target file", analyser);
            Assert.are_equal(
                8,
                locations[0].start_line,
                "class HOST declared at core.ghul:8 (above edit). Got "
                "line {locations[0].start_line}.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        // ─────────────────────────────────────────────────────────────────
        //   DECLARATION tests — same shape
        // ─────────────────────────────────────────────────────────────────

        declaration_from_unedited_file_lands_on_shifted_target() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_declaration("client.ghul", 18, 36);

            let response = analyser.read_query_response();
            assert isa Response.DECLARATION(response) else "expected DECLARATION response";

            let locations = parse_locations(response.locations);
            Assert.is_true(locations.count >= 1, "DECLARATION on farewell_helper returned no locations");

            assert_location_ends_with(locations[0], "core.ghul", "farewell_helper target file", analyser);
            Assert.are_equal(
                34,
                locations[0].start_line,
                "farewell_helper declaration moved from core.ghul:31 → 34.\n"
                "Got line {locations[0].start_line}.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // ─────────────────────────────────────────────────────────────────
        //   TYPEDEFINITION tests
        // ─────────────────────────────────────────────────────────────────

        // TYPEDEFINITION on `g` (local of type `HOST`) in client line 8.
        // 12 leading spaces + `let ` puts `g` at col 17. The type's
        // declaration is in core line 8 (above edit, unchanged).
        type_definition_on_local_of_cross_file_class_type() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_type_definition("client.ghul", 8, 17);

            let response = analyser.read_query_response();
            assert isa Response.TYPE_DEFINITION(response) else "expected TYPE_DEFINITION response";

            let locations = parse_locations(response.locations);
            Assert.is_true(locations.count >= 1, "TYPEDEFINITION on g returned no locations");
            assert_location_ends_with(locations[0], "core.ghul", "HOST class file", analyser);
            Assert.are_equal(
                8,
                locations[0].start_line,
                "HOST class is at core.ghul:8 (above edit). Got line "
                "{locations[0].start_line}.\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        // ─────────────────────────────────────────────────────────────────
        //   REFERENCES tests — cross-file
        // ─────────────────────────────────────────────────────────────────

        // REFERENCES on `HOST` declared in core (line 8 col 11 on
        // `class HOST: Greeter is`). Expected uses:
        //   client line 2  — `class POLITE_HOST: HOST is`
        //   client line 8  — `let g = HOST("guest");`
        //   client line 20 — `make_two() -> HOST => make_host("bob");`
        //   core   line 33 → 36 post-shift — `make_host(name: string) -> HOST => HOST(name);`
        //                    (two uses: return-type annotation and call)
        references_on_cross_file_class_returns_uses_in_both_files() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_references("core.ghul", 8, 11);

            let response = analyser.read_query_response();
            assert isa Response.REFERENCES(response) else "expected REFERENCES response";

            let core_lines = lines_in_file(response.locations, "core.ghul");
            let client_lines = lines_in_file(response.locations, "client.ghul");

            // client.ghul uses are in an untouched file; the F/G bucket
            // must not lose them.
            assert_contains_line(client_lines, 2, "POLITE_HOST: HOST", analyser);
            assert_contains_line(client_lines, 8, "HOST(\"guest\")", analyser);
            assert_contains_line(client_lines, 20, "make_two -> HOST", analyser);

            // core.ghul `make_host` is below the edit and shifted from
            // line 33 → 36. The signature uses `HOST` twice (return
            // type, constructor call); at least one of those must be
            // present at the post-shift line.
            assert_contains_line(
                core_lines,
                36,
                "make_host signature on core post-shift line 36",
                analyser
            );
        si

        // REFERENCES on `farewell_helper` (declared core post-shift
        // line 34). Anchored at the *post-shift* declaration site, so
        // the analyser must (a) find the symbol there, and (b) walk to
        // its single use in client line 18.
        references_on_shifted_core_symbol_from_post_shift_declaration_site() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // core post-shift line 34 cols 5-19 on `    farewell_helper()...`
            analyser.send_references("core.ghul", 34, 7);

            let response = analyser.read_query_response();
            assert isa Response.REFERENCES(response) else "expected REFERENCES response";

            let client_lines = lines_in_file(response.locations, "client.ghul");
            assert_contains_line(
                client_lines,
                18,
                "farewell_helper() call site in unedited file",
                analyser
            );
        si

        // ─────────────────────────────────────────────────────────────────
        //   IMPLEMENTATION tests
        // ─────────────────────────────────────────────────────────────────

        // IMPLEMENTATION on the trait abstract `Greeter.greet` (core
        // line 3) must walk to *all* implementations across files:
        //   core   line 15 — HOST.greet (above edit, line-stable)
        //   client line 15 — FORMAL_GREETER.greet (untouched file)
        implementation_on_trait_abstract_spans_both_files() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_implementation("core.ghul", 3, 10);

            let response = analyser.read_query_response();
            assert isa Response.IMPLEMENTATION(response) else "expected IMPLEMENTATION response";

            let core_lines = lines_in_file(response.locations, "core.ghul");
            let client_lines = lines_in_file(response.locations, "client.ghul");

            assert_contains_line(core_lines, 15, "HOST.greet override (core)", analyser);
            assert_contains_line(client_lines, 15, "FORMAL_GREETER.greet (client)", analyser);
        si

        // ─────────────────────────────────────────────────────────────────
        //   Helpers
        // ─────────────────────────────────────────────────────────────────

        // Initial multi-file EDIT (both files) then incremental EDIT to
        // core only. Each EDIT must produce zero diagnostics.
        prime(analyser: ANALYSER_PROCESS) is
            analyser.send_edit_files([
                EDIT_FILE("core.ghul", core_baseline()),
                EDIT_FILE("client.ghul", client_source())
            ]);
            drain_edit_assert_clean(analyser, "initial multi-file EDIT");

            analyser.send_edit("core.ghul", core_edited());
            drain_edit_assert_clean(analyser, "incremental EDIT to core.ghul");
        si

        drain_edit_assert_clean(analyser: ANALYSER_PROCESS, label: string) is
            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                "{label}: fixture expected to compile clean — got "
                "{user_diagnostics.count} diagnostics. fixture bug.\n"
                "{diagnostics_summary(label, user_diagnostics)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

        si

        hover_body_is_empty(response: Response.HOVER) -> bool =>
            string.is_null_or_white_space(response.signature);

        assert_hover_non_empty(response: Response.HOVER, label: string, analyser: ANALYSER_PROCESS) is
            Assert.is_false(
                hover_body_is_empty(response),
                "HOVER for {label} returned an empty body — the use "
                "was not recorded at the queried coordinates.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // Sorted start lines of locations in a location-list response
        // whose file path ends with `file_name`.
        lines_in_file(locations: Collections.LIST[Analysis.Protocol.LOCATION_DTO], file_name: string) -> LIST[int] is
            let result = LIST[int]();

            for loc in locations do
                if loc.file.ends_with(file_name) then
                    result.add(loc.start_line);
                fi
            od

            return LIST[int](result | .sort((a, b) => a - b));
        si

        // Full parsed locations (file + start_line) for tests that need
        // both fields together.
        parse_locations(locations: Collections.LIST[Analysis.Protocol.LOCATION_DTO]) -> LIST[LOCATION_ROW] is
            let result = LIST[LOCATION_ROW]();

            for loc in locations do
                result.add(LOCATION_ROW(loc.file, loc.start_line));
            od

            return result;
        si

        assert_location_ends_with(loc: LOCATION_ROW, file: string, label: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                loc.file.ends_with(file),
                "{label}: expected file ending with '{file}', got "
                "'{loc.file}'\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
        si

        assert_contains_line(lines: LIST[int], expected: int, label: string, analyser: ANALYSER_PROCESS) is
            for l in lines do
                if l == expected then
                    return;
                fi
            od

            Assert.is_true(
                false,
                "expected reference at line {expected} ({label}) not "
                "present in result: {line_list_to_string(lines)}\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        line_list_to_string(lines: LIST[int]) -> string is
            let result = System.Text.StringBuilder();
            result.append("[");

            let first mut = true;
            for l in lines do
                if !first then
                    result.append(", ");
                fi
                result.append("{l}");
                first = false;
            od

            result.append("]");
            return result.to_string();
        si
    si

    class LOCATION_ROW is
        file: string public;
        start_line: int public;

        init(file: string, start_line: int) is
            self.file = file;
            self.start_line = start_line;
        si
    si
si
