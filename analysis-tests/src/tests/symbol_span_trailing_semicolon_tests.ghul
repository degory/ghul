namespace Analysis.Tests is
    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // SYMBOLS over a file whose last definition is terminated by `;` (a
    // primary-constructor-only class or struct, or a variant) must report
    // spans with positive 1-based coordinates. The end position must not
    // absorb the EOF token, whose location sits at column 0 of the line past
    // the file's trailing newline.
    class SYMBOL_SPAN_TRAILING_SEMICOLON_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = Path.combine(fixture_dir("symbol-span-trailing-semicolon"), "main.ghul");
            assert File.exists(path) else "fixture missing: {path}";
            return File.read_all_text(path);
        si

        // The class `SCORE` is the last definition in the fixture and ends with
        // a semicolon followed by a newline. Its span should end at the
        // semicolon, not at the EOF position.
        trailing_semicolon_class_should_have_positive_span() is
            @test()

            let source = load_fixture();

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit_files([EDIT_FILE("main.ghul", source)]);

            let initial_diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(initial_diagnostics) else "expected DIAGNOSTICS response";

            analyser.send_symbols("main.ghul");

            let response = analyser.read_query_response();
            assert isa Response.SYMBOLS(response) else "expected SYMBOLS response";

            Assert.is_true(
                response.files.count > 0,
                "SYMBOLS returned no files\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            for file in response.files do
                for symbol in file.symbols do
                    Assert.is_true(
                        symbol.start_line > 0,
                        "symbol {symbol.search_description} has non-positive start_line {symbol.start_line}"
                    );
                    Assert.is_true(
                        symbol.start_column > 0,
                        "symbol {symbol.search_description} has non-positive start_column {symbol.start_column}"
                    );
                    Assert.is_true(
                        symbol.end_line > 0,
                        "symbol {symbol.search_description} has non-positive end_line {symbol.end_line}"
                    );
                    Assert.is_true(
                        symbol.end_column > 0,
                        "symbol {symbol.search_description} has non-positive end_column {symbol.end_column} (start {symbol.start_line},{symbol.start_column} end {symbol.end_line},{symbol.end_column})"
                    );
                od
            od
        si
    si
si
