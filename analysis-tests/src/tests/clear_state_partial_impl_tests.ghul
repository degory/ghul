namespace Analysis.Tests is
    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Regression marker for the StrictVisitor coverage holes on
    // Definitions.PARTIAL / Definitions.IMPL. CLEAR_STATE_VISITOR and the
    // source printers inherit from StrictVisitor, which throws on any node
    // type without an explicit override. Without one, the re-walk of a
    // retained AST containing a `partial` or `impl` block blows up on the
    // second compile — surfacing as "does not define a visit method for
    // partial ..." on analyser stderr and breaking HOVER / completion /
    // every operation that depends on a subsequent full compile. Same shape
    // as the VAL_BLOCK / AWAIT regressions.
    class CLEAR_STATE_PARTIAL_IMPL_TESTS is
        @test()

        init() is si

        load_source() -> string is
            let path = fixture_path("clear-state-partial-impl/clear-state-partial-impl.ghul");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("clear-state-partial-impl.ghul", source);

            let edit_diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit_diagnostics) else "expected DIAGNOSTICS response";
        si

        // HOVER on a no-symbol position (column 1 of `namespace`) falls
        // through to FULL_COMPILER.compile_all, which runs
        // CLEAR_STATE_VISITOR over every source file's AST. On a file with a
        // PARTIAL or IMPL node that visit throws unless an explicit override
        // is in place.
        hover_after_edit_should_not_choke_on_partial_or_impl() is
            @test()

            let source = load_source();
            let use analyser = ANALYSER_PROCESS();

            prime(analyser, source);

            analyser.send_hover("clear-state-partial-impl.ghul", 1, 1);

            let hover_response = analyser.read_query_response();
            assert isa Response.HOVER(hover_response) else "expected hover response after HOVER's compile_all, got '{hover_response.get_type().name}'";

            let stderr = analyser.stderr_capture;
            Assert.is_false(
                stderr.contains("does not define a visit method"),
                "analyser stderr surfaced a missing StrictVisitor override across HOVER's compile_all on a file with a partial / impl block:\n--- analyser stderr ---\n{stderr}"
            );
        si
    si
si
