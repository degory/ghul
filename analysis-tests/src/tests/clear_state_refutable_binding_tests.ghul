namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Regression marker for missing CLEAR_STATE_VISITOR overrides. The
    // visitor inherits StrictVisitor, so any AST node kind without an
    // explicit override throws on dispatch. The exception is caught and
    // logged to analyser stderr as `FULL COMPILE caught: ...`, leaving
    // downstream HOVER / completion / definition silently degraded —
    // hence the stderr assertion rather than a diagnostic check.
    class CLEAR_STATE_REFUTABLE_BINDING_TESTS is
        @test()

        init() is si

        load_source() -> string is
            let path = fixture_path("clear-state-refutable-binding/clear-state-refutable-binding.ghul");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("clear-state-refutable-binding.ghul", source);

            let edit_diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit_diagnostics) else "expected DIAGNOSTICS response";
        si

        // HOVER on a no-symbol position falls through to
        // FULL_COMPILER.compile_all, which is the path that runs
        // CLEAR_STATE_VISITOR over every retained AST.
        hover_after_edit_should_not_choke_on_refutable_binding() is
            @test()

            let source = load_source();
            let use analyser = ANALYSER_PROCESS();

            prime(analyser, source);

            analyser.send_hover("clear-state-refutable-binding.ghul", 1, 1);

            let hover_response = analyser.read_query_response();
            assert isa Response.HOVER(hover_response) else "expected hover response after HOVER's compile_all, got '{hover_response.get_type().name}'";

            let stderr = analyser.stderr_capture;
            Assert.is_false(
                stderr.contains("does not define a visit method"),
                "analyser stderr surfaced a missing StrictVisitor override across HOVER's compile_all on a file with a refutable binding:\n--- analyser stderr ---\n{stderr}"
            );
        si
    si
si
