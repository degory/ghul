namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // A lambda whose parameter type is unannotated is body-walked
    // before the type is known and again once a later call settles
    // it. Each discarded walk's recorded symbol uses roll back with
    // its diagnostics, so HOVER on a no-arg generic variant
    // constructor inside the body describes the settled walk's
    // specialization - not the placeholder-typed one an earlier walk
    // recorded at the same span.
    class LAMBDA_REWALK_HOVER_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("lambda-rewalk-hover/lambda-rewalk-hover.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("lambda-rewalk-hover.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("lambda-rewalk-hover.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.signature? then
                return "";
            fi
            return response.signature;
        si

        // HOVER on the bare DONE in the inner lambda: its owner
        // type-args are only inferable once the outer lambda's
        // parameter settles to string from the later call, giving
        // STEP[char,int]. A hover that reports object type-args is
        // reading a record left behind by the pre-settlement walk.
        hover_on_noarg_variant__shows_settled_type_args() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let actual = hover_description(analyser, 31, 49);

            Assert.is_true(
                actual.contains("DONE[char,int]"),
                "expected HOVER on DONE to show the settled specialization DONE[char,int], got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
