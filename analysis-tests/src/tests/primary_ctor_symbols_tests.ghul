namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.EDIT_FILE;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Primary-constructor classes synthesise an `init` and (when the
    // user has not opted out) a `deconstruct`. Neither corresponds to
    // anything the user wrote, so the SYMBOLS response — the basis for
    // the VSCE outline and workspace-symbol search — must not surface
    // them as separate entries. The class itself, and any user-readable
    // auto-property reflecting a primary parameter, remain visible.
    class PRIMARY_CTOR_SYMBOLS_TESTS is
        @test()

        init() is si

        load() -> string is
            let path = Path.combine(fixture_dir("primary-ctor-symbols"), "main.ghul");
            assert File.exists(path) else "fixture missing: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit_files([EDIT_FILE("main.ghul", source)]);
            analyser.read_response();
            analyser.send_edit("main.ghul", source);
            analyser.read_response();
        si

        synthesised_init_and_deconstruct_are_filtered_from_symbols() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            analyser.send_symbols("main.ghul");

            let response = analyser.read_query_response();
            assert isa Response.SYMBOLS(response) else "expected SYMBOLS response";

            Assert.is_true(
                response.files.count > 0,
                "SYMBOLS returned no files\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let main_file_opt: Analysis.Protocol.SYMBOL_FILE? mut = null;
            for f in response.files do
                if f.path =~ "main.ghul" then
                    main_file_opt = f;
                fi
            od
            assert main_file_opt? else "no entry for main.ghul in SYMBOLS response";

            let main_file = main_file_opt!;

            let descriptions = System.Text.StringBuilder();
            descriptions.append("file path: [{main_file.path}], {main_file.symbols.count} symbols\n");
            for s in main_file.symbols do
                descriptions.append("  [{s.search_description}] qualifier=[{s.qualifier}]\n");
            od

            let saw_class mut = false;
            let saw_value mut = false;
            let saw_box_init mut = false;
            let saw_box_deconstruct mut = false;

            for s in main_file.symbols do
                if s.search_description =~ "BOX" /\ s.qualifier =~ "PrimaryCtorSymbols" then
                    saw_class = true;
                fi
                if s.search_description =~ "value" /\ s.qualifier =~ "PrimaryCtorSymbols.BOX" then
                    saw_value = true;
                fi
                if s.qualifier =~ "PrimaryCtorSymbols.BOX" /\ s.search_description.starts_with("init(") then
                    saw_box_init = true;
                fi
                if s.qualifier =~ "PrimaryCtorSymbols.BOX" /\ s.search_description.starts_with("deconstruct(") then
                    saw_box_deconstruct = true;
                fi
            od

            Assert.is_true(saw_class, "primary-ctor class BOX missing from outline. Got:\n{descriptions}");
            Assert.is_true(saw_value, "primary-ctor auto-property `value` missing from outline. Got:\n{descriptions}");
            Assert.is_false(saw_box_init, "synthesised init leaked into outline for BOX. Got:\n{descriptions}");
            Assert.is_false(saw_box_deconstruct, "synthesised deconstruct leaked into outline for BOX. Got:\n{descriptions}");
        si
    si
si
