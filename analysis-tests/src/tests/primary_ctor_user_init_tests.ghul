namespace Analysis.Tests is
    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // The primary-constructor rewriter consumes the user's `init(..) is
    // body si` FUNCTION node and synthesises a replacement. The
    // synthesised init's name identifier is anchored at the user's own
    // `init` source location (when an `init(..)` body is present) so
    // hover and the semantic-tokens classifier resolve to the synthesised
    // init at the user-typed keyword. Without this the user's `init`
    // falls through to TextMate colouring with no hover info.
    class PRIMARY_CTOR_USER_INIT_TESTS is
        @test()

        init() is si

        load() -> string is
            let path = Path.combine(fixture_dir("primary-ctor-user-init"), "main.ghul");
            assert File.exists(path) else "fixture missing: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("main.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
        si

        // Fixture line 3 column 9: the `i` of the user-written `init(..)`.
        hover_on_user_init_returns_init_description() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            analyser.send_hover("main.ghul", 3, 9);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";

            Assert.is_true(
                response.signature? /\ response.signature.length > 0,
                "HOVER on user-written init(..) returned no description.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.is_true(
                response.signature.contains("init"),
                "HOVER on user-written init(..) should mention init; got: '{response.signature}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // The user-written `init(..)` keyword spans line 3, columns 9..12.
        // The semantic-tokens classifier should emit a `method` token at
        // that exact 4-char span.
        semantic_tokens_mark_user_init_as_method() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            analyser.send_semantic_tokens("main.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let init_line = 3;
            let init_start = 9;
            let init_end = 12;

            let found mut = false;

            for token in response.tokens do
                if
                    token.token_type =~ "method" /\
                    token.start_line == init_line /\
                    token.start_column == init_start /\
                    token.end_line == init_line /\
                    token.end_column == init_end
                then
                    found = true;
                fi
            od

            Assert.is_true(
                found,
                "expected a `method` token for the user-written init at line {init_line}, columns {init_start}..{init_end}.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
