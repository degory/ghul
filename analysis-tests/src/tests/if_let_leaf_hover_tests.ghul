namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // The if-let leaf-name shorthand (`if let b.contents?`) declares
    // its synthesised local on the scrutinee's own member token. That
    // local's definition and the member access share one source range,
    // so a position query there has two candidates. HOVER, DEFINITION
    // and SEMANTIC_TOKENS must all describe the member the value came
    // from, not the local derived from it — while a genuine use of the
    // local in the then-branch still resolves to the local.
    class IF_LET_LEAF_HOVER_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("if-let-leaf-hover/if-let-leaf-hover.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("if-let-leaf-hover.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("if-let-leaf-hover.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.signature? then
                return "";
            fi
            if response.kind_label? then
                return "{response.signature} // {response.kind_label}";
            fi
            return response.signature;
        si

        assert_hover_contains(actual: string, expected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ actual.contains(expected_substring),
                "{where}: expected HOVER to contain '{expected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        assert_hover_lacks(actual: string, forbidden_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_false(
                actual? /\ actual.contains(forbidden_substring),
                "{where}: expected HOVER NOT to contain '{forbidden_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // HOVER on the `.contents` leaf in `if let b.contents?` shows
        // the member the value came from, not the local it declares.
        hover_on_shorthand_leaf__shows_member_not_local() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 17, 20);
            assert_hover_contains(description, "BOX.contents", "hover on `b.contents` leaf", analyser);
            assert_hover_lacks(description, "local value", "hover on `b.contents` leaf", analyser);
        si

        // HOVER on the narrowed use of the bound local in the
        // then-branch shows the local, narrowed to non-optional.
        hover_on_shorthand_bound_use__shows_local_value() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 18, 22);
            assert_hover_contains(description, "contents: Ghul.string", "hover on narrowed `contents` use", analyser);
            assert_hover_contains(description, "local value", "hover on narrowed `contents` use", analyser);
        si

        // DEFINITION on the leaf resolves to the property declaration,
        // not to the leaf token itself.
        definition_on_shorthand_leaf__resolves_to_member() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            analyser.send_definition("if-let-leaf-hover.ghul", 17, 20);

            let response = analyser.read_query_response();
            assert isa Response.DEFINITION(response) else "expected DEFINITION response";

            Assert.are_equal(
                1,
                response.locations.count,
                "DEFINITION on `b.contents` leaf expected exactly one location, got "
                "{response.locations.count}.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(
                9,
                response.locations[0].start_line,
                "DEFINITION on `b.contents` leaf should land on the `contents` field "
                "declaration line 9, got {response.locations[0].start_line}.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // The semantic token covering the leaf classifies as the
        // member (`property`), not the derived local (`variable`).
        semantic_token_on_shorthand_leaf__is_property_not_variable() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            analyser.send_semantic_tokens("if-let-leaf-hover.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let leaf_line = 17;
            let leaf_column = 18;

            let leaf_token_type: string mut = "";

            for token in response.tokens do
                if token.start_line == leaf_line /\ token.start_column == leaf_column then
                    leaf_token_type = token.token_type;
                fi
            od

            Assert.are_equal(
                "property",
                leaf_token_type,
                "semantic token on the `b.contents` leaf should be `property`, got "
                "'{leaf_token_type}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
