namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // HOVER descriptions surface the store-free analysis: a function,
    // method or property getter the infer-store-free pass proves
    // store-free renders `pure` inside the trailing kind comment
    // (`// pure method`), and one it cannot prove renders the plain
    // kind comment.
    class STORE_FREE_HOVER_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("store-free-hover/store-free-hover.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("store-free-hover.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("store-free-hover.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.description? then
                return "";
            fi
            return response.description;
        si

        assert_hover_contains(actual: string, expected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ actual.contains(expected_substring),
                "{where}: expected HOVER to contain '{expected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        assert_hover_lacks(actual: string, unexpected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ !actual.contains(unexpected_substring),
                "{where}: expected HOVER not to contain '{unexpected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        hover_on_store_free_global_function__shows_pure() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 20, 17);
            assert_hover_contains(description, "// pure global function", "hover on `helper` call", analyser);
        si

        hover_on_store_free_method__shows_pure() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 21, 21);
            assert_hover_contains(description, "// pure method", "hover on `side` call", analyser);
        si

        hover_on_store_free_getter__shows_pure_property() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 22, 21);
            assert_hover_contains(description, "// pure instance property", "hover on `label` read", analyser);
        si

        hover_on_storing_method__shows_no_pure() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 23, 21);
            assert_hover_contains(description, "// method", "hover on `bump` call", analyser);
            assert_hover_lacks(description, "pure", "hover on `bump` call", analyser);
        si
    si
si
