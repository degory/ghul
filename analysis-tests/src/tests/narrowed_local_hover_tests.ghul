namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // HOVER on `let` local variables whose type is refined by
    // flow-sensitive narrowing. Companion to NARROWING_HOVER_TESTS,
    // which covers narrowed *parameters*; this file covers `let`
    // locals across the narrowing forms — `isa` then-branch,
    // divergent guard, within-condition `/\`, union-variant
    // accessor, two-variant `else` — plus a local inside a class
    // method and one declared alongside iterative-inference work.
    //
    // Each test asserts the narrowed type shows at a narrowed use
    // and the declared type still shows at the declaration. One
    // test re-checks a narrowed use after a full COMPILE, since the
    // IDE serves hovers both after a partial EDIT and after a
    // debounced COMPILE.
    class NARROWED_LOCAL_HOVER_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("narrowing-hover/narrowed-local.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("narrowed-local.ghul", source);

            let diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", diagnostics.kind);

            let user_diagnostics = LIST(diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        // A full COMPILE: drains the diagnostics response it writes.
        compile(analyser: ANALYSER_PROCESS) is
            analyser.send_compile();

            let diagnostics = analyser.read_response();
            Assert.are_equal("diagnostics", diagnostics.kind);
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("narrowed-local.ghul", line, column);
            let response = analyser.read_query_response();
            Assert.are_equal("hover", response.kind);
            if !response.description? then
                return "";
            fi
            return response.description;
        si

        assert_hover_contains(actual: string, expected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ actual.contains(expected_substring),
                "{where}: expected HOVER to contain '{expected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // `let v = source()` — HOVER on the declaration shows the
        // declared (inferred) type; nothing is narrowed there.
        hover_on_let_local_decl__shows_declared_object() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 13, 13);
            assert_hover_contains(description, "v: Ghul.object", "hover on `v` declaration", analyser);
        si

        // `return v.length` inside `if isa string(v)` — HOVER on the
        // narrowed use of the `let` local shows `string`.
        hover_on_narrowed_let_local_in_isa_branch__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 15, 20);
            assert_hover_contains(description, "v: Ghul.string", "hover on narrowed `v` in isa branch", analyser);
        si

        // `return w.length` after `if !isa string(w) then return fi`
        // — HOVER on the `let` local shows `string`.
        hover_on_narrowed_let_local_after_divergent_guard__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 25, 16);
            assert_hover_contains(description, "w: Ghul.string", "hover on narrowed `w` after divergent guard", analyser);
        si

        // `if isa string(a) /\ a.length > 0` — HOVER on the second
        // `a`, narrowed by the first operand within the condition.
        hover_on_narrowed_let_local_in_and_chain__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 31, 20);
            assert_hover_contains(description, "a: Ghul.string", "hover on narrowed `a` in /\\ chain", analyser);
        si

        // `return b.text.length` inside `if b.is_word` — HOVER on
        // the `let` local narrowed to the `WORD` union variant.
        hover_on_let_local_narrowed_to_union_variant__shows_variant() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 39, 20);
            assert_hover_contains(description, "b: NarrowedLocal.Box.WORD", "hover on `b` narrowed to WORD variant", analyser);
        si

        // `return c.n` in the `else` of `if c.is_word` — HOVER on
        // the `let` local narrowed to the other variant, `COUNT`.
        hover_on_let_local_narrowed_in_else_branch__shows_other_variant() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 49, 20);
            assert_hover_contains(description, "c: NarrowedLocal.Box.COUNT", "hover on `c` narrowed to COUNT in else branch", analyser);
        si

        // `return x.length` where the same method also drives
        // iterative type inference (`nums | .map(...) .collect()`)
        // — HOVER on the narrowed local still shows `string`.
        hover_on_narrowed_let_local_with_iterative_inference__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 58, 20);
            assert_hover_contains(description, "x: Ghul.string", "hover on narrowed `x` alongside iterative inference", analyser);
        si

        // `return z.length` inside a class instance method — HOVER
        // on the narrowed `let` local shows `string`.
        hover_on_narrowed_let_local_in_class_method__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 69, 24);
            assert_hover_contains(description, "z: Ghul.string", "hover on narrowed `z` in class method", analyser);
        si

        // The IDE serves hovers after a debounced full COMPILE as
        // well as after a partial EDIT — the narrowed type must
        // survive the COMPILE rebuild.
        hover_on_narrowed_let_local_after_compile__shows_string() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);
            compile(analyser);

            let use_description = hover_description(analyser, 15, 20);
            assert_hover_contains(use_description, "v: Ghul.string", "hover on narrowed `v` after COMPILE", analyser);

            let decl_description = hover_description(analyser, 13, 13);
            assert_hover_contains(decl_description, "v: Ghul.object", "hover on `v` declaration after COMPILE", analyser);
        si
    si
si
