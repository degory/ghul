namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Assignments to captured mut locals and arguments across the
    // incremental body re-walk. Capture and boxing state lives on the
    // symbols as derived flags; the re-walk must not let a previous
    // walk's flags reject code that a cold compile accepts.
    class CAPTURED_MUT_REWALK_TESTS is
        @test()

        init() is si

        // A mut local assigned through a capturing lambda is legal - the
        // outer scope and the closure share one boxed cell. A body-only
        // edit of the same function must not surface a spurious
        // "captured value may not be assigned to" on the re-walk.
        captured_mut_local_assignment_stays_clean_across_a_body_edit() is
            @test()

            let baseline =
                "namespace CapMut is\n"
                "    run() -> int is\n"
                "        let total mut = 0;\n"
                "\n"
                "        let bump = (n: int) is\n"
                "            total = total + n;\n"
                "        si;\n"
                "\n"
                "        bump(5);\n"
                "\n"
                "        return total;\n"
                "    si\n"
                "si\n";

            let body_edited =
                "namespace CapMut is\n"
                "    run() -> int is\n"
                "        let total mut = 0;\n"
                "\n"
                "        let bump = (n: int) is\n"
                "            total = total + n;\n"
                "        si;\n"
                "\n"
                "        bump(7);\n"
                "\n"
                "        return total;\n"
                "    si\n"
                "si\n";

            let use analyser = ANALYSER_PROCESS();

            let cold = edit_and_collect(analyser, "capmut.ghul", baseline);
            Assert.are_equal(
                0,
                cold.count,
                diagnostics_summary("cold EDIT of a clean captured-mut-local source had diagnostics", cold)
            );

            let rewalked = edit_and_collect(analyser, "capmut.ghul", body_edited);
            Assert.are_equal(
                0,
                rewalked.count,
                "{diagnostics_summary("body-only EDIT surfaced spurious diagnostics on the re-walk", rewalked)}"
                "\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // A lambda capturing an argument marks the argument symbol
        // captured; the argument is a retained interface symbol, so the
        // mark survives a body edit. Once the edit removes the lambda,
        // an assignment to the (mut) argument is legal and must not be
        // rejected off the stale mark.
        argument_capture_mark_does_not_outlive_the_capturing_lambda() is
            @test()

            let baseline =
                "namespace CapArg is\n"
                "    make(n: int mut) -> int is\n"
                "        let f = () => n;\n"
                "\n"
                "        return f();\n"
                "    si\n"
                "si\n";

            let body_edited =
                "namespace CapArg is\n"
                "    make(n: int mut) -> int is\n"
                "        n = n + 1;\n"
                "\n"
                "        return n;\n"
                "    si\n"
                "si\n";

            let use analyser = ANALYSER_PROCESS();

            let cold = edit_and_collect(analyser, "caparg.ghul", baseline);
            Assert.are_equal(
                0,
                cold.count,
                diagnostics_summary("cold EDIT of a clean captured-argument source had diagnostics", cold)
            );

            let rewalked = edit_and_collect(analyser, "caparg.ghul", body_edited);
            Assert.are_equal(
                0,
                rewalked.count,
                "{diagnostics_summary("assignment to a mut argument was rejected off a stale capture mark", rewalked)}"
                "\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // The restriction itself stays for now: captured arguments are
        // not yet boxed the way captured mut locals are, so assigning
        // one from inside the closure body is an error even for a mut
        // argument.
        assignment_to_a_captured_argument_still_reports_an_error() is
            @test()

            let source =
                "namespace CapArgErr is\n"
                "    make(n: int mut) -> int is\n"
                "        let f = () is\n"
                "            n = n + 1;\n"
                "        si;\n"
                "\n"
                "        f();\n"
                "\n"
                "        return n;\n"
                "    si\n"
                "si\n";

            let use analyser = ANALYSER_PROCESS();

            let diagnostics = edit_and_collect(analyser, "capargerr.ghul", source);

            Assert.are_equal(
                1,
                diagnostics.count,
                diagnostics_summary("expected exactly the captured-argument error", diagnostics)
            );
            Assert.is_true(
                diagnostics[0].message.contains("captured argument"),
                "expected a captured-argument error, got: '{diagnostics[0].message}'"
            );
        si

        // A non-mut local assigned through a lambda is rejected for the
        // real reason - the local isn't mut - not for being captured.
        assignment_to_a_captured_non_mut_local_reports_immutability() is
            @test()

            let source =
                "namespace CapImm is\n"
                "    run() -> int is\n"
                "        let total = 0;\n"
                "\n"
                "        let bump = (n: int) is\n"
                "            total = total + n;\n"
                "        si;\n"
                "\n"
                "        bump(5);\n"
                "\n"
                "        return total;\n"
                "    si\n"
                "si\n";

            let use analyser = ANALYSER_PROCESS();

            let diagnostics = edit_and_collect(analyser, "capimm.ghul", source);

            Assert.are_equal(
                1,
                diagnostics.count,
                diagnostics_summary("expected exactly the immutability error", diagnostics)
            );
            Assert.is_true(
                diagnostics[0].message.contains("cannot be reassigned"),
                "expected an immutability error, got: '{diagnostics[0].message}'"
            );
        si

        // Send a single-file EDIT; return its user diagnostics for that
        // file.
        edit_and_collect(analyser: ANALYSER_PROCESS, path: string, source: string) -> LIST[DIAGNOSTIC] is
            analyser.send_edit(path, source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
            Assert.are_equal("partial", diagnostics.phase);

            let result = LIST[DIAGNOSTIC]();

            for d in user_diagnostics_of(diagnostics) do
                if d.path.ends_with(path) then
                    result.add(d);
                fi
            od

            return result;
        si
    si
si
