namespace Analysis.Tests is
    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Protocol-mismatch requests - malformed frames, or valid JSON that
    // doesn't match any known request kind - used to force the analyser
    // to emit a restart response and exit. That was disruptive: a client
    // hitting one unrecognised request lost its warm session and had to
    // re-establish it before the next query. The analyser now answers
    // with a discrete Response.ERROR frame and keeps the process alive.
    class PROTOCOL_ERROR_RESPONSE_TESTS is
        @test()

        init() is si

        unparseable_frame__returns_error_and_analyser_survives() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            analyser.write_raw_line("{{\"command\":\"not_a_real_command_kind\"}}");

            let response = analyser.read_response();

            if let err: Response.ERROR = response then
                Assert.is_true(
                    err.message.length > 0,
                    "ERROR response must carry a message"
                );
            else
                Assert.fail("expected Response.ERROR after an unrecognised request kind, got {response.get_type().name}");
            fi

            // The analyser must be alive for a subsequent request - the
            // whole point of turning the case into an error rather than
            // a restart is that one bad frame doesn't cost the session.
            analyser.send_edit("survives.ghul", "namespace Survives is entry() is si si\n");
            let follow_up = analyser.read_response();

            Assert.is_true(
                isa Response.DIAGNOSTICS(follow_up),
                "expected DIAGNOSTICS after the error - the analyser must still be alive"
            );
        si
    si
si
