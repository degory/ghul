namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.RESPONSE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Regression marker for the CLEAR_STATE_VISITOR coverage hole on
    // Expressions.AWAIT and Expressions.SPILL added in #1408. The
    // visitor inherits StrictVisitor and needs an explicit override
    // per AST node kind. Without one, any query handler that falls
    // through to FULL_COMPILER.compile_all on a file containing await
    // re-walks the retained AST — the walk now encounters AWAIT
    // (parser-produced) and SPILL (synthesised by SPILL_AWAITS during
    // the first compile-expressions) and throws. The exception is
    // caught and logged as `FULL_COMPILE caught: ...` on analyser
    // stderr; downstream HOVER / completion / definition responses
    // come back without the data they should have, which the user
    // perceives as analysis-mode silently failing.
    class CLEAR_STATE_AWAIT_TESTS is
        @test()

        init() is si

        load_source() -> string is
            let path = fixture_path("clear-state-await/clear-state-await.ghul");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("clear-state-await.ghul", source);

            let edit_diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", edit_diagnostics.header);

            let edit_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", edit_done.header);
        si

        // HOVER on a no-symbol position (column 1 of `namespace`) falls
        // through to FULL_COMPILER.compile_all, which runs
        // CLEAR_STATE_VISITOR over every source file's AST. On a file
        // with AWAIT / SPILL nodes that visit throws unless an explicit
        // override is in place. Asserting against stderr because the
        // visitor exception is caught and logged out-of-band rather
        // than surfaced as a user diagnostic.
        hover_after_edit_should_not_choke_on_await_or_spill() is
            @test()

            let source = load_source();
            let use analyser = ANALYSER_PROCESS();

            prime(analyser, source);

            analyser.send_hover("clear-state-await.ghul", 1, 1);

            let diagnostics = analyser.read_response();
            Assert.are_equal(
                "DIAGNOSTICS",
                diagnostics.header,
                "expected DIAGNOSTICS frame from HOVER's compile_all, got '{diagnostics.header}'"
            );

            let hover_response = analyser.read_response();
            Assert.are_equal(
                "HOVER",
                hover_response.header,
                "expected HOVER frame after DIAGNOSTICS, got '{hover_response.header}'"
            );

            let stderr = analyser.stderr_capture;
            Assert.is_false(
                stderr.contains("does not define a visit method"),
                "analyser stderr surfaced a missing StrictVisitor override across HOVER's compile_all on a file with await / spill:\n--- analyser stderr ---\n{stderr}"
            );
        si
    si
si
