namespace Analysis.Tests is
    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Issue #88: member completion inside an incomplete construct (an `if`
    // with no `then` yet) used to fall back to enclosing-scope suggestions
    // because the partially typed member access was dropped.
    class MEMBER_COMPLETION_INCOMPLETE_TESTS is
        @test()

        init() is si

        load(name: string) -> string is
            let path = fixture_path("member-completion-incomplete/{name}");
            assert File.exists(path) else "fixture not copied to test output: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, name: string) is
            analyser.send_edit(name, load(name));

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
        si

        has_completion(response: Response.COMPLETION, name: string) -> bool is
            for item in response.items do
                if item.name =~ name then
                    return true;
                fi
            od

            return false;
        si

        // Line 12 is `        if g.` — completion right after the `.`
        // should list GREETER's members, not run()'s locals.
        completion_after_dot_in_incomplete_if_lists_members() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, "member-completion-incomplete.ghul");

            analyser.send_completion("member-completion-incomplete.ghul", 12, 14);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            Assert.is_true(
                has_completion(response, "greet"),
                "expected `greet` among member completions for `g.` in an "
                "incomplete `if`.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.is_false(
                has_completion(response, "g"),
                "completion fell back to enclosing-scope suggestions (local `g` "
                "is visible there) instead of GREETER's members"
            );
        si

        // Line 9 is `        let x: Shapes.` — completion after the `.` in
        // an incomplete type expression should list the `Shapes`
        // namespace's members, not run()'s locals.
        completion_after_dot_in_incomplete_type_expression_lists_members() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, "incomplete-type-expression.ghul");

            analyser.send_completion("incomplete-type-expression.ghul", 9, 23);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            Assert.is_true(
                has_completion(response, "CIRCLE"),
                "expected `CIRCLE` among type-member completions for `Shapes.` "
                "in an incomplete type expression.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        assert_lists_members_at(analyser: ANALYSER_PROCESS, line: int, column: int, where: string) is
            analyser.send_completion("incomplete-statements.ghul", line, column);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            Assert.is_true(
                has_completion(response, "greet"),
                "expected `greet` among member completions {where}.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // Member completion after `g.` should resolve GREETER's members in
        // an incomplete `while`, `return` and `let` initializer too.
        completion_after_dot_in_incomplete_statements_lists_members() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, "incomplete-statements.ghul");

            assert_lists_members_at(analyser, 10, 17, "in an incomplete `while`");
            assert_lists_members_at(analyser, 15, 18, "in an incomplete `return`");
            assert_lists_members_at(analyser, 20, 19, "in an incomplete `let` initializer");
        si

        // Member completion after `g.` must contain only members of the
        // LHS type. In-scope locals, sibling types/functions, statement
        // keywords, namespaces, and other non-members must not leak in.
        completion_after_dot_is_strictly_members() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, "strict-member-completion.ghul");

            // Line 22 is `        g.` — cursor sits in column 11
            // (1-based), right after the dot.
            analyser.send_completion("strict-member-completion.ghul", 22, 11);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            Assert.is_true(
                has_completion(response, "greet"),
                "expected `greet` among LHS members.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            // Build a sorted summary of every name returned so failures
            // tell us which leak path is firing.
            let names = Collections.LIST[string]();
            for item in response.items do
                names.add("{item.name} (kind={item.kind})");
            od
            let summary = string.join("\n  ", names);

            assert_not_present(response, "local_variable", "in-scope local",       summary);
            assert_not_present(response, "another_local",  "in-scope local",       summary);
            assert_not_present(response, "g",              "in-scope local",       summary);
            assert_not_present(response, "UNRELATED_TYPE", "sibling type",         summary);
            assert_not_present(response, "unrelated_function", "sibling function", summary);
            assert_not_present(response, "run",            "sibling function",     summary);
            assert_not_present(response, "while",          "statement keyword",    summary);
            assert_not_present(response, "return",         "statement keyword",    summary);
            assert_not_present(response, "let",            "statement keyword",    summary);
            assert_not_present(response, "if",             "statement keyword",    summary);
            assert_not_present(response, "System",         "root .NET namespace",  summary);
            assert_not_present(response, "Ghul",           "root ghūl namespace",  summary);
        si

        // Same strict rule when a partial member name has been typed
        // after the dot: `g.gr` should still only suggest LHS members,
        // not in-scope locals, siblings, keywords, or namespaces.
        completion_after_partial_member_name_is_strictly_members() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, "partial-member-name.ghul");

            // Line 17 is `        g.gr` — cursor sits in column 13
            // (1-based), right after the partial `gr`.
            analyser.send_completion("partial-member-name.ghul", 17, 13);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            let names = Collections.LIST[string]();
            for item in response.items do
                names.add("{item.name} (kind={item.kind})");
            od
            let summary = string.join("\n  ", names);

            Assert.is_true(
                has_completion(response, "greet"),
                "expected `greet` among LHS members for partial `g.gr`.\n"
                "all returned items:\n  {summary}"
            );

            assert_not_present(response, "local_variable", "in-scope local",       summary);
            assert_not_present(response, "g",              "in-scope local",       summary);
            assert_not_present(response, "unrelated_function", "sibling function", summary);
            assert_not_present(response, "run",            "sibling function",     summary);
            assert_not_present(response, "while",          "statement keyword",    summary);
            assert_not_present(response, "let",            "statement keyword",    summary);
            assert_not_present(response, "System",         "root .NET namespace",  summary);
            assert_not_present(response, "Ghul",           "root ghūl namespace",  summary);
        si

        // `CONTAINER.` — left is a type name (static-access form).
        // Completion must be limited to CONTAINER's members; the
        // enclosing scope's locals/functions/keywords must not leak.
        completion_after_dot_on_type_is_strictly_members() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            prime(analyser, "static-member-access.ghul");

            // Line 16 is `        CONTAINER.` — cursor sits in column 19
            // (1-based), right after the dot.
            analyser.send_completion("static-member-access.ghul", 16, 19);

            let response = analyser.read_query_response();

            assert isa Response.COMPLETION(response) else "expected COMPLETION response";

            let names = Collections.LIST[string]();
            for item in response.items do
                names.add("{item.name} (kind={item.kind})");
            od
            let summary = string.join("\n  ", names);

            assert_not_present(response, "local_variable", "in-scope local",       summary);
            assert_not_present(response, "unrelated_function", "sibling function", summary);
            assert_not_present(response, "run",            "sibling function",     summary);
            assert_not_present(response, "while",          "statement keyword",    summary);
            assert_not_present(response, "let",            "statement keyword",    summary);
            assert_not_present(response, "System",         "root .NET namespace",  summary);
            assert_not_present(response, "Ghul",           "root ghūl namespace",  summary);
        si

        assert_not_present(
            response: Response.COMPLETION,
            name: string,
            description: string,
            summary: string
        ) is
            Assert.is_false(
                has_completion(response, name),
                "completion after `.` should be limited to LHS members, "
                "but `{name}` ({description}) appeared in the result set.\n"
                "all returned items:\n  {summary}"
            );
        si
    si
si
