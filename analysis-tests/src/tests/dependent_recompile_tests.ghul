namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;
    use Analysis.Protocol.user_diagnostics_of;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // A signature edit to a function that a same-file body references must
    // re-bind that body: the incremental interface path reconciles the
    // changed declaration and recompiles the edited file's expressions, so
    // a call whose validity depends on the new signature is re-checked.
    // Observed by a call that flips valid/invalid across the edit.
    class DEPENDENT_RECOMPILE_TESTS is
        @test()

        init() is si

        // probe takes a string; caller passes 0 (int) — invalid.
        source_param_string() -> string =>
            "namespace DepRec is\n"
            "    class C is\n"
            "        init() is si\n"
            "\n"
            "        probe(a: string) -> int => 0;\n"
            "\n"
            "        caller() -> int is\n"
            "            return probe(0);\n"
            "        si\n"
            "    si\n"
            "si\n";

        // probe now takes an int; caller's probe(0) becomes valid. Same
        // declaration count (skeleton-preserving); only observable if the
        // referencing body re-bound.
        source_param_int() -> string =>
            "namespace DepRec is\n"
            "    class C is\n"
            "        init() is si\n"
            "\n"
            "        probe(a: int) -> int => 0;\n"
            "\n"
            "        caller() -> int is\n"
            "            return probe(0);\n"
            "        si\n"
            "    si\n"
            "si\n";

        edit(analyser: ANALYSER_PROCESS, source: string) -> LIST[DIAGNOSTIC] is
            analyser.send_edit("deprec.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response after EDIT";

            return LIST[DIAGNOSTIC](user_diagnostics_of(diagnostics));
        si

        summary(diagnostics: LIST[DIAGNOSTIC]) -> string is
            let result = System.Text.StringBuilder();
            for d in diagnostics do
                result.append("\n  ").append(d.to_string());
            od
            return result.to_string();
        si

        // Invalid -> valid: fixing probe's parameter type clears the
        // caller's error, only if caller re-bound to the new signature.
        signature_edit_clears_a_same_file_referencing_error() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let baseline = edit(analyser, source_param_string());
            Assert.is_true(
                baseline.count > 0,
                "baseline (int arg to string param) should error\n--- stderr ---\n{analyser.stderr_capture}"
            );

            edit(analyser, source_param_int());

            // The debounced COMPILE trues up expression diagnostics across
            // the project — the point being that after the reconcile the
            // caller re-binds, so nothing re-reports the old error.
            analyser.send_compile();
            let compiled = analyser.read_response();
            assert isa Response.DIAGNOSTICS(compiled) else "expected DIAGNOSTICS after COMPILE";

            let after = LIST[DIAGNOSTIC](user_diagnostics_of(compiled));
            Assert.are_equal(
                0,
                after.count,
                "after widening probe to take int + COMPILE, caller's probe(0) should be valid; residual:{summary(after)}\n--- stderr ---\n{analyser.stderr_capture}"
            );
        si

        // Valid -> invalid: narrowing probe's parameter makes the caller's
        // call fail, only if caller re-bound.
        signature_edit_introduces_a_same_file_referencing_error() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            let baseline = edit(analyser, source_param_int());
            Assert.are_equal(
                0,
                baseline.count,
                "baseline (int arg to int param) should be clean; got:{summary(baseline)}\n--- stderr ---\n{analyser.stderr_capture}"
            );

            let after = edit(analyser, source_param_string());
            Assert.is_true(
                after.count > 0,
                "after narrowing probe to take string, caller's probe(0) should error (proving it re-bound)\n--- stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
