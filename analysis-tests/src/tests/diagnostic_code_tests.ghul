namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // The wire DIAGNOSTIC DTO carries the suppressable code slug so an LSP
    // client can offer a `@suppress("<code>")` quick-fix. A `throw` of a
    // non-Exception value raises the `non-exception-throw` warning — assert
    // the code round-trips through the JSON protocol intact.
    class DIAGNOSTIC_CODE_TESTS is
        @test()

        init() is si

        coded_warning_carries_code_on_the_wire() is
            @test()

            let source = File.read_all_text(fixture_path("diagnostic-code/diagnostic-code.ghul"));

            let use analyser = ANALYSER_PROCESS();

            analyser.send_edit("diagnostic-code.ghul", source);

            let response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(response) else "expected DIAGNOSTICS response";

            let user = LIST[DIAGNOSTIC](user_diagnostics_of(response));

            let found mut = false;

            for d in user do
                if d.code? /\ d.code =~ "non-exception-throw" then
                    found = true;
                fi
            od

            Assert.is_true(
                found,
                "expected a diagnostic with code 'non-exception-throw'\n"
                "{diagnostics_summary("got", user)}"
            );
        si
    si
si
