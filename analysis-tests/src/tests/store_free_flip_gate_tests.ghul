namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // A body edit that flips a function's store-free bit must not leave
    // the bit stale. The incremental EDIT paths recompile expressions
    // without re-running infer-store-free, so the debounced COMPILE
    // re-derives the bits and escalates to a full rebuild on any flip.
    // Observed through the hover kind label, which renders `pure` exactly
    // when the store-free bit is set.
    class STORE_FREE_FLIP_GATE_TESTS is
        @test()

        init() is si

        // `probe` reads a field only — store-free.
        source_store_free() -> string =>
            "namespace SFFlip is\n"
            "    class PROBE is\n"
            "        v: int public;\n"
            "        init() is si\n"
            "\n"
            "        probe() -> int is\n"
            "            let w = v;\n"
            "            return w;\n"
            "        si\n"
            "\n"
            "        caller() -> int is\n"
            "            return probe();\n"
            "        si\n"
            "    si\n"
            "si\n";

        // Interface-identical to source_store_free (same signature, same
        // line count), but `probe` now stores to a field — not store-free.
        source_storing() -> string =>
            "namespace SFFlip is\n"
            "    class PROBE is\n"
            "        v: int public;\n"
            "        init() is si\n"
            "\n"
            "        probe() -> int is\n"
            "            v = 7;\n"
            "            return v;\n"
            "        si\n"
            "\n"
            "        caller() -> int is\n"
            "            return probe();\n"
            "        si\n"
            "    si\n"
            "si\n";

        edit(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("sf-flip.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response after EDIT";

            let user_diagnostics = LIST[DIAGNOSTIC](user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        // Hover the `probe()` call inside `caller` — line 12, inside the
        // call name — so the response carries `probe`'s kind label.
        probe_hover_label(analyser: ANALYSER_PROCESS) -> string is
            analyser.send_hover("sf-flip.ghul", 12, 22);

            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";

            if response.kind_label? then
                return response.kind_label;
            fi

            return "";
        si

        // The regression: after the storing edit is committed by a COMPILE,
        // the incremental paths never re-ran infer-store-free, so without
        // the flip-gate `probe` still rendered as `pure` and every caller's
        // narrowing across a call to it stayed unsound.
        body_edit_that_adds_a_store_drops_the_store_free_bit_on_compile() is
            @test()

            let use analyser = ANALYSER_PROCESS();

            edit(analyser, source_store_free());

            let baseline = probe_hover_label(analyser);
            Assert.is_true(
                baseline.contains("pure"),
                "baseline: expected `probe` to render as pure, got '{baseline}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            edit(analyser, source_storing());

            analyser.send_compile();
            let compile_response = analyser.read_response();
            assert isa Response.DIAGNOSTICS(compile_response) else "expected DIAGNOSTICS response after COMPILE";

            let after = probe_hover_label(analyser);
            Assert.is_true(
                !after.contains("pure"),
                "after storing edit + COMPILE: expected `probe` to no longer render as pure, got '{after}'\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si
    si
si
