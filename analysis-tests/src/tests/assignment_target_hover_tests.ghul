namespace Analysis.Tests is
    use Collections.LIST;

    use IO.File;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // HOVER on the target of an assignment. Assigning a
    // non-optional value to a declared-optional variable leaves it
    // known to hold a value, so the assignment target reports the
    // non-optional type — the state the assignment leaves behind,
    // agreeing with a subsequent read — while an optional
    // right-hand side and the declaration itself keep the declared
    // `T?`. Covers reference (`string?`) and value (`int?`)
    // optionals, locals and fields.
    class ASSIGNMENT_TARGET_HOVER_TESTS is
        @test()

        init() is si

        load_fixture() -> string is
            let path = fixture_path("assignment-target-hover/assignment-target-hover.ghul");

            assert File.exists(path) else "fixture missing: {path}";

            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("assignment-target-hover.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";

            let user_diagnostics = LIST(user_diagnostics_of(diagnostics));
            Assert.are_equal(
                0,
                user_diagnostics.count,
                diagnostics_summary("EDIT had unexpected diagnostics", user_diagnostics)
            );
        si

        // A full COMPILE: drains the diagnostics response it writes.
        compile(analyser: ANALYSER_PROCESS) is
            analyser.send_compile();

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("assignment-target-hover.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.signature? then
                return "";
            fi
            if response.kind_label? then
                return "{response.signature} // {response.kind_label}";
            fi
            return response.signature;
        si

        assert_hover_contains(actual: string, expected_substring: string, where: string, analyser: ANALYSER_PROCESS) is
            Assert.is_true(
                actual? /\ actual.contains(expected_substring),
                "{where}: expected HOVER to contain '{expected_substring}', got '{actual}'.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // `s = "hello"` where `s: string?` — HOVER on the target
        // shows non-optional `string`. The ` //` tail pins the type
        // as exactly `Ghul.string`, not `Ghul.string?`.
        hover_on_target_with_non_optional_rhs__shows_non_optional() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 12, 13);
            assert_hover_contains(description, "string?\n    ▶ string //", "hover on `s` assignment target", analyser);
        si

        // `return s.length` after the assignment — the read agrees
        // with the target.
        hover_on_read_after_assignment__shows_non_optional() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 14, 20);
            assert_hover_contains(description, "string?\n    ▶ string //", "hover on `s` read after assignment", analyser);
        si

        // The declaration itself keeps the declared `string?`.
        hover_on_declaration__keeps_declared_optional() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 9, 13);
            assert_hover_contains(description, "s: string?", "hover on `s` declaration", analyser);
        si

        // `t = from` where `from: string?` — an optional right-hand
        // side proves nothing, so the target keeps `string?`.
        hover_on_target_with_optional_rhs__keeps_declared_optional() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 26, 9);
            assert_hover_contains(description, "t: string?", "hover on `t` assignment target", analyser);
        si

        // `n = 42` where `n: int?` — the value-type optional
        // lowering behaves the same.
        hover_on_value_optional_target__shows_non_optional() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 38, 13);
            assert_hover_contains(description, "int?\n    ▶ int //", "hover on `n` assignment target", analyser);
        si

        // `_note = value` where `_note: string?` and `value: string`
        // — a field target reports non-optional too.
        hover_on_field_target__shows_non_optional() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 52, 13);
            assert_hover_contains(description, "string?\n    ▶ string // field", "hover on `_note` assignment target", analyser);
        si

        // `return _note.length` inside `if _note?` — a narrowed
        // field read renders its narrowed type.
        hover_on_narrowed_field_read__shows_non_optional() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);

            let description = hover_description(analyser, 57, 24);
            assert_hover_contains(description, "string?\n    ▶ string // field", "hover on narrowed `_note` read", analyser);
        si

        // The IDE serves hovers after a debounced full COMPILE as
        // well as after a partial EDIT.
        hover_on_target_after_compile__shows_non_optional() is
            @test()

            let source = load_fixture();
            let use analyser = ANALYSER_PROCESS();
            prime(analyser, source);
            compile(analyser);

            let target_description = hover_description(analyser, 12, 13);
            assert_hover_contains(target_description, "string?\n    ▶ string //", "hover on `s` assignment target after COMPILE", analyser);

            let decl_description = hover_description(analyser, 9, 13);
            assert_hover_contains(decl_description, "s: string?", "hover on `s` declaration after COMPILE", analyser);
        si
    si
si
