namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.RESPONSE;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Tests targeting symbols whose **declaration span** wraps an
    // edited body (the E position from the matrix). A class's brace
    // range starts above the edit and ends below it; an
    // interface-preserving body edit must shift the class's end-line
    // — via the virtual `Symbol.set_span` that #1350 added — even
    // though the class's name-location (start) is unchanged.
    //
    // #SYMBOLS# (the document outline) is the primary surface that
    // notices a missed `set_span`: its rows carry endLine, so a
    // stale end-line shows up as the class's outline entry pointing
    // at the wrong closing line. HOVER on a symbol's own
    // declaration is the other surface, since it derives from the
    // same span field.
    class INCREMENTAL_WRAPPED_EDIT_TESTS is
        @test()

        init() is si

        // Baseline:
        //   1 namespace Wrap is
        //   2     use Collections.LIST;
        //   3
        //   4     class CONTAINER is               ← class span START
        //   5         _data: LIST[int];
        //   6
        //   7         init() is
        //   8             _data = LIST[int]();
        //   9         si
        //  10
        //  11         first() -> int => _data[0];
        //  12
        //  13         last() -> int is
        //  14             return _data[_data.count - 1];
        //  15         si
        //  16
        //  17         sum() -> int is             ← method whose body grows
        //  18             let total mut = 0;
        //  19             for x in _data do
        //  20                 total = total + x;
        //  21             od
        //  22             return total;
        //  23         si
        //  24
        //  25         count: int => _data.count;
        //  26
        //  27         is_empty: bool => _data.count == 0;
        //  28     si                              ← class span END
        //  29
        //  30     summarise(c: CONTAINER) -> int => c.count + c.sum();
        //  31 si
        baseline() -> string =>
            "namespace Wrap is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    class CONTAINER is\n"
            "        _data: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _data = LIST[int]();\n"
            "        si\n"
            "\n"
            "        first() -> int => _data[0];\n"
            "\n"
            "        last() -> int is\n"
            "            return _data[_data.count - 1];\n"
            "        si\n"
            "\n"
            "        sum() -> int is\n"
            "            let total mut = 0;\n"
            "            for x in _data do\n"
            "                total = total + x;\n"
            "            od\n"
            "            return total;\n"
            "        si\n"
            "\n"
            "        count: int => _data.count;\n"
            "\n"
            "        is_empty: bool => _data.count == 0;\n"
            "    si\n"
            "\n"
            "    summarise(c: CONTAINER) -> int => c.count + c.sum();\n"
            "si\n";

        // Edited: `sum`'s body grows by three lines. The class's span
        // end-line shifts from 28 → 31 (and `count`, `is_empty`,
        // `summarise` shift by +3 too). `class CONTAINER`'s name
        // location is unchanged (still line 4 col 11); its span end
        // is what moves.
        edited() -> string =>
            "namespace Wrap is\n"
            "    use Collections.LIST;\n"
            "\n"
            "    class CONTAINER is\n"
            "        _data: LIST[int];\n"
            "\n"
            "        init() is\n"
            "            _data = LIST[int]();\n"
            "        si\n"
            "\n"
            "        first() -> int => _data[0];\n"
            "\n"
            "        last() -> int is\n"
            "            return _data[_data.count - 1];\n"
            "        si\n"
            "\n"
            "        sum() -> int is\n"
            "            let a = 1;\n"
            "            let b = 2;\n"
            "            let c = 3;\n"
            "            let total mut = a + b + c;\n"
            "            for x in _data do\n"
            "                total = total + x;\n"
            "            od\n"
            "            return total;\n"
            "        si\n"
            "\n"
            "        count: int => _data.count;\n"
            "\n"
            "        is_empty: bool => _data.count == 0;\n"
            "    si\n"
            "\n"
            "    summarise(c: CONTAINER) -> int => c.count + c.sum();\n"
            "si\n";

        // The class span starts at line 4 (name location), ends at
        // line 28 (the closing `si`) in baseline. After the +3 edit,
        // the closing `si` is at line 31. If `Symbol.set_span` was
        // missed on the class itself, the outline still reports the
        // class's span as ending at line 28.
        class_span_end_line_shifts_with_wrapped_body_edit() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_symbols("wrap.ghul");

            let response = analyser.read_query_response();
            Assert.are_equal("SYMBOLS", response.header);

            let rows = symbol_rows(response);
            let class_row = find_row_by_description(rows, "CONTAINER");

            Assert.is_true(
                class_row?,
                "no #SYMBOLS# row matched CONTAINER. rows:\n"
                "{format_rows(rows)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let span = parse_span(class_row);

            Assert.are_equal(
                4,
                span.start_line,
                "CONTAINER's name location is on line 4 (unchanged "
                "across the edit). Got start line {span.start_line}.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
            Assert.are_equal(
                31,
                span.end_line,
                "CONTAINER's closing `si` moved from line 28 → 31 with "
                "the body edit. Got end line {span.end_line} — "
                "Symbol.set_span did not run on the wrapping class.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // `count` is a property declared below the edit (line 25 →
        // 28). Its outline span should reflect the new line.
        property_below_edit_outline_span_shifts() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_symbols("wrap.ghul");

            let response = analyser.read_query_response();
            Assert.are_equal("SYMBOLS", response.header);

            let rows = symbol_rows(response);
            let count_row = find_row_by_description(rows, "count");

            Assert.is_true(
                count_row?,
                "no #SYMBOLS# row matched `count`. rows:\n"
                "{format_rows(rows)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let span = parse_span(count_row);
            Assert.are_equal(
                28,
                span.start_line,
                "`count` declaration moved from line 25 → 28 with the "
                "edit. Got line {span.start_line}.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // `is_empty` is two lines further down (line 27 → 30).
        further_property_below_edit_outline_span_shifts() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_symbols("wrap.ghul");

            let response = analyser.read_query_response();
            Assert.are_equal("SYMBOLS", response.header);

            let rows = symbol_rows(response);
            let row = find_row_by_description(rows, "is_empty");

            Assert.is_true(
                row?,
                "no #SYMBOLS# row matched `is_empty`. rows:\n"
                "{format_rows(rows)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let span = parse_span(row);
            Assert.are_equal(
                30,
                span.start_line,
                "`is_empty` declaration moved from line 27 → 30. Got "
                "line {span.start_line}.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // `summarise` is a namespace-level function below the class
        // (line 30 → 33). Its outline span should shift, *and* the
        // class members (`count`, `sum`) are referenced inside its
        // body — DEFINITION on the `c.count` use must land on post-
        // shift line 28.
        definition_on_post_shift_property_use_lands_on_post_shift_declaration() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // post-edit line 33 — `    summarise(c: CONTAINER) -> int => c.count + c.sum();`
            // `c.count` — `c` at col 41, `.` at 42, `count` at 43-47.
            analyser.send_definition("wrap.ghul", 33, 45);

            let response = analyser.read_query_response();
            Assert.are_equal("DEFINITION", response.header);

            let lines = location_start_lines(response, "wrap.ghul");
            Assert.is_true(
                lines.count >= 1,
                "DEFINITION on c.count returned no locations\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
            Assert.are_equal(
                28,
                lines[0],
                "`count` declaration moved 25 → 28; DEFINITION should "
                "land on post-shift line 28. Got {lines[0]}.\n"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // SYMBOLS dedup after the edit — no row should appear twice.
        // The Phase 2.x reconciliation drops body definitions and
        // re-records them; if it neglected the file's
        // SYMBOL_DEFINITION_LOCATIONS too, every member would appear
        // twice in the outline.
        symbols_outline_has_no_duplicate_rows_after_wrapped_edit() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            analyser.send_symbols("wrap.ghul");

            let response = analyser.read_query_response();
            Assert.are_equal("SYMBOLS", response.header);

            let rows = symbol_rows(response);
            let distinct = Collections.SET[string]();
            for r in rows do
                distinct.add(r);
            od

            Assert.is_true(
                rows.count > 0,
                "#SYMBOLS# returned no rows\n--- analyser stderr ---\n"
                "{analyser.stderr_capture}"
            );
            Assert.are_equal(
                rows.count,
                distinct.count,
                "#SYMBOLS# returned {rows.count} rows but only "
                "{distinct.count} are distinct. dup rows:\n"
                "{format_rows(rows)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        // ─────────────────────────────────────────────────────────────────
        //   Helpers
        // ─────────────────────────────────────────────────────────────────

        prime(analyser: ANALYSER_PROCESS) is
            analyser.send_edit("wrap.ghul", baseline());
            drain_edit_assert_clean(analyser, "baseline");

            analyser.send_edit("wrap.ghul", edited());
            drain_edit_assert_clean(analyser, "incremental edit");
        si

        drain_edit_assert_clean(analyser: ANALYSER_PROCESS, label: string) is
            let diagnostics = analyser.read_response();
            Assert.are_equal("DIAGNOSTICS", diagnostics.header);

            let user_diagnostics = LIST(diagnostics.user_diagnostics);
            Assert.are_equal(
                0,
                user_diagnostics.count,
                "{label}: fixture expected to compile clean — got "
                "{user_diagnostics.count} diagnostics. fixture bug.\n"
                "{diagnostics_summary(label, user_diagnostics)}"
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            let partial_done = analyser.read_response();
            Assert.are_equal("PARTIAL DONE", partial_done.header);
        si

        // SYMBOLS response: first body line is the file path, then
        // one symbol-info row per declared symbol. Each row is
        // `description \t kind \t startLine \t startCol \t endLine \t endCol \t qualifier`.
        symbol_rows(response: RESPONSE) -> LIST[string] is
            let rows = LIST[string]();
            let seen_path mut = false;

            for line in response.lines do
                if !seen_path then
                    seen_path = true;
                    continue;
                fi
                if string.is_null_or_white_space(line) then
                    continue;
                fi
                rows.add(line);
            od

            return rows;
        si

        // Find the first row whose description (field 0) contains
        // the given name fragment. Returns null if none matches —
        // tests assert the presence themselves.
        find_row_by_description(rows: LIST[string], name: string) -> string? is
            for row in rows do
                let fields = LIST[string](row.split(['\t']));
                if fields.count >= 1 /\ fields[0].contains(name) then
                    return row;
                fi
            od
            return null;
        si

        // Extract (startLine, startCol, endLine, endCol) from a
        // SYMBOLS row.
        parse_span(row: string) -> SPAN is
            let fields = LIST[string](row.split(['\t']));
            assert fields.count >= 6
                else "SYMBOLS row has too few fields: '{row}'";

            return SPAN(
                System.Convert.to_int32(fields[2]),
                System.Convert.to_int32(fields[3]),
                System.Convert.to_int32(fields[4]),
                System.Convert.to_int32(fields[5])
            );
        si

        format_rows(rows: LIST[string]) -> string is
            let result = System.Text.StringBuilder();
            for r in rows do
                result.append("  ");
                result.append(r);
                result.append('\n');
            od
            return result.to_string();
        si

        location_start_lines(response: RESPONSE, file_name: string) -> LIST[int] is
            let result = LIST[int]();

            for line in response.lines do
                if string.is_null_or_white_space(line) then
                    continue;
                fi

                let fields = LIST[string](line.split(['\t']));

                if fields.count >= 2 /\ fields[0].ends_with(file_name) then
                    result.add(System.Convert.to_int32(fields[1]));
                fi
            od

            return LIST[int](result | .sort((a, b) => a - b));
        si
    si

    class SPAN is
        start_line: int public;
        start_column: int public;
        end_line: int public;
        end_column: int public;

        init(start_line: int, start_column: int, end_line: int, end_column: int) is
            self.start_line = start_line;
            self.start_column = start_column;
            self.end_line = end_line;
            self.end_column = end_column;
        si
    si
si
