namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.RENAME_EDIT;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // The target name of an impl/partial block is a reference to the
    // target type: hover renders the target's signature and rename from
    // the injection site covers the declaration and every other
    // occurrence. A union's hover also lists its traits - both a trait
    // declared on its header and one attached by an impl block.
    class INJECTION_TARGET_QUERY_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace App is\n"
            "    trait TAGGED is\n"
            "        tag() -> string => \"t\";\n"
            "    si\n"
            "    trait PRINTED is\n"
            "        pr() -> string => \"p\";\n"
            "    si\n"
            "    class WIDGET is\n"
            "    si\n"
            "    union LU: PRINTED is\n"
            "        NIL;\n"
            "        CONS(v: int);\n"
            "    si\n"
            "    partial WIDGET is\n"
            "        w() -> int => 42;\n"
            "    si\n"
            "    impl TAGGED for WIDGET is\n"
            "        tag() -> string => \"w\";\n"
            "    si\n"
            "    impl TAGGED for LU is\n"
            "        tag() -> string => \"u\";\n"
            "    si\n"
            "si\n";

        prime(analyser: ANALYSER_PROCESS) is
            analyser.send_edit("inj.ghul", source());

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
        si

        hover(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("inj.ghul", line, column);

            let response = analyser.read_query_response();

            assert isa Response.HOVER(response) else "expected HOVER response";

            if !response.signature? then
                return "<none>";
            fi

            return response.signature;
        si

        hover_on_partial_target_shows_the_target() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // the WIDGET in `partial WIDGET`
            Assert.are_equal(
                "class WIDGET",
                hover(analyser, 14, 13),
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        hover_on_impl_target_shows_the_target() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // the WIDGET in `impl TAGGED for WIDGET`
            Assert.are_equal(
                "class WIDGET",
                hover(analyser, 17, 21),
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        hover_on_union_lists_declared_and_injected_traits() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // the LU in `union LU: PRINTED is`
            let at_declaration = hover(analyser, 10, 11);

            // the LU in `impl TAGGED for LU`
            let at_impl_target = hover(analyser, 20, 21);

            Assert.are_equal(
                "union LU: PRINTED, TAGGED",
                at_declaration,
                "--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.are_equal(at_declaration, at_impl_target, "declaration and impl-target hovers should agree");
        si

        rename_from_impl_target_covers_all_occurrences() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser);

            // rename WIDGET, positioned on the target name in the impl header
            analyser.send_rename_request("inj.ghul", 17, 21, "GADGET");

            let response = analyser.read_query_response();
            assert isa Response.RENAME(response) else "expected RENAME response.\n--- analyser stderr ---\n{analyser.stderr_capture}";

            let edits = LIST[RENAME_EDIT](response.edits);
            let lines = LIST[int]();

            for e in edits do
                Assert.are_equal("GADGET", e.new_name, "edit carried wrong new name: {e}");
                lines.add(e.start_line);
            od

            lines.sort();

            // declaration, partial target, impl target
            Assert.are_equal(3, edits.count, "expected declaration + partial + impl edits");
            Assert.are_equal(8, lines[0]);
            Assert.are_equal(14, lines[1]);
            Assert.are_equal(17, lines[2]);
        si
    si
si
