namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.INLAY_HINT;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // Drives EDIT, COMPILE, INLAY_HINTS and asserts that a narrowing kill
    // surfaces as an inlay carrying the `narrowing-killed` code — never as
    // a hint diagnostic. Also confirms the open-files gate: no inlay is
    // recorded for a file the client is not viewing.
    class NARROWING_KILL_HINT_SMOKE_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace KillHint is\n"
            "    class WIDGET is\n"
            "        init() is si\n"
            "        make() -> WIDGET? => WIDGET();\n"
            "        run() is\n"
            "            let w mut = make();\n"
            "            if w? then\n"
            "                w = make();\n"
            "            fi\n"
            "        si\n"
            "    si\n"
            "si\n";

        // Drive EDIT then COMPILE then INLAY_HINTS. `open_paths` is declared
        // before the edit, per the open-files contract.
        compile_inlays(open_paths: Collections.Iterable[string]) -> LIST[INLAY_HINT] is
            let use analyser = ANALYSER_PROCESS();

            analyser.send_open_files(open_paths);

            analyser.send_edit("killhint.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            let compile = analyser.read_response();
            assert isa Response.DIAGNOSTICS(compile) else "expected DIAGNOSTICS after COMPILE";

            analyser.send_inlay_hints("killhint.ghul");
            let inlays = analyser.read_response();
            assert isa Response.INLAY_HINTS(inlays) else "expected INLAY_HINTS response";

            return LIST[INLAY_HINT](inlays.hints);
        si

        has_kill_inlay(hints: Collections.Iterable[INLAY_HINT]) -> bool is
            for h in hints do
                if h.code =~ "narrowing-killed" /\ h.detail.contains("reassigned") then
                    return true;
                fi
            od

            return false;
        si

        kill_inlay_present_when_file_is_open() is
            @test()

            let inlays = compile_inlays(["killhint.ghul"]);

            Assert.is_true(
                has_kill_inlay(inlays),
                "expected a narrowing-killed inlay for the open file"
            );
        si

        kill_inlay_absent_when_file_is_not_open() is
            @test()

            let inlays = compile_inlays(["other.ghul"]);

            Assert.is_false(
                has_kill_inlay(inlays),
                "expected no narrowing-killed inlay for a file that is not open"
            );
        si

        // The kill inlay's label is the direction sigil `◀`; the
        // reverted-to declared type is named in `detail` so hover
        // surfaces it. For the `w` local its declared type is
        // `WIDGET?` (from `make()`), so `detail` mentions `WIDGET?`.
        kill_inlay_label_carries_reverted_type() is
            @test()

            let inlays = compile_inlays(["killhint.ghul"]);

            let saw mut = false;
            for h in inlays do
                if h.code =~ "narrowing-killed" /\ h.label =~ "◀" /\ h.detail.contains("WIDGET?") then
                    saw = true;
                fi
            od

            Assert.is_true(saw, "expected a narrowing-killed inlay with label ◀ whose detail carries the declared type WIDGET?");
        si
    si
si
