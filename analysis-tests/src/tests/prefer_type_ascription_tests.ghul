namespace Analysis.Tests is
    use Collections.LIST;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.DIAGNOSTIC;
    use Analysis.Protocol.FIX_EDIT;
    use Analysis.Protocol.QUICK_FIX;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // The prefer-type-ascription hint fires on `if let x = cast T(v)` — a
    // checked scrutinee cast that reads the same as `if let x: T = v` — and
    // carries a quick fix that performs that rewrite.
    class PREFER_TYPE_ASCRIPTION_TESTS is
        @test()

        init() is si

        source() -> string =>
            "namespace Ascribe is\n"
            "    trait ANIMAL is\n"
            "    si\n"
            "    class CAT: ANIMAL is\n"
            "        init() is si\n"
            "        meow() is si\n"
            "    si\n"
            "    class USER is\n"
            "        init() is si\n"
            "        run(a: ANIMAL) is\n"
            "            if let c = cast CAT(a) then\n"
            "                c.meow();\n"
            "            fi\n"
            "        si\n"
            "    si\n"
            "si\n";

        collect_diagnostics() -> LIST[DIAGNOSTIC] is
            let use analyser = ANALYSER_PROCESS();

            analyser.send_open_files(["ascribe.ghul"]);

            analyser.send_edit("ascribe.ghul", source());
            let edit = analyser.read_response();
            assert isa Response.DIAGNOSTICS(edit) else "expected DIAGNOSTICS after EDIT";

            analyser.send_compile();
            let compile = analyser.read_response();
            assert isa Response.DIAGNOSTICS(compile) else "expected DIAGNOSTICS after COMPILE";

            return LIST[DIAGNOSTIC](user_diagnostics_of(compile));
        si

        // severity 4 == HINT.
        hint_of(diagnostics: Collections.Iterable[DIAGNOSTIC], code: string) -> DIAGNOSTIC? is
            for d in diagnostics do
                if d.severity == 4 /\ d.code? /\ d.code =~ code then
                    return d;
                fi
            od

            return null;
        si

        hint_is_reported() is
            @test()

            let diagnostics = collect_diagnostics();

            Assert.is_true(
                hint_of(diagnostics, "prefer-type-ascription")?,
                "expected a prefer-type-ascription hint for `if let c = cast CAT(a)`\n"
                "{diagnostics_summary("got", diagnostics)}"
            );
        si

        // The cast is checked by the if let, so the cast-may-throw warning
        // must not fire alongside the hint.
        cast_may_throw_is_suppressed() is
            @test()

            let diagnostics = collect_diagnostics();

            let found mut = false;

            for d in diagnostics do
                if d.code? /\ d.code =~ "cast-may-throw" then
                    found = true;
                fi
            od

            Assert.is_false(
                found,
                "expected no cast-may-throw warning on a checked scrutinee cast\n"
                "{diagnostics_summary("got", diagnostics)}"
            );
        si

        fix_rewrites_to_ascription() is
            @test()

            let diagnostics = collect_diagnostics();

            let hint = hint_of(diagnostics, "prefer-type-ascription");

            assert hint? else "expected a prefer-type-ascription hint";

            let fixes = hint.fixes;

            assert fixes? else "expected the hint to carry fixes";

            let rewrite: QUICK_FIX? mut = null;

            for f in fixes do
                if f.title =~ "Replace cast with type ascription" then
                    rewrite = f;
                fi
            od

            assert rewrite? else "expected a Replace cast with type ascription fix";

            let rewritten = apply_edits(source(), rewrite.edits);

            Assert.is_true(
                rewritten.contains("if let c: Ascribe.CAT = a then"),
                "expected the fix to rewrite the clause to a type ascription; got line:\n{rewritten}"
            );

            Assert.is_false(
                rewritten.contains("cast CAT"),
                "expected the cast to be removed; got:\n{rewritten}"
            );
        si

        // Apply a set of FIX_EDITs to a source string. Wire coordinates are
        // 1-based with an exclusive end column; edits are spliced in
        // descending start-offset order so earlier offsets stay valid.
        apply_edits(source: string, edits: Collections.Iterable[FIX_EDIT]) -> string is
            let ordered =
                edits |
                    .sort(
                        (a, b) =>
                            _offset(source, b.start_line, b.start_column) -
                            _offset(source, a.start_line, a.start_column)
                    )
                    .collect();

            let result mut = source;

            for e in ordered do
                let start = _offset(result, e.start_line, e.start_column);
                let end = _offset(result, e.end_line, e.end_column);

                result = "{result.substring(0, start)}{e.new_text}{result.substring(end)}";
            od

            return result;
        si

        // Absolute character offset of a 1-based (line, column) position.
        _offset(source: string, line: int, column: int) -> int is
            let offset mut = 0;
            let current_line mut = 1;

            while current_line < line do
                offset = source.index_of("\n", offset) + 1;
                current_line = current_line + 1;
            od

            return offset + column - 1;
        si
    si
si
