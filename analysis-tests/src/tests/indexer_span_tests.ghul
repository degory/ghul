namespace Analysis.Tests is
    use IO.File;
    use IO.Path;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // The indexer-accessor symbol use was previously recorded with a
    // bracket-shaped span whose end column was two columns left of the
    // closing `]`. Hover at the `]` returned nothing and the SEMANTIC
    // TOKENS classifier emitted a `method` token over a partial range
    // (the `[` and the first character of the index expression).
    // The span should run from `[` through `]` so the brackets and the
    // whole index access hover to the resolved get_Item, while
    // find_hover_use's shortest-match tiebreak keeps an inner
    // identifier hover (e.g. on `idx` itself) winning over the wider
    // bracket span.
    class INDEXER_SPAN_TESTS is
        @test()

        init() is si

        load() -> string is
            let path = Path.combine(fixture_dir("indexer-span"), "main.ghul");
            assert File.exists(path) else "fixture missing: {path}";
            return File.read_all_text(path);
        si

        prime(analyser: ANALYSER_PROCESS, source: string) is
            analyser.send_edit("main.ghul", source);

            let diagnostics = analyser.read_response();
            assert isa Response.DIAGNOSTICS(diagnostics) else "expected DIAGNOSTICS response";
        si

        hover_description(analyser: ANALYSER_PROCESS, line: int, column: int) -> string is
            analyser.send_hover("main.ghul", line, column);
            let response = analyser.read_query_response();
            assert isa Response.HOVER(response) else "expected HOVER response";
            if !response.signature? then
                return "";
            fi
            if response.kind_label? then
                return "{response.signature} // {response.kind_label}";
            fi
            return response.signature;
        si

        // `let v = xs[idx];` on line 5 — `xs` at cols 17..18,
        // `[` at 19, `idx` at 20..22, `]` at 23.

        // Hover on the closing `]` returns the indexer accessor —
        // previously empty because the recorded span ended at col 21.
        hover_on_closing_bracket_returns_indexer() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            let description = hover_description(analyser, 5, 23);

            Assert.is_true(
                description? /\ description.length > 0,
                "HOVER on `]` returned no description.\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            Assert.is_true(
                description.contains("get_Item") \/
                description.contains("Item") \/
                description.contains("int"),
                "HOVER on `]` should describe the indexer accessor; got: '{description}'"
            );
        si

        // Hover on the opening `[` also returns the indexer.
        hover_on_opening_bracket_returns_indexer() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            let description = hover_description(analyser, 5, 19);

            Assert.is_true(
                description? /\ description.length > 0,
                "HOVER on `[` returned no description"
            );
        si

        // Hover on the inner index expression `idx` resolves to the
        // local variable, not the enclosing indexer — the shortest-
        // match tiebreak in find_hover_use makes the inner use win.
        hover_on_inner_index_expression_returns_variable() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            let description = hover_description(analyser, 5, 21);

            Assert.is_true(
                description? /\ description.length > 0,
                "HOVER on `idx` returned no description"
            );

            Assert.is_true(
                description.contains("idx"),
                "HOVER on `idx` should describe the local variable; got: '{description}'"
            );
        si

        // The semantic-tokens classifier should not emit a `method`
        // token that strictly contains the inner `idx` identifier.
        // Either the bracket span is filtered out entirely (because
        // it strictly contains `idx`) or it lands strictly on the
        // brackets — never partially overlapping the identifier.
        semantic_tokens_method_span_does_not_partially_overlap_index() is
            @test()

            let use analyser = ANALYSER_PROCESS();
            prime(analyser, load());

            analyser.send_semantic_tokens("main.ghul");

            let response = analyser.read_response();
            assert isa Response.SEMANTIC_TOKENS(response) else "expected SEMANTIC_TOKENS response";

            let idx_line = 5;
            let idx_start = 20;
            let idx_end = 22;

            for token in response.tokens do
                if token.token_type !~ "method" \/ token.start_line != idx_line then
                    continue;
                fi

                let partial_overlap =
                    token.start_column <= idx_end /\
                    token.end_column >= idx_start /\
                    !(token.start_column <= idx_start /\ token.end_column >= idx_end);

                Assert.is_false(
                    partial_overlap,
                    "method token at cols {token.start_column}..{token.end_column} partially overlaps the index expression `idx` at cols {idx_start}..{idx_end}"
                );
            od
        si
    si
si
