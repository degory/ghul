namespace Analysis.Tests is
    use Collections.Iterable;

    use Analysis.Protocol.ANALYSER_PROCESS;
    use Analysis.Protocol.Response;

    use Microsoft.VisualStudio.TestTools.UnitTesting.Assert;

    // End-to-end round-trip checks for the analysis-mode source formatter:
    // each fixture is sent through FORMAT and the response is asserted to
    // match the canonical form. The fixtures cover syntax forms that the
    // formatter has historically dropped, mangled, or crashed on — anything
    // not already exercised here is fair game to regress.
    //
    // FORMAT_ISOLATION_TESTS covers the "errors-in-other-files do not block
    // formatting" guarantee; this fixture is focussed on the printer
    // producing source that re-parses to the same tree.
    class FORMATTER_ROUND_TRIP_TESTS is
        @test()

        init() is si

        // The formatter always finishes its output with a single trailing
        // newline; the helper appends one so the test source can read as a
        // newline-separated list of lines without that detail in every
        // fixture.
        lines(parts: Iterable[string]) -> string is
            let result = System.Text.StringBuilder();
            for part in parts do
                result.append(part);
                result.append('\n');
            od
            return result.to_string();
        si

        // Format `source` once and assert the result equals `expected`.
        // Then format the result a second time and assert idempotence — a
        // formatter that drops or mangles syntax usually trips the second
        // pass too, so the idempotence check is a cheap second signal.
        assert_round_trips(source: string, expected: string) is
            let use analyser = ANALYSER_PROCESS();

            analyser.send_format("round_trip.ghul", source);
            let first = analyser.read_response();

            assert isa Response.FORMAT(first) else
                "expected FORMAT response on first pass\n--- analyser stderr ---\n{analyser.stderr_capture}";

            Assert.are_equal(
                expected,
                first.text,
                "first-pass format did not match expected output\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );

            analyser.send_format("round_trip.ghul", first.text);
            let second = analyser.read_response();

            assert isa Response.FORMAT(second) else
                "expected FORMAT response on second pass\n--- analyser stderr ---\n{analyser.stderr_capture}";

            Assert.are_equal(
                first.text,
                second.text,
                "formatter is not idempotent\n--- analyser stderr ---\n{analyser.stderr_capture}"
            );
        si

        primary_constructor_header_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    class BOX(value: int) is",
                "        _value;",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        primary_constructor_semicolon_shorthand_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    class BOX(value: int);",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        primary_constructor_with_init_modifier_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    class TOKEN_PAIR(token: int, value: string init) is",
                "        get_value() -> string => value;",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        struct_with_primary_constructor_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    struct POINT(x: int, y: int);",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        super_call_body_declaration_round_trips() is
            @test()

            // SUPER_CALL is reachable only from inside a primary-ctor
            // class body. Without an explicit FORMATTER override the
            // StrictVisitor base throws and FORMAT echoes the buffer back
            // unchanged — invisible to the user but a pure-regression
            // path.
            let body = lines([
                "namespace Test is",
                "    class ANIMAL is",
                "        init(name: string) is",
                "        si",
                "    si",
                "",
                "    class DOG(name: string): ANIMAL is",
                "        super(name);",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        secondary_init_splice_marker_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    class POINT(x: int, y: int) is",
                "        init(.., label: string) is",
                "        si",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        let_mut_modifier_round_trips() is
            @test()

            // A trailing `mut` on a local declares a reassignable variable;
            // without it the local is immutable. Dropping `mut` on format
            // silently changes the program's meaning.
            let body = lines([
                "namespace Test is",
                "    main() is",
                "        let a mut = 0;",
                "        let b: int mut = 1;",
                "        a = a + 1;",
                "        b = b + 1;",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        union_variants_round_trip() is
            @test()

            let body = lines([
                "namespace Test is",
                "    union COLOUR is",
                "        RED;",
                "        GREEN;",
                "        BLUE(intensity: int);",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        union_with_primary_constructor_round_trips() is
            @test()

            // A union primary-constructor header `(name: string)` is part
            // of the source the user wrote and must survive a format pass.
            // Variant fields containing `..` round-trip verbatim; a variant
            // with no additional fields round-trips to the bare-`NAME;`
            // form (the implicit splice).
            let source = lines([
                "namespace Test is",
                "    union Color(name: string) is",
                "        RED(..);",
                "        GREEN;",
                "        BLUE(intensity: int, ..);",
                "    si",
                "si"
            ]);

            let expected = lines([
                "namespace Test is",
                "    union Color(name: string) is",
                "        RED;",
                "        GREEN;",
                "        BLUE(intensity: int, ..);",
                "    si",
                "si"
            ]);

            assert_round_trips(source, expected);
        si

        case_statement_then_else_round_trips() is
            @test()

            // The inherited base printer emits the legacy `when X :` /
            // `default` arm shape, which the parser does not accept;
            // the formatter must produce `when X then` / `else` for the
            // output to re-parse.
            let body = lines([
                "namespace Test is",
                "    label(value: int) is",
                "        case value",
                "        when 200 then",
                "            let ok = 1;",
                "        when 500 then",
                "            let server = 2;",
                "        else",
                "            let other = 3;",
                "        esac",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        case_expression_round_trips() is
            @test()

            let source = lines([
                "namespace Test is",
                "    label(value: int) -> string =>",
                "        case value",
                "        when 200 then",
                "            \"ok\"",
                "        else",
                "            \"other\"",
                "        esac;",
                "si"
            ]);

            let expected = lines([
                "namespace Test is",
                "    label(value: int) -> string => case value",
                "    when 200 then",
                "        \"ok\"",
                "    else",
                "        \"other\"",
                "    esac;",
                "si"
            ]);

            assert_round_trips(source, expected);
        si

        case_binding_pattern_round_trips() is
            @test()

            let source = lines([
                "namespace Test is",
                "    describe(p: int) -> string =>",
                "        case p",
                "        when v: int then",
                "            \"int\"",
                "        else",
                "            \"other\"",
                "        esac;",
                "si"
            ]);

            let expected = lines([
                "namespace Test is",
                "    describe(p: int) -> string => case p",
                "    when v: int then",
                "        \"int\"",
                "    else",
                "        \"other\"",
                "    esac;",
                "si"
            ]);

            assert_round_trips(source, expected);
        si

        case_literal_leaf_pattern_round_trips() is
            @test()

            let source = lines([
                "namespace Test is",
                "    describe(p: (int, int)) -> string =>",
                "        case p",
                "        when (1, n) then",
                "            \"first\"",
                "        else",
                "            \"other\"",
                "        esac;",
                "si"
            ]);

            let expected = lines([
                "namespace Test is",
                "    describe(p: (int,int)) -> string => case p",
                "    when (1, n) then",
                "        \"first\"",
                "    else",
                "        \"other\"",
                "    esac;",
                "si"
            ]);

            assert_round_trips(source, expected);
        si

        if_let_chained_guard_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    sum(x: int?, y: int) -> int => if let v = x /\\ v > 0 /\\ y > v then v + y else 0 fi;",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        generic_kind_constraint_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    typed[T: class](x: T) -> T => x;",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        generic_new_constraint_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    typed[T: class new](x: T) -> T => x;",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        generic_variance_constraint_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    trait COVARIANT[T: out] is",
                "    si",
                "    trait CONTRAVARIANT[T: in] is",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        optional_type_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    length(name: string?) -> int => if name? then name!.length else 0 fi;",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        yield_in_iterable_returning_function_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    first_three() -> Collections.Iterable[int] is",
                "        yield 1;",
                "        yield 2;",
                "        yield 3;",
                "    si",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        default_expression_round_trips() is
            @test()

            let body = lines([
                "namespace Test is",
                "    blank() -> int => default;",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        postfix_pipe_wrap_round_trips() is
            @test()

            // The parser desugars `xs |` into a synthesised
            // `Ghul.Pipes.pipe(xs)` call with `is_pipe_wrap` set;
            // without a dedicated formatter branch the round-trip emits
            // the literal `Ghul.Pipes.pipe(xs).find(...)` instead of the
            // user's `xs | .find(...)`.
            let body = lines([
                "namespace Test is",
                "    use Collections;",
                "    first_big(xs: List[int]) -> int? => xs | .find(x => x > 10);",
                "si"
            ]);

            assert_round_trips(body, body);
        si

        // `val ... lav` is a value-producing block. The formatter
        // emits the keyword pair as its own lines so multi-statement
        // bodies stack vertically; each inner statement renders via
        // its own visit.

        val_lav_value_block_round_trips() is
            @test()

            let source = lines([
                "namespace Test is",
                "    f() -> int => val let y = 5; y * 2 lav;",
                "si"
            ]);

            let expected = lines([
                "namespace Test is",
                "    f() -> int => val",
                "        let y = 5;",
                "        y * 2;",
                "    lav;",
                "si"
            ]);

            assert_round_trips(source, expected);
        si

        val_lav_void_block_round_trips() is
            @test()

            // Void-tail (LET) block in void position: the formatter
            // emits the same form; semantic context decides void vs
            // value at compile time, not at format time.
            let source = lines([
                "namespace Test is",
                "    f() is",
                "        val write_line(\"hi\"); let unused = 99; lav;",
                "    si",
                "si"
            ]);

            let expected = lines([
                "namespace Test is",
                "    f() is",
                "        val",
                "            write_line(\"hi\");",
                "            let unused = 99;",
                "        lav;",
                "    si",
                "si"
            ]);

            assert_round_trips(source, expected);
        si
    si
si
