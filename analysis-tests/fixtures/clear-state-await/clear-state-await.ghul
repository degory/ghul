// Repro fixture for the CLEAR_STATE_VISITOR regression that fires when
// the analyser runs a FULL_COMPILE after an EDIT touching a file with
// `await` or any operand the SPILL_AWAITS pass wrapped in SPILL. The
// visitor inherits from StrictVisitor and so requires explicit overrides
// for every AST node kind — AWAIT and SPILL were added by #1408 without
// matching overrides, so the visitor's throwNotImplemented fell through
// on the second compile, surfacing as "Visitor … does not define a
// visit method for await/spill" in analyser stderr and breaking HOVER /
// completion / every other analysis operation that depends on a
// subsequent full compile.

namespace ClearStateAwait is
    use System.Threading.Tasks;
    use IO.Std;

    fetch_int() -> Tasks.Task[int] => Tasks.Task.from_result(42);

    add(a: int, b: int) -> int => a + b;

    entry() -> Tasks.Task is
        let x = await fetch_int();
        // A binary expression with an await operand drives SPILL_AWAITS
        // to synthesise SPILL nodes, so the re-walk has to clear both.
        let y = add(await fetch_int(), x);
        Std.write_line("x={x}, y={y}");
    si
si
