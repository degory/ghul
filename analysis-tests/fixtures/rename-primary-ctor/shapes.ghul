namespace RenamePrimaryCtor is
    use IO.Std;

    // Auto-property form: the primary parameter `x` becomes a public
    // property `x`; uses read it by that bare name.
    class POINT(x: int, y: int) is
        show() -> string => "({x}, {y})";
    si

    // Capture form: the primary parameter `value` is captured by the
    // body field declaration `_value` under the `_foo` / `foo` matching
    // rule. The parameter name and the field name differ by the `_`.
    class BOX(value: int) is
        _value;

        peek() -> string => "[{_value}]";
    si

    // Modifier form: the leading `_` makes `_count` a private field with
    // no public property; the parameter and field share the one name.
    class COUNTER(_count: int) is
        bump() -> int => _count + 1;
    si

    entry() is
        let p = POINT(1, 2);
        Std.write_line("{p.x} {p.y} {p.show()}");

        let b = BOX(7);
        Std.write_line("{b.peek()}");

        let c = COUNTER(0);
        Std.write_line("{c.bump()}");
    si
si
