namespace ConstructorCallTokens is
    class BOX[T] is
        _value: T;
        init(value: T) is _value = value; si
        get() -> T => _value;
    si

    entry() is
        let bare = BOX(1);
        let explicit = BOX[int](2);
        IO.Std.write_line("{bare.get()} {explicit.get()}");
    si
si
