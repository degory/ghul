// Repro fixture for the CLEAR_STATE_VISITOR (and other StrictVisitor)
// coverage holes on Definitions.PARTIAL / Definitions.IMPL. Those
// visitors throw on any node type they have no override for, so the
// re-walk of a retained AST containing a `partial` or `impl` block
// blows up on the second compile with "does not define a visit method
// for partial ...", breaking HOVER / completion / every operation that
// depends on a subsequent full compile.

namespace ClearStatePartialImpl is
    use IO.Std;

    trait Printer is
        print() -> string => "?";
    si

    class BOX is
        _v: int;
        init(v: int) is _v = v; si
    si

    partial BOX is
        value() -> int => _v;
    si

    impl Printer for BOX is
        print() -> string => "box {_v}";
    si

    entry() is
        let b = BOX(3);
        Std.write_line("{b.value()}");
        let p: Printer = b;
        Std.write_line(p.print());
    si
si
