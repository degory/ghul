namespace NoArgVariantInferenceHover is
    use IO.Std;
    use Collections;

    // Fixture for the no-arg-variant inference back-feed: when a
    // no-arg union variant constructor (NIL) sits in a sibling
    // position alongside a value-bearing constructor (CONS) whose
    // type-arg is itself bound to a generic-function type parameter,
    // the LUB merge through the union ancestor should resolve NIL's
    // owner type-arg phantom — so analyse-mode HOVER renders the
    // resolved type, not `***`.

    union List[T] is
        NIL;
        CONS(head: T, tail: List[T]);
    si

    use List.NIL;
    use List.CONS;

    list_example[T](elements: Collections.List[T]) is
        let list = CONS(elements[0], CONS(elements[1], CONS(elements[2], NIL())));
        Std.write_line("count: {elements.count}");
    si

    entry() is
        list_example([1, 2, 3]);
        list_example(["A", "B", "C"]);
    si
si
