namespace FieldPropertyTokens is
    use IO.Std;

    class BOX is
        count: int public;
        label: string => "box";

        init(count: int) is
            self.count = count;
        si
    si

    entry() is
        let b = BOX(3);
        let total mut = b.count;
        total = total + b.count;
        Std.write_line("{b.label} {total}");
    si
si
