namespace QuickFixes is
    use IO.Std;

    class BOX is
        label: string;

        init() is
            label = "hello";
        si
    si

    get_box() -> BOX? => BOX();

    entry() is
        let b = get_box();

        if b? then
            Std.out.write_line(b!.label);
            Std.out.write_line("{b?}");
            Std.out.write_line(b?.label);
        fi
    si
si
