// Repro fixture for the CLEAR_STATE_VISITOR coverage hole on
// Statements.REFUTABLE_BINDING. The visitor inherits from StrictVisitor
// and so requires an explicit override per AST node kind. REFUTABLE_BINDING
// is the new node driving `if let` arms; without an override, any analyser
// path that re-walks a retained AST after EDIT throws on the second
// compile-expressions, surfacing as "Visitor … does not define a visit
// method for refutable binding" on analyser stderr and breaking HOVER /
// completion / every other analysis operation that depends on a
// subsequent full compile.

namespace ClearStateRefutableBinding is
    use IO.Std;

    pick(x: int) -> int? is
        if x > 0 then
            return x;
        fi

        return null;
    si

    entry() is
        if let y = pick(7) then
            Std.write_line("got {y}");
        else
            Std.write_line("nothing");
        fi
    si
si
