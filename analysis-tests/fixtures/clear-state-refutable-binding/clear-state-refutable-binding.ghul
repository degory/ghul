namespace ClearStateRefutableBinding is
    use IO.Std;

    pick(x: int) -> int? is
        if x > 0 then
            return x;
        fi

        return null;
    si

    entry() is
        if let y = pick(7) then
            Std.write_line("got {y}");
        else
            Std.write_line("nothing");
        fi
    si
si
