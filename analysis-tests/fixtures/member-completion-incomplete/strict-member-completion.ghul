namespace StrictMemberCompletion is
    class GREETER is
        init() is si

        greet() -> string => "hello";

        farewell() -> string => "goodbye";
    si

    class UNRELATED_TYPE is
        init() is si

        unrelated_method() -> int => 42;
    si

    unrelated_function() -> int => 99;

    run() is
        let local_variable = 1;
        let another_local = "x";
        let g = GREETER();
        g.
    si
si
