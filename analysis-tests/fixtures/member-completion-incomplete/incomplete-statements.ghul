namespace MemberCompletionVariety is
    class GREETER is
        init() is si

        greet() -> string => "hello";
    si

    in_while() is
        let g = GREETER();
        while g.
    si

    in_return() -> string is
        let g = GREETER();
        return g.
    si

    in_let() is
        let g = GREETER();
        let y = g.
    si
si
