namespace StoreFreeHover is
    use IO.Std;

    helper(x: int) -> int => x + 1;

    class BOX is
        v: int public;
        label: int => v * 2;
        init() is si
        side() -> int => 1;

        bump() -> int is
            v = v + 1;
            return v;
        si
    si

    entry() is
        let box = BOX();
        let a = helper(1);
        let b = box.side();
        let c = box.label;
        let d = box.bump();
        Std.write_line("{a} {b} {c} {d}");
    si
si
