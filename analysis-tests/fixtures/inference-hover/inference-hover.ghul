namespace InferenceHover is
    use IO.Std;
    use Collections;

    class BOX[T] is
        _value: T;
        init(value: T) is _value = value; si
        get() -> T => _value;
    si

    identity[T](x: T) -> T => x;

    make_pair[A, B](a: A, b: B) -> (left: A, right: B) =>
        (left = a, right = b);

    class FACTORY is
        wrap[T](x: T) -> BOX[T] static => BOX(x);
    si

    entry() is
        let ints = [1, 2, 3];
        let b = BOX(42);
        let id_str = identity("hello");
        let pair = make_pair(1, "two");
        let wrapped = FACTORY.wrap(99);
        let doubled = ints | .map(n => n * 2) .collect();
        let nested = BOX(BOX("inner"));
        let lam = (s: string) => s.length;

        for x in ints do
            Std.write_line("x={x}");
        od

        let two_tuple = (7, "seven");
        let (first_el, second_el) = two_tuple;

        Std.write_line("first_el={first_el} second_el={second_el}");
        Std.write_line("ok ints.count={ints.count} b={b.get()} id_str={id_str}");
        Std.write_line("pair.left={pair.left} wrapped.get={wrapped.get()}");
        Std.write_line("doubled.count={doubled.count} nested.get.get={nested.get().get()} lam={lam("hi")}");
    si
si
