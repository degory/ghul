namespace RenameUnion is
    use IO.Std;

    union TREE is
        NODE(left: int, right: int);
        LEAF(value: int);
        EMPTY;
    si

    describe(t: TREE) -> string is
        if let node: TREE.NODE = t then
            return "node {node.left} {node.right}";
        elif let leaf: TREE.LEAF = t then
            return "leaf {leaf.value}";
        fi

        return "empty";
    si

    entry() is
        let t: TREE = TREE.NODE(1, 2);
        let u: TREE = TREE.LEAF(3);
        let e: TREE = TREE.EMPTY;

        Std.write_line(describe(t));
        Std.write_line(describe(u));
        Std.write_line(describe(e));
    si
si
