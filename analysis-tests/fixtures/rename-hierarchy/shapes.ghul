namespace RenameHierarchy is
    trait SHAPE is
        area() -> int;

        kind: string;
    si

    class POLYGON: SHAPE is
        init() is si

        area() -> int => 0;

        kind: string => "polygon";
    si

    class SQUARE: POLYGON is
        _side: int;

        init(side: int) is
            super.init();
            _side = side;
        si

        area() -> int => _side * _side;

        kind: string => "square";
    si

    class TRIANGLE: POLYGON is
        _width: int;
        _height: int;

        init(width: int, height: int) is
            super.init();
            _width = width;
            _height = height;
        si

        area() -> int => _width * _height / 2;

        kind: string => "triangle";
    si
si
