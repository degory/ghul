namespace RenameHierarchy is
    use IO.Std;

    entry() is
        let sh: SHAPE = SQUARE(3);
        Std.write_line("{sh.area()} {sh.kind}");

        let po: POLYGON = TRIANGLE(4, 6);
        Std.write_line("{po.area()} {po.kind}");

        let sq = SQUARE(5);
        Std.write_line("{sq.area()} {sq.kind}");

        let tr = TRIANGLE(2, 8);
        Std.write_line("{tr.area()} {tr.kind}");
    si
si
