namespace LambdaRewalkHover is
    use IO.Std;

    // Fixture for hover freshness across inference re-walks: the
    // outer lambda's parameter `s` is unannotated, so its body is
    // walked before `s`'s type is known - the bare DONE below can
    // only specialize against placeholder types on that walk - and
    // walked again once the later call fixes `s: string`. HOVER on
    // DONE must describe the settled walk's specialization
    // (STEP[char,int]), not the placeholder walk's.

    union STEP[T, S] is
        DONE;
        YIELD(value: T, state: S);
    si

    use STEP.DONE;
    use STEP.YIELD;

    first[T, S](initial: S, advance: S -> STEP[T, S]) -> string is
        if let y: STEP.YIELD[T, S] = advance(initial) then
            return "yielded {y.value}";
        fi

        return "done";
    si

    entry() is
        let first_char = s =>
            let xs = s.to_char_array() in
            first(0, i => if i == xs.count then DONE else YIELD(xs[i], i + 1) fi);

        Std.write_line(first_char("hello"));
    si
si
