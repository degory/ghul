namespace InferenceHoverIterative is
    use IO.Std;
    use Collections;

    // Fixture for HOVER over identifiers whose type only resolves
    // through iterative inference — i.e., the variable's type
    // starts as a placeholder and converges across multiple body
    // walks. The classic shapes:
    //   - `let xs = LIST();`  (resolved by a later `.add(int)`)
    //   - `let m = MAP();`    (resolved by a later set / lookup)
    //   - `[1,2,3] | .filter(p => p > 0)` where `p` is inferred
    //     from the body's `> 0` constraint, not from a formal
    //
    // These are the hard cases for iterative inference — the
    // variable carries a placeholder type initially and only
    // resolves later. HOVER must show the *resolved* type.

    entry() is
        let xs = LIST();
        xs.add(10);
        xs.add(20);
        xs.add(30);

        let m = MAP();
        m["alpha"] = 1;
        m["beta"] = 2;

        let big = xs | .filter(p => p > 15) .collect();

        let mapped = xs | .map(n => "{n}!") .collect();

        Std.write_line("xs.count={xs.count}");
        Std.write_line("m.count={m.count}");
        Std.write_line("big.count={big.count}");
        Std.write_line("mapped.count={mapped.count}");
    si
si
