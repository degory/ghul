@precedence("##", "addition")

namespace UserOperatorTokens is
    use IO.Std;

    class POINT(x: int, y: int) is
        x: int => x;
        y: int => y;
    si

    // Overload of a standard operator for a user type.
    +(a: POINT, b: POINT) -> POINT => POINT(a.x + b.x, a.y + b.y);

    // A novel user-defined operator.
    ##(a: int, b: int) -> int => a + b;

    entry() is
        let p = POINT(1, 2) + POINT(3, 4);
        let n = 5 ## 6;
        Std.write_line("{p.x} {n}");
    si
si
