namespace NarrowedLocal is
    use IO.Std;

    union Box is
        WORD(text: string);
        COUNT(n: int);
    si

    source() -> object => "text";
    make_box() -> Box => Box.WORD("hi");

    in_branch() -> int is
        let v = source();
        if isa string(v) then
            return v.length;
        fi
        return 0;
    si

    after_guard() -> int is
        let w = source();
        if !isa string(w) then
            return -1;
        fi
        return w.length;
    si

    and_chain() -> int is
        let a = source();
        if isa string(a) /\ a.length > 0 then
            return a.length;
        fi
        return 0;
    si

    variant_branch() -> int is
        let b = make_box();
        if isa Box.WORD(b) then
            return b.text.length;
        fi
        return 0;
    si

    variant_else() -> int is
        let c = make_box();
        if isa Box.WORD(c) then
            return c.text.length;
        else
            return c.n;
        fi
    si

    iterative() -> int is
        let x = source();
        let nums = [1, 2, 3];
        let doubled = nums | .map(n => n * 2) .collect();
        if isa string(x) then
            return x.length + doubled.count;
        fi
        return 0;
    si

    class CONSUMER is
        init() is si
        pick() -> object => "z";
        run() -> int is
            let z = pick();
            if isa string(z) then
                return z.length;
            fi
            return 0;
        si
    si

    entry() is
        Std.write_line("{in_branch()}");
        Std.write_line("{after_guard()}");
        Std.write_line("{and_chain()}");
        Std.write_line("{variant_branch()}");
        Std.write_line("{variant_else()}");
        Std.write_line("{iterative()}");
    si
si
