namespace AssignmentTargetHover is
    use IO.Std;

    // Assignment-target hover: `s` is declared `string?`; assigning
    // a non-optional value leaves it known to hold a value, so
    // hover on the assignment target reports non-optional `string`,
    // agreeing with the read on the following line.
    assign_reference(flag: bool) -> int is
        let s: string? mut = null;

        if flag then
            s = "hello";

            return s.length;
        fi

        return 0;
    si

    // Assigning an optional right-hand side: the target may still
    // be empty afterwards, so the target keeps the declared
    // `string?`.
    assign_optional(from: string?) -> string? is
        let t: string? mut = null;

        t = from;

        return t;
    si

    // Value-type optional target: `int?` lowers to a wrapper
    // struct, but the assignment leaves it holding a value all the
    // same.
    assign_value(flag: bool) -> int is
        let n: int? mut = null;

        if flag then
            n = 42;

            return n;
        fi

        return 0;
    si

    class HOLDER is
        _note: string?;

        init() is si

        set_note(value: string) is
            _note = value;
        si

        read_note() -> int is
            if _note? then
                return _note.length;
            fi

            return 0;
        si
    si

    entry() is
        Std.write_line("{assign_reference(true)}");
        Std.write_line("{assign_optional("x")}");
        Std.write_line("{assign_value(true)}");

        let holder = HOLDER();
        holder.set_note("hi");
        Std.write_line("{holder.read_note()}");
    si
si
