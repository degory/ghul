namespace RenameEnum is
    use IO.Std;

    class STORE is
        classify(level: SEVERITY) -> string is
            if level == SEVERITY.HIGH then
                return "high";
            elif level == SEVERITY.MEDIUM then
                return "medium";
            fi

            return "low";
        si

        worst() -> SEVERITY => SEVERITY.HIGH;

        report(r: REPORT) is
            let s: SEVERITY = r.level;
            Std.write_line(classify(s));
        si
    si
si
