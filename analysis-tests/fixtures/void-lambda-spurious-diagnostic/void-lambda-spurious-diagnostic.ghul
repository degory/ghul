// Repro for a spurious analysis-mode "cannot use void value here"
// diagnostic on a void-returning expression-bodied lambda whose body
// is itself a void call (`t => on_complete(t);`). Reduced from
// Ghul.Async._FOR_DRIVER in ghul-runtime.
//
// Trigger: the slot's parameter type is a constructed .NET generic
// (here Tasks.TASK[int]) whose underlying open type matches the
// innate Task generic. Func slots store the return type as the last
// entry of `arguments`; Action slots strip the void return, so
// `arguments[count-1]` is the last input arg, not void. compile_lambdas
// used to read that entry as the return, which falsely matched the
// Task[T]-slot detection and set wrap_inferred_return_as_task, then
// visit(Bodies.EXPRESSION) wrapped the void body call as
// Tasks.TASK.from_result(...) — and the wrap's argument check tripped
// "cannot use void value here".

namespace VoidLambda is
    class DRIVER is
        _callback: (Tasks.TASK[int]) -> void;

        init() is
            _callback = t => on_complete(t);
        si

        on_complete(t: Tasks.TASK[int]) is si
    si

    entry() is si
si
