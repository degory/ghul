// Repro fixture for the CLEAR_STATE_VISITOR coverage hole on
// Expressions.VAL_BLOCK. The visitor inherits from StrictVisitor,
// whose pre(VAL_BLOCK) throws. Without an explicit pre override on
// CLEAR_STATE_VISITOR, the re-walk of any file containing `val ... lav`
// blows up as soon as it hits the block — surfacing as
// "Visitor Syntax.Process.CLEAR_STATE_VISITOR does not define a visit
// method for val block ..." on analyser stderr and breaking HOVER /
// completion / every operation that depends on a subsequent full
// compile.

namespace ClearStateValBlock is
    use IO.Std;

    parse(text: string) -> Iterable[string] => val
        let words = text.split([' '], System.StringSplitOptions.REMOVE_EMPTY_ENTRIES);

        if words.length == 0 then
            return LIST[string]();
        fi

        let result = LIST[string]();
        for w in words do
            result.add(w);
        od
        return result;
    lav;

    entry() is
        let bits = parse("hello world");
        for b in bits do
            Std.write_line(b);
        od
    si
si
