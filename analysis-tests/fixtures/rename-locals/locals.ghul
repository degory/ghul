namespace RenameLocals is
    use IO.Std;
    use Collections.LIST;

    run() is
        let total mut = 0;
        total = total + 1;
        total = total + 2;
        Std.write_line("{total}");

        let numbers = LIST[int]();
        numbers.add(2);
        numbers.add(3);

        let squared = numbers | .map((value: int) => value * value);

        for s in squared do
            Std.write_line("{s}");
        od
    si
si
