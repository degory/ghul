namespace IfLetLeafHover is
    use IO.Std;

    // `if let b.contents?` declares an immutable local `contents` on
    // the scrutinee's `.contents` member token. HOVER on that leaf
    // must describe the property the value came from; HOVER on the
    // narrowed use in the then-branch describes the derived local.
    class BOX is
        contents: string? public;

        init(contents: string?) is
            self.contents = contents;
        si
    si

    describe(b: BOX) -> int is
        if let b.contents? then
            return contents.length;
        fi

        return 0;
    si

    entry() is
        Std.write_line("{describe(BOX("hello"))}");
    si
si
