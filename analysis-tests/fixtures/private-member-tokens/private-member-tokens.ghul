namespace PrivateMemberTokens is
    use IO.Std;

    class BOX is
        _count: int;
        total: int public;

        init(count: int) is
            _count = count;
            total = count;
        si

        value() -> int => _count;
    si

    entry() is
        let b = BOX(3);
        Std.write_line("{b.total} {b.value()}");
    si
si
