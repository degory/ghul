namespace TraitMembersReferences is
    trait GREETER is
        greet() -> string;

        polite_greet() -> string => "Hello, {greet()}";

        name: string;
    si

    class FORMAL_GREETER: GREETER is
        init() is si

        greet() -> string => "Good day";

        name: string => "Formal";
    si

    class CASUAL_GREETER: GREETER is
        init() is si

        greet() -> string => "Hi";

        name: string => "Casual";

        polite_greet() -> string => "Hi, friend";
    si
si
