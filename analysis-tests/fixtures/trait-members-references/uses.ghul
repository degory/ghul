namespace TraitMembersReferences is
    use IO.Std;

    entry() is
        let g1: GREETER = FORMAL_GREETER();
        Std.write_line(g1.greet());
        Std.write_line(g1.polite_greet());
        Std.write_line(g1.name);

        let g2: GREETER = CASUAL_GREETER();
        Std.write_line(g2.greet());
        Std.write_line(g2.polite_greet());
        Std.write_line(g2.name);

        let f = FORMAL_GREETER();
        Std.write_line(f.greet());
        Std.write_line(f.polite_greet());
        Std.write_line(f.name);

        let c = CASUAL_GREETER();
        Std.write_line(c.greet());
        Std.write_line(c.polite_greet());
        Std.write_line(c.name);
    si
si
