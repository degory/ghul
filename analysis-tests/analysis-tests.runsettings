<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <MSTest>
    <Parallelize>
      <!-- Workers=0 → use Environment.ProcessorCount. Each test class
           spawns its own ANALYSER_PROCESS subprocess, so per-class
           independence is what we exploit; ClassLevel keeps methods
           within a class serial so they can safely share the spawned
           subprocess. -->
      <Workers>0</Workers>
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>
</RunSettings>
