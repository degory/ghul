<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <EnvironmentVariables>
      <!-- Opt the spawned analyser into the incremental body re-walk so the
           INCREMENTAL_* test classes actually exercise that path. The
           compiler defaults the flag off; ANALYSER_PROCESS forwards the env
           var via the response file. -->
      <ANALYSER_EXTRA_ARGS>--incremental-analysis</ANALYSER_EXTRA_ARGS>
    </EnvironmentVariables>
  </RunConfiguration>
  <MSTest>
    <Parallelize>
      <!-- Workers=0 → use Environment.ProcessorCount. Each test class
           spawns its own ANALYSER_PROCESS subprocess, so per-class
           independence is what we exploit; ClassLevel keeps methods
           within a class serial so they can safely share the spawned
           subprocess. -->
      <Workers>0</Workers>
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>
</RunSettings>
