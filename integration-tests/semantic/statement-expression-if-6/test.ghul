use IO.Std.write_line;

class BASE is
si

class DERIVED_A: BASE is
    init() is si
si

class DERIVED_B: BASE is
    init() is si
si

entry() is
    let valid_if_branch_throw_else = if true then 1 else throw System.Exception("oops") fi;
    let throw_if_branch_valid_else = if true then throw System.Exception("oops") else 2 fi;

    // FIXME expect error
    let throw_both_branches = if true then throw System.Exception("oops") else throw System.Exception("oops") fi;
si

if_else_all_branches_null_is_error() is
    let result =
        if true then
            null
        else
            null
        fi
si

if_elif_else_all_branches_null_is_error() is
    let result =
        if true then
            null
        elif false then
            null
        else
            null
        fi        
si

if_else_if_branch_null_is_ok() is
    let result: string =
        if true then
            null
        else
            "1234"
        fi
si

if_else_else_branch_null_is_ok() is
    let result: string =
        if true then
            "1234"
        else
            null
        fi
si

if_elif_if_branch_null_is_ok() is
    let result: string =
        if true then
            null
        elif false then
            null
        else
            "1234"
        fi
si

if_elif_elif_branch_null_is_ok() is
    let result: string =
        if true then
            "1234"
        elif false then
            null
        else
            null
        fi
si


// A value-type branch mixed with a null branch widens the joined
// type to the value type's optional carrier (int?), in any position.
if_else_null_then_int_widens_to_optional() is
    let result =
        if true then
            null
        else
            1234
        fi
si

if_else_int_then_null_widens_to_optional() is
    let result =
        if true then
            1234
        else
            null
        fi
si

if_elif_int_arms_else_null_widens_to_optional() is
    let result =
        if true then
            1234
        elif false then
            5678
        else
            null
        fi
si

if_elif_null_arm_widens_to_optional() is
    let result =
        if true then
            1234
        elif false then
            null
        else
            5678
        fi
si

