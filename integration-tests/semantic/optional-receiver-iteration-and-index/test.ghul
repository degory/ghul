namespace Test is
    use Collections;

    // Iterating or indexing through an optional receiver not proven to
    // hold a value here warns, the same as member access on an optional
    // receiver: the receiver's members are reached off its non-optional
    // shape, so an absent value would fault at run time.

    class MAIN is
        iterate(xs: LIST[int]?) is
            for x in xs do
                return;
            od
        si

        index(xs: LIST[int]?) -> int => xs[0];

        entry() static is
            return;
        si
    si
si
