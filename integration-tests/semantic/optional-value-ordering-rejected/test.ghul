namespace Test is
    // Order comparison on an optional value is rejected: the generic
    // `struct`-constrained comparison does not bind its type parameter
    // to a value optional, so `a < b` on an optional is a clean
    // overload-not-found diagnostic rather than a silent comparison of
    // a possibly-absent value. A parameter stays optional (no narrowing
    // from an initializer), so the comparison is on `int?`.

    class MAIN is
        compare_optional(a: int?) -> bool => a < 10;

        entry() static is
            return;
        si
    si
si
