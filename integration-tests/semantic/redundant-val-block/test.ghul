use IO.Std.write_line;

// Positive cases: `val ... lav` in expression-statement position
// where the surrounding context already accepts a statement list.
// Each of these should warn with [redundant-val-block].

bare_expression_statement() is
    val
        write_line("a");
        write_line("b");
    lav;
si

if_then_arm_statement_position(flag: bool) is
    if flag then
        val
            write_line("then a");
            write_line("then b");
        lav;
    fi
si

if_else_arms_statement_position(flag: bool) is
    if flag then
        val
            write_line("then");
        lav;
    else
        val
            write_line("else");
        lav;
    fi
si

if_elif_else_arms_statement_position(n: int) is
    if n == 0 then
        val
            write_line("zero");
        lav;
    elif n == 1 then
        val
            write_line("one");
        lav;
    else
        val
            write_line("other");
        lav;
    fi
si

if_arms_expression_position(flag: bool) -> int =>
    if flag then
        val
            write_line("then");
            1
        lav
    else
        val
            write_line("else");
            2
        lav
    fi;

case_arms_statement_position(n: int) is
    case n
    when 0 then
        val
            write_line("zero");
        lav;
    when 1 then
        val
            write_line("one");
        lav;
    else
        val
            write_line("other");
        lav;
    esac
si

// Negative cases: should NOT warn.

let_declaration_in_body() is
    val
        let local = 42;
        write_line("local = {local}");
    lav;
si

bare_return_inside(flag: bool) is
    val
        if flag then
            return;
        fi
        write_line("did work");
    lav;
si

valued_return_inside(flag: bool) -> int =>
    val
        if flag then
            return 99;
        fi
        7
    lav;

// Function-body val-block: not in expression-statement position,
// can be the only way to write a multi-statement `=>` body.
function_body() =>
    val
        write_line("a");
        write_line("b");
    lav;

// RHS of let: val needed, no warning.
let_rhs() is
    let x = val write_line("setup"); 42 lav;
    write_line("x = {x}");
si

entry() is
    bare_expression_statement();
    if_then_arm_statement_position(true);
    if_else_arms_statement_position(true);
    if_elif_else_arms_statement_position(1);
    write_line("expr = {if_arms_expression_position(true)}");
    case_arms_statement_position(0);
    let_declaration_in_body();
    bare_return_inside(false);
    write_line("valued = {valued_return_inside(false)}");
    function_body();
    let_rhs();
si
