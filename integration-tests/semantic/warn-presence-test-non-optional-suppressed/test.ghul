namespace Test is
    use Std = IO.Std;

    class BOX is
        label: string;
        init(label: string) is self.label = label; si
    si

    class Main is
        entry() static is
            // With `--suppress presence-test-non-optional` the presence
            // test on the non-optional reference `b` does not warn.
            let b = BOX("hi");
            if b? then
                Std.out.write_line(b.label);
            fi
            return;
        si
    si
si
