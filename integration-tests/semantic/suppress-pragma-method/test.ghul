namespace Test is

    class MAIN is
        // Method-level @suppress: the whole method body sits inside
        // the wrapper, every throw is silenced.
        @suppress("non-exception-throw")
        silenced() is
            throw 12345;
            throw "still suppressed";
        si

        // Sibling method without the pragma — warns.
        warns() is
            throw "this one warns";
        si

        entry() static is
        si
    si
si
