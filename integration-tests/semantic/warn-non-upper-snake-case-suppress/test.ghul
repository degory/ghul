namespace Test is
    use IO.Std;

    @suppress("non-upper-snake-case-name")
    class Holder is
        value: int public;

        init(v: int) is
            value = v;
        si
    si

    class Main is
        entry() static is
            let h = Holder(42);
            Std.write_line("{h.value}");
        si
    si
si
