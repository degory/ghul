// A type bound on a *function* type parameter is now enforced when the
// type argument is inferred from the call — `identity("hi")` infers
// T = string, which doesn't derive from A.

namespace Test is
    class A is
        init() is si
    si

    identity[T: A](x: T) -> T => x;

    class Main is
        entry() static is
            identity("hi");
            return;
        si
    si
si
