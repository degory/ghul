namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Statement-level @suppress: silences the non-exception-throw
            // warning on the throw it wraps. The second throw, outside the
            // pragma, still warns.
            @suppress("non-exception-throw") throw 12345;

            throw "should warn not exception";
        si
    si
si
