namespace Test is
    use Collections;

    class ANIMAL is
        init() is si
    si

    class CAT: ANIMAL is
        init() is super.init(); si
    si

    class BASE is
        init() is si

        // Method intended to be overridden by a narrower-typed version.
        add_things(things: List[ANIMAL]) is
        si

        // Sister case: narrower receiver type than the inherited one.
        greet(a: ANIMAL) -> string => "ANIMAL";
    si

    class DERIVED: BASE is
        init() is super.init(); si

        // Mistake: meant to override but used `LIST[ANIMAL]` (concrete)
        // instead of `List[ANIMAL]` (the inherited abstract trait).
        // expect warning: looks like meant-to-override mismatch.
        add_things(things: LIST[ANIMAL]) is
        si

        // Mistake: narrower arg type — should warn.
        // expect warning: looks like meant-to-override mismatch.
        greet(a: CAT) -> string => "CAT";
    si
si
