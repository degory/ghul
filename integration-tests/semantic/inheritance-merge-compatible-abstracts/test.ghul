namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let c = CONCRETE();
            let a: HasCountA = c;
            let b: HasCountB = c;

            Std.write_line("{c.count}");
            Std.write_line("{a.count}");
            Std.write_line("{b.count}");
        si
    si

    trait HasCountA is
        count: int;
    si

    trait HasCountB is
        count: int;
    si

    // Trait inherits two abstract `count` declarations with identical
    // signatures. ghūl previously errored "cannot inherit multiple
    // abstract methods"; the resolver now merges them into a single
    // virtual slot.
    trait BOTH: HasCountA, HasCountB is
    si

    class CONCRETE: BOTH is
        init() is si

        count: int => 7;
    si
si
