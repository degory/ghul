use IO.Std.write_line;

class POINT is
    x: int public;
    y: int public;

    init(x: int, y: int) is
        self.x = x;
        self.y = y;
    si
si

bad_by_name_member() is
    let p = POINT(1, 2);
    let (x = x, q = q) = p;
    write_line("{x}");
si

bad_not_destructurable_positional() is
    let n = 5;
    let (a, b) = n;
    write_line("{a}");
si

bad_not_destructurable_by_name() is
    let n = 5;
    let (a = x, b = y) = n;
    write_line("{a}");
si

bad_mixed_named_positional() is
    let p = POINT(1, 2);
    let (x = x, y) = p;
    write_line("{x}");
si
