
use IO.Std.write_line;

class POINT is
    x: int public;
    y: int public;

    init(x: int, y: int) is
        self.x = x;
        self.y = y;
    si
si

bad_by_name_member() is
    let p = POINT(1, 2);
    let (x, q) = p;
    write_line("{x}");
si

bad_not_destructurable() is
    let n = 5;
    let (a, b) = n;
    write_line("{a}");
si
