namespace Test is
    class Main is
        entry() static is
            check((1, "hello"));
        si

        check(pair: (int, string)?) static is
            // String literal at an `int`-typed source position — the
            // value-equality test cannot succeed; reject with a
            // clear "not comparable" diagnostic rather than letting
            // the IL emit and fail at JIT time.
            if let ("oops", n) = pair then
                IO.Std.write_line(n);
            fi
        si
    si
si
