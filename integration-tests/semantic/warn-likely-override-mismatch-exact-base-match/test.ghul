namespace Test is
    // When a base declares both a catch-all method and a per-subtype
    // overload (the visitor double-dispatch shape used throughout the
    // compiler's `Syntax.Visitor` hierarchy), a subclass's per-subtype
    // override cleanly overrides the specific signature — the
    // narrowing-against-the-catch-all heuristic should stay silent.

    class NODE is
        init() is si
    si

    class CALL: NODE is
        init() is super.init(); si
    si

    class INDEX: NODE is
        init() is super.init(); si
    si

    class BASE is
        init() is si

        visit(node: NODE) is si
        visit(call: CALL) is si
        visit(index: INDEX) is si
    si

    // Both visits are exact-signature overrides of BASE's specific
    // overloads; neither should warn against the catch-all `visit(NODE)`.
    class DERIVED: BASE is
        init() is super.init(); si

        visit(call: CALL) is si
        visit(index: INDEX) is si
    si
si
