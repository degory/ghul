// Soundness: a loop body that writes a narrowed variable drops
// the narrow — the loop's back-edge could carry the written
// value into a later iteration, so the narrow cannot be assumed
// inside the body or after the loop. `a` is `ANIMAL` again, so
// `a.purr()` must not resolve.

use IO.Std.write_line;

class ANIMAL is
    name: string public;
    init(name: string) is self.name = name; si
    speak() -> string => "animal {name}";
si

class CAT: ANIMAL is
    init(name: string) is super.init(name); si
    purr() -> string => "{name} purrs";
si

class DOG: ANIMAL is
    init(name: string) is super.init(name); si
    bark() -> string => "{name} barks";
si

test_loop_reassign_drops_narrow_after() is
    let a: ANIMAL mut = CAT("tom");

    if !isa CAT(a) then
        return;
    fi

    for i in 0..2 do
        a = DOG("rex");
    od

    write_line(a.purr());
si

test_loop_reassign_drops_narrow_inside() is
    let a: ANIMAL mut = CAT("felix");

    if !isa CAT(a) then
        return;
    fi

    while a.speak().length > 0 do
        write_line(a.purr());
        a = DOG("odie");
    od
si
