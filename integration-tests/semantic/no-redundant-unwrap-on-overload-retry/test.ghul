namespace Test is
    use Std = IO.Std;

    class SPAN is
        from: int;
        to: int;
        init(from: int, to: int) is self.from = from; self.to = to; si
    si

    class IDENT is
        location: SPAN;
        name: string;
        init() is location = SPAN(1, 2); name = "id"; si
    si

    class BODY is
        init() is si
    si

    class NULL_BODY: BODY is
        init() is si
    si

    class NODE(span: SPAN public, a: BODY, b: BODY, c: BODY) is
    si

    get_ident() -> IDENT? => IDENT();

    // Three coercion-scored arguments sum to the same value as the
    // resolver's retry marker; the call must not re-walk its arguments
    // over the facts the first walk recorded, so the `!` here - which
    // records that `name` holds a value as it compiles - must not be
    // reported redundant by a second compile of the same expression.
    build_node(name: IDENT?) -> NODE =>
        NODE(name!.location, NULL_BODY(), NULL_BODY(), NULL_BODY());

    apply_fn[T, U](v: T, f: T -> U) -> U => f(v);

    // A function-literal argument with implicit parameter types makes
    // resolution genuinely retry and re-walk every argument; the
    // re-walk restores the narrowing facts captured before the first
    // walk, so the sibling `!` again must not see its own effects.
    measure(name: IDENT?) -> int =>
        apply_fn(name!.name, s => s.length);

    class Main is
        entry() static is
            let node = build_node(get_ident());
            Std.out.write_line(node.span.from);
            Std.out.write_line(measure(get_ident()));
        si
    si
si
