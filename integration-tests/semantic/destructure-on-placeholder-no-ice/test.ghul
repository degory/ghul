// Regression: a destructure-on-placeholder where no call site or
// other body operation supplies enough information to widen the
// placeholder used to ICE in IL gen (Type.gen_type on ERROR).
// The closure_arg_resolver implied-type filter now rejects
// ERROR-bearing implied types, falling through to the placeholder
// path which emits "cannot infer type here". IL gen short-circuits
// via GENERATE_IL.apply's `if _logger.any_errors then return; fi`.
//
// The scenario: a let-bound lambda that's declared but never
// invoked. Inside the body, the parameter is destructured. With
// no call site and no operations supplying type info, iteration
// can never resolve the parameter's type — the right outcome is a
// real compile error, not an ICE.

namespace Test is
    class Main is
        entry() static is
            let f = state =>
                let (a, b) = state in
                a;                                  // expect "cannot infer type here" on state
            return;
        si
    si
si
