// A mismatch in the reference-`?` flag at an invariant generic
// argument position must fail to compile, in both directions:
// reading from the slot could surface a null its type denies, and
// writing through it could store one. `x ref` is the same rule --
// the reference type is a generic over the operand's declared type.
class BOX is
    name: string;
    init() is si
si

class MAIN is
    init() is si

    take_ref(b: BOX ref) -> bool is
        return true;
    si

    take_opt_ref(b: BOX? ref) -> bool is
        return true;
    si

    take_list(l: Collections.LIST[BOX]) is
    si

    take_opt_list(l: Collections.LIST[BOX?]) is
    si

    entry() static is
        let m = MAIN();

        let opt: BOX? mut = null;
        let solid: BOX mut = BOX();

        m.take_ref(opt ref);

        m.take_opt_ref(solid ref);

        let list_opt = Collections.LIST[BOX?]();
        m.take_list(list_opt);

        let list_solid = Collections.LIST[BOX]();
        m.take_opt_list(list_solid);
    si
si
