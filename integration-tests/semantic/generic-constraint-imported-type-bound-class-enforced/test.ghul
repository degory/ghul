// `System.IParsable[T]` declares the class-level type bound
// `where T : IParsable<T>`. `object` does not implement that
// interface, so naming `IParsable[object]` is now rejected (rather
// than emitting an unchecked-constraints warning).

namespace Test is
    entry() is
        let p: System.IParsable[object] mut;
    si
si
