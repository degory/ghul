// `double.CreateChecked<TOther>` has a method-level type bound
// (`where TOther : INumberBase<TOther>`). `int` satisfies it on
// .NET 8, so the call compiles silently — the bound is read from
// the imported method's metadata and checked at instantiation rather
// than producing an unchecked-constraints warning.

namespace Test.GenericArguments is
    entry() is
        double.create_checked`[int](123);
    si
si