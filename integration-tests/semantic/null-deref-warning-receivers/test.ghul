namespace Test is
    class INNER is
        label: string public;
        init(label: string) is self.label = label; si
    si

    class HOLDER is
        inner: INNER? public;
        init(inner: INNER?) is self.inner = inner; si
    si

    class COUNTER is
        n: int? public;
        init(n: int?) is self.n = n; si
    si

    class Main is
        find() -> INNER? static => INNER("found");

        entry() static is
            let h = HOLDER(INNER("x"));

            // reading through an optional member path - warns
            IO.Std.write_line(h.inner.label);

            // reading through an optional call result - warns
            IO.Std.write_line(find().label);

            // an un-narrowed optional local - warns
            let maybe = find();
            IO.Std.write_line(maybe.label);

            // ?. short-circuits on absence - no warn
            IO.Std.write_line("{h.inner?.label}");

            // value-type optional: has_value is a presence query,
            // not a dereference - no warn
            let c = COUNTER(41);
            IO.Std.write_line("{c.n.has_value}");

            // ...but reading .value through it is one - warns
            IO.Std.write_line("{c.n.value}");

            // ! takes responsibility - no warn
            // (`! .` spaced so `!.` is not lexed as one operator)
            IO.Std.write_line(h.inner! .label);

            // narrowed local - no warn
            if maybe? then
                IO.Std.write_line(maybe.label);
            fi

            // if let reads the path into a local - no warn
            if let h.inner? then
                IO.Std.write_line(inner.label);
            fi
        si
    si
si
