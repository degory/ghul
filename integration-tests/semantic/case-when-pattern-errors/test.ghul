namespace Test is
    class Main is
        entry() static is
            check("hello");
        si

        check(o: object) static is
            case o
            // `int` is a value type, so narrowing to it has nothing
            // to test. The one error binds `i` with ERROR type so the
            // use below is absorbed rather than producing a cascade.
            when i: int then
                IO.Std.write_line("got {i.no_such_member}");
            when s: string then
                IO.Std.write_line(s);
            esac
        si
    si
si
