namespace Test is
    use Collections;

    // A `T?` slot never accepts a `T?` value at any construction shape.
    // An optional generic must not silently widen to a non-optional
    // supertype (interface or base class) — that would lose the null
    // discriminator and admit a null where a value is required.

    class CAT is
        init() is si
    si

    takes_iterable(xs: Iterable[CAT]) -> int => 0;

    class MAIN is
        entry() static is
            let cats: LIST[CAT]? = null;
            let _ = takes_iterable(cats);
            return;
        si
    si
si
