namespace Test is
    use Std = IO.Std;

    class Main is
        // `yield X;` parses but the generator desugar isn't
        // implemented yet, so compile_expressions emits a
        // diagnostic. The function would otherwise need to
        // return Iterable[int]; that check is part of Phase 2
        // proper.
        gen() -> Collections.Iterable[int] static is
            yield 1;
            yield 2;
            yield 3;
        si

        entry() static is
            return;
        si
    si
si
