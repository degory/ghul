namespace Test is
    // Abstract class with a primary constructor: synthesised init
    // can still be called from `super.init(...)`, but a direct
    // `Animal("cat")` should be rejected.
    class Animal(name: string) abstract is si

    class CAT: Animal is
        init(name: string) is
            super.init(name);
        si
    si

    class Main is
        entry() static is
            let _ = Animal("forbidden");
            let _ = CAT("ok");
            return;
        si
    si
si
