namespace Test is
    use IO.Std;

    // Two let-bound lambdas referencing each other: `is_even(n)`
    // calls `is_odd(n-1)` and vice versa.
    //
    // ghūl walks bindings in order, so the first body can't see
    // the second's name yet — `is_odd` resolves to an undefined
    // reference, the body's `if` branches resolve to (ERROR, bool),
    // and "incompatible types in if branches: !!! and Ghul.bool"
    // fires. That diagnostic IS what we want today (ghūl doesn't
    // support mutual recursion between let-bound lambdas).
    //
    // Pinned to guard a path that previously crashed the compiler
    // with an internal cascade (NRE in
    // Closure._load_closure_non_generic, NotImplementedException
    // in Type.walk and Type.gen_type on ERROR, plus an assert
    // failure in set_arguments). The single clean diagnostic above
    // is preserved by three structural guards in the compiler:
    //   1. ERROR.walk is a leaf no-op (analysis paths skip
    //      gracefully; gen_type / gen_class_name DELIBERATELY
    //      still throw — they're an IL-emission safety net for
    //      "the logger wasn't poisoned but we're trying to emit
    //      anyway").
    //   2. FRAME.declare_constructor defaults a null field type
    //      to ERROR (set_arguments asserts no nulls).
    //   3. Closure._load_closure_non_generic bails to DUMMY(ERROR)
    //      when any captured value has an error or null type,
    //      preventing the IL-emission cascade in the first place.
    //
    // If a future change wires up real forward-reference handling
    // for let-bound lambdas, this test should be updated to
    // assert the working behaviour rather than the current
    // diagnostic.

    class Main is
        entry() static is
            let is_even = n => if n == 0 then true else is_odd(n - 1) fi;
            let is_odd  = n => if n == 0 then false else is_even(n - 1) fi;
            Std.write_line("{is_even(4)}");
            return;
        si
    si
si
