namespace Test is
    class A is
        name: string;

        init(name: string) is
            self.name = name;
        si
    si

    show_destructure(a: A) -> string? =>
        if let n = a.name then
            "got {n}";
        fi;

    show_type_test(o: object) -> string? =>
        if let s: string = o then
            "string: {s}";
        fi;

    show_chained(a: A?, b: A?) -> string? =>
        if let x = a then
            x.name;
        elif let y = b then
            y.name;
        fi;

    entry() is
        IO.Std.write_line(show_destructure(A("alice")));
        IO.Std.write_line(show_type_test("hi"));
        IO.Std.write_line(show_chained(null, A("bob")));
    si
si
