class SCALAR: System.Attribute is
    number: int public;

    init() is si
si

class NEEDS_INT: System.Attribute is
    init(value: int) is si
si

get_value() -> int => 42;

@Nonexistent()
class UNKNOWN_ATTRIBUTE is
    init() is si
si

@SCALAR(bogus = 5)
class UNKNOWN_MEMBER is
    init() is si
si

@NEEDS_INT(get_value())
class NON_CONSTANT is
    init() is si
si

entry() static is
    return;
si
