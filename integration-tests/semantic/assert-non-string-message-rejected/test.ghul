namespace Test is
    class Main is
        // The else clause must be a string or System.Exception. Statement
        // form previously had a latent typo that compared the message kind
        // against the condition's type, leaving the error path dead, so an
        // int message was silently accepted. Both forms are now checked
        // against the message's own type.

        statement_form_int_message() is
            assert true else 42;
        si

        statement_form_string_message_ok() is
            assert true else "ok";
        si

        statement_form_exception_message_ok() is
            assert true else System.Exception("boom");
        si

        expression_form_int_message() -> string =>
            assert true else 42 in "never reached";

        expression_form_string_message_ok() -> string =>
            assert true else "ok" in "yielded";

        expression_form_exception_message_ok() -> string =>
            assert true else System.Exception("boom") in "yielded";

        entry() static is
            return;
        si
    si
si
