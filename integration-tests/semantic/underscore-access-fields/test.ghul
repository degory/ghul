@no_std()
namespace Test is
    class BASE is
        _v: int;
    si
    class DERIVED: BASE is
        // subclass access to a base private underscore field: advisory error
        read() -> int => _v;
    si
    class OTHER is
        // unrelated cross-class access: advisory error
        peek(b: BASE) -> int => b._v;
    si
si
