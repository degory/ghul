namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            outer: for i in 0..3 do
                for j in 0..3 do
                    if j == 1 then
                        break missing;
                    fi

                    if j == 2 then
                        continue also_missing;
                    fi

                    Std.out.write_line("i {i} j {j}");
                od
            od
        si
    si
si
