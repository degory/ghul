namespace Test is
    use IO.Std.write_line;

    entry() is
        let all_null =
            case 1
            when 1 then null
            when 2 then null
            else null
            esac;

        let mixed_null_and_int =
            case 1
            when 1 then 10
            else null
            esac;

        let mixed_null_first =
            case 1
            when 1 then null
            else 20
            esac;

        write_line("done");
    si
si
