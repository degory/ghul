namespace Test is
    use IO.Std.write_line;

    entry() is
        // Every arm null with no expected type: nothing to infer the
        // element type from, so this stays an error.
        let all_null =
            case 1
            when 1 then null
            when 2 then null
            else null
            esac;

        // A value-type arm mixed with a null arm widens the joined type
        // to the value type's optional carrier (int?), in either order.
        let mixed_null_and_int =
            case 1
            when 1 then 10
            else null
            esac;

        let mixed_null_first =
            case 1
            when 1 then null
            else 20
            esac;

        write_line("done");
    si
si
