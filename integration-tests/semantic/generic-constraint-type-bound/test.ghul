// Phase 2: a type bound on a type parameter is enforced at instantiation.
// `BOX[T: ANIMAL]` records the bound; instantiating it with `string` —
// not an ANIMAL — is now an error.

namespace Test is
    use IO.Std;

    class ANIMAL is
        init() is si
    si

    class BOX[T: ANIMAL] is
        _value: T;
        init(value: T) is _value = value; si
        value: T => _value;
    si

    class Main is
        entry() static is
            let b = BOX[string]("hello");
            Std.write_line(b.value);
        si
    si
si
