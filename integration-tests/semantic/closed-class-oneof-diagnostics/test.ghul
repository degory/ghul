// Diagnostics for ONE_OF over a closed-class hierarchy. The hinted
// "narrow further" message — already wired for unions — now fires
// for closed-class subclass narrows that share a member name across
// every in-set subclass but where the root doesn't declare it.

class Animal abstract is
    init() is si
si

class CAT: Animal is
    init() is super.init(); si
    speak() -> string => "meow";
si

class DOG: Animal is
    init() is super.init(); si
    speak() -> string => "woof";
si

class BIRD: Animal is
    init() is super.init(); si
    speak() -> string => "tweet";
si

entry() is
    test_intersection_miss_with_shared_method();
si

// `a.speak()` through ONE_OF{CAT, DOG} hits the hinted error: every
// in-set subclass has `speak`, but `Animal` doesn't.
test_intersection_miss_with_shared_method() is
    let a: Animal = CAT();
    if isa BIRD(a) then
        return;
    else
        a.speak();                  // expect hinted error
    fi
si
