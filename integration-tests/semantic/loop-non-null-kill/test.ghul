// Soundness: a loop body that reassigns a variable known to hold
// a value drops that non-null fact — the back-edge could carry a
// null write into a later iteration, so the access after the loop
// cannot assume present. Parallel to `loop-narrowing-kill` for the
// type-narrow domain.

class BOX is
    arguments: int[] public;
    init(args: int[]) is arguments = args; si
si

specialize(seed: int) -> BOX? => if seed > 0 then BOX([1,2,3]) else null fi;

probe_for_kills_non_null(seed: int) is
    let candidate mut = specialize(seed);

    if candidate? then
        for _ in 0..2 do
            candidate = specialize(seed);
        od

        let post = candidate.arguments;
    fi
si

probe_while_kills_non_null(seed: int) is
    let candidate mut = specialize(seed);
    let count mut = seed;

    if candidate? then
        while count > 0 do
            candidate = specialize(seed);
            count = count - 1;
        od

        let post = candidate.arguments;
    fi
si

entry() is
    probe_for_kills_non_null(1);
    probe_while_kills_non_null(1);
si
