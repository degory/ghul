namespace Test is
    use Std = IO.Std;

    class BASE is
        init() is si
    si

    class DERIVED: BASE is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            let b: BASE = DERIVED();

            let a = cast DERIVED(b);

            Std.out.write_line("{a?}");
            return;
        si
    si
si
