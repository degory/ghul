// The `new` ctor constraint requires the type argument to expose an
// accessible parameterless constructor. Standalone, compound with a
// kind constraint, and compound with a type bound all parse.

namespace Test is
    class A is init() is si si
    class B: A is init() is super.init(); si si

    f[T: new](x: T) -> T => x;
    g[T: class new](x: T) -> T => x;
    h[T: A new](x: T) -> T => x;
    i[T: A class new](x: T) -> T => x;

    class Main is
        entry() static is
            f(A());
            g(A());
            h(A());
            h(B());
            i(A());
            return;
        si
    si
si
