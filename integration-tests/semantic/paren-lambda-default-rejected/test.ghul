namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // ghūl has no default formal values; these must NOT parse as
            // lambdas. The contents are routed through the statement parser
            // — an assignment to an undeclared `n` — and the trailing `=>`
            // is then a syntax error.

            // expect error
            let f1 = (n = 1) => n + 1;

            // expect error
            let f2 = (n: int = 1) => n + 1;

            return;
        si
    si
si
