// A type bound on a *function* type parameter is now enforced when the
// function is explicitly specialized. `identity[T: A]` requires the
// argument to derive from A; `string` does not.

namespace Test is
    class A is
        init() is si
    si

    identity[T: A](x: T) -> T => x;

    class Main is
        entry() static is
            identity[string]("hi");
            return;
        si
    si
si
