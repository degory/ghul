namespace Test is
    class MAIN is
        // The inner expression sees the condition-holds narrowing — s? makes
        // s.length safe here.
        inner_is_narrowed(s: string?) -> int =>
            assert s? else "s is null" in s.length;

        // The else message runs only when the condition fails, so it must NOT
        // see the condition-holds narrowing — dereferencing s here should
        // warn because s could still be null when the message is built.
        message_is_not_narrowed(s: string?) -> int =>
            assert s? else "s.length was {s.length}" in 0;

        // Statement-position drop: assert-in yields a value, so dropping it
        // should error the way `let x = e in expr;` does.
        dropped_value() is
            assert true else "nope" in "yielded but unused";
        si

        entry() static is
            return;
        si
    si
si
