// Phase 2: a constraint on a *function* type parameter parses — this
// was rejected outright before ("type constraints are not supported").
// The function is then usable with an inferred type argument.

namespace Test is
    use IO.Std;

    identity[T: option](x: T) -> T => x;

    class Main is
        entry() static is
            Std.write_line("{identity(42)}");
        si
    si
si
