namespace Test is
    class Main is
        entry() static is
            check("hello");
        si

        check(o: object) static is
            // a value type is always present: cannot be tested with if let
            if let i: int = o then
                IO.Std.write_line("got {i}");
            fi

            // the binding is scoped to its own then-arm
            if let s: string = o then
                IO.Std.write_line(s);
            else
                IO.Std.write_line(s);
            fi

            IO.Std.write_line(s);
        si
    si
si
