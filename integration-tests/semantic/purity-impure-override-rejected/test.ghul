namespace Test is
    // Purity is covariant on override. A caller holding a
    // Base-typed receiver expects the contract Base declared;
    // an override that weakens the contract is rejected.

    class BASE is
        // PURE on Base: callers expect path narrowings to
        // survive Base.read(...).
        read() -> int pure => 1;

        // MUT on Base: callers expect only Base's receiver-
        // rooted narrowings to drop.
        bump() mut is si

        // Constructors auto-classify as MUT — explicit `impure`
        // override still has to honour the auto-MUT here.
        init() is si
    si

    class DERIVED: BASE is
        // Overriding pure with impure violates the contract.
        read() -> int impure => 2;

        // Overriding mut with impure also weakens — caller
        // narrowings of unrelated paths would die unexpectedly.
        bump() impure is si

        init() is super.init(); si
    si

    class Main is
        entry() static is
            return;
        si
    si
si
