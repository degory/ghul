// Namespace-level @suppress: the whole namespace, with everything
// it contains, sits inside the wrapper.
@suppress("non-exception-throw")
namespace Test.Silenced is
    class A is
        method() is
            throw 12345;
            throw "still silenced";
        si
    si

    class B is
        method() is
            throw 6.28;
        si
    si

    class Main is
        entry() static is
        si
    si
si

// Sibling namespace without the pragma — its throw warns.
namespace Test.Warns is
    class C is
        method() is
            throw "out of scope";
        si
    si
si
