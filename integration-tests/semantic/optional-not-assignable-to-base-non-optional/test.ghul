namespace Test is
    class BASE is
        name: string public;
        init(name: string) is self.name = name; si
    si

    class DERIVED: BASE is
        init(name: string) is super.init(name); si
    si

    class MAIN is
        init() is si

        // Two overloads. The body below should bind to neither
        // because the argument is optional.
        f(b: BASE) -> int => 1;
        f(d: DERIVED) -> int => 2;

        entry() static is
            let m = MAIN();

            let d_opt: DERIVED? = null;

            // Should error: DERIVED? is not assignable to either
            // f(b: BASE) or f(d: DERIVED) — both take non-optional
            // parameters. The user has to write `d_opt!` to assert
            // non-null at the call site, or extract to a local
            // after a presence check.
            let result = m.f(d_opt);
        si
    si
si
