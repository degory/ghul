namespace Test is
    // An abstract class cannot be instantiated. Subclasses can still
    // call its `init` via `super.init()`, but a direct `Animal()` at
    // a call site is a compile error. The diagnostic fires for both
    // surface forms (the bare-call form and the deprecated `new`).

    class Animal abstract is
        init() is si
    si

    class Main is
        entry() static is
            let _ = Animal();
            let _ = new Animal();
            return;
        si
    si
si
