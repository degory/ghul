namespace Test is
    class Foo is
        init() is si
    si

    class Main is
        entry() static is
            let a = Foo();
            let b = Foo();
            // `<` on reference types must reject cleanly — the generic
            // <>[T: struct] in the lib is the only `<>` overload that
            // could otherwise match; the struct kind constraint
            // excludes Foo.
            let r = a < b;
            return;
        si
    si
si
