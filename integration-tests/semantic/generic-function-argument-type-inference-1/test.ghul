use Collections;

entry() is
    function(1, 2);
    
    function(1.0, 2.0);

    function("a", "b");

    function(true, false);

    // sibling value types — LUB widens T to a common ancestor.
    function(1, 2.0);

    function([1234], [5678]);


    function([1, 2.0], [3, 4.0]);

    function([1, 2.0, "a"], [3, 4.0, "b"]);

    // expect error
    // infers a not very useful interface - LUB needs tuning
    function([1, 2, 3], [4, 5, 6.0]);

    // expect error. Note this doesn't work in C# either:
    function([1234, 5678], LIST[int]([91011, 121314]));

    // sibling generic types over int — LUB walks ancestors and widens
    // T to a common interface (Iterable[int]).
    function([1, 2, 3], [4, 5, 6] |);
si

function[T](a: T, b: T) -> T is
    return a;
si
