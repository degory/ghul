namespace Test is
    use IO.Std;

    class Animal is
        init() is si
    si

    class Cat: Animal is
        init() is super.init(); si
    si

    class Dog: Animal is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            describe(Cat());
        si

        describe(a: Animal) static is
            case a
            when _: Cat then Std.write_line("c");
            esac
        si
    si
si
