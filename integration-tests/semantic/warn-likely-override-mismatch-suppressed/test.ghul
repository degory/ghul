namespace Test is
    use Collections;

    // Same shape as warn-likely-override-mismatch but built with
    // `--no-warn-likely-override-mismatch`. Confirms the opt-out
    // silences the warning (default-on is pinned by its sibling test).

    class ANIMAL is
        init() is si
    si

    class CAT: ANIMAL is
        init() is super.init(); si
    si

    class BASE is
        init() is si

        add_things(things: List[ANIMAL]) is si

        greet(a: ANIMAL) -> string => "ANIMAL";
    si

    class DERIVED: BASE is
        init() is super.init(); si

        add_things(things: LIST[ANIMAL]) is si

        greet(a: CAT) -> string => "CAT";
    si
si
