namespace Test is
    // A type argument in a type-expression position — a field,
    // parameter, return or local type annotation — must satisfy its
    // type parameter's declared type bound, the same way a construction
    // or call site already does. A satisfying argument (GOOD) is
    // accepted; a violating one (BAD) is rejected at each position.

    trait Comparable[T] is
        compare_to(other: T) -> int;
    si

    class BOX[E: Comparable[E]] is
        init() is si
    si

    class GOOD: Comparable[GOOD] is
        init() is si
        compare_to(other: GOOD) -> int => 0;
    si

    class BAD is
        init() is si
    si

    class USER is
        _ok: BOX[GOOD];
        _bad: BOX[BAD];

        take(x: BOX[BAD]) -> BOX[BAD] => x;

        run() is
            let ok: BOX[GOOD] mut;
            let bad: BOX[BAD] mut;
        si
    si
si
