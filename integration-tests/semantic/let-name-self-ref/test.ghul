use IO.Std.write_line;

union STEP[T] is
    DONE;
    YIELD(value: T, rest: () -> STEP[T]);
si

use STEP.DONE;
use STEP.YIELD;

// A let-bound name referenced from inside its own RHS lambda body
// (here `fib_step` inside fib_step's own closure) — by the time the
// closure body is compiled, the let-binding hasn't yet executed, so
// the slot the closure captures is null at runtime. Reflected at
// compile time: fib_step's type isn't yet pinned, the closure's
// return type collapses to ERROR, and IL emission would otherwise
// crash on it. Pinned here so the diagnostic surfaces instead.
// Recursive self-reference should use `rec` (see the patterns in
// execution/anon-function-recursion-*).
entry() is
    let counting = n -> STEP[int] rec =>
        let r = rec in
        if n == 0 then DONE() else YIELD(n, () => r(n - 1)) fi;

    let fib_step = (prev: int, current: int) -> STEP[int] rec =>
        YIELD(current, () => fib_step(current, prev + current));

    write_line("ok");
si
