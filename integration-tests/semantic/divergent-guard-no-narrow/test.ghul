// Soundness cases for divergent-guard narrowing: a `!isa T(x)`
// only carries a narrow past the guard when it is *itself* the
// whole branch condition AND the branch body diverges. The three
// cases below each fail one of those requirements, so `a` is
// still `ANIMAL` afterwards and `a.purr()` must not resolve.

use IO.Std.write_line;

class ANIMAL is
    name: string public;
    init(name: string) is self.name = name; si
    speak() -> string => "animal {name}";
si

class CAT: ANIMAL is
    init(name: string) is super.init(name); si
    purr() -> string => "{name} purrs";
si

accept(b: bool) -> bool => b;

// Non-divergent branch: the `!isa` body falls through, so the
// guard does not carry — `a` is still `ANIMAL`.
test_non_divergent_branch() is
    let a: ANIMAL = CAT("ginger");

    if !isa CAT(a) then
        write_line("fell through");
    fi

    write_line(a.purr());
si

// `!isa` buried inside a call argument: the branch condition is
// the call, not the `!isa`, so no narrow is captured even though
// the body diverges.
test_buried_negation() is
    let a: ANIMAL = CAT("felix");

    if accept(!isa CAT(a)) then
        return;
    fi

    write_line(a.purr());
si

// `!isa` as one conjunct of a `/\`: reaching past the guard does
// not imply `isa CAT(a)` (the other conjunct may have been
// false), so the conjunction must not carry a narrow.
test_conjunction_does_not_carry() is
    let a: ANIMAL = CAT("tom");
    let flag = true;

    if !isa CAT(a) /\ flag then
        return;
    fi

    write_line(a.purr());
si
