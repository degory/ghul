namespace Test is
    use IO.Std;

    enum Color is
        RED,
        GREEN,
        BLUE
    si

    class Main is
        entry() static is
            Std.write_line(describe(Color.RED));
            Std.write_line(describe(Color.GREEN));
            Std.write_line(describe(Color.BLUE));
        si

        describe(c: Color) -> string static is
            return case c
            when Color.RED then "r"
            when Color.GREEN then "g"
            when Color.BLUE then "b"
            esac;
        si
    si
si
