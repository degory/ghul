namespace Test is
    use IO.Std;

    class HelperBox is
        greet() static is
            Std.write_line("hello pascal");
        si

        message: string static => "static pascal";

        _seed: int static;
    si

    class HIGHER_ORDER_FUNCTIONS is
        apply(f: int -> int, x: int) -> int static =>
            f(x);
    si

    class Main is
        entry() static is
            HelperBox.greet();
            Std.write_line(HelperBox.message);
            Std.write_line("{HIGHER_ORDER_FUNCTIONS.apply(x: int => x * 2, 21)}");
        si
    si
si
