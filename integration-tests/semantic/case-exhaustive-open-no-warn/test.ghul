namespace Test is
    use IO.Std;

    class ANIMAL open is
        name: string;
        init(name: string) is self.name = name; si
    si

    class CAT: ANIMAL open is
        init(name: string) is super.init(name); si
    si

    class DOG: ANIMAL open is
        init(name: string) is super.init(name); si
    si

    class Main is
        entry() static is
            describe(CAT("felix"));
            describe(1);
        si

        describe(a: ANIMAL) static is
            case a
            when _: CAT then Std.write_line("c");
            when _: DOG then Std.write_line("d");
            else Std.write_line("?");
            esac
        si

        describe(n: int) static is
            case n
            when 0 then Std.write_line("z");
            when 1 then Std.write_line("o");
            else Std.write_line("other");
            esac
        si
    si
si
