namespace Test is
    use IO.Std;

    class Animal abstract is
        init() is si
    si

    class CAT: Animal is
        init() is super.init(); si
    si

    class DOG: Animal is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            Std.write_line(describe(CAT()));
            Std.write_line(describe(DOG()));
        si

        describe(a: Animal) -> string static is
            return case a
            when _: CAT then "c"
            when _: DOG then "d"
            esac;
        si
    si
si
