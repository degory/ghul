namespace Test is
    use IO.Std;

    class Animal is
        init() is si
    si

    class Cat: Animal is
        init() is super.init(); si
    si

    class Dog: Animal is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            Std.write_line(describe(Cat()));
            Std.write_line(describe(Dog()));
        si

        describe(a: Animal) -> string static is
            return case a
            when _: Cat then "c"
            when _: Dog then "d"
            esac;
        si
    si
si
