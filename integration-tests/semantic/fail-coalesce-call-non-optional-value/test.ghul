namespace Test is
    use Std = IO.Std;

    struct POINT is
        x: int field;

        init(x: int) is
            self.x = x;
        si

        sum() -> int => x;
    si

    class Main is
        entry() static is
            // A struct is never null, so `?.` on a never-optional
            // value-type receiver has no defensive value.
            let p = POINT(1);
            let bad = p?.sum();

            Std.out.write_line("{bad}");
        si
    si
si
