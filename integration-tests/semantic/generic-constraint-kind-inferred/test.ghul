// Phase 2: a kind constraint is enforced at a constructor call even
// when the type argument is inferred from the call arguments —
// `CELL("hello")` infers T = string, which violates `[T: struct]`.

namespace Test is
    use IO.Std;

    class CELL[T: struct] is
        _value: T;
        init(value: T) is _value = value; si
        value: T => _value;
    si

    class Main is
        entry() static is
            let c = CELL("hello");
            Std.write_line(c.value);
        si
    si
si
