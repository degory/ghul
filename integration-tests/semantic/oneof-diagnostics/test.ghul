// Diagnostics for ONE_OF — the internal narrowing-only sum type.
//
// 1) `is_<X>` on a ONE_OF whose set excludes X is statically false.
//    The predicate compiles (so existing flow continues) but a
//    warning surfaces the dead-code branch.
// 2) Member access through a ONE_OF for a name that's on every
//    in-set variant but not on the union: variant-private fields
//    can't be reached without further narrowing, so we replace the
//    bare "member not found" error with a hinted version directing
//    the user to a `if v.is_<...>` refinement.

union Trio[T] is
    A(a: T);
    B(b: T);
    C(c: T);
si

// Two-variant union where both variants share a field name but
// each is a separate symbol; intersection-miss hint should fire
// when accessing through ONE_OF{OK, SKIP}.
union Carries[T] is
    OK(value: T);
    SKIP(value: T);
    DROP(reason: string);
si

entry() is
    test_statically_false_is_X_on_one_of();
    test_intersection_miss_with_shared_field();
    test_member_not_found_unchanged_for_non_one_of();
    test_member_not_found_unchanged_when_no_intersection();
si

// Inside the else of `if t.is_a` the receiver is narrowed to
// ONE_OF{B, C}. A subsequent `if t.is_a` is dead code — warn.
test_statically_false_is_X_on_one_of() is
    let t: Trio[int] = Trio.B[int](1);
    if t.is_a then
        return;
    else
        if t.is_a then              // expect warn — always false
            return;
        fi
    fi
si

// `c.value` through ONE_OF{OK, SKIP} hits the hinted error: every
// in-set variant has `value`, but the union doesn't.
test_intersection_miss_with_shared_field() is
    let c: Carries[int] = Carries.OK[int](42);
    if c.is_drop then
        return;
    else
        c.value;                    // expect hinted error
    fi
si

// Member-not-found on a plain (non-ONE_OF) variant keeps the
// existing bare error message — the hint path only triggers for
// ONE_OF receivers.
test_member_not_found_unchanged_for_non_one_of() is
    let ok: Carries.OK[int] = Carries.OK[int](42);
    ok.nonsense;                    // expect plain "not found"
si

// Member access through ONE_OF where the name is on some — but
// not every — in-set variant: hint path declines, bare error fires.
// `reason` is on Carries.DROP only. Carries narrowed to
// ONE_OF{OK, SKIP} (else of `is_drop`) doesn't include DROP, so
// the hint declines and the plain `not found` error surfaces.
test_member_not_found_unchanged_when_no_intersection() is
    let c: Carries[int] = Carries.OK[int](42);
    if c.is_drop then
        return;
    else
        let r = c.reason;           // expect plain "not found" (reason only on DROP)
    fi
si
