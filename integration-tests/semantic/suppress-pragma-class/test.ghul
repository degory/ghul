namespace Test is

    // Class-level @suppress: the whole class body — every method,
    // every nested expression — sits inside the wrapper.
    @suppress("non-exception-throw")
    class Silenced is
        method_a() is
            throw 12345;
        si

        method_b() is
            throw "still silenced";
        si

        entry() static is
        si
    si

    // Sibling class without the pragma — warns.
    class Warns is
        method() is
            throw 42;
        si
    si
si
