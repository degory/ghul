namespace Test is
    class Main is
        entry() static is
            check((1, "one"));
        si

        check(pair: (int, string)) static is
            // Literal leaf in a plain `let` would silently skip the
            // value test at runtime — the user's intent ("match the
            // tuple where the first element is 1") would not actually
            // be tested. Rejected with a clear error.
            let (1, b) = pair;

            IO.Std.write_line(b);
        si
    si
si
