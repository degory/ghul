namespace Test is
    class BOX is
        label: string;
        init(label: string) is self.label = label; si
    si

    struct POINT is
        x: int;
        init(x: int) is self.x = x; si
    si

    identity[T](t: T) -> T is
        // `t` was never optional: unwrapping it is an error whatever
        // `T` turns out to be.
        return t!;
    si

    class Main is
        entry() static is
            let b = BOX("hi");
            let x = b!;

            let i = 42;
            let j = i!;

            let p = POINT(1);
            let q = p!;
        si
    si
si
