// Phase 2: the `option` kind constraint parses (a contextual keyword).
// Its enforcement is deferred to nullable-types support, so any type
// argument is currently accepted.

namespace Test is
    use IO.Std;

    class HOLDER[T: option] is
        _value: T;
        init(value: T) is _value = value; si
        value: T => _value;
    si

    class Main is
        entry() static is
            let h = HOLDER[int](42);
            Std.write_line("{h.value}");
        si
    si
si
