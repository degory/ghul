// Definite-assignment analysis: reading a deferred-init local
// (`let x: T;` with no initializer) before it has been assigned
// on every path reaching the read is warned. A `let` with an
// initializer, and a deferred-init local assigned on every path
// before its use, are not warned.

namespace Test is
    use IO.Std;

    class Main is
        // Warn: `x` is read before any assignment.
        read_before_assign() static is
            let x: int;
            Std.write_line("{x}");
        si

        // Warn: `x` is assigned on only one branch of the if.
        assigned_on_one_branch(c: bool) static is
            let x: int;

            if c then
                x = 1;
            fi

            Std.write_line("{x}");
        si

        // No warn: `x` is assigned on every branch before the use.
        assigned_on_all_branches(c: bool) static is
            let x: int;

            if c then
                x = 1;
            else
                x = 2;
            fi

            Std.write_line("{x}");
        si

        // No warn: straight-line assignment before the use.
        assigned_before_use() static is
            let x: int;

            x = 42;

            Std.write_line("{x}");
        si

        // No warn: a `let` with an initializer is never a
        // deferred-init local.
        initialized_let() static is
            let x = 7;

            Std.write_line("{x}");
        si

        entry() static is
            assigned_before_use();
            assigned_on_all_branches(true);
            initialized_let();
        si
    si
si
