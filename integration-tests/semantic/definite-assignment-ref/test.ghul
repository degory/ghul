// Definite-assignment through a `ref` argument. A `ref` argument is
// written by the callee, so a deferred-init local passed by `ref` is
// assigned from that point on and needs no `= default` primer. The
// write only counts on the edges where the argument was actually
// evaluated, so a `ref` behind a short-circuit is not enough on its
// own.

namespace Test is
    use IO.Std;
    use Collections.MAP;

    class Main is
        // A ghul-declared `ref` parameter is plain in/out: the callee
        // may read the incoming value, so an unassigned local is not
        // safe to pass.
        fill(x: string ref) static is
        si

        // Warn: fill takes v by plain ref and may read it while it is
        // unassigned. A reflected out slot (below) does not warn here.
        ghul_ref_unassigned() -> string static is
            let v: string mut;

            fill(v ref);

            return v;
        si

        // No warn: the `ref` runs unconditionally before the use.
        ref_unconditional(m: MAP[string,string]) -> string static is
            let v: string mut;

            m.try_get_value("k", v ref);

            return v;
        si

        // No warn: on the then edge the `ref` has run, so `v` is assigned.
        ref_in_condition(m: MAP[string,string]) -> string static is
            let v: string mut;

            if m.try_get_value("k", v ref) then
                return v;
            fi

            return "none";
        si

        // Warn: on the `flag`-false path the `ref` never ran.
        ref_behind_short_circuit(flag: bool, m: MAP[string,string]) -> string static is
            let v: string mut;

            if flag /\ m.try_get_value("k", v ref) then
            fi

            return v;
        si

        // Warn: the `??` right operand runs only when `flag` is null,
        // so the `ref` is not a definite write.
        ref_behind_coalesce(flag: bool?, m: MAP[string,string]) -> string static is
            let v: string mut;

            if flag ?? m.try_get_value("k", v ref) then
            fi

            return v;
        si

        // Warn: a deferred-init local with no `ref` and no assignment.
        no_ref_use_before_assign() -> int static is
            let n: int mut;

            return n;
        si

        entry() static is
            let m = MAP[string,string]();

            Std.write_line(ref_unconditional(m));
            Std.write_line(ref_in_condition(m));
        si
    si
si
