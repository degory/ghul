namespace Test is
    use IO.Std;

    union Color is
        RED;
        GREEN;
        BLUE;
    si

    class Main is
        entry() static is
            Std.write_line(describe(Color.RED()));
        si

        describe(c: Color) -> string static =>
            case c
            when _: Color.RED then "r"
            when _: Color.GREEN then "g"
            esac;
    si
si
