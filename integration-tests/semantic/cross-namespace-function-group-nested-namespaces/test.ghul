namespace Root is
    use Outside;

    namespace InsideA is
        use InsideB;

        class TEST_A is
            init(s: string) is si
            test(a: A) -> A => a;
        si

        // InsideA.TEST_A should hide used Outside.TEST_A here:
        do_stuff(a: A) -> A is
            let should_be_inside_a_test_a = TEST_A("hello");

            // expect error: InsideA.TEST_A does not have test(O):
            should_be_inside_a_test_a.test(O());

            // InsideA.TEST_A does have test(A):
            should_be_inside_a_test_a.test(A());

            let inside_a_test_a_doesnt_have_this_constructor = TEST_A(a);
        si
    si

    namespace InsideB is
        class TEST_B is
            test(b: B) -> B => b;
        si

        // used Outside.TEST_A should be in scope here:
        do_stuff(a: A) -> A is
            let should_be_outside_test_a = TEST_A(a);

            // Outside.TEST_A has test(O):
            should_be_outside_test_a.test(O());

            // expected error: Outside.TEST_A does not have test(A):
            should_be_outside_test_a.test(A());

            // expect error:
            let outside_test_a_doesnt_have_this_constructor = TEST_A("hello");
        si        
    si

si

namespace Outside is
    class TEST_A is
        init(a: A) is si
        test(o: O) -> O => o;
    si    
si

