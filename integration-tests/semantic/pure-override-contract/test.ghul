// A function that overrides or implements a declared-pure base must
// itself be pure - declared or proven. Call sites trust the base's
// declared bit across dispatch, so an unprovable, undeclared
// override is rejected; a declared or provably store-free one is
// accepted.

trait COUNTER is
    next() -> int pure;
si

class PROVEN: COUNTER is
    _base: int;
    init(base: int) is _base = base; si
    next() -> int => _base + 1;
si

class DECLARED: COUNTER is
    _count: int;
    init() is si
    next() -> int pure is
        return _count + 1;
    si
si

class STORING: COUNTER is
    _count: int;
    init() is si
    next() -> int is
        _count = _count + 1;
        return _count;
    si
si

entry() is
    IO.Std.write_line("{PROVEN(1).next()}");
si
