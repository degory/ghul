namespace Test is
    use Std = IO.Std;

    class Main is
        // `return X;` inside a generator emits a diagnostic — values
        // are emitted via `yield`, not returned. The diagnostic
        // fires from the rewriter at desugar time.
        with_value() -> Collections.Iterable[int] static is
            yield 1;
            return 42;
        si

        entry() static is
            return;
        si
    si
si
