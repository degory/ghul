namespace TEST.GenericInheritance is
    use Collections;

    class THING[T] is
        init() is si

        test_iterable(t: Iterable[TEST]) -> TEST;
    si

    class TEST is
        test() is
            let thing_int = THING[int]();

            let ti: TEST = thing_int.test_iterable([self]);            
        si
    si
si