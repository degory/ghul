namespace Test is
    use IO.Std;

    // Regression test for an internal compiler error (NRE) that
    // previously fired in
    // Symbols.Function.try_bind_generic_arguments →
    // GENERIC_ARGUMENT_BIND_RESULTS.check_complete when a
    // non-generic instance method was called on a generic class
    // whose owner type-args were unbound.
    //
    // Today the compiler reports a clean overload-not-found
    // error here. (Once iterative inference is extended to
    // structural placeholders for owner type-args, `m.set(42)`
    // will instead bind T = int and the test would change shape;
    // until then this captures the no-crash contract.)
    //
    // Trigger: zero-arg constructor on Box[T] with no LHS type
    // constraint and no construction-arg inferring T, followed
    // by an instance-method call that tries to bind T from the
    // actual argument.
    class Box[T] is
        _value: T;
        init() is si
        set(value: T) is _value = value; si
        get() -> T => _value;
    si

    class Main is
        entry() static is
            let m = Box();
            m.set(42);
            let x = m.get();
            Std.write_line("{x}");
            return;
        si
    si
si
