namespace Test is
    // `open` opts a class out of closed-to-assembly narrowing. With
    // `open` on `Animal`, the else edge of `isa Cat(a)` cannot narrow
    // `a` to the singleton complement, since another assembly could
    // introduce a third `Animal` subclass. Calling `bark()` on the
    // wide `Animal` therefore fails to resolve.

    class Animal open is
        init() is si
    si

    class Cat: Animal is
        init() is super.init(); si
    si

    class Dog: Animal is
        init() is super.init(); si
        bark() -> string => "bark";
    si

    class Main is
        entry() static is
            return;
        si

        describe(a: Animal) static is
            if isa Cat(a) then
                return;
            fi

            let _ = a.bark();
        si
    si
si
