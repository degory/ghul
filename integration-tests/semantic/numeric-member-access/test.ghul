use IO.Std;

entry() is
    let p = (1, 2);

    // Positional tuple members are named by index, but a bare number is
    // not an identifier, so it must be backtick-escaped (p.`0). A bare
    // p.0 must give that hint - not build a null-identifier member node
    // that crashes a later pass.
    let n = p.0;

    Std.write_line("{n}");
si
