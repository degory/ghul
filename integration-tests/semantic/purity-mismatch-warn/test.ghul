namespace Test is
    // VERIFY_PURITY runs after compile-expressions and warns
    // when a function's body, observed against the resolved
    // call graph and assignment shapes, is weaker than its
    // declared / inferred contract.
    //
    // Covered here:
    //
    //   - explicit `pure` body calling an explicit `impure`
    //     helper  — soundness hole INFER_PURITY couldn't see
    //   - explicit `pure` body assigning to `self.x`
    //     (MUT shape)
    //   - explicit `mut` body assigning a non-self field
    //     (IMPURE shape)
    //   - inferred-PURE block body calling an explicit
    //     `impure` helper  — the headline arrow/block hole
    //   - inferred-PURE arrow body calling an explicit
    //     `impure` helper

    class HELPERS is
        do_impure() static impure is si
    si

    class SUBJECT is
        x: int;

        init() is si

        // Explicit pure, body calls impure — warn.
        explicit_pure_calls_impure() -> int pure is
            HELPERS.do_impure();
            return 42;
        si

        // Explicit pure, body writes self.x — warn.
        explicit_pure_writes_self() -> int pure is
            self.x = 1;
            return self.x;
        si

        // Explicit mut, body writes through a non-self path —
        // here a static helper. Caught by the LHS shape
        // classifier.
        explicit_mut_writes_global(other: SUBJECT) mut is
            other.x = 1;
        si

        // Block body with no modifier — INFER_PURITY seeds
        // PURE. The call to impure_thing is invisible at
        // INFER_PURITY's slot in the pipeline; VERIFY_PURITY
        // catches it here.
        inferred_pure_calls_impure() -> int is
            HELPERS.do_impure();
            return 7;
        si

        // Same hole, arrow shape. declare-symbols seeds PURE
        // structurally; the arrow's call to impure_thing is
        // the missed downgrade.
        inferred_pure_arrow_calls_impure() -> int => arrow_body();

        // Helper for the arrow case — a separate function so
        // the arrow body has a CALL to inspect.
        arrow_body() -> int is
            HELPERS.do_impure();
            return 9;
        si
    si

    class Main is
        entry() static is
            return;
        si
    si
si
