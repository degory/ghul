namespace Test is
    struct POINT is
        x: int;
        init(x: int) is self.x = x; si
    si

    class Main is
        entry() static is
            // A value type can never be null, so `?` and `?.` on a
            // never-optional value operand have no defensive use and
            // are errors (unlike a never-optional reference, where
            // the emitted null test is legal defensive code).
            let p = POINT(1);
            let x = p?.x;

            let i = 42;
            let b = i?;
        si
    si
si
