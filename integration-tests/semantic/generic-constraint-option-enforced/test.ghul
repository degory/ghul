// The `option` kind constraint is enforced where a generic type is
// named in type position. `int` and `string` are not optional types,
// so neither satisfies `[T: option]`.

namespace Test is
    class HOLDER[T: option] is
        _value: T;
        init(value: T) is _value = value; si
    si

    class Main is
        _bad_value: HOLDER[int];
        _bad_ref: HOLDER[string];

        entry() static is si
    si
si
