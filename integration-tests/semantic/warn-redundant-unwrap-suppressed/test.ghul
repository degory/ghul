namespace Test is
    use Std = IO.Std;

    class BOX is
        label: string;
        init(label: string) is self.label = label; si
    si

    class Main is
        entry() static is
            // With `--suppress redundant-unwrap` the redundant `!`
            // does not warn.
            let x = BOX("hi");
            Std.out.write_line(x!.label);
        si
    si
si
