namespace Test is
    use Std = IO.Std;

    class BOX is
        label: string;
        init(label: string) is self.label = label; si
    si

    get_box() -> BOX? => BOX("hi");

    class Main is
        entry() static is
            // With `--suppress redundant-unwrap` the redundant `!`
            // inside the `if b?` arm does not warn.
            let b = get_box();
            if b? then
                Std.out.write_line(b!.label);
            fi
        si
    si
si
