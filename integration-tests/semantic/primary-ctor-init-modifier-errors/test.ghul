// `init` modifier is only valid on a primary-ctor parameter, and only on
// its own — cannot combine with visibility or with a `_`-prefixed name.

class A(value: int public init) is
si

class B(_value: int init) is
si

// Body decl with `init` modifier — diagnosed.
class C(value: int) is
    other: int init;
si

// Class with no primary header — `init` on a body decl should still error.
class D is
    init() is si

    other: int init;
si
