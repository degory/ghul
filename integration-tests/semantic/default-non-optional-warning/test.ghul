namespace Test is
    use Std = IO.Std;

    class BOX is
        init() is si
    si

    class Main is
        entry() static is
            // Should warn: non-optional reference target — `default` here
            // is a null-in-disguise for a slot the type claims non-null.
            let a: BOX mut = default;

            // Should NOT warn: optional reference target — a null default
            // is well-typed.
            let b: BOX? mut = default;

            // Should NOT warn: value-type target — `default` is a zeroed
            // value, no null involved.
            let c: int mut = default;

            // Should NOT warn: value-type optional target — the empty
            // Nullable.
            let d: int? mut = default;

            a = BOX();
            b = BOX();
            d = 7;

            Std.out.write_line("ok");
            return;
        si
    si
si
