namespace Test is
    use IO.Std;

    class MAIN is
        entry() static is
            Std.out.write_line(make(1));
        si

        // The compiler does not yet box captured arguments the way it
        // boxes captured mut locals, so a mut argument cannot be
        // assigned to once a closure captures it - the two copies
        // would silently diverge.
        make(n: int mut) -> int static is
            let f = () is
                n = n + 1; // expect error - cannot assign to captured argument
            si;

            f();

            n = n + 10; // expect error - n is captured by the closure above

            return n;
        si
    si
si
