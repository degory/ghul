namespace Test.GenericFunctionTypeInference is
    use Collections;

    class TYPE is
        is_object: bool;
    si
    
    struct THING is
        arguments: Iterable[TYPE];
        
        init() is            
        si
    si

    entry() is
        let non_generic_matches = LIST[THING]();

        non_generic_matches |
            .filter(f => f.arguments | .find(a => a.is_object).has_value);
    si
si