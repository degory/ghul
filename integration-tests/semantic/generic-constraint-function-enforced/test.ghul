// Phase 2: a kind constraint on a function type parameter is enforced
// when the function is explicitly specialized — `identity[string]`
// violates `[T: struct]`, string being a reference type.

namespace Test is
    use IO.Std;

    identity[T: struct](x: T) -> T => x;

    class Main is
        entry() static is
            Std.write_line(identity[string]("hi"));
        si
    si
si
