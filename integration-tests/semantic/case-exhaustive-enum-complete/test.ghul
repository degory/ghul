namespace Test is
    use IO.Std;

    enum Color is
        RED,
        GREEN,
        BLUE
    si

    class Main is
        entry() static is
            describe(Color.RED);
            describe(Color.GREEN);
            describe(Color.BLUE);
        si

        describe(c: Color) static is
            case c
            when Color.RED then Std.write_line("r");
            when Color.GREEN then Std.write_line("g");
            when Color.BLUE then Std.write_line("b");
            esac
        si
    si
si
