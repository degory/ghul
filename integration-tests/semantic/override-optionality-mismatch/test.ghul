namespace Test is
    trait NAMED is
        name: string;

        greet(who: string?) -> string;
    si

    class WIDGET: NAMED is
        init() is si

        name: string? => null;

        greet(who: string) -> string? => null;
    si

    class BASE is
        init() is si

        fetch() -> string => "base";

        item: string? public;
    si

    class DERIVED: BASE is
        init() is si

        fetch() -> string? => null;

        item: string public => "tight", = value is si
    si

    class Main is
        entry() static is
        si
    si
si
