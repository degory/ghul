// Definite-return analysis: a non-void, block-bodied function
// whose control flow can reach the end of the body without a
// value having been returned is warned. Functions that return,
// throw, `assert false`, or loop forever on every path — and
// void or expression-bodied functions — are not warned.

namespace Test is
    use IO.Std;

    class Main is
        // Warn: control falls off the end when `c` is false.
        partial_return(c: bool) -> int is
            if c then
                return 1;
            fi
        si

        // Warn: an if / elif chain with no else can fall through.
        no_else(c: bool) -> int is
            if c then
                return 1;
            elif !c then
                return 2;
            fi
        si

        // No warn: every branch of the if returns.
        all_branches_return(c: bool) -> int is
            if c then
                return 1;
            else
                return 2;
            fi
        si

        // No warn: the body ends in a return.
        plain_return() -> int is
            return 42;
        si

        // No warn: the body ends in a throw.
        always_throws() -> int is
            throw System.Exception("no value");
        si

        // No warn: `assert false` always throws.
        asserts_false() -> int is
            assert false else "unreachable";
        si

        // No warn: an unconditional loop with no break never
        // completes, so control cannot reach the end.
        loops_forever() -> int is
            do
                Std.write_line("tick");
            od
        si

        // No warn: a void function need not return a value.
        void_no_return() is
            Std.write_line("void");
        si

        // No warn: expression-bodied functions always yield a value.
        expression_bodied() -> int => 7;

        entry() static is
            Std.write_line("ok");
        si
    si
si
