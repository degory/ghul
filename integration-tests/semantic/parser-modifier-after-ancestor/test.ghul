namespace Test is
    // The type-list parser stops short of a modifier keyword that
    // follows an ancestor on the same line — the contextual `open`
    // (still lexed as an identifier) as well as the reserved
    // `abstract` — so `class CAT: Animal open is` parses as the
    // class `CAT` extending `Animal` with the postfix `open`
    // modifier — not as two ancestors with a missing comma between
    // them.

    class Animal abstract is si

    class CAT: Animal open is si

    class Dog: Animal abstract is si

    class Main is
        entry() static is
            return;
        si
    si
si
