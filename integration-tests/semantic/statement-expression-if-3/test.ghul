namespace Test is
    use IO.Std.write_line;

    class BASE is
    si

    class DERIVED_A: BASE is
        init() is si
    si
   
    class DERIVED_B: BASE is
        init() is si
    si

    entry() is
        let no_else_let_1_elif: BASE =
            if true then
                DERIVED_A()
            elif false then
                DERIVED_B()
            fi;

        let no_else_let_2_elif: BASE =
            if true then
                DERIVED_A()
            elif true then
                DERIVED_B()
            elif false then
                DERIVED_A()
            fi;

        let no_else_let_1_elif_compatible_types_1: BASE = 
            if true then
                object()
            elif false then
                DERIVED_A()
            fi;

        let no_else_let_1_elif_compatible_types_2: BASE =
            if true then
                DERIVED_A()
            elif false then
                object()
            fi;

        let no_else_let_1_elif_incompatible_types_1 =
            if true then
                DERIVED_A()
            elif false then
                DERIVED_B()
            fi;

        let no_else_let_1_elif_incompatible_types_2 =
            if true then
                DERIVED_A()
            elif true then
                DERIVED_B()
            elif false then
                DERIVED_A()
            fi;
    si

    return_statement_1_elif_compatible_types() -> int is
        return
            if true then
                1
            elif false then
                2
            fi;
    si

    return_statement_1_elif_incompatible_types_1() -> int is
        return
            if true then
                "a"
            elif false then
                123
            fi;
    si

    return_statement_1_elif_incompatible_types_2() -> int is
        return
            if true then
                123
            elif false then
                "a"
            fi;
    si

    return_statement_3_elif_incompatible_types_1() -> int is
        return
            if true then
                123
            elif true then
                "a"
            elif false then
                123
            elif true then
                456
            fi;
    si

    return_statement_1_elif_inferred_compatible_types_1() -> object is
        return
            if true then
                DERIVED_A()
            elif false then
                DERIVED_B()
            fi;
    si

    return_statement_2_elif_incompatible_types_1() -> BASE is
        return
            if true then
                DERIVED_A()
            elif false then
                DERIVED_B()
            elif true then
                12345;
            fi;
    si

    expression_bodied_function_1_elif_compatible_types_1() -> int =>
        if true then 1 elif false then 2 fi;

        expression_bodied_function_2_elif_compatible_types_1() -> object =>
        if true then DERIVED_A() elif false then DERIVED_B() elif false then DERIVED_A() fi;

        expression_bodied_function_2_elif_inferred_compatible_types_1() -> BASE =>
        if true then DERIVED_A() elif false then DERIVED_B() elif false then DERIVED_A() fi;
si