namespace Test is
    class Main is
        entry() static is
            check("hello", "world");
        si

        check(a: string?, b: string?) static is
            // A non-last clause missing its initializer: every
            // clause in an `if let` must have one. The diagnostic
            // points at the offending clause; the rest of the
            // chain still parses so subsequent diagnostics
            // remain useful.
            if let x = a, y, z = b then
                IO.Std.write_line("{x} {y} {z}");
            fi

            // Last clause missing its initializer.
            if let p = a, q then
                IO.Std.write_line("{p} {q}");
            fi
        si
    si
si
