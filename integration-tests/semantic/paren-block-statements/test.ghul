namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // 1. Lambda body that's a paren-wrapped assignment statement
            let counter1 mut = 0;
            let bump1 = (n: int) => (
                counter1 = counter1 + n;
            );
            bump1(5);
            Std.write_line("counter1 = {counter1}");

            // 2. Same, without trailing semicolon
            let counter2 mut = 0;
            let bump2 = (n: int) => (
                counter2 = counter2 + n
            );
            bump2(7);
            Std.write_line("counter2 = {counter2}");

            // 3. Paren-wrapped assignment at top level — no lambda
            let counter3 mut = 0;
            (counter3 = counter3 + 11);
            Std.write_line("counter3 = {counter3}");

            // 4. Single-expression parens — collapses to bare expression
            let v = (1 + 2);
            Std.write_line("v = {v}");

            // 5. Block expression with let-in-block and trailing value
            let w = (let inner = 100; inner + 1);
            Std.write_line("w = {w}");

            // 6. Tuple with named elements — unchanged behaviour
            let p = (x = 10, y = 20);
            Std.write_line("p.x = {p.x}, p.y = {p.y}");

            // 7. Multi-statement block with an assignment
            let counter4 mut = 0;
            let bump4 = (n: int) => (
                counter4 = counter4 + n;
                Std.write_line("bumped by {n}, counter4 now {counter4}");
            );
            bump4(3);

            return;
        si
    si
si
