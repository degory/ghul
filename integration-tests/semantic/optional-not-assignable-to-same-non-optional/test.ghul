namespace Test is
    class BASE is
        name: string public;
        init(name: string) is self.name = name; si
    si

    class MAIN is
        init() is si
        f(b: BASE) -> int => 1;

        entry() static is
            let m = MAIN();
            let b_opt: BASE? = null;
            // Same-type test: BASE? passed where BASE expected.
            let result = m.f(b_opt);
        si
    si
si
