namespace Test is
    use IO.Std;

    class ANIMAL is
        init() is si
        name() -> string => "animal";
    si

    class CAT: ANIMAL is
        init() is super.init(); si
        purr() -> string => "purr";
    si

    class DOG: ANIMAL is
        init() is super.init(); si
        bark() -> string => "woof";
    si

    class Main is
        entry() static is
            go(1);
        si

        go(which: int) static is
            let pet: ANIMAL mut = ANIMAL();

            if which == 1 then
                pet = CAT();
            else
                pet = DOG();
            fi

            // the joined view after divergent assignments does not
            // keep either branch's narrow
            Std.out.write_line(pet.bark());

            pet = DOG();
            pet.name();

            // a call between the assignment and the read leaves a
            // local's narrow in force
            Std.out.write_line(pet.bark());
        si
    si
si
