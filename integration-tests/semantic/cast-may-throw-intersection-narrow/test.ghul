namespace Test is
    use Std = IO.Std;

    // A trait that cross-cuts the class hierarchy — flow narrowing on
    // isa THING(x) where x has a class type produces an INTERSECTION
    // source (class & trait), not a plain type. The cast-may-throw
    // predicate must recognise the intersection covers the target.

    trait THING is
        say() is Std.out.write_line("thing"); si
    si

    class HOLDER is
        init() is si
    si

    class REAL_THING: HOLDER, THING is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            let h: HOLDER = REAL_THING();

            // Should NOT warn: `isa THING(h)` narrows h to
            // INTERSECTION(HOLDER, THING). `cast THING(h)` targets
            // THING; the intersection carries THING, so the cast is
            // guaranteed to succeed.
            if isa THING(h) then
                let t = cast THING(h);
                t.say();
            fi

            return;
        si
    si
si
