// `System.IParsable[T]` declares a CRTP-style type bound
// (`where T : IParsable<T>`). `int` satisfies it on .NET 8, so the
// instantiation compiles silently — the bound is read from the
// assembly metadata and checked at instantiation rather than
// producing an unchecked-constraints warning.

namespace Test.GenericArguments is
    entry() is
        let p: System.IParsable[int];
    si
