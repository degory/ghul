// `T?` on an unconstrained type parameter is not yet supported —
// the value/reference lowering needs the parameter's kind known.
wrap[T](x: T) -> T? => null;

class BOX is
    init() is
    si
si

take_int(n: int) -> int => n;

entry() is
    // a `BOX?` is not assignable where a plain `int` is expected;
    // the diagnostic renders the nullable type with its `?` suffix.
    let b: BOX? = BOX();

    take_int(b);
si
