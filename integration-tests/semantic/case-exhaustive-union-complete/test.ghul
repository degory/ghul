namespace Test is
    use IO.Std;

    union Color is
        RED;
        GREEN;
        BLUE;
    si

    class Main is
        entry() static is
            describe(Color.RED());
            describe(Color.GREEN());
            describe(Color.BLUE());
        si

        describe(c: Color) static is
            case c
            when _: Color.RED then Std.write_line("r");
            when _: Color.GREEN then Std.write_line("g");
            when _: Color.BLUE then Std.write_line("b");
            esac
        si
    si
si
