use IO.Std.write_line;

entry() is
    // Block expected to produce an `int` — `return "wrong"` inside
    // it must error against the pushed-down expected type, not
    // silently widen the LUB to `object`.
    let x: int = val
        if true then
            return "wrong";
        fi
        42
    lav;

    write_line("x = {x}");
si
