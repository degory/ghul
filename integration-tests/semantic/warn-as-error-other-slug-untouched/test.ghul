namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let n = 42;

            // int (value type) cast to string (unrelated reference type)
            // can never succeed at runtime — the source's runtime type
            // is its declared type and is not assignable to the target.
            let s = cast string(n);

            Std.out.write_line("done");
            return;
        si
    si
si
