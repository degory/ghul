use IO.Std.write_line;

entry() is
    // Bare `return;` inside a val-block whose result is consumed is
    // an error — the block has been asked for a value but the return
    // path contributes none.
    let x: int = val
        if true then
            return;
        fi
        42
    lav;

    write_line("x = {x}");
si
