namespace Test is
    use Std = IO.Std;

    class BOX is
        label: string;
        init(label: string) is self.label = label; si
    si

    get_box() -> BOX? => BOX("hi");

    class Main is
        entry() static is
            // Redundant: `b` is a non-optional reference, so per its
            // static type the presence test can never fail.
            let b = BOX("hi");
            if b? then
                Std.out.write_line(b.label);
            fi

            // Not redundant: the call result is optional and unchecked.
            let o = get_box();
            if o? then
                Std.out.write_line(o.label);
            fi
            return;
        si
    si
si
