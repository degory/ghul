// `double.CreateChecked<TOther>` declares a method-level type bound
// `where TOther : INumberBase<TOther>`. `string` does not implement
// that interface, so the explicit specialization is now rejected
// (rather than emitting an unchecked-constraints warning).

namespace Test is
    class Main is
        entry() static is
            double.create_checked`[string]("hello");
        si
    si
si
