namespace Test is
    use Std = IO.Std;

    class TE is
        init() is si
        freeze() -> TE? => self;
        m() -> int => 42;
    si

    class C is
        init() is si

        g(t: TE) -> int => 1;
        make() -> TE? => TE();
        make_list() -> Collections.List[TE]? => [TE(), TE()];

        run_ret(fn: () -> TE) -> TE => fn();

        // The body of a value-returning lambda ends with `return`,
        // leaving the flow environment unreachable — a compilation
        // re-walk of the body (delegate conversion here) must restart
        // from the facts in force at the literal, so the narrow from
        // `if x? then` still holds on every walk.
        returning_lambda() -> int is
            let r = run_ret(() is
                let x = make();

                if x? then
                    g(x);
                    return x;
                fi

                return TE();
            si);

            return r.m();
        si

        // The recursive re-walk of the body must restart from the same
        // baseline.
        recursive_lambda() -> int is
            let f = (n: int) rec is
                let x = make();

                if x? then
                    g(x);

                    if n > 0 then
                        return rec(n - 1);
                    fi

                    return x;
                fi

                return TE();
            si;

            return f(2).m();
        si

        // The `!` genuinely unwraps the optional parameter; a re-walk
        // of the lambda body must not see the presence fact the first
        // walk recorded and report the unwrap redundant.
        unwrap_in_rewalked_lambda() -> int is
            let frozen = make_list()
                | .map(t => t.freeze())
                  .filter(f => f?)
                  .map(f => f!)
                  .collect();

            return frozen.count;
        si
    si

    class Main is
        entry() static is
            let c = C();

            Std.out.write_line(c.returning_lambda());
            Std.out.write_line(c.recursive_lambda());
            Std.out.write_line(c.unwrap_in_rewalked_lambda());
        si
    si
si
