// Phase 2: a kind constraint is enforced at a constructor call with
// explicit type arguments. `string` is a reference type, violating the
// `struct` constraint on T.

namespace Test is
    use IO.Std;

    class CELL[T: struct] is
        _value: T;
        init(value: T) is _value = value; si
        value: T => _value;
    si

    class Main is
        entry() static is
            let c = CELL[string]("hello");
            Std.write_line(c.value);
        si
    si
si
