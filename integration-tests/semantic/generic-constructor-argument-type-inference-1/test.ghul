use Collections;

class Animal is
    init() is si
si

class Cat: Animal is
    init() is si
si

class Dog: Animal is
    init() is si
si

class Pair[T] is
    init(a: T, b: T) is si
si

class Triple[T] is
    init(a: T, b: T, c: T) is si
si

class Holder[T] is
    init(items: Iterable[T], extra: T) is si
si

struct PAIR_STRUCT[T] is
    init(a: T, b: T) is si
si

union OPTION_PAIR[T] is
    NONE;
    BOTH(a: T, b: T);
si

entry() is
    // Sibling subtypes of a common base — T inferred via LUB to Animal.
    Pair(Cat(), Dog());

    // Mix of base and derived — T inferred to Animal, since Cat <: Animal.
    Pair(Cat(), Animal());

    // Three-way LUB across positions.
    Triple(Cat(), Dog(), Animal());

    // Sibling value types — LUB widens T to a common ancestor.
    Pair(1, 2.0);

    // T appears nested inside a covariant generic. LUB widens T from
    // Cat-vs-Dog to Animal; Iterable[Cat] then satisfies Iterable[Animal]
    // by covariance (#1207).
    Holder([Cat()], Dog());

    // Same LUB behaviour applies to generic structs.
    PAIR_STRUCT(Cat(), Dog());

    // And to generic union variants — BOTH(a: T, b: T) should infer
    // T = Animal here.
    OPTION_PAIR.BOTH(Cat(), Dog());

    // T appears as the LUB of two siblings (`int[]` and `LIST[int]`)
    // that aren't subtypes of each other but share a trait ancestor.
    // The LUB's trait walk specialises both sides' ancestors so the
    // common trait — `Iterable[int]` here — surfaces.
    Pair([1, 2, 3], LIST[int]([4, 5, 6]));
si
