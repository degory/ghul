namespace Test is
    use IO.Std;

    union my_shape is
        CIRCLE;
        SQUARE;
    si

    class Main is
        entry() static is
            let s: my_shape = my_shape.CIRCLE;
            if isa my_shape.CIRCLE(s) then
                Std.write_line("circle");
            elif isa my_shape.SQUARE(s) then
                Std.write_line("square");
            fi
        si
    si
si
