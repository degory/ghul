// The `optional` kind constraint requires the type argument to be an
// optional type — a reference type's `T?` form, or the value-type
// optional. Both are accepted; a non-optional argument is rejected
// (see generic-constraint-optional-enforced).

namespace Test is
    use IO.Std;

    class HOLDER[T: optional] is
        _value: T;
        init(value: T) is _value = value; si
        value: T => _value;
    si

    class MAIN is
        // A value-type optional argument satisfies `[T: optional]`.
        _value_optional: HOLDER[int?];

        entry() static is
            // A reference type's `T?` form satisfies it too.
            let r = HOLDER[string?]("hello");
            Std.write_line("{r.value}");
        si
    si
si
