namespace Test is
    use Std = IO.Std;

    class ANIMAL is
        name: string public;
        init(name: string) is
            self.name = name;
        si
    si

    class CAT: ANIMAL is
        init(name: string) is
            super.init(name);
        si
    si

    trait HasPet is
        pet() -> ANIMAL;
    si

    // The resolver previously rejected this with "cannot inherit
    // multiple abstract methods" because the inherited `pet` from
    // HasPet has return type ANIMAL while the re-declaration here
    // narrows to CAT. C# 9-style covariant return: the most-derived
    // slot wins and the diamond compiles. (Concrete implementing
    // class is out of scope here — that needs separate IL-bridge
    // metadata work.)
    trait CatOwner: HasPet is
        pet() -> CAT;
    si

    class Main is
        entry() static is
            Std.write_line("compiled");
        si
    si
si
