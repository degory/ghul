namespace Test is
    use Collections;
    use IO.Std;

    class FOO is
        init() is si
        functions: LIST[FOO] => LIST[FOO]();
    si

    class Main is
        entry() static is
            let _constructor = cast FOO(undefined_handler.find_member("init")).functions
                | .filter(f => f == f)
                .only();
            return;
        si
    si
si
