use IO.Std.write_line;

// `rec` inside a non-recursive lambda with no recursive ancestor at
// all — the diagnostic still fires. The compile-expressions visit
// for RECURSE walks up the enclosing closure chain looking for a
// recursive ancestor; this case has none, so the lookup fails and
// the original error is preserved.
entry() is
    let inner = (n: int) -> int => rec(n);

    write_line("ok");
si
