namespace Test is
    // Tests: assigning to a member of a struct-typed value that is a
    // temporary copy - a property get, a method result or an indexer
    // element - is a compile error rather than a silently lost write.

    struct S is
        tag: int public;
        init(tag: int) is
            self.tag = tag;
        si
    si

    struct OUTER is
        inner: S field;
        init() is si
    si

    class N is
        state: S public;
        deep: OUTER public;
        init() is si

        poke() is
            // in-class access still goes through the property
            self.state.tag = 21;
        si
    si

    make_s() -> S static => S(0);

    class Main is
        entry() static is
            let n = N();

            // through a property get
            n.state.tag = 7;

            // through a method result
            make_s().tag = 99;

            // through an indexer element
            let arr = [S(0), S(0)];
            arr[0].tag = 17;

            // field under a property get: the chain root is a copy
            n.deep.inner.tag = 13;
        si
    si
si
