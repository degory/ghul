namespace Test is
    use Std = IO.Std;

    class BOX is
        v: string;

        init(v: string) is
            self.v = v;
        si

        get_it() -> string => v;

        make() -> BOX? static => BOX("made");
    si

    class Main is
        entry() static is
            let b = BOX.make();

            if b? then
                // b is flow-narrowed to present here, so the `?.`
                // call can never take its null arm.
                Std.out.write_line("{b?.get_it()}");
            fi
        si
    si
si
