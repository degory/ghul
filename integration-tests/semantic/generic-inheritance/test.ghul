        check_int(prop_int);
        let prop_thing = it.stuff_thing;
        check_thing_int(prop_thing);
        let prop_list = it.stuff_list; 
        check_list_int(prop_list);            

        let ii = prop_list[5];
        check_int(ii);

        let indexed_iterable_int = it[prop_thing];                        
        check_int(indexed_iterable_int.iterator.current);
    si

