namespace Test is
    use Std = IO.Std;

    class Animal is
        name: string;
        init(name: string) is self.name = name; si
    si

    class Cat: Animal is
        init(name: string) is super.init(name); si
    si

    class Main is
        entry() static is
            let c = Cat("Felix");

            // Always succeeds: typed form, Cat is already a Cat
            if let same: Cat = c then
                Std.out.write_line(same.name);
            fi

            // Always succeeds: typed form, Cat is already an Animal
            if let any: Animal = c then
                Std.out.write_line(any.name);
            fi
        si
    si
si
