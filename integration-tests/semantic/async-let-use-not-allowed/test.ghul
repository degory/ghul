namespace Test is
    use Std = IO.Std;

    class HANDLE: Disposable is
        init() is si

        dispose() is
            Std.write_line("dispose");
        si
    si

    class Main is
        run() -> Tasks.TASK static is
            let use h = HANDLE();
            await Tasks.TASK.delay(1);
            return;
        si

        entry() static is
            run().wait();
        si
    si
si
