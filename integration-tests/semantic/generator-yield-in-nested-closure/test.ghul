
namespace Test is
    use Std = IO.Std;

    class Main is
        // A yield inside a nested closure belongs to *that* closure,
        // not to the enclosing generator. If the closure's return
        // type isn't Iterable[T] / Iterator[T] the yield is illegal
        // — diagnosed per yield by compile_expressions.
        outer() -> Collections.Iterable[int] static is
            let inner = () -> void is
                yield 99;
            si;
            inner();
            yield 1;
        si

        entry() static is
            return;
        si
    si
si
