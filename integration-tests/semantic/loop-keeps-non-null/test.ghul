// Soundness: a non-null narrow on a variable the loop body never
// writes survives the loop, parallel to the type-narrow rule. The
// for-loop with an unrelated isa narrow in scope used to take a
// path that dropped non-null facts entirely; both `pre` and `post`
// accesses below must resolve without a `null-deref` warning.

class BOX is
    arguments: int[] public;
    init(args: int[]) is arguments = args; si
si

class ANIMAL is init() is si si
class CAT: ANIMAL is init() is si si

specialize(seed: int) -> BOX? => if seed > 0 then BOX([1,2,3]) else null fi;

probe_for_loop(seed: int, a: ANIMAL) is
    let candidate = specialize(seed);

    if candidate? then
        let pre = candidate.arguments;

        if isa CAT(a) then
            for i in 0..10 do
            od
        fi

        let post = candidate.arguments;
    fi
si

probe_while_loop(seed: int, a: ANIMAL) is
    let candidate = specialize(seed);

    if candidate? then
        let pre = candidate.arguments;

        if isa CAT(a) then
            while false do
            od
        fi

        let post = candidate.arguments;
    fi
si

entry() is
    probe_for_loop(1, CAT());
    probe_while_loop(1, CAT());
si
