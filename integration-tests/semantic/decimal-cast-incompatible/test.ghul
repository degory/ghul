namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let d = 12.34m;

            // bool, word, uword, and char have no System.Decimal::op_*
            // overload in either direction (char goes via int in .NET).
            let b = cast bool(d);
            let w = cast word(d);
            let c = cast char(d);
            let from_c = cast decimal('a');

            Std.out.write_line("{b} {w} {c} {from_c}");
        si
    si
si
