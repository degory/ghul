namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let d = 12.34m;

            // No System.Decimal::op_*(bool) overload exists; before the
            // decimal-touches-decimal gate in TYPE_CASTER this fell
            // through to conv.u1 and emitted unverifiable IL.
            let b = cast bool(d);
            // Same story for word / uword: no decimal op_* overload.
            let w = cast word(d);
            // char also lacks a Decimal::op_* overload in either
            // direction (route through int explicitly when needed).
            let c = cast char(d);
            let from_c = cast decimal('a');

            Std.out.write_line("{b} {w} {c} {from_c}");
        si
    si
si
