namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let d = 12.34m;

            // No System.Decimal::op_*(bool) overload exists; before the
            // decimal-touches-decimal gate in TYPE_CASTER this fell
            // through to conv.u1 and emitted unverifiable IL.
            let b = cast bool(d);
            // Same story for word / uword: no decimal op_* overload.
            let w = cast word(d);

            Std.out.write_line("{b} {w}");
        si
    si
si
