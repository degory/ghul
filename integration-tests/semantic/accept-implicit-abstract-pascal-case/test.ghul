namespace Test is
    use Std = IO.Std;

    // Implicitly abstract: a user-written body-less instance method
    // makes Shape abstract, so its PascalCase name is accepted and
    // must not draw a non-upper-snake-case warning.
    class Shape is
        area() -> int;
    si

    class SQUARE: Shape is
        _side: int;

        init(side: int) is
            _side = side;
        si

        area() -> int => _side * _side;
    si

    class Main is
        entry() static is
            let s: Shape = SQUARE(3);
            Std.write_line("{s.area()}");
        si
    si
si
