// Regression test for issue #1136: importing instance members of a
// reflected type into the surrounding namespace scope is unsafe (no
// implicit instance is available at the call site) and must produce
// a clear diagnostic at the `use` rather than silently letting the
// import through and surfacing a follow-up confusion later.
namespace Example is
    class TEST is
        init() is si

        test_static() static is si

        test_instance() is si

        instance_property: int => 42;
    si
si

namespace TestInstanceMethod is
    use Example.TEST.test_instance;
si

namespace TestInstanceProperty is
    use Example.TEST.instance_property;
si

namespace TestStaticMethod is
    use Example.TEST.test_static;

    class Caller is
        run() static is
            test_static();
        si
    si
si
