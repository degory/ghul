namespace Test is
    use Std = IO.Std;

    class A is init() is si si
    class B: A is init() is super.init(); si si
    class C: B is init() is super.init(); si si

    trait Level1 is
        get() -> A;
    si

    trait Level2: Level1 is
        get() -> B;
    si

    // Three-link chain — Level3.get returns C which is-a B which is-a A.
    // The resolver picks the most-derived (C-returning) slot as the
    // single canonical abstract.
    trait Level3: Level2 is
        get() -> C;
    si

    class Main is
        entry() static is
            Std.write_line("compiled");
        si
    si
si
