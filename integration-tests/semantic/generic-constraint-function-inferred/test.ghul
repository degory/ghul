// Phase 2: a kind constraint on a function type parameter is enforced
// when the type argument is inferred from the call — `identity("hi")`
// infers T = string, which violates `[T: struct]`.

namespace Test is
    use IO.Std;

    identity[T: struct](x: T) -> T => x;

    class Main is
        entry() static is
            Std.write_line(identity("hi"));
        si
    si
si
