namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let s = SUM();
            let a: Adds = s;
            let b: AlsoAdds = s;

            Std.write_line("{s.add(1, 2)}");
            Std.write_line("{a.add(3, 4)}");
            Std.write_line("{b.add(5, 6)}");
        si
    si

    trait Adds is
        add(x: int, y: int) -> int;
    si

    trait AlsoAdds is
        add(x: int, y: int) -> int;
    si

    trait BOTH: Adds, AlsoAdds is
    si

    class SUM: BOTH is
        init() is si

        add(x: int, y: int) -> int => x + y;
    si
si
