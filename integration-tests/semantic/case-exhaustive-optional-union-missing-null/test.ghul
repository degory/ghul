namespace Test is
    use IO.Std;

    union Color is
        RED;
        GREEN;
    si

    class Main is
        entry() static is
            describe(Color.RED());
        si

        describe(c: Color?) static is
            case c
            when _: Color.RED then Std.write_line("r");
            when _: Color.GREEN then Std.write_line("g");
            esac
        si
    si
si
