namespace Test is
    use Std = IO.Std;

    class Main is
        // `yield X;` in a function whose return type is not
        // Iterable[T] / Iterator[T]. DESUGAR_YIELD doesn't classify
        // this as a generator (return is int) and leaves the YIELD
        // nodes in place; compile_expressions then emits the
        // "only allowed in a function returning..." diagnostic per
        // yield encountered.
        not_a_generator() -> int static is
            yield 1;
            yield 2;
            yield 3;
            return 0;
        si

        entry() static is
            return;
        si
    si
si
