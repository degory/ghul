// names that are only in scope at the target's declaration site - its
// namespace siblings and its file's use imports - are not visible inside
// an impl or partial block written elsewhere; the block resolves names at
// its own write site
namespace Data is
    helper() -> string => "helper";

    class WIDGET is
        _n: int;
        init(n: int) is _n = n; si
    si
si

namespace App is
    trait PRINTER is
        print() -> string;
    si

    impl PRINTER for Data.WIDGET is
        print() -> string => helper();
    si

    partial Data.WIDGET is
        described() -> string => helper();
    si
si
