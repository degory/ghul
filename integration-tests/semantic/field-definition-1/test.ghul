namespace Test.ParseUnary is
    use Collections;

    class TEST is
        _value: int field;
        value: int field;

        init(a: int, b: int) is
            // all should be assignable here
            _value = a;
            value = b;
        si

        get_values() -> (int, int) =>
            (_value, value);
    si

    test_is_not_publicly_readable() is
        let test = TEST(1, 2);

        // expect error
        let value: int = test._value;
    si

    test_is_publicly_readable() is
        let test = TEST(1, 2);

        let value: int mut = test.value;
    si

    test_is_not_publicly_assignable() is
        let test = TEST(1, 2);

        // expect error
        test.value = 5;
    si
si
