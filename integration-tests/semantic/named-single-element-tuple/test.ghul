use IO.Std;

entry() is
    // `(name = value)` with a single element is not a tuple - ghul has
    // no 1-tuples, so the name has nowhere to bind. This must report a
    // clean diagnostic rather than poisoning to ERROR and crashing IL
    // emission.
    let x = (only = 1);

    Std.write_line("{x}");
si
