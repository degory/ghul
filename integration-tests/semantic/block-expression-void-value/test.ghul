use IO.Std.write_line;

entry() is
    // Void-tolerant contexts: silent. A `(stmt;)` block whose last
    // statement does not produce a value flows void through to the
    // consumer; an expression-statement and a void-returning
    // expression body both accept it without diagnostic.

    (assert true else "ok");
    (for i in 1..2 do write_line("loop"); od);
    void_returning_assert();
    void_returning_for();

    // Value-consuming contexts: a single "cannot use void value
    // here" — same diagnostic an if-expression with void branches
    // emits, no duplicated warning.

    let a = (assert true else "ok");
    let b = (for i in 1..2 do write_line("loop"); od);
si

void_returning_assert() => (assert true else "ok");
void_returning_for() => (for i in 1..2 do write_line("loop"); od);
