// Compound constraints `[T: class new]` and `[T: A new]` enforce both
// requirements. `class new` rejects value types (which violate `class`)
// and reference types without a parameterless ctor; `A new` rejects
// types that don't derive from A and derived types without a ctor.

namespace Test is
    class A is
        init() is si
    si

    class C: A is
        init(x: int) is super.init(); si
    si

    g[T: class new](x: T) -> T => x;
    h[T: A new](x: T) -> T => x;

    class Main is
        entry() static is
            g(42);
            h(C(1));
            return;
        si
    si
si
