namespace Test is
    use IO.Std;

    // Concrete closed-class roots can be constructed directly, so
    // covering every direct subclass still leaves the bare-root case
    // open — the checker requires an explicit `ANIMAL` arm (or an
    // `else`) for exhaustiveness.

    class ANIMAL is
        init() is si
    si

    class CAT: ANIMAL is
        init() is super.init(); si
    si

    class DOG: ANIMAL is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            describe(CAT());
            describe(DOG());
        si

        describe(a: ANIMAL) static is
            case a
            when _: CAT then Std.write_line("c");
            when _: DOG then Std.write_line("d");
            esac
        si
    si
si
