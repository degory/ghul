namespace Test is
    use Std = IO.Std;

    // A static field or static property may name a constant and so
    // may be UPPER_SNAKE_CASE without drawing a non-snake-case warning.
    class HOLDER is
        GREETING: string static => "hello";
        MAX_COUNT: int static;

        entry() static is
            MAX_COUNT = 5;
            Std.write_line("{GREETING} {MAX_COUNT}");
        si
    si
si
