namespace Test is
    // Constructor analogue of the invariant-position case in
    // generic-function-definition: when a generic class has a
    // constructor argument in an invariant generic position
    // (e.g. Iterable[T] — invariant unless reflection metadata
    // marks it covariant) and is called with siblings whose LUB
    // widens T past the invariant constraint, the constructor
    // call must be rejected. Otherwise the compiler binds the
    // owner generic to a wrongly-widened type and emits malformed
    // IL — `InvalidProgramException` at run time, with no
    // compile-time complaint.
    //
    // Mirrors the function-side `structured(1, "hello")` rejection
    // PR #1205 added for try_bind_generic_arguments.

    class BOX[T] is
        item: T;
        bag: Collections.Iterable[T];

        init(item: T, bag: Collections.Iterable[T]) is
            self.item = item;
            self.bag = bag;
        si
    si

    class MAIN is
        test() is
            // arg 0: T = int
            // arg 1: Iterable[T] vs string (which is Iterable[char]) → T = char
            // Conflict; LUB widens to ValueType.
            // Iterable is invariant: string is NOT Iterable[ValueType].
            // expect error:
            BOX(1, "hello");

            return;
        si
    si
si
