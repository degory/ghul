namespace Test is
    use IO.Std;

    union Result[T, E] is
        OK(value: T);
        ERR(error: E);
    si

    class Main is
        entry() static is
            describe(Result.OK[int, string](42));
        si

        describe(r: Result[int, string]) static is
            case r
            when _: Result.OK[int, string] then Std.write_line("ok");
            esac
        si
    si
si
