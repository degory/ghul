namespace Test is
    use Std = IO.Std;
    use Collections.LIST;

    class TYPE is
        name: string => "type";
        init() is si
    si

    class VALUE is
        type: TYPE? public;
        init(type: TYPE) is self.type = type; si
    si

    class EXPR is
        value: VALUE? public;
        left: EXPR public;
        items: LIST[EXPR] public;
        init() is items = LIST[EXPR](); si
    si

    class Main is
        // A `?.` on a legitimately-optional receiver sits textually
        // before a divergent guard that flow-narrows the receiver to
        // present. When a later inference trigger (the `.map` lambda)
        // forces the body-retry fall-back to re-walk the body, that
        // re-walk must start from an empty narrowing environment — or
        // the guard's non-null facts leak back onto the earlier `?.`
        // and it is wrongly flagged redundant.
        describe(e: EXPR) -> string static is
            let left_value = e.left?.value;
            let left_type = left_value?.type;

            if
                !left_value? \/
                !left_type?
            then
                return "absent";
            fi

            let names = e.items | .map(x => x.value).collect();

            return "{left_type.name}/{names.count}";
        si

        entry() static is
            let root = EXPR();
            let child = EXPR();
            child.value = VALUE(TYPE());
            root.left = child;

            Std.out.write_line(describe(root));

            return;
        si
    si
si
