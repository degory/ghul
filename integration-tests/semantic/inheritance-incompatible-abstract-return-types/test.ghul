namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            return;
        si
    si

    trait CountInt is
        count: int;
    si

    trait CountString is
        count: string;
    si

    // Same-name abstract slots but different return types — these are
    // *not* a single virtual slot. The resolver must still reject the
    // diamond.
    trait Both: CountInt, CountString is
    si
si
