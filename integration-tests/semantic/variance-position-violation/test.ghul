// Variance-position safety: a covariant type parameter may appear only
// in output positions, a contravariant one only in input positions.
// `accept`'s parameter is an input position; `produce`'s return type an
// output position.
namespace Test is
    trait BadCovariant[T: out] is
        accept(value: T);
    si

    trait BadContravariant[T: in] is
        produce() -> T;
    si
si
