namespace Test is
    use Std = IO.Std;

    class BOX is
        label: string;
        init(label: string) is self.label = label; si
    si

    get_box() -> BOX? => BOX("hi");
    get_int() -> int? => 42;

    class Main is
        entry() static is
            // Redundant: `x` is declared non-optional (BOX, not BOX?).
            let x = BOX("hi");
            Std.out.write_line(x!.label);

            // Redundant: `b` is flow-narrowed to non-null inside the
            // `if b?` arm before the `!`.
            let b = get_box();
            if b? then
                Std.out.write_line(b!.label);
            fi

            // Redundant: value-type optional `n` is flow-narrowed to
            // hold a value inside the `if n?` arm before the `!`.
            let n = get_int();
            if n? then
                Std.out.write_line("{n!}");
            fi
        si
    si
si
