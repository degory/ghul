namespace Test is
    use Std = IO.Std;

    class BOX is
        label: string;
        init(label: string) is self.label = label; si
    si

    // Option-shaped structurally via has_value/value: `!` asserts the
    // has_value layer, which flow analysis does not track, so it is
    // never redundant.
    struct SLOT is
        has_value: bool;
        value: int;
        init(v: int) is has_value = true; value = v; si
    si

    class LAZY is
        has_value: bool => true;
        value: string => "lazy";
        init() is si
    si

    get_box() -> BOX? => BOX("hi");
    get_int() -> int? => 42;

    describe[T](t: T?) -> string is
        if t? then
            // Redundant: `t` is flow-proven to hold a value inside
            // the `if t?` arm, whatever `T?` lowers to.
            return "{t!}";
        fi

        return "absent";
    si

    class Main is
        entry() static is
            // Redundant: `b` is flow-narrowed to non-null inside the
            // `if b?` arm before the `!`.
            let b = get_box();
            if b? then
                Std.out.write_line(b!.label);
            fi

            // Redundant: value-type optional `n` is flow-proven to
            // hold a value inside the `if n?` arm before the `!`.
            let n = get_int();
            if n? then
                Std.out.write_line("{n!}");
            fi

            Std.out.write_line(describe[int](Ghul.MAYBE[int](7)));

            // Not redundant: the call result is optional and unchecked.
            Std.out.write_line(get_box()!.label);

            // Not redundant: option-shaped operands support `!` with
            // no diagnostics, checked or not.
            let s = SLOT(9);
            Std.out.write_line("{s!}");

            if s? then
                Std.out.write_line("{s!}");
            fi

            let l = LAZY();
            Std.out.write_line(l!.value);
        si
    si
si
