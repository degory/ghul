namespace Test is
    use IO.Std.write_line;

    entry() is
        let no_else_let_1: int =
            case 1
            when 1 then 100
            esac;

        let no_else_let_2: int =
            case 1
            when 1 then 100
            when 2 then 200
            esac;

        write_line("{no_else_let_1}");
        write_line("{no_else_let_2}");

        let no_else_arg: string = "{case 1 when 1 then 10 esac}";
        write_line(no_else_arg);
    si
si
