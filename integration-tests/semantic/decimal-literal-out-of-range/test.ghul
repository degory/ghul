namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Decimal's scale slot is 0-28; a 29-digit fraction is
            // out of range.
            let too_precise = 0.12345678901234567890123456789m;

            // 30 nines (~9.99e29) overflows the 96-bit mantissa slot.
            let too_big = 999999999999999999999999999999m;

            Std.out.write_line("{too_precise} {too_big}");
        si
    si
si
