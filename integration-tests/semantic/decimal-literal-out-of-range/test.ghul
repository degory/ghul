namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Decimal's scale slot is 0-28; a 29-digit fraction is
            // out of range. Without compile-time validation this
            // would build a methodref that the BCL's .ctor throws
            // ArgumentOutOfRangeException on at runtime.
            let too_precise = 0.12345678901234567890123456789m;

            // 30 nines (~9.99e29) overflows the 96-bit mantissa
            // slot. Without validation the high word silently
            // masked and the literal compiled to a truncated value.
            let too_big = 999999999999999999999999999999m;

            Std.out.write_line("{too_precise} {too_big}");
        si
    si
si
