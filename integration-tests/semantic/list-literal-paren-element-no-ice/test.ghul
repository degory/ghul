namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // case 1: list literal where every element is a parenthesised
            // expression. (8) is a paren-group, not a 1-tuple — list
            // element types should be int, not a phantom 1-tuple.
            let v1 = [(8)];
            let v2 = [(8), (9)];
            let v3 = [((1+2)+3), ((4+5)+6)];

            // case 2: paren-wrapped if expression on the RHS of a typed
            // tuple-let. The outer constraint (int, int) must flow into
            // the if expression as a whole, not into a phantom 1-tuple
            // slot.
            let v4: (int, int) = (if true then (1,2) else (3,4) fi);

            Std.write_line("{v1[0]} {v2[0]} {v3[0]} {v4.`0} {v4.`1}");

            return;
        si
    si
si
