use IO.Std.write_line;

// `val ... lav` opens a `.try` INSIDE its body, and a return inside
// that try targets the val-block. Crossing the try's protected
// region with a `br` is invalid IL and `leave` can't carry a value,
// so generate-il rejects this with a clear error rather than emit
// an InvalidProgramException at runtime. Future work could spill
// to a try-local stash before `leave`-ing.
entry() is
    let x: int = val
        try
            if true then
                return 42;
            fi
        finally
            write_line("cleanup");
        yrt
        99
    lav;

    write_line("x = {x}");
si
