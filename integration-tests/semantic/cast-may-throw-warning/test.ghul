namespace Test is
    use Std = IO.Std;

    class BASE is
        init() is si
    si

    class DERIVED: BASE is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            let b: BASE = DERIVED();
            let d: DERIVED = DERIVED();

            // Should warn: non-optional reference target, source not
            // statically assignable to it.
            let a1 = cast DERIVED(b);

            // Should NOT warn: optional target — the migration form.
            let a2 = cast DERIVED?(b);

            // Should NOT warn: source's static type is already assignable
            // to the target (upcast), so the cast is provably safe.
            let a3 = cast BASE(d);

            Std.out.write_line("{a1?} {a2?} {a3?}");
            return;
        si
    si
si
