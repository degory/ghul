namespace Test is
    use Std = IO.Std;

    class MAIN is
        entry() static is
            let s = "hello";
            let xs = Collections.LIST[string]();
            xs.add(s);

            // presence tests inside an assert condition are a
            // deliberate runtime trap for laundered nulls: no hint
            assert s? else "laundered null";
            assert xs | .all(x => x?) else "null element";

            // outside an assert the same test still hints
            if s? then
                Std.out.write_line(s);
            fi
        si
    si
si
