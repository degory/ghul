namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Block-level @suppress: the do ... od is a single statement,
            // and the pragma wraps it. Every throw inside is silenced.
            @suppress("non-exception-throw") do
                throw 12345;
                throw "still suppressed";
                throw 6.28;
            od

            // Back outside the block — warns again.
            throw "out of scope";
        si
    si
si
