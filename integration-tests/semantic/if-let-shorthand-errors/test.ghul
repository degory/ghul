namespace Test is
    class INNER is
        label: string public;
        init(label: string) is self.label = label; si
    si

    class HOLDER is
        inner: INNER? public;
        init(inner: INNER?) is self.inner = inner; si
    si

    class Main is
        find() -> INNER? static => INNER("x");

        entry() static is
            let h = HOLDER(INNER("x"));

            // No path leaf to name the variable after: the tested
            // value needs a name given with the full form.
            if let find()? then
                IO.Std.write_line("unreachable");
            fi

            // A bare local has no path leaf to name a fresh variable
            // after, and a same-named local would only shadow it: use
            // plain `if maybe?` narrowing, or the full form.
            let maybe = h.inner;

            if let maybe then
                IO.Std.write_line("unreachable");
            fi
        si
    si
si
