namespace Test is
    use IO.Std;

    class Animal abstract is
        init() is si
    si

    class CAT: Animal is
        init() is super.init(); si
    si

    class DOG: Animal is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            describe(CAT());
        si

        describe(a: Animal) static is
            case a
            when _: CAT then Std.write_line("c");
            when _: CAT then Std.write_line("c2");
            when _: DOG then Std.write_line("d");
            esac
        si
    si
si
