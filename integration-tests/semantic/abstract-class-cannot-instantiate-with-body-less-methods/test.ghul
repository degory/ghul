namespace Test is
    // A class declared with any body-less method is implicitly
    // abstract — the user wrote the method as a contract for
    // subclasses to satisfy, and a bare instance would have nothing
    // useful to invoke. Constructing such a class directly is
    // rejected; subclasses can still inherit and override.

    class ABSTRACT is
        init() is si
        do_something() -> string;
        do_something_else();
    si

    class Main is
        entry() static is
            let _ = ABSTRACT();
            return;
        si
    si
si
