namespace Test is
    // The else edge of a narrowing test on an optional receiver
    // keeps the null case: ruling out one alternative says nothing
    // about presence, so the complement type stays optional and
    // dereferences through it warn. A value proven present before
    // the test keeps its presence fact through the complement
    // narrow, and the join after the statement is optional again.

    class ANIMAL abstract is
        init() is si
        name: string => "animal";
    si

    class CAT: ANIMAL is
        init() is super.init(); si
    si

    class DOG: ANIMAL is
        init() is super.init(); si
    si

    class BIRD: ANIMAL is
        init() is super.init(); si
    si

    union SHAPE is
        CIRCLE(radius: int);
        SQUARE(side: int);
    si

    class Main is
        entry() static is
            return;
        si

        if_let_else_keeps_null(a: ANIMAL?) static is
            if let c: CAT = a then
                let n1 = c.name;
            else
                let n2 = a.name;
            fi

            let n3 = a.name;
        si

        isa_else_keeps_null(a: ANIMAL?) static is
            if isa CAT(a) then
                let n1 = a.name;
            else
                let n2 = a.name;
            fi
        si

        union_isa_else_keeps_null(s: SHAPE?) static is
            if isa SHAPE.CIRCLE(s) then
                let n1 = s.to_string();
            else
                let n2 = s.to_string();
            fi
        si

        proven_present_else_is_null_free(a: ANIMAL?) static is
            if !a? then
                return;
            fi

            if let c: CAT = a then
                let n1 = c.name;
            else
                let n2 = a.name;
            fi
        si
    si
si
