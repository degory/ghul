// Phase 2: kind constraints are enforced where a generic type is named
// in type position. `int` violates `class`; `string` violates `struct`.

namespace Test is
    class REF_CELL[T: class] is
        _value: T;
        init(value: T) is _value = value; si
    si

    class VAL_CELL[T: struct] is
        _value: T;
        init(value: T) is _value = value; si
    si

    class Main is
        _bad_ref: REF_CELL[int];
        _bad_val: VAL_CELL[string];

        entry() static is si
    si
si
