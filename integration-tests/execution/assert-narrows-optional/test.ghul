namespace Test is
    use Std = IO.Std;

    class BOX is
        value: int public;
        init(v: int) is value = v; si
    si

    class Main is
        // `assert x?` narrows x to non-optional for the rest of the
        // enclosing scope. Without the narrowing, accessing `x.value`
        // after the assert would warn "x may not hold a value".
        use_after_assert(b: BOX?) static is
            assert b? else "expected a box";
            Std.write_line("value = {b.value}");
        si

        entry() static is
            use_after_assert(BOX(42));
        si
    si
si
