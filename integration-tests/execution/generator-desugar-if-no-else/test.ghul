
namespace Test is
    use Std = IO.Std;

    class Main is
        // `if` with no `else`. The dispatch state's synthesised
        // else-branch goes directly to the join state — control
        // falls through the if without entering either branch.
        skip_if_false(cond: bool) -> Collections.Iterable[int] static is
            yield 1;
            if cond then
                yield 10;
                yield 20;
            fi
            yield 2;
        si

        entry() static is
            let total_true mut = 0;
            for x in skip_if_false(true) do
                total_true = total_true + x;
            od

            let total_false mut = 0;
            for x in skip_if_false(false) do
                total_false = total_false + x;
            od

            Std.write_line("true={total_true} false={total_false}");
        si
    si
si
