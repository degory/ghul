namespace Test is
    use Std = IO.Std;

    class Main is
        gen(xs: Collections.Iterable[int]) -> Ghul.Pipes.Pipe[int] static is
            let it = xs.iterator;
            while it.move_next() do
                yield it.current * 10;
            od
        si

        entry() static is
            for v in gen([1, 2, 3, 4]) do
                Std.write_line("v: {v}");
            od
        si
    si
si
