namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Two levels of nesting: counter is owned by entry,
            // captured by outer, captured again by inner.
            // Both closure layers should agree on the same
            // Ghul.BOX[int] cell — every mutation visible
            // everywhere.
            let counter mut = 0;

            let outer = () is
                let inner = () is
                    counter = counter + 1;
                si;

                inner();
                inner();
            si;

            outer();
            outer();

            Std.write_line("counter = {counter}");
        si
    si
si
