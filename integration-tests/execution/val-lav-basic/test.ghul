use IO.Std.write_line;

void_body() => val write_line("vb head"); write_line("vb tail"); lav;

inferred_void_lambda() is
    let f = () => val write_line("ivl head"); write_line("ivl tail"); lav;
    f();
si

void_let_tail() => val write_line("vlt head"); let unused = 99; lav;

entry() is
    // Tail is an expression → block value flows.
    let a = val let y = 5; y * 2 lav;
    write_line("a = {a}");

    // Multiple bindings + arithmetic tail.
    let b = val let p = 3; let q = 4; p + q lav;
    write_line("b = {b}");

    // Side effect then value.
    let c = val write_line("c effect"); 42 lav;
    write_line("c = {c}");

    // Loop-as-expression via mutable accumulator.
    let d = val
        let total mut = 0;
        for i in 1..5 do
            total = total + i;
        od;
        total
    lav;
    write_line("d = {d}");

    // Void block in expression-statement position (value discarded).
    val write_line("e effect"); write_line("e tail"); lav;

    // Void block as `=>` body of a void-returning function.
    void_body();

    // Void block as inferred-void lambda body.
    inferred_void_lambda();

    // Void block whose last statement does not provide a value
    // (a LET) — also legal in void context.
    void_let_tail();
si
