namespace Test is
    use Std = IO.Std;

    class ANIMAL is
        init() is si
    si

    class DOG: ANIMAL is
        init() is si
        bark() is Std.write_line("woof"); si
    si

    class Main is
        // `assert isa DOG(a)` narrows a from ANIMAL to DOG for the
        // rest of the enclosing scope, so `a.bark()` resolves
        // without an explicit cast.
        use_as_dog(a: ANIMAL) static is
            assert isa DOG(a);
            a.bark();
        si

        entry() static is
            use_as_dog(DOG());
        si
    si
si
