namespace Test is
    use IO.Std.write_line;

    // Iterative-inference regression: an inner lambda captures an
    // outer let-bound lambda (`is_even`) whose value type starts as
    // `Func<placeholder, bool>` (its arg `n` infers from the body
    // `n % 2`). When the inner lambda first walks, it captures
    // is_even with the still-placeholder-bearing function type.
    // Without contains_inferred-aware captured-field refresh, the
    // field never refreshes (Func<placeholder, bool>.is_inferred is
    // false; only contains_inferred picks up the nested case) and
    // the frame ctor IL leaks the placeholder comment string.
    entry() is
        let is_even =
            (n) =>
                if n % 2 == 0 then
                    true
                else
                    false
                fi;

        let parity =
            (n) =>
                if is_even(n) then
                    "even"
                else
                    "odd"
                fi;

        write_line("parity(10): {parity(10)}");
    si
si
