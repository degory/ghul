namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Ghul.Pipes.Pipe[string] static is
            yield "alpha";
            yield "beta";
            yield "gamma";
        si

        entry() static is
            for s in gen() do
                Std.write_line("s: {s}");
            od
        si
    si
si
