namespace Test is
    use Std = IO.Std;

    class Main is
        // Branching with await
        compute(flag: bool) -> Tasks.TASK[int] static is
            if flag then
                let a = await Tasks.TASK.from_result(10);
                return a + 1;
            else
                let b = await Tasks.TASK.from_result(20);
                return b * 2;
            fi
        si

        entry() static is
            let r1 = compute(true);
            let r2 = compute(false);
            Std.write_line("t={r1.result} f={r2.result}");
        si
    si
si
