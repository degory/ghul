namespace Test is
    use Std = IO.Std;

    class Main is
        // Inferred return type on a lambda whose body contains a
        // `let await`. DESUGAR_AWAIT flags the lambda (and its
        // synthesised continuation lambdas), so compile-lambdas /
        // visit_return wrap a bare-T body value as `Tasks.TASK[T]`.
        // Without the wrap the surrounding
        // `Tasks.TaskExtensions.unwrap(... continue_with ...)` chain
        // would reject the synthesised continuation lambda's `T` body
        // value.
        compute() static is
            let f = () is
                let await a = Tasks.TASK.from_result(5);
                return a * 10;
            si;

            Std.write_line("f={f().result}");
        si

        entry() static is
            compute();
        si
    si
si
