namespace Test is
    use Std = IO.Std;

    class Main is
        // A lambda with an inferred return type whose body contains
        // an `await`. The body's bare-T value must be lifted into
        // the enclosing TASK[T] return type without an explicit
        // signature.
        compute() static is
            let f = () is
                let a = await Tasks.TASK.from_result(5);
                return a * 10;
            si;

            Std.write_line("f={f().result}");
        si

        entry() static is
            compute();
        si
    si
si
