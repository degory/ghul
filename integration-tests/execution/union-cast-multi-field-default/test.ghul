use IO.Std.write_line;

// Multi-field default variant: `u!` returns the variant itself so
// every field is reachable through it, no single-field projection.
union Pair[A, B] is
    BOTH(first: A, second: B) default;
    NEITHER;
si

entry() is
    let p: Pair[int, string] = Pair.BOTH[int, string](7, "seven");
    let n: Pair[int, string] = Pair.NEITHER[int, string]();

    write_line("p?: {p?}");
    write_line("n?: {n?}");

    let both = p!;
    write_line("both.first: {both.first}");
    write_line("both.second: {both.second}");

    try
        let neither = n!;
        write_line("neither.first: {neither.first}");
    catch ex: System.Exception
        write_line("threw");
    yrt
si
