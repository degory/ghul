namespace Test is
    use Std = IO.Std;

    class Main is
        // A function returning plain int (not Task[int]) — no wrap should
        // ever fire, and `return 5;` works as it always has.
        plain() -> int static is
            return 5;
        si

        // Function returning TASK[string] — auto-wrap on a string literal.
        named() -> Tasks.TASK[string] static is
            return "hi";
        si

        entry() static is
            Std.write_line("plain={plain()}");
            Std.write_line("named={named().result}");
        si
    si
si
