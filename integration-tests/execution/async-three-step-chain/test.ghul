namespace Test is
    use Std = IO.Std;

    // 10 → *2 → +1 → *100 = 2100
    class Main is
        entry() static is
            let result =
                Tasks.TaskExtensions.unwrap(
                    Tasks.TASK.from_result(10).continue_with(
                        (t1: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                            Tasks.TaskExtensions.unwrap(
                                Tasks.TASK.from_result(t1.result * 2).continue_with(
                                    (t2: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                                        Tasks.TaskExtensions.unwrap(
                                            Tasks.TASK.from_result(t2.result + 1).continue_with(
                                                (t3: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                                                    Tasks.TASK.from_result(t3.result * 100)
                                            )
                                        )
                                )
                            )
                    )
                );

            Std.write_line("three_step.result={result.result}");
        si
    si
si
