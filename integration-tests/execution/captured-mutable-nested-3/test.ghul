namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Three levels of nesting. The captured cell must
            // be threaded all the way down through each
            // intermediate frame — outer captures it from
            // entry, mid captures it from outer's frame, inner
            // captures it from mid's frame.
            let x mut = 0;

            let outer = () is
                let mid = () is
                    let inner = () is
                        x = x + 10;
                    si;
                    inner();
                si;
                mid();
            si;

            outer();
            outer();
            outer();

            Std.write_line("x = {x}");
        si
    si
si
