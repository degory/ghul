namespace Test is
    use Std = IO.Std;

    class BOX is
        value: int public;
        init(v: int) is value = v; si
    si

    class Main is
        // Compound condition: `assert a? /\ b?` should narrow both.
        // Uses the same condition-analyzer path the `if` statement
        // does, so /\ /\| /\ etc. flow through correctly.
        sum(a: BOX?, b: BOX?) -> int static is
            assert a? /\ b? else "expected both";
            return a.value + b.value;
        si

        entry() static is
            Std.write_line("{sum(BOX(3), BOX(4))}");
        si
    si
si
