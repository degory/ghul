namespace Test is
    use Std = IO.Std;

    class Main is
        // User-written try/finally with await in the try BODY.
        // Same IL pathology as let-use, same fix.
        run() -> Tasks.TASK[int] static is
            try
                Std.write_line("before");
                let x = await Tasks.TASK.from_result(42);
                Std.write_line("after");
                return x + 1;
            finally
                Std.write_line("finally");
            yrt
        si

        entry() static is
            Std.write_line("{run().result}");
        si
    si
si
