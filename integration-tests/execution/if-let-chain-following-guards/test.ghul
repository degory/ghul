namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            describe(CAT("Felix", true));
            describe(CAT("Whiskers", false));
            describe(DOG("Rex"));
            describe(null);

            show(PAIR(42, "hello"), true);
            show(PAIR(7, "skipped"), false);
            show(null, true);

            multi(CAT("Tom", true), 5);
            multi(CAT("Jerry", true), 0);
            multi(DOG("Spot"), 5);

            sequence(SOME_HOLDER(SOME_INNER(99)));
            sequence(SOME_HOLDER(SOME_INNER(0)));
            sequence(SOME_HOLDER(null));
            sequence(null);
        si

        // Single trailing guard, type-ascription binding.
        // c.is_friendly proves the binding narrowed to CAT.
        describe(animal: ANIMAL?) static is
            if let c: CAT = animal /\ c.is_friendly then
                Std.out.write_line("friendly cat: {c.name}");
            elif let c: CAT = animal then
                Std.out.write_line("unfriendly cat: {c.name}");
            elif let d: DOG = animal then
                Std.out.write_line("dog: {d.name}");
            else
                Std.out.write_line("no animal");
            fi
        si

        // Bare binding plus a guard that doesn't reference the binding —
        // the guard still gates entry to the then-arm.
        show(p: PAIR?, want: bool) static is
            if let pair = p /\ want then
                Std.out.write_line("pair: {pair.first}, {pair.second}");
            else
                Std.out.write_line("skip");
            fi
        si

        // Two following guards — both must hold to enter the then-arm.
        multi(animal: ANIMAL?, n: int) static is
            if let c: CAT = animal /\ c.is_friendly /\ n > 0 then
                Std.out.write_line("friendly cat {c.name} got {n}");
            else
                Std.out.write_line("multi: nope");
            fi
        si

        // Guard referencing a nested optional member off the binding.
        sequence(h: SOME_HOLDER?) static is
            if let holder = h /\ holder.inner? then
                if let inner = holder.inner /\ inner.value > 0 then
                    Std.out.write_line("got {inner.value}");
                else
                    Std.out.write_line("zero or absent inner");
                fi
            else
                Std.out.write_line("no holder");
            fi
        si
    si

    class ANIMAL is
        name: string;
        init(name: string) is self.name = name; si
    si

    class CAT: ANIMAL is
        is_friendly: bool;
        init(name: string, is_friendly: bool) is
            super.init(name);
            self.is_friendly = is_friendly;
        si
    si

    class DOG: ANIMAL is
        init(name: string) is super.init(name); si
    si

    class PAIR is
        first: int;
        second: string;
        init(a: int, b: string) is
            first = a;
            second = b;
        si
    si

    class SOME_INNER is
        value: int;
        init(value: int) is self.value = value; si
    si

    class SOME_HOLDER is
        inner: SOME_INNER?;
        init(inner: SOME_INNER?) is self.inner = inner; si
    si
si
