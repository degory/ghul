namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // All-literal destructure — every position is a value
            // test; no names are bound. Useful for matching specific
            // tuple values.
            show((0, 0));
            show((0, 1));
            show((1, 0));
            show(null);
        si

        show(point: (int, int)?) static is
            if let (0, 0) = point then
                Std.out.write_line("origin");
            else
                Std.out.write_line("elsewhere");
            fi
        si
    si
si
