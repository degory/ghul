namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Captured mutable shared between two closures —
            // bump mutates, peek reads. Mutations are visible
            // across closures and to the outer scope because
            // they all share one Ghul.BOX[T] cell.
            let count mut = 10;

            let bump = () is
                count = count + 1;
            si;

            let peek = () -> int => count;

            bump();
            bump();

            count = count + 100;

            Std.write_line("peek() = {peek()}");
            Std.write_line("count  = {count}");
        si
    si
si
