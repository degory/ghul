namespace Test is
    use Std = IO.Std;

    // A `let await` on a faulted task surfaces the inner exception
    // type, not the AggregateException wrapper. Matches C# `await`
    // semantics via `Task.GetAwaiter().GetResult()`.

    class Main is
        boom() -> Tasks.TASK[int] static =>
            Tasks.TASK.from_exception[int](
                System.InvalidOperationException("inner cause")
            );

        consume_via_let_await() -> Tasks.TASK[string] static is
            let value = await boom();
            return "unexpected value={value}";
        si

        entry() static is
            try
                let _ = consume_via_let_await().result;
                Std.write_line("UNEXPECTED no exception");
            catch ae: System.AggregateException
                // Inner depth-1: the outer `.result` wraps once.
                // Without the unwrap fix, depth-2 would show "One or
                // more errors occurred. (inner cause)" instead of the
                // bare InvalidOperationException.
                let inner = ae.inner_exception!;

                if isa System.InvalidOperationException(inner) then
                    Std.write_line("inner is InvalidOperationException: {inner.message}");
                else
                    Std.write_line("inner type {inner.get_type().name}: {inner.message}");
                fi
            yrt
        si
    si
si
