namespace Test is
    use IO.Std;

    // Generic subclass / base relationship: a call producing the
    // derived type with no args to bind its type-param should infer
    // the type-param from a base-type-shaped return constraint via
    // OWNER_CONSTRAINT_SPECIALIZER's try_unify_via_ancestor path.

    class Animal[T] is
        tag: T public;

        init(tag: T) is super.init(); self.tag = tag; si
    si

    class Dog[T]: Animal[T] is
        init(tag: T) is super.init(tag); si
    si

    // Slot-renaming subclass: ancestor declares Animal[U] where the
    // subclass's own type-arg has a different name; alignment must
    // still recover the binding from the constraint slot.
    class Pet[U]: Animal[U] is
        init(tag: U) is super.init(tag); si
    si

    // Slot-rewriting subclass: the first ancestor slot is pinned at
    // declaration time (`Animal[int]`), only the second flows through.
    class TaggedDog[V]: Animal[int] is
        extra: V public;

        init(extra: V) is super.init(0); self.extra = extra; si
    si

    make_animal() -> Animal[int] is
        return Dog(7);
    si

    make_pet() -> Animal[string] is
        return Pet("rex");
    si

    let_init() -> Animal[int] is
        let a: Animal[int] = Dog(42);
        return a;
    si

    class Main is
        entry() static is
            let a = make_animal();
            let p = make_pet();
            let l = let_init();
            let t: Animal[int] = TaggedDog("paw");

            Std.write_line("dog tag: {a.tag}");
            Std.write_line("pet tag: {p.tag}");
            Std.write_line("init tag: {l.tag}");
            Std.write_line("tagged tag: {t.tag}");

            return;
        si
    si
si
