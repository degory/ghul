namespace Test is
    use IO.Std;

    // Generic subclass / base relationship exercised through the
    // CONSTRUCTOR_CONSTRAINT_RETRY ancestor-unification path. The
    // subclass's constructor passes an arg that binds one owner
    // type-param but leaves the other unsourced, so first-pass
    // overload resolution returns null (S has no source from args).
    // The retry then walks the candidate owner's ancestors to find
    // the constraint's head and pins both slots from the constraint.

    class Animal[T, S] is
        tag: T public;

        init(tag: T) is super.init(); self.tag = tag; si
    si

    // Same-name slots: Dog declares `Animal[T, S]` as its base.
    // The retry's try_unify_via_ancestor lines Dog's T, S up with
    // the constraint's slots through Animal's ancestor declaration.
    class Dog[T, S]: Animal[T, S] is
        init(tag: T) is super.init(tag); si
    si

    // Slot-renamed subclass: Pet's own slots are named U, V; the
    // ancestor declaration substitutes them into Animal's positions.
    // try_unify_via_ancestor keys the recovered map by owner_classy's
    // argument_names (U, V), so the constraint's args land on Pet's
    // own slots even with the rename.
    class Pet[U, V]: Animal[U, V] is
        init(tag: U) is super.init(tag); si
    si

    make_animal() -> Animal[int, string] is
        return Dog(7);
    si

    make_pet() -> Animal[string, int] is
        return Pet("rex");
    si

    let_init() -> Animal[int, string] is
        let a: Animal[int, string] = Dog(42);
        return a;
    si

    class Main is
        entry() static is
            let a = make_animal();
            let p = make_pet();
            let l = let_init();

            Std.write_line("dog: {isa Dog[int, string](a)}");
            Std.write_line("dog tag: {a.tag}");
            Std.write_line("pet: {isa Pet[string, int](p)}");
            Std.write_line("pet tag: {p.tag}");
            Std.write_line("init: {isa Dog[int, string](l)}");
            Std.write_line("init tag: {l.tag}");

            return;
        si
    si
si
