namespace Test is
    use Std = IO.Std;

    class COUNTER is
        _base: int;
        init(base: int) is _base = base; si

        // Instance method async
        compute(delta: int) -> Tasks.TASK[int] is
            let x = await Tasks.TASK.from_result(_base + delta);
            return x * 2;
        si
    si

    class Main is
        entry() static is
            let c = COUNTER(100);
            let r = c.compute(5);
            IO.Std.write_line("got={r.result}");
        si
    si
si
