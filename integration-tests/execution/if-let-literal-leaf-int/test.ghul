namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Literal leaf at first position: matches only when the
            // tuple's first element equals 1.
            show((1, "one"));
            show((1, "still one"));
            show((2, "two"));
            show(null);
        si

        show(pair: (int, string)?) static is
            if let (1, name) = pair then
                Std.out.write_line("first is one: {name}");
            else
                Std.out.write_line("nope");
            fi
        si
    si
si
