namespace Test is
    use Std = IO.Std;

    class COUNTER is
        next_id: int static;

        init() static is
            next_id = 100;
        si

        id: int;

        init() is
            id = next_id;
            next_id = next_id + 1;
        si
    si

    struct MARKER is
        origin: int static;

        init() static is
            origin = 5;
        si
    si

    class Main is
        entry() static is
            let a = COUNTER();
            let b = COUNTER();

            Std.write_line("a.id = {a.id}");
            Std.write_line("b.id = {b.id}");
            Std.write_line("COUNTER.next_id = {COUNTER.next_id}");
            Std.write_line("MARKER.origin = {MARKER.origin}");

            return;
        si
    si
si
