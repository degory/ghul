namespace Test is
    use Std = IO.Std;

    class Main is
        // Try/catch with await in the try BODY — succeeds, no exception.
        ok() -> Tasks.TASK[int] static is
            try
                let x = await Tasks.TASK.from_result(7);
                return x * 10;
            catch e: System.Exception
                return -1;
            yrt
        si

        // Try/catch with await in try BODY — the awaited task is faulted,
        // exception unwraps and the catch fires.
        boom() -> Tasks.TASK[int] static is
            try
                let x = await Tasks.TASK.from_result(0);
                throw System.Exception("post-await");
            catch e: System.Exception
                return -1;
            yrt
        si

        entry() static is
            Std.write_line("ok={ok().result}");
            Std.write_line("boom={boom().result}");
        si
    si
si
