namespace Test is
    use Std = IO.Std;

    // Tests: a `ref` written argument threaded through `|>` binds the
    // correct formal. The subject takes formal 0, so `w ref` binds
    // formal 1, and definite-assignment analysis must behave exactly as
    // for the direct call `fill(5, w ref)`.

    fill(a: int, out: int ref) static is
        out! = a * 10;
    si

    class MAIN is
        entry() static is
            let w: int mut;
            5 |> fill(w ref);
            Std.out.write_line("w = {w}");
        si
    si
si
