namespace Test is
    use IO.Std;
    use Collections;

    // Tests: `let xs = LIST()` with no explicit T
    // and no initialiser to bind T from. Later `xs.add(42)` should
    // back-feed int as the element type.
    //
    // Today _try_specialize_owner_with_placeholders creates phantoms
    // for each unbound type-arg slot. The `.add(42)` call's overload
    // resolution should bind T=int and back-feed onto the phantom.
    // On the body retry's next iteration, the phantom resolves and
    // xs's type becomes LIST[int].

    class Main is
        entry() static is
            let xs = LIST();
            xs.add(1);
            xs.add(2);
            xs.add(3);

            Std.write_line("count={xs.count}");
            return;
        si
    si
si
