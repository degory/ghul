namespace Test is
    use IO.Std;

    // Iterative inference of a recursive lambda's argument type
    // with no annotations. The body has `n == 0` which constrains
    // n to int via overload-resolver back-feed, and `n * rec(n - 1)`
    // which similarly constrains. The recursive call rec(n - 1)
    // passes an int so the recursive formal arg also resolves to
    // int.
    class Main is
        entry() static is
            let fac = n rec => if n == 0 then 1 else n * rec(n - 1) fi;
            Std.write_line("{fac(5)}");
            return;
        si
    si
si
