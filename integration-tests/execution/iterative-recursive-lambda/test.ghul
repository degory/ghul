namespace Test is
    use IO.Std;

    // Iterative-inference probe: recursive lambda without explicit
    // type annotations on the argument. The 2024 attempt at
    // iterative inference hit a "issue with recursive lambdas"
    // failure mode (commit baa16706 on
    // origin/degory/iterative-type-inference-1). This probe checks
    // whether today's retry-loop architecture sidesteps the
    // original problem.
    //
    // The body has `n == 0` which constrains n to int via
    // overload-resolver back-feed, and `n * rec(n - 1)` which
    // similarly constrains. The recursive call rec(n - 1) passes
    // an int so the recursive formal arg should also be int.
    class Main is
        entry() static is
            let fac = n rec => if n == 0 then 1 else n * rec(n - 1) fi;
            Std.write_line("{fac(5)}");
            return;
        si
    si
si
