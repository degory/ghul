namespace Test is
    use Std = IO.Std;

    class Main is
        // Without `[int]`, from_exception's two overloads
        // (`Tasks.TASK.from_exception(ex)` returning the non-generic
        // `Tasks.TASK`, vs `Tasks.TASK.from_exception[T](ex)` returning
        // `Tasks.TASK[T]`) require the return-type constraint
        // `Tasks.TASK[int]` to disambiguate. The resolver picks
        // wrongly today.
        divide(a: int, b: int) -> Tasks.TASK[int] static is
            if b == 0 then
                return Tasks.TASK.from_exception(
                    System.InvalidOperationException("division by zero")
                );
            fi
            return a / b;
        si

        entry() static is
            try
                let r = divide(10, 0).result;
                Std.write_line("unexpected: {r}");
            catch ex: System.AggregateException
                Std.write_line("caught: {ex.get_base_exception().message}");
            yrt
        si
    si
si
