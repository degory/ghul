namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            describe(Cat("Felix"));
            describe(Dog("Rex"));
            describe(Animal("creature"));
            describe(null);
        si

        describe(animal: Animal?) static is
            case animal
            when null then
                Std.out.write_line("nothing");
            when c: Cat then
                c.meow();
            when d: Dog then
                d.bark();
            else
                Std.out.write_line("just an animal: {animal!.name}");
            esac
        si
    si

    class Animal open is
        name: string;
        init(name: string) is self.name = name; si
    si

    class Cat: Animal open is
        init(name: string) is super.init(name); si
        meow() is Std.out.write_line("{name} says meow"); si
    si

    class Dog: Animal open is
        init(name: string) is super.init(name); si
        bark() is Std.out.write_line("{name} says woof"); si
    si
si
