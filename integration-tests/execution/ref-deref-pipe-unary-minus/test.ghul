namespace Test is
    use Std = IO.Std;

    entry() is
        // `xs | -y` is binary OR with -y as the RHS (previously
        // the primary-parser probe misclassified it as postfix
        // pipe-wrap of xs, then `-y` would dangle).
        let a = 0x0F;
        let b = 0x10;
        let c = a | -b;
        Std.out.write_line("{c}");
    si
si
