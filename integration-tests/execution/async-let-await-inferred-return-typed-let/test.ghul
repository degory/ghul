namespace Test is
    use Std = IO.Std;

    class Main is
        // Receiver of the lambda is `let r: Tasks.TASK[int] = f();`
        // — the surrounding context expects Task[int], confirming the
        // inferred-return wrap produces an externally-callable
        // Task[int] result (not Task[Task[int]]).
        entry() static is
            let f = () is
                let await a = Tasks.TASK.from_result(7);
                return a + 1;
            si;

            let r: Tasks.TASK[int] = f();

            Std.write_line("r={r.result}");
        si
    si
si
