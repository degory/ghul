namespace Test is
    use IO.Std;
    use Collections;

    // Tests: a single-param lambda whose parameter is
    // a tuple, with the body destructuring the tuple via a `let`.
    // The parameter type should be inferred from the sibling-arg
    // owner-generic binding (Iterable[(int,int)] → param: (int,int)).
    // Then the destructure `let (a, b) = p` has a concrete p to
    // pull names from.

    each[T](xs: Iterable[T], action: T -> void) is
        for x in xs do
            action(x);
        od
    si

    class Main is
        entry() static is
            let pairs = [(1, 2), (3, 4), (5, 6)];
            each(pairs, p => let (a, b) = p in Std.write_line("{a}+{b}={a+b}"));
            return;
        si
    si
si
