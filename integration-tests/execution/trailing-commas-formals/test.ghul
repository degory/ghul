namespace Test is
    use Std = IO.Std;

    // Function formal-argument list with trailing comma.
    sum_two(a: int, b: int,) -> int => a + b;

    sum_three(
        a: int,
        b: int,
        c: int,
    ) -> int => a + b + c;

    class Main is
        // Method formal-argument list with trailing comma.
        emit(label: string, value: int,) static is
            Std.write_line("{label}={value}");
        si

        entry() static is
            // let-statement variable list with trailing comma.
            let x: int = 1, y: int = 2,;

            emit("two", sum_two(10, 20));
            emit("three", sum_three(100, 200, 300));
            Std.write_line("xy={x + y}");

            return;
        si
    si
si
