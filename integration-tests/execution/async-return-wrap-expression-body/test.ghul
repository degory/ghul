namespace Test is
    use Std = IO.Std;

    class Main is
        // Expression-body function: `=> EXPR` in a function declared
        // to return TASK[int]. Should auto-wrap.
        compute() -> Tasks.TASK[int] static => 7;

        entry() static is
            let task = compute();
            Std.write_line("got={task.result}");
        si
    si
si
