use IO.Std.write_line;

union Color(name: string, count: int) is
    RED;
    GREEN;
    BLUE(extra: string, ..);
si

entry() is
    let r: Color = Color.RED("red", 1);
    let g: Color = Color.GREEN("green", 2);
    let b: Color = Color.BLUE("extra", "blue", 3);

    write_line(r.name);
    write_line(r.count);

    write_line(g.name);
    write_line(g.count);

    write_line(b.name);
    write_line(b.count);

    if let blue: Color.BLUE = b then
        write_line(blue.extra);
    fi
si
