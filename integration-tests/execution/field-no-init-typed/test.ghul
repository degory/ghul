namespace Test is
    use IO.Std;
    use Collections;

    // Regression guard: a class field typed `LIST[T]` (with the
    // class's T) initialised in the constructor body with `LIST()`
    // — no explicit type-arg. The assignment-LHS-from-constraint
    // path infers `LIST[T]` from the field's declared type.
    //
    // The inline-field-initialiser form `xs: LIST[T] = LIST();`
    // currently breaks with "symbol not found: Box" at the
    // construction site — a separate parser/semantic bug,
    // unrelated to inference, captured by tests but not
    // pinned here.

    class Box[T] is
        xs: LIST[T];
        init() is
            xs = LIST();
        si

        add_one(x: T) is
            xs.add(x);
        si

        count() -> int => xs.count;
    si

    class Main is
        entry() static is
            let b = Box[int]();
            b.add_one(1);
            b.add_one(2);
            Std.write_line("count={b.count()}");
            return;
        si
    si
si
