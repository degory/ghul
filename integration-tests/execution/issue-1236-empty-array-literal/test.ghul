namespace Test is
    use Std = IO.Std;

    total(xs: int[]) -> int is
        let t mut = 0;
        for x in xs do t = t + x; od
        return t;
    si

    class Main is
        entry() static is
            let typed: int[] = [];
            Std.out.write_line("typed count: {typed.count}");

            let nested: int[][] = [];
            Std.out.write_line("nested count: {nested.count}");

            let inferred = [];
            Std.out.write_line("inferred count: {inferred.count}");

            Std.out.write_line("total of typed: {total(typed)}");
            return;
        si
    si
si
