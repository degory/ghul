s =~ m (both hello): True
s =~ o (hello vs other): False
s =~ n (non-null vs null): False
m =~ s (both hello, swapped): True
n =~ s (null vs non-null): False
n =~ n (both null): True
m =~ m (same non-null): True
s !~ n (non-null vs null): True
n !~ n (both null): False
a == b (non-null vs null): False
b == null (null vs null literal): True
a != b (non-null vs null): True
