namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let s: string = "hello";
            let n: string? = null;
            let m: string? = "hello";
            let o: string? = "other";

            Std.out.write_line("s =~ m (both hello): {s =~ m}");
            Std.out.write_line("s =~ o (hello vs other): {s =~ o}");
            Std.out.write_line("s =~ n (non-null vs null): {s =~ n}");
            Std.out.write_line("m =~ s (both hello, swapped): {m =~ s}");
            Std.out.write_line("n =~ s (null vs non-null): {n =~ s}");
            Std.out.write_line("n =~ n (both null): {n =~ n}");
            Std.out.write_line("m =~ m (same non-null): {m =~ m}");

            Std.out.write_line("s !~ n (non-null vs null): {s !~ n}");
            Std.out.write_line("n !~ n (both null): {n !~ n}");

            let a: object = s;
            let b: object? = null;

            Std.out.write_line("a == b (non-null vs null): {a == b}");
            Std.out.write_line("b == null (null vs null literal): {b == null}");
            Std.out.write_line("a != b (non-null vs null): {a != b}");
        si
    si
si
