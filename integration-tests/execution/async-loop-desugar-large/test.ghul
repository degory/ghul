namespace Test is
    use Std = IO.Std;

    class Main is
        // Returns a Task that completes immediately. Cheap source
        // of an async-shaped operation so the loop yields per
        // iteration rather than running synchronously inline.
        tick(x: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(0).continue_with(
                (t: Tasks.TASK) -> int => x
            );

        // 1000 iterations through a real for-loop with let-await
        // inside. The desugar produces a chain of .continue_with
        // calls; each yield is dispatched on a fresh thread-pool
        // frame so the call stack stays bounded regardless of
        // iteration count.
        sum_to(n: int) -> Tasks.TASK[int] static is
            let mutable_xs = Collections.LIST[int]();
            for i in 0..n do
                mutable_xs.add(i);
            od
            let xs: Collections.List[int] = mutable_xs;
            let total mut = 0;
            for x in xs do
                let v = await tick(x);
                total = total + v;
            od
            return total;
        si

        entry() static is
            // sum of 0..1000 (exclusive) = 0+1+...+999 = 499500.
            let result = sum_to(1000).result;
            Std.write_line("result={result}");
        si
    si
si
