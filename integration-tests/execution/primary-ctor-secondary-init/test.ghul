namespace Test is
    use Std = IO.Std;

    class POINT(x: int, y: int) is
        _x;
        _y;

        init(.., label: string) is
            Std.write_line("{label}: ({_x}, {_y})");
        si

        show() is
            Std.write_line("({_x}, {_y})");
        si
    si

    class Main is
        entry() static is
            POINT(1, 2).show();
            POINT(3, 4, "origin offset");
        si
    si
si
