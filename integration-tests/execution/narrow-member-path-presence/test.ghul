// Presence narrowing over member-access paths: `if x.y? then x.y.z fi`
// type-checks when every hop is a field or a property whose getter is
// proven store-free, because re-reading such a path under an unchanged
// heap repeats the same answer. The flow transfers forget a path the
// moment the heap may have changed what it reads: any possibly-storing
// call forgets every path; any heap store forgets getter-bearing paths;
// a store to a field a path reads through — on any receiver, aliased or
// not — forgets that path; reassigning the root forgets its paths. A
// path through a getter that stores never narrows at all.

use Std = IO.Std;

class INNER is
    tag: string? public;      // auto-property: store-free getter
    hits: int? public;        // value-type optional through the path
    init(t: string?, h: int?) is
        tag = t;
        hits = h;
    si
si

class OUTER is
    inner: INNER? public;     // auto-property: store-free getter
    _raw: INNER?;             // raw field hop
    counter: int public;

    noisy: INNER? is          // getter with a store: never a path hop
        counter = counter + 1;
        return _raw;
    si

    raw_inner: INNER? => _raw;

    init(inner: INNER?) is
        self.inner = inner;
        _raw = inner;
    si

    poke() is
        counter = counter + 1;
    si
si

single_hop(o: OUTER) is
    if o.inner? then
        Std.write_line("single: {o.inner.tag}");
    fi
si

two_hops(o: OUTER) is
    if o.inner? /\ o.inner.tag? then
        Std.write_line("two: {o.inner.tag.length}");
    fi
si

value_type_leaf(o: OUTER) is
    if o.inner? /\ o.inner.hits? then
        Std.write_line("hits: {o.inner.hits + 1}");
    fi
si

field_hop(o: OUTER) is
    if o.raw_inner? /\ o.raw_inner.tag? then
        Std.write_line("field hop: {o.raw_inner.tag}");
    fi
si

storing_getter_never_narrows(o: OUTER) is
    if o.noisy? then
        Std.write_line("noisy checked");

        if o.noisy? then
            Std.write_line("still noisy");
        fi
    fi
si

call_forgets(o: OUTER) is
    if o.inner? then
        o.poke();

        if o.inner? then
            Std.write_line("call: re-proven");
        fi
    fi
si

root_reassignment_forgets(o: OUTER, other: OUTER) is
    let r mut = o;

    if r.inner? then
        r = other;

        if r.inner? then
            Std.write_line("root: re-proven");
        fi
    fi
si

entry() is
    let inner = INNER("hello", 41);
    let o = OUTER(inner);

    single_hop(o);
    two_hops(o);
    value_type_leaf(o);
    field_hop(o);
    storing_getter_never_narrows(o);
    call_forgets(o);
    root_reassignment_forgets(o, OUTER(null));
si
