namespace Ghul.Generators is
    enum _GEN_STEP_KIND is
        DONE,
        YIELD,
        TRANSITION,
    si

    struct _GEN_STEP[T] is
        kind: _GEN_STEP_KIND;
        value: T;
        next_state: int;

        init() is si

        init(kind: _GEN_STEP_KIND, value: T, next_state: int) is
            self.kind = kind;
            self.value = value;
            self.next_state = next_state;
        si
    si

    class _GEN_DRIVER[T]: Collections.Iterable[T], Collections.Iterator[T] is
        _states: Collections.List[() -> _GEN_STEP[T]];
        _state_index: int;
        _current: T;
        _done: bool;

        init(states: Collections.List[() -> _GEN_STEP[T]]) is
            _states = states;
            _state_index = 0;
            _done = false;
        si

        iterator: Collections.Iterator[T] => self;
        current: T => _current;

        move_next() -> bool is
            if _done then return false; fi
            while true do
                let step = _states[_state_index]();
                if step.kind == _GEN_STEP_KIND.DONE then
                    _done = true;
                    return false;
                elif step.kind == _GEN_STEP_KIND.YIELD then
                    _current = step.value;
                    _state_index = step.next_state;
                    return true;
                else
                    _state_index = step.next_state;
                fi
            od
            return false;
        si

        reset() is
            _state_index = 0;
            _done = false;
        si

        dispose() is si
    si

    _gen_pipe[T](states: Collections.List[() -> _GEN_STEP[T]])
        -> Collections.Iterable[T]
    =>
        _GEN_DRIVER[T](states);
si

namespace Test is
    use Std = IO.Std;

    class Main is
        // Conditional yield. The `if` branches contain yields, so
        // DESUGAR_YIELD splits the state machine at the if: state 0
        // dispatches to either the then-branch's first state or the
        // else-branch's first state; both branches' trailing states
        // TRANSITION to the join state which carries on with the
        // post-if yields.
        maybe_yield(cond: bool) -> Collections.Iterable[int] static is
            yield 1;
            if cond then
                yield 100;
                yield 200;
            else
                yield 999;
            fi
            yield 2;
        si

        entry() static is
            let total_true mut = 0;
            for x in maybe_yield(true) do
                total_true = total_true + x;
            od

            let total_false mut = 0;
            for x in maybe_yield(false) do
                total_false = total_false + x;
            od

            Std.write_line("true={total_true} false={total_false}");
        si
    si
si
