namespace Test is
    use Std = IO.Std;

    class Main is
        compute() -> Tasks.TASK[int] static is
            Std.write_line("before-await");

            await Tasks.TASK.delay(5);

            Std.write_line("after-first-await");

            let await answer = Tasks.TASK.from_result(42);

            Std.write_line("got-answer={answer}");

            await Tasks.TASK.from_result(99);

            Std.write_line("after-discard-await");

            return Tasks.TASK.from_result(answer + 1);
        si

        entry() static is
            let result = compute();

            Std.write_line("final={result.result}");
        si
    si
si
