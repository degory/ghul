namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A terminal Pipe consumer over a fusible map/filter chain lowers to an
    // inline driving loop that produces the consumer's result directly,
    // instead of building the pipe objects and iterating them. Covers each
    // consumer over a guarded collection source and a sealed range source;
    // results must match the ordinary pipe lowering.

    class Main is
        entry() static is
            let xs = LIST[int]([1, 2, 3, 4, 5, 6]);

            Std.write_line("count: {pipe(xs).map(n => n * 2).filter(n => n > 4).count()}");
            Std.write_line("any: {pipe(xs).map(n => n * 2).any(n => n > 10)}");
            Std.write_line("all: {pipe(xs).map(n => n * 3).all(n => n < 10)}");
            Std.write_line("reduce: {pipe(xs).map(n => n * 10).reduce(0, (a: int, n: int) => a + n)}");

            let find = pipe(xs).map(n => n * 10).find(n => n > 25);
            Std.write_line("find: {if find? then find! else -1 fi}");

            let first = pipe(xs).filter(n => n % 2 == 0).first();
            Std.write_line("first: {if first? then first! else -1 fi}");

            let collected = pipe(xs).map(n => n * 10).filter(n => n > 25).collect_list();
            let sum mut = 0;
            for c in collected do sum = sum + c; od
            Std.write_line("collect: count={collected.count} sum={sum}");

            let seen mut = 0;
            pipe(xs).filter(n => n % 2 == 0).for_each((n: int) is seen = seen + n; si);
            Std.write_line("for_each: {seen}");

            // sealed range source (fused directly, no guard)
            Std.write_line("range count: {(0..10) | .filter(n => n % 3 == 0) .count()}");
            Std.write_line("range any: {(0..10) | .map(n => n * n) .any(n => n > 50)}");
        si
    si
si
