use IO.Std.write_line;

f() -> int is
    write_line("f called");
    return 42;
si

entry() is
    // `let _ = expr` evaluates and discards (repeatable in scope)
    let _ = f();
    let _ = "again";
    let _ = 3.14;

    // Tuple destructure with multiple discards
    let triple = (1, "x", 99);
    let (_, _, z) = triple;
    write_line(z);

    // Lambda parameters
    let only_first = (x: int, _: int) -> int => x;
    write_line(only_first(10, 20));

    // Two discards in lambda params
    let always_zero = (_: int, _: int) -> int => 0;
    write_line(always_zero(1, 2));

    // for-loop variable as discard (iterate side effects only)
    let count = 0;
    for _ in 1..3 do
        count = count + 1;
    od
    write_line(count);
si
