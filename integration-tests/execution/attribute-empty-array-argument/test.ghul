class TAGGED: System.Attribute is
    tags: string[] public;

    init(tags: string[]) is
        self.tags = tags;
    si
si

@TAGGED([])
class A is init() is si si

@TAGGED([ ])
class B is init() is si si

@TAGGED(["x", "y"])
class C is init() is si si

show(name: string, target: System.Type) static is
    for a in target.get_custom_attributes(false) do
        if let tagged: TAGGED = a then
            IO.Std.write_line("{name}: {tagged.tags.count} tags");
        fi
    od
si

entry() static is
    show("A", typeof A);
    show("B", typeof B);
    show("C", typeof C);

    return;
si
