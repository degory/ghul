namespace Test is
    use Std = IO.Std;

    // Recursive lambda whose only argument is a union-typed value: with
    // no explicit type annotation on the argument, inference should
    // resolve it from the call site. The closure shape produces bad IL
    // today — runtime BadImageFormatException — when the argument's
    // type is left to inference.

    union List[T] is
        NIL;
        CONS(head: T, tail: List[T]);
    si

    use List.NIL;
    use List.CONS;

    list_example[T](elements: Collections.List[T]) is
        assert elements.count == 3 else "expected 3 elements";

        let list = CONS(elements[0], CONS(elements[1], CONS(elements[2], NIL())));

        let stringify_list = l rec =>
            if isa CONS(l) then
                let (head, tail) = l in
                "{head}, {rec(tail)}"
            else
                "nil"
            fi;

        Std.out.write_line(stringify_list(list));
    si

    class Main is
        entry() static is
            list_example([1, 2, 3]);
            list_example(["A", "B", "C"]);

            return;
        si
    si
si
