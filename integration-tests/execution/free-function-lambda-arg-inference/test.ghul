// Inference for a lambda argument to a free generic function.
// `generate[T, S](initial: S, generator: (S) -> (S, T))` is the
// shape; the call site supplies a (0, 1) tuple and a lambda whose
// `state` parameter the user expects to infer to `(int, int)` from
// the sibling actual. Without the inference fix the lambda's body
// walked under `state: INFERRED`, the destructure failed, references
// to the destructured names became ERROR-typed, and the resulting
// lambda type was ERROR-tainted enough that the overload resolver's
// PARTIAL binding pinned S to `(ERROR, ERROR)` rather than
// `(int, int)`. Re-specialising from CLEAN sibling actuals in the
// PARTIAL re-walk path closes the gap.

namespace Test is
    use IO.Std;

    class GENERATOR[T, S] is
        _initial: S;
        _generator: (S) -> (S, T);

        init(initial: S, generator: (S) -> (S, T)) is
            self._initial = initial;
            self._generator = generator;
        si

        first: T => let (_, t) = _generator(_initial) in t;
    si

    generate[T, S](initial: S, generator: (S) -> (S, T)) -> GENERATOR[T, S] =>
        GENERATOR[T, S](initial, generator);

    class Main is
        entry() static is
            // Fibonacci-step generator: state = (prev, current),
            // next = (current, prev + current), emit = current.
            let g = generate((0, 1), state =>
                let (prev, current) = state in
                ((current, prev + current), current));

            // First yield value is `current` from state (0, 1) = 1.
            Std.write_line("{g.first}");
            return;
        si
    si
si
