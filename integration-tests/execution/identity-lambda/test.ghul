namespace Test is
    use IO.Std;
    use Collections;

    // Tests: identity lambda `x => x` has no body
    // signal at all about x's type — the constraint must come
    // entirely from the use site. Here we pass it through
    // `apply_to(int, T -> int)` so the lambda's param resolves to
    // int via the formal-arg push.

    apply_to[T](v: T, f: T -> T) -> T => f(v);

    class Main is
        entry() static is
            let r = apply_to(42, x => x);
            Std.write_line("{r}");
            return;
        si
    si
si
