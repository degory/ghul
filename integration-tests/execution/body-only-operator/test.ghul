namespace Test is
    use IO.Std;

    // Tests: a let-bound lambda whose parameter type
    // would have to be inferred from BODY usage alone — `x * 2` —
    // because the lambda is never called from a use site that
    // could back-feed.
    //
    // We DO assign the lambda's result to a typed local in `entry`
    // to force the IL emission path. If the body emits a placeholder
    // type, ilasm will reject.

    class Main is
        entry() static is
            let f = x => x * 2;
            let g = f;
            return;
        si
    si
si
