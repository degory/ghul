// Gap #2: rec referring to an outer recursive ancestor, where the
// inner closure does the rec call. Analogous to gap #3 but the rec
// is nested. The outer lambda's parameter type narrows from the call
// site (the static type of `list` is the single variant `CONS[int]`),
// then the inner thunk calls `rec(tail)` where `tail`'s static type
// is the wide `List[int]`. The self-rec back-feed misses this because
// `current_function` at the inner call site is the non-rec thunk, not
// the outer rec lambda. Without nested-rec back-feed, the outer
// lambda's parameter stays pinned to `CONS[int]` and rec(tail) fails
// type-check.

namespace Test is
    use IO.Std;

    union List[T] is
        NIL;
        CONS(head: T, tail: List[T]);
    si

    use List.NIL;
    use List.CONS;

    class Main is
        entry() static is
            let list = CONS(1, CONS(2, CONS(3, NIL[int]())));

            // Outer is recursive; rec call is inside a thunk one level
            // deep. Outer's parameter must widen from the narrow
            // call-site type to accept `tail: List[int]`.
            let stringify_list = l rec =>
                if isa CONS(l) then
                    let (head, tail) = l in
                    "{head}, {(() => rec(tail))()}"
                else
                    "nil"
                fi;

            Std.write_line(stringify_list(list));
            return;
        si
    si
si
