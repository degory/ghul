use IO.Std.write_line;

union TRIVIA(line: int) is
    LINE_COMMENT(text: string, ..);
    LEADING_LINE_COMMENT(.., text: string);
si

entry() is
    let trailing = TRIVIA.LINE_COMMENT("hi", 7);
    let (a, b) = trailing;
    write_line(a);
    write_line(b);

    let leading = TRIVIA.LEADING_LINE_COMMENT(12, "lo");
    let (c, d) = leading;
    write_line(c);
    write_line(d);
si
