namespace Test is
    use Std = IO.Std;

    // Exercises every piece together: instance method, `self`-implicit
    // member access, a captured parameter, a body local that mutates
    // across yields, a `while` loop body.
    class COUNTER is
        base: int;

        init(base: int) is self.base = base; si

        sequence(limit: int) -> Ghul.Pipes.Pipe[int] is
            let i mut = 0;
            while i < limit do
                yield base + i;
                i = i + 1;
            od
        si
    si

    class Main is
        entry() static is
            let c = COUNTER(100);
            for v in c.sequence(3) do
                Std.write_line("v: {v}");
            od
        si
    si
si
