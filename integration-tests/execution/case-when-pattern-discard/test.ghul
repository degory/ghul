namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // discard pattern: type-test only, no binding
            describe(Cat("Felix"));
            describe(Dog("Rex"));
            describe(Animal("creature"));
            describe(null);
        si

        describe(animal: Animal?) static is
            case animal
            when null then
                Std.out.write_line("nothing");
            when _: Cat then
                Std.out.write_line("a cat");
            when _: Dog then
                Std.out.write_line("a dog");
            else
                Std.out.write_line("something else");
            esac
        si
    si

    class Animal is
        name: string;
        init(name: string) is self.name = name; si
    si

    class Cat: Animal is
        init(name: string) is super.init(name); si
    si

    class Dog: Animal is
        init(name: string) is super.init(name); si
    si
si
