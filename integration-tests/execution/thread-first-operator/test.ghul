namespace Test is
    use IO.Std;

    // Tests: the `|>` thread-first operator. `x |> f(a)` calls `f` with
    // `x` as its first argument, resolving the callee exactly as written.
    // Covers a bare callee, a chain (left-associative), an enclosing
    // method via `self`, a member method on an explicit receiver, and a
    // generic function whose type argument is inferred from the subject.

    double(x: int) -> int => x * 2;
    add(x: int, y: int) -> int => x + y;
    identity[T](t: T) -> T => t;

    class BOX is
        _v: int;
        init(v: int) is _v = v; si
        combine(a: int, b: int) -> int => _v + a + b;
    si

    class MAIN is
        _base: int;
        init() is _base = 100; si

        offset(x: int, delta: int) -> int => x + delta + _base;

        run() is
            Std.write_line("{5 |> double()}");
            Std.write_line("{5 |> add(3)}");
            Std.write_line("{5 |> double() |> add(1)}");
            Std.write_line("{5 |> offset(2)}");
            Std.write_line("{5 |> BOX(10).combine(3)}");
            Std.write_line("{42 |> identity()}");
        si

        entry() static is
            MAIN().run();
        si
    si
si
