namespace Test is
    use IO.Std;

    // Three-subclass closed hierarchy: an `if isa A / elif isa B /
    // else` chain narrows the trailing else to the last subclass.
    // Each elif eliminates one more subclass from the running set;
    // the final else fires with a singleton narrow that lets a
    // subtype-only method resolve.

    class Animal is
        init() is si
    si

    class Cat: Animal is
        init() is super.init(); si
        purr() -> string => "purr";
    si

    class Dog: Animal is
        init() is super.init(); si
        bark() -> string => "bark";
    si

    class Hamster: Animal is
        init() is super.init(); si
        squeak() -> string => "squeak";
    si

    class Main is
        entry() static is
            describe(Cat());
            describe(Dog());
            describe(Hamster());
        si

        describe(a: Animal) static is
            if isa Cat(a) then
                Std.out.write_line(a.purr());
            elif isa Dog(a) then
                Std.out.write_line(a.bark());
            else
                Std.out.write_line(a.squeak());
            fi
        si
    si
si
