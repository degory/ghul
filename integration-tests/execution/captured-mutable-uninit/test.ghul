namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Captured mutable without initializer. The slot is
            // promoted to `Ghul.BOX[int]`; allocation at the
            // declaration is what lets the closure and the outer
            // scope share one cell.
            let x: int mut;

            let read_x = () -> int => x;

            x = 42;

            Std.write_line("read_x() = {read_x()}");
            Std.write_line("x        = {x}");
        si
    si
si
