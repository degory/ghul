namespace Test is
    use Std = IO.Std;

    class Main is
        // Named async + lambda capturing the await result (Case 4)
        compute() -> Tasks.TASK[int] static is
            let x = await Tasks.TASK.from_result(10);
            let f = () => x + 1;
            return f() + f();
        si

        entry() static is
            let r = compute();
            Std.write_line("got={r.result}");
        si
    si
si
