namespace Test is
    use IO.Std;

    // Tests: lambda body has a chained member access
    // on a placeholder parameter: `s.length.to_string()`. The
    // first `.length` triggers MEMBER_CONSTRAINT("length") on s's
    // origin. The chained `.to_string()` triggers MEMBER_CONSTRAINT
    // ("to_string") on whatever `s.length` evaluated to — which
    // is itself a placeholder. Does the chain propagate?

    class Main is
        entry() static is
            let f = s => s.length.to_string();
            Std.write_line(f("hello"));
            return;
        si
    si
si
