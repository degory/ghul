namespace Test is
    use Std = IO.Std;

    class Main is
        // Async function whose body's tail expression is a val-block.
        // The val-block contains returns targeting it; the surrounding
        // await happens before the val-block runs, the val-block's
        // body has no suspend point itself.
        async_with_val_returns(n: int) -> Tasks.TASK[int] static is
            let x = await Tasks.TASK.from_result(n);

            let result = val
                if x < 0 then
                    return 0;
                fi
                x * 2
            lav;

            return result + 1;
        si

        // Async function with an `await` INSIDE the val-block body.
        // The val-block's BLOCK-with-suspend spill (pre(VAL_BLOCK)
        // in generate-il) emits the body inline in the outer
        // MoveNext stream and stashes the val-block's result into a
        // frame field, so the consumer's `let pinned = ...` sees a
        // clean ldfld with no replayed `leave` across its receiver.
        async_await_inside_val(n: int) -> Tasks.TASK[int] static is
            let pinned = val
                let y = await Tasks.TASK.from_result(n);
                if y > 100 then
                    return 999;
                fi
                y + 10
            lav;

            return pinned;
        si

        // Generator (returns Pipe[int]) whose val-block does not
        // itself contain a yield. The val-block runs entirely within
        // one MoveNext invocation between surrounding yields.
        generator_with_val() -> Ghul.Pipes.Pipe[int] static is
            yield 1;

            let computed = val
                if true then
                    return 42;
                fi
                99
            lav;

            yield computed;
            yield 3;
        si

        // Generator with a `yield` INSIDE the val-block body. The
        // val-block's BLOCK spill emits the body (including the
        // yield's state-stamp + ret) inline in MoveNext, and the
        // val-block's result lands in a frame field — so the
        // consumer's `let computed = ...` sees a ldfld and the
        // state lost across the yield's MoveNext re-entry never
        // included a pending receiver.
        generator_yield_inside_val() -> Ghul.Pipes.Pipe[int] static is
            let computed = val
                yield 7;
                yield 8;
                if false then
                    return 99;
                fi
                42
            lav;

            yield computed;
        si

        entry() static is
            Std.write_line("async_with_val_returns(5).result = {Main.async_with_val_returns(5).result}");
            Std.write_line("async_with_val_returns(-3).result = {Main.async_with_val_returns(-3).result}");
            Std.write_line("async_await_inside_val(5).result = {Main.async_await_inside_val(5).result}");

            for v in Main.generator_with_val() do
                Std.write_line("yielded {v}");
            od

            for v in Main.generator_yield_inside_val() do
                Std.write_line("y_in_val {v}");
            od
        si
    si
si
