namespace Test is
    use Std = IO.Std;

    class INNER is
        label: string public;
        init(label: string) is self.label = label; si
    si

    class HOLDER is
        inner: INNER? public;
        init(inner: INNER?) is self.inner = inner; si
    si

    class Main is
        entry() static is
            show(HOLDER(INNER("present")));
            show(HOLDER(null));
            guarded(HOLDER(INNER("keep")));
            guarded(HOLDER(INNER("drop")));
        si

        // Bare-path shorthand: no `?`, no `: T`, no `=`. Binds a local
        // named after the path's leaf (`inner`) to the narrowed value;
        // refutable because `h.inner` is optional, exactly as the full
        // form `if let inner = h.inner` would be.
        show(h: HOLDER) static is
            if let h.inner then
                Std.out.write_line("present: {inner.label}");
            else
                Std.out.write_line("absent");
            fi
        si

        // Bare path carrying a guard: the leftmost leaf is the scrutinee,
        // the `/\` tail is the guard evaluated once `inner` is in scope.
        guarded(h: HOLDER) static is
            if let h.inner /\ inner.label =~ "keep" then
                Std.out.write_line("kept: {inner.label}");
            else
                Std.out.write_line("skipped");
            fi
        si
    si
si
