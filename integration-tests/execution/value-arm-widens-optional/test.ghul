namespace Test is
    use Std = IO.Std;

    // Expected-type widening: a bare value-type arm flows into an
    // int? result and must wrap as Nullable[int], not stay a bare int.
    pick(f: bool, a: int) -> int? => if f then a else null fi;

    // Value-type arm boxed into a wider object result.
    boxed(f: bool) -> object => if f then 123 else 456 fi;

    // Case-arm analogue.
    classify(n: int) -> int? =>
        case n
        when 0 then null;
        when 1 then 100;
        else 999;
        esac;

    class MAIN is
        entry() static is
            Std.out.write_line("pick true: {pick(true, 7)}");
            Std.out.write_line("pick false present: {pick(false, 7)?}");
            Std.out.write_line("boxed: {boxed(true)}");
            Std.out.write_line("classify 1: {classify(1)}");
            Std.out.write_line("classify 2: {classify(2)}");
            Std.out.write_line("classify 0 present: {classify(0)?}");

            // No expected type: the joined type is inferred, and a null
            // arm must widen the value-type LUB to its optional form.
            let inferred = if true then 55 else null fi;
            Std.out.write_line("inferred: {inferred}");

            let inferred_case = case 1 when 0 then null; else 42; esac;
            Std.out.write_line("inferred case: {inferred_case}");
        si
    si
si
