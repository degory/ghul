namespace Test is
    // Tests: a `|>` whose right-hand side is a constructor call is
    // rejected. Construction resolves through a path that takes no
    // subject, so threading one in would silently drop it; the compiler
    // reports an error instead.

    class BOX is
        _v: int;
        init(v: int) is _v = v; si
    si

    class MAIN is
        entry() static is
            let b = 5 |> BOX(10);
        si
    si
si
