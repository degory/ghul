namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let a = 1;
            let b = 2;
            let c = 3;

            let abc = (a, b, c);
            Std.out.write_line("a={abc.a} b={abc.b} c={abc.c}");

            let mixed = (a, 10 + 20);
            Std.out.write_line("mixed a={mixed.a} positional={mixed.`1}");
            return;
        si
    si
si
