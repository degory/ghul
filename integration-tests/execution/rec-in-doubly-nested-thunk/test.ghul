use IO.Std.write_line;

entry() is
    // `rec` referenced two closures deep, threaded through an
    // intermediate non-recursive lambda. Exercises the chain-capture:
    // both the immediate thunk and the wrapper between it and the
    // recursive outer need their own `$outer_recurse_<outer>` field.
    let sum = (n: int) -> int rec =>
        if n <= 0 then
            0
        else
            n + (() => (() => rec(n - 1))())()
        fi;

    write_line("sum(0) is {sum(0)}");
    write_line("sum(1) is {sum(1)}");
    write_line("sum(5) is {sum(5)}");
si
