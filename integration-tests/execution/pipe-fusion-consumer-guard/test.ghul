namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A user Pipe whose map override ignores the mapper and yields its raw
    // values.
    class WEIRD_PIPE: Pipe[int] is
        _values: LIST[int];
        _index: int;

        init(values: LIST[int]) is
            _values = values;
            _index = -1;
        si

        iterator: Iterator[int] => self;
        current: int => _values[_index];

        move_next() -> bool is
            _index = _index + 1;
            return _index < _values.count;
        si

        reset() is
            _index = -1;
        si

        dispose() is
        si

        map[U](mapper: (int) -> U pure) -> Pipe[U] pure => cast Pipe[U](self);
    si

    class Main is
        entry() static is
            // Statically Iterable[int] (so a consumer over it is fused
            // behind the runtime guard), dynamically a WEIRD_PIPE. The guard
            // must fall back and honour the override: map is ignored, so the
            // raw value 3 is found, not the mapped 300.
            let weird: Iterable[int] = WEIRD_PIPE(LIST[int]([1, 2, 3, 4]));
            let f = pipe(weird).map(n => n * 100).find(n => n == 3);
            Std.write_line("guarded find: {if f? then f! else -1 fi}");

            // @suppress opts a scope out of fusion, so the real Pipe
            // implementation runs.
            let xs = LIST[int]([1, 2, 3, 4]);

            @suppress("pipe-fusion")
            let n = pipe(xs).filter(x => x > 1).count();
            Std.write_line("suppressed count: {n}");
        si
    si
si
