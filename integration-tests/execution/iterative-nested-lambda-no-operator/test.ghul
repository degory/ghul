namespace Test is
    use IO.Std;
    use Collections;

    // Iterative-inference regression: companion to
    // iterative-nested-lambda-operator. The same captured-field
    // stale-type bug, but with a normal method call (`t.match(u)`)
    // instead of a binary operator on the captured `t`. Without the
    // fix, frame ctor IL was emitted with the placeholder type for
    // the captured field, producing an internal-compiler-error during
    // GENERATE_IL ("not implemented by Semantic.Types.ERROR" in
    // Type.gen_type) rather than the operator-not-found message.
    class Wrapper is
        value: int;
        init(value: int) is
            super.init();
            self.value = value;
        si
        match(other: Wrapper) -> bool => self.value == other.value;
    si

    class Main is
        entry() static is
            let xs = LIST[Wrapper]();
            xs.add(Wrapper(1));
            xs.add(Wrapper(2));
            let ys = LIST[Wrapper]();
            ys.add(Wrapper(2));

            let result = xs | .filter(t => ys | .any(u => t.match(u))) .collect_list();
            Std.write_line(result.count.to_string());
            return;
        si
    si
si
