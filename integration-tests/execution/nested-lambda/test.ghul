namespace Test is
    use IO.Std;

    // Tests: a lambda whose body itself is a lambda
    // (curried form). The outer lambda's param is inferred from
    // use, and so is the inner lambda's. Both need to converge.

    class Main is
        entry() static is
            let curried_add = a => b => a + b;
            let add_5 = curried_add(5);
            Std.write_line("{add_5(3)}");
            return;
        si
    si
si
