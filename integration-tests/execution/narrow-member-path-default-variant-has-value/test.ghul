// `x?` on a path where the receiver is a union with a default variant
// narrows the path itself on BOTH edges: the true edge to the default
// variant (so its unique fields resolve on subsequent reads), the false
// edge to the complement (so the sibling variant's fields resolve).

use Std = IO.Std;

union RESULT is
    OK(value: int) default;
    ERR(msg: string);
si

class BOX is
    result: RESULT public;
    init(r: RESULT) is
        result = r;
    si
si

describe_isa(b: BOX) is
    if isa RESULT.OK(b.result) then
        Std.write_line("ok isa: {b.result.value}");
    else
        Std.write_line("err isa: {b.result.msg}");
    fi
si

describe_has_value(b: BOX) is
    if b.result? then
        Std.write_line("ok ?: {b.result.value}");
    else
        Std.write_line("err ?: {b.result.msg}");
    fi
si

entry() is
    describe_isa(BOX(RESULT.OK(42)));
    describe_isa(BOX(RESULT.ERR("nope")));

    describe_has_value(BOX(RESULT.OK(7)));
    describe_has_value(BOX(RESULT.ERR("bad")));
si
