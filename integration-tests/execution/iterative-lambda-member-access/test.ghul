namespace Test is
    use IO.Std;

    // Iterative-inference probe 2: placeholder receiver of member
    // access. The lambda's argument `x` has no annotation and no
    // call-site formal context. The body `x.length` accesses a
    // member on `x`. For this to converge, the member-resolution
    // path needs to either (a) succeed with a placeholder receiver
    // (unlikely — member lookup needs concrete-typed receivers) or
    // (b) the call site `g("hello")` needs to push string in via
    // a constraint-pushback path that today's overload-resolver
    // back-feed doesn't cover (function-typed call branch, not
    // OVERLOAD_RESOLVER).
    class Main is
        entry() static is
            let g = x => x.length;
            let result = g("hello");
            Std.write_line("{result}");
            return;
        si
    si
si
