namespace Test is
    use IO.Std;

    // Placeholder receiver of member access in a lambda body. The
    // lambda's argument `x` has no annotation and no call-site
    // formal context — `x.length` accesses a member on x. For this
    // to converge, the call site `g("hello")` pushes string onto
    // x's origin through the closure-call back-feed path; the body
    // retry then re-walks `x.length` with x: string, which resolves
    // member access against the concrete type.
    class Main is
        entry() static is
            let g = x => x.length;
            let result = g("hello");
            Std.write_line("{result}");
            return;
        si
    si
si
