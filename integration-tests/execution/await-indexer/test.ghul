namespace Test is
    use Std = IO.Std;
    class Main is
        get_index() -> Tasks.TASK[int] static => Tasks.TASK.from_result(2);

        compute() -> Tasks.TASK[int] static is
            let arr = [10, 20, 30];
            let x = arr[await get_index()];
            return x;
        si

        entry() static is
            Std.write_line("got={compute().result}");
        si
    si
si
