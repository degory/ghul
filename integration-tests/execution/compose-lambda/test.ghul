namespace Test is
    use IO.Std;
    use Collections;

    // Function composition: the compose body's lambda
    // `x => g(f(x))` infers x's type as A — the outer function's
    // first type parameter, surfaced as the first argument of the
    // Function-typed return.
    //
    // Mechanism (compile_expressions.ghul + closure.ghul):
    //   - `pre(expression: EXPRESSION)` propagates compose's
    //     return type `(A) -> C` onto the body lambda's
    //     `constraint`.
    //   - The lambda's args-resolution sees implied_argument_type
    //     = A and accepts type-variable implied types.
    //   - The implied arg type is walked for type-variables and
    //     each is recorded via `closure.add_type_argument_
    //     reference` so IL emission generates a generic closure
    //     method with a matching `!!N` slot.
    //
    // Sibling to box-factory (same mechanism).
    //
    // Note: explicit `[int,int,int]` type args are needed at the
    // compose call site — the inner lambdas (`p => p+1`, `q => q*10`)
    // would need their own arg-type inference from the call site's
    // formal Function types AND from body-internal operator
    // constraints to bind A, B, C. Only the latter currently fires
    // (`+ 1` pushes int onto p's origin); call-site Function-formal
    // back-feed into compose's type-arg binding from a chained
    // lambda placeholder arg is an open inference gap.

    compose[A,B,C](f: (A) -> B, g: (B) -> C) -> (A) -> C =>
        x => g(f(x));

    class Main is
        entry() static is
            let h = compose[int,int,int](p => p + 1, q => q * 10);
            Std.write_line("{h(5)}");
            return;
        si
    si
si
