namespace Test is
    use Std = IO.Std;

    class Main is
        // try/catch with await OUTSIDE, return inside
        compute() -> Tasks.TASK[string] static is
            let x = await Tasks.TASK.from_result(42);
            try
                if x > 10 then
                    throw System.Exception("too big");
                fi
                return "ok={x}";
            catch e: System.Exception
                return "caught={e.message}";
            yrt
        si

        entry() static is
            let r = compute();
            Std.write_line("got={r.result}");
        si
    si
si
