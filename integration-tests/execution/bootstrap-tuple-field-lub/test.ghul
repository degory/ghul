namespace Test is
    use IO.Std;
    use Collections;

    // Bootstrap-blocker repro: two sites push constraints onto the
    // same LIST() instance with structurally-equivalent named-tuple
    // element types but *different field names*. The first push
    // matches the declared formal (`xs`); the second comes via the
    // `helper` call's formal `Iterable[(name: string, value: int)]`.
    // Both are positionally identical to the local declaration's
    // `(label: string, count: int)` shape, but with different names.
    //
    // After body-retry inference picks an element type for LIST(),
    // it has to be consistent with the local declaration's named
    // tuple — otherwise `x.label` / `x.count` lookups error with
    // "member not found".
    //
    // This is fragile against constraint-ordering changes in the
    // LUB: if two formals push tuple shapes with the same positional
    // types but different field names, the LUB can tip toward
    // whichever push lands first. The robust shape is to align
    // field names across both formals so the LUB has only one
    // candidate. This test guards against regressions of the same
    // shape — covers a real compiler-source pattern that's hard
    // to reach through synthetic tests.

    // Three constraint sources push different shapes onto the same
    // LIST() placeholder:
    //   - inner_add's formal `(label: string, count: int)`
    //   - check's formal       `(name:  string, value: int)`
    //   - the local for-loop's body accesses `x.label` / `x.count`
    // The use-site access pins the shape that has to win. The same
    // pattern appears in `src/semantic/dotnet/symbol_factory.ghul`
    // where `methods` is passed through two formals with different
    // field names, then iterated with `.symbol` access. A LUB
    // tie-break that picks the wrong shape breaks the bootstrap.

    inner_add(xs: LIST[(label: string, count: int)]) is
        xs.add(("two", 2));
    si

    check(items: Iterable[(name: string, value: int)]) is
        for it in items do
            Std.write_line("via check: {it.name} = {it.value}");
        od
    si

    class Main is
        consume(xs: LIST[(label: string, count: int)]) static is
            inner_add(xs);
            check(xs);

            for x in xs do
                Std.write_line("via consume: {x.label} = {x.count}");
            od
        si

        entry() static is
            let xs = LIST();
            xs.add(("one", 1));

            consume(xs);
            return;
        si
    si
si
