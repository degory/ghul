
namespace Test is
    use Std = IO.Std;

    class Main is
        // The canonical fibs case. The while-body has a yield, so
        // DESUGAR_YIELD allocates a header state (checks `a < limit`),
        // a body state (yields a and advances a/b/tmp), and an exit
        // state. The state machine pumps through header → body →
        // header → … until the condition flips false, then exits.
        fibs(limit: int) -> Collections.Iterable[int] static is
            let a mut = 0;
            let b mut = 1;
            let tmp mut = 0;
            while a < limit do
                yield a;
                tmp = a + b;
                a = b;
                b = tmp;
            od
        si

        entry() static is
            let total mut = 0;
            for x in fibs(100) do
                total = total + x;
            od
            Std.write_line("total={total}");
        si
    si
si
