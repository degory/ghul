namespace Ghul.Generators is
    enum _GEN_STEP_KIND is
        DONE,
        YIELD,
        TRANSITION,
    si

    struct _GEN_STEP[T] is
        kind: _GEN_STEP_KIND;
        value: T;
        next_state: int;

        init() is si

        init(kind: _GEN_STEP_KIND, value: T, next_state: int) is
            self.kind = kind;
            self.value = value;
            self.next_state = next_state;
        si
    si

    class _GEN_DRIVER[T]: Collections.Iterable[T], Collections.Iterator[T] is
        _states: Collections.List[() -> _GEN_STEP[T]];
        _state_index: int;
        _current: T;
        _done: bool;

        init(states: Collections.List[() -> _GEN_STEP[T]]) is
            _states = states;
            _state_index = 0;
            _done = false;
        si

        iterator: Collections.Iterator[T] => self;
        current: T => _current;

        move_next() -> bool is
            if _done then return false; fi
            while true do
                let step = _states[_state_index]();
                if step.kind == _GEN_STEP_KIND.DONE then
                    _done = true;
                    return false;
                elif step.kind == _GEN_STEP_KIND.YIELD then
                    _current = step.value;
                    _state_index = step.next_state;
                    return true;
                else
                    _state_index = step.next_state;
                fi
            od
            return false;
        si

        reset() is
            _state_index = 0;
            _done = false;
        si

        dispose() is si
    si

    _gen_pipe[T](states: Collections.List[() -> _GEN_STEP[T]])
        -> Collections.Iterable[T]
    =>
        _GEN_DRIVER[T](states);
si

namespace Test is
    use Std = IO.Std;

    class Main is
        // The canonical fibs case. The while-body has a yield, so
        // DESUGAR_YIELD allocates a header state (checks `a < limit`),
        // a body state (yields a and advances a/b/tmp), and an exit
        // state. The state machine pumps through header → body →
        // header → … until the condition flips false, then exits.
        fibs(limit: int) -> Collections.Iterable[int] static is
            let a mut = 0;
            let b mut = 1;
            let tmp mut = 0;
            while a < limit do
                yield a;
                tmp = a + b;
                a = b;
                b = tmp;
            od
        si

        entry() static is
            let total mut = 0;
            for x in fibs(100) do
                total = total + x;
            od
            Std.write_line("total={total}");
        si
    si
si
