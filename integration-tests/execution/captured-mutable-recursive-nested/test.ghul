namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Recursive closure nested inside a non-recursive
            // closure, all sharing one captured cell. The
            // recursive `bump` is constructed once per outer()
            // call; each recursive descent reads/writes the
            // same `total` box that entry, outer, and bump
            // all see.
            let total mut = 0;

            let outer = (start: int) is
                let bump = (n: int) -> void rec is
                    if n <= 0 then
                        return;
                    fi
                    total = total + start;
                    rec(n - 1);
                si;

                bump(3);
            si;

            outer(1);
            outer(10);

            Std.write_line("total = {total}");
        si
    si
si
