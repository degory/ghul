namespace Test is
    use IO.Std;
    use Collections;

    // Tests: array literal whose elements have a
    // common ancestor (CAT <: ANIMAL, DOG <: ANIMAL). Compiler
    // should LUB the element types to `ANIMAL` and let the
    // resulting `ANIMAL[]` flow into an `Iterable[ANIMAL]`
    // formal via array covariance.
    //
    // Pinned because the LUB-on-element-types path interacts
    // with the array-literal type-resolution rules, and a
    // regression that defaulted to the leftmost element type
    // would break this without errors elsewhere.

    class ANIMAL is
        init() is si
        speak() is Std.write_line("generic"); si
    si

    class CAT: ANIMAL is
        init() is super.init(); si
        speak() is Std.write_line("meow"); si
    si

    class DOG: ANIMAL is
        init() is super.init(); si
        speak() is Std.write_line("woof"); si
    si

    each(xs: Iterable[ANIMAL]) is
        for a in xs do a.speak(); od
    si

    class Main is
        entry() static is
            each([CAT(), DOG()]);
            return;
        si
    si
si
