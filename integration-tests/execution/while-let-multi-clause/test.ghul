namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            test_both_required();
            test_second_clause_chains_first();
        si

        // Multi-clause `while let x = a, y = b`: every clause's
        // test must succeed for the body to fire.
        test_both_required() static is
            let xs = QUEUE(); xs.push("a"); xs.push("b");
            let ys = QUEUE(); ys.push("X");

            while let x = xs.pop(), y = ys.pop() do
                Std.out.write_line("01-pair: {x}/{y}");
            od
            Std.out.write_line("01-done");
        si

        // Second clause's scrutinee can refer to the first clause's
        // bound name — chained binding.
        test_second_clause_chains_first() static is
            let q = NESTED_QUEUE();
            q.push(QUEUE.of("inner-a", "inner-b"));
            q.push(QUEUE.of("inner-c"));

            while let inner = q.pop(), item = inner.pop() do
                Std.out.write_line("02-item: {item}");
            od
            Std.out.write_line("02-done");
        si
    si

    class QUEUE is
        _items: Collections.LIST[string];

        init() is _items = Collections.LIST[string](); si

        of(a: string) -> QUEUE static is
            let q = QUEUE();
            q.push(a);
            return q;
        si

        of(a: string, b: string) -> QUEUE static is
            let q = QUEUE();
            q.push(a);
            q.push(b);
            return q;
        si

        push(s: string) is _items.add(s); si

        pop() -> string? is
            if _items.count == 0 then
                return null;
            fi
            let result = _items[0];
            _items.remove_at(0);
            return result;
        si
    si

    class NESTED_QUEUE is
        _items: Collections.LIST[QUEUE];

        init() is _items = Collections.LIST[QUEUE](); si

        push(q: QUEUE) is _items.add(q); si

        pop() -> QUEUE? is
            if _items.count == 0 then
                return null;
            fi
            let result = _items[0];
            _items.remove_at(0);
            return result;
        si
    si
si
