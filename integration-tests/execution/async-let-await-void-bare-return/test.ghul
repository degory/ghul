namespace Test is
    use Std = IO.Std;

    class Main is
        // Bare `return;` inside a void async lambda — gets
        // rewritten to `return Tasks.TASK.completed_task;` by
        // compile_bindings.visit_return so the chain terminates
        // with a completed Task rather than a default-null Task
        // reference. Mixing with `let await` ensures the synthesised
        // continuation lambdas are involved.
        entry() static is
            let f = (n: int) is
                if n < 0 then
                    Std.write_line("negative; bailing");
                    return;
                fi
                let await x = Tasks.TASK.from_result(n * 2);
                Std.write_line("doubled = {x}");
            si;

            f(-1).wait();
            f(5).wait();

            Std.write_line("done");
        si
    si
si
