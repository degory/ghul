namespace Test is
    use Std = IO.Std;

    class REF is
        init() is si
    si

    struct VAL is
        n: int;
    si

    // `default` of an unconstrained class type parameter.
    class HOLDER[T] is
        make() -> T static => default;
        make_explicit() -> T static => default[T];
    si

    // `default` under a `class` constraint — the value is null.
    first_of[T: class]() -> T static => default;

    // `default` under a `struct` constraint — the value is zeroed.
    count_of[T: struct]() -> T static => default;

    class Main is
        entry() static is
            let r = HOLDER[REF].make();
            Std.out.write_line("HOLDER[REF].make() is null: {!r?}");

            let v = HOLDER[VAL].make_explicit();
            Std.out.write_line("HOLDER[VAL].make_explicit().n: {v.n}");

            let cr = first_of[REF]();
            Std.out.write_line("first_of[REF]() is null: {!cr?}");

            let cv = count_of[int]();
            Std.out.write_line("count_of[int](): {cv}");
        si
    si
si
