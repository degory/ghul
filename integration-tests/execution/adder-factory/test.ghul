namespace Test is
    use IO.Std;

    // Tests: a function that returns a closure
    // capturing its argument. The closure's parameter type is
    // inferred from body usage; the factory's parameter type
    // from how the closure is later used.

    make_adder(n: int) -> int -> int =>
        x => x + n;

    class Main is
        entry() static is
            let add_3 = make_adder(3);
            Std.write_line("{add_3(10)}");
            Std.write_line("{add_3(20)}");
            return;
        si
    si
si
