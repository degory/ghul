namespace Test is
    use Std = IO.Std;

    // Tests: a `|>` subject survives an await in a later argument. The
    // subject is threaded in as the first actual and evaluated before
    // the await, so it must be spilled across the suspension.

    combine(a: int, b: int) -> int => a + b;

    class MAIN is
        run(x: int) -> Tasks.TASK[int] static is
            let r = (x + 100) |> combine(await Tasks.TASK.from_result(10));
            return r;
        si

        entry() static is
            Std.write_line("{run(5).result}");
        si
    si
si
