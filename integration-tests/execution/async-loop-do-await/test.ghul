namespace Test is
    use Std = IO.Std;

    // Phase 1 — do-await: DO_DRIVER. Same shape as WHILE_DRIVER but
    // the body runs once before the condition is evaluated. Key
    // behavioural difference: body fires at least once even if the
    // condition is false initially.
    //
    // Hand-desugared form of:
    //     do
    //         let await x = step_async();
    //         count = count + 1;
    //     while count < 3 od

    enum LOOP_RESULT_TYPE is CONTINUE, BREAK, RETURN si

    struct LOOP_RESULT[T] is
        type: LOOP_RESULT_TYPE;
        value: T;

        init() is si

        init(type: LOOP_RESULT_TYPE, value: T) is
            self.type = type;
            self.value = value;
        si
    si

    class DO_DRIVER[T_ret] is
        _body: () -> Tasks.TASK[LOOP_RESULT[T_ret]];
        _condition: () -> Tasks.TASK[bool];
        _tcs: Tasks.TaskCompletionSource[LOOP_RESULT[T_ret]];
        _on_body_complete: (Tasks.TASK[LOOP_RESULT[T_ret]]) -> void;
        _on_condition_complete: (Tasks.TASK[bool]) -> void;

        init(
            body: () -> Tasks.TASK[LOOP_RESULT[T_ret]],
            condition: () -> Tasks.TASK[bool]
        ) is
            _body = body;
            _condition = condition;
            _tcs = Tasks.TaskCompletionSource[LOOP_RESULT[T_ret]]();
            _on_body_complete = t => on_body_complete(t);
            _on_condition_complete = t => on_condition_complete(t);
        si

        start() -> Tasks.TASK[LOOP_RESULT[T_ret]] is
            pump();
            return _tcs.task;
        si

        // Body first, then condition.
        pump() is
            try
                while true do
                    let body_task = _body();
                    if !body_task.is_completed then
                        body_task.continue_with(_on_body_complete);
                        return;
                    fi
                    if handle_body(body_task) then return; fi
                    // Body completed CONTINUE — check condition.
                    let cond_task = _condition();
                    if !cond_task.is_completed then
                        cond_task.continue_with(_on_condition_complete);
                        return;
                    fi
                    if handle_condition(cond_task) then return; fi
                od
            catch ex: System.Exception
                _tcs.set_exception(ex);
            yrt
        si

        on_body_complete(t: Tasks.TASK[LOOP_RESULT[T_ret]]) is
            if handle_body(t) then return; fi
            let cond_task = _condition();
            if !cond_task.is_completed then
                cond_task.continue_with(_on_condition_complete);
                return;
            fi
            if handle_condition(cond_task) then return; fi
            pump();
        si

        on_condition_complete(t: Tasks.TASK[bool]) is
            if handle_condition(t) then return; fi
            pump();
        si

        handle_body(t: Tasks.TASK[LOOP_RESULT[T_ret]]) -> bool is
            if t.is_faulted then
                _tcs.set_exception(t.exception);
                return true;
            fi
            let r = t.result;
            if r.type == LOOP_RESULT_TYPE.RETURN \/ r.type == LOOP_RESULT_TYPE.BREAK then
                _tcs.set_result(r);
                return true;
            fi
            return false;
        si

        handle_condition(t: Tasks.TASK[bool]) -> bool is
            if t.is_faulted then
                _tcs.set_exception(t.exception);
                return true;
            fi
            if !t.result then
                _tcs.set_result(LOOP_RESULT[T_ret]());
                return true;
            fi
            return false;
        si
    si

    class COUNTER is
        count: int;
        init() is count = 0; si
        bump() is count = count + 1; si
    si

    class Main is
        step_async() -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => 1
            );

        entry() static is
            // Case A: condition stops after a few iterations.
            let counter1 = COUNTER();
            let driver1 = DO_DRIVER[int](
                () is
                    let await x = step_async();
                    counter1.bump();
                    Std.write_line("A.body: count_now={counter1.count} step_returned={x}");
                    return LOOP_RESULT[int]();
                si,
                () => Tasks.TASK.from_result(counter1.count < 3)
            );
            let r1 = driver1.start().result;
            Std.write_line("A.final.type={r1.type} count={counter1.count}");

            // Case B: condition is false from the start — body must
            // still fire exactly once. This is the do/while contract
            // that distinguishes it from while.
            let counter2 = COUNTER();
            let driver2 = DO_DRIVER[int](
                () is
                    let await x = step_async();
                    counter2.bump();
                    Std.write_line("B.body: count_now={counter2.count} step_returned={x}");
                    return LOOP_RESULT[int]();
                si,
                () => Tasks.TASK.from_result(false)
            );
            let r2 = driver2.start().result;
            Std.write_line("B.final.type={r2.type} count={counter2.count}");
        si
    si
si
