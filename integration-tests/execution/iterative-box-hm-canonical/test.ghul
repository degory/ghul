namespace Test is
    use IO.Std;

    //     let m = Box();   // m: Box[?] — owner generic arg unbound
    //     m.set(42);       // pins ? = int
    //     let x = m.get(); // reads x as int
    class Box[T] is
        _value: T;

        init() is
        si

        set(value: T) is
            _value = value;
        si

        get() -> T => _value;
    si

    class Main is
        entry() static is
            let m = Box();
            m.set(42);
            let x = m.get();
            Std.write_line("{x}");
            return;
        si
    si
si
