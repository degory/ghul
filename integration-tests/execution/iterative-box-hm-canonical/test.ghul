namespace Test is
    use IO.Std;

    // Iterative-inference probe: the Hindley-Milner canonical case.
    //
    //     let m = Box();   // m: Box[?] — owner generic arg unbound
    //     m.set(42);       // pins ? = int
    //     let x = m.get(); // reads x as int
    //
    // Box's owner generic arg is a *structural* placeholder (a
    // type-arg slot on a type symbol), not a Symbol-bound variable
    // placeholder. Today's INFERRED_VARIABLE_TYPE only carries
    // origin: Symbols.Variable, so it doesn't model this case.
    // For this to converge, the placeholder mechanism would need
    // to extend to constructor-instantiation type-args, with origin
    // pointing at the constructor expression's AST node (or some
    // similar identity carrier).
    class Box[T] is
        _value: T;

        init() is
        si

        set(value: T) is
            _value = value;
        si

        get() -> T => _value;
    si

    class Main is
        entry() static is
            let m = Box();
            m.set(42);
            let x = m.get();
            Std.write_line("{x}");
            return;
        si
    si
si
