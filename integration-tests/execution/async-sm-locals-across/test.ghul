namespace Test is
    use Std = IO.Std;

    class Main is
        // Locals across awaits
        compute() -> Tasks.TASK[int] static is
            let total mut = 0;
            let a = await Tasks.TASK.from_result(10);
            total = total + a;
            let b = await Tasks.TASK.from_result(20);
            total = total + b;
            let c = await Tasks.TASK.from_result(30);
            total = total + c;
            return total;
        si

        entry() static is
            let r = compute();
            Std.write_line("total={r.result}");
        si
    si
si
