namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // `System.Tuple` is a reflected name shared across arities:
            // the non-generic static `Tuple` class plus `Tuple\`1`..`\`8`.
            // It imports as a TYPE_GROUP. Accessing a static member off
            // the bare name in expression position must collapse the
            // group to the no-arguments member rather than producing a
            // Load.SYMBOL of the group (which is not a typed value).
            let pair = System.Tuple.create(10, 20);
            Std.write_line("{pair.item1} {pair.item2}");

            let single = System.Tuple.create("solo");
            Std.write_line(single.item1);

            return;
        si
    si
si
