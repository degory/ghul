namespace Test is
    use Std = IO.Std;

    struct POINT is
        x: int public;
        y: int public;

        init(x: int, y: int) is
            self.x = x;
            self.y = y;
        si
    si

    class Main is
        entry() static is
            let p = POINT(1, 2);
            replace(p ref);
            Std.out.write_line("({p.x}, {p.y})");
        si

        replace(target: POINT ref) static is
            target! = POINT(10, 20);
        si
    si
si
