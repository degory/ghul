namespace Test is
    use Std = IO.Std;

    class Main is
        compute() -> Tasks.TASK[int] static is
            let i mut = 0;
            let total mut = 0;
            while i < 5 do
                let x = await Tasks.TASK.from_result(i * 10);
                total = total + x;
                i = i + 1;
            od
            return total;
        si

        entry() static is
            let r = compute();
            Std.write_line("total={r.result}");
        si
    si
si
