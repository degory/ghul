namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A `for` over a pipe chain containing `take`/`skip` stages is lowered
    // to one inline loop over the source's own iterator: `take` becomes a
    // running counter that exits the loop once exhausted, `skip` a counter
    // that drops the leading elements, and neither builds a TAKE_PIPE /
    // SKIP_PIPE object. This pins the observable behaviour - the fused and
    // unfused lowerings must produce identical results - across source
    // kinds (sealed value-type range, array, guarded collection) and every
    // stage ordering relative to map/filter.

    class Main is
        entry() static is
            // --- range source (sealed value type: unconditional fuse) ---
            for x in (0..10) | .take(3) do
                Std.write_line("take: {x}");
            od

            for x in (0..10) | .skip(7) do
                Std.write_line("skip: {x}");
            od

            // filter before take: take counts the filtered elements.
            for x in (0..10) | .filter(n => n % 2 == 0).take(2) do
                Std.write_line("filter-take: {x}");
            od

            // take before filter: filter selects among the taken elements.
            for x in (0..10) | .take(4).filter(n => n % 2 == 1) do
                Std.write_line("take-filter: {x}");
            od

            // map after take.
            for x in (0..10) | .take(3).map(n => n * 100) do
                Std.write_line("take-map: {x}");
            od

            // skip then take: drop 2, keep next 3.
            for x in (0..10) | .skip(2).take(3) do
                Std.write_line("skip-take: {x}");
            od

            // take then skip: keep first 5, then drop 2 of those.
            for x in (0..10) | .take(5).skip(2) do
                Std.write_line("take-skip: {x}");
            od

            // --- edge cases ---
            for x in (0..10) | .take(0) do
                Std.write_line("take0: {x}");
            od

            for x in (0..3) | .skip(10) do
                Std.write_line("skip-past: {x}");
            od

            for x in (0..3) | .take(10) do
                Std.write_line("take-past: {x}");
            od

            // --- array source (sealed: unconditional fuse) ---
            let xs = [5, 4, 3, 2, 1];
            for x in xs | .skip(1).take(2) do
                Std.write_line("array: {x}");
            od

            // --- guarded collection source (LIST: fused behind isa guard) ---
            let ys = LIST[int]([10, 20, 30, 40, 50]);
            for x in ys | .filter(n => n > 15).take(2) do
                Std.write_line("list: {x}");
            od

            // count of a taken/skipped chain still goes through the pipe
            // objects (consumer fusion declines take/skip) - included to pin
            // that this stays correct.
            let n = ys | .skip(1).take(2).count();
            Std.write_line("count: {n}");
        si
    si
si
