namespace Test is
    use Std = IO.Std;
    use Collections.List;

    class Main is
        entry() static is
            // Delayed-init `let` assigned a lambda whose arg type
            // is an abstract `List[int]` (not a native `int[]`),
            // then called. Iter 1 records `Func[List[int],
            // INFERED_RETURN_TYPE]` on the placeholder's LUB
            // from the assignment, and previously the call's
            // back-feed pushed a second `Func[<actual-arg-type>,
            // INFERED_RETURN_TYPE]` candidate that the per-
            // position merge couldn't fold, leaving the slot
            // type with a placeholder that gen_type emitted as
            // a literal IL comment (rejected by ilasm).
            //
            // Fuzz finding 04 / survey §4.24.
            let v9 mut;
            v9 = (v8: List[int]) => 28;
            Std.write_line("v9([4]) = {v9([4])}");

            return;
        si
    si
si
