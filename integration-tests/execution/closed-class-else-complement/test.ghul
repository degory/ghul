namespace Test is
    use IO.Std;

    // Closed-by-default class hierarchies: the else edge of `isa C(x)`
    // narrows `x` to the complement of the closed root's subclasses.
    // With two ghūl-declared subclasses and no `open` modifier on the
    // base, eliminating `Cat` on the else edge leaves `Dog` as the
    // singleton narrow — `a.bark()` resolves without a cast.

    class Animal is
        init() is si
    si

    class Cat: Animal is
        init() is super.init(); si
        purr() -> string => "purr";
    si

    class Dog: Animal is
        init() is super.init(); si
        bark() -> string => "bark";
    si

    class Main is
        entry() static is
            describe(Cat());
            describe(Dog());
        si

        describe(a: Animal) static is
            if isa Cat(a) then
                Std.out.write_line(a.purr());
            else
                Std.out.write_line(a.bark());
            fi
        si
    si
si
