namespace Test is
    use IO.Std;

    // Closed-by-default class hierarchies: the else edge of `isa C(x)`
    // narrows `x` to the complement of the closed root's subclasses.
    // `Animal` is `abstract` so a bare `Animal()` instance can't exist
    // at runtime; with that, eliminating `CAT` on the else edge leaves
    // `DOG` as the singleton narrow and `a.bark()` resolves without
    // a cast.

    class Animal abstract is
        init() is si
    si

    class CAT: Animal is
        init() is super.init(); si
        purr() -> string => "purr";
    si

    class DOG: Animal is
        init() is super.init(); si
        bark() -> string => "bark";
    si

    class Main is
        entry() static is
            describe(CAT());
            describe(DOG());
        si

        describe(a: Animal) static is
            if isa CAT(a) then
                Std.out.write_line(a.purr());
            else
                Std.out.write_line(a.bark());
            fi
        si
    si
si
