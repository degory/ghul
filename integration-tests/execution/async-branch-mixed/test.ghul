namespace Test is
    use Std = IO.Std;

    class Main is
        get_value(use_async: bool) -> Tasks.TASK[int] static =>
            if use_async then
                Tasks.TaskExtensions.unwrap(
                    Tasks.TASK.from_result(42).continue_with(
                        (t: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                            Tasks.TASK.from_result(t.result + 1000)
                    )
                )
            else
                Tasks.TASK.from_result(-1)
            fi;

        entry() static is
            let async_path = get_value(true);
            let sync_path = get_value(false);

            Std.write_line("async_path.result={async_path.result}");
            Std.write_line("sync_path.result={sync_path.result}");
        si
    si
si
