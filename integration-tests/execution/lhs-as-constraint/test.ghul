namespace Test is
    use Std = IO.Std;

    // LHS-as-constraint propagation: the type of an assignment target
    // (typed variable initializer or assignment to an already-typed
    // variable) is now pushed down as a constraint on the right-hand
    // side. The most useful immediate consequence is that anonymous
    // function literals on the RHS can infer their argument types
    // from the LHS type, instead of requiring explicit annotations.
    //
    // Implements the "left side of assignment statements as constraint
    // producers" item in #1174 and gives a working answer to the
    // "lambda assigned after a one-line refactor lost its arg types"
    // ergonomics complaint.

    class Main is
        entry() static is
            // ---- typed variable initializer (was already wired to
            //      call set_constraint, but FUNCTION ignored it; now
            //      consumes via the same path the new pre(assignment)
            //      uses).

            let f1: (int) -> int = x => x + 1;
            Std.out.write_line("init unary: {f1(10)}");

            let f2: (int, int) -> int = (a, b) => a + b;
            Std.out.write_line("init binary: {f2(3, 4)}");

            let f3: (int) -> string = n => "n is {n}";
            Std.out.write_line("init mixed-type: {f3(7)}");

            // ---- assignment to a previously declared typed variable

            let g1: (int) -> int;
            g1 = x => x * 2;
            Std.out.write_line("assign unary: {g1(5)}");

            let g2: (int, string) -> string;
            g2 = (n, s) => "{s} {n}";
            Std.out.write_line("assign multi-arg: {g2(99, "value:")}");

            // ---- explicit lambda arg types still work (the constraint
            //      is harmless when not needed).

            let h: (int) -> int;
            h = (x: int) => x + 100;
            Std.out.write_line("assign explicit: {h(1)}");

            // ---- non-lambda RHS still works (constraint set on the
            //      RHS expression is silently ignored by Expressions
            //      that don't override set_constraint, and the existing
            //      type-check still verifies assignability).

            let direct: int;
            direct = 42;
            Std.out.write_line("assign int: {direct}");

            // ---- reassignment after a successful inferred initial.

            let reassign: (int) -> int = x => x + 10;
            Std.out.write_line("reassign before: {reassign(1)}");
            reassign = x => x + 20;
            Std.out.write_line("reassign after: {reassign(1)}");

            return;
        si
    si
si
