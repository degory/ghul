namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A `for` over a `map`/`filter` pipe chain whose base is a pinned
    // source (value type or array) is lowered to one inline loop over
    // the source's own iterator: the ADAPTOR_PIPE / MAP_PIPE / FilterPipe
    // objects and their per-element virtual dispatch are never emitted.
    // This pins the observable behaviour; the fused and unfused
    // lowerings must produce identical results.

    class Main is
        entry() static is
            // value-type (range) source.
            for x in (0..10) | .map(n => n * 10).filter(n => n > 30) do
                Std.write_line("map/filter: {x}");
            od

            for x in (0..6) | .filter(n => n % 2 == 0) do
                Std.write_line("filter: {x}");
            od

            for x in (0..4) | .map(n => n + 100) do
                Std.write_line("map: {x}");
            od

            // filter before map: stage order preserved.
            for x in (0..6) | .filter(n => n > 2).map(n => n * n) do
                Std.write_line("filter/map: {x}");
            od

            // array source.
            let xs = [3, 1, 4, 1, 5, 9, 2, 6];
            for x in xs | .map(n => n * 2).filter(n => n > 8) do
                Std.write_line("array: {x}");
            od
        si
    si
si
