namespace Test is
    use IO.Std;

    // Variant constructors whose arguments don't bind every type-arg
    // of the parent union: the unbound slot(s) should be inferred from
    // the enclosing return-type / let-type / assignment-type context
    // via the existing OWNER_CONSTRAINT_SPECIALIZER variant-of-
    // constraint path. Before the fix, overload resolution failed
    // (S unbound from args) and never reached the post-resolution
    // specialiser; the call errored as if no constraint were present.

    union RESULT[T, S] is
        OK(value: T);
        ERR(reason: S);
    si

    // Return position pins both slots from the declared return type.
    // OK's arg binds T from 42; S comes from RESULT[int, string].
    ok_from_return() -> RESULT[int, string] is
        return RESULT.OK(42);
    si

    // ERR mirror: arg binds S from "oops"; T from the declared return.
    err_from_return() -> RESULT[int, string] is
        return RESULT.ERR("oops");
    si

    // let-init with declared type: same constraint path.
    let_init() -> RESULT[int, string] is
        let r: RESULT[int, string] = RESULT.OK(7);
        return r;
    si

    class Main is
        entry() static is
            let a = ok_from_return();
            let b = err_from_return();
            let c = let_init();

            Std.write_line("ok: {isa RESULT[int, string].OK(a)}");
            Std.write_line("err: {isa RESULT[int, string].ERR(b)}");
            Std.write_line("init: {isa RESULT[int, string].OK(c)}");

            return;
        si
    si
si
