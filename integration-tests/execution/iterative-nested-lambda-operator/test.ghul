namespace Test is
    use IO.Std;
    use Collections;

    // Iterative-inference regression: inner lambda captures the outer
    // lambda's placeholder-typed argument `t`. Iteration N captures `t`
    // with the placeholder type into the inner closure's frame field;
    // iteration N+1 resolves `t` to WRAPPER but the captured field's
    // type was previously sticky, so the operator dispatch in the
    // inner body kept seeing the placeholder receiver and failed with
    // "operator *** =~ Test.WRAPPER not found".
    class WRAPPER is
        value: int;
        init(value: int) is
            super.init();
            self.value = value;
        si
        =~(other: WRAPPER) -> bool => self.value == other.value;
    si

    class Main is
        entry() static is
            let xs = LIST[WRAPPER]();
            xs.add(WRAPPER(1));
            xs.add(WRAPPER(2));
            let ys = LIST[WRAPPER]();
            ys.add(WRAPPER(2));

            let result = xs | .filter(t => ys | .any(u => t =~ u)) .collect_list();

            Std.write_line(result.count.to_string());
            return;
        si
    si
si
