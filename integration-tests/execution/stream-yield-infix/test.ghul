namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;
    use STREAM.DONE;
    use STREAM.YIELD;

    // End-to-end check of the `||` yield infix lowering against the
    // STREAM[T, S] union: each step lambda returns either `DONE` or
    // `value || next_state`, the latter desugared to
    // `STREAM.YIELD(value, next_state)`.

    class Main is
        entry() static is
            // State `int` cursor, output `string` — state and output
            // genuinely different types. Counts down 3..1 emitting
            // labelled strings.

            let labels =
                stream`[string, int](
                    3,
                    (i: int) =>
                        if i == 0 then
                            DONE[string, int]()
                        else
                            "step {i}" || (i - 1)
                        fi
                );

            for line in labels do
                Std.write_line(line);
            od

            return;
        si
    si
si
