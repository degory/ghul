namespace Test is
    use Std = IO.Std;

    enum Level is
        LOW,
        MID,
        HIGH
    si

    class Main is
        entry() static is
            let lo = Level.LOW;
            let hi = Level.HIGH;

            Std.out.write_line("LOW < HIGH: {lo < hi}");
            Std.out.write_line("HIGH < LOW: {hi < lo}");
            Std.out.write_line("MID > LOW: {Level.MID > lo}");
            Std.out.write_line("HIGH >= HIGH: {hi >= Level.HIGH}");
            Std.out.write_line("LOW <= MID: {lo <= Level.MID}");

            if lo < hi then
                Std.out.write_line("ordered");
            fi
            return;
        si
    si
si
