namespace Test is
    use Std = IO.Std;

    class MAIN is
        name(want: bool) -> string static => if want then "value" else "other" fi;

        entry() static is
            let want = true;

            // no expected type pushed: the joined type is inferred, and
            // the null arms must make it optional
            let a = if want then name(true) else null fi;
            let b = if !want then name(false) else null fi;

            let c = case 1 when 1 then "one" else null esac;
            let d = case 2 when 1 then "one" else null esac;

            if a? then
                Std.out.write_line("a: {a}");
            fi

            if !b? then
                Std.out.write_line("b is null");
            fi

            if c? then
                Std.out.write_line("c: {c}");
            fi

            if !d? then
                Std.out.write_line("d is null");
            fi
        si
    si
si
