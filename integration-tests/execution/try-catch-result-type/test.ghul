namespace Test is
    use IO.Std;
    use System.Exception;

    // Tests: return type inference across try/catch.
    // The try body returns int; the catch body returns int too.
    // Function return type should be inferred as int.

    safe_div(a: int, b: int) -> int is
        try
            return a / b;
        catch e: Exception
            return 0;
        yrt
    si

    class Main is
        entry() static is
            Std.write_line("{safe_div(10, 2)}");
            Std.write_line("{safe_div(10, 0)}");
            return;
        si
    si
si
