namespace Test is
    use Std = IO.Std;

    // Constructor-call-as-constrained-RHS: when an LHS context provides
    // a constraint of the same generic class, the visitor uses that
    // constraint to bind owner generic arguments that couldn't be
    // inferred from the supplied constructor arguments alone. Covers
    // both the deprecated-`new` form `Box()` and the explicit
    // `new Box()` form, on typed-initializer and assignment-after-
    // declaration shapes.

    class Box[T] is
        item: T;

        // Zero-arg constructor — T is not inferable from arguments,
        // it has to come from the constraint.
        init() is si

        init(item: T) is
            self.item = item;
        si

        get() -> T => item;

        set(item: T) is
            self.item = item;
        si
    si

    class Pair[T, U] is
        first: T;
        second: U;

        // Zero-arg pair — both T and U have to come from the
        // constraint.
        init() is si

        init(first: T, second: U) is
            self.first = first;
            self.second = second;
        si

        get_first: T => first;
        get_second: U => second;
    si

    class Main is
        entry() static is
            // ---- typed initializer + zero-arg constructor (deprecated-`new` form)

            let b1: Box[int] = Box();
            b1.set(42);
            Std.out.write_line("b1: {b1.get()}");

            // ---- assignment after declaration

            let b2: Box[int];
            b2 = Box();
            b2.set(7);
            Std.out.write_line("b2: {b2.get()}");

            // ---- typed initializer + zero-arg constructor (explicit `new` form)

            let b3: Box[string] = new Box();
            b3.set("hello");
            Std.out.write_line("b3: {b3.get()}");

            // ---- two type-parameter case (Pair[T, U]) — both come from constraint

            let p1: Pair[int, string] = Pair();
            Std.out.write_line("p1: {p1.get_first}" + " | {p1.get_second}");

            // ---- regression: constraint AND args together, args agree

            let b4: Box[int] = Box(99);
            Std.out.write_line("b4: {b4.get()}");

            return;
        si
    si
si
