namespace Test is
    use Std = IO.Std;

    trait T is
        flag: bool => false;
    si

    class A: T is
        flag: bool => super.flag;
        init() is si
    si

    class Mid: A is
        init() is si
    si

    class B: Mid is
        flag: bool => true;
        init() is si
    si

    class Main is
        entry() static is
            let b = B();
            let m: Mid = b;
            let a: A = b;
            let t: T = b;
            Std.write_line("b: {b.flag}");
            Std.write_line("m: {m.flag}");
            Std.write_line("a: {a.flag}");
            Std.write_line("t: {t.flag}");
        si
    si
si
