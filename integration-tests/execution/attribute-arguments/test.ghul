class SIMPLE: System.Attribute is
    init() is si
si

class SCALAR: System.Attribute is
    text: string public;
    number: int public;
    flag: bool public;

    init() is si

    init(text: string, number: int, flag: bool) is
        self.text = text;
        self.number = number;
        self.flag = flag;
    si
si

class TARGETED: System.Attribute is
    kind: System.AttributeTargets public;

    init() is si

    init(kind: System.AttributeTargets) is
        self.kind = kind;
    si
si

class WITH_ARRAYS: System.Attribute is
    words: string[] public;
    values: int[] public;

    init(words: string[]) is
        self.words = words;
    si
si

class TYPED: System.Attribute is
    the_type: System.Type public;

    init() is si

    init(t: System.Type) is
        self.the_type = t;
    si
si

@SIMPLE()
class MARKED is
    init() is si
si

@SCALAR("positional text", -12, true)
class POSITIONAL is
    init() is si
si

@SCALAR(text = "named text", number = 7, flag = false)
class NAMED is
    init() is si
si

@TARGETED(kind = System.AttributeTargets.CLASS)
class ENUM_NAMED is
    init() is si
si

class HAS_METHOD is
    init() is si

    @TARGETED(System.AttributeTargets.METHOD)
    run() is si
si

@WITH_ARRAYS(["a", "b", "c"], values = [10, 20])
class ARRAYS is
    init() is si
si

@TYPED(typeof MARKED)
class TYPEOF_POSITIONAL is
    init() is si
si

@TYPED(the_type = typeof NAMED)
class TYPEOF_NAMED is
    init() is si
si

show(name: string, instance: object) static is
    for a in instance.get_type().get_custom_attributes(false) do
        if isa SIMPLE(a) then
            IO.Std.write_line("{name}: simple attribute present");
        fi

        let scalar = cast SCALAR(a);
        if scalar? then
            IO.Std.write_line("{name}: text=[{scalar.text}] number={scalar.number} flag={scalar.flag}");
        fi

        let targeted = cast TARGETED(a);
        if targeted? then
            IO.Std.write_line("{name}: kind={targeted.kind}");
        fi

        let arrays = cast WITH_ARRAYS(a);
        if arrays? then
            IO.Std.write_line("{name}: words=[{arrays.words[0]},{arrays.words[1]},{arrays.words[2]}] values=[{arrays.values[0]},{arrays.values[1]}]");
        fi

        let typed = cast TYPED(a);
        if typed? then
            IO.Std.write_line("{name}: the_type={typed.the_type.name}");
        fi
    od
si

entry() static is
    show("MARKED", MARKED());
    show("POSITIONAL", POSITIONAL());
    show("NAMED", NAMED());
    show("ENUM_NAMED", ENUM_NAMED());
    show("ARRAYS", ARRAYS());
    show("TYPEOF_POSITIONAL", TYPEOF_POSITIONAL());
    show("TYPEOF_NAMED", TYPEOF_NAMED());

    for a in HAS_METHOD().get_type().get_method("run").get_custom_attributes(false) do
        let targeted = cast TARGETED(a);
        if targeted? then
            IO.Std.write_line("run: kind={targeted.kind}");
        fi
    od

    return;
si
