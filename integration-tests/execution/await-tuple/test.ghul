namespace Test is
    use Std = IO.Std;
    class Main is
        get_value() -> Tasks.TASK[int] static => Tasks.TASK.from_result(7);

        // Tuple with an `await` element. The tuple constructs its
        // pair after the await resumes; first element evaluated
        // before the await needs no spill (literal).
        compute() -> Tasks.TASK[(int, int)] static is
            let t = (10, await get_value());
            return t;
        si

        entry() static is
            let (a, b) = compute().result;
            Std.write_line("a={a} b={b}");
        si
    si
si
