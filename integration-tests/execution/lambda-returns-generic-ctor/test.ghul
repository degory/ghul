namespace Test is
    use IO.Std;
    use Collections;

    // Tests: lambda body returns a generic constructor
    // with no explicit type-args. The constructor's T should be
    // inferred from the constructor's own arg (concrete int), but
    // *also* the lambda's return type should resolve to `Box[int]`.
    //
    // Two inference paths interact here:
    //   1. `Box(n)` — constructor type-arg inferred from arg (works).
    //   2. The lambda's return type — INFERRED_RETURN_TYPE that needs
    //      to be replaced by Box[int] once (1) resolves.

    class Box[T] is
        _value: T;
        init(v: T) is _value = v; si
        value: T => _value;
    si

    class Main is
        entry() static is
            let make_box = n => Box(n);
            let b = make_box(42);
            Std.write_line("{b.value}");
            return;
        si
    si
si
