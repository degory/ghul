namespace Test is
    use IO.Std;

    // Tests: in-place mutation of structs embedded in heap objects
    // through field member paths. Every lvalue route to a struct held
    // in a class field must write through to the stored value: nested
    // member write, mutating method call, ref argument, and chains of
    // struct fields at depth. Struct locals are the baseline.

    struct S is
        tag: int public;
        init(tag: int) is
            self.tag = tag;
        si
        set_tag(t: int) is
            tag = t;
        si
        read() -> int => tag;
    si

    struct OUTER is
        inner: S field;
        init() is si
    si

    struct GS[T] is
        value: T public;
        init(value: T) is
            self.value = value;
        si
    si

    class N is
        state: S field;
        deep: OUTER field;
        gbox: GS[int] field;
        prop: S public;
        init() is
            gbox = GS(0);
        si
    si

    bump(s: S ref) static is
        s!.tag = 42;
    si

    class Main is
        entry() static is
            // baseline: struct local routes
            let l mut = S(0);
            l.tag = 5;
            Std.write_line("local write: {l.tag}");

            l.set_tag(6);
            Std.write_line("local mutating method: {l.tag}");

            bump(l ref);
            Std.write_line("local ref arg: {l.tag}");

            // nested member write through a class field
            let n = N();
            n.state.tag = 7;
            Std.write_line("field write: {n.state.tag}");

            // mutating method on a class field
            let n2 = N();
            n2.state.set_tag(9);
            Std.write_line("field mutating method: {n2.state.tag}");

            // ref argument from a class field
            let n3 = N();
            bump(n3.state ref);
            Std.write_line("field ref arg: {n3.state.tag}");

            // struct-in-struct-in-class chain
            let n4 = N();
            n4.deep.inner.tag = 11;
            Std.write_line("deep field write: {n4.deep.inner.tag}");

            n4.deep.inner.set_tag(12);
            Std.write_line("deep field mutating method: {n4.deep.inner.tag}");

            bump(n4.deep.inner ref);
            Std.write_line("deep field ref arg: {n4.deep.inner.tag}");

            // generic struct field
            let n6 = N();
            n6.gbox.value = 21;
            Std.write_line("generic struct field write: {n6.gbox.value}");

            // whole-struct assignment through a property still works
            let n5 = N();
            n5.prop = S(3);
            Std.write_line("whole struct property assignment: {n5.prop.tag}");

            // reads and method calls through a property copy are legal
            let r = n5.prop.read();
            Std.write_line("read through property copy: {r}");
        si
    si
si
