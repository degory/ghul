namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Ghul.Pipes.Pipe[int] static is
            for x in [1, 2, 3] do
                for y in [10, 20] do
                    yield x * 100 + y;
                od
            od
        si

        entry() static is
            for v in gen() do
                Std.write_line("v: {v}");
            od
        si
    si
si
