namespace Test is
    use IO.Std;

    get_string(x: int) -> string is
        return "value is {x}";
    si

    get_string_global(x: int) -> string => "global value is {x}";

    class BOX is
        init() is si

        get_self_string() -> string is
            return "box says {self.identity}";
        si

        identity: string => "hello";
    si

    class Main is
        entry() static is
            Std.write_line(get_string(42));
            Std.write_line(get_string_global(7));
            Std.write_line(BOX().get_self_string());
            return;
        si
    si
si
