namespace Test is








    use Std = IO.Std;

    class Main is
        entry() static is
            

            Std.out.write_line("iterable"); 

            for i in ITERABLE() do
                Std.out.write_line("index: {i}"); 
            od

            Std.out.write_line("iterator"); 

            for i in ITERABLE().iterator do
                Std.out.write_line("index: {i}"); 
            od

            Std.out.write_line("iterator"); 

            for i in ITERATOR() do
                Std.out.write_line("index: {i}"); 
            od
        si
    si

    class ITERABLE is
        iterator: ITERATOR is return ITERATOR(); si

        init() is            
        si        
    si

    class ITERATOR is
        _count: int;

        init() is
            _count = 5;
        si
        
        move_next() -> bool is
            _count = _count - 1;
            return _count >= 0;
        si

        current: int is
            return _count;    
        si                
    si
si

