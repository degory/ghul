namespace Test is
    use IO.Std;

    // Tests: a tuple of two lambdas. The tuple's
    // element types should be inferred from each lambda's body.

    class Main is
        entry() static is
            let funcs = (x => x + 1, y => y * 2);
            Std.write_line("{funcs.`0(10)}");
            Std.write_line("{funcs.`1(10)}");
            return;
        si
    si
si
