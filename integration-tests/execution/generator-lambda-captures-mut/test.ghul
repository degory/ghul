namespace Test is
    use Std = IO.Std;

    class Main is
        // Captured mut local
        gen() -> Collections.Iterable[int] static is
            let i mut = 100;
            let bump = () is i = i + 1; si;
            bump();
            yield i;
            bump();
            yield i;
        si

        entry() static is
            for x in gen() do
                Std.write_line("got {x}");
            od
        si
    si
si
