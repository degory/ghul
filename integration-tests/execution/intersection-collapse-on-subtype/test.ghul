namespace Test is
    use Std = IO.Std;

    class ANIMAL is
        base_kind: string => "animal";
    si

    trait Trainable is
        train();
    si

    class DOG: ANIMAL, Trainable is
        init() is si

        dog_thing() is
            Std.out.write_line("dog_thing");
        si

        train() is
            Std.out.write_line("trained");
        si
    si

    class Main is
        entry() static is
            let a: ANIMAL = DOG();

            // First narrow: a → ANIMAL & Trainable.
            if isa Trainable(a) then
                a.train();

                // Second narrow to a strict subtype that implies
                // both ANIMAL and Trainable. The factory should
                // collapse the intersection to just DOG and unlock
                // DOG-specific members like dog_thing().
                if isa DOG(a) then
                    a.dog_thing();
                    a.train();
                    Std.out.write_line(a.base_kind);
                fi
            fi
        si
    si
si
