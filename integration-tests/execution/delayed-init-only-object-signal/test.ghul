namespace Test is
    use IO.Std;

    // Pins the "only signal is an upper bound" fallback: a
    // delayed-init binding's ONLY information is that it's
    // passed to a function expecting `object`. The upper-bound
    // back-feed records `object` as a bound but never as a
    // lower-bound LUB candidate. `try_get_inferred_type` falls
    // back to the single upper bound when no lower bound exists,
    // so v still settles to object (preserving the pre-fix
    // behaviour for this corner case). Surfaces if a future
    // change drops the single-upper-bound fallback.

    consume(o: object) -> string => "{o}";

    entry() is
        let v mut;
        consume(v);
        v = "hello";
        Std.out.write_line(consume(v));
    si
si
