class MARK: System.Attribute is
    label: string public;

    init(label: string) is
        self.label = label;
    si
si

class CARRIER is
    @MARK("instance field")
    name: string public;

    @MARK("static field")
    counter: int static public;

    @MARK("private field")
    _hidden: int;

    @MARK("computed property")
    doubled: int => _hidden * 2;

    init() is
        name = "x";
        _hidden = 7;
    si
si

entry() is
    let t = typeof CARRIER;

    show("name property", t.get_property("name")!.get_custom_attributes(true));
    show("counter property", t.get_property("counter")!.get_custom_attributes(true));
    show("doubled property", t.get_property("doubled")!.get_custom_attributes(true));

    let hidden = t.get_field("_hidden", cast System.Reflection.BindingFlags(32 + 4));

    if hidden? then
        show("_hidden field", hidden.get_custom_attributes(true));
    else
        IO.Std.write_line("_hidden field: not found");
    fi
si

show(what: string, attributes: object[]) is
    for a in attributes do
        if isa MARK(a) then
            IO.Std.write_line("{what}: MARK({cast MARK(a).label})");
        fi
    od
si
