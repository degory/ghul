namespace Test is
    use Std = IO.Std;

    class Main is
        // Nested lambdas: outer lambda contains inner lambda
        gen() -> Collections.Iterable[int] static is
            let base mut = 0;
            for i in [10, 20, 30] do
                base = i;
                let make_offset = (off: int) is
                    let computed = () => base + off;
                    base = base + computed();
                si;
                make_offset(1);
                yield base;
            od
        si

        entry() static is
            for x in gen() do
                Std.write_line("got {x}");
            od
        si
    si
si
