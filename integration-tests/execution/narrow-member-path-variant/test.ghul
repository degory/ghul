// Variant-of-union narrowing over a member-access path. `isa NUM(b.x)`
// narrows `b.x` (a SHAPE union) to NUM on the then edge and to STR on
// the else edge (the complement of the variant list minus NUM).

use Std = IO.Std;

union SHAPE is
    NUM(value: int);
    STR(value: string);
si

class BOX is
    x: SHAPE public;
    init(x: SHAPE) is
        self.x = x;
    si
si

describe(b: BOX) is
    if isa SHAPE.NUM(b.x) then
        Std.write_line("num: {b.x.value}");
    else
        Std.write_line("str: {b.x.value}");
    fi
si

entry() is
    describe(BOX(SHAPE.NUM(42)));
    describe(BOX(SHAPE.STR("hello")));
si
