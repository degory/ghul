namespace Test is
    use Std = IO.Std;

    // Call-argument-as-constraint-producer: when a call argument is a
    // constructor expression that produces an under-determined
    // owner-generic type (e.g. zero-arg `BOX()` for a generic `BOX[T]`)
    // and the called function has exactly one arity-matching overload,
    // the visitor pushes the formal argument's type as a constraint
    // and re-walks the argument so the constructor specialises against
    // the formal type. Idiomatically: `apply(BOX())` where
    // `apply(b: BOX[int])` infers `BOX[int]()`.

    class BOX[T] is
        item: T;

        init() is si

        init(item: T) is
            self.item = item;
        si

        get() -> T => item;

        set(item: T) is
            self.item = item;
        si
    si

    class PAIR[T, U] is
        first: T;
        second: U;

        init() is si

        get_first: T => first;
        get_second: U => second;

        set(first: T, second: U) is
            self.first = first;
            self.second = second;
        si
    si

    apply_int(b: BOX[int]) is
        b.set(42);
        Std.out.write_line("apply_int: {b.get()}");
    si

    apply_string(b: BOX[string]) is
        b.set("hello");
        Std.out.write_line("apply_string: {b.get()}");
    si

    apply_pair(p: PAIR[int, string]) is
        p.set(7, "seven");
        Std.out.write_line("apply_pair: {p.get_first} | {p.get_second}");
    si

    apply_new(b: BOX[int]) is
        b.set(99);
        Std.out.write_line("apply_new: {b.get()}");
    si

    class Main is
        entry() static is
            // ---- single type-parameter, deprecated-`new` form

            apply_int(BOX());

            // ---- single type-parameter, different concrete type

            apply_string(BOX());

            // ---- multi-type-parameter

            apply_pair(PAIR());

            // ---- explicit `new` form

            apply_new(new BOX());

            // ---- regression: arg already binds T (no retry needed)

            apply_int(BOX(123));

            return;
        si
    si
si
