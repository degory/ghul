namespace Test is
    use Std = IO.Std;

    // A Pipe-like type that implements BOTH Iterable[int] AND
    // Iterator[int]. A `for` loop over a value of such a type
    // should iterate via the Iterator face directly rather than
    // call `.iterator` (which would return a fresh enumerator
    // and lose iteration state). To prove the preference, this
    // type's `iterator` returns a *decoy* that yields a single
    // sentinel value; a wrong-path implementation would surface
    // that sentinel.
    class PIPE_LIKE: Collections.Iterable[int], Collections.Iterator[int] is
        _values: Collections.List[int];
        _index: int;

        init(values: Collections.List[int]) is
            _values = values;
            _index = -1;
        si

        // Iterator[int] members.
        current: int => _values[_index];
        move_next() -> bool is
            _index = _index + 1;
            return _index < _values.count;
        si
        reset() is _index = -1; si
        dispose() is si

        // Iterable[int] member — deliberately returns a "wrong"
        // iterator to prove the lowering uses the Iterator path
        // and never calls .iterator.
        iterator: Collections.Iterator[int] => DECOY_ITERATOR();
    si

    class DECOY_ITERATOR: Collections.Iterator[int] is
        _delivered: bool;
        init() is _delivered = false; si
        current: int => 99;
        move_next() -> bool is
            if _delivered then return false; fi
            _delivered = true;
            return true;
        si
        reset() is _delivered = false; si
        dispose() is si
    si

    class Main is
        double_async(x: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => x * 2
            );

        // `pipe` is statically typed as PIPE_LIKE — both Iterable[int]
        // and Iterator[int]. The for-loop must iterate it through the
        // Iterator face (the real values), not call `.iterator` (the
        // decoy's single 99).
        sum_pipe(pipe: PIPE_LIKE) -> Tasks.TASK[int] static is
            let total mut = 0;
            for x in pipe do
                let y = await double_async(x);
                total = total + y;
            od
            return total;
        si

        entry() static is
            let values: Collections.List[int] = [10, 20, 30];
            let pipe = PIPE_LIKE(values);
            let result = sum_pipe(pipe).result;
            // If lowering correctly picks Iterator: 10*2+20*2+30*2 = 120.
            // If it wrongly picks Iterable (calling .iterator on pipe):
            //   the decoy yields just 99, so 99*2 = 198.
            Std.write_line("result={result}");
        si
    si
si
