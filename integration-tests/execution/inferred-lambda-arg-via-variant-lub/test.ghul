use IO.Std.write_line;

union STEP[T] is
    DONE;
    YIELD(value: T);
si

use STEP.DONE;
use STEP.YIELD;

// Stream-like driver. Both the output type T and the cursor type S
// are call-site inferred via the lambda's first walk + the LUB across
// DONE and YIELD branches. No explicit annotations required.
run_one[T, S](initial: S, advance: S -> STEP[T]) -> int is
    let step = advance(initial);

    return if step.is_yield then 1 else 0 fi;
si

entry() is
    // The user's "drop the type annotation" shape — the lambda's
    // parameter `i` has no annotation and the variant constructor
    // `DONE()` carries no payload. Inference goes:
    //   - i bound from the formal `S` (phantom from PARTIAL retry)
    //   - operator== body usage pins i = int via back-feed
    //   - YIELD(i) pins T = int, S = int
    //   - LUB across DONE[<phantom>] and YIELD[int] merges through
    //     the shared STEP[…] ancestor
    let a = run_one(3, i => if i == 0 then DONE() else YIELD(i) fi);
    write_line("a = {a}");

    let b = run_one(0, i => if i == 0 then DONE() else YIELD(i) fi);
    write_line("b = {b}");
si
