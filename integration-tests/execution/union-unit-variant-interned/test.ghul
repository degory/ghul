namespace Test is
    use Std = IO.Std;

    union COLOR is
        RED;
        GREEN;
    si

    union OPT[T] is
        SOME(value: T);
        NONE;
    si

    class Main is
        entry() static is
            let c1: COLOR = COLOR.RED();
            let c2: COLOR = COLOR.RED();
            Std.write_line(c1 == c2);

            let c3: COLOR = COLOR.GREEN();
            Std.write_line(c1 == c3);

            let n1: OPT[int] = OPT.NONE[int]();
            let n2: OPT[int] = OPT.NONE[int]();
            Std.write_line(n1 == n2);

            let s1: OPT[int] = OPT.SOME[int](42);
            let s2: OPT[int] = OPT.SOME[int](42);
            Std.write_line(s1 == s2);
        si
    si
si
