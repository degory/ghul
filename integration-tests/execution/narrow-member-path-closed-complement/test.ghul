// Closed-class else-edge complement narrowing over a member-access
// path. Since ANIMAL is closed and CAT/DOG are its only direct
// subclasses, `if isa CAT(b.animal) then … else …` narrows `b.animal`
// to DOG on the else edge — the complement of {CAT, DOG} minus {CAT}.

use Std = IO.Std;

class ANIMAL abstract is
    name: string public;
    init(name: string) is
        self.name = name;
    si
si

class CAT: ANIMAL is
    init(name: string) is
        super.init(name);
    si
    meow() -> string => "meow ({name})";
si

class DOG: ANIMAL is
    init(name: string) is
        super.init(name);
    si
    bark() -> string => "bark ({name})";
si

class BOX is
    animal: ANIMAL public;
    init(a: ANIMAL) is
        animal = a;
    si
si

describe(b: BOX) is
    if isa CAT(b.animal) then
        Std.write_line("then: {b.animal.meow()}");
    else
        Std.write_line("else: {b.animal.bark()}");
    fi
si

entry() is
    describe(BOX(CAT("felix")));
    describe(BOX(DOG("rex")));
si
