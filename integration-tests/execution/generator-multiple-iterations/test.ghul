namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Ghul.Pipes.Pipe[int] static is
            yield 10;
            yield 20;
        si

        entry() static is
            for x in gen() do Std.write_line("first: {x}"); od
            for y in gen() do Std.write_line("second: {y}"); od
        si
    si
si
