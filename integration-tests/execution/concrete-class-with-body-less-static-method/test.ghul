namespace Test is
    use IO.Std;

    // A body-less *static* method does not make the class abstract.
    // The DECLARE_SYMBOLS guard skips statics — they don't bear on
    // whether an instance can exist, so the class is still
    // constructible. (If the static is called it will throw at
    // runtime via the synthesised body, same as today.)

    class Box is
        init() is si

        // Body-less static — does NOT mark the class abstract.
        helper() -> int static;

        observed() -> int => 7;
    si

    class Main is
        entry() static is
            let b = Box();
            Std.out.write_line("observed: {b.observed()}");
        si
    si
si
