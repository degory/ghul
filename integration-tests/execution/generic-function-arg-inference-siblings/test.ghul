namespace Test is
    use Std = IO.Std;

    // Regression test for the LUB-extension fix: when a generic function is
    // called with sibling argument types (e.g. `merge[T](Cat(), Dog())`),
    // generic-argument inference should resolve T to their common ancestor
    // (Animal) rather than failing the overload match. Previously the
    // bind-results pairwise widening gave up on siblings and produced a
    // "no overload found" error.

    class Animal is
        init() is si
        speak() -> string => "animal";
    si

    class Cat: Animal is
        init() is si
    si

    class Dog: Animal is
        init() is si
    si

    class Plant is
        init() is si
    si

    class Helper is
        merge[T](a: T, b: T) -> T static is return a; si
        merge3[T](a: T, b: T, c: T) -> T static is return a; si
    si

    class Main is
        entry() static is
            // Two siblings — T should be inferred as Animal.
            let a = Helper.merge(Cat(), Dog());
            Std.out.write_line("siblings: " + a.speak());

            // Sibling + ancestor — pairwise widening already handles this.
            let b = Helper.merge(Cat(), Animal());
            Std.out.write_line("ancestor first: " + b.speak());

            let c = Helper.merge(Animal(), Cat());
            Std.out.write_line("ancestor second: " + c.speak());

            // Three siblings — T should still be inferred as Animal.
            let d = Helper.merge3(Cat(), Dog(), Cat());
            Std.out.write_line("three siblings: " + d.speak());

            // Unrelated types — LUB falls back to object.
            // Calling `to_string` confirms T was bound (to System.Object).
            let e = Helper.merge(Cat(), Plant());
            Std.out.write_line("unrelated: " + e.to_string());

            return;
        si
    si
si
