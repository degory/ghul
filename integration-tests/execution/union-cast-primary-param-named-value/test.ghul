use IO.Std.write_line;

// Primary parameters of a union can be named `value` or `has_value`
// without collision now that `?` and `!` lower to `isa`/`cast`
// against the default variant. Synthesised structural equality on
// each variant references these spliced fields by name through
// `self.<name>` and `other.<name>`.
union HOLDER(value: int, has_value: bool) is
    BOX(payload: string, ..) default;
    BAG(items: int, ..);
si

entry() is
    let one: HOLDER = HOLDER.BOX("hi", 1, true);
    let two: HOLDER = HOLDER.BAG(7, 2, false);

    write_line("one.value: {one.value}");
    write_line("one.has_value: {one.has_value}");
    write_line("two.value: {two.value}");
    write_line("two.has_value: {two.has_value}");

    write_line("one?: {one?}");
    write_line("two?: {two?}");

    write_line("one!.payload: {one!.payload}");
si
