
namespace Test is
    use Std = IO.Std;

    class Main is
        // Three-branch if with yields in each branch — exercises the
        // multi-branch dispatch path. All three branches share a
        // single join state; the dispatch state's synthesised if
        // chains TRANSITIONs to each branch-first-state in order.
        pick(which: int) -> Collections.Iterable[int] static is
            if which == 1 then
                yield 100;
            elif which == 2 then
                yield 200;
                yield 201;
            else
                yield 999;
            fi
            yield 0;
        si

        entry() static is
            let one mut = 0;
            for x in pick(1) do one = one + x; od
            let two mut = 0;
            for x in pick(2) do two = two + x; od
            let other mut = 0;
            for x in pick(42) do other = other + x; od
            Std.write_line("one={one} two={two} other={other}");
        si
    si
si
