namespace Test is
    use IO.Std;
    use Collections;

    // Two sibling actuals to a `PAIR[T].init(a: T, b: T)` constructor
    // are concrete but disjoint — `int[]` (a .NET array) and
    // `LIST[int]` (the concrete mutable list class). Neither is
    // assignable from the other; binding T from both requires a
    // structural-LUB walk to a SHARED TRAIT they both implement
    // (the result here is `Iterable[int]` or `List[int]` — the
    // trait, not the class).

    class PAIR[T] is
        a: T;
        b: T;
        init(a: T, b: T) is
            self.a = a;
            self.b = b;
        si

        first() -> T => a;
    si

    class Main is
        entry() static is
            let ints_list = LIST[int]();
            ints_list.add(10);

            let p = PAIR([1, 2, 3], ints_list);

            Std.write_line("first={p.first()}");
            return;
        si
    si
si
