namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let task = Tasks.TASK.from_result(42);

            Std.write_line("from_result.result={task.result}");

            let nested =
                task.continue_with(
                    (t: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                        Tasks.TASK.from_result(t.result + 1)
                );

            let chained = Tasks.TaskExtensions.unwrap(nested);

            Std.write_line("chained.result={chained.result}");
        si
    si
si
