namespace Test is
    use Std = IO.Std;

    // Auto-synthesised deconstruct on a primary-ctor class: each
    // public-readable capture surfaces as one ref-typed parameter
    // in primary-header order. Verifies the destructure binder
    // reaches it via the existing tuple/deconstruct precedence.
    class POINT(x: int, y: int) is
    si

    // Capture-via-`_`-prefix is still public-readable by default,
    // so it participates. Verifies the synthesis follows the same
    // visibility rule as the rest of the primary-ctor lowering.
    class HOLDER(_value: int) is
    si

    // Three captures destructure positionally.
    class TRIPLE(a: int, b: string, c: int) is
    si

    // Nested destructure through two primary-ctor classes —
    // both have auto-synthesised deconstructs.
    class PAIR(left: POINT, right: POINT) is
    si

    // `init` modifier suppresses field/property synthesis, so the
    // param never becomes a capture and is not part of the
    // deconstruct. Only `kept` participates.
    class TAG(kept: int, ignored: int init) is
    si

    // Struct primary ctor — same machinery as classes.
    struct VEC(x: int, y: int) is
    si

    // User-supplied `deconstruct` wins over synthesis. The user's
    // shape (one element, returning the sum) is preserved.
    class SUM(a: int, b: int) is
        deconstruct(total: int ref) is
            total! = a + b;
        si
    si

    // User-supplied backtick-numeric properties suppress synthesis.
    // The destructure binder falls through to the positional path
    // and finds the user's `0 / `1.
    class PRIO(x: int, y: int) is
        `0: int => x * 10;
        `1: int => y * 100;
    si

    class Main is
        entry() static is
            let (px, py) = POINT(3, 4);
            Std.out.write_line("({px}, {py})");

            let (v) = HOLDER(99);
            Std.out.write_line("v={v}");

            let (a, b, c) = TRIPLE(1, "two", 3);
            Std.out.write_line("{a} {b} {c}");

            let ((lx, ly), (rx, ry)) = PAIR(POINT(1, 2), POINT(3, 4));
            Std.out.write_line("({lx},{ly})-({rx},{ry})");

            let (k) = TAG(7, 11);
            Std.out.write_line("k={k}");

            let (sx, sy) = VEC(5, 6);
            Std.out.write_line("vec=({sx},{sy})");

            let (sum) = SUM(10, 20);
            Std.out.write_line("sum={sum}");

            let (px10, py100) = PRIO(2, 3);
            Std.out.write_line("prio=({px10},{py100})");

            // The synthesised method is published as .NET's standard
            // `Deconstruct` (capital D) via `@IL.name`, so C# positional
            // patterns and other cross-language consumers find it.
            let dotnet_type = cast System.Type(typeof POINT);
            let dotnet_method = dotnet_type.get_method("Deconstruct");
            Std.out.write_line("Deconstruct={dotnet_method?}");
        si
    si
si
