namespace Test is
    use IO.Std.write_line;

    class SCORE is
        `0: string field;
        `1: int field;

        init(who: string, points: int) is
            `0 = who;
            `1 = points;
        si
    si

    show_destructure(score: SCORE?) -> string? =>
        if let (who, _) = score then
            "winner: {who}";
        fi;

    show_type_test(o: object) -> string? =>
        if let s: string = o then
            "string: {s}";
        fi;

    show_chained(a: SCORE?, b: SCORE?) -> string? =>
        if let (who, _) = a then
            "a: {who}";
        elif let (who, _) = b then
            "b: {who}";
        fi;

    show_plain_if(b: bool) -> string? =>
        if b then
            "true";
        fi;

    pick_value(n: int) -> int? =>
        if n > 0 then
            n;
        fi;

    show_optional(s: string?) =>
        if s? then write_line(s) else write_line("(none)") fi;

    show_int(n: int?) =>
        if n? then write_line("{n}") else write_line("(none)") fi;

    entry() is
        show_optional(show_destructure(SCORE("Alice", 10)));
        show_optional(show_destructure(null));

        show_optional(show_type_test("hi"));
        show_optional(show_type_test(42));

        show_optional(show_chained(SCORE("a", 1), null));
        show_optional(show_chained(null, SCORE("b", 2)));
        show_optional(show_chained(null, null));

        show_optional(show_plain_if(true));
        show_optional(show_plain_if(false));

        show_int(pick_value(7));
        show_int(pick_value(-1));
    si
si
