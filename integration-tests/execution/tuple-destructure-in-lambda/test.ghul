namespace Test is
    use IO.Std;
    use Collections;

    // Tests: lambda whose parameter is a tuple type,
    // inferred from a sibling-arg-driven owner-generic binding.
    // `each_pair(pairs, (a, b) => ...)` — pairs is LIST[(int,int)],
    // so the lambda's parameter type should resolve to (int, int).
    //
    // The destructure `(a, b)` on the parameter relies on the
    // parameter's type being known *before* the body walks.

    each_pair[T,U](pairs: Iterable[(T, U)], action: (T, U) -> void) is
        for p in pairs do
            action(p.`0, p.`1);
        od
    si

    class Main is
        entry() static is
            let pairs = [(1, 2), (3, 4), (5, 6)];
            each_pair(pairs, (a, b) => Std.write_line("{a}+{b}={a+b}"));
            return;
        si
    si
si
