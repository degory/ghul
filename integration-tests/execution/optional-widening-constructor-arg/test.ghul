namespace Test is
    use Std = IO.Std;

    // Constructor parameter is `int?`; a bare-`int` argument must widen
    // at the `newobj` slot, exactly as it does at a method-call slot.
    class BOX is
        value: int?;

        init(value: int?) is
            super.init();
            self.value = value;
        si

        describe() -> string is
            if value? then
                return "value present: {value}";
            fi

            return "value absent";
        si
    si

    // Constructor parameter is `object`; a bare-`int` argument must box
    // at the `newobj` slot. Same boundary, the value-type→object case.
    class WRAPPED is
        boxed: object;

        init(boxed: object) is
            super.init();
            self.boxed = boxed;
        si

        describe() -> string => "boxed: {boxed}";
    si

    class Main is
        entry() static is
            Std.out.write_line(BOX(42).describe());
            Std.out.write_line(WRAPPED(7).describe());
        si
    si
si
