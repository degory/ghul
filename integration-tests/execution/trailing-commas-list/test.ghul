namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // List literal with trailing comma.
            let xs = [1, 2, 3,];

            // Tuple literal with trailing comma.
            let p = (10, 20,);

            // Call argument list with trailing comma.
            Std.write_line("{xs.count} {p.`0} {p.`1}");

            return;
        si
    si
si
