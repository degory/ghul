use IO.Std.write_line;

// The implicit-default rule — "exactly one non-unit variant" —
// counts own fields, not inherited primary fields. `FULL` has an own
// field (`payload`), `EMPTY` only inherits from the union's primary
// header, so `FULL` is picked as the default and `?` discriminates.
union BOX_OPT[T](id: int) is
    FULL(payload: T, ..);
    EMPTY(..);
si

entry() is
    let full: BOX_OPT[int] = BOX_OPT.FULL[int](42, 7);
    let empty: BOX_OPT[int] = BOX_OPT.EMPTY[int](9);

    write_line("full?: {full?}");
    write_line("empty?: {empty?}");

    write_line("full.id: {full.id}");
    write_line("empty.id: {empty.id}");

    // `FULL` has two fields total (own `payload` + inherited `id`)
    // so `full!` returns the variant — multi-field defaults unwrap
    // to the variant itself, not a single projection.
    write_line("full!.payload: {full!.payload}");
    write_line("full!.id: {full!.id}");
si
