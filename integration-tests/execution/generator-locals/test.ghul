namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Collections.Iterable[int] static is
            let a = 1;
            let b = 2;
            let c = a + b;
            yield a;
            yield b;
            yield c;
            yield a + c;
        si

        entry() static is
            for v in gen() do
                Std.write_line("v: {v}");
            od
        si
    si
si
