namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // Stateful source + side-effecting inner map pin that the fused
    // take/skip lowering advances the source, and applies an inner map,
    // exactly as many times as the pipe-object lowering. Both are eager:
    // FilterPipeBase.move_next pulls its inner iterator before the
    // take-count check, and MAP_PIPE.move_next applies its mapper inside
    // move_next - so a `take` over-pulls one element and runs an inner map
    // on that discarded element in the pipe-object lowering too. The fused
    // loop matches, keeping the counts identical.

    class COUNTING: Iterable[int], Iterator[int] is
        _n: int;
        _limit: int;
        moves: int;
        iterator: Iterator[int] => self;
        current: int => _n;
        init(limit: int) is _n = -1; _limit = limit; moves = 0; si
        move_next() -> bool is moves = moves + 1; _n = _n + 1; return _n < _limit; si
        reset() is _n = -1; si
        dispose() is si
    si

    class MAPPED is
        _calls: int static;
        reset() static is _calls = 0; si
        calls() -> int static => _calls;
        f(n: int) -> int static is _calls = _calls + 1; return n * 10; si
    si

    class Main is
        entry() static is
            let a = COUNTING(20);
            for x in a | .take(3) do od
            Std.write_line("take(3) moves: {a.moves}");

            let b = COUNTING(20);
            for x in b | .filter(n => n % 2 == 0).take(2) do od
            Std.write_line("filter.take(2) moves: {b.moves}");

            let c = COUNTING(20);
            MAPPED.reset();
            for x in c | .map(n => MAPPED.f(n)).take(2) do od
            Std.write_line("map.take(2) moves: {c.moves}, mapper calls: {MAPPED.calls()}");

            let d = COUNTING(20);
            for x in d | .skip(3).take(2) do od
            Std.write_line("skip(3).take(2) moves: {d.moves}");
        si
    si
si
