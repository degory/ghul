namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let a: int = 12; // 1100
            let b: int = 10; // 1010

            Std.out.write_line(a & b); // 1000 = 8
            Std.out.write_line(a | b); // 1110 = 14
            Std.out.write_line(a ^ b); // 0110 = 6

            let p: long = 0xFF00FF00L;
            let q: long = 0x0FF00FF0L;

            Std.out.write_line(p & q);
            Std.out.write_line(p | q);
            Std.out.write_line(p ^ q);

            return;
        si
    si
si
