namespace Test is
    use IO.Std;

    // Tests: a let-bound value from a conditional
    // where the two branches have related types. The let's type
    // should be the LUB.
    //
    // `CAT` and `DOG` share `ANIMAL` — let should resolve to
    // ANIMAL.

    class ANIMAL is
        init() is si
        speak() -> string => "...";
    si

    class CAT: ANIMAL is
        init() is si
        speak() -> string => "meow";
    si

    class DOG: ANIMAL is
        init() is si
        speak() -> string => "woof";
    si

    class Main is
        entry() static is
            let pet = if 3 > 2 then CAT() else DOG() fi;
            Std.write_line(pet.speak());
            return;
        si
    si
si
