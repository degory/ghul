namespace Test is
    use IO.Std;

    // Tests: a let-bound value from a conditional
    // where the two branches have related types. The let's type
    // should be the LUB.
    //
    // `Cat` and `Dog` share `Animal` — let should resolve to
    // Animal.

    class Animal is
        init() is si
        speak() -> string => "...";
    si

    class Cat: Animal is
        init() is si
        speak() -> string => "meow";
    si

    class Dog: Animal is
        init() is si
        speak() -> string => "woof";
    si

    class Main is
        entry() static is
            let pet = if 3 > 2 then Cat() else Dog() fi;
            Std.write_line(pet.speak());
            return;
        si
    si
si
