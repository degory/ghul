namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.collect_array() -> T[]`
    // in `ghul-runtime/src/pipe.ghul`. The result type is `T[]`
    // (.NET array). verifies pipe-element-type → array-element-type
    // propagation. Distinct from `.collect()` which returns
    // `List[T]` — this exercises the array-typed return path.

    class Main is
        entry() static is
            let arr = [1, 2, 3, 4, 5] | .filter(n => n % 2 == 0) .collect_array();

            for v in arr do
                Std.write_line("{v}");
            od

            Std.write_line("len={arr.count}");

            return;
        si
    si
si
