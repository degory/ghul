namespace Ghul.Async is
    enum LOOP_RESULT_TYPE is CONTINUE, BREAK, RETURN si

    struct LOOP_RESULT[T] is
        type: LOOP_RESULT_TYPE;
        value: T;

        init() is si

        init(type: LOOP_RESULT_TYPE, value: T) is
            self.type = type;
            self.value = value;
        si
    si

    class FOR_EACH_DRIVER[T_elem, T_ret] is
        _iter: Collections.Iterator[T_elem];
        _body: T_elem -> Tasks.TASK[LOOP_RESULT[T_ret]];
        _tcs: Tasks.TaskCompletionSource[LOOP_RESULT[T_ret]];
        _on_complete_callback: (Tasks.TASK[LOOP_RESULT[T_ret]]) -> void;

        init(
            iter: Collections.Iterator[T_elem],
            body: T_elem -> Tasks.TASK[LOOP_RESULT[T_ret]]
        ) is
            _iter = iter;
            _body = body;
            _tcs = Tasks.TaskCompletionSource[LOOP_RESULT[T_ret]]();
            _on_complete_callback = t => on_complete(t);
        si

        start() -> Tasks.TASK[LOOP_RESULT[T_ret]] is
            pump();
            return _tcs.task;
        si

        pump() is
            try
                while _iter.move_next() do
                    let body_task = _body(_iter.current);
                    if !body_task.is_completed then
                        body_task.continue_with(_on_complete_callback);
                        return;
                    fi
                    if handle_result(body_task) then return; fi
                od
                _tcs.set_result(LOOP_RESULT[T_ret]());
            catch ex: System.Exception
                _tcs.set_exception(ex);
            yrt
        si

        on_complete(t: Tasks.TASK[LOOP_RESULT[T_ret]]) is
            if handle_result(t) then return; fi
            pump();
        si

        handle_result(t: Tasks.TASK[LOOP_RESULT[T_ret]]) -> bool is
            if t.is_faulted then
                _tcs.set_exception(t.exception);
                return true;
            fi
            let r = t.result;
            if r.type == LOOP_RESULT_TYPE.RETURN \/ r.type == LOOP_RESULT_TYPE.BREAK then
                _tcs.set_result(r);
                return true;
            fi
            return false;
        si
    si

    for_each_async[T_elem, T_ret](
        iter: Collections.Iterator[T_elem],
        body: T_elem -> Tasks.TASK[LOOP_RESULT[T_ret]]
    ) -> Tasks.TASK[LOOP_RESULT[T_ret]] =>
        FOR_EACH_DRIVER[T_elem, T_ret](iter, body).start();
si

namespace Test is
    use Std = IO.Std;

    class Main is
        double_async(x: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => x * 2
            );

        // Real for-loop source whose body throws when x == 2. The
        // exception is caught by the driver's try/catch and
        // propagated via tcs.set_exception, surfacing as a faulted
        // Task on the caller's side (AggregateException when
        // accessed via .result).
        compute(xs: Collections.List[int]) -> Tasks.TASK[int] static is
            let total mut = 0;
            for x in xs do
                let await y = double_async(x);
                if x == 2 then
                    throw System.InvalidOperationException("boom on x=2");
                fi
                total = total + y;
            od
            return total;
        si

        entry() static is
            let xs: Collections.List[int] = [1, 2, 3];
            try
                let _ = compute(xs).result;
                Std.write_line("UNEXPECTED no exception");
            catch ae: System.AggregateException
                Std.write_line("caught AggregateException, inner={ae.inner_exception.message}");
            yrt
        si
    si
si
