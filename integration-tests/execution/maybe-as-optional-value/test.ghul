namespace Test is
    use IO.Std;
    use Collections;

    // Value-type `T?` slots accept a `Ghul.MAYBE[T]` source via a
    // pure layout-blit — `MAYBE[T]` and `System.Nullable[T]` are
    // both sequential-layout structs declared `(bool, T)`, so the
    // struct copy at the slot boundary already produces a
    // well-formed `Nullable[T]`. No IL coercion is emitted.
    class Main is
        find_int(xs: List[int], n: int) -> int? static =>
            xs | .find(x => x == n);

        first_int(xs: List[int]) -> int? static =>
            xs | .first();

        // Argument-pass through a value-type `T?` slot — exercises
        // VALUE_BOXER.box_arguments' wrap-before-box ordering.
        report(found: int?) static is
            if found? then
                Std.write_line("report: {found!}");
            else
                Std.write_line("report: none");
            fi
        si

        entry() static is
            let xs = [10, 20, 30, 40];

            let found = find_int(xs, 30);
            if found? then
                Std.write_line("found {found!}");
            else
                Std.write_line("not found");
            fi

            let missing = find_int(xs, 99);
            if missing? then
                Std.write_line("found {missing!}");
            else
                Std.write_line("missing: not found");
            fi

            let first = first_int(xs);
            if first? then
                Std.write_line("first {first!}");
            fi

            let empty: List[int] = LIST[int]();
            let none = first_int(empty);
            if none? then
                Std.write_line("none: had value");
            else
                Std.write_line("none: empty");
            fi

            report(xs | .find(x => x == 20));
            report(xs | .find(x => x > 100));

            return;
        si
    si
si
