// A store through a member the path reads through kills the path
// narrow — keyed on the member symbol, not the receiver, so a store
// through an aliased receiver still invalidates. Here `b.animal =
// DOG(...)` invalidates the narrow on `b.animal` (proved from the
// preceding `isa CAT(b.animal)`), so the second `.meow()` call would
// no longer type-check and the code falls back to `.name`.

use Std = IO.Std;

class ANIMAL is
    name: string public;
    init(name: string) is
        self.name = name;
    si
si

class CAT: ANIMAL is
    init(name: string) is
        super.init(name);
    si
    meow() -> string => "meow ({name})";
si

class DOG: ANIMAL is
    init(name: string) is
        super.init(name);
    si
    bark() -> string => "bark ({name})";
si

class BOX is
    animal: ANIMAL public;
    init(a: ANIMAL) is
        animal = a;
    si
si

reassign_kills(b: BOX, d: DOG) is
    if isa CAT(b.animal) then
        Std.write_line("before: {b.animal.meow()}");
        b.animal = d;
        // narrow is forgotten — b.animal is ANIMAL again.
        Std.write_line("after: {b.animal.name}");
    fi
si

entry() is
    let b = BOX(CAT("felix"));
    reassign_kills(b, DOG("rex"));
si
