namespace Test is
    use Std = IO.Std;

    class Main is
        // yield inside try body; finally fires AFTER exhaustion when
        // the consumer iterates to completion. Each yield must NOT
        // run the finally — only on real exit.
        gen() -> Ghul.Pipes.Pipe[int] static is
            try
                yield 1;
                yield 2;
                yield 3;
            finally
                Std.write_line("finally");
            yrt
        si

        entry() static is
            for x in gen() do
                Std.write_line("got {x}");
            od
            Std.write_line("done");
        si
    si
si
