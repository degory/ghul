namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // 1. Construct a Tasks.TaskCompletionSource[int], confirm its
            //    `task` accessor returns an incomplete Task initially.
            let tcs = Tasks.TaskCompletionSource[int]();
            Std.write_line("initial.is_completed={tcs.task.is_completed}");

            // 2. set_result completes the task with a value.
            tcs.set_result(42);
            Std.write_line("after_set_result.is_completed={tcs.task.is_completed}");
            Std.write_line("after_set_result.result={tcs.task.result}");

            // 3. Compose with .continue_with — same pattern the driver
            //    will use. The continuation observes the completed value.
            let tcs2 = Tasks.TaskCompletionSource[int]();
            let chained = tcs2.task.continue_with(
                (t: Tasks.TASK[int]) -> int => t.result * 2
            );
            tcs2.set_result(10);
            Std.write_line("chained.result={chained.result}");

            // 4. set_exception propagates through .result as a faulted
            //    AggregateException — confirm the shape.
            let tcs3 = Tasks.TaskCompletionSource[int]();
            tcs3.set_exception(System.InvalidOperationException("boom"));
            Std.write_line("faulted.is_faulted={tcs3.task.is_faulted}");
            Std.write_line("faulted.is_completed={tcs3.task.is_completed}");

            try
                let _ = tcs3.task.result;
                Std.write_line("UNEXPECTED no exception");
            catch ae: System.AggregateException
                Std.write_line("caught AggregateException, inner={ae.inner_exception.message}");
            yrt
        si
    si
si
