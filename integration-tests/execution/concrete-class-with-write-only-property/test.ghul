namespace Test is
    use IO.Std;

    // A write-only property — `value: int public = v is ...` with no
    // get body — leaves the synthesised getter body-less, but the
    // class is NOT implicitly abstract. The user wrote a set-only
    // property, not an abstract member; constructing `Holder()`
    // must still succeed.

    class Holder is
        _stored: int;

        init() is
            _stored = 0;
        si

        stored: int public
            = v is
                _stored = v;
            si

        observed_stored() -> int => _stored;
    si

    class Main is
        entry() static is
            let h = Holder();
            h.stored = 42;
            Std.out.write_line("stored: {h.observed_stored()}");
        si
    si
si
