namespace Test is
    use Std = IO.Std;

    class PAIR[T] is
        a: T;
        init(a: T) is self.a = a; si
        kind() -> string => "one";
    si

    class PAIR[T, U] is
        a: T; b: U;
        init(a: T, b: U) is self.a = a; self.b = b; si
        kind() -> string => "two";
    si

    class Main is
        entry() static is
            let p1 = PAIR[int](10);
            let p2 = PAIR[int, string](20, "hello");

            Std.write_line(p1.kind());
            Std.write_line(p2.kind());

            return;
        si
    si
si
