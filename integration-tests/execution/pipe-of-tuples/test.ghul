namespace Test is
    use IO.Std;
    use Collections;

    // Tests: pipe whose element type is a named
    // tuple `(name: string, age: int)`, with downstream filter
    // and map accessing named fields. verifies member-name access
    // on a tuple element type flowing through pipe → filter → map.

    class Main is
        entry() static is
            let people = [
                (name = "alice", age = 30),
                (name = "bob", age = 17),
                (name = "carol", age = 42)
            ];

            let adults = people
                | .filter(p => p.age >= 18)
                .map(p => "{p.name} is {p.age}")
                .collect();

            for line in adults do
                Std.write_line(line);
            od

            return;
        si
    si
si
