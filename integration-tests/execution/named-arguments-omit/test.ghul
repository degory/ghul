namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            box(width = 5);
            box(width = 5, height = 3);
            box(height = 4, width = 2, depth = 7);
        si

        box(width: int, height: int, depth: int) static is
            Std.out.write_line("{width} x {height} x {depth}");
        si
    si
si
