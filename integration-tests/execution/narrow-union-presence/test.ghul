use IO.Std.write_line;

// `r?` on a union with a default variant narrows both edges, exactly
// like `isa Default(r)`: the then-edge to the default variant and the
// else-edge to the complement. This program compiles only if that
// narrowing happens — `value` is only on `OK` and `error` only on
// `ERROR`, neither is a member of the bare `Result` union.
union Result is
    OK(value: int) default;
    ERROR(error: string);
si

describe(r: Result) is
    if r? then
        write_line("ok: {r.value}");
    else
        write_line("err: {r.error}");
    fi
si

entry() is
    describe(Result.OK(11));
    describe(Result.ERROR("nope"));
si
