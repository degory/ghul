namespace Test is
    use Std = IO.Std;

    // The `init` modifier marks a primary-ctor param as ctor-scoped only:
    // no field auto-generates; the param is in scope inside the
    // synthesised init body and the explicit init(..) body, nowhere else.

    // `value` is init-only. The explicit body decl `value_string` holds
    // the transformed payload; the auto-init body assigns it from the
    // param.
    class TOKEN_PAIR(token: int, location: int, value: string init) is
        value_string: string;

        init(..) is
            value_string = "<{value}>";
        si

        describe: string =>
            "{token}@{location} {value_string}";
    si

    // Mix init-only + auto-gen params. `seed` is init-only (consumed by
    // a computed field); `label` auto-gens.
    class HASHER(label: string, seed: int init) is
        hash: int;

        init(..) is
            hash = seed * 31;
        si

        describe: string => "{label}:{hash}";
    si

    class Main is
        entry() static is
            Std.write_line(TOKEN_PAIR(7, 42, "hello").describe);
            Std.write_line(HASHER("counter", 5).describe);
        si
    si
si
