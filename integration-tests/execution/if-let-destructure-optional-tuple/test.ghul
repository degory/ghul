namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Refutable destructure unwraps the value-type optional in
            // the true branch — `(name, age)` bind against the inner
            // `(string, int)` tuple, not the surrounding `T?`.
            try_destructure(lookup("alice"));
            try_destructure(lookup("bob"));

            // Discards work inside the pattern.
            try_first(lookup("alice"));
            try_first(lookup("bob"));
        si

        // A value-type optional is constructed explicitly via
        // `OPTION[T](...)`; there is no implicit T → T? coercion for
        // value types (intentional — the wrap should be visible at the
        // construction site).
        lookup(key: string) -> (string, int)? static is
            if key == "alice" then
                return OPTION[(string, int)](("alice", 42));
            fi
            return null;
        si

        try_destructure(value: (string, int)?) static is
            if let (name, age) = value then
                Std.out.write_line("destructured: {name} = {age}");
            else
                Std.out.write_line("nothing");
            fi
        si

        try_first(value: (string, int)?) static is
            if let (name, _) = value then
                Std.out.write_line("first: {name}");
            else
                Std.out.write_line("no first");
            fi
        si
    si
si
