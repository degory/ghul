namespace Test is
    use Std = IO.Std;

    class HANDLE: Disposable is
        _label: string;

        init(label: string) is
            _label = label;
            Std.write_line("open {_label}");
        si

        dispose() is
            Std.write_line("dispose {_label}");
        si
    si

    class Main is
        // Single await inside a `let use` scope. Dispose must fire on
        // normal completion AFTER the await resumes; must NOT fire on
        // suspend.
        run() -> Tasks.TASK static is
            let use h = HANDLE("a");

            Std.write_line("before");
            await Tasks.TASK.delay(1);
            Std.write_line("after");

            return;
        si

        entry() static is
            run().wait();
            Std.write_line("done");
        si
    si
si
