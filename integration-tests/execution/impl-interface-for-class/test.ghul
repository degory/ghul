namespace Test is
    use IO.Std;

    trait Printer is print() -> string; si
    trait Eq[T] is equals(other: T) -> bool; si

    class GREETER is
        _name: string;
        init(name: string) is _name = name; si
    si

    impl Printer for GREETER is
        print() -> string => "hello {_name}";
    si

    class BOX[T] is
        value: T;
        init(value: T) is self.value = value; si
    si

    impl Eq[BOX[T]] for BOX[T] is
        equals(other: BOX[T]) -> bool => value == other.value;
    si

    class Main is
        entry() static is
            let p: Printer = GREETER("world");
            Std.write_line(p.print());

            let a = BOX(7);
            let e: Eq[BOX[int]] = a;
            Std.write_line("{e.equals(BOX(7))}");
            Std.write_line("{e.equals(BOX(9))}");
            return;
        si
    si
si
