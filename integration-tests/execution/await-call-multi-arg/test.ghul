namespace Test is
    use Std = IO.Std;
    class Main is
        counter: int public static;

        bump() -> int static is
            let old = counter;
            counter = counter + 100;
            return old;
        si

        change_after_delay() -> Tasks.TASK[int] static is
            return Tasks.TASK.delay(5).continue_with(
                (t: Tasks.TASK) -> int is
                    counter = counter + 1;
                    return 7;
                si
            );
        si

        f(a: int, b: int, c: int) -> int static => a + b + c;

        compute() -> Tasks.TASK[int] static is
            // Expected: bump() returns 0 (counter→100), await returns 7
            //   (continuation: counter→101), then `c` arg is just 1.
            // Result: 0 + 7 + 1 = 8.
            // Without spiller for CALL: bump() fires AFTER await, returns 1,
            //   result is 1 + 7 + 1 = 9.
            return f(bump(), await change_after_delay(), 1);
        si

        entry() static is
            let r = compute().result;
            Std.write_line("x={r} counter={counter}");
        si
    si
si
