namespace Test is
    use IO.Std;
    use Collections;

    // A lambda captures `xs: LIST[phantom]` whose element type
    // isn't yet bound at lambda-creation time. The body
    // `xs.add(x)` chains x's type ← LIST[?].add's formal, and the
    // use site `add_to_xs(1)` propagates `int` back to x's origin.
    // The retry loop then re-walks the lambda body with x: int,
    // which back-feeds int onto xs's phantom, resolving xs to
    // LIST[int].
    //
    // Pinned to guard the closure-call back-feed: the visitor's
    // call path for Function-typed (non-FUNCTION_GROUP) callees
    // must run `back_feed.pair(formal, actual)` for each arg/
    // formal pair, not just `compare`-validate. Without that
    // back-feed step the retry loop has nothing new to consume on
    // each iteration and the lambda's argument origin never gets
    // a constraint.

    class Main is
        entry() static is
            let xs = LIST();
            let add_to_xs = x => xs.add(x);
            add_to_xs(1);
            add_to_xs(2);
            add_to_xs(3);
            Std.write_line("count={xs.count}");
            return;
        si
    si
si
