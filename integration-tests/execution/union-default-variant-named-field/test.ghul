use IO.Std.write_line;

// The default-variant `?` / `!` unwrap reads the single field of
// the default variant positionally — the field need not be named
// `value`. Pin that here so a future rename or accidental rewrite
// can't quietly break the contract.
union Box[T] is
    SOME(item: T) default;
    NONE;
si

entry() is
    let s: Box[int] = Box.SOME(42);
    let n: Box[int] = Box.NONE();

    write_line(s?);
    write_line(n?);

    write_line(s!);

    try
        write_line(n!);
    catch ex: System.Exception
        write_line("threw");
    yrt
si
