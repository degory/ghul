use IO.Std.write_line;

union STEP[T, S] is
    DONE;
    YIELD(value: T, next: S);
si

use STEP.DONE;
use STEP.YIELD;

run[S, T](initial: S, advance: S -> STEP[T, S]) is
    let state mut = initial;
    while true do
        let step = advance(state);
        if isa YIELD(step) then
            write_line("{step.value}");
            state = step.next;
        else
            return;
        fi
    od
si

// Binary user-defined operator with a generic state type S and a value
// type T inferred via the lambda's body. Without constraint-push retry
// on the operator path the lambda parameter `s` has no source for its
// type (member access on `s` then can't resolve) and T leaks into the
// emitted IL as a dangling type-parameter reference.
$$[S, T](initial: S, advance: S -> STEP[T, S]) =>
    run(initial, advance);

entry() is
    // The lambda's parameter `s` is unannotated; its type must come
    // from the operator's formal so that s.current and s.prev resolve.
    (prev = 0, current = 1) $$
        s =>
            if s.current > 8 then
                DONE
            else
                YIELD(s.current, (prev = s.current, current = s.prev + s.current))
            fi;

    write_line("---");

    // Output type differs from state type — pin both directions of the
    // formal flow at once.
    "go" $$
        s =>
            if s.length == 0 then
                DONE
            else
                YIELD(s.length, s.substring(1))
            fi;
si
