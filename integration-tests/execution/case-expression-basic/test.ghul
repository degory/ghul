namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            test(-1, "minus one");
            test(0, "zero");
            test(1, "one");
            test(2, "two");
            test(6, "small");
            test(7, "small");
            test(8, "small");
            test(13, "unlucky");
            test(99, "other");
        si

        test(value: int, expected: string) static is
            let result = describe(value);

            if result =~ expected then
                Std.out.write_line("expected: {value} => {result} == {expected}");
            else
                Std.out.write_line("not expected: {value} => {result} != {expected}");
            fi
        si

        describe(value: int) -> string static is
            return case value
            when -1 then "minus one"
            when 0 then "zero"
            when 1 then "one"
            when 2 then "two"
            when 6, 7, 8 then "small"
            when 13 then "unlucky"
            else "other"
            esac;
        si
    si
si
