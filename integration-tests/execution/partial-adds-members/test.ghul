namespace Test is
    use IO.Std;

    class COUNTER is
        _count: int;
        init() is _count = 0; si
    si

    partial COUNTER is
        bump() is _count = _count + 1; si
    si

    partial COUNTER is
        value() -> int => _count;
    si

    class BOX[T] is
        _value: T;
        init(value: T) is _value = value; si
    si

    partial BOX[T] is
        get() -> T => _value;
    si

    class Main is
        entry() static is
            let c = COUNTER();
            c.bump();
            c.bump();
            c.bump();
            Std.write_line("{c.value()}");

            let b = BOX("hello");
            Std.write_line(b.get());
            return;
        si
    si
si
