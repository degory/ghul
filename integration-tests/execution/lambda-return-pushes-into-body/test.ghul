use IO.Std.write_line;

union STEP[T] is
    DONE;
    YIELD(value: T);
si

use STEP.DONE;
use STEP.YIELD;

// Verifies the lambda's call-site formal-derived return-type
// constraint reaches expressions in the body. Without that
// pushdown, the IF below would LUB across DONE[?]/YIELD[int],
// widen to object (different variant heads + invariant union
// args), and the outer overload would fail with
// "no overload found for run(int, int -> object)".
run_one[T, S](initial: S, advance: S -> STEP[T]) -> bool is
    let step = advance(initial);
    return isa YIELD(step);
si

run_two[T, S, R](initial: S, advance: S -> STEP[T], decide: STEP[T] -> R) -> R is
    let step = advance(initial);
    return decide(step);
si

entry() is
    // Call-site type args spelled explicitly because today's inference
    // widens T to object at the lambda's return-LUB while the YIELD
    // branch still constructs YIELD[int]; the `isa YIELD(step)` body
    // needs both ends to agree at runtime.
    //
    // 1: single-T STEP, payload-bearing YIELD on one branch, DONE() on the other.
    let a = run_one`[int, int](3, i => if i == 0 then DONE() else YIELD(i) fi);
    write_line("a = {a}");

    // 2: same shape but the lambda is a block body — verifies the
    // pushdown also feeds the implicit-return path on a block.
    let b = run_one`[int, int](0, i => if i == 0 then DONE() else YIELD(i) fi);
    write_line("b = {b}");

    // 3: two-typearg call-site formal (S -> STEP[T] with extra R for
    // the second lambda) — checks the pushdown selects the correct
    // formal slot rather than always taking the last one in the
    // function's signature.
    let c = run_two`[int, int, int](
        2,
        i => if i == 0 then DONE() else YIELD(i) fi,
        s => if isa DONE(s) then 0 else 1 fi
    );
    write_line("c = {c}");
si
