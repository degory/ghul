namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Fuzz finding 06: nested call to a delayed-init lambda
            // inside a tuple literal. On iter 1 the inner call
            // recorded CALL_CONSTRAINT([int]) on v7's placeholder
            // origin and resolved to DUMMY(ERROR); the outer call
            // then recorded a second CALL_CONSTRAINT([ERROR]) which
            // — under the old try_discharge logic that deferred on
            // any !is_settled captured arg — never discharged on
            // any later iter (ERROR is terminal). v7 stayed as
            // INFERRED_VARIABLE_TYPE, v8's tuple inherited
            // `(ERROR, int)` from iter 1's eager LUB add, and
            // `.locals init (ValueTuple`2 <!!!, int>)` reached
            // ilasm. The fix treats ERROR-typed captured args as
            // wildcard-satisfying at discharge time instead of
            // deferring.
            let v7;
            v7 = (v5: int) => 29;
            let v8;
            v8 = (v7(v7(68)), 94);

            Std.write_line("v8 = {v8}");

            return;
        si
    si
si
