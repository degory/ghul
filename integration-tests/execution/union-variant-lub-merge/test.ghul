use IO.Std.write_line;

union STEP[T] is
    DONE;
    YIELD(value: T);
si

use STEP.DONE;
use STEP.YIELD;

union TUPLE[T, U] is
    EMPTY;
    PAIR(left: T, right: U);
si

use TUPLE.EMPTY;
use TUPLE.PAIR;

// LUB of two different variants of the same union — neither side
// determines the variant's type-args alone (DONE has no payload),
// but together their slot-wise merge through the shared union
// ancestor picks the concrete type. Without the cross-head merge
// the LUB would walk to the common ancestor and fall to object
// (variants of an invariant union don't unify on type-args via
// `=~` when one slot is a placeholder).
//
// Both orderings exercised — the merge walks ancestors of both
// inputs, so DONE-then-YIELD and YIELD-then-DONE both need to
// reach `STEP[int]`.
//
// The LHS type is spelled explicitly so the unit-variant branch
// constructs at the same instantiation as the payload-bearing
// branch; today's LUB widens the result-type to STEP[object] while
// emitting YIELD[int]/DONE[object], and the `isa V(x)` body relies
// on those agreeing at runtime. The synthesized `.is_<variant>`
// accessors used to mask this via virtual dispatch.
test_one_typearg() is
    let x: STEP[int] = if true then DONE() else YIELD(42) fi;
    write_line("x is YIELD = {isa YIELD(x)}");

    let y: STEP[int] = if false then YIELD(99) else DONE() fi;
    write_line("y is DONE = {isa DONE(y)}");
si

// Multi-typearg union. PAIR pins both T and U from its args; EMPTY
// has neither, so the merge must accept the PAIR side's concretes
// for both slots.
test_multi_typearg() is
    let p: TUPLE[int, string] = if true then EMPTY() else PAIR(1, "hello") fi;

    write_line("p is PAIR = {isa PAIR(p)}");
si

entry() is
    test_one_typearg();
    test_multi_typearg();
si
