namespace Test is
    // Tests: a `|>` call whose callee is a function-typed value (a
    // delegate) with a type-mismatched written argument reports a clean
    // error against the offending argument. The subject occupies actual
    // slot 0, so the reported location must account for it rather than
    // reading past the end of the written-argument list.

    class MAIN is
        entry() static is
            let f = (a: int, b: int) => a + b;
            let r = 5 |> f(true);
        si
    si
si
