namespace Test is
    use Std = IO.Std;

    // Auto-generated body decls for primary-ctor parameters that aren't
    // matched by an explicit body decl and aren't consumed by super(...).
    // Verifies the synthesised property/field is reachable from methods
    // and from outside the class according to its inferred visibility.

    // No body decls for any param — all three auto-gen as public-read
    // properties (default visibility).
    class TRIVIA(kind: int, text: string, position: int) is
        describe: string =>
            "[{position}] {kind}: {text}";
    si

    // Method references auto-gen'd fields directly.
    class POINT(x: int, y: int) is
        manhattan: int => x + y;
    si

    // Visibility suffix `public` flows through — externally assignable.
    class COUNTER(value: int public) is
    si

    // `_` prefix → field, not auto-property. Methods can read internally.
    class HOLDER(_value: int) is
        peek: int => _value;
    si

    class Main is
        entry() static is
            Std.write_line(TRIVIA(1, "hello", 42).describe);

            Std.write_line(POINT(3, 4).manhattan);

            let c = COUNTER(7);
            c.value = 100;
            Std.write_line(c.value);

            Std.write_line(HOLDER(99).peek);
        si
    si
si
