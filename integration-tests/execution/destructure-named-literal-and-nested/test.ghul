namespace Test is
    use Std = IO.Std;

    class PERSON is
        name: string public;
        age: int public;

        init(name: string, age: int) is
            self.name = name;
            self.age = age;
        si
    si

    class PAIR is
        left: PERSON public;
        right: PERSON public;

        init(left: PERSON, right: PERSON) is
            self.left = left;
            self.right = right;
        si
    si

    class Main is
        entry() static is
            // Literal-LHS value-equality match: the arm fires only
            // when person.name == "Alice"; `a` binds to person.age.
            describe(PERSON("Alice", 30));
            describe(PERSON("Bob", 40));

            // Mixed literal + bind in a single named group.
            describe_both(PERSON("Alice", 30));
            describe_both(PERSON("Alice", 31));
            describe_both(PERSON("Bob", 30));

            // Nested: outer positional tuple, inner by-name on PERSON.
            show_pair_outer_pos((PERSON("Alice", 30), 99));

            // Nested: outer by-name on PAIR, inner by-name on PERSON.
            show_pair_outer_named(PAIR(PERSON("Alice", 30), PERSON("Bob", 40)));
        si

        describe(person: PERSON?) static is
            if let ("Alice" = name, a = age) = person then
                Std.out.write_line("matched Alice age {a}");
            else
                Std.out.write_line("not Alice");
            fi
        si

        describe_both(person: PERSON?) static is
            if let ("Alice" = name, 30 = age) = person then
                Std.out.write_line("Alice age 30");
            else
                Std.out.write_line("other");
            fi
        si

        show_pair_outer_pos(pair: (PERSON, int)) static is
            // Outer (...) is positional (tuple slots); inner (...)
            // is named on PERSON.
            let ((n = name, a = age), score) = pair;
            Std.out.write_line("{n}/{a}/{score}");
        si

        show_pair_outer_named(pair: PAIR) static is
            // Outer (...) is by-name on PAIR; inner (...)s are
            // by-name on PERSON.
            let ((ln = name, la = age) = left, (rn = name, ra = age) = right) = pair;
            Std.out.write_line("{ln}/{la} -- {rn}/{ra}");
        si
    si
si
