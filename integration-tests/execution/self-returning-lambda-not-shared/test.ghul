use IO.Std.write_line;

// A method returning `() => self` yields a delegate whose result IS the
// receiver. Two receivers must produce thunks returning their own self;
// the delegate is receiver-dependent and must not be shared between them.
class BOX is
    id: int;

    init(id: int) is
        self.id = id;
    si

    self_thunk() -> () -> BOX => () => self;
si

entry() is
    let a = BOX(1);
    let b = BOX(2);

    let from_a = a.self_thunk();
    let from_b = b.self_thunk();

    write_line("a -> {from_a().id}");
    write_line("b -> {from_b().id}");
si
