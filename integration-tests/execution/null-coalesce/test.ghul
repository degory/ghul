namespace Test is
    use Std = IO.Std;

    class Main is
        _side_effects: int static;

        entry() static is
            let nothing: string? = null;
            let something: string? = "value";

            Std.out.write_line("{nothing ?? "default"}");
            Std.out.write_line("{something ?? "default"}");

            let a: string? = null;
            let b: string? = null;
            let c: string? = "third";
            Std.out.write_line("{a ?? b ?? c ?? "fallback"}");

            let x: string? = null;
            let y: string? = "second";
            let z: string? = "third";
            Std.out.write_line("{x ?? y ?? z ?? "fallback"}");

            _side_effects = 0;
            let present: string? = "yes";
            let kept = present ?? bump();
            Std.out.write_line("kept: {kept} bumps: {_side_effects}");

            _side_effects = 0;
            let absent: string? = null;
            let fallback = absent ?? bump();
            Std.out.write_line("fallback: {fallback} bumps: {_side_effects}");

            _side_effects = 0;
            let absent2: string? = null;
            let absent3: string? = null;
            let final = absent2 ?? absent3 ?? bump();
            Std.out.write_line("final: {final} bumps: {_side_effects}");

            let m: string? = null;
            let n: string? = null;
            let unclosed: string? = m ?? n;
            Std.out.write_line("unclosed-null: {unclosed?}");

            let m2: string? = null;
            let n2: string? = "still-here";
            let unclosed2: string? = m2 ?? n2;
            Std.out.write_line("unclosed-some: {unclosed2 ?? "<absent>"}");

            let p: string? = null;
            let q: string? = null;
            let r: string? = "found";
            let unclosed3: string? = p ?? q ?? r;
            Std.out.write_line("unclosed-chain: {unclosed3 ?? "<absent>"}");
        si

        bump() -> string static is
            _side_effects = _side_effects + 1;
            return "bumped";
        si
    si
si
