namespace Test is
    use Std = IO.Std;
    class BAG is
        seed: int;
        init(seed: int) is self.seed = seed; si
        combine(x: int) -> int is return seed + x; si
    si

    class Main is
        counter: int public static;

        // bump() mutates global counter and returns the previous BAG.
        bump_bag() -> BAG static is
            let v = counter;
            counter = counter + 100;
            return BAG(v);
        si

        get_delayed() -> Tasks.TASK[int] static is
            return Tasks.TASK.delay(5).continue_with(
                (t: Tasks.TASK) -> int is
                    counter = counter + 1;
                    return 7;
                si
            );
        si

        // Expected: bump_bag() fires BEFORE the await (counter→100,
        //   returns BAG(0)). Then await runs (counter→101, gets 7).
        //   combine(7) on BAG(0) → 0 + 7 = 7.
        compute() -> Tasks.TASK[int] static is
            return bump_bag().combine(await get_delayed());
        si

        entry() static is
            let r = compute().result;
            Std.write_line("x={r} counter={counter}");
        si
    si
si
