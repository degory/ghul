namespace Test is
    use Std = IO.Std;

    // Tests: an await in the `|>` subject, with the callee on an explicit
    // receiver. The subject evaluates after the receiver, so the receiver
    // (BOX(10)) must be spilled across the suspension.

    class BOX is
        _v: int;
        init(v: int) is _v = v; si
        combine(a: int, b: int) -> int => _v + a + b;
    si

    class MAIN is
        get() -> Tasks.TASK[int] static => Tasks.TASK.from_result(5);

        run() -> Tasks.TASK[int] static is
            let r = (await get()) |> BOX(10).combine(3);
            return r;
        si

        entry() static is
            Std.write_line("{run().result}");
        si
    si
si
