namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Bare `Lazy[T]` — works because the import side strips
            // the `\`N` suffix from reflected generic types.
            let a = System.Lazy[int](() => 42);
            Std.write_line("a={a.value}");

            return;
        si
    si
si
