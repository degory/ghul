namespace Test is
    use Std = IO.Std;

    class Main is
        // Returns `int` literal in a function declared to return TASK[int].
        // The compiler should auto-wrap with Tasks.TASK.from_result.
        compute() -> Tasks.TASK[int] static is
            return 42;
        si

        entry() static is
            let task = compute();
            Std.write_line("got={task.result}");
        si
    si
si
