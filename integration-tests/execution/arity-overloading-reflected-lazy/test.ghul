namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // New form: bare `Lazy[T]` — works after the import side
            // strips the `\`N` suffix from reflected generic types.
            let a = System.Lazy[int](() => 42);
            Std.write_line("a={a.value}");

            // Bootstrap form: `Lazy\`1[T]` — must still resolve via the
            // backtick-arity fallback so compiler source unchanged
            // builds under the new compiler.
            let b = System.Lazy`1[int](() => 99);
            Std.write_line("b={b.value}");

            return;
        si
    si
si
