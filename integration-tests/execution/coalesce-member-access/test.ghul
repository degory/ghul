namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            test_field_access();
            test_property_access();
            test_chained();
            test_widens_non_optional_member();
            test_keeps_optional_member();
        si

        // `a?.b` on a present receiver reads the field; on a null
        // receiver yields null.
        test_field_access() static is
            let p: PAIR? = PAIR("alpha", "beta");
            let absent: PAIR? = null;

            let a = p?.a;
            let b = absent?.a;

            Std.out.write_line("01-present: {a}");
            Std.out.write_line("01-absent: {if b? then b! else "<null>" fi}");
        si

        // Property access — `name` is a computed property.
        test_property_access() static is
            let p: PAIR? = PAIR("hello", "world");
            let n = p?.name;
            Std.out.write_line("02-property: {n}");

            let absent: PAIR? = null;
            let n2 = absent?.name;
            Std.out.write_line("02-absent: {if n2? then n2! else "<null>" fi}");
        si

        // Chained `?.` — outer is optional too.
        test_chained() static is
            let outer: HOLDER? = HOLDER(PAIR("first", "second"));
            let empty: HOLDER? = HOLDER(null);
            let absent: HOLDER? = null;

            let r1 = outer?.value?.a;
            let r2 = empty?.value?.a;
            let r3 = absent?.value?.a;

            Std.out.write_line("03-outer: {if r1? then r1! else "<null>" fi}");
            Std.out.write_line("03-empty: {if r2? then r2! else "<null>" fi}");
            Std.out.write_line("03-absent: {if r3? then r3! else "<null>" fi}");
        si

        // Non-optional field type → result is widened to optional.
        test_widens_non_optional_member() static is
            let p: PAIR? = PAIR("widen", "test");
            let a = p?.a;
            // `p` is provably present here, so `p?.a` keeps the plain
            // member type and needs no unwrap.
            let s = if a? then a else "<null>" fi;
            Std.out.write_line("04-widened: {s}");
        si

        // Already-optional member stays at the same type — no double wrap.
        test_keeps_optional_member() static is
            let h: HOLDER? = HOLDER(null);
            let v = h?.value;
            // v is PAIR? — HOLDER.value is already PAIR?, no double wrap.
            Std.out.write_line("05-keeps-optional: {if v? then "present" else "absent" fi}");
        si
    si

    class PAIR is
        a: string public;
        b: string public;

        init(a: string, b: string) is
            self.a = a;
            self.b = b;
        si

        name: string => "{a}+{b}";
    si

    class HOLDER is
        value: PAIR? public;

        init(value: PAIR?) is
            self.value = value;
        si
    si
si
