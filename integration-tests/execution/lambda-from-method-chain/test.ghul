namespace Test is
    use IO.Std;
    use Collections;

    // Tests: lambda parameter inferred from a method
    // call inside the body, where the method is on a concrete type
    // and returns something usable downstream.
    //
    // `xs | .filter(s => s.length > 3)` — the filter's predicate
    // formal is `string -> bool`. `s.length` only makes sense when
    // `s` is something with `.length` (string in scope here).

    class Main is
        entry() static is
            let xs = ["hi", "hello", "ok", "world"];
            let longish = xs | .filter(s => s.length > 3) .collect();
            for w in longish do
                Std.write_line(w);
            od
            return;
        si
    si
si
