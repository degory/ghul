namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A fused stage whose argument is a literal expression-bodied lambda
    // runs its body inline - no delegate, no closure frame. Captured
    // enclosing locals resolve as ordinary locals. This pins the
    // observable behaviour across the inline and delegate lowerings.

    class Main is
        entry() static is
            // capturing map + filter (enclosing scale / threshold).
            let scale = 3;
            let threshold = 6;
            for x in (0..6) | .map(n => n * scale).filter(n => n > threshold) do
                Std.write_line("cap: {x}");
            od

            // parameter used more than once: assigned once, read twice.
            for x in (0..5) | .map(n => n * n) do
                Std.write_line("sq: {x}");
            od

            // captured-and-reassigned local (boxed): lazy pull sees its
            // value at pull time.
            let acc mut = 10;
            for x in (0..3) | .map(n => n + acc) do
                Std.write_line("mut: {x}");
                acc = acc + 100;
            od

            // delegate-variable stage falls back to the delegate path;
            // the literal filter still inlines.
            let f = (n: int) => n * 3;
            for x in (0..5) | .map(f).filter(n => n > 6) do
                Std.write_line("mix: {x}");
            od
        si
    si
si
