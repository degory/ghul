namespace Test is
    use IO.Std;

    trait SOUND is
        label: string?;

        pick() -> string?;

        take(s: string) -> string;
    si

    class GOOD: SOUND is
        init() is si

        label: string => "tight";

        pick() -> string => "value";

        take(s: string?) -> string => if s? then s else "absent" fi;
    si

    class BASE is
        init() is si

        fetch() -> string? => null;
    si

    class DERIVED: BASE is
        init() is si

        fetch() -> string => "narrowed";
    si

    class Main is
        entry() static is
            let g: SOUND = GOOD();

            Std.write_line("{g.label} {g.pick()} {g.take("x")}");

            let b: BASE = DERIVED();

            Std.write_line(b.fetch() ?? "null");
        si
    si
si
