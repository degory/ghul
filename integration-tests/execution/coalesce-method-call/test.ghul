namespace Test is
    use Std = IO.Std;

    struct POINT is
        x: int field;
        y: int field;

        init(x: int, y: int) is
            self.x = x;
            self.y = y;
        si

        sum() -> int => x + y;
        describe() -> string => "({x},{y})";
    si

    class COUNTER is
        n: int field;

        init() is
        si

        bump() -> string is
            n = n + 1;
            return "arg";
        si
    si

    class BOX is
        v: string;
        bumps: int field;
        callback: () -> string;

        init(v: string) is
            self.v = v;
            self.callback = () => "callback-on-{v}";
        si

        get_it() -> string => v;
        shout(prefix: string) -> string => "{prefix}+{v}";
        answer() -> int => 42;
        maybe_none() -> string? => null;
        pick[T](value: T) -> T => value;

        bump() is
            bumps = bumps + 1;
        si

        stat() -> string static => "static-result";
        stat_prop: string static => "static-property";

        make(want: bool) -> BOX? static =>
            if want then BOX("made") else null fi;
    si

    class Main is
        entry() static is
            let present = BOX.make(true);
            let absent = BOX.make(false);
            let counter = COUNTER();

            // Instance method through `?.`: calls on a present
            // receiver, yields null on an absent one.
            Std.out.write_line("01-present: {ns(present?.get_it())}");
            Std.out.write_line("01-absent: {ns(absent?.get_it())}");

            // Arguments short-circuit with the call: the counter
            // bumps for the present receiver only.
            Std.out.write_line("02-args: {ns(present?.shout(counter.bump()))} evals={counter.n}");
            Std.out.write_line("02-absent: {ns(absent?.shout(counter.bump()))} evals={counter.n}");

            // A value-type result widens to optional.
            let a1 = present?.answer();
            let a2 = absent?.answer();
            Std.out.write_line("03-value-result: {ni(a1)} {ni(a2)}");

            // A void method runs on a present receiver and is
            // skipped on an absent one.
            present?.bump();
            absent?.bump();
            Std.out.write_line("04-void: bumps={ni(present?.bumps)}");

            // An already-optional result stays a single layer of
            // optional.
            let m1 = present?.maybe_none();
            Std.out.write_line("05-optional-result: {ns(m1)}");

            // Statics reached through `?.` never consume the tested
            // receiver.
            Std.out.write_line("06-static-method: {ns(present?.stat())} {ns(absent?.stat())}");
            Std.out.write_line("07-static-property: {ns(present?.stat_prop)} {ns(absent?.stat_prop)}");

            // A function-typed member invoked through `?.`
            // short-circuits the invocation itself.
            Std.out.write_line("08-delegate: {ns(present?.callback())} {ns(absent?.callback())}");

            // Chained coalescing calls.
            Std.out.write_line("09-chained: {ns(present?.get_it()?.to_upper())} {ns(absent?.get_it()?.to_upper())}");

            // Generic method with inferred type argument.
            Std.out.write_line("10-generic: {ns(present?.pick("picked"))} {ns(absent?.pick("picked"))}");

            // Struct methods on a value-type optional receiver.
            let p: POINT? = make_point(true);
            let np: POINT? = make_point(false);
            Std.out.write_line("11-struct: {ni(p?.sum())} {ni(np?.sum())}");
            Std.out.write_line("12-struct-string: {ns(p?.describe())} {ns(np?.describe())}");

            // BCL struct method on int?.
            let oi: int? = make_int(true);
            let nix: int? = make_int(false);
            Std.out.write_line("13-int-optional: {ns(oi?.to_string())} {ns(nix?.to_string())}");

            // Statement position: non-void result is discarded.
            present?.get_it();
            absent?.get_it();
            Std.out.write_line("14-statement: ok");
        si

        make_point(want: bool) -> POINT? static =>
            if want then POINT(3, 4) else null fi;

        make_int(want: bool) -> int? static =>
            if want then 123 else null fi;

        ns(s: string?) -> string static =>
            if s? then s! else "<null>" fi;

        ni(i: int?) -> string static =>
            if i? then "{i}" else "<null>" fi;
    si
si
