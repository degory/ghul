
use IO.Std.write_line;
use Collections.KeyValuePair;

entry() is
    let pair = KeyValuePair[string, int]("answer", 42);
    let (k, v) = pair;
    write_line("k={k} v={v}");

    let kk: string mut, vv: int mut;
    (kk, vv) = KeyValuePair[string, int]("question", 6);
    write_line("kk={kk} vv={vv}");
si
