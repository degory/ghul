namespace Test is
    use Std = IO.Std;

    class Main is
        gen[T](xs: Collections.Iterable[T]) -> Collections.Iterable[T] static is
            for x in xs do
                yield x;
                yield x;
            od
        si

        entry() static is
            for v in gen[int]([1, 2, 3]) do
                Std.write_line("v: {v}");
            od
        si
    si
si
