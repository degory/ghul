// Type narrowing over member-access paths. `isa T(x.y)` and
// `if let p: T = x.y` narrow the path `x.y` to `T` on the then edge, so
// `T`-typed member lookups on subsequent reads of `x.y` type-check. The
// else edge narrows to the complement when the receiver is a closed
// hierarchy (variant of a union, direct subclass of a closed class).
// The flow transfers drop path narrows on the same events as path
// presence narrows: a possibly-storing call kills all path narrows; a
// heap store kills getter-bearing path narrows; a store to a field the
// path reads through kills paths through that field; reassigning the
// root kills its paths.

use Std = IO.Std;

class ANIMAL is
    name: string public;
    init(name: string) is
        self.name = name;
    si
si

class CAT: ANIMAL is
    init(name: string) is
        super.init(name);
    si

    meow() -> string => "meow ({name})";
si

class DOG: ANIMAL is
    init(name: string) is
        super.init(name);
    si

    bark() -> string => "bark ({name})";
si

class BOX is
    animal: ANIMAL public;
    counter: int public;

    init(a: ANIMAL) is
        animal = a;
    si

    poke() is
        counter = counter + 1;
    si
si

isa_narrows_path(b: BOX) is
    if isa CAT(b.animal) then
        Std.write_line("cat: {b.animal.meow()}");
    fi
si

if_let_narrows_path(b: BOX) is
    if let c: CAT = b.animal then
        Std.write_line("if let: {c.meow()}");
    fi
si

isa_then_property_read(b: BOX) is
    if isa CAT(b.animal) then
        Std.write_line("nested: {b.animal.name} / {b.animal.meow()}");
    fi
si

call_forgets_path_narrow(b: BOX) is
    if isa CAT(b.animal) then
        Std.write_line("before call: {b.animal.meow()}");
        b.poke();
        Std.write_line("after call: {b.animal.name}");
    fi
si

root_reassignment_forgets(b1: BOX, b2: BOX) is
    let r mut = b1;

    if isa CAT(r.animal) then
        Std.write_line("root: {r.animal.meow()}");
        r = b2;
        Std.write_line("after root reassign: {r.animal.name}");
    fi
si

entry() is
    let bc = BOX(CAT("felix"));
    let bd = BOX(DOG("rex"));

    isa_narrows_path(bc);
    if_let_narrows_path(bc);
    isa_then_property_read(bc);
    call_forgets_path_narrow(bc);
    root_reassignment_forgets(bc, bd);
si
