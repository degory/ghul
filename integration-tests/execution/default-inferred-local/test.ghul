namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // `let i = default` — no explicit type, no real value:
            // the type is inferred from a later assignment, exactly
            // as for a bare `let i`. Unlike `let i`, the binding
            // counts as definitely assigned, so neither the read
            // before the assignment nor `i` itself is warned.
            let i mut = default;

            Std.out.write_line("i before assign: {i}");

            i = 7;

            Std.out.write_line("i after assign: {i}");
        si
    si
si
