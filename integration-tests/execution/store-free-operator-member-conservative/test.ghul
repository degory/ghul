// When a source type declares an operator as a member, that operator
// applied to an operand whose type is not trivially derivable can no
// longer be bounded — the operand could be that type — so the function
// is conservatively not store-free and a literal calling it draws the
// impure-function-value warning. Soundness does not depend on the
// warning being heeded; the heap facts are dropped regardless.

use Std = IO.Std;

class VEC is
    n: int;
    init(n: int) is self.n = n; si
    +(other: VEC) -> VEC => VEC(n + other.n);
si

g(x: int) -> int => (x % 3) + 1;

apply(f: (int) -> int pure, x: int) -> int pure => f(x);

entry() is
    Std.write_line("{apply(i => g(i), 7)}");
    Std.write_line("{(VEC(1) + VEC(2)).n}");
si
