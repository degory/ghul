namespace Test is
    use IO.Std;

    // A self-applied function call `(f, x) => f(f(x))` calls a
    // placeholder-typed receiver inside a lambda body before the
    // outer call site has had a chance to back-feed the receiver's
    // type.
    //
    // Currently disabled and asserting "cannot infer type here" at
    // the lambda's arg-resolution step. The shape would resolve if
    // either (a) the outer body-retry fully reset lambda symbol
    // state before re-walking, so a later iteration could pick up
    // the back-fed type, or (b) closure-arg-resolution deferred its
    // "cannot infer type here" emission until the outer retry was
    // exhausted. Today the lambda's argument-symbol type-resolution
    // happens during the OUTER function's body walk — on the first
    // walk f's symbol has no constraints (outer back-feed hasn't
    // run yet) so the error is committed and the visit returns
    // before back-feed completes; subsequent re-walks skip closure
    // setup when the symbol already carries a placeholder type.

    class Main is
        entry() static is
            let times_2 = x => x * 2;
            let apply_twice = (f, x) => f(f(x));
            Std.write_line("{apply_twice(times_2, 5)}");
            return;
        si
    si
si
