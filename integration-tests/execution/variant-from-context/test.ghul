namespace Test is
    use IO.Std;

    // Tests: a union with generic type-parameter. The
    // variant BOTH carries the union's T. Calling BOTH(1, 2) — the
    // variant's T should be inferred to int from the concrete args,
    // and the result's static type should be OptionPair[int].

    union OptionPair[T] is
        NEITHER;
        BOTH(a: T, b: T);
    si

    describe[T](p: OptionPair[T]) -> string =>
        if isa OptionPair[T].NEITHER(p) then
            "neither";
        else
            let b = cast OptionPair[T].BOTH(p);
            "{b.a}, {b.b}";
        fi;

    class Main is
        entry() static is
            let p = OptionPair.BOTH(10, 20);
            Std.write_line(describe(p));
            return;
        si
    si
si
