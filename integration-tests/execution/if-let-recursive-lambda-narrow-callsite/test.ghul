namespace Test is
    use IO.Std;

    // `if let` inference parity with the hand-written
    // `if isa V(t) then let p = t in ...` form, for an unannotated
    // recursive-lambda parameter typed only by the call site.
    //
    // The lambda parameter `l` has no annotation; the binding
    // pattern `(head, tail): CONS` is the only narrowing test. For
    // this to compile, the body-retry loop must converge `l` to
    // `List[int]` (wide enough for both the destructure-on-CONS in
    // the then-arm and the `rec(tail)` call that passes a
    // `List[int]`-typed `tail`). The mechanism is the same as the
    // isa form's: the destructure on the still-INFERRED scrutinee
    // emits a `DESTRUCTURE_CONSTRAINT` onto `l`'s origin in iter 1;
    // iter 2 picks a LUB candidate that satisfies the constraint.
    //
    // The cast-desugar approach broke this because the destructure
    // saw the cast's typed value, not the scrutinee's INFERRED-typed
    // load, so the constraint never landed on `l`'s origin.
    union List[T] is
        NIL;
        CONS(head: T, tail: List[T]);
    si

    use List.NIL;
    use List.CONS;

    class Main is
        entry() static is
            let list = CONS(1, CONS(2, CONS(3, NIL[int]())));

            let stringify_list = l rec =>
                if let (head, tail): CONS = l then
                    "{head}, {rec(tail)}"
                else
                    "nil"
                fi;

            Std.write_line(stringify_list(list));
            return;
        si
    si
si
