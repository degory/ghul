use IO.Std.write_line;

entry() is
    // `rec` referenced from inside a nested closure (the () => ... thunk),
    // not directly in the outer recursive lambda's body. The outer
    // lambda IS marked `rec`. This is the generator-style pattern:
    // YIELD(..., () => rec(...)).
    let factorial = (n: int) -> int rec =>
        if n <= 1 then
            1
        else
            n * (() => rec(n - 1))()
        fi;

    write_line("factorial(0) is {factorial(0)}");
    write_line("factorial(1) is {factorial(1)}");
    write_line("factorial(5) is {factorial(5)}");
si
