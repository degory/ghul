class MARK: System.Attribute is
    label: string public;

    init(label: string) is
        self.label = label;
    si
si

class MARK[T]: System.Attribute is
    init() is si
si

@MARK("hello")
class TARGET is
    init() is si
si

entry() static is
    for a in (typeof TARGET).get_custom_attributes(false) do
        if let mark: MARK = a then
            IO.Std.write_line("mark: {mark.label}");
        fi
    od

    return;
si
