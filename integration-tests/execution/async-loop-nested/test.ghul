namespace Test is
    use Std = IO.Std;

    // Phase 1 — nested loops: outer for + inner for, both async,
    // both share the same enclosing T_ret. RETURN from the inner
    // body must propagate up through the outer body's _LOOP_RESULT
    // and stop the outer loop. CONTINUE from inner just falls
    // through to the next outer iteration.
    //
    // Hand-desugared form of:
    //     find(xs: List[int], ys: List[int], target: int) -> TASK[int] is
    //         for x in xs do
    //             for y in ys do
    //                 let await px = double_async(x);
    //                 let await py = double_async(y);
    //                 if px + py == target then
    //                     return px * 100 + py;
    //                 fi
    //             od
    //         od
    //         return -1;
    //     si

    enum _LOOP_RESULT_TYPE is CONTINUE, BREAK, RETURN si

    struct _LOOP_RESULT[T] is
        type: _LOOP_RESULT_TYPE;
        value: T;

        init() is si

        init(type: _LOOP_RESULT_TYPE, value: T) is
            self.type = type;
            self.value = value;
        si
    si

    class _FOR_EACH_DRIVER[T_elem, T_ret] is
        _iter: Collections.Iterator[T_elem];
        _body: T_elem -> Tasks.TASK[_LOOP_RESULT[T_ret]];
        _tcs: Tasks.TaskCompletionSource[_LOOP_RESULT[T_ret]];
        _on_complete_callback: (Tasks.TASK[_LOOP_RESULT[T_ret]]) -> void;

        init(
            iter: Collections.Iterator[T_elem],
            body: T_elem -> Tasks.TASK[_LOOP_RESULT[T_ret]]
        ) is
            _iter = iter;
            _body = body;
            _tcs = Tasks.TaskCompletionSource[_LOOP_RESULT[T_ret]]();
            _on_complete_callback = t => on_complete(t);
        si

        start() -> Tasks.TASK[_LOOP_RESULT[T_ret]] is
            pump();
            return _tcs.task;
        si

        pump() is
            try
                while _iter.move_next() do
                    let body_task = _body(_iter.current);
                    if !body_task.is_completed then
                        body_task.continue_with(_on_complete_callback);
                        return;
                    fi
                    if handle_result(body_task) then return; fi
                od
                _tcs.set_result(_LOOP_RESULT[T_ret]());
            catch ex: System.Exception
                _tcs.set_exception(ex);
            yrt
        si

        on_complete(t: Tasks.TASK[_LOOP_RESULT[T_ret]]) is
            if handle_result(t) then return; fi
            pump();
        si

        handle_result(t: Tasks.TASK[_LOOP_RESULT[T_ret]]) -> bool is
            if t.is_faulted then
                _tcs.set_exception(t.exception);
                return true;
            fi
            let r = t.result;
            if r.type == _LOOP_RESULT_TYPE.RETURN \/ r.type == _LOOP_RESULT_TYPE.BREAK then
                _tcs.set_result(r);
                return true;
            fi
            return false;
        si
    si

    class Main is
        double_async(x: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => x * 2
            );

        // Outer loop body — for each x, run inner loop. If inner
        // returned, propagate; otherwise continue outer.
        outer_body(x: int, ys: Collections.List[int], target: int)
            -> Tasks.TASK[_LOOP_RESULT[int]] static is
            let inner = _FOR_EACH_DRIVER[int, int](
                ys.iterator,
                y is
                    let await px = double_async(x);
                    let await py = double_async(y);
                    if px + py == target then
                        Std.write_line("inner: hit px={px} py={py}");
                        return _LOOP_RESULT[int](_LOOP_RESULT_TYPE.RETURN, px * 100 + py);
                    fi
                    Std.write_line("inner: x={x} y={y}");
                    return _LOOP_RESULT[int]();
                si
            );

            let await inner_result = inner.start();

            if inner_result.type == _LOOP_RESULT_TYPE.RETURN then
                return inner_result;
            fi
            // inner CONTINUE → outer CONTINUE
            return _LOOP_RESULT[int]();
        si

        entry() static is
            let xs: Collections.List[int] = [1, 2, 3];
            let ys: Collections.List[int] = [10, 20, 30];

            // target = 2*2 + 2*20 = 4 + 40 = 44; should hit at x=2, y=20.
            let outer = _FOR_EACH_DRIVER[int, int](
                xs.iterator,
                x => outer_body(x, ys, 44)
            );
            let r = outer.start().result;
            Std.write_line("final.type={r.type} value={r.value}");
        si
    si
si
