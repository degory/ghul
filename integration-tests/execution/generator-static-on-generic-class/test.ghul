namespace Test is
    use Std = IO.Std;

    class Container[T] is
        // Static method on a generic class — uses Container's T in
        // its signature and body. The state-machine class captures
        // Container's T as a class-level type-parameter (even though
        // the method itself isn't declared `static [T]`).
        items(items: Collections.Iterable[T]) -> Collections.Iterable[T] static is
            for x in items do
                yield x;
            od
        si
    si

    class Main is
        entry() static is
            for v in Container[int].items([1, 2, 3]) do
                Std.write_line("int: {v}");
            od

            for s in Container[string].items(["a", "b"]) do
                Std.write_line("str: {s}");
            od
        si
    si
si
