namespace Test is
    use IO.Std;

    // Variant-complement narrowing on the else edge of `if let`. The
    // else arm references `t` directly (the bound name is out of
    // scope), and the access `t.value` must resolve against the
    // complement variant of the union, not the original wide union
    // — `value` is only on `LEAF`, not on `Tree`. Mirrors the
    // variant branch of `isa V(t)`'s else narrowing.
    union Tree[T] is
        LEAF(value: T);
        NODE(left: Tree[T], right: Tree[T]);
    si

    use Tree.LEAF;
    use Tree.NODE;

    class Main is
        entry() static is
            // Two-variant union: `if let ...: NODE = t then ... else
            // t.value fi` requires `t` to narrow to `LEAF` in the
            // else arm for `t.value` to resolve. Test runs on a
            // value of each variant.
            describe(LEAF[int](42));
            describe(NODE[int](LEAF[int](1), LEAF[int](2)));
        si

        describe[T](t: Tree[T]) static is
            if let (left, right): NODE = t then
                Std.out.write_line("node");
                describe(left);
                describe(right);
            else
                Std.out.write_line("leaf: {t.value}");
            fi
        si
    si
si
