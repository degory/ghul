namespace Test is
    use IO.Std;

    // S inferred from the first positional arg constrains the
    // lambda parameter in a later positional arg of the same call:
    //
    //     init(initial: S, generator: S -> (S, T))
    //
    // The lambda's `state` argument resolves to S without an
    // annotation.

    class GENERATOR[T, S] is
        _initial: S;
        _state: S;
        _generator: S -> (S, T);
        current: T;

        init(initial: S, generator: S -> (S, T)) is
            _initial = initial;
            _generator = generator;
            _state = initial;
        si

        move_next() -> bool is
            (_state, current) = _generator(_state);
            return true;
        si
    si

    class Main is
        entry() static is
            let g = GENERATOR(
                (0, 1),
                state =>
                    let
                        (prev, current) = state,
                        next = prev + current
                    in
                        ((current, next), next)
            );

            g.move_next();
            g.move_next();
            g.move_next();
            Std.write_line("{g.current}");
            return;
        si
    si
si
