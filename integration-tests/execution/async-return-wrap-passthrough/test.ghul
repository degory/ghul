namespace Test is
    use Std = IO.Std;

    class Main is
        // When the expression already has type TASK[int], the type
        // matches and no wrap should fire. Verifies that explicit
        // Tasks.TASK.from_result(...) calls aren't double-wrapped.
        compute() -> Tasks.TASK[int] static is
            return Tasks.TASK.from_result(99);
        si

        entry() static is
            let task = compute();
            Std.write_line("got={task.result}");
        si
    si
si
