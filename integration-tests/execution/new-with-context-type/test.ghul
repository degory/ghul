namespace Test is
    use IO.Std;
    use Collections.LIST;

    class BOX[T] is
        v: T public;
        init() is si
        init(v: T) is self.v = v; si
    si

    class Main is
        entry() static is
            let xs: LIST[int] = new();
            xs.add(1);
            xs.add(2);
            Std.write_line("xs.count={xs.count}");

            let b: BOX[int] = new(42);
            Std.write_line("b.v={b.v}");
            return;
        si
    si
si
