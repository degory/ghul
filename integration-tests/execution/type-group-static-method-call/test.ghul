namespace Test is
    use Std = IO.Std;

    // `Tasks.TASK` reflects as a TYPE_GROUP (non-generic + Task`1).
    // A static-method access must collapse the group to the bare
    // member before reaching IR; previously crashed with an ICE
    // (TYPE_GROUP isn't TypeTyped, so `member.left.value.type` was null).
    class CAPTURING is
        _value: int;

        init() is
            _value = 42;

            Tasks.TASK.run(
                () is
                    Std.write_line("captured={_value}");
                si
            ).wait();
        si
    si

    class Main is
        entry() static is
            CAPTURING();
        si
    si
si
