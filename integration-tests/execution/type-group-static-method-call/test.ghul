namespace Test is
    use Std = IO.Std;

    // `System.Threading.Tasks.Task` reflects as a TYPE_GROUP holding
    // both the non-generic and the generic variants. A static-method
    // access (`Task.run(...)`) must collapse the group to the bare
    // member before reaching IR; previously the chain crashed with an
    // ICE because TYPE_GROUP isn't TypeTyped, so `member.left.value`
    // came back with a null `type`.
    class CAPTURING is
        _value: int;

        init() is
            _value = 42;

            System.Threading.Tasks.Task.run(
                () is
                    Std.write_line("captured={_value}");
                si
            ).wait();
        si
    si

    class Main is
        entry() static is
            CAPTURING();
        si
    si
si
