use IO.Std.write_line;

class BOX is
    contents: int;

    init(contents: int) is
        self.contents = contents;
    si

    describe() -> string => "box of {contents}";
si

probe(present: bool) -> BOX? =>
    if present then
        BOX(7);
    else
        null;
    fi;

entry() is
    let maybe = probe(true);

    // unguarded dereference of a `BOX?` — would warn, but the
    // build sets `--no-warn-null-deref`, so no diagnostic is emitted
    write_line(maybe.describe());

    // guarded by `?` — the flow analysis proves it present, no warn
    if maybe? then
        write_line(maybe.describe());
    fi

    // explicit `!` — the unwrap takes responsibility, no warn
    // (`! .` spaced so `!.` is not lexed as one operator)
    write_line(maybe! .describe());

    // `if let` binds a present value — no warn inside the arm
    if let g = probe(true) then
        write_line(g.describe());
    fi
si
