// Fact-lifetime rules for member-path and field presence facts, and
// the walk-order holes they close: a possibly-storing call forgets
// every path and every field or property fact — including a call
// inside the very condition that establishes a fact, inside a nested
// condition, or inside a loop body, where the branch environments
// derive from a snapshot taken before the walk. A store through
// `receiver.member` forgets the member's facts on every receiver —
// the written receiver may alias the one the fact was proven on. A
// heap store forgets getter-bearing paths but spares fields-only
// paths. An assert's else-message is only evaluated on the failure
// path, so what it calls does not invalidate what the passing
// condition proves.

use Std = IO.Std;

class NODE is
    _next: NODE?;
    _peer: NODE?;
    _bump: int;
    tag: string? public;

    init(next: NODE?, peer: NODE?, t: string?) is
        _next = next;
        _peer = peer;
        tag = t;
    si

    poke() is
        _bump = _bump + 1;
    si

    keep(nudge: bool) -> bool is
        _bump = _bump + 1;
        return nudge;
    si

    after_call() is
        if _next? then
            poke();
            Std.write_line("after call: {_next.tag}");
        fi
    si

    conjunct_kill() is
        if _next? /\ keep(true) then
            Std.write_line("conjunct: {_next.tag}");
        fi
    si

    nested_condition_kill() is
        if _next? then
            if keep(true) then
                Std.write_line("nested: {_next.tag}");
            fi
        fi
    si

    loop_body_kill() is
        if _next? then
            for i in 0..2 do
                poke();
            od

            Std.write_line("loop: {_next.tag}");
        fi
    si

    assert_message_is_benign() is
        assert _next? else "bumped {keep(false)}";

        Std.write_line("assert kept: {_next.tag}");
    si

    alias_member_store(other: NODE) is
        if _next? then
            other._next = null;
            Std.write_line("alias: {_next.tag}");
        fi
    si

    field_path_facts(other: NODE) is
        if _next? /\ _next._peer? then
            // a store to an unrelated field spares a fields-only path
            other._bump = 1;

            Std.write_line("deep: {_next._peer.tag}");

            // a store to a field the path reads through kills it,
            // whatever receiver it goes through
            other._peer = null;

            Std.write_line("deep after: {_next._peer.tag}");
        fi
    si

    getter_path_dies_on_heap_store(other: NODE) is
        if _next? /\ _next.tag? then
            other._bump = 1;

            Std.write_line("getter path: {_next.tag.length}");
        fi
    si
si

entry() is
    let leaf = NODE(null, null, "leaf");
    let mid = NODE(leaf, leaf, "mid");
    let root = NODE(mid, mid, "root");
    let bystander = NODE(NODE(null, null, "b"), null, "bystander");

    root.after_call();
    root.conjunct_kill();
    root.nested_condition_kill();
    root.loop_body_kill();
    root.assert_message_is_benign();
    root.alias_member_store(bystander);
    root.field_path_facts(bystander);
    root.getter_path_dies_on_heap_store(bystander);
si
