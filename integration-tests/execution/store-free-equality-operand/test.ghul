// A named function classifies store-free when its only heap-relevant
// content is equality on a compound operand. `==` and `!=` carry one
// compiler-generated implementation and admit no member operator, so
// the operand's type never has to be trivially derivable to bound
// them — `(i & 1)` here is not, yet the function still proves
// store-free. A literal calling it then satisfies a pure
// function-typed parameter without an impure-function-value warning.

use Std = IO.Std;

is_even(i: int) -> bool => (i & 1) == 0;

apply(f: (int) -> bool pure, x: int) -> bool pure => f(x);

entry() is
    Std.write_line("{apply(i => is_even(i), 4)}");
    Std.write_line("{apply(i => is_even(i), 7)}");
si
