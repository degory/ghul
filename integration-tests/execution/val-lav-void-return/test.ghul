use IO.Std.write_line;

// Bare `return;` inside a void-tolerant val-block (expression-
// statement position) exits the block early, skipping side effects
// that follow.
early_exit(skip: bool) is
    val
        if skip then
            write_line("early returning");
            return;
        fi
        write_line("doing work");
        write_line("more work");
    lav;
si

// Same shape as `=>` body of a void-returning function.
void_body(skip: bool) =>
    val
        if skip then
            return;
        fi
        write_line("body work");
    lav;

entry() is
    early_exit(true);
    early_exit(false);

    void_body(true);
    void_body(false);
si
