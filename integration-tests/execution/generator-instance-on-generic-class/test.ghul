namespace Test is
    use Std = IO.Std;

    // Generator on an instance method of a *generic class*. The
    // state-machine class needs to capture the enclosing class's
    // type-parameters into its own class-level generics so the
    // body's `T` (which is WRAPPER's T) resolves correctly inside
    // MoveNext.
    class WRAPPER[T] is
        value: T;

        init(v: T) is value = v; si

        repeat(n: int) -> Ghul.Pipes.Pipe[T] is
            let i mut = 0;
            while i < n do
                yield value;
                i = i + 1;
            od
        si
    si

    class Main is
        entry() static is
            let wi = WRAPPER[int](42);
            for v in wi.repeat(3) do
                Std.write_line("int: {v}");
            od

            let ws = WRAPPER[string]("hi");
            for s in ws.repeat(2) do
                Std.write_line("str: {s}");
            od
        si
    si
si
