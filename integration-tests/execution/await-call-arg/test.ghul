namespace Test is
    use Std = IO.Std;
    class Main is
        twice(x: int) -> int static => x * 2;

        compute() -> Tasks.TASK[int] static is
            return twice(await Tasks.TASK.from_result(21));
        si

        entry() static is
            Std.write_line("got={compute().result}");
        si
    si
si
