namespace Test is
    use Std = IO.Std;

    // A bare `null` literal passed as a call argument to a value-type
    // optional parameter is the empty optional, not a null reference.
    // The constraint that drives the `null`->empty-optional lowering
    // reaches a `return` or a `let` but not a call argument, so the
    // coercion happens at the boxing boundary. A plain `ldnull` into a
    // `Nullable<T>` slot is invalid IL.
    class HOLDER is
        value: int?;

        init(value: int?) is
            super.init();
            self.value = value;
        si
    si

    class Main is
        // Parameter is `int?`; the call site passes a bare `null`.
        describe(value: int?) -> string static =>
            if value? then "present:{value!}" else "absent" fi;

        entry() static is
            Std.out.write_line("method: {describe(null)}");

            let h = HOLDER(null);
            Std.out.write_line("ctor: {if h.value? then "present:{h.value!}" else "absent" fi}");
        si
    si
si
