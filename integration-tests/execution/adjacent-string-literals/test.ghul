namespace Test is
    use IO.Std;

    entry() is
        let x = 42;

        // plain + plain
        Std.write_line("Hello, "
                       "world.");

        // plain + interpolated
        Std.write_line("answer: "
                       "is {x}!");

        // interpolated + plain
        Std.write_line("answer is {x}"
                       " (end)");

        // interpolated + interpolated
        Std.write_line("first {x}"
                       " then {x + 1}");

        // three plain literals across lines
        Std.write_line("Line 1 "
                       "Line 2 "
                       "Line 3");

        // escape sequences span pieces correctly
        Std.write_line("tab:\t"
                       "between");

        // empty fragment between
        Std.write_line("a"
                       ""
                       "b");
    si
si
