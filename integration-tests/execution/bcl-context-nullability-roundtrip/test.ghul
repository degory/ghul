// Pin that BCL `?` annotations carried by an enclosing
// `NullableContextAttribute` (rather than a per-slot
// `NullableAttribute`) reach ghūl. Without context reading, every
// position the BCL relies on the context default for reflects as
// non-`?`, which produces spurious "null where non-optional expected"
// warnings on perfectly-legal BCL call shapes.

use Std = IO.Std;

class Main is
    entry() static is
        // `string.is_null_or_empty(string? value)` — the parameter
        // accepts null. With per-slot-only reading the parameter
        // reflects as non-`?` and passing a `string?` local needs
        // a guard first. With context-attribute reading it works.
        let maybe_name: string? = null;

        if string.is_null_or_empty(maybe_name) then
            Std.write_line("empty");
        else
            Std.write_line("not empty");
        fi

        // `AggregateException.inner_exception` returns `Exception?`.
        // The narrow + `!` shape pins that the BCL-declared `?` reaches
        // ghūl as a real optional, not as plain Exception.
        let agg = System.AggregateException("outer", System.InvalidOperationException("boom"));
        let inner = agg.inner_exception;

        if inner? then
            Std.write_line("inner: {inner!.message}");
        else
            Std.write_line("no inner");
        fi
    si
si
