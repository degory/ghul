namespace Test is
    use IO.Std;

    // Tests: a let-bound lambda that references itself
    // recursively via `rec`. The lambda's return type depends on
    // itself; current inference treats this as a forward reference
    // and can't resolve without a use-site type annotation.
    //
    // Per existing memory: rec-lambda return-type inference is a
    // known-deferred case that needs use-site context.

    class Main is
        entry() static is
            // Standard form requires explicit param type:
            //     let fac = (n: int) rec => if n == 0 then 1 else n * rec(n - 1) fi;
            // Tests: can we infer `n` from the body (n == 0 needs
            // an int operand on the other side, n * rec(...) ditto)?
            let fac = n rec => if n == 0 then 1 else n * rec(n - 1) fi;
            Std.write_line("{fac(5)}");
            return;
        si
    si
si
