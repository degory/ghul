namespace Test is
    use IO.Std;

    class BOX: System.IComparable[BOX], System.IEquatable[BOX] is
        _v: int;
        init(v: int) is _v = v; si
        compare_to(other: BOX) -> int => _v - other._v;
        equals(other: BOX) -> bool => _v == other._v;
    si

    class Main is
        entry() static is
            let a = BOX(3);
            let b = BOX(5);
            let c: System.IComparable[BOX] = a;
            Std.write_line("{c.compare_to(b)}");
            let e: System.IEquatable[BOX] = a;
            Std.write_line("{e.equals(b)}");
            Std.write_line("{e.equals(BOX(3))}");
            return;
        si
    si
si
