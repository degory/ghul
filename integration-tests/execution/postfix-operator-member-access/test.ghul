use IO.Std.write_line;

entry() is
    let present: int? = OPTION[int](42);

    // `!.` lexes as postfix unwrap `!` followed by member access `.`,
    // not as a single `!.` operator.
    write_line(present!.to_string());

    // `?.` lexes the same way: postfix has-value `?` then member access.
    // `present?` is a bool here — this is not null-coalescing access.
    write_line(present?.to_string());
si
