namespace Test is
    use Std = IO.Std;

    class Main is
        // Named async + non-async lambda (Case 1)
        compute() -> Tasks.TASK[int] static is
            let x = await Tasks.TASK.from_result(7);
            let f = (y: int) => y * 2;
            return f(x);
        si

        entry() static is
            let r = compute();
            Std.write_line("got={r.result}");
        si
    si
si
