namespace Test is
    use IO.Std;

    trait Printer is print() -> string; si

    union List[T] is
        NIL;
        CONS(head: T, tail: List[T]);
    si

    impl Printer for List[T] is
        print() -> string =>
            if let (head, tail): CONS = self then
                "{head} {tail.print()}"
            else
                "nil"
            fi;
    si

    class Main is
        entry() static is
            let xs = List.CONS(1, List.CONS(2, List.CONS(3, List.NIL[int]())));
            let p: Printer = xs;
            Std.write_line(p.print());
            return;
        si
    si
si
