use IO.Std.write_line;

union Option[T] is
    SOME(value: T);
    NONE;
si

union Result[T,E] is
    OK(value: T);
    ERROR(error: E, code: int);
si

entry() is
    // =~ on primitives
    let s1 = Option.SOME(42);
    let s2 = Option.SOME(42);
    let s3 = Option.SOME(43);
    let n1 = Option.NONE[int]();
    let n2 = Option.NONE[int]();
    write_line(s1 =~ s2);
    write_line(s1 =~ s3);
    write_line(n1 =~ n2);
    let o1: Option[int] = s1;
    let o2: Option[int] = n1;
    write_line(o1 =~ o2);

    // =~ on string fields (uses string equality, not reference)
    let str1 = Option.SOME("hello");
    let str2 = Option.SOME("hello");
    let str3 = Option.SOME("world");
    write_line(str1 =~ str2);
    write_line(str1 =~ str3);

    // Multi-field variants
    let e1 = Result.ERROR[int,string]("oops", 42);
    let e2 = Result.ERROR[int,string]("oops", 42);
    let e3 = Result.ERROR[int,string]("oops", 43);
    write_line(e1 =~ e2);
    write_line(e1 =~ e3);

    // Recursive: nested unions, dispatched through Equals(object)
    let nn1 = Option.SOME[Option[int]](Option.SOME(42));
    let nn2 = Option.SOME[Option[int]](Option.SOME(42));
    let nn3 = Option.SOME[Option[int]](Option.SOME(43));
    write_line(nn1 =~ nn2);
    write_line(nn1 =~ nn3);

    // Object.Equals (.NET interop) override is in place
    write_line((cast object(s1)).equals(cast object(s2)));
    write_line((cast object(s1)).equals(cast object(n1)));

    // Hash codes consistent with equality
    write_line(s1.get_hash_code() == s2.get_hash_code());
    write_line(n1.get_hash_code() == n2.get_hash_code());
    write_line(s1.get_hash_code() != n1.get_hash_code());

    // Use as a Collections.MAP key — exercises Equals + GetHashCode together
    let map = Collections.MAP[Option[int], string]();
    map[Option.SOME(1)] = "one";
    map[Option.SOME(2)] = "two";
    map[Option.NONE[int]()] = "none";
    write_line(map.count);
    write_line(map[Option.SOME(1)]);
    write_line(map[Option.NONE[int]()]);
si
