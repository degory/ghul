namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.reduce[TRunning,TOut]`
    // in `ghul-runtime/src/pipe.ghul`:
    //   reduce[TRunning,TOut](
    //       seed: TRunning,
    //       accumulator: (TRunning,T) -> TRunning,
    //       mapper: (TRunning) -> TOut
    //   ) -> TOut
    //
    // Three type variables, but only TWO have sibling concrete
    // actuals driving them:
    //   - T from the pipe         → int
    //   - TRunning from `0`        → int
    //   - TOut from the mapper's
    //     return                  → string (from interpolation)
    //
    // The accumulator lambda's two formals come from already-
    // bound TRunning + T. The mapper lambda's formal comes from
    // already-bound TRunning. Should resolve cleanly.

    class Main is
        entry() static is
            let xs = [10, 20, 30, 40];

            let summary = xs | .reduce(
                0,
                (acc, x) => acc + x,
                running => "sum is {running}");

            Std.write_line(summary);

            return;
        si
    si
si
