namespace Test is
    use Std = IO.Std;

    class Main is
        // Void async — uses let-await internally to qualify
        run() -> Tasks.TASK static is
            let x = await Tasks.TASK.from_result(5);
            Std.write_line("got {x}");
            return;
        si

        entry() static is
            let t = run();
            t.wait();
            Std.write_line("done");
        si
    si
si
