namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Recursive closure that mutates a captured local
            // on every recursive call. The box is captured once
            // (when f's frame is built); every recursive
            // invocation shares the same cell, so the
            // accumulator accumulates across calls.
            let total mut = 0;

            let f = (n: int) -> int rec is
                if n <= 0 then
                    return total;
                fi
                total = total + n;
                return rec(n - 1);
            si;

            let result = f(5);

            Std.write_line("result = {result}");
            Std.write_line("total  = {total}");
        si
    si
si
