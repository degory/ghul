
namespace Test is
    use Std = IO.Std;

    class Main is
        // break and continue inside a state-split loop.  continue
        // TRANSITIONs back to the header; break TRANSITIONs to the
        // exit state.
        skip_evens_until(limit: int) -> Collections.Iterable[int] static is
            let i mut = 0;
            while true do
                i = i + 1;
                if i >= limit then
                    break;
                fi
                if i % 2 == 0 then
                    continue;
                fi
                yield i;
            od
        si

        entry() static is
            let total mut = 0;
            for x in skip_evens_until(10) do
                total = total + x;
            od
            Std.write_line("total={total}");
        si
    si
si
