namespace Ghul.Generators is
    enum _GEN_STEP_KIND is
        DONE,
        YIELD,
        TRANSITION,
    si

    struct _GEN_STEP[T] is
        kind: _GEN_STEP_KIND;
        value: T;
        next_state: int;

        init() is si

        init(kind: _GEN_STEP_KIND, value: T, next_state: int) is
            self.kind = kind;
            self.value = value;
            self.next_state = next_state;
        si
    si

    class _GEN_DRIVER[T]: Collections.Iterable[T], Collections.Iterator[T] is
        _states: Collections.List[() -> _GEN_STEP[T]];
        _state_index: int;
        _current: T;
        _done: bool;

        init(states: Collections.List[() -> _GEN_STEP[T]]) is
            _states = states;
            _state_index = 0;
            _done = false;
        si

        iterator: Collections.Iterator[T] => self;
        current: T => _current;

        move_next() -> bool is
            if _done then return false; fi
            while true do
                let step = _states[_state_index]();
                if step.kind == _GEN_STEP_KIND.DONE then
                    _done = true;
                    return false;
                elif step.kind == _GEN_STEP_KIND.YIELD then
                    _current = step.value;
                    _state_index = step.next_state;
                    return true;
                else
                    _state_index = step.next_state;
                fi
            od
            return false;
        si

        reset() is
            _state_index = 0;
            _done = false;
        si

        dispose() is si
    si

    _gen_pipe[T](states: Collections.List[() -> _GEN_STEP[T]])
        -> Collections.Iterable[T]
    =>
        _GEN_DRIVER[T](states);
si

namespace Test is
    use Std = IO.Std;

    class Main is
        // break and continue inside a state-split loop.  continue
        // TRANSITIONs back to the header; break TRANSITIONs to the
        // exit state.
        skip_evens_until(limit: int) -> Collections.Iterable[int] static is
            let i mut = 0;
            while true do
                i = i + 1;
                if i >= limit then
                    break;
                fi
                if i % 2 == 0 then
                    continue;
                fi
                yield i;
            od
        si

        entry() static is
            let total mut = 0;
            for x in skip_evens_until(10) do
                total = total + x;
            od
            Std.write_line("total={total}");
        si
    si
si
