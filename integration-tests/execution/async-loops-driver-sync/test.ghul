namespace Test is
    use Std = IO.Std;

    // Phase 0 driver-class POC. All helpers inlined; this is the
    // shape we'll later promote to Ghul.Async per the async-loops
    // design doc.

    enum LOOP_RESULT_TYPE is
        CONTINUE,
        BREAK,
        RETURN,
    si

    struct LOOP_RESULT[T] is
        type: LOOP_RESULT_TYPE;
        value: T;

        init() is
        si

        init(type: LOOP_RESULT_TYPE, value: T) is
            self.type = type;
            self.value = value;
        si
    si

    class FOR_EACH_DRIVER[T_elem, T_ret] is
        _iter: Collections.Iterator[T_elem];
        _body: T_elem -> Tasks.TASK[LOOP_RESULT[T_ret]];
        _tcs: Tasks.TaskCompletionSource[LOOP_RESULT[T_ret]];
        _on_complete_callback: (Tasks.TASK[LOOP_RESULT[T_ret]]) -> void;

        init(
            iter: Collections.Iterator[T_elem],
            body: T_elem -> Tasks.TASK[LOOP_RESULT[T_ret]]
        ) is
            _iter = iter;
            _body = body;
            _tcs = Tasks.TaskCompletionSource[LOOP_RESULT[T_ret]]();
            _on_complete_callback = t => on_complete(t);
        si

        start() -> Tasks.TASK[LOOP_RESULT[T_ret]] is
            pump();
            return _tcs.task;
        si

        pump() is
            try
                while _iter.move_next() do
                    let body_task = _body(_iter.current);
                    if !body_task.is_completed then
                        body_task.continue_with(_on_complete_callback);
                        return;
                    fi
                    if handle_result(body_task) then return; fi
                od
                _tcs.set_result(LOOP_RESULT[T_ret]());
            catch ex: System.Exception
                _tcs.set_exception(ex);
            yrt
        si

        on_complete(t: Tasks.TASK[LOOP_RESULT[T_ret]]) is
            if handle_result(t) then return; fi
            pump();
        si

        handle_result(t: Tasks.TASK[LOOP_RESULT[T_ret]]) -> bool is
            if t.is_faulted then
                _tcs.set_exception(t.exception);
                return true;
            fi
            let r = t.result;
            if r.type == LOOP_RESULT_TYPE.RETURN \/ r.type == LOOP_RESULT_TYPE.BREAK then
                _tcs.set_result(r);
                return true;
            fi
            return false;
        si
    si

    class Main is
        entry() static is
            // Case 1: body always returns CONTINUE; loop falls through.
            let xs: Collections.List[int] = [1, 2, 3];
            let driver1 = FOR_EACH_DRIVER[int, int](
                xs.iterator,
                x => Tasks.TASK.from_result(LOOP_RESULT[int]())
            );
            let r1 = driver1.start().result;
            Std.write_line("case1.type={r1.type} value={r1.value}");

            // Case 2: body returns RETURN(42) on the second element.
            let driver2 = FOR_EACH_DRIVER[int, int](
                xs.iterator,
                x => if x == 2 then
                    Tasks.TASK.from_result(LOOP_RESULT[int](LOOP_RESULT_TYPE.RETURN, 42))
                else
                    Tasks.TASK.from_result(LOOP_RESULT[int]())
                fi
            );
            let r2 = driver2.start().result;
            Std.write_line("case2.type={r2.type} value={r2.value}");

            // Case 3: body throws on the second element.
            let driver3 = FOR_EACH_DRIVER[int, int](
                xs.iterator,
                x => if x == 2 then
                    throw System.InvalidOperationException("boom on x=2");
                else
                    Tasks.TASK.from_result(LOOP_RESULT[int]())
                fi
            );
            try
                let _ = driver3.start().result;
                Std.write_line("UNEXPECTED no exception");
            catch ae: System.AggregateException
                Std.write_line("case3.caught inner={ae.inner_exception.message}");
            yrt

            // Case 4: empty iterator — should produce CONTINUE result.
            let empty: Collections.List[int] = [];
            let driver4 = FOR_EACH_DRIVER[int, int](
                empty.iterator,
                x => Tasks.TASK.from_result(LOOP_RESULT[int]())
            );
            let r4 = driver4.start().result;
            Std.write_line("case4.type={r4.type} value={r4.value}");
        si
    si
si
