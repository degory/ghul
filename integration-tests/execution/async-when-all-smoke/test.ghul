namespace Test is
    use Std = IO.Std;

    class Main is
        produce(value: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.run(
                () -> int is
                    return value;
                si
            );

        entry() static is
            let tasks: Collections.List[Tasks.TASK[int]] = [
                produce(10),
                produce(20),
                produce(30),
                produce(40)
            ];

            let combined =
                Tasks.TASK.when_all(tasks).continue_with(
                    (t: Tasks.TASK[int[]]) -> int is
                        let total mut = 0;
                        for v in t.result do
                            total = total + v;
                        od

                        return total;
                    si
                );

            Std.write_line("when_all.sum={combined.result}");
        si
    si
si
