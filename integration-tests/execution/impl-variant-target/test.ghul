namespace Test is
    use IO.Std;

    trait Printer is print() -> string => "?"; si

    union LIST[E] is
        NIL;
        CONS(head: E, tail: LIST[E]);
    si

    impl Printer for LIST.NIL is
        print() -> string => "nil";
    si

    class Main is
        entry() static is
            let p: Printer = LIST.NIL[int];
            Std.write_line(p.print());
            return;
        si
    si
si
