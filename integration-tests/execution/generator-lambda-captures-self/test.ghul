namespace Test is
    use Std = IO.Std;

    class Counter is
        _base: int;
        init(base: int) is
            _base = base;
        si

        // Instance generator with self-capturing lambda
        gen() -> Collections.Iterable[int] is
            let add = (n: int) => _base + n;   // captures self via _base
            yield add(1);
            yield add(2);
            yield add(3);
        si
    si

    class Main is
        entry() static is
            let c = Counter(10);
            for x in c.gen() do
                IO.Std.write_line("got {x}");
            od
        si
    si
si
