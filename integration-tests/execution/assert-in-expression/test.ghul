namespace Test is
    use Std = IO.Std;

    use System.Exception;

    class Main is
        entry() static is
            run("passing assert yields inner expression value", () -> void is
                let s = assert 1 + 1 == 2 else "math broken" in "ok";
                Std.out.write_line(s);
            si);

            run("failing assert throws with else message", () -> void is
                let s = assert 1 + 1 == 3 else "math broken" in "never reached";
                Std.out.write_line(s);
            si);

            run("assert with no else throws with condition as message", () -> void is
                let s = assert 1 == 2 in "never reached";
                Std.out.write_line(s);
            si);

            run("inner expression value flows out as the function result", () -> void is
                Std.out.write_line(passing(5));
            si);

            run("failing assert in expression-body throws", () -> void is
                Std.out.write_line(passing(0));
            si);

            run("assert-in chains with let-in", () -> void is
                let result =
                    assert 4 > 0 else "should be positive" in
                    let doubled = 4 * 2 in
                    "doubled = {doubled}";
                Std.out.write_line(result);
            si);

            run("inner expression evaluation is skipped when assert fails", () -> void is
                let s =
                    assert false else "expected fail" in
                    side_effect();
                Std.out.write_line(s);
            si);

            run("assert narrows optional for inner expression", () -> void is
                Std.out.write_line(length_of("hello"));
            si);

            run("assert-in inside expression-body, value flows up the chain", () -> void is
                Std.out.write_line(classify(42));
            si);
        si

        passing(n: int) -> string static =>
            assert n > 0 else "n must be positive" in
            "n is {n}";

        side_effect() -> string static is
            Std.out.write_line("side-effect ran");
            return "side-effect result";
        si

        length_of(s: string?) -> string static =>
            assert s? else "s is null" in
            "length = {s.length}";

        classify(n: int) -> string static =>
            assert n >= 0 else "negative" in
            if n == 0 then "zero" elif n % 2 == 0 then "even" else "odd" fi;

        run(description: string, test: () -> void) static is
            try
                Std.out.write_line(description);
                test();
                Std.out.write_line("did not throw");
            catch ex: Exception
                Std.out.write_line("threw: {ex.get_type().name} {ex.message}");
            finally
                Std.out.write_line();
            yrt
        si
    si
si
