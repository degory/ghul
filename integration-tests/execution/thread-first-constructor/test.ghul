namespace Test is
    use IO.Std;

    // Tests: a `|>` whose right-hand side is a constructor call threads
    // the subject in as the constructor's first argument, resolving the
    // constructor exactly as written. Covers a non-generic constructor
    // (subject as the first of several arguments), owner type-argument
    // inference from the threaded subject, a two-parameter generic with
    // both arguments inferred, and a constructor result threaded onward
    // into a free function.

    class POINT is
        x: int public;
        y: int public;
        init(x: int, y: int) is
            self.x = x;
            self.y = y;
        si
        to_string() -> string => "({x},{y})";
    si

    class WRAP[T] is
        value: T public;
        init(value: T) is self.value = value; si
    si

    class PAIR[T,U] is
        first: T public;
        second: U public;
        init(first: T, second: U) is
            self.first = first;
            self.second = second;
        si
    si

    describe(p: POINT) -> string => "point {p}";

    class MAIN is
        entry() static is
            Std.write_line("{10 |> POINT(20)}");
            let w = 42 |> WRAP();
            Std.write_line("{w.value}");
            let p = 123 |> PAIR("hello");
            Std.write_line("{p.first} {p.second}");
            Std.write_line("{1 |> POINT(2) |> describe()}");
        si
    si
si
