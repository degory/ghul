namespace Test is
    use Std = IO.Std;

    trait Marker is
        flag: bool => false;
    si

    class MID: Marker is
        flag: bool => super.flag;
        init() is si
    si

    class LEAF: MID is
        flag: bool => true;
        init() is si
    si

    class Main is
        entry() static is
            let m = MID();
            let l = LEAF();
            Std.write_line("MID.flag = {m.flag}");
            Std.write_line("LEAF.flag = {l.flag}");
        si
    si
si
