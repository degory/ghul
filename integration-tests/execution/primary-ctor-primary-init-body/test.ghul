namespace Test is
    use Std = IO.Std;

    class COUNTER(start: int) is
        _start;
        _count: int;

        init(..) is
            _count = _start;
            Std.write_line("counter primed at {_count}");
        si

        bump() is
            _count = _count + 1;
        si

        show() is
            Std.write_line("count = {_count}");
        si
    si

    class Main is
        entry() static is
            let c = COUNTER(10);
            c.bump();
            c.bump();
            c.show();
        si
    si
si
