namespace Test is
    use IO.Std;
    use Collections;

    // Tests: lambda body uses indexer `xs[0]` on a
    // placeholder parameter. ghūl desugars `xs[0]` to a get_at
    // call. Triggers MEMBER_DEMAND on xs's placeholder for get_at.

    class Main is
        entry() static is
            let f = xs => xs[0];
            let v = f([10, 20, 30]);
            Std.write_line("{v}");
            return;
        si
    si
si
