namespace Test is








    use Std = IO.Std;

    class Main is
        entry() static is
            

            let o: object mut;
            let t: THING mut;

            o = THING();
            t = THING();

            Std.out.write_line(o.to_string());
            Std.out.write_line(t.to_string());
        si
    si

    class THING is
        init() is si

        @IL.name("ToString")
        to_string() -> string is
            return "A thing";            
        si
    si
si



