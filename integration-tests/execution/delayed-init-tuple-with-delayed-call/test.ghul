namespace Test is
    use Std = IO.Std;
    use Collections.List;

    class Main is
        entry() static is
            // Fuzz finding 05: both bindings delayed-init, v18's
            // tuple init contains a call to the delayed-init
            // lambda. On iter 1 the call (against a still-
            // unresolved v8) returned DUMMY(ERROR) and v18's LUB
            // recorded `(ERROR, int)`. On iter 2 the refined
            // tuple value `(int, int)` failed to land because
            // `_try_get_assignment_left_type` short-circuited on
            // ERROR-bearing LHS types — the back-feed never ran
            // and the per-position LUB merge would have preferred
            // ERROR over the placeholder side anyway. Without
            // the fix, `.locals init (ValueTuple`2 <!!!, int>
            // 'v18.1')` reached IL emission and ICE'd on
            // ERROR.gen_type.
            let v8;
            v8 = (v7: List[int]) => 11;
            let v18;
            v18 = (v8([19]), 78 * 35 - 77 - 47);

            Std.write_line("v18 = {v18}");

            return;
        si
    si
si
