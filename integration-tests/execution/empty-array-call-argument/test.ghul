f(xs: string[]) static is
    IO.Std.write_line("count {xs.count}");
si

g[T](xs: T[], fallback: T) -> T static is
    if xs.count > 0 then
        return xs[0];
    fi

    return fallback;
si

entry() static is
    f([]);
    f([ ]);
    f(["a", "b"]);

    IO.Std.write_line("g {g([], 42)}");

    return;
si
