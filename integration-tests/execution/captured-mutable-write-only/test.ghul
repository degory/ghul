namespace Test is
    use Std = IO.Std;

    class Main is
        run_it(f: () -> void) static is
            f();
        si

        entry() static is
            // A closure that only writes a captured mut local (never
            // reads it) must still share the mutation with the enclosing
            // scope. Exercised in both closure positions: assigned to a
            // local, and passed directly as a call argument.
            let a: string? mut = null;

            let write_a = () is
                a = "A";
            si;

            write_a();
            Std.write_line("a = {a}");

            let b: string? mut = null;

            run_it(
                () is
                    b = "B";
                si
            );

            Std.write_line("b = {b}");
        si
    si
si
