namespace Ghul.Generators is
    enum _GEN_STEP_KIND is
        DONE,
        YIELD,
        TRANSITION,
    si

    struct _GEN_STEP[T] is
        kind: _GEN_STEP_KIND;
        value: T;
        next_state: int;

        init() is si

        init(kind: _GEN_STEP_KIND, value: T, next_state: int) is
            self.kind = kind;
            self.value = value;
            self.next_state = next_state;
        si
    si

    class _GEN_DRIVER[T]: Collections.Iterable[T], Collections.Iterator[T] is
        _states: Collections.List[() -> _GEN_STEP[T]];
        _state_index: int;
        _current: T;
        _done: bool;

        init(states: Collections.List[() -> _GEN_STEP[T]]) is
            _states = states;
            _state_index = 0;
            _done = false;
        si

        iterator: Collections.Iterator[T] => self;
        current: T => _current;

        move_next() -> bool is
            if _done then return false; fi
            while true do
                let step = _states[_state_index]();
                if step.kind == _GEN_STEP_KIND.DONE then
                    _done = true;
                    return false;
                elif step.kind == _GEN_STEP_KIND.YIELD then
                    _current = step.value;
                    _state_index = step.next_state;
                    return true;
                else
                    _state_index = step.next_state;
                fi
            od
            return false;
        si

        reset() is
            _state_index = 0;
            _done = false;
        si

        dispose() is si
    si

    _gen_pipe[T](states: Collections.List[() -> _GEN_STEP[T]])
        -> Collections.Iterable[T]
    =>
        _GEN_DRIVER[T](states);
si

namespace Test is
    use Std = IO.Std;
    use Ghul.Generators;

    class Main is
        // The state lambdas are let-bound rather than passed
        // inline as `states.add(() -> ... is ... si)` — the
        // inline form fails capture detection for a/b/tmp on
        // the second closure (likely a box-capture-pass gap).
        fibs(limit: int) -> Collections.Iterable[int] static is
            let a mut = 0;
            let b mut = 1;
            let tmp mut = 0;

            let header = () -> _GEN_STEP[int] is
                if a < limit then
                    return _GEN_STEP[int](_GEN_STEP_KIND.YIELD, a, 1);
                else
                    return _GEN_STEP[int]();
                fi
            si;

            let body = () -> _GEN_STEP[int] is
                tmp = a + b;
                a = b;
                b = tmp;
                return _GEN_STEP[int](_GEN_STEP_KIND.TRANSITION, 0, 0);
            si;

            let states = Collections.LIST[() -> _GEN_STEP[int]]();
            states.add(header);
            states.add(body);

            return _gen_pipe(states);
        si

        entry() static is
            let total mut = 0;
            for x in Main.fibs(100) do
                total = total + x;
            od
            Std.write_line("total={total}");

            let empty_states = Collections.LIST[() -> _GEN_STEP[int]]();
            empty_states.add(() -> _GEN_STEP[int] => _GEN_STEP[int]());
            let count mut = 0;
            for x in _gen_pipe(empty_states) do
                count = count + 1;
            od
            Std.write_line("empty_count={count}");
        si
    si
si
