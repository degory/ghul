// A field narrowed by a presence guard is plain storage a callee can
// reach through `self` and reassign, so the narrow cannot survive a
// call: a method, a custom-body property getter, a user operator all
// drop it. The exceptions keep it — an intrinsic operation (built-in
// arithmetic), a plain field access, and an effectively-final
// auto-property getter (structurally pure: it just returns a backing
// field, so it reassigns nothing). A local is unreachable to a callee
// and always keeps its narrow. The receiver of an assignment target is
// read before the right-hand side, so a call there does not null it.

use IO.Std;

class BOX is
    v: int public;                 // auto-property: pure getter
    label: int => v * 2;           // custom-body property: not pure
    init() is si
    touch() -> int => v;
    side() -> int => 1;
si

class HOLDER is
    _b: BOX?;
    _o: BOX;

    init() is _b = BOX(); _o = BOX(); si

    single() -> int is
        if _b? then return _b.touch(); fi
        return -1;
    si

    after_method() -> int is
        if _b? then let n = _o.side(); return _b.touch(); fi
        return -1;
    si

    after_custom_getter() -> int is
        if _b? then let n = _o.label; return _b.touch(); fi
        return -1;
    si

    after_auto_getter() -> int is
        if _b? then let n = _o.v; return _b.touch(); fi
        return -1;
    si

    after_intrinsic() -> int is
        if _b? then let n = 1 + 2; return _b.touch(); fi
        return -1;
    si

    assign_then_read() -> int is
        if _b? then _b.v = side_free(); return _b.touch(); fi
        return -1;
    si

    side_free() -> int => 9;

    local_survives(b: BOX?) -> int is
        if b? then let n = side_free(); return b.touch(); fi
        return -1;
    si
si

class Main is
    entry() static is
        let h = HOLDER();
        Std.write_line("{h.single()}");
        Std.write_line("{h.after_method()}");
        Std.write_line("{h.after_custom_getter()}");
        Std.write_line("{h.after_auto_getter()}");
        Std.write_line("{h.after_intrinsic()}");
        Std.write_line("{h.assign_then_read()}");
        Std.write_line("{h.local_survives(BOX())}");
    si
si
