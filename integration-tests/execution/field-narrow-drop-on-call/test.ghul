// A field narrowed by a presence guard is plain storage a callee can
// reach through `self` and reassign, so the narrow cannot survive a
// call. Any real call drops it — a method, a property getter, a
// user operator — while an intrinsic operation (built-in arithmetic)
// and accesses with no intervening call keep it. A local is
// unreachable to a callee and keeps its narrow. The receiver of an
// assignment target is read before the right-hand side, so a call
// there does not make it null.

use IO.Std;

class BOX is
    v: int public;
    prop: int => v;
    init() is si
    touch() -> int => v;
si

class HOLDER is
    _b: BOX?;
    _other: BOX;

    init() is _b = BOX(); _other = BOX(); si

    side() -> int => 1;

    single() -> int is
        if _b? then
            return _b.touch();
        fi
        return -1;
    si

    after_method() -> int is
        if _b? then
            let n = side();
            return _b.touch();
        fi
        return -1;
    si

    after_getter() -> int is
        if _b? then
            let n = _other.prop;
            return _b.touch();
        fi
        return -1;
    si

    after_intrinsic() -> int is
        if _b? then
            let n = 1 + 2;
            return _b.touch();
        fi
        return -1;
    si

    assign_target() is
        if _b? then
            _b.v = side();
        fi
    si

    assign_then_read() -> int is
        if _b? then
            _b.v = side();
            return _b.touch();
        fi
        return -1;
    si

    local_survives(b: BOX?) -> int is
        if b? then
            let n = side();
            return b.touch();
        fi
        return -1;
    si
si

class Main is
    entry() static is
        let h = HOLDER();
        Std.write_line("{h.single()}");
        Std.write_line("{h.after_method()}");
        Std.write_line("{h.after_getter()}");
        Std.write_line("{h.after_intrinsic()}");
        h.assign_target();
        Std.write_line("{h.assign_then_read()}");
        Std.write_line("{h.local_survives(BOX())}");
    si
si
