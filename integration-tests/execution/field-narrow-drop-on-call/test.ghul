// A field narrowed by a presence guard is plain storage a callee
// could reach through `self` and reassign, so the narrow survives a
// call only when the callee provably performs no store to any
// pre-existing heap location — directly or through anything the call
// could dispatch to. Provable, so the narrow survives: intrinsic
// operations, field and auto-property reads, and methods or custom
// getters whose bodies only read and call other provably store-free
// functions, including mutually recursive ones. Not provable, so the
// narrow still drops: a callee that stores, a callee with an
// override that stores, a method on an `open` class (another
// assembly could override it with a store), a delegate invocation,
// and an imported function. A local is unreachable to a callee and
// always keeps its narrow.

use IO.Std;

class BOX is
    v: int public;                 // auto-property: store-free getter
    label: int => v * 2;           // custom getter over store-free reads
    init() is si
    touch() -> int => v;
    side() -> int => 1;
    ping(n: int) -> int => if n > 0 then pong(n - 1) else 0 fi;
    pong(n: int) -> int => if n > 0 then ping(n - 1) else 0 fi;

    bump() -> int is
        v = v + 1;
        return v;
    si
si

class QUIET is
    init() is si
    calm() -> int => 5;
si

class NOISY: QUIET is
    n: int public;
    init() is si

    // storing override: calls bound to QUIET.calm may dispatch here
    calm() -> int is
        n = n + 1;
        return n;
    si
si

class LOUD open is
    init() is si
    shout() -> int => 3;           // store-free body, but openly overridable
si

class HOLDER is
    _b: BOX?;
    _o: BOX;
    _q: QUIET;
    _l: LOUD;

    init() is
        _b = BOX();
        _o = BOX();
        _q = QUIET();
        _l = LOUD();
    si

    single() -> int is
        if _b? then return _b.touch(); fi
        return -1;
    si

    after_method() -> int is
        if _b? then let n = _o.side(); return _b.touch(); fi
        return -1;
    si

    after_custom_getter() -> int is
        if _b? then let n = _o.label; return _b.touch(); fi
        return -1;
    si

    after_auto_getter() -> int is
        if _b? then let n = _o.v; return _b.touch(); fi
        return -1;
    si

    after_intrinsic() -> int is
        if _b? then let n = 1 + 2; return _b.touch(); fi
        return -1;
    si

    after_mutual_recursion() -> int is
        if _b? then let n = _o.ping(3); return _b.touch(); fi
        return -1;
    si

    assign_then_read() -> int is
        if _b? then _b.v = side_free(); return _b.touch(); fi
        return -1;
    si

    side_free() -> int => 9;

    local_survives(b: BOX?) -> int is
        if b? then let n = side_free(); return b.touch(); fi
        return -1;
    si

    after_store() -> int is
        if _b? then let n = _o.bump(); return _b.touch(); fi
        return -1;
    si

    after_storing_override() -> int is
        if _b? then let n = _q.calm(); return _b.touch(); fi
        return -1;
    si

    after_open_class_method() -> int is
        if _b? then let n = _l.shout(); return _b.touch(); fi
        return -1;
    si

    after_delegate(f: () -> int) -> int is
        if _b? then let n = f(); return _b.touch(); fi
        return -1;
    si

    after_imported() -> int is
        if _b? then let n = "abc".index_of('b'); return _b.touch(); fi
        return -1;
    si
si

class Main is
    entry() static is
        let h = HOLDER();
        Std.write_line("{h.single()}");
        Std.write_line("{h.after_method()}");
        Std.write_line("{h.after_custom_getter()}");
        Std.write_line("{h.after_auto_getter()}");
        Std.write_line("{h.after_intrinsic()}");
        Std.write_line("{h.after_mutual_recursion()}");
        Std.write_line("{h.assign_then_read()}");
        Std.write_line("{h.local_survives(BOX())}");
        Std.write_line("{h.after_store()}");
        Std.write_line("{h.after_storing_override()}");
        Std.write_line("{h.after_open_class_method()}");
        Std.write_line("{h.after_delegate(() -> int => 7)}");
        Std.write_line("{h.after_imported()}");
    si
si
