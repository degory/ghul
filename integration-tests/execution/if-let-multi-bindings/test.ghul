namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            both_present(some_string("a"), some_int(1));
            both_present(null, some_int(1));
            both_present(some_string("a"), null);
            both_present(null, null);

            chained_through_first(Holder(Inner("inner")));
            chained_through_first(Holder(null));
            chained_through_first(null);

            narrow_then_destructure(Pair("k", 42));
            narrow_then_destructure(null);

            guards_interleave(Holder(Inner("ok")));
            guards_interleave(Holder(Inner("bad")));
            guards_interleave(Holder(null));

            with_ascription_chain(Cat("Felix"), Cat("Whiskers"));
            with_ascription_chain(Cat("Felix"), Dog("Rex"));
            with_ascription_chain(Dog("Rex"), Cat("Felix"));
        si

        // Two bare bindings: both initializers must be non-null.
        // Independent — neither references the other.
        both_present(s: string?, i: int?) static is
            if let str = s, n = i then
                Std.out.write_line("both: {str} {n}");
            else
                Std.out.write_line("missing");
            fi
        si

        // The second clause reads the first clause's binding —
        // demonstrates the value flowing left-to-right.
        chained_through_first(h: Holder?) static is
            if let outer = h, inner = outer.value then
                Std.out.write_line("got inner: {inner.label}");
            else
                Std.out.write_line("no inner");
            fi
        si

        // Mix: bare presence test on the first clause, destructure
        // on the second. The second clause destructures the first
        // clause's binding directly — a destructure pattern over
        // the narrowed (non-null) value.
        narrow_then_destructure(p: Pair?) static is
            if let q = p, (k, v) = q then
                Std.out.write_line("entry: {k} -> {v}");
            else
                Std.out.write_line("no entry");
            fi
        si

        // Per-clause guard on the second clause: the second clause's
        // bindings come into scope, then its `/\` guard runs against
        // them. A failing guard short-circuits to the else arm even
        // though both presence tests succeeded.
        guards_interleave(h: Holder?) static is
            if let outer = h, inner = outer.value /\ inner.label =~ "ok" then
                Std.out.write_line("ok: {inner.label}");
            else
                Std.out.write_line("rejected");
            fi
        si

        // Ascriptions on two unrelated scrutinees; both must narrow.
        with_ascription_chain(a: Animal, b: Animal) static is
            if let c: Cat = a, d: Cat = b then
                Std.out.write_line("two cats: {c.name} and {d.name}");
            else
                Std.out.write_line("not two cats");
            fi
        si

        some_string(s: string) -> string? static => s;
        some_int(n: int) -> int? static => n;
    si

    class Holder is
        value: Inner?;

        init(value: Inner?) is
            self.value = value;
        si
    si

    class Inner is
        label: string;

        init(label: string) is
            self.label = label;
        si
    si

    class Pair is
        `0: string field;
        `1: int field;

        init(k: string, v: int) is
            `0 = k;
            `1 = v;
        si
    si

    class Animal is
        name: string;

        init(name: string) is
            self.name = name;
        si
    si

    class Cat: Animal is
        init(name: string) is
            super.init(name);
        si
    si

    class Dog: Animal is
        init(name: string) is
            super.init(name);
        si
    si
si
