namespace Test is
    use IO.Std;
    use Collections;

    // Tests: an array literal supplied directly to a
    // generic function whose formal is `Iterable[T]`. The compiler
    // must read T from the array's element type (.NET's covariance
    // gives `int[] <: Iterable[int]`). Stripped from ghul-runtime
    // patterns where array literals fan into Pipe.from(xs).map(...)
    // chains.
    //
    // Pinned because regressing this would break a *lot* of caller
    // code with confusing "no overload found" errors.

    fn[T](xs: Iterable[T]) -> int is
        let count = 0;
        for x in xs do count = count + 1; od
        return count;
    si

    class Main is
        entry() static is
            Std.write_line("ints={fn([1, 2, 3])}");
            Std.write_line("chars={fn(['a', 'b'])}");
            return;
        si
    si
si
