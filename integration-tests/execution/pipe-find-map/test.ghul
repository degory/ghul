namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.find_map[U]` in
    // `ghul-runtime/src/pipe.ghul`:
    //   find_map[U](mapper: (T) -> MAYBE[U]) -> MAYBE[U]
    //
    // The lambda's return type is a generic wrapper `MAYBE[U]`
    // whose U comes from the constructor argument inside the
    // body. The pipe's element type T flows down into the
    // lambda arg; U flows up from the lambda's body to the
    // outer find_map type-args.
    //
    // Three inference paths combined:
    //   - T from `[1,2,3] | ...` → lambda arg is int
    //   - U from `MAYBE(n.to_string())` → U = string
    //   - Outer type from find_map[string] → MAYBE[string]

    class Main is
        entry() static is
            let xs = [1, 2, 3, 4, 5];

            let found = xs | .find_map(n =>
                if n > 3 then
                    MAYBE(n.to_string())
                else
                    MAYBE[string]()
                fi);

            if found? then
                Std.write_line("found={found!}");
            else
                Std.write_line("not found");
            fi

            return;
        si
    si
si
