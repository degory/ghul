namespace Test is
    use Std = IO.Std;
    class Box is
        v: int public;
        init(v: int) is self.v = v; si
    si

    class Main is
        get_value() -> Tasks.TASK[int] static => Tasks.TASK.from_result(42);

        compute() -> Tasks.TASK[int] static is
            let b = new Box(await get_value());
            return b.v;
        si

        entry() static is
            Std.write_line("got={compute().result}");
        si
    si
si
