namespace Test is
    use Std = IO.Std;

    class Main is
        boom(value: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.run(
                () -> int is
                    if value < 0 then
                        throw System.InvalidOperationException("negative seed: {value}");
                    fi
                    return value * 2;
                si
            );

        entry() static is
            let chained =
                Tasks.TaskExtensions.unwrap(
                    boom(-5).continue_with(
                        (t1: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                            Tasks.TASK.from_result(t1.result + 1000)
                    )
                );

            try
                let value = chained.result;
                Std.write_line("unexpectedly got value={value}");
            catch ex: System.AggregateException
                let inner = ex.inner_exception;
                if inner? then
                    Std.write_line("caught: {inner.message}");
                else
                    Std.write_line("caught aggregate with no inner");
                fi
            yrt
        si
    si
si
