use IO.Std.write_line;

// `val ... lav` in expression position (NOT a function body) whose
// body has every reachable path diverging via val-targeted returns.
// The "expected a value" check on the body LIST is suppressed when
// `_flow.is_unreachable` at end of body, so this works even though
// the last statement (a let here) does not itself provide a value.
// The block's value is the LUB of the returns.
classify(n: int) -> int is
    let label = val
        if n < 0 then
            return -1;
        fi
        if n == 0 then
            return 0;
        fi
        return 1;
        let unreachable = 99;
    lav;

    return label + 100;
si

entry() is
    write_line("classify(-3) = {classify(-3)}");
    write_line("classify(0) = {classify(0)}");
    write_line("classify(5) = {classify(5)}");
si
