use IO.Std.write_line;

// `val ... lav` whose body contains a `try ... yrt`. The try has
// no val-targeted return inside it, so nothing crosses its
// protected region — the try opens, runs to completion, the
// finally fires, and the val-block continues past the try with
// its tail expression supplying the value.
divide_safely(n: int, d: int) -> int is
    let result = val
        let accumulator mut = -1;
        try
            accumulator = n / d;
            write_line("computed {n}/{d} = {accumulator}");
        catch e: System.DivideByZeroException
            accumulator = 0;
            write_line("caught divide-by-zero");
        finally
            write_line("finally ran");
        yrt
        accumulator
    lav;

    return result + 100;
si

// Try-around-val with try-inside-val on a separate path — outer
// try sits around the val-block (no boundary issue, no val-target
// crosses it), inner try is in val-block body without crossing.
nested_trys(n: int) -> int is
    try
        return val
            try
                write_line("inner work for {n}");
            yrt
            n * 5
        lav;
    catch e: System.Exception
        return -1;
    yrt
si

entry() is
    write_line("divide_safely(20, 4) = {divide_safely(20, 4)}");
    write_line("divide_safely(10, 0) = {divide_safely(10, 0)}");
    write_line("nested_trys(3) = {nested_trys(3)}");
si
