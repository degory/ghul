use IO.Std.write_line;

union STEP[T] is
    DONE;
    YIELD(value: T, rest: () -> STEP[T]);
si

use STEP.DONE;
use STEP.YIELD;

// Pin two related behaviours:
// 1. `DONE()` (no payload, no explicit type arg) pins T from the
//    surrounding function's return type — this used to leave STEP[ERROR]
//    that crashed IL emission, but works correctly today.
// 2. `let r = rec in` captures the recursive self-reference so a nested
//    () => ... thunk can call back into the lambda — without it, `rec`
//    is only in scope of the immediately-enclosing function literal.
entry() is
    let counting = n -> STEP[int] rec =>
        let r = rec in
        if n == 0 then
            DONE()
        else
            YIELD(n, () => r(n - 1))
        fi;

    let fib_step = (prev: int, current: int) -> STEP[int] rec =>
        let r = rec in
        YIELD(current, () => r(current, prev + current));

    write_line("counting(0).is_done is {counting(0).is_done}");
    write_line("counting(1).is_yield is {counting(1).is_yield}");
    write_line("fib_step(0, 1).is_yield is {fib_step(0, 1).is_yield}");
si
