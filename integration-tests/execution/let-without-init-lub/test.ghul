namespace Test is
    use IO.Std;

    class ANIMAL is
        init() is si
        say() -> string => "animal";
    si

    class CAT: ANIMAL is
        init() is super.init(); si
        say() -> string => "meow";
    si

    class DOG: ANIMAL is
        init() is super.init(); si
        say() -> string => "woof";
    si

    class Main is
        entry() static is
            let pet mut;
            let b = true;
            if b then
                pet = CAT();
            else
                pet = DOG();
            fi
            Std.write_line(pet.say());
            return;
        si
    si
si
