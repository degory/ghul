namespace Test is
    use IO.Std;

    class Animal is
        init() is si
        say() -> string => "animal";
    si

    class Cat: Animal is
        init() is super.init(); si
        say() -> string => "meow";
    si

    class Dog: Animal is
        init() is super.init(); si
        say() -> string => "woof";
    si

    class Main is
        entry() static is
            let pet;
            let b = true;
            if b then
                pet = Cat();
            else
                pet = Dog();
            fi
            Std.write_line(pet.say());
            return;
        si
    si
si
