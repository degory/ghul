namespace Test is
    use IO.Std;
    use Collections.LIST;

    // Iterative-inference probe: chained generic methods where each
    // step's lambda argument type must be inferred from the
    // previous step's element type. Stresses back-feed under
    // generic specialisation: filter[T](pred: T -> bool) and
    // map[T,U](f: T -> U) need their lambda arg types inferred
    // from the receiver's element type at each step.
    class Main is
        entry() static is
            let xs = [1, 2, 3];
            for s in xs | .filter(x => x > 0) .map(y => y.to_string()) do
                Std.write_line(s);
            od
            return;
        si
    si
si
