namespace Test is
    use Std = IO.Std;

    class Main is
        double_async(x: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => x * 2
            );

        // **REAL** for-loop source with `return X;` inside the body.
        // The desugar must wrap that return as _LOOP_RESULT[int](RETURN, X)
        // so it propagates through the _for_async chain back to
        // the enclosing function. Exercises
        // LOOP_RESULT_CONVERSION.wrap_returns_in_body.
        //
        // Returns the first doubled value that exceeds the threshold.
        // For threshold=15 the loop hits x=10 (y=20) and returns 20.
        find_first_above(
            xs: Collections.List[int],
            threshold: int
        ) -> Tasks.TASK[int] static is
            for x in xs do
                let await y = double_async(x);
                Std.write_line("body: x={x} y={y}");
                if y > threshold then
                    Std.write_line("returning y={y}");
                    return y;
                fi
            od
            Std.write_line("no match");
            return -1;
        si

        entry() static is
            // Hit at first element (x=10, y=20 > 15).
            let xs: Collections.List[int] = [10, 20, 30];
            let result1 = find_first_above(xs, 15).result;
            Std.write_line("result1={result1}");

            // No match — y values are 20, 40, 60; all > 100 false.
            let result2 = find_first_above(xs, 100).result;
            Std.write_line("result2={result2}");
        si
    si
si
