namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let times_2 = x => x * 2;

            // Curried: outer `f` and inner `x` both need to be inferred from the call sites.
            // The outer `f` resolves cleanly; the inner `x` requires the outer's return-type
            // slot (a Function whose argument slot is the inner placeholder) to refresh after
            // earlier walks see resolved phantoms.
            let create_apply_twice = f => x => f(f(x));
            let apply_twice_times_2 = create_apply_twice(times_2);
            Std.write_line("apply_twice_times_2(5) = {apply_twice_times_2(5)}");
        si
    si
si
