namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Positional tuple members are named by index; a numeric member
            // name is reached by backtick-escaping the index.
            let p = (10, 20, 30);

            Std.write_line("{p.`0} {p.`1} {p.`2}");
        si
    si
si
