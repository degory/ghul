namespace Test is
    use Std = IO.Std;

    class Main is
        // `counter` is `let mut`, captured by every continuation
        // lambda DESUGAR_AWAIT synthesises (one per `let await`).
        // Three `let await`s produce three nested synthesised
        // closures, each capturing `counter` and reassigning it.
        // mark-boxed-locals should box `counter`; the box
        // reference must flow through each nested continuation
        // frame as a BOX[int] capture (multi-level inter-frame
        // transfer — the bug fixed in the PR feedback round).
        compute() -> Tasks.TASK[int] static is
            let counter mut = 0;

            let await a = Tasks.TASK.from_result(10);
            counter = counter + a;

            let await b = Tasks.TASK.from_result(20);
            counter = counter + b;

            let await c = Tasks.TASK.from_result(30);
            counter = counter + c;

            return Tasks.TASK.from_result(counter);
        si

        entry() static is
            let result = compute();

            Std.write_line("counter = {result.result}");
        si
    si
si
