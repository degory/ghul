namespace Test is
    use Std = IO.Std;

    class Main is
        // `counter` is `let mut`, reassigned after each of three
        // `await`s in a single async-classified function body.
        // The reassignments must survive across the suspension
        // points (each `await` resumes into a fresh frame, but
        // the mutable local must read and write the same storage).
        compute() -> Tasks.TASK[int] static is
            let counter mut = 0;

            let a = await Tasks.TASK.from_result(10);
            counter = counter + a;

            let b = await Tasks.TASK.from_result(20);
            counter = counter + b;

            let c = await Tasks.TASK.from_result(30);
            counter = counter + c;

            return counter;
        si

        entry() static is
            let result = compute();

            Std.write_line("counter = {result.result}");
        si
    si
si
