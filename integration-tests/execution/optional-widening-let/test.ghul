namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // T → T? implicit widening at the typed-let boundary:
            // `42` is a non-optional `int`, the slot is `int?` — the
            // boxer emits a Nullable<int>::.ctor(int) wrap, no explicit
            // OPTION[int](...) needed.
            let widened: int? = 42;
            let absent: int? = null;

            Std.out.write_line("widened present: {widened?}");
            Std.out.write_line("widened value: {widened!}");
            Std.out.write_line("absent present: {absent?}");

            if let v = widened then
                Std.out.write_line("if let bound {v}");
            fi
        si
    si
si
