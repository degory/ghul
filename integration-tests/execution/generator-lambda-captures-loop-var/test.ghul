namespace Test is
    use Std = IO.Std;

    class Main is
        // Captured for-loop variable
        gen(items: Collections.Iterable[int]) -> Ghul.Pipes.Pipe[int] static is
            for item in items do
                let doubler = () => item * 2;
                yield doubler();
            od
        si

        entry() static is
            for x in gen([1, 2, 3, 4]) do
                Std.write_line("got {x}");
            od
        si
    si
si
