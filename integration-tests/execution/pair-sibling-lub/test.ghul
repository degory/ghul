namespace Test is
    use IO.Std;

    // Tests: a generic class taking two args of the
    // same T, with sibling subtypes. T should be inferred as the
    // LUB (Animal) so both Cat and Dog are accepted.
    //
    // GENERIC_ARGUMENT_BIND_RESULTS already has the LUB-on-conflict
    // logic; this exercises it end-to-end through a constructor call.

    class Animal is
        init() is si
        speak() -> string => "...";
    si

    class Cat: Animal is
        init() is si
        speak() -> string => "meow";
    si

    class Dog: Animal is
        init() is si
        speak() -> string => "woof";
    si

    class Pair[T] is
        a: T;
        b: T;
        init(a: T, b: T) is
            self.a = a;
            self.b = b;
        si
    si

    class Main is
        entry() static is
            let p = Pair(Cat(), Dog());
            Std.write_line("{p.a.speak()} {p.b.speak()}");
            return;
        si
    si
si
