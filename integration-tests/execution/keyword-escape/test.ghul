namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // A backtick escapes a keyword so it can be used as an
            // ordinary identifier; the name does not include the backtick.
            let `class = 42;
            let `if = `class + 1;

            Std.write_line("{`if}");

            // Escaping a non-keyword is a no-op: `value names the same
            // local as value.
            let value = 7;

            Std.write_line("{`value}");

            return;
        si
    si
si
