
use IO.Std.write_line;

class POINT is
    x: int public;
    y: int public;
    z: int public;

    init(x: int, y: int, z: int) is
        self.x = x;
        self.y = y;
        self.z = z;
    si
si

by_name_all() -> string is
    let p = POINT(1, 2, 3);
    let (x = x, y = y, z = z) = p;
    return "x={x} y={y} z={z}";
si

by_name_subset() -> string is
    let p = POINT(1, 2, 3);
    let (z = z, x = x) = p;
    return "z={z} x={x}";
si

by_name_rename() -> string is
    let p = POINT(1, 2, 3);
    let (px = x, py = y, pz = z) = p;
    return "px={px} py={py} pz={pz}";
si

by_name_tuple() -> string is
    let t: (first: int, second: int, third: int) = (10, 20, 30);
    let (third = third, first = first) = t;
    return "third={third} first={first}";
si

by_name_for() is
    let points = [POINT(1, 2, 3), POINT(4, 5, 6)];

    for (x = x, z = z) in points do
        write_line("for x={x} z={z}");
    od
si

entry() is
    write_line(by_name_all());
    write_line(by_name_subset());
    write_line(by_name_rename());
    write_line(by_name_tuple());
    by_name_for();
si
