namespace Test is
    use IO.Std;

    class Main is
        entry() static is
            let total = Ghul.BOX(0);

            let bump = (n: int) is
                total.value = total.value + n;
            si;

            bump(5);
            bump(10);
            bump(3);

            Std.write_line("{total.value}");
        si
    si
si
