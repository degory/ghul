namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let x = 5;
            mul(x ref);
            sub(x ref);
        si

        mul(p: int ref) static is
            let r = (p^) * 3;
            Std.out.write_line("mul: {r}");
        si

        sub(p: int ref) static is
            let r = (p^) - 1;
            Std.out.write_line("sub: {r}");
        si
    si
si
