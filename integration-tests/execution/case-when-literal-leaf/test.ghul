namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Literal leaves work the same way inside `case`-when
            // arm patterns — the shared PATTERN grammar lights up
            // for both constructs through the same machinery.
            show((1, "small"));
            show((42, "answer"));
            show((0, "zero"));
            show((7, "lucky"));
        si

        show(pair: (int, string)) static is
            case pair
            when (0, label) then
                Std.out.write_line("zero: {label}");
            when (42, label) then
                Std.out.write_line("answer: {label}");
            when (n, label) then
                Std.out.write_line("other {n}: {label}");
            esac
        si
    si
si
