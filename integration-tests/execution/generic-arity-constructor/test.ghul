namespace Test is
    use IO.Std;

    class Main is
        entry() static is
            // Collections.KeyValuePair collides with a non-generic static
            // KeyValuePair factory class at arity 0; a bare-name constructor
            // call must resolve to the generic KeyValuePair[K,V] and infer
            // its arguments.
            let kv = Collections.KeyValuePair("answer", 42);
            Std.write_line("{kv.key}={kv.value}");
            return;
        si
    si
si
