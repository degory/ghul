
use IO.Std.write_line;
use Collections.KeyValuePair;

look_up(dict: Collections.MAP[string, int], key: string) -> KeyValuePair[string, int]? is
    let value: int mut = 0;
    if dict.try_get_value(key, value ref) then
        return KeyValuePair[string, int](key, value);
    fi
    return null;
si

entry() is
    let dict = Collections.MAP[string, int]();
    dict.add("alpha", 1);
    dict.add("beta", 2);

    if let (k, v) = look_up(dict, "alpha") then
        write_line("got {k}={v}");
    else
        write_line("missing alpha");
    fi

    if let (k, v) = look_up(dict, "zeta") then
        write_line("got {k}={v}");
    else
        write_line("missing zeta");
    fi
si
