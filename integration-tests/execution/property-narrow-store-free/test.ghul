// A property whose getter is proven store-free narrows like a field:
// a presence guard or isa test on the bare property read holds until
// the heap may have changed. Re-reading such a getter under an
// unchanged heap repeats the same presence and dynamic-type answers,
// so the facts are sound. They die sooner than field facts, though —
// a getter can read arbitrary heap, so any state-changing call AND
// any direct heap store (even to an unrelated field) forgets them;
// field facts survive stores to other fields. A property whose
// getter cannot be proven store-free never narrows. Local stores
// invalidate nothing.

use IO.Std;

class BOX is
    v: int public;
    init() is si
    touch() -> int => v + 1;
    side() -> int => 1;
si

class ANIMAL is
    init() is si
si

class CAT: ANIMAL is
    init() is si
    meow() -> int => 42;
si

class HOLDER is
    _box: BOX?;
    _other: int;
    _pet: ANIMAL;

    // store-free getter: narrows
    current: BOX? => _box;

    // store-free getter over a closed hierarchy: isa-narrows
    pet: ANIMAL => _pet;

    // storing getter: never narrows
    counted: BOX? is
        _other = _other + 1;
        return _box;
    si

    init() is
        _box = BOX();
        _pet = CAT();
        _other = 0;
    si

    bump() -> int is
        _other = _other + 1;
        return _other;
    si

    presence_holds() -> int is
        if current? then return current.touch(); fi
        return -1;
    si

    isa_narrow_holds() -> int is
        if isa CAT(pet) then return pet.meow(); fi
        return -1;
    si

    presence_survives_store_free_call() -> int is
        if current? then let n = _box!.side(); return current.touch(); fi
        return -1;
    si

    presence_survives_local_store() -> int is
        if current? then
            let n mut = 1;
            n = 2;
            return current.touch() + n;
        fi
        return -1;
    si

    storing_getter_never_narrows() -> int is
        if counted? then return counted.touch(); fi
        return -1;
    si

    call_forgets_property() -> int is
        if current? then let n = bump(); return current.touch(); fi
        return -1;
    si

    heap_store_forgets_property() -> int is
        if current? then _other = 9; return current.touch(); fi
        return -1;
    si

    heap_store_keeps_field() -> int is
        if _box? then _other = 9; return _box.touch(); fi
        return -1;
    si
si

class Main is
    entry() static is
        let h = HOLDER();
        Std.write_line("{h.presence_holds()}");
        Std.write_line("{h.isa_narrow_holds()}");
        Std.write_line("{h.presence_survives_store_free_call()}");
        Std.write_line("{h.presence_survives_local_store()}");
        Std.write_line("{h.storing_getter_never_narrows()}");
        Std.write_line("{h.call_forgets_property()}");
        Std.write_line("{h.heap_store_forgets_property()}");
        Std.write_line("{h.heap_store_keeps_field()}");
    si
si
