namespace Test is
    use Std = IO.Std;

    class Main is
        delayed_step(initial: int, delta: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.run(
                () -> int is
                    return initial + delta;
                si
            );

        entry() static is
            let chained =
                Tasks.TaskExtensions.unwrap(
                    delayed_step(0, 1).continue_with(
                        (t1: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                            Tasks.TaskExtensions.unwrap(
                                delayed_step(t1.result, 10).continue_with(
                                    (t2: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                                        delayed_step(t2.result, 100)
                                )
                            )
                    )
                );

            Std.write_line("delayed_chain.result={chained.result}");
        si
    si
si
