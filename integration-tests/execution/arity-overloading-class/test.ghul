namespace Test is
    use Std = IO.Std;

    class FOO is
        init() is si

        kind() -> string => "non-generic";
    si

    class FOO[T] is
        init() is si

        kind() -> string => "generic";
    si

    class Main is
        entry() static is
            let zero = FOO();
            let one = FOO[int]();
            let two = FOO[string]();

            Std.write_line(zero.kind());
            Std.write_line(one.kind());
            Std.write_line(two.kind());

            return;
        si
    si
si
