class CARRY: System.Attribute is
    value: object public;

    init() is si

    init(v: object) is
        self.value = v;
    si
si

class CARRY_MANY: System.Attribute is
    values: object[] public;

    init(values: object[]) is
        self.values = values;
    si
si

@CARRY(5)
class POSITIONAL_INT is
    init() is si
si

@CARRY("hello")
class POSITIONAL_STRING is
    init() is si
si

@CARRY(-7)
class POSITIONAL_NEGATIVE is
    init() is si
si

@CARRY(value = true)
class NAMED_BOOL is
    init() is si
si

@CARRY(typeof POSITIONAL_INT)
class POSITIONAL_TYPEOF is
    init() is si
si

@CARRY(value = null)
class NAMED_NULL is
    init() is si
si

@CARRY_MANY([1, "two", true, -3])
class WITH_OBJECT_ARRAY is
    init() is si
si

show_one(name: string, instance: object) static is
    for a in instance.get_type().get_custom_attributes(false) do
        let c = cast CARRY(a);
        if c? then
            IO.Std.write_line("{name}: value=[{c.value}]");
        fi
    od
si

entry() static is
    show_one("POSITIONAL_INT", POSITIONAL_INT());
    show_one("POSITIONAL_STRING", POSITIONAL_STRING());
    show_one("POSITIONAL_NEGATIVE", POSITIONAL_NEGATIVE());
    show_one("NAMED_BOOL", NAMED_BOOL());
    show_one("POSITIONAL_TYPEOF", POSITIONAL_TYPEOF());
    show_one("NAMED_NULL", NAMED_NULL());

    for a in WITH_OBJECT_ARRAY().get_type().get_custom_attributes(false) do
        let many = cast CARRY_MANY(a);
        if many? then
            IO.Std.write_line("WITH_OBJECT_ARRAY: values=[{many.values[0]},{many.values[1]},{many.values[2]},{many.values[3]}]");
        fi
    od

    return;
si
