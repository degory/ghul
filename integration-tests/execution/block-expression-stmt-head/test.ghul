use IO.Std.write_line;

entry() is
    let a = (
        assert true else "always";
        42
    );
    write_line("a = {a}");

    let b = (
        let total mut = 0;
        for i in 1..4 do
            total = total + i;
        od;
        total
    );
    write_line("b = {b}");

    let c = (
        let n mut = 1;
        while n < 100 do
            n = n * 2;
        od;
        n
    );
    write_line("c = {c}");

    let d = (
        try
            write_line("guarded");
        catch e: System.Exception
            write_line("caught {e.message}");
        yrt;
        7
    );
    write_line("d = {d}");
si
