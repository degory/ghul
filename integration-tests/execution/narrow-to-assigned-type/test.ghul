namespace Test is
    use IO.Std;

    class ANIMAL is
        init() is si
        name() -> string => "animal";
    si

    class CAT: ANIMAL is
        init() is super.init(); si
        purr() -> string => "purr";
    si

    class DOG: ANIMAL is
        init() is super.init(); si
        bark() -> string => "woof";
    si

    class Main is
        entry() static is
            go(1);
        si

        go(which: int) static is
            let pet: ANIMAL mut = ANIMAL();

            if isa CAT(pet) then
                Std.out.write_line(pet.purr());
            fi

            pet = DOG();

            // narrowed to DOG by the assignment: bark() resolves
            Std.out.write_line(pet.bark());

            if which == 1 then
                pet = CAT();
            else
                pet = DOG();
            fi

            // divergent branch assignments: joined view is the
            // subtype set, so only ANIMAL members resolve
            Std.out.write_line(pet.name());
        si
    si
si
