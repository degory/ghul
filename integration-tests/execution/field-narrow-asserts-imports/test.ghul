// Field narrows survive asserts, interpolation of typed fragments,
// and trusted store-free imports: an assert's failure path allocates
// a fresh exception and stores nothing pre-existing; interpolation of
// fragments with known types dispatches bounded, store-free
// to_string bodies; list indexing, dictionary lookups and stack peek
// are trusted reads. An interpolation fragment whose type cannot be
// derived still drops the narrow.

use Collections;

use IO.Std;

class BOX is
    v: int public;
    init() is si
    touch() -> int => v + 3;
si

class HOLDER is
    _b: BOX?;
    _count: int;
    _list: Collections.LIST[int];
    _map: Collections.MAP[string, int];
    _stack: Collections.STACK[int];

    init() is
        _b = BOX();
        _count = 7;
        _list = Collections.LIST[int]([10, 20, 30]);
        _map = Collections.MAP[string, int]();
        _map["k"] = 5;
        _stack = Collections.STACK[int]();
        _stack.push(11);
    si

    after_plain_assert() -> int is
        if _b? then
            assert _count >= 0;
            return _b.touch();
        fi
        return -1;
    si

    after_literal_message_assert() -> int is
        if _b? then
            assert _count >= 0 else "count went negative";
            return _b.touch();
        fi
        return -1;
    si

    after_typed_interpolation() -> int is
        if _b? then
            let message = "count is {_count}";
            return _b.touch() + message.length;
        fi
        return -1;
    si

    after_list_index() -> int is
        if _b? then
            let element = _list[1];
            return _b.touch() + element;
        fi
        return -1;
    si

    after_map_lookup() -> int is
        if _b? then
            let present = _map.contains_key("k");
            return _b.touch();
        fi
        return -1;
    si

    after_stack_peek() -> int is
        if _b? then
            let top = _stack.peek();
            return _b.touch() + top;
        fi
        return -1;
    si

    after_untyped_interpolation[T](anything: T) -> int is
        if _b? then
            let message = "got {anything}";
            return _b.touch() + message.length;
        fi
        return -1;
    si

    after_poisoned_object_interpolation(anything: object) -> int is
        if _b? then
            let message = "got {anything}";
            return _b.touch() + message.length;
        fi
        return -1;
    si
si

// A storing to_string override anywhere in the program poisons
// dispatch through object.to_string, so interpolating an
// object-typed fragment cannot keep narrows alive.
class SHOUTY is
    n: int public;
    init() is si

    to_string() -> string is
        n = n + 1;
        return "shouty {n}";
    si
si

class Main is
    entry() static is
        let h = HOLDER();
        Std.write_line("{h.after_plain_assert()}");
        Std.write_line("{h.after_literal_message_assert()}");
        Std.write_line("{h.after_typed_interpolation()}");
        Std.write_line("{h.after_list_index()}");
        Std.write_line("{h.after_map_lookup()}");
        Std.write_line("{h.after_stack_peek()}");
        Std.write_line("{h.after_untyped_interpolation(BOX())}");
        Std.write_line("{h.after_poisoned_object_interpolation(SHOUTY())}");
    si
si
