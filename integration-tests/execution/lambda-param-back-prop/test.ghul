namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let times_2 = x => x * 2;

            // Uncurried: both args are inferred from the immediate call site.
            let apply_twice = (f, x) => f(f(x));
            Std.write_line("apply_twice(times_2, 5) = {apply_twice(times_2, 5)}");
        si
    si
si
