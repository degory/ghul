namespace Test is
    use IO.Std;

    class Box is
        index: int public;

        init(index: int) is
            self.index = index;
        si

        // Method takes a callback whose arg types must be inferred
        // from the formal — same shape as
        // src/semantic/symbols/closure.ghul:177's gen_type_override.
        with_callback(cb: (Box, int) -> void) is
            cb(self, 42);
        si
    si

    class Main is
        entry() static is
            let b = Box(7);

            // Statement-block lambda whose arg types (a, b) need to
            // be inferred from the formal (Box, int) -> void.
            b.with_callback((a, b) is
                Std.write_line("{a.index} {b}");
            si);

            return;
        si
    si
si
