namespace Test is
    use Std = IO.Std;

    // `throw` as the body of an expression-bodied function or property,
    // for stubbing out code that is not written yet. The body takes its
    // type from the declared return type (explicit, generic, or void), or
    // settles void when the return type is inferred.

    expression_body_int() -> int => throw System.Exception("expression_body_int");
    expression_body_void() => throw System.Exception("expression_body_void");
    expression_body_inferred() => throw System.Exception("expression_body_inferred");
    generic_return[T]() -> T => throw System.Exception("generic_return");
    all_arms_diverge() -> int => if true then throw System.Exception("all_arms_diverge") else throw System.Exception("unreached") fi;

    class HAS_PROPERTY is
        init() is si
        value: int => throw System.Exception("property_body");
    si

    entry() is
        try expression_body_int(); catch e: System.Exception Std.write_line(e.message); yrt
        try expression_body_void(); catch e: System.Exception Std.write_line(e.message); yrt
        try expression_body_inferred(); catch e: System.Exception Std.write_line(e.message); yrt
        try generic_return[int](); catch e: System.Exception Std.write_line(e.message); yrt
        try all_arms_diverge(); catch e: System.Exception Std.write_line(e.message); yrt
        try let v = HAS_PROPERTY().value; catch e: System.Exception Std.write_line(e.message); yrt
        Std.write_line("reached end");
    si
si
