namespace Test is
    use Std = IO.Std;

    class Box[T] is
        _items: Collections.LIST[T];
        init() is
            _items = Collections.LIST[T]();
        si
        add(x: T) is _items.add(x); si

        // Instance generator on a generic class with a lambda capturing self+T
        gen_with_lambda() -> Ghul.Pipes.Pipe[T] is
            let collector = (i: int) => _items[i];
            for j in 0..(_items.count) do
                yield collector(j);
            od
        si
    si

    class Main is
        entry() static is
            let b = Box[string]();
            b.add("a");
            b.add("b");
            b.add("c");
            for x in b.gen_with_lambda() do
                Std.write_line("got {x}");
            od
        si
    si
si
