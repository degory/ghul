namespace Test is
    use Std = IO.Std;

    class Main is
        // `if`-in-expression-position with an `await` inside an arm.
        // Stored to a state-machine-promoted local. Store.LOCAL_
        // VARIABLE.gen's evaluate-then-stash reorder keeps the
        // receiver off the eval stack across the await's `leave`.
        if_with_await(n: int) -> Tasks.TASK[int] static is
            let x =
                if n > 0 then
                    await Tasks.TASK.from_result(n * 2)
                else
                    0
                fi;

            return x + 1;
        si

        // Same shape with `case`.
        case_with_await(n: int) -> Tasks.TASK[int] static is
            let x =
                case n
                when 0 then 100
                when 1 then await Tasks.TASK.from_result(10)
                else        await Tasks.TASK.from_result(n * 5)
                esac;

            return x;
        si

        entry() static is
            Std.write_line("if_with_await(5).result = {Main.if_with_await(5).result}");
            Std.write_line("if_with_await(-3).result = {Main.if_with_await(-3).result}");
            Std.write_line("case_with_await(0).result = {Main.case_with_await(0).result}");
            Std.write_line("case_with_await(1).result = {Main.case_with_await(1).result}");
            Std.write_line("case_with_await(7).result = {Main.case_with_await(7).result}");
        si
    si
si
