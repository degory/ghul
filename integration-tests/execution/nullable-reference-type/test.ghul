use IO.Std.write_line;

class GREETER is
    name: string;

    init(name: string) is
        self.name = name;
    si

    greet() -> string => "hi, {name}";
si

entry() is
    // `GREETER?` is a reference nullable — the same CLR type as
    // `GREETER`, distinct in the type system. Both `null` and a
    // plain `GREETER` are assignable to it.
    let present: GREETER? = GREETER("ada");
    let absent: GREETER? = null;

    write_line(present?);
    write_line(absent?);

    if let g = present then
        write_line(g.greet());
    fi

    if let g = absent then
        write_line("absent should not bind");
    else
        write_line("absent is empty");
    fi

    // `Foo?` and `Foo` are mutually assignable (non-breaking).
    let plain: GREETER = present;
    write_line(plain.greet());

    // a function returning a reference nullable
    write_line(lookup(true)?);
    write_line(lookup(false)?);

    if let g = lookup(true) then
        write_line("looked up {g.greet()}");
    fi
si

lookup(found: bool) -> GREETER? =>
    if found then
        GREETER("grace");
    else
        null;
    fi;
