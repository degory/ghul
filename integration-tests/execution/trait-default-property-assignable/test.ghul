namespace Test is
    use Std = IO.Std;

    trait HasMessage is
        message: string => "trait-default",
            = value is Std.write_line("set called: {value}"); si
    si

    class HOLDER: HasMessage is
        init() is si
    si

    class Main is
        entry() static is
            let h = HOLDER();
            Std.write_line(h.message);
            h.message = "hello";
        si
    si
si
