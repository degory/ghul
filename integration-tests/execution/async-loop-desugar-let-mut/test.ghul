namespace Test is
    use Std = IO.Std;

    class Main is
        double_async(x: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => x * 2
            );

        // `let total mut = 0;` outside the loop is captured by the
        // synthesised body lambda's closure. Per Ghul.BOX[T] (#1391)
        // the variable is boxed when captured-and-mutated, so the
        // body's writes are visible across iterations AND visible
        // to the caller after the loop completes.
        compute(xs: Collections.List[int]) -> Tasks.TASK[int] static is
            let total mut = 0;
            for x in xs do
                let y = await double_async(x);
                total = total + y;
                Std.write_line("after x={x}: total={total}");
            od
            return total;
        si

        entry() static is
            let xs: Collections.List[int] = [10, 20, 30];
            let result = compute(xs).result;
            // 10*2 + 20*2 + 30*2 = 120
            Std.write_line("result={result}");
        si
    si
si
