namespace Test is
    use Std = IO.Std;

    class Main is
        // Chained async — one async function awaits another
        produce() -> Tasks.TASK[int] static is
            let x = await Tasks.TASK.from_result(42);
            return x + 100;
        si

        consume() -> Tasks.TASK[string] static is
            let v = await produce();
            return "value is {v}";
        si

        entry() static is
            let r = consume();
            Std.write_line("got={r.result}");
        si
    si
si
