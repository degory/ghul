namespace Test is
    use Std = IO.Std;

    trait HasMessage is
        message: string => "trait-default",
            = value is Std.write_line("trait set: {value}"); si
    si

    class Holder: HasMessage is
        init() is si

        // Override only the read half; should inherit the default set.
        message: string public => "class-override";
    si

    class Main is
        entry() static is
            let h = Holder();
            Std.write_line(h.message);
            h.message = "hello";
        si
    si
si
