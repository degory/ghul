namespace Test is
    use Std = IO.Std;

    class Main is
        // Generic generator function with a lambda capturing T
        gen[T](item: T, count: int) -> Ghul.Pipes.Pipe[T] static is
            let extract = () => item;
            for i in 0..count do
                yield extract();
            od
        si

        entry() static is
            for x in gen[string]("hello", 3) do
                Std.write_line("got {x}");
            od
        si
    si
si
