namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Non-optional value-type tuple: destructure is irrefutable
            // — the arm always matches, just renaming the components.
            show(("alice", 42));
            show(("bob", 7));
        si

        show(pair: (string, int)) static is
            case pair
            when (name, age) then
                Std.out.write_line("{name} = {age}");
            esac
        si
    si
si
