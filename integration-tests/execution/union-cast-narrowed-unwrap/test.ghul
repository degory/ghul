use IO.Std.write_line;

// Inside an `isa Default(u)` arm, `u` is narrowed to the default
// variant. `u!` should not emit a second `castclass`/`isinst` — the
// receiver is already variant-shaped, the projection can read the
// field directly. Exercises the elided-cast branch in
// `compile_access._build_default_variant_unwrap`.
union Result[T,E] is
    OK(value: T) default;
    ERROR(error: E);
si

ok[T](v: T) -> Result[T,string] => Result.OK[T,string](v);
err[E](e: E) -> Result[int,E] => Result.ERROR[int,E](e);

entry() is
    let good = ok(11);
    let bad = err("nope");

    if isa Result.OK[int,string](good) then
        // good is narrowed to Result.OK[int,string]; ! still
        // projects to the sole own field.
        write_line("narrowed: {good!}");
    fi

    // Non-narrowed `?` and `!` go through the full cast path.
    write_line("good?: {good?}");
    write_line("good!: {good!}");
    write_line("bad?: {bad?}");
si
