namespace Test is
    use IO.Std;
    use Collections;

    // Tests: a pipe whose source is an empty
    // `LIST()` (no element-type from contents) plus a downstream
    // operation that constrains the element type.
    //
    //   let xs = LIST();
    //   xs.add(1); xs.add(2); xs.add(3);
    //   let doubled = xs | .map(n => n * 2) .collect();
    //
    // The `LIST()` constructor has no concrete arg, so its T
    // is initially a placeholder. The subsequent `.add(int)`
    // calls constrain T = int. The `|` pipe and `.map` consume
    // that resolved T.
    //
    // Distinct from `list-from-later-add` (which
    // pins LIST() from a single later add) — this combines
    // *also* piping the result, so the chain must work without
    // the element type being annotated anywhere.

    class Main is
        entry() static is
            let xs = LIST();
            xs.add(10);
            xs.add(20);
            xs.add(30);

            let doubled = xs | .map(n => n * 2) .collect();

            for v in doubled do
                Std.write_line("{v}");
            od

            return;
        si
    si
si
