namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Collections.Iterable[int] static is
            yield 1;
            if true then
                yield 2;
            else
                yield -2;
            fi
            yield 3;
        si

        entry() static is
            for x in gen() do
                Std.write_line("v: {x}");
            od
        si
    si
si
