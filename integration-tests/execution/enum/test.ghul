namespace Test is
    use Std = IO.Std;

    enum Blah is
        Bloop,
        Blip,
        Blergh
    si

    struct Ergh is
        
    si
    
    
    class Main is
        entry() static is
            

            let x mut = Blah.Bloop;
            let y mut = Blah.Blergh;

            let bf: System.Reflection.BindingFlags mut;
            let cf: System.Reflection.BindingFlags mut;

            bf == cf;

            if x == y then
                Std.out.write_line("not expected: {x} == {y}");
            else
                Std.out.write_line("expected: {x} != {y}");
            fi

            x = Blah.Blip;
            y = Blah.Bloop;

            if x != y then
                Std.out.write_line("expected: {x} != {y}");
            else
                Std.out.write_line("not expected: {x} == {y}");
            fi

            x = y;

            if x == y then
                Std.out.write_line("expected: {x} == {y}");
            else
                Std.out.write_line("not expected: {x} != {y}");
            fi
        si
    si
si