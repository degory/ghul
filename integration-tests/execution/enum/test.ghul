namespace Test is
    use Std = IO.Std;

    enum Blah is
        BLOOP,
        BLIP,
        BLERGH
    si

    struct ERGH is
        
    si
    
    
    class Main is
        entry() static is
            

            let x mut = Blah.BLOOP;
            let y mut = Blah.BLERGH;

            let bf: System.Reflection.BindingFlags mut;
            let cf: System.Reflection.BindingFlags mut;

            bf == cf;

            if x == y then
                Std.out.write_line("not expected: {x} == {y}");
            else
                Std.out.write_line("expected: {x} != {y}");
            fi

            x = Blah.BLIP;
            y = Blah.BLOOP;

            if x != y then
                Std.out.write_line("expected: {x} != {y}");
            else
                Std.out.write_line("not expected: {x} == {y}");
            fi

            x = y;

            if x == y then
                Std.out.write_line("expected: {x} == {y}");
            else
                Std.out.write_line("not expected: {x} != {y}");
            fi
        si
    si
si