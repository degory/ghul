namespace Test is
    use Std = IO.Std;

    // The base class has its own members.
    class Animal is
        name: string;

        init(name: string) is
            self.name = name;
        si

        describe() -> string => "animal: {name}";
    si

    // A trait some Animals implement.
    trait Trainable is
        train();
    si

    // A class that is both Animal and Trainable.
    class Dog: Animal, Trainable is
        init(name: string) is
            super.init(name);
        si

        train() is
            Std.out.write_line("{name} trained");
        si
    si

    class Main is
        entry() static is
            let a: Animal = Dog("Rex");

            // a's declared type is Animal. The isa-narrow makes a's
            // type Animal & Trainable inside the body — so both
            // a.describe() (Animal-side) and a.train() (Trainable-side)
            // resolve.
            if isa Trainable(a) then
                Std.out.write_line(a.describe());
                a.train();
            fi
        si
    si
si
