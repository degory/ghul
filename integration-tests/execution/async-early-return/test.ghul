namespace Test is
    use Std = IO.Std;

    class Main is
        compute(seed: int) -> Tasks.TASK[int] static =>
            Tasks.TaskExtensions.unwrap(
                Tasks.TASK.from_result(seed).continue_with(
                    (t_x: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                        if t_x.result > 100 then
                            Tasks.TASK.from_result(-1)
                        else
                            Tasks.TaskExtensions.unwrap(
                                Tasks.TASK.from_result(t_x.result * 10).continue_with(
                                    (t_y: Tasks.TASK[int]) -> Tasks.TASK[int] =>
                                        Tasks.TASK.from_result(t_x.result + t_y.result)
                                )
                            )
                        fi
                )
            );

        entry() static is
            let early_path = compute(200);    // 200 > 100 → -1
            let full_path = compute(5);       // 5 → 5 * 10 = 50, total 5 + 50 = 55

            Std.write_line("early_path.result={early_path.result}");
            Std.write_line("full_path.result={full_path.result}");
        si
    si
si
