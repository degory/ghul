namespace Test is
    use Std = IO.Std;

    class GREETER(prefix: string, name: string, suffix: string) is
        _prefix;
        _name;
        _suffix;

        say() is
            Std.write_line("{_prefix}{_name}{_suffix}");
        si
    si

    class Main is
        entry() static is
            let g = GREETER("hello, ", "world", "!");
            g.say();
        si
    si
si
