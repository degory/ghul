namespace Test is
    use Std = IO.Std;

    trait Top is
        ping() is
            Std.write_line("top default");
        si
    si

    trait Middle: Top is
    si

    class Bottom: Middle is
        init() is si
    si

    class Main is
        entry() static is
            let b = Bottom();
            b.ping();
        si
    si
si
