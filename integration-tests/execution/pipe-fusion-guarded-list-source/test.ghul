namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A `for` over a `map`/`filter` pipe chain whose base source is a
    // collection (here a LIST[int], and an Iterable[int]-typed variable) -
    // not a sealed value type or array. Such a source could dynamically be
    // a user Pipe with an overridden map/filter, so the chain is fused
    // behind a per-site `source isa Pipe[element]` guard that mirrors what
    // pipe() itself does. When the source is not actually a Pipe (the
    // common case) the guard takes the fused loop; the result must match
    // the unfused lowering.

    class Main is
        entry() static is
            let xs = LIST[int]([1, 2, 3, 4, 5]);

            // map then filter over a concrete LIST source.
            for x in pipe(xs).map(n => n * 10).filter(n => n > 20) do
                Std.write_line("map/filter: {x}");
            od

            // filter only.
            for x in pipe(xs).filter(n => n % 2 == 0) do
                Std.write_line("filter: {x}");
            od

            // Source typed as the Iterable interface - still guarded, still
            // fused when the dynamic value is a plain list.
            let ys: Iterable[int] = LIST[int]([10, 20, 30, 40]);
            for x in pipe(ys).map(n => n + 1).filter(n => n > 21) do
                Std.write_line("iterable: {x}");
            od
        si
    si
si
