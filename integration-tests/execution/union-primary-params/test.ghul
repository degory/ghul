use IO.Std.write_line;

union TRIVIA(line: int) is
    LINE_COMMENT(text: string, ..);
    BLOCK_COMMENT(text: string, ..);
    BLANK_LINE(..);
si

entry() is
    let line_c: TRIVIA = TRIVIA.LINE_COMMENT("// hi", 7);
    let block_c: TRIVIA = TRIVIA.BLOCK_COMMENT("/* hi */", 12);
    let blank: TRIVIA = TRIVIA.BLANK_LINE(42);

    write_line(line_c.line);
    write_line(block_c.line);
    write_line(blank.line);

    if let lc: TRIVIA.LINE_COMMENT = line_c then
        write_line(lc.text);
        write_line(lc.line);
    fi

    if let bc: TRIVIA.BLOCK_COMMENT = block_c then
        write_line(bc.text);
        write_line(bc.line);
    fi
si
