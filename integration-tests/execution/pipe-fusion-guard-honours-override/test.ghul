namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A user Pipe whose filter override ignores the predicate and lets
    // everything through.
    class WEIRD_PIPE: Pipe[int] is
        _values: LIST[int];
        _index: int;

        init(values: LIST[int]) is
            _values = values;
            _index = -1;
        si

        iterator: Iterator[int] => self;
        current: int => _values[_index];

        move_next() -> bool is
            _index = _index + 1;
            return _index < _values.count;
        si

        reset() is
            _index = -1;
        si

        dispose() is
        si

        filter(predicate: (int) -> bool pure) -> Pipe[int] pure => self;
    si

    class Main is
        entry() static is
            // Statically Iterable[int] (so the chain is fused behind a
            // runtime guard), dynamically a WEIRD_PIPE. The guard's
            // `source isa Pipe[int]` test fires, so pipe() would
            // short-circuit to the value and run its own filter - the
            // fused loop must NOT run. The override lets everything
            // through, so all four values appear despite the n > 100
            // predicate that the default filter would drop.
            let weird: Iterable[int] = WEIRD_PIPE(LIST[int]([1, 2, 3, 4]));
            for x in pipe(weird).filter(n => n > 100) do
                Std.write_line("weird: {x}");
            od
        si
    si
si
