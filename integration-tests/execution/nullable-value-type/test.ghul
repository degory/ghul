use IO.Std.write_line;

entry() is
    // `int?` is the value-type nullable (System.Nullable<int> under
    // the hood). A non-optional `int` widens to `int?` at slot
    // boundaries — assignment, return, call argument — so the wrap
    // is implicit. `null` is the absent value.
    let present: int? = 42;
    let absent: int? = null;

    write_line(present?);
    write_line(absent?);

    if present? then
        write_line("present holds {present!}");
    fi

    if absent? then
        write_line("absent should not get here");
    else
        write_line("absent is empty");
    fi

    // `if let` binds the unwrapped value, scoped and narrowed.
    if let v = present then
        write_line("if let bound {v}");
    fi

    if let v = absent then
        write_line("if let absent should not bind {v}");
    else
        write_line("if let absent fell through");
    fi

    // a function returning `int?`
    write_line(halve(84)!);
    write_line(halve(7)?);

    // char? exercises a second value type
    let c: char? = 'x';
    if c? then
        write_line("char {c!}");
    fi
si

// returns the half of an even number, absent for an odd one.
// The `if` body branches widen at the branch's value-site — for now,
// the present branch returns through a let-binding so the assignment
// boundary triggers the wrap; widening directly at an if-branch's
// expression value is a separate boundary site.
halve(n: int) -> int? is
    if n % 2 == 0 then
        let half: int? = n / 2;
        return half;
    fi
    return null;
si
