namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            show(value = 42);
            show(value = "hello");
        si

        show(value: int) static is
            Std.out.write_line("int: {value}");
        si

        show(value: string) static is
            Std.out.write_line("string: {value}");
        si
    si
si
