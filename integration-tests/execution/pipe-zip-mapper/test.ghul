namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.zip[U,TOut]` in
    // `ghul-runtime/src/pipe.ghul`:
    //   zip[U,TOut](other: Iterable[U], mapper: (T,U) -> TOut)
    //       -> Pipe[TOut]
    //
    // Three type variables flowing through a partial path:
    //   - T from the receiver `[1,2,3] | ...`            → int
    //   - U from the second arg `["a","b","c"]`           → string
    //   - TOut from the third arg's lambda body          → string
    //
    // The lambda is (int, string) -> string. The TOut slot has
    // no sibling concrete actual driving it; it must back-propagate
    // from the lambda body's interpolation result.

    class Main is
        entry() static is
            let ints = [1, 2, 3];
            let labels = ["alpha", "beta", "gamma"];

            let labelled = ints | .zip(labels, (n, name) => "{n}-{name}") .collect();

            for line in labelled do
                Std.write_line(line);
            od

            return;
        si
    si
si
