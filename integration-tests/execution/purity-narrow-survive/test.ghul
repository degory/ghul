namespace Test is
    use Std = IO.Std;

    // Path-presence narrowing across calls is gated on callee
    // purity:
    //   PURE  -> all path facts survive untouched.
    //   MUT   -> drop paths rooted at the receiver only; no-op
    //            when there's no caller-receiver expression
    //            (constructor / static / global call).
    //   IMPURE (default unless reclassified) -> clear all paths.
    // Constructors and property setters default to MUT.

    class HOLDER is
        name: string?;
        init(name: string?) is self.name = name; si
    si

    class BUCKET is
        seen: string?;
        // Auto-property: ghūl synthesises a getter and setter
        // pair. The setter is recognised in declare-symbols
        // (`function.for_property` with arguments) and
        // auto-classifies as MUT.
        label: string? public;
        init() is si
        // `mut` modifier: mutates receiver only. Sibling
        // narrowings (rooted at a different local) survive.
        note(s: string) mut is self.seen = s; si
    si

    class CHECKS is
        do_pure(x: int) -> int static pure => x + 1;

        do_impure() static is
            // No-op body — the *modifier* is what counts at
            // call sites, not what the body actually does.
        si

        report_pure(h: HOLDER) static is
            if h.name? then
                let after_pure = CHECKS.do_pure(42);
                // PURE callee: h.name narrowing intact.
                let n: string = h.name;
                Std.write_line("pure: n={n} +{after_pure}");
            fi
        si

        report_mut_keeps_sibling(h: HOLDER, b: BUCKET) static is
            if h.name? then
                b.note("hello");
                // MUT callee with `b` as the receiver: drops
                // paths rooted at `b`, leaves `h.name` (rooted
                // at `h`) alone.
                let n: string = h.name;
                Std.write_line("mut-sibling: n={n} seen={b.seen}");
            fi
        si

        report_setter_keeps_sibling(h: HOLDER, b: BUCKET) static is
            if h.name? then
                b.label = "tagged";
                // Property setter on `b` auto-classified as MUT:
                // drops paths rooted at `b` only, h.name intact.
                let n: string = h.name;
                Std.write_line("setter-sibling: n={n} label={b.label}");
            fi
        si

        report_impure(h: HOLDER) static is
            if h.name? then
                // Capture into a local — locals are sound across
                // calls regardless of callee purity.
                let before = h.name;
                CHECKS.do_impure();
                // IMPURE callee: h.name's path fact is cleared;
                // the captured local stands in.
                Std.write_line("impure: before={before}");
            fi
        si

        report_constructor_no_op(h: HOLDER) static is
            if h.name? then
                let fresh = BUCKET();
                // Constructor defaults to MUT, but the call has
                // no caller-receiver expression (NEW IR), so
                // on_call is a no-op: h.name narrowing intact.
                let n: string = h.name;
                Std.write_line("ctor: n={n} fresh.seen={fresh.seen}");
            fi
        si
    si

    class Main is
        entry() static is
            let h = HOLDER("hello");
            let b = BUCKET();
            CHECKS.report_pure(h);
            CHECKS.report_mut_keeps_sibling(h, b);
            CHECKS.report_setter_keeps_sibling(h, b);
            CHECKS.report_impure(h);
            CHECKS.report_constructor_no_op(h);
            return;
        si
    si
si
