namespace Test is
    use Std = IO.Std;

    namespace Async is
        and_then_int(task: Tasks.TASK[int], f: int -> Tasks.TASK[int]) -> Tasks.TASK[int] =>
            Tasks.TaskExtensions.unwrap(
                task.continue_with(
                    (t: Tasks.TASK[int]) -> Tasks.TASK[int] => f(t.result)
                )
            );

        return_int(value: int) -> Tasks.TASK[int] => Tasks.TASK.from_result(value);
    si

    class Main is
        entry() static is
            let result =
                Async.and_then_int(
                    Async.return_int(42),
                    (x: int) -> Tasks.TASK[int] => Async.return_int(x + 1)
                );

            Std.write_line("and_then.result={result.result}");
        si
    si
si
