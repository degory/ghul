use IO.Std.write_line;

// Methods returning val-blocks — same composition as free functions
// but exercised through an instance method dispatch.
class CALC is
    init() is si

    // Non-void `=>` method body: val-block with explicit return AND
    // a tail expression. Block value type is LUB(returns, tail) = int.
    classify(n: int) -> int =>
        val
            if n < 0 then
                return -1;
            fi
            n
        lav;

    // Non-void `=>` method body: val-block with no explicit return,
    // tail only.
    double(n: int) -> int =>
        val
            let scaled = n * 2;
            scaled
        lav;

    // Void `=>` method body: val-block with explicit `return;` for
    // early exit, plus side-effect tail.
    log_if(skip: bool, label: string) =>
        val
            if skip then
                return;
            fi
            write_line("CALC.log_if: {label}");
        lav;

    // Void `=>` method body: val-block with no return, side effects
    // only.
    log_pair(a: string, b: string) =>
        val
            write_line("CALC.log_pair a = {a}");
            write_line("CALC.log_pair b = {b}");
        lav;
si

// Non-void `=>` free function returning val-block, no explicit
// return (tail only) — pairs with method `double` above.
fn_tail_only(n: int) -> int =>
    val
        let trebled = n * 3;
        trebled
    lav;

// Void `=>` free function returning val-block, no return.
fn_void_no_return(label: string) =>
    val
        write_line("fn_void_no_return: {label}");
    lav;

entry() is
    let c = CALC();

    write_line("classify(-3) = {c.classify(-3)}");
    write_line("classify(7) = {c.classify(7)}");

    write_line("double(4) = {c.double(4)}");

    c.log_if(true, "skipped");
    c.log_if(false, "run");

    c.log_pair("first", "second");

    write_line("fn_tail_only(5) = {fn_tail_only(5)}");

    fn_void_no_return("tail");
si
