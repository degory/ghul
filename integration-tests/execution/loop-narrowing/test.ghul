use IO.Std.write_line;

class ANIMAL is
    name: string public;
    init(name: string) is self.name = name; si
    speak() -> string => "animal {name}";
si

class CAT: ANIMAL is
    init(name: string) is super.init(name); si
    purr() -> string => "{name} purrs";
si

entry() is
    test_narrow_survives_into_for_body();
    test_narrow_survives_after_for();
    test_narrow_survives_after_while();
    test_narrow_survives_loop_that_writes_other_variable();
si

// A divergent guard before a loop: the loop body does not write
// `a`, so its narrow to CAT is loop-invariant and survives into
// the body.
test_narrow_survives_into_for_body() is
    let a: ANIMAL = CAT("tom");

    if !isa CAT(a) then
        return;
    fi

    for i in 0..2 do
        write_line("01-into-for-body: {a.purr()}");
    od
si

// ... and the narrow survives past the loop.
test_narrow_survives_after_for() is
    let a: ANIMAL = CAT("felix");

    if !isa CAT(a) then
        return;
    fi

    for i in 0..1 do
        write_line("02-in-loop: counting {i}");
    od

    write_line("02-after-for: {a.purr()}");
si

test_narrow_survives_after_while() is
    let a: ANIMAL = CAT("garfield");

    if !isa CAT(a) then
        return;
    fi

    let n mut = 0;
    while n < 2 do
        n = n + 1;
    od

    write_line("03-after-while: {a.purr()}");
si

// The loop writes a different variable (`total`); the narrow on
// `a` is untouched and survives.
test_narrow_survives_loop_that_writes_other_variable() is
    let a: ANIMAL = CAT("milo");

    if !isa CAT(a) then
        return;
    fi

    let total mut = 0;
    for i in 0..3 do
        total = total + i;
    od

    write_line("04-other-var-written: {a.purr()} total {total}");
si
