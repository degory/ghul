namespace Test is
    use IO.Std;

    // A recursive lambda over a union where the call site supplies
    // a value whose *static* type is a single variant (not the wide
    // union): `let list = CONS(...)` is typed `List.CONS[int]`. The
    // call-site back-feed propagates that narrow type into the
    // lambda's parameter placeholder. Inside the body, the recursive
    // call `rec(tail)` passes `List[int]` (the wide field type on
    // CONS) — type mismatch against the now-pinned `List.CONS[int]`
    // formal.
    //
    // Desired behaviour: the recursive call's back-feed at the call
    // site should LUB-widen the placeholder origin's accumulator
    // from `[List.CONS[int]]` to `[List.CONS[int], List[int]]` =
    // `List[int]`. Iter N+1 then walks the body with `l: List[int]`,
    // narrowing fires inside `if l.is_cons`, the destructure and the
    // recursive call type-check, and inference converges.
    //
    // A widened let — `let list: List[int] = CONS(...)` — does
    // converge today, so this case is specifically about the
    // narrow-LUB-from-call-site path.
    union List[T] is
        NIL;
        CONS(head: T, tail: List[T]);
    si

    use List.NIL;
    use List.CONS;

    class Main is
        entry() static is
            let list = CONS(1, CONS(2, CONS(3, NIL[int]())));

            let stringify_list = l rec =>
                if l.is_cons then
                    let (head, tail) = l in
                    "{head}, {rec(tail)}"
                else
                    "nil"
                fi;

            Std.write_line(stringify_list(list));
            return;
        si
    si
si
