namespace Test is
    use IO.Std;
    use Collections;

    // Assigning a no-arg constructor to a field whose type pins
    // the type-arg infers the constructor's type-arg from the
    // field type — `LIST()` resolves to `LIST[T]` from the field's
    // declared `MutableList[T]`.

    class BOX[T] is
        _items: MutableList[T];

        init() is
            _items = LIST();   // should be LIST[T]() — wanted: inferred
        si

        add(item: T) =>
            _items.add(item);

        count() -> int =>
            _items.count;
    si

    class Main is
        entry() static is
            let b = BOX[int]();
            b.add(1);
            b.add(2);
            Std.write_line("count={b.count()}");
            return;
        si
    si
si
