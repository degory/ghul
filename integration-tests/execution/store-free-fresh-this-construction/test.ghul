// A constructor that writes only its own instance fields writes only
// the fresh object a NEW builds, so constructing one where a pure
// function-typed parameter is expected is store-free — no
// impure-function-value warning. Covers both the bare-field (`x = a`)
// and `self.field` assignment forms.

use Std = IO.Std;

class POINT is
    x: int field;
    y: int field;
    init(a: int, b: int) is
        x = a;
        self.y = b;
    si
si

apply(f: (int) -> POINT pure, n: int) -> POINT => f(n);

entry() is
    let p = apply(n => POINT(n, n + 1), 3);

    Std.write_line("{p.x},{p.y}");
si
