namespace Test is
    use IO.Std;

    // Iterative inference of a lambda argument passed to a generic
    // *free* function. `OWNER_TYPE_ARG_SPECIALIZER` already does this
    // for generic-class constructors and methods (specialise the
    // candidate from concrete sibling actuals, then push the
    // specialised formal as a constraint to the under-determined
    // lambda), so `GENERATOR((0, 1), state => ...)` resolves.
    // Free generic functions take a different overload-resolution
    // path: the specializer only fires when the *owner* is generic,
    // not when the function itself carries the type parameters.
    //
    // Desired behaviour: state's type is inferred as (int, int) from
    // S = (int, int) bound by the initial actual. The lambda body
    // then walks cleanly with prev and current as int.
    work[T, S](initial: S, fn: S -> (S, T)) -> S => initial;

    class Main is
        entry() static is
            let result = work(
                (0, 1),
                state =>
                    let
                        (prev, current) = state,
                        next = prev + current
                    in ((current, next), next)
            );
            Std.write_line("{result.`0}");
            return;
        si
    si
si
