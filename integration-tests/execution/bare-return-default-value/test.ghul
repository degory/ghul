namespace Test is
    use Std = IO.Std;

    class Main is
        // Bare `return;` from a non-void function should push the
        // declared return type's default value before `ret` —
        // matches the fall-off-end semantic and honours the
        // pre_return warning ("return without value from non void
        // function returns default value of type T"). Without the
        // default push the IL is invalid and the JIT throws
        // InvalidProgramException at runtime.
        as_bool() -> bool static is
            return;
        si

        as_int() -> int static is
            return;
        si

        as_string() -> string static is
            return;
        si

        entry() static is
            Std.write_line("bool={as_bool()}");
            Std.write_line("int={as_int()}");
            Std.write_line("string=[{as_string()}]");
        si
    si
si
