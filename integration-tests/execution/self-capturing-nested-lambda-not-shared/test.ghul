use IO.Std.write_line;

// An outer lambda that captures nothing directly, but whose body builds an
// inner lambda that captures self. The self dependence is recorded on the
// inner closure, yet the outer's body still loads the receiver to construct
// it, so the outer delegate is receiver-dependent and must not be shared.
class BOX is
    id: int;

    init(id: int) is
        self.id = id;
    si

    outer_thunk() -> () -> int => () => (() => id)();
si

entry() is
    let a = BOX(1);
    let b = BOX(2);

    let from_a = a.outer_thunk();
    let from_b = b.outer_thunk();

    write_line("a -> {from_a()}");
    write_line("b -> {from_b()}");
si
