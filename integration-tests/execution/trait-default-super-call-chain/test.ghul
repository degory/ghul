namespace Test is
    use Std = IO.Std;

    trait Top is
        ping() is
            Std.write_line("top");
        si
    si

    trait Middle: Top is
    si

    class Bottom: Middle is
        init() is si

        ping() is
            super.ping();
            Std.write_line("bottom");
        si
    si

    class Main is
        entry() static is
            let b = Bottom();
            b.ping();
        si
    si
si
