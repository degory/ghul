namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.for_each(action: T -> void)`
    // in `ghul-runtime/src/pipe.ghul`.
    //
    // The lambda has a single T param and returns void (the action
    // is for-effect, not for-value). Tests the void-return inference
    // path — lambdas that have no return statement and whose body
    // expressions are statement-style. Distinct from `.map(...)`
    // whose lambda returns a value: `for_each` expects an Action[T]
    // conversion (or equivalent void-returning delegate).

    class Main is
        entry() static is
            let xs = [10, 20, 30];

            xs | .for_each(x => Std.write_line("x={x}"));

            return;
        si
    si
si
