namespace Test is
    use IO.Std;

    // `T?` on an unconstrained type parameter lowers to
    // `Ghul.MAYBE[T]` — the value-type carrier that represents
    // absent or present without committing to a value/reference
    // lowering at declaration site. Recognition flows through the
    // structural `has_value` / `value` members so `?` and `!` work
    // uniformly across the three `T?` lowerings.
    class Holder[T] is
        slot: T?;

        init() is si

        store(v: T) is slot = Ghul.MAYBE[T](v); si

        present: bool => slot?;
    si

    class Main is
        entry() static is
            let with_int = Holder[int]();
            Std.write_line("int empty: present? {with_int.present}");
            with_int.store(42);
            Std.write_line("int after store: present? {with_int.present}");

            let with_string = Holder[string]();
            Std.write_line("string empty: present? {with_string.present}");
            with_string.store("hello");
            Std.write_line("string after store: present? {with_string.present}");
            return;
        si
    si
si
