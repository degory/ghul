namespace Test is
    use IO.Std;
    use Collections;

    class ANIMAL(name: string);

    class CAT(name: string): ANIMAL is
        super(name);

        meow() is
            Std.write_line("{name} says meow");
        si
    si

    class Main is
        find_pet(cats: List[CAT], name: string) -> CAT? static =>
            cats | .find(c => c.name == name);

        // Receives a `CAT?` argument — exercises the argument-pass
        // path through VALUE_BOXER.box_arguments. A bare
        // `cats | .find(...)` returns MAYBE[CAT] and is passed
        // directly into the CAT? slot, so the coercion has to fire
        // before the value-type-into-reference-slot boxing branch.
        report(found: CAT?) static is
            if found? then
                Std.write_line("report: {found!.name}");
            else
                Std.write_line("report: none");
            fi
        si

        entry() static is
            let cats = [CAT("Felix"), CAT("Eric"), CAT("Geoff")];

            let found = find_pet(cats, "Eric");

            if found? then
                Std.write_line("found {found!.name}");
                found!.meow();
            else
                Std.write_line("not found");
            fi

            let missing = find_pet(cats, "Whiskers");

            if missing? then
                Std.write_line("found {missing!.name}");
            else
                Std.write_line("missing: not found");
            fi

            // Argument-pass: a `.find` result flows straight into
            // a CAT? formal parameter — exercises box_arguments'
            // MAYBE → reference-T? coercion.
            report(cats | .find(c => c.name == "Geoff"));
            report(cats | .find(c => c.name == "Nobody"));

            return;
        si
    si
si
