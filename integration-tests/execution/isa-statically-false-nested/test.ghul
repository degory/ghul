namespace Test is
    use IO.Std;

    class ANIMAL is
        init() is si
    si

    class CAT: ANIMAL is
        init() is super.init(); si
    si

    class DOG: ANIMAL is
        init() is super.init(); si
    si

    class Main is
        entry() static is
            let a: ANIMAL = CAT();

            if isa CAT(a) then
                if isa DOG(a) then
                    Std.out.write_line("impossible");
                fi
                Std.out.write_line("cat");
            fi
        si
    si
si
