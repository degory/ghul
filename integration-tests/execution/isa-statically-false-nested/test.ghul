namespace Test is
    use IO.Std;

    class ANIMAL is
        init() is si
    si

    class CAT: ANIMAL is
        init() is super.init(); si
    si

    class DOG: ANIMAL is
        init() is super.init(); si
    si

    class HOLDER is
        pet: CAT;
        init() is pet = CAT(); si
    si

    class Main is
        entry() static is
            let a: ANIMAL = CAT();

            if isa CAT(a) then
                if isa DOG(a) then
                    Std.out.write_line("impossible");
                fi
                Std.out.write_line("cat");
            fi

            // the member-access-path mirror of the same shape: the
            // path's static type CAT is unrelated to DOG
            let h = HOLDER();

            if isa DOG(h.pet) then
                Std.out.write_line("impossible");
            fi

            Std.out.write_line("done");
        si
    si
si
