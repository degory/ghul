namespace Test is
    use IO.Std;

    // An `if let` / `while let` clause whose bound value is itself an
    // `if` expression: the branch bodies are identifier-led, so parsing
    // the clause value speculates internally. Exercises the clause parse
    // end to end for the plain, nested, multi-clause, and `let ... in`
    // fallback forms.
    class BOX is
        value: string? public;
        other: string? public;
        init(value: string?, other: string?) is
            self.value = value;
            self.other = other;
        si
    si

    class TEST is
        clause_if(p: BOX, q: BOX) -> string static is
            if let a = if p.value? then p.value else q.value fi then
                return a;
            fi
            return "absent";
        si

        clause_while(p: BOX) -> int static is
            let n mut = 0;
            while let v = if p.value? then p.other else p.value fi do
                n = n + 1;
                if n > 2 then break; fi
            od
            return n;
        si

        clause_nested(p: BOX, q: BOX) -> string static is
            if let a =
                if p.value? then
                    if let b = q.other then b else q.value fi
                else
                    p.other
                fi
            then
                return a;
            fi
            return "absent";
        si

        cond_let_in() -> int static is
            if let n = 5 in n > 3 then
                return 1;
            fi
            return 0;
        si

        clause_multi(p: BOX, q: BOX) -> string static is
            if
                let a = if p.value? then p.value else q.value fi,
                c = if q.other? then q.other else p.other fi
            then
                return "{a}-{c}";
            fi
            return "absent";
        si

        entry() static is
            let full = BOX("x", "y");
            let empty = BOX(null, "z");

            Std.write_line(clause_if(full, empty));
            Std.write_line(clause_if(empty, full));
            Std.write_line("{clause_while(full)}");
            Std.write_line(clause_nested(full, BOX("n1", "n2")));
            Std.write_line("{cond_let_in()}");
            Std.write_line(clause_multi(full, BOX("m1", "m2")));
        si
    si
si
