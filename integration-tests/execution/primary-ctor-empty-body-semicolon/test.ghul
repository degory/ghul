namespace Test is
    use Std = IO.Std;

    class BOX(value: int);

    struct POINT(x: int, y: int);

    class PAIR[T, U](first: T, second: U);

    class EMPTY();

    class Main is
        entry() static is
            let b = BOX(42);
            Std.write_line("{b.value}");

            let p = POINT(3, 4);
            Std.write_line("{p.x},{p.y}");

            let pair = PAIR(1, "hello");
            Std.write_line("{pair.first},{pair.second}");

            let e = EMPTY();
            Std.write_line("empty ok");
        si
    si
si
