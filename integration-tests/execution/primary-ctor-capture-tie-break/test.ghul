namespace Test is
    use Std = IO.Std;

    class BOX(value: int) is
        _value;
        value: int public;

        init(..) is
            self.value = _value * 10;
        si

        show_internal() is
            Std.write_line("internal={_value}");
        si
    si

    class Main is
        entry() static is
            let b = BOX(7);
            b.show_internal();
            Std.write_line("public={b.value}");
        si
    si
si
