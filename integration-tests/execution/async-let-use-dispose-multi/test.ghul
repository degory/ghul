namespace Test is
    use Std = IO.Std;

    class HANDLE: Disposable is
        _label: string;

        init(label: string) is
            _label = label;
            Std.write_line("open {_label}");
        si

        touch() -> int is
            Std.write_line("touch {_label}");
            return 7;
        si

        dispose() is
            Std.write_line("dispose {_label}");
        si
    si

    class Main is
        // Two awaits separated by a let-use, multiple statements
        // around them. Mirrors the shape of the web-api product-API
        // handlers (open resource, do work involving await, close).
        run() -> Tasks.TASK[int] static is
            let use h = HANDLE("h");

            Std.write_line("step1");
            await Tasks.TASK.delay(1);
            Std.write_line("step2");
            let n = h.touch();
            await Tasks.TASK.delay(1);
            Std.write_line("step3");

            return n + 1;
        si

        entry() static is
            Std.write_line("result={run().result}");
        si
    si
si
