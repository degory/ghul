namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Collections.Iterable[int] static is
            let i mut = 0;
            while i < 4 do
                let snap = i;
                let bump = () => snap + 10;
                yield bump();
                i = i + 1;
            od
        si

        entry() static is
            for x in gen() do
                Std.write_line("got {x}");
            od
        si
    si
si
