namespace Test is
    use Std = IO.Std;

    class Main is
        double_each[T](xs: Collections.Iterable[T]) -> Collections.Iterable[T] static is
            for x in xs do
                yield x;
                yield x;
            od
        si

        entry() static is
            for v in double_each[int]([1, 2, 3]) do
                Std.write_line("d: {v}");
            od
            for s in double_each[string](["x", "y"]) do
                Std.write_line("s: {s}");
            od
        si
    si
si
