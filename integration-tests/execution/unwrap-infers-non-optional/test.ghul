use IO.Std.write_line;

class BOX is
    label: string;

    init(label: string) is
        self.label = label;
    si
si

get_box() -> BOX? => BOX("hello");

entry() is
    // `!` on a non-variable optional (here a call result) yields a
    // non-optional type, so the inferred `let` binding is non-optional
    // and dereferencing it does not warn that it may be null.
    let unwrapped = get_box()!;

    write_line(unwrapped.label);
si
