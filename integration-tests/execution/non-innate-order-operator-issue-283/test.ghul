namespace Test is
    use IO.Std;

    class BOX is
        value: int;
        init(value: int) is
            self.value = value;
        si
        <>(other: BOX) -> int => value - other.value;
    si

    class Main is
        entry() static is
            let a = BOX(5);
            let b = BOX(10);
            Std.write_line("a > b should be False: {a > b}");
            Std.write_line("b > a should be True: {b > a}");
            Std.write_line("a < b should be True: {a < b}");
            Std.write_line("a >= b should be False: {a >= b}");
            Std.write_line("b >= a should be True: {b >= a}");
            return;
        si
    si
si
