namespace Test is
    use Std = IO.Std;

    class Main is
        // Lambda capturing multiple locals
        gen() -> Collections.Iterable[int] static is
            let a = 10;
            let b mut = 1;
            let combine = (m: int) => a * m + b;
            yield combine(1);
            b = 100;
            yield combine(2);
            b = 1000;
            yield combine(3);
        si

        entry() static is
            for x in gen() do
                Std.write_line("got {x}");
            od
        si
    si
si
