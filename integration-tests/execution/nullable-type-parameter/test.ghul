use IO.Std.write_line;

// `T?` on a `struct`-constrained parameter lowers to OPTION[T].
wrap[T: struct](value: T) -> T? => OPTION[T](value);

// `T?` on a `class`-constrained parameter lowers to a nullable
// reference.
first[T: class](items: Collections.List[T]) -> T? =>
    if items.count > 0 then
        items[0];
    else
        null;
    fi;

entry() is
    // struct parameter — explicit and inferred specialization
    let wrapped = wrap[int](42);
    write_line(wrapped?);

    if let v = wrapped then
        write_line("wrapped {v}");
    fi

    if let v = wrap(99) then
        write_line("inferred {v}");
    fi

    // class parameter — present and absent
    let names = ["ada", "grace"];

    if let n = first[string](names) then
        write_line("first {n}");
    fi

    let empty = Collections.LIST[string]();

    if let n = first[string](empty) then
        write_line("should not bind {n}");
    else
        write_line("empty has no first");
    fi
si
