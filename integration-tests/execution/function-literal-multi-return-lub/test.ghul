namespace Test is
    use Std = IO.Std;

    // LUB inference for the return type of a block-bodied function
    // literal with multiple return statements. Implements the
    // "Inferring the return type of function literals with multiple
    // return statements" checkbox in #1173.
    //
    // Before the fix: the first `return X;` set the inferred return
    // type to X, then any subsequent `return Y;` whose type was not
    // assignable to X produced
    //   "cannot return value of type Y where X expected".
    // Now: when the function's return type was originally inferred,
    // mismatched returns trigger LUB widening to the common ancestor.

    class ANIMAL is
        init() is si
        speak() -> string => "animal";
    si

    class CAT: ANIMAL is
        init() is si
    si

    class DOG: ANIMAL is
        init() is si
    si

    class PLANT is
        init() is si
    si

    class Main is
        entry() static is
            // ---- block-bodied function literals (procedural, multi-return) ----

            // Two siblings — return type should widen to ANIMAL.
            let f = (which: bool) is
                if which then
                    return CAT();
                else
                    return DOG();
                fi
            si;

            Std.out.write_line("siblings true: {f(true).speak()}");
            Std.out.write_line("siblings false: {f(false).speak()}");

            // First return narrower, second wider — should widen to ANIMAL.
            let g = (which: bool) is
                if which then
                    return CAT();
                else
                    return ANIMAL();
                fi
            si;

            Std.out.write_line("narrow then wide: {g(true).speak()}");
            Std.out.write_line("narrow then wide: {g(false).speak()}");

            // First return wider, second narrower — current behaviour
            // (first wins, second is assignable) was already correct;
            // included as regression coverage.
            let h = (which: bool) is
                if which then
                    return ANIMAL();
                else
                    return CAT();
                fi
            si;

            Std.out.write_line("wide then narrow: {h(true).speak()}");
            Std.out.write_line("wide then narrow: {h(false).speak()}");

            // Three returns spanning two siblings + a strict subtype.
            let three = (n: int) is
                if n == 0 then
                    return CAT();
                elif n == 1 then
                    return DOG();
                else
                    return CAT();
                fi
            si;

            Std.out.write_line("three: {three(0).speak()}");
            Std.out.write_line("three: {three(1).speak()}");
            Std.out.write_line("three: {three(2).speak()}");

            // Unrelated types — LUB falls back to object. Calling
            // to_string on the result confirms the closure compiled.
            let mixed = (which: bool) is
                if which then
                    return CAT();
                else
                    return PLANT();
                fi
            si;

            Std.out.write_line("mixed: {mixed(true).to_string()}");
            Std.out.write_line("mixed: {mixed(false).to_string()}");

            // ---- expression-bodied function literals (`=>`) ----

            // Expression-bodied function literal with an if-expression
            // body. This was already supported by the if-expression
            // branch-LUB (a separate ticked checkbox in #1173); the
            // multi-return fix doesn't touch this path. Included as
            // regression coverage that both forms now produce the same
            // inferred return type for sibling branches.
            let expr_siblings = (which: bool) =>
                if which then CAT() else DOG() fi;

            Std.out.write_line("expr siblings: {expr_siblings(true).speak()}");
            Std.out.write_line("expr siblings: {expr_siblings(false).speak()}");

            // Expression-bodied with three branches via elif.
            let expr_three = (n: int) =>
                if n == 0 then CAT()
                elif n == 1 then DOG()
                else CAT() fi;

            Std.out.write_line("expr three: {expr_three(0).speak()}");
            Std.out.write_line("expr three: {expr_three(1).speak()}");

            return;
        si
    si
si
