
use IO.Std.write_line;
use Collections.KeyValuePair;
use Collections.LIST;
use Collections.MAP;

entry() is
    let dict = MAP[string, int]();
    dict.add("alpha", 1);
    dict.add("beta", 2);
    dict.add("gamma", 3);

    let names = LIST[string]();
    for (k, v) in dict do
        names.add("{k}={v}");
    od
    names.sort();
    for n in names do
        write_line(n);
    od

    let one = KeyValuePair[int, string](1, "one");
    let two = KeyValuePair[int, string](2, "two");
    let pairs = [one, two];

    for (n, name) in pairs do
        write_line("{n}: {name}");
    od
si
