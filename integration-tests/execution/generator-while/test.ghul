namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Ghul.Pipes.Pipe[int] static is
            let i mut = 0;
            while i < 4 do
                yield i;
                i = i + 1;
            od
        si

        entry() static is
            for v in gen() do
                Std.write_line("v: {v}");
            od
        si
    si
si
