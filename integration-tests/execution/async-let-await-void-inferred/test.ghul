namespace Test is
    use Std = IO.Std;

    class Main is
        // Inferred-return lambda whose body contains `let await`
        // but no value-returning `return X;` — settles as the
        // non-generic `Tasks.TASK`. End-of-body fallthrough emits
        // `Tasks.TASK.completed_task` for the synthesised inner
        // continuation lambda.
        entry() static is
            let f = () is
                let await x = Tasks.TASK.from_result(42);
                Std.write_line("got {x}");
            si;

            f().wait();

            Std.write_line("done");
        si
    si
si
