namespace Test is
    use IO.Std;
    use Collections;

    // Tests: a generic method (function-level T)
    // inside a generic class (owner-level T). Both type variables
    // exist; the method's T should be inferable independently.

    class Container[T] is
        _value: T;
        init(v: T) is _value = v; si

        // Method-level type-arg U distinct from owner's T.
        map_to[U](f: T -> U) -> Container[U] =>
            Container[U](f(_value));

        value: T => _value;
    si

    class Main is
        entry() static is
            let c = Container(42);
            let s = c.map_to(n => "n={n}");
            Std.write_line(s.value);
            return;
        si
    si
si
