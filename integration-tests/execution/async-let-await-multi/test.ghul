namespace Test is
    use Std = IO.Std;

    class Main is
        compute() -> Tasks.TASK[int] static is
            let await a = Tasks.TASK.from_result(10);
            let await b = Tasks.TASK.from_result(20);
            let await c = Tasks.TASK.from_result(30);

            return Tasks.TASK.from_result(a + b + c);
        si

        entry() static is
            let result = compute();

            Std.write_line("multi.result={result.result}");
        si
    si
si
