namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let x = 10;
            let y = 20;
            swap(x ref, y ref);
            Std.out.write_line("x={x} y={y}");
        si

        swap(a: int ref, b: int ref) static is
            let t = a!;
            a! = b!;
            b! = t;
        si
    si
si
