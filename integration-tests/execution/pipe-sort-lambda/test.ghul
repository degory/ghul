namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.sort` in
    // `ghul-runtime/src/pipe.ghul`:
    //   sort(compare: (T, T) -> int) -> Pipe[T]
    //
    // Single type variable; the lambda has two T-typed params.
    // Both lambda params should infer from the pipe's element
    // type without back-feed via body operations — the formal
    // `(T, T) -> int` carries the binding.

    class Main is
        entry() static is
            let xs = [3, 1, 4, 1, 5, 9, 2, 6];

            let sorted = xs | .sort((a, b) => a - b) .collect();

            for v in sorted do
                Std.write_line("{v}");
            od

            return;
        si
    si
si
