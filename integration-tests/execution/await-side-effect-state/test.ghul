namespace Test is
    use Std = IO.Std;
    class Main is
        counter: int public static;

        // bump() reads counter, increments by 100, returns the OLD value.
        // Called from LHS of a binary; should evaluate BEFORE the await
        // suspends (source eval order).
        bump() -> int static is
            let old = counter;
            counter = counter + 100;
            return old;
        si

        change_after_delay() -> Tasks.TASK[int] static is
            return Tasks.TASK.delay(5).continue_with(
                (t: Tasks.TASK) -> int is
                    counter = counter + 1;
                    return 7;
                si
            );
        si

        // User wrote `bump() + await ...`. Expected:
        //   1. bump() reads counter=0, sets counter=100, returns 0.
        //   2. await suspends.
        //   3. continuation runs after delay: counter=101, await result = 7.
        //   4. add: 0 + 7 = 7.
        //
        // If the spiller is missing, bump() fires AFTER the await:
        //   1. await suspends.
        //   2. continuation: counter=1, await result=7.
        //   3. bump() reads counter=1, sets counter=101, returns 1.
        //   4. add: 1 + 7 = 8 (WRONG).
        compute() -> Tasks.TASK[int] static is
            let x = bump() + await change_after_delay();
            return x;
        si

        entry() static is
            let r = compute().result;
            Std.write_line("x={r} counter={counter}");
        si
    si
si
