namespace Test is
    use IO.Std;

    // Guarded if-let: the else arm is reached on two paths — the
    // type test failed, OR the test succeeded but the guard was
    // false. On the second path the scrutinee genuinely IS the
    // narrow target, so the else arm can't assume the complement.
    // Narrowing the scrutinee to the complement variant here would
    // be unsound. The `elif isa CIRCLE(s)` test would be statically
    // dead if the bug had fired; if it doesn't fire we observe the
    // degenerate-circle case at runtime.
    union Shape is
        CIRCLE(radius: int);
        SQUARE(side: int);
    si

    use Shape.CIRCLE;
    use Shape.SQUARE;

    class Main is
        entry() static is
            describe(CIRCLE(0));
            describe(CIRCLE(5));
            describe(SQUARE(3));
        si

        describe(s: Shape) static is
            if let c: CIRCLE = s /\ c.radius > 0 then
                Std.out.write_line("non-degenerate circle of radius {c.radius}");
            elif isa CIRCLE(s) then
                Std.out.write_line("degenerate circle");
            else
                Std.out.write_line("square");
            fi
        si
    si
si
