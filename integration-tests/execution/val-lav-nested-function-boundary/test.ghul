use IO.Std.write_line;

// A `return` inside a function literal nested inside a val-block
// must target the function literal, NOT the enclosing val-block.
// The compile-expressions val-block stack pushes a null marker at
// each function-literal boundary so the lookup at `return` sees no
// val-block target and routes to the function-return path.

// Block-bodied lambda nested in a val-block. `return 42` exits the
// lambda; the val-block resumes with the lambda's value.
block_body_lambda() -> int is
    let result = val
        let h = () -> int is
            return 42;
        si;

        h() + 1
    lav;

    return result;
si

// Expression-bodied lambda nested in a val-block where the lambda's
// body is itself a val-block. Inner val-block return targets inner;
// inner lambda's value flows back to the outer val-block.
nested_val_in_lambda() -> int is
    let result = val
        let f = () =>
            val
                if true then
                    return 10;
                fi
                999
            lav;

        f() * 2
    lav;

    return result;
si

// Lambda whose body contains a `return` while the lambda's call
// site is part of an outer val-block's tail expression — the
// lambda's return doesn't escape to the val-block.
lambda_return_in_val_tail() -> int is
    let result = val
        let g = (n: int) -> int is
            if n < 0 then
                return 0;
            fi
            return n * 100;
        si;

        g(3) + g(-1)
    lav;

    return result;
si

entry() is
    write_line("block_body_lambda = {block_body_lambda()}");
    write_line("nested_val_in_lambda = {nested_val_in_lambda()}");
    write_line("lambda_return_in_val_tail = {lambda_return_in_val_tail()}");
si
