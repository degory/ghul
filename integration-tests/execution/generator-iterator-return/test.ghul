namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Ghul.Pipes.Pipe[int] static is
            yield 100;
            yield 200;
        si

        entry() static is
            let it = gen();
            while it.move_next() do
                Std.write_line("it: {it.current}");
            od
        si
    si
si
