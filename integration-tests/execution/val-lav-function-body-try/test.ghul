use IO.Std.write_line;

// `=> val ... lav` body of a function/method/lambda elides itself:
// returns inside flow to the enclosing function via the ordinary
// function-return path. So `return` inside a `try ... yrt` inside
// a `=> val ... lav` body uses the same machinery as `return`
// inside a `try ... yrt` inside an `is ... si` body — finally fires
// before the return takes effect, no boundary-crossing rejection.

// `=>` body with try-catch-finally + returns on all paths.
divide_or_default(n: int, d: int) -> int =>
    val
        try
            return n / d;
        catch e: System.DivideByZeroException
            write_line("caught divide-by-zero");
            return 0;
        finally
            write_line("finally ran");
        yrt
    lav;

// Method body: same shape, plus a value-providing tail. Returns
// inside the if take the early exit; fall-through emits the tail.
class CLAMP is
    init() is si

    clamp(n: int) -> int =>
        val
            if n < 0 then
                return 0;
            fi
            if n > 100 then
                return 100;
            fi
            n
        lav;
si

entry() is
    write_line("divide_or_default(20, 4) = {divide_or_default(20, 4)}");
    write_line("divide_or_default(10, 0) = {divide_or_default(10, 0)}");

    let c = CLAMP();
    write_line("clamp(-5) = {c.clamp(-5)}");
    write_line("clamp(50) = {c.clamp(50)}");
    write_line("clamp(150) = {c.clamp(150)}");

    // Lambda with explicit `-> int` and val-block body containing
    // a try with return inside.
    let safe_div = (n: int, d: int) -> int =>
        val
            try
                return n / d;
            catch e: System.DivideByZeroException
                return -1;
            yrt
        lav;

    write_line("safe_div(15, 3) = {safe_div(15, 3)}");
    write_line("safe_div(7, 0) = {safe_div(7, 0)}");

    // Inferred-return lambda whose val-body has all-returns (no
    // value-providing tail). Lambda's return type infers from the
    // returns inside, which flow via the function-return path.
    let inferred_div = (n: int, d: int) =>
        val
            try
                return n / d;
            catch e: System.DivideByZeroException
                return 0;
            yrt
        lav;

    write_line("inferred_div(12, 4) = {inferred_div(12, 4)}");
    write_line("inferred_div(9, 0) = {inferred_div(9, 0)}");
si
