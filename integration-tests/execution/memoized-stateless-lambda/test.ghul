namespace Test is
    use IO.Std.write_line;

    // A stateless (zero-capture) global lambda. Every evaluation of the
    // literal yields the same cached delegate instance, so two loads are
    // reference-equal.
    stateless() -> int -> int => n => n + 1;

    entry() is
        let a = stateless();
        let b = stateless();

        write_line("same instance: {object.reference_equals(a, b)}");
        write_line("a(41) = {a(41)}");
    si
si
