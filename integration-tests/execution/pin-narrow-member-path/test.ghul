namespace Test is
    use IO.Std;

    // The pinning presence test `path?!`: evaluates the member-access
    // path once, binds the tested value to a hidden local, and — on
    // the true edge — uses of the path load the pinned value at its
    // non-optional type. The pin is a local, so it survives calls
    // (nothing a callee does can rebind it) and a computed getter runs
    // once at the test, not once per use. Covers the reference `T?`
    // and value-type `NULLABLE[T]` shapes, a mutating call between
    // test and use, a `?.` chain, and pin invalidation by a visible
    // write to the path.

    class NODE is
        _next: NODE?;
        name: string public;
        next: NODE? => _next;
        init(name: string, next: NODE?) is
            self.name = name;
            self._next = next;
        si
    si

    class COUNTER is
        n: int? public;
        pokes: int public;
        init(n: int?) is self.n = n; si
        poke() is
            pokes = pokes + 1;
        si
    si

    class CELL is
        finds: int public;
        _items: Collections.Iterable[NODE];
        big: NODE? is
            finds = finds + 1;
            return _items | .find(n => n.name.length > 3);
        si
        init(items: Collections.Iterable[NODE]) is _items = items; si
    si

    class HOLDER is
        cell: CELL? public;
        init(cell: CELL?) is self.cell = cell; si
    si

    class Main is
        shout(s: string) static is
            // takes a non-optional string — only reachable through a
            // sound narrow
            Std.write_line("ref: {s}");
        si

        add_one(n: int) static is
            Std.write_line("val: {n + 1}");
        si

        entry() static is
            let head = NODE("head", NODE("tail", null));

            if head.next?! then
                shout(head.next.name);
            fi

            let lone = NODE("lone", null);
            if lone.next?! then
                Std.write_line("unreachable");
            else
                Std.write_line("ref: absent");
            fi

            // value-type optional: the use projects the pinned wrapper
            let c = COUNTER(41);
            if c.n?! then
                c.poke();               // a call between test and use
                add_one(c.n);
            fi
            Std.write_line("pokes: {c.pokes}");

            let cempty = COUNTER(null);
            if cempty.n?! then
                Std.write_line("unreachable");
            else
                Std.write_line("val: absent");
            fi

            // computed getter: runs once at the test, not per use
            let cell = CELL([NODE("cell", null)]);
            if cell.big?! then
                shout(cell.big.name);
                shout(cell.big.name);
            fi
            Std.write_line("finds: {cell.finds}");

            // `?.` chain: the leaf pin narrows the chained respelling
            let holder = HOLDER(cell);
            if holder.cell?.big?! then
                shout(holder.cell?.big.name);
            fi

            // a visible write to the path drops the pin: after the
            // store the path reads back at its optional type
            let d = COUNTER(7);
            if d.n?! then
                d.n = null;
                if d.n? then
                    Std.write_line("unreachable");
                else
                    Std.write_line("val: dropped");
                fi
            fi

            return;
        si
    si
si
