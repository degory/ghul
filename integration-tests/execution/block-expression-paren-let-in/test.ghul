use IO.Std.write_line;

entry() is
    // `(let x = e in body)` continues to parse as a parenthesised
    // let-in expression — the block-expression dispatch only triggers
    // when `;` follows the let's variable list.
    let n = (let x = 5 in x * 3);
    write_line("n = {n}");

    // Nested: outer block, inner let-in.
    let m = (
        let a = 4;
        let b = (let c = a + 1 in c * c);
        b - 1
    );
    write_line("m = {m}");
si
