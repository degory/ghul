namespace Test is
    use IO.Std;

    // Tests: two-param lambda where each parameter
    // gets distinct type signals from the body. `a.length` forces
    // a to have a `length` member (string fits). `b + 1` forces
    // b to be addable to int.

    class Main is
        entry() static is
            let f = (a, b) => a.length + b;
            Std.write_line("{f("hello", 5)}");
            return;
        si
    si
si
