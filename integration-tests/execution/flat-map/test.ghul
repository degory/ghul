namespace Test is
    use IO.Std;
    use Collections;

    // Tests: flat_map has TWO type variables —
    // T (from the receiver Iterable[T]) and U (from the mapper's
    // return type). U must be inferred from the mapper's return,
    // requiring back-feed from the mapper's body.

    class Main is
        entry() static is
            let xs = [1, 2, 3];
            let result = xs | .flat_map(x => [x, x * 10]) .collect();
            for v in result do
                Std.write_line("{v}");
            od
            return;
        si
    si
si
