namespace Test is
    use Std = IO.Std;

    trait HasName is
        name: string => "default";
    si

    class CUSTOM: HasName is
        init() is si

        name: string public => "custom";
    si

    class Main is
        entry() static is
            let c = CUSTOM();
            Std.write_line(c.name);
        si
    si
si
