class HOST is
    init() is si

    @System.Obsolete("legacy", diagnostic_id = "GHUL001", url_format = "https://ghul.dev/obsolete")
    old_method() is si
si

entry() static is
    for a in HOST().get_type().get_method("old_method").get_custom_attributes(false) do
        let obsolete = cast System.ObsoleteAttribute(a);
        if obsolete? then
            IO.Std.write_line("message={obsolete.message}");
            IO.Std.write_line("diagnostic_id={obsolete.diagnostic_id}");
            IO.Std.write_line("url_format={obsolete.url_format}");
        fi
    od

    return;
si
