namespace Test is
    use IO.Std;
    use Collections;

    // Regression guard: passing a function reference to a higher-
    // order function. ghūl currently doesn't support bare method-
    // group references as values — `apply_each(xs, double)` errors
    // with "cannot use this here" (separate gap: needs a method-
    // group-to-function conversion mechanism). The lambda wrapper
    // `apply_each(xs, x => double(x))` works today. Pinned because
    // a tightening of the consumable/back-feed predicates could
    // accidentally regress the wrapper form too.

    double(x: int) -> int => x * 2;

    apply_each[T,U](xs: Iterable[T], f: T -> U) -> LIST[U] is
        let result = LIST[U]();
        for x in xs do
            result.add(f(x));
        od
        return result;
    si

    class Main is
        entry() static is
            let xs = [1, 2, 3];
            let doubled = apply_each(xs, x => double(x));
            for d in doubled do
                Std.write_line("{d}");
            od
            return;
        si
    si
si
