namespace Test is
    use Std = IO.Std;

    class Main is
        compute() -> Tasks.TASK[int] static is
            Std.write_line("step.1");
            let a = await Tasks.TASK.from_result(7);
            Std.write_line("step.2.a={a}");
            let scaled = a * 100;
            let b = await Tasks.TASK.from_result(scaled);
            Std.write_line("step.3.b={b}");

            return b + 1;
        si

        entry() static is
            let result = compute();

            Std.write_line("interspersed.result={result.result}");
        si
    si
si
