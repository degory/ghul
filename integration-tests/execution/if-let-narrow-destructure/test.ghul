namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // root narrowing + destructure: `(name, age): Cat = animal`
            describe_cat(Cat("Felix", 3));
            describe_cat(Dog("Rex"));
            describe_cat(null);

            // per-element narrowing: `(c: Cat, d: Dog) = pair`
            try_pair(Cat("Felix", 3), Dog("Rex"));
            try_pair(Dog("Rex"), Dog("Rex"));
            try_pair(Cat("Felix", 3), Cat("Mog", 2));
            try_pair(null, Dog("Rex"));

            // narrowed type lets subtype-only methods through
            narrowed_methods(Cat("Felix", 3), Dog("Rex"));
            narrowed_methods(Dog("Rex"), Cat("Felix", 3));

            // recursive nested narrow:
            // `((x, y): POINT, c: Color) = box`
            recursive_destruct(BOX(POINT(3, 4), RED()));
            recursive_destruct(BOX("not a point", RED()));
            recursive_destruct(BOX(POINT(1, 2), "not a color"));

            // elif let chain with per-element narrowing
            elif_chain(PAIR(Cat("Felix", 3), Cat("Mog", 2)));
            elif_chain(PAIR(Dog("Rex"), Dog("Spot")));
            elif_chain(PAIR(Cat("Tom", 4), Dog("Rex")));
        si

        describe_cat(animal: Animal?) static is
            if let (name, age): Cat = animal then
                Std.out.write_line("cat: {name}, {age}");
            else
                Std.out.write_line("not a cat");
            fi
        si

        try_pair(a: Animal?, b: Animal?) static is
            let p: PAIR? = if a? /\ b? then PAIR(a!, b!) else null fi;

            if let (c: Cat, d: Dog) = p then
                Std.out.write_line("c={c.name}, d={d.name}");
            else
                Std.out.write_line("no");
            fi
        si

        narrowed_methods(a: Animal, b: Animal) static is
            let p = PAIR(a, b);

            if let (c: Cat, d: Dog) = p then
                c.meow();
                d.bark();
            else
                Std.out.write_line("nope");
            fi
        si

        recursive_destruct(box: BOX) static is
            if let ((x, y): POINT, c: Color) = box then
                Std.out.write_line("point ({x},{y}) {c.label}");
            else
                Std.out.write_line("no shape");
            fi
        si

        elif_chain(p: PAIR) static is
            if let (c: Cat, d: Dog) = p then
                Std.out.write_line("cat-dog: {c.name}/{d.name}");
            elif let (c1: Cat, c2: Cat) = p then
                Std.out.write_line("two cats: {c1.name}/{c2.name}");
            elif let (d1: Dog, d2: Dog) = p then
                Std.out.write_line("two dogs: {d1.name}/{d2.name}");
            else
                Std.out.write_line("other");
            fi
        si
    si

    class Animal is
        name: string;
        init(name: string) is self.name = name; si
    si

    class Cat: Animal is
        age: int;
        init(name: string, age: int) is super.init(name); self.age = age; si
        meow() is Std.out.write_line("{name} meow"); si
    si

    class Dog: Animal is
        init(name: string) is super.init(name); si
        bark() is Std.out.write_line("{name} woof"); si
    si

    class PAIR is
        `0: Animal field;
        `1: Animal field;
        init(a: Animal, b: Animal) is `0 = a; `1 = b; si
    si

    class POINT is
        `0: int field;
        `1: int field;
        init(x: int, y: int) is `0 = x; `1 = y; si
    si

    class Color is
        label: string;
        init(label: string) is self.label = label; si
    si

    class RED: Color is
        init() is super.init("red"); si
    si

    class BOX is
        `0: object field;
        `1: object field;
        init(a: object, b: object) is `0 = a; `1 = b; si
    si
si
