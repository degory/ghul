use IO.Std.write_line;

// Basic: `return E` inside `val ... lav` exits the block, not the
// enclosing function.
basic(n: int) -> int is
    let x = val
        if n < 0 then
            return 0;
        fi
        n * 2
    lav;

    write_line("basic({n}) saw x = {x}");

    return x + 1;
si

// LUB across returns + tail. All three contributors are int so the
// block's value type is int.
lub_returns_and_tail(n: int) -> int is
    let x = val
        if n == 0 then
            return -1;
        elif n == 1 then
            return 100;
        fi
        n * 10
    lav;

    return x;
si

// Nesting: `return E` targets the innermost val-block, the outer
// block continues with the value the inner block produced.
nesting() -> int is
    let total = val
        let inner = val
            if true then
                return 7;
            fi
            999
        lav;

        write_line("nesting inner = {inner}");
        inner + 3
    lav;

    return total;
si

// val-block as `=>` body of an expression-bodied function. The
// block's inferred type IS the function's return type.
expr_body(n: int) -> int =>
    val
        if n < 0 then
            return -n;
        fi
        n
    lav;

// val-block as `=>` body of a lambda. Same composition.
lambda_test() is
    let f = (n: int) -> int =>
        val
            if n == 0 then
                return 999;
            fi
            n + 1
        lav;

    write_line("lambda(0) = {f(0)}");
    write_line("lambda(5) = {f(5)}");
si

// Tail-only val-block (no returns) keeps working — purely an
// expression-form local-binding sequence.
tail_only(n: int) -> int =>
    val
        let doubled = n * 2;
        doubled + 1
    lav;

entry() is
    write_line("basic(-1) = {basic(-1)}");
    write_line("basic(3) = {basic(3)}");

    write_line("lub(0) = {lub_returns_and_tail(0)}");
    write_line("lub(1) = {lub_returns_and_tail(1)}");
    write_line("lub(7) = {lub_returns_and_tail(7)}");

    write_line("nesting() = {nesting()}");

    write_line("expr_body(-4) = {expr_body(-4)}");
    write_line("expr_body(9) = {expr_body(9)}");

    lambda_test();

    write_line("tail_only(5) = {tail_only(5)}");
si
