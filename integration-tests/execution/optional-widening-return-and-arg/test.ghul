namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Return-boundary widening: function declares `int?` return
            // type, function body returns `int` — the boxer wraps at
            // the return site.
            show(present_int(42));
            show(absent_int());

            // Argument-boundary widening: parameter declared `int?`,
            // caller passes a bare `int` — wrap at the call site.
            describe(7);
            describe(0);
        si

        // Returns a non-optional `int` value into a slot typed `int?`
        // — the wrap must fire on the return path.
        present_int(value: int) -> int? static is
            return value;
        si

        absent_int() -> int? static is
            return null;
        si

        // Parameter `count` is `int?`; a bare-`int` argument widens.
        describe(count: int?) static is
            if count? then
                Std.out.write_line("count present: {count!}");
            else
                Std.out.write_line("count absent");
            fi
        si

        show(c: int?) static is
            if c? then
                Std.out.write_line("show: {c!}");
            else
                Std.out.write_line("show: nothing");
            fi
        si
    si
si
