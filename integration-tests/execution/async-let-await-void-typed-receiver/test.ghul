namespace Test is
    use Std = IO.Std;

    class Main is
        // Void async lambda's inferred return type is the
        // non-generic `Tasks.TASK`. Confirming it slots into a
        // `() -> Tasks.TASK` parameter cleanly (the inferred type
        // matches a callee's declared parameter type).
        run(work: () -> Tasks.TASK) static is
            work().wait();
        si

        entry() static is
            let counter mut = 0;

            run(() is
                let await n = Tasks.TASK.from_result(7);
                counter = counter + n;
            si);

            run(() is
                let await n = Tasks.TASK.from_result(11);
                counter = counter + n;
            si);

            Std.write_line("counter = {counter}");
        si
    si
si
