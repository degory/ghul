namespace Test is
    use IO.Std;

    // Optional narrowing extends from locals to member-access paths:
    // `if receiver.prop? then … receiver.prop …` narrows the property
    // access from optional to non-optional within the guarded region,
    // so a further member access (`receiver.prop.member`) type-checks
    // without an explicit unwrap. Covers all three optional shapes —
    // reference `T?`, value-type `NULLABLE[T]`, and `MAYBE[T]` — and a
    // two-hop path through a nested guard. An unguarded path access
    // elsewhere still reports the optional type (and would warn).

    class NODE is
        _next: NODE?;
        name: string public;
        next: NODE? => _next;
        init(name: string, next: NODE?) is
            self.name = name;
            self._next = next;
        si
    si

    class COUNTER is
        _n: int?;
        n: int? => _n;
        init(n: int?) is _n = n; si
    si

    class CELL is
        _items: Collections.Iterable[NODE];
        big: NODE? => _items | .find(n => n.name.length > 3);
        init(items: Collections.Iterable[NODE]) is _items = items; si
    si

    class Main is
        entry() static is
            let head = NODE("head", NODE("tail", null));

            if head.next? then
                Std.write_line("ref: {head.next.name}");
            fi

            if head.next? then
                if head.next.next? then
                    Std.write_line("ref2: {head.next.next.name}");
                else
                    Std.write_line("ref2: absent");
                fi
            fi

            let lone = NODE("lone", null);
            if lone.next? then
                Std.write_line("unreachable");
            else
                Std.write_line("ref: absent");
            fi

            let c = COUNTER(41);
            if c.n? then
                Std.write_line("val: {c.n + 1}");
            fi

            let cempty = COUNTER(null);
            if cempty.n? then
                Std.write_line("unreachable");
            else
                Std.write_line("val: absent");
            fi

            let cell = CELL([NODE("cell", null)]);
            if cell.big? then
                Std.write_line("maybe: {cell.big.name}");
            fi

            let cellempty = CELL([NODE("ab", null)]);
            if cellempty.big? then
                Std.write_line("unreachable");
            else
                Std.write_line("maybe: absent");
            fi

            return;
        si
    si
si
