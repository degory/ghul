namespace Test is
    use Std = IO.Std;

    // An unconstrained T? lowers to Ghul.MAYBE[T]. A bare T flowing into
    // a T? slot widens implicitly, in both direct and if-arm positions,
    // for value-type and reference-type T alike.
    wrap[T](a: T) -> T? => a;
    wrap_if[T](f: bool, a: T) -> T? => if f then a else null fi;

    round_trip[T](a: T) -> T is
        let o = wrap(a);
        return o!;
    si

    class MAIN is
        entry() static is
            let a = wrap(42);
            Std.out.write_line("a: {a?} {a!}");

            let b = wrap("hello");
            Std.out.write_line("b: {b?} {b!}");

            Std.out.write_line("absent: {wrap_if[int](false, 7)?}");
            Std.out.write_line("present: {wrap_if[int](true, 7)!}");

            Std.out.write_line("rt int: {round_trip(99)}");
            Std.out.write_line("rt str: {round_trip("xyz")}");

            if let v = wrap(123) then
                Std.out.write_line("if-let: {v}");
            fi
        si
    si
si
