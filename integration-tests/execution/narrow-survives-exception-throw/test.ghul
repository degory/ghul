// Constructing a fresh exception writes only that new object, never a
// pre-existing heap slot, so a function that throws an imported
// exception stays store-free and a field narrowed across a call to it
// survives. The boundary is drawn at reflected exception types: a
// user-declared exception's constructor could store, and constructing
// any non-exception type is still unbounded, so both drop the narrow.

use IO.Std;

class BOX is
    v: int public;
    init() is si
    touch() -> int => v;
si

// a user-declared exception: its constructor is not trusted
class UNDERFLOW: System.Exception is
    init(message: string) is super.init(message); si
si

class HOLDER is
    _b: BOX?;
    init() is _b = BOX(); si

    // throws an imported (BCL) exception on one branch: store-free
    withdraw(balance: int, amount: int) -> int is
        if amount > balance then
            throw System.InvalidOperationException("insufficient funds");
        fi
        return balance - amount;
    si

    // throws a user-declared exception: not store-free
    withdraw_user(balance: int, amount: int) -> int is
        if amount > balance then
            throw UNDERFLOW("insufficient funds");
        fi
        return balance - amount;
    si

    // constructs a non-exception imported type: not store-free
    build_text() -> int is
        let sb = System.Text.StringBuilder();
        return sb.length;
    si

    // narrow survives the throwing call
    after_bcl_throw() -> int is
        if _b? then let n = withdraw(10, 1); return _b.touch() + n; fi
        return -1;
    si

    // narrow drops: user exception construction is not trusted
    after_user_throw() -> int is
        if _b? then let n = withdraw_user(10, 1); return _b.touch() + n; fi
        return -1;
    si

    // narrow drops: non-exception construction is not trusted
    after_non_exception_construction() -> int is
        if _b? then let n = build_text(); return _b.touch() + n; fi
        return -1;
    si
si

class Main is
    entry() static is
        let h = HOLDER();
        Std.write_line("{h.after_bcl_throw()}");
        Std.write_line("{h.after_user_throw()}");
        Std.write_line("{h.after_non_exception_construction()}");
    si
si
