// A contravariant trait — `SINK[T: in]` — accepts a `T` in an input
// position. A `SINK[ANIMAL]` is usable where a `SINK[CAT]` is expected,
// because a sink of animals can accept any cat.
namespace Test is
    use IO.Std;

    trait ANIMAL is
        speak() -> string;
    si

    class CAT: ANIMAL is
        init() is si
        speak() -> string => "meow";
    si

    trait SINK[T: in] is
        accept(value: T);
    si

    class PRINTER[T: ANIMAL]: SINK[T] is
        init() is si
        accept(value: T) is Std.write_line(value.speak()); si
    si

    class Main is
        entry() static is
            let animal_sink: SINK[ANIMAL] = PRINTER[ANIMAL]();
            let cat_sink: SINK[CAT] = animal_sink;
            cat_sink.accept(CAT());
        si
    si
si
