namespace Test is
    use IO.Std;
    use Collections;

    // Generic factory whose expression body is a lambda that uses
    // the outer T:
    //
    //   box_factory[T]() -> (T) -> BOX[T] => x => BOX(x);
    //
    // Inside `x => BOX(x)`:
    //   - the lambda's formal x has no annotation
    //   - the outer return type says the lambda is `(T) -> BOX[T]`
    //   - so x resolves to T
    //
    // The mechanism: when a lambda is the expression body of an
    // outer generic function whose return type is a Function shape,
    // the outer Function's argument types are back-fed onto the
    // lambda's arg-placeholder origins before the lambda body
    // walks.

    class BOX[T] is
        v: T;
        init(v: T) is self.v = v; si
    si

    box_factory[T]() -> (T) -> BOX[T] =>
        x => BOX(x);

    class Main is
        entry() static is
            let f = box_factory[int]();
            let b = f(42);
            Std.write_line("{b.v}");
            return;
        si
    si
si
