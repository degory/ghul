namespace Test is
    use IO.Std;
    use Collections;

    // Tests: `let m = MAP()` with no explicit K/V and
    // no initialiser. Later `m["a"] = 1` should back-feed K=string,
    // V=int onto the two phantom origins.

    class Main is
        entry() static is
            let m = MAP();
            m["a"] = 1;
            m["b"] = 2;
            m["c"] = 3;
            Std.write_line("count={m.count}");
            Std.write_line("a={m["a"]}");
            return;
        si
    si
si
