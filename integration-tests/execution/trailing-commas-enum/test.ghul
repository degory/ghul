namespace Test is
    use Std = IO.Std;

    // Enum members with trailing comma.
    enum COLOUR is
        RED,
        GREEN,
        BLUE,
    si

    // Enum members with assigned values + trailing comma.
    enum FLAGS is
        ON = 1,
        OFF = 2,
    si

    class Main is
        entry() static is
            let c = COLOUR.BLUE;
            let f = FLAGS.ON;
            Std.write_line("{c} {f}");
            return;
        si
    si
si
