use IO.Std.write_line;

// ---- Inference for lambdas containing val-blocks ----

// Lambda directly returning a val-block, with multiple returns
// inside contributing to the LUB. Lambda's inferred return type
// is the val-block's resolved type (int here).
lambda_returns_propagate() is
    let pick = (n: int) =>
        val
            if n == 1 then
                return 10;
            elif n == 2 then
                return 20;
            fi
            n * 100
        lav;

    let a = pick(1);
    let b = pick(2);
    let c = pick(3);

    write_line("pick(1) = {a}, pick(2) = {b}, pick(3) = {c}");
si

// Lambda containing a val-block as part of a larger expression
// body — the val-block is one of the contributors, not the whole
// body. The lambda's inferred return type still settles correctly
// from the surrounding expression.
lambda_contains_val_block() is
    let add_one = (n: int) =>
        val
            let doubled = n * 2;
            doubled
        lav + 1;

    write_line("add_one(5) = {add_one(5)}");
si

// ---- Inference for nested val-blocks ----

// Inner val-block's value type propagates as a contributor to the
// outer val-block's LUB. The outer block's tail consumes the inner
// block's value via a local.
nested_val_block_inference() is
    let result = val
        let inner = val
            if true then
                return 7;
            fi
            99
        lav;

        inner + 3
    lav;

    write_line("nested result = {result}");
si

// Returns at multiple nesting levels all target their innermost
// val-block. Inner returns 5; outer returns 10. Inner's value =
// LUB(5, tail=fallthrough). Outer's value = LUB(10, tail=inner * 2).
nested_returns_target_innermost() is
    let result = val
        let inner = val
            if true then
                return 5;
            fi
            99
        lav;

        if false then
            return 10;
        fi
        inner * 2
    lav;

    write_line("nested returns result = {result}");
si

// ---- Inference between if-expressions and val-blocks ----

// val-block whose tail is an if-expression. The if's branches must
// agree on a type; that propagates up as the val-block's value type.
val_block_with_if_tail() is
    let result = val
        let n = 7;
        if n > 0 then
            n * 2
        else
            0
        fi
    lav;

    write_line("val(if tail) = {result}");
si

// if-expression whose branches are val-blocks. Each branch's
// val-block value contributes to the if's LUB.
if_branches_are_val_blocks() is
    let result =
        if true then
            val
                let a = 4;
                a + 1
            lav
        else
            val
                return 0;
            lav
        fi;

    write_line("if(val branches) = {result}");
si

// val-block whose tail is an if-expression that itself uses val-
// blocks inside branches — deep mixed nesting, the LUB chain has
// to settle through each layer.
deeply_mixed_inference() is
    let result = val
        let n = 3;
        if n > 5 then
            val
                let big = n * 10;
                big
            lav
        elif n > 0 then
            val
                if n == 3 then
                    return 333;
                fi
                n + 100
            lav
        else
            val
                return -1;
            lav
        fi
    lav;

    write_line("deeply mixed = {result}");
si

entry() is
    lambda_returns_propagate();
    lambda_contains_val_block();
    nested_val_block_inference();
    nested_returns_target_innermost();
    val_block_with_if_tail();
    if_branches_are_val_blocks();
    deeply_mixed_inference();
si
