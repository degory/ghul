namespace Test is
    use Std = IO.Std;

    class Main is
        // This is the case that killed the previous CPS-based design:
        // a local declared once, referenced both before and after the
        // intervening yield, must keep its value across the
        // suspend/resume boundary. Lives on a frame field today.
        gen() -> Collections.Iterable[int] static is
            let x = 100;
            yield x;
            yield x + 1;
            let y = 200;
            yield y;
            yield x + y;
        si

        entry() static is
            for v in gen() do
                Std.write_line("v: {v}");
            od
        si
    si
si
