namespace Test is
    use IO.Std;

    // Tests: `NIL()` inside a `CONS` chain should
    // pick up T from the enclosing CONS's `tail: List[T]` parameter
    // type. Today it appears to typecheck but emits IL the CLR
    // rejects with InvalidProgramException.

    union List[T] is
        NIL;
        CONS(head: T, tail: List[T]);
    si

    use List.NIL;
    use List.CONS;

    class Main is
        entry() static is
            // NIL() innermost — T flows from the surrounding CONS's
            // tail: List[T] formal so the nil resolves to NIL[int].
            let l = CONS(1, CONS(2, CONS(3, NIL())));

            let stringify = (xs: List[int]) -> string rec =>
                if isa CONS(xs) then
                    let (head, tail) = xs in
                    "{head}, {rec(tail)}"
                else
                    "nil"
                fi;

            Std.write_line(stringify(l));
            return;
        si
    si
si
