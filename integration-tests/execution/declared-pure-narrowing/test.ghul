// Declared `pure` trusts a function as effectively store-free
// without proof, so callers keep flow-narrowing facts across calls
// to it. A pure function-typed parameter admits a literal whose body
// proved store-free on the spot; an unprovable literal draws a
// warning and the call conservatively drops heap facts anyway, so
// soundness never depends on the warning being heeded.

use Std = IO.Std;

trait COUNTER is
    next() -> int pure;
si

class GOOD: COUNTER is
    _base: int;
    init(base: int) is _base = base; si
    next() -> int pure => _base + 1;
si

class HOLDER is
    _tag: string?;

    init(t: string?) is
        _tag = t;
    si

    helper() -> int pure is
        return "abc".to_upper().length;
    si

    apply(f: (int) -> int pure, x: int) -> int pure => f(x);

    probe() is
        if _tag? then
            let n = helper();

            Std.write_line("kept: {_tag.length} {n}");
        fi

        Std.write_line("applied: {apply(y => y + 1, 3)}");

        if _tag? then
            let m = apply(y => y * 2, 4);

            Std.write_line("kept2: {_tag.length} {m}");
        fi

        if _tag? then
            let k = apply(y => val let z = poke() in y + z lav, 5);

            Std.write_line("dropped: {_tag.length} {k}");
        fi
    si

    poke() -> int is
        _tag = "clobbered";
        return 0;
    si
si

entry() is
    HOLDER("hi").probe();
    Std.write_line("{GOOD(1).next()}");
si
