namespace Test is
    use Std = IO.Std;
    class Main is
        // Two awaits in a single expression — exercises frame-field
        // persistence across multiple suspends. With CLR-local
        // storage of await results, the first result would be lost
        // when the second await suspends and re-enters MoveNext.
        compute() -> Tasks.TASK[int] static is
            let x = await Tasks.TASK.from_result(20) + await Tasks.TASK.from_result(22);
            return x;
        si

        entry() static is
            Std.write_line("got={compute().result}");
        si
    si
si
