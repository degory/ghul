use IO.Std.write_line;

entry() is
    // Block expression in void / statement position: the trailing
    // expression's value is discarded because the surrounding
    // context expects no value.
    (write_line("one"); write_line("two"); write_line("three"));

    // Block ending on a void statement is also fine in void context.
    (write_line("four"); write_line("five");

    );
si
