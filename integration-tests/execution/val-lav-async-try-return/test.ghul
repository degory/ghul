namespace Test is
    use Std = IO.Std;

    class Main is
        // Async function whose val-block body opens a `.try` and a
        // val-targeted `return` fires from inside that try. The
        // val-block's body also contains an `await`, so the spill
        // path runs: the targeted-return stfld's into the spill
        // field (stack empty) and then `leave`s the protected
        // region to the val-block's end_label. Outside spill mode
        // this shape would be rejected — `br end_label` would be
        // invalid IL across the try boundary and `leave` couldn't
        // carry the value.
        async_try_return(n: int) -> Tasks.TASK[int] static is
            let cleaned mut = "";

            let computed = val
                let warm = await Tasks.TASK.from_result(n);
                try
                    if warm < 0 then
                        return -1;
                    fi
                    if warm > 100 then
                        return 999;
                    fi
                finally
                    cleaned = "done";
                yrt
                warm * 2
            lav;

            Std.write_line("cleaned={cleaned}");
            return computed;
        si

        entry() static is
            Std.write_line("async_try_return(-5).result = {Main.async_try_return(-5).result}");
            Std.write_line("async_try_return(7).result = {Main.async_try_return(7).result}");
            Std.write_line("async_try_return(500).result = {Main.async_try_return(500).result}");
        si
    si
si
