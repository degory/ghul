namespace Test is
    use Std = IO.Std;

    class Main is
        compute(seed: int) -> Tasks.TASK[int] static is
            let x = await Tasks.TASK.from_result(seed);
            return x + 100;
        si

        chained(seed: int) -> Tasks.TASK[int] static is
            let x = await Tasks.TASK.from_result(seed);
            let y = await Tasks.TASK.from_result(x * 2);
            return x + y;
        si

        entry() static is
            let single = compute(7);
            let nested = chained(10);

            Std.write_line("let_in.single={single.result}");
            Std.write_line("let_in.nested={nested.result}");
        si
    si
si
