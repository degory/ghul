namespace Test is
    use Std = IO.Std;

    class Main is
        compute(seed: int) -> Tasks.TASK[int] static =>
            let await x = Tasks.TASK.from_result(seed) in
                Tasks.TASK.from_result(x + 100);

        chained(seed: int) -> Tasks.TASK[int] static =>
            let await x = Tasks.TASK.from_result(seed) in
                let await y = Tasks.TASK.from_result(x * 2) in
                    Tasks.TASK.from_result(x + y);

        entry() static is
            let single = compute(7);
            let nested = chained(10);

            Std.write_line("let_in.single={single.result}");
            Std.write_line("let_in.nested={nested.result}");
        si
    si
si
