namespace Test is
    use IO.Std;

    trait ANIMAL is
        speak() -> string;
    si

    class CAT: ANIMAL is
        init() is si
        speak() -> string => "meow";
    si

    trait STREAM[T: out] is
        head() -> T;
    si

    class SINGLE[T]: STREAM[T] is
        _value: T;
        init(value: T) is _value = value; si
        head() -> T => _value;
    si

    class Main is
        entry() static is
            let cats: STREAM[CAT] = SINGLE[CAT](CAT());
            let animals: STREAM[ANIMAL] = cats;
            Std.write_line(animals.head().speak());
        si
    si
si
