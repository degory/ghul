namespace Test is
    use Std = IO.Std;

    class Main is
        // Recursive lambda inside generator using `n rec =>` syntax
        gen() -> Ghul.Pipes.Pipe[int] static is
            let fact = n rec => if n == 0 then 1 else n * rec(n - 1) fi;
            yield fact(1);
            yield fact(3);
            yield fact(5);
        si

        entry() static is
            for x in gen() do
                Std.write_line("got {x}");
            od
        si
    si
si
