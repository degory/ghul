namespace Test is
    use Std = IO.Std;

    class HOLDER is
        init() is si

        emit() is Std.write_line("non-generic"); si
        emit[T](value: T) is Std.write_line("generic-{value}"); si
    si

    class Main is
        entry() static is
            let h = HOLDER();
            h.emit();
            h.emit[int](42);
            h.emit[string]("hello");

            return;
        si
    si
si
