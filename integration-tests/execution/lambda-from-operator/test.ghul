namespace Test is
    use IO.Std;

    // Regression guard: a let-bound lambda whose parameter type is
    // inferred from how the body uses it. Here `x` is used with the
    // `*` operator against an int literal, and the lambda is
    // immediately called with an int. The lambda's full type
    // resolves to `int -> int`.
    //
    // This currently works — the use-site call `times_2(7)` back-
    // feeds int to x's origin during the body retry loop, and the
    // re-walk picks `int * int -> int`. Pinned here so a future
    // change to the operator-on-placeholder path or the back-feed
    // ordering doesn't silently regress this idiom.

    class Main is
        entry() static is
            let times_2 = x => x * 2;
            Std.write_line("{times_2(7)}");
            return;
        si
    si
si
