namespace Test is
    use Std = IO.Std;
    use Collections.LIST;

    // Verifies that super(...) class-body declarations accept arbitrary
    // expressions whose free names are primary-ctor params (plus literals
    // and module/type-level references), not just bare identifiers.

    // Pre-existing identifier-only form still works.
    class ANIMAL is
        _name: string;

        init(name: string) is
            _name = name;
        si

        introduce() is
            Std.write_line("I am {_name}");
        si
    si

    // Literal in super(...).
    class WIDGET is
        _id: int;
        _label: string;

        init(id: int, label: string) is
            _id = id;
            _label = label;
        si

        describe() is
            Std.write_line("{_label}#{_id}");
        si
    si

    class NAMELESS(id: int): WIDGET is
        super(id, "anon");
    si

    // Member access on a primary param.
    class BOX[T] is
        _inner: T;

        init(inner: T) is
            _inner = inner;
        si

        unwrap: T => _inner;
    si

    class UNBOXED[T](source: BOX[T]): BOX[T] is
        super(source.unwrap);
    si

    // Wrapping expression: list literal built from a primary param.
    class STORE is
        _items: LIST[int];

        init(items: LIST[int]) is
            _items = items;
        si

        total: int is
            let s mut = 0;
            for i in _items do s = s + i; od
            return s;
        si
    si

    class SINGLE_ITEM_STORE(item: int): STORE is
        super(LIST[int]([item]));
    si

    // Same primary param twice in super(...) (preserves the
    // InnateFunction-style pattern).
    class PAIR is
        _left: int;
        _right: int;

        init(left: int, right: int) is
            _left = left;
            _right = right;
        si

        sum: int => _left + _right;
    si

    class DOUBLED(value: int): PAIR is
        super(value, value);
    si

    class Main is
        entry() static is
            NAMELESS(42).describe();
            Std.write_line(UNBOXED[int](BOX[int](7)).unwrap);
            Std.write_line(SINGLE_ITEM_STORE(99).total);
            Std.write_line(DOUBLED(5).sum);
        si
    si
si
