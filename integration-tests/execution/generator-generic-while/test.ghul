namespace Test is
    use Std = IO.Std;

    class Main is
        take[T](xs: Collections.Iterable[T], n: int) -> Ghul.Pipes.Pipe[T] static is
            let i mut = 0;
            let it = xs.iterator;
            while i < n /\ it.move_next() do
                yield it.current;
                i = i + 1;
            od
        si

        entry() static is
            for v in take[int]([10, 20, 30, 40, 50], 3) do
                Std.write_line("int: {v}");
            od
            for s in take[string](["a", "b", "c", "d"], 2) do
                Std.write_line("str: {s}");
            od
        si
    si
si
