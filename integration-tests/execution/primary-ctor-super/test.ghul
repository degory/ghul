namespace Test is
    use Std = IO.Std;

    class ANIMAL is
        _name: string;

        init(name: string) is
            _name = name;
        si

        introduce() is
            Std.write_line("I am {_name}");
        si
    si

    class DOG(name: string, breed: string): ANIMAL is
        _breed;

        super(name);

        bark() is
            Std.write_line("{_name} the {_breed} says woof");
        si
    si

    class Main is
        entry() static is
            let d = DOG("Rex", "labrador");
            d.introduce();
            d.bark();
        si
    si
si
