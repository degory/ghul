namespace Test is
    use IO.Std;
    use Collections;

    // Tests: lambda whose parameter is itself a
    // generic constructed type (`BOX[T]`), inferred via sibling-arg
    // owner-generic binding.
    //
    // `apply_to_box(BOX(42), b => b.value + 1)` — the first arg
    // binds T=int via `BOX[T]` formal. The lambda's parameter
    // formal `BOX[T]` becomes BOX[int]. Body uses `b.value` which
    // needs the parameter type to be a concrete BOX[int].

    class BOX[T] is
        _value: T;
        init(v: T) is _value = v; si
        value: T => _value;
    si

    apply_to_box[T](b: BOX[T], f: BOX[T] -> int) -> int =>
        f(b);

    class Main is
        entry() static is
            let r = apply_to_box(BOX(42), b => b.value + 1);
            Std.write_line("{r}");
            return;
        si
    si
si
