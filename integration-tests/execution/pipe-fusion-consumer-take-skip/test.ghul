namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // Terminal Pipe consumers (`count`/`any`/`all`/`reduce`/`find`/`first`/
    // `collect`) fuse with chains carrying `take`/`skip` stages, and with
    // bare chains that have no map/filter stage at all: the loop drives the
    // source's own iterator, `take`/`skip` become running counters, and the
    // ADAPTOR_PIPE / TAKE_PIPE / SKIP_PIPE objects (and, for a sealed
    // source, the box) are never built. The fused and unfused lowerings must
    // agree.

    class Main is
        entry() static is
            let ys = LIST[int]([10, 20, 30, 40, 50, 60]);

            // consumer over take/skip stages.
            Std.write_line("count:  {ys | .filter(n => n > 15).take(2).count()}");
            Std.write_line("any:    {ys | .skip(2).take(2).any(n => n == 40)}");
            Std.write_line("all:    {ys | .skip(1).take(3).all(n => n >= 20)}");
            Std.write_line("first:  {(ys | .skip(2).first()) ?? -1}");
            Std.write_line("reduce: {ys | .skip(1).take(2).reduce(0, (a, n) => a + n)}");

            // sealed range source with take/skip + consumer.
            Std.write_line("r-count: {(0..100) | .filter(n => n % 3 == 0).take(4).count()}");

            // bare (zero-stage) consumers - just the wrap, no map/filter.
            Std.write_line("bare-count: {ys | .count()}");
            Std.write_line("bare-any:   {ys | .any(n => n > 55)}");
            let arr = [7, 8, 9];
            Std.write_line("arr-count:  {arr | .count()}");
            Std.write_line("range-all:  {(0..5) | .all(n => n < 10)}");
        si
    si
si
