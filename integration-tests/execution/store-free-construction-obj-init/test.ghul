// Fresh-receiver reasoning applies only to construction. Calling a
// constructor as a method on a pre-existing object mutates that
// object, so it stays state-changing and drops the narrowing facts
// held on the receiver — the compiler can no longer assume `slot` is
// present after the call, even though this one happens to reset it to
// a value.

use Std = IO.Std;

class CELL is
    slot: string? field;
    init(s: string?) is slot = s; si
si

probe(c: CELL) is
    if c.slot? then
        c.init("reset");
        Std.write_line("{c.slot.length}");
    fi
si

entry() is probe(CELL("hi")); si
