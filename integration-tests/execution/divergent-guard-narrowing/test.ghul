use IO.Std.write_line;

union Maybe[T] is
    YES(value: T);
    NO;
si

class ANIMAL is
    name: string public;
    init(name: string) is self.name = name; si
    speak() -> string => "animal {name}";
si

class CAT: ANIMAL is
    init(name: string) is super.init(name); si
    purr() -> string => "{name} purrs";
si

class DOG: ANIMAL is
    init(name: string) is super.init(name); si
    bark() -> string => "{name} barks";
si

entry() is
    test_return_guard();
    test_throw_guard();
    test_continue_guard();
    test_break_guard();
    test_nested_all_branches_diverge();
    test_sequential_guards();
    test_guard_inside_outer_if();
    test_statements_before_return();
    test_variant_accessor_guard();
    test_non_divergent_does_not_carry();
si

// `if !isa T(x) then return fi` — the body diverges via return,
// so after the guard `a` is observed as `CAT`.
test_return_guard() is
    let a: ANIMAL = CAT("whiskers");

    if !isa CAT(a) then
        return;
    fi

    write_line("01-return-guard: {a.purr()}");
si

// Divergence via `throw` carries the narrow the same way.
test_throw_guard() is
    let a: ANIMAL = CAT("felix");

    if !isa CAT(a) then
        throw System.Exception("not a cat");
    fi

    write_line("02-throw-guard: {a.purr()}");
si

// Divergence via `continue` — the narrow carries for the rest of
// the loop body.
test_continue_guard() is
    let animals = [cast ANIMAL(CAT("tom")), cast ANIMAL(DOG("rex")), cast ANIMAL(CAT("sylvester"))];

    for a in animals do
        if !isa CAT(a) then
            continue;
        fi

        write_line("03-continue-guard: {a.purr()}");
    od
si

// Divergence via `break`.
test_break_guard() is
    let animals = [cast ANIMAL(CAT("garfield")), cast ANIMAL(DOG("odie"))];

    for a in animals do
        if !isa CAT(a) then
            break;
        fi

        write_line("04-break-guard: {a.purr()}");
    od
si

// The guard body is a nested if whose every branch diverges
// (return / throw). The body still counts as divergent.
test_nested_all_branches_diverge() is
    let a: ANIMAL = CAT("simba");
    let flag = true;

    if !isa CAT(a) then
        if flag then
            return;
        else
            throw System.Exception("not a cat");
        fi
    fi

    write_line("05-nested-all-diverge: {a.purr()}");
si

// Two divergent guards in sequence narrow two different
// variables; both narrows are live for the code that follows.
test_sequential_guards() is
    let a: ANIMAL = CAT("milo");
    let b: ANIMAL = DOG("buddy");

    if !isa CAT(a) then
        return;
    fi

    if !isa DOG(b) then
        return;
    fi

    write_line("06-sequential-guards: {a.purr()} | {b.bark()}");
si

// A divergent guard nested inside an outer non-divergent if —
// the narrow is scoped to the outer if's body and used there.
test_guard_inside_outer_if() is
    let a: ANIMAL = CAT("nala");
    let outer = true;

    if outer then
        if !isa CAT(a) then
            return;
        fi

        write_line("07-guard-inside-outer-if: {a.purr()}");
    fi
si

// Divergence detection looks at the last statement of the guard
// body, so statements before the `return` do not disturb it.
test_statements_before_return() is
    let a: ANIMAL = CAT("oreo");

    if !isa CAT(a) then
        write_line("08-guard-body-ran-unexpectedly");
        return;
    fi

    write_line("08-statements-before-return: {a.purr()}");
si

// The same mechanism carries a union variant narrow observed
// through a `!isa V(x)` guard.
test_variant_accessor_guard() is
    let m: Maybe[int] = Maybe.YES[int](42);

    if !isa Maybe.YES(m) then
        return;
    fi

    write_line("09-variant-accessor-guard: {m.value}");
si

// A non-divergent `!isa` branch must NOT carry a narrow — the
// branch falls through, so after it `a` is still `ANIMAL`. The
// body here uses only the wide-type API, confirming the program
// compiles and runs without the narrow.
test_non_divergent_does_not_carry() is
    let a: ANIMAL = CAT("ginger");

    if !isa CAT(a) then
        write_line("10-branch-ran-unexpectedly");
    fi

    write_line("10-non-divergent-no-carry: {a.speak()}");
si
