use IO.Std.write_line;

union Color is
    RED;
    GREEN;
si

union Option[T] is
    SOME(value: T);
    NONE;
si

union Many[T, U, V] is
    A(t: T);
    B(u: U);
    EMPTY;
si

same_ref(a: object, b: object) -> bool => a == b;

take_option(o: Option[int]) -> bool =>
    isa Option.NONE(o);

entry() is
    let c1: Color = Color.RED;
    let c2: Color = Color.RED();
    write_line(same_ref(c1, c2));
    write_line(isa Color.RED(c1));

    let n1: Option[int] = Option.NONE;
    let n2: Option[int] = Option.NONE();
    write_line(same_ref(n1, n2));
    write_line(isa Option.NONE(n1));

    let n_str: Option[string] = Option.NONE;
    write_line(same_ref(n1, n_str));

    let e1: Many[int, string, bool] = Many.EMPTY;
    let e2: Many[int, string, bool] = Many.EMPTY();
    write_line(same_ref(e1, e2));
    write_line(isa Many.EMPTY(e1));

    let m: Option[int] mut;
    m = Option.NONE;
    write_line(isa Option.NONE(m));

    write_line(take_option(Option.NONE));

    let n3: Option[int] = Option.NONE[int];
    write_line(same_ref(n1, n3));

    let s: Option[int] = Option.SOME(42);
    write_line(s!);
si
