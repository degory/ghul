namespace Test is
    use Std = IO.Std;

    struct VECTOR(dx: int, dy: int) is
        _dx;
        _dy;

        magnitude_squared() -> int => _dx * _dx + _dy * _dy;
    si

    class Main is
        entry() static is
            let v = VECTOR(3, 4);
            Std.write_line("{v.magnitude_squared()}");
        si
    si
si
