namespace Test is
    use Std = IO.Std;

    // Regression test for variance loaded from .NET reflection metadata.
    //
    // System.Collections.Generic.IEnumerable<out T> is declared covariant
    // in C#. ghūl maps it to Collections.Iterable[T]. With variance read
    // from GenericParameterAttributes, LIST[CAT] should satisfy
    // Iterable[ANIMAL] (CAT <: ANIMAL, Iterable covariant in T).

    class ANIMAL is
        init() is si
        kind: string => "animal";
    si

    class CAT: ANIMAL is
        init() is si
        kind: string => "cat";
    si

    print_each(animals: Collections.Iterable[ANIMAL]) static is
        for a in animals do
            Std.write_line(a.kind);
        od
    si

    class Main is
        entry() static is
            let cats = Collections.LIST[CAT]();
            cats.add(CAT());
            cats.add(CAT());

            print_each(cats);

            let as_iterable: Collections.Iterable[ANIMAL] = cats;

            for a in as_iterable do
                Std.write_line("via local: {a.kind}");
            od

            return;
        si
    si
si
