namespace Test is
    use IO.Std;

    trait Printer is print() -> string => "?"; si

    class BLAH() is
        _n: int;
        init(n: int) is _n = n; si
    si

    partial Test.BLAH is
        doubled() -> int => _n * 2;
    si

    impl Printer for Test.BLAH is
        print() -> string => "blah {_n}";
    si

    class Main is
        entry() static is
            let b = BLAH(21);
            Std.write_line("{b.doubled()}");
            let p: Printer = b;
            Std.write_line(p.print());
            return;
        si
    si
si
