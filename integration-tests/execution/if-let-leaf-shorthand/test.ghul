namespace Test is
    use IO.Std;

    // The if-let leaf-name shorthand: `if let x.y.z?` declares an
    // immutable local named after the path's last member, holding the
    // tested value — sugar for `if let z = x.y.z`. `if let x.y: T`
    // does the same with an isa narrow to T. Covers the reference
    // `T?` and value-type `NULLABLE[T]` shapes, guards, multi-clause
    // chains, `while let`, self-rooted paths, and the narrow form.

    class NODE is
        _next: NODE?;
        name: string public;
        next: NODE? => _next;
        init(name: string, next: NODE?) is
            self.name = name;
            self._next = next;
        si
    si

    class COUNTER is
        n: int? public;
        init(n: int?) is self.n = n; si
    si

    class ANIMAL is
        noise: string => "...";
    si

    class CAT: ANIMAL is
        noise: string => "meow";
        init() is si
    si

    class ZOO is
        pet: ANIMAL public;
        init(pet: ANIMAL) is self.pet = pet; si
    si

    class STACK is
        _items: Collections.LIST[string];
        top: string? =>
            if _items.count > 0 then _items[_items.count - 1] else null fi;
        init(items: Collections.LIST[string]) is _items = items; si
        pop() is _items.remove_at(_items.count - 1); si
    si

    class SELFY is
        thing: string? public;
        init(thing: string?) is self.thing = thing; si
        describe() -> string is
            if let self.thing? then
                return "selfy: {thing.to_upper()}";
            fi
            return "selfy: absent";
        si
    si

    class Main is
        shout(s: string) static is
            Std.write_line("ref: {s}");
        si

        entry() static is
            let head = NODE("head", NODE("tail", null));

            if let head.next? then
                shout(next.name);
            fi

            let lone = NODE("lone", null);
            if let lone.next? then
                Std.write_line("unreachable");
            else
                Std.write_line("ref: absent");
            fi

            // value-type optional
            let c = COUNTER(41);
            if let c.n? then
                Std.write_line("val: {n + 1}");
            fi

            // guard sees the declared name
            let deep = NODE("deep", NODE("abcd", null));
            if let deep.next? /\ next.name.length > 3 then
                shout(next.name);
            fi

            // multi-clause: later clauses see earlier names
            if let head.next?, c.n? then
                Std.write_line("chain: {next.name} {n}");
            fi

            // narrow form
            let zoo = ZOO(CAT());
            if let zoo.pet: CAT then
                Std.write_line("narrow: {pet.noise}");
            fi

            // while let: re-tested and re-declared each iteration
            let stack = STACK(Collections.LIST[string](["a", "b", "c"]));
            while let stack.top? do
                Std.write_line("top: {top}");
                stack.pop();
            od

            // self-rooted path inside a method
            Std.write_line(SELFY("hi").describe());
            Std.write_line(SELFY(null).describe());

            return;
        si
    si
si
