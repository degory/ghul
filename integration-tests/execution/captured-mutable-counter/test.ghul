namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let counter mut = 0;

            let bump = (n: int) is
                counter = counter + n;
            si;

            bump(1);
            bump(2);
            bump(3);

            Std.write_line("counter = {counter}");
        si
    si
si
