namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Ghul.Pipes.Pipe[int] static is
            let x mut = 1;
            yield x;
            x = x + 10;
            yield x;
            x = x * 2;
            yield x;
        si

        entry() static is
            for v in gen() do
                Std.write_line("v: {v}");
            od
        si
    si
si
