namespace Test is
    use Std = IO.Std;

    // Bootstrap-form `Foo\`N` references resolve via backtick-count
    // fallback. This is the migration path for source — including the
    // compiler's own source — that still spells third-party reflected
    // generic types with the .NET suffix.
    use Pair = Collections.KeyValuePair`2;

    class Main is
        entry() static is
            let p = Pair[string, int]("hello", 42);
            Std.write_line("{p.key}={p.value}");

            // Lazy`1 — single-generic-argument bootstrap form still works.
            let lazy: System.Lazy`1[int] = System.Lazy[int](() => 7);
            Std.write_line("{lazy.value}");

            return;
        si
    si
si
