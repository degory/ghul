namespace Test is
    use IO.Std;

    // `if x?` narrows a `MAYBE[T]` local to `T` on the true edge,
    // so a subsequent read can access members of `T` directly
    // without an explicit `!` unwrap. The member name here is
    // deliberately not `value` — that would also resolve via the
    // wrapper's structural `value: T` field and mask the narrowing.

    class Box is
        size: int;
        init(v: int) is size = v; si
        describe() -> string => "Box({size})";
    si

    class Main is
        entry() static is
            let xs = [Box(7), Box(11)];

            let hit = xs | .find(b => b.size > 8);
            if hit? then
                Std.write_line(hit.describe());
            else
                Std.write_line("none");
            fi

            let miss = xs | .find(b => b.size > 100);
            if miss? then
                Std.write_line(miss.describe());
            else
                Std.write_line("none");
            fi

            return;
        si
    si
si
