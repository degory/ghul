namespace Test is
    use Std = IO.Std;

    class POINT is
        x: int;
        y: int;

        init(x: int, y: int) is
            self.x = x;
            self.y = y;
        si

        deconstruct(a: int ref, b: int ref) is
            a! = x;
            b! = y;
        si
    si

    class Main is
        entry() static is
            let p = POINT(3, 7);
            let (px, py) = p;
            Std.out.write_line("({px}, {py})");
        si
    si
si
