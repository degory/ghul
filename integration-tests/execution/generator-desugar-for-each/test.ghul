namespace Ghul.Generators is
    enum _GEN_STEP_KIND is
        DONE,
        YIELD,
        TRANSITION,
    si

    struct _GEN_STEP[T] is
        kind: _GEN_STEP_KIND;
        value: T;
        next_state: int;

        init() is si

        init(kind: _GEN_STEP_KIND, value: T, next_state: int) is
            self.kind = kind;
            self.value = value;
            self.next_state = next_state;
        si
    si

    class _GEN_DRIVER[T]: Collections.Iterable[T], Collections.Iterator[T] is
        _states: Collections.List[() -> _GEN_STEP[T]];
        _state_index: int;
        _current: T;
        _done: bool;

        init(states: Collections.List[() -> _GEN_STEP[T]]) is
            _states = states;
            _state_index = 0;
            _done = false;
        si

        iterator: Collections.Iterator[T] => self;
        current: T => _current;

        move_next() -> bool is
            if _done then return false; fi
            while true do
                let step = _states[_state_index]();
                if step.kind == _GEN_STEP_KIND.DONE then
                    _done = true;
                    return false;
                elif step.kind == _GEN_STEP_KIND.YIELD then
                    _current = step.value;
                    _state_index = step.next_state;
                    return true;
                else
                    _state_index = step.next_state;
                fi
            od
            return false;
        si

        reset() is
            _state_index = 0;
            _done = false;
        si

        dispose() is si
    si

    _gen_pipe[T](states: Collections.List[() -> _GEN_STEP[T]])
        -> Collections.Iterable[T]
    =>
        _GEN_DRIVER[T](states);
si

namespace Test is
    use Std = IO.Std;

    class Main is
        // `for x in xs do yield ... od` desugars to a hidden while
        // on an explicit iterator. The for-loop variable is hoisted
        // to function scope (with type T extracted from xs's element
        // type via INTERNAL_DEFAULT_OF_ITERABLE_ELEMENT) so the state
        // lambdas can see it across yield-induced state splits.
        echo_doubled(xs: Collections.Iterable[int]) -> Collections.Iterable[int] static is
            for x in xs do
                yield x;
                yield x * 2;
            od
        si

        entry() static is
            let inputs: Collections.Iterable[int] = [1, 2, 3];
            let total mut = 0;
            for v in echo_doubled(inputs) do
                total = total + v;
            od
            Std.write_line("total={total}");
        si
    si
si
