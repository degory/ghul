use IO.Std.write_line;

// A bounded type parameter behaves as its bound inside a trait, struct
// or union body, matching how class and function generics already
// resolve member access through the declared bound. A value of such a
// parameter also dispatches through the bound at run time.

trait Comparable[T] is
    compare_to(other: T) -> int;
si

class BOX: Comparable[BOX] is
    value: int public;

    init(value: int) is
        self.value = value;
    si

    compare_to(other: BOX) -> int => value - other.value;
si

// bound member resolves in a trait default-method body
trait RANKER[E: Comparable[E]] is
    beats(a: E, b: E) -> bool => a.compare_to(b) > 0;
si

class RANKED: RANKER[BOX] is
    init() is si
si

// bound member resolves in a struct method body
struct CHOOSER[E: Comparable[E]] is
    init() is si

    larger(a: E, b: E) -> E => if a.compare_to(b) >= 0 then a else b fi;
si

// bounded union: constructs, reaches IL generation, and the bound
// member resolves in an impl block attached to it
union HOLDER[E: Comparable[E]] is
    NOTHING;
    ONE(item: E);
si

use HOLDER.NOTHING;
use HOLDER.ONE;

impl Comparable[HOLDER[E]] for HOLDER[E] is
    compare_to(other: HOLDER[E]) -> int =>
        if let this: ONE = self then
            if let that: ONE = other then
                this.item.compare_to(that.item)
            else
                1
            fi
        elif isa ONE(other) then
            -1
        else
            0
        fi;
si

entry() is
    write_line("{RANKED().beats(BOX(5), BOX(2))}");
    write_line("{RANKED().beats(BOX(1), BOX(9))}");
    write_line("{CHOOSER[BOX]().larger(BOX(3), BOX(7)).value}");

    let a: HOLDER[BOX] = ONE(BOX(7));
    let b: HOLDER[BOX] = ONE(BOX(3));
    let empty: HOLDER[BOX] = NOTHING;

    write_line("{a.compare_to(b)}");
    write_line("{a.compare_to(empty)}");
    write_line("{empty.compare_to(a)}");
si
