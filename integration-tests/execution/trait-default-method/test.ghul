namespace Test is
    use Std = IO.Std;

    trait Greeter is
        greet() is
            Std.write_line("hello from the trait default");
        si
    si

    class Greeting: Greeter is
        init() is si
    si

    class Main is
        entry() static is
            let g = Greeting();
            g.greet();
        si
    si
si
