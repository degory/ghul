use IO.Std.write_line;

// KNOWN LIMITATION (pinned, not fixed here): when a union has a
// primary-constructor header, the `..` splice expands a variant's
// inherited fields into `variant.fields`, which makes a
// would-be-unit variant non-unit. Add-accessors' implicit-default
// rule — "exactly one non-unit variant defaults to that variant" —
// then doesn't trigger, so no `value` / `has_value` is synthesised
// on the union. `?` on the variant collapses to a bare null-check
// (`compile_access.get_reference_has_value` with member=null), so
// the non-default variant reports `True` for `?` instead of `False`.
//
// Correct resolution would be to count own fields (not inherited)
// when classifying variants for implicit-default detection.
// Separate from the primary-params feature; tracked as a follow-up.
union BOX_OPT[T](id: int) is
    FULL(payload: T, ..);
    EMPTY(..);
si

entry() is
    let full: BOX_OPT[int] = BOX_OPT.FULL[int](42, 7);
    let empty: BOX_OPT[int] = BOX_OPT.EMPTY[int](9);

    // Current (incorrect) behavior: both report True because no
    // default variant is established and `?` collapses to a
    // null-check. With implicit-default detection counting own
    // fields, these should report True / False respectively.
    write_line("full?: {full?}");
    write_line("empty?: {empty?}");

    // Inherited member access still works on both, regardless.
    write_line("full.id: {full.id}");
    write_line("empty.id: {empty.id}");
si
