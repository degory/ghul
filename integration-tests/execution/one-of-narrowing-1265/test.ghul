use IO.Std.write_line;

union Trio[T] is
    A(a: T);
    B(b: T);
    C(c: T);
si

union Quad is
    W;
    X(x: int);
    Y(y: string);
    Z(z: bool);
si

union Maybe[T] is
    YES(value: T);
    NO;
si

entry() is
    test_three_variant_else_complement_b_taken();
    test_three_variant_else_complement_c_taken();
    test_three_variant_else_then_is_b();
    test_three_variant_else_then_is_a_statically_false();
    test_four_variant_elif_else_complement();
    test_full_elif_chain_exhaustive();
    test_full_elif_chain_complement_singleton();
    test_complement_member_via_union();
    test_chain_different_targets_no_narrow();
    test_chain_non_is_cond_kills();
    test_chain_repeated_variant_no_double_count();
    test_assignment_inside_oneof_else();
    test_generic_args_thread_into_oneof();
    test_disjunction_then_narrow_two_leaves();
    test_disjunction_then_narrow_three_leaves();
    test_disjunction_else_complement();
    test_disjunction_in_elif();
    test_disjunction_different_targets_no_narrow();
    test_disjunction_mixed_with_non_is_no_narrow();
    test_disjunction_singleton_after_dedup();
si

// 3-variant union, if t.is_a then ... else <- t narrowed to {B, C}.
// b path: read via outer ONE_OF then refine with `t.is_b`.
test_three_variant_else_complement_b_taken() is
    let t: Trio[int] = Trio.B[int](7);
    if t.is_a then
        write_line("01-then-not-reached");
    else
        if t.is_b then
            write_line("01-else-b: {t.b}");
        elif t.is_c then
            write_line("01-else-c-not-reached: {t.c}");
        fi
    fi
si

// 3-variant union, c path: same shape, exercises the other half
// of the {B, C} complement at runtime.
test_three_variant_else_complement_c_taken() is
    let t: Trio[string] = Trio.C[string]("see");
    if t.is_a then
        write_line("02-then-not-reached");
    else
        if t.is_b then
            write_line("02-else-b-not-reached: {t.b}");
        elif t.is_c then
            write_line("02-else-c: {t.c}");
        fi
    fi
si

// Subsequent is_<variant> on a ONE_OF receiver narrows to the
// singleton variant — confirms ONE_OF participates in the
// predicate path (not just member access).
test_three_variant_else_then_is_b() is
    let t: Trio[int] = Trio.B[int](42);
    if t.is_a then
        write_line("03-then-not-reached");
    else
        if t.is_b then
            let v: int = t.b;
            write_line("03-narrow-to-b: {v}");
        fi
    fi
si

// `is_<variant>` for a variant NOT in the ONE_OF set is
// statically false. V1 doesn't emit a diagnostic; here we just
// confirm the predicate evaluates to false at runtime (B doesn't
// satisfy is_a).
test_three_variant_else_then_is_a_statically_false() is
    let t: Trio[int] = Trio.B[int](99);
    if t.is_a then
        write_line("04-then-not-reached");
    else
        if t.is_a then
            write_line("04-statically-false-not-reached");
        else
            write_line("04-statically-false-else");
        fi
    fi
si

// 4-variant union, if + 2 elifs eliminate W, X, Y. Else complement
// is {Z}; ONE_OF.create degenerates to a singleton Z variant type.
test_four_variant_elif_else_complement() is
    let q: Quad = Quad.Z(true);
    if q.is_w then
        write_line("05-w-not-reached");
    elif q.is_x then
        write_line("05-x-not-reached: {q.x}");
    elif q.is_y then
        write_line("05-y-not-reached: {q.y}");
    else
        write_line("05-else-z: {q.z}");
    fi
si

// All variants eliminated. Else complement is empty; no narrowing
// is pushed. Body still compiles by accessing the union widely.
test_full_elif_chain_exhaustive() is
    let q: Quad = Quad.Y("hello");
    if q.is_w then
        write_line("06-w-not-reached");
    elif q.is_x then
        write_line("06-x-not-reached: {q.x}");
    elif q.is_y then
        write_line("06-y: {q.y}");
    elif q.is_z then
        write_line("06-z-not-reached: {q.z}");
    else
        write_line("06-else-not-reached");
    fi
si

// if + 2 elifs eliminate W, X, Y → else complement is singleton Z.
// Confirms the singleton-degenerate path: t.z (variant member) is
// directly accessible without an inner is_z check.
test_full_elif_chain_complement_singleton() is
    let q: Quad = Quad.Z(false);
    if q.is_w then
        write_line("07-w-not-reached");
    elif q.is_x then
        write_line("07-x-not-reached");
    elif q.is_y then
        write_line("07-y-not-reached");
    else
        let z: bool = q.z;
        write_line("07-else-singleton-z: {z}");
    fi
si

// Member access on a ONE_OF resolves to the union's own members.
// `to_string()` is inherited via the union from object — accessible
// on ONE_OF the same way it is on the plain union.
test_complement_member_via_union() is
    let t: Trio[int] = Trio.B[int](100);
    if t.is_a then
        write_line("08-then-not-reached");
    else
        let s: string = t.to_string();
        write_line("08-else-union-member: {s.length > 0}");
    fi
si

// Chain over two different variables — the second cond's target
// differs from the first chain entry, killing the frame. Else
// must NOT narrow.
test_chain_different_targets_no_narrow() is
    let a: Trio[int] = Trio.A[int](1);
    let b: Trio[int] = Trio.B[int](2);
    if a.is_a then
        write_line("09-a-taken");
    elif b.is_b then
        write_line("09-b-not-reached");
    else
        write_line("09-else-not-reached");
    fi
si

// Chain with a non-is_<variant> condition in the middle kills the
// frame. Else must NOT narrow (we exercise widely via is_b).
test_chain_non_is_cond_kills() is
    let t: Trio[int] = Trio.B[int](33);
    if t.is_a then
        write_line("10-a-not-reached");
    elif false then
        write_line("10-false-not-reached");
    else
        if t.is_b then
            write_line("10-else-via-is-b: {t.b}");
        fi
    fi
si

// Repeating an already-eliminated variant in an elif (dead code,
// but legal) doesn't double-count. With Trio (3 variants) and elim
// = {A, A} the complement is still {B, C}.
test_chain_repeated_variant_no_double_count() is
    let t: Trio[int] = Trio.C[int](11);
    if t.is_a then
        write_line("11-a-not-reached");
    elif t.is_a then
        write_line("11-a-redundant-not-reached");
    else
        if t.is_c then
            write_line("11-else-c: {t.c}");
        fi
    fi
si

// Assignment inside a complement-narrowed else: cancel_for
// restores the declared union type, so assigning the wider union
// type is legal (and the narrowing then no longer applies for
// later reads — none here, but the assignment must typecheck).
test_assignment_inside_oneof_else() is
    let t: Trio[int] = Trio.B[int](5);
    if t.is_a then
        write_line("12-a-not-reached");
    else
        t = Trio.A[int](77);
        if t.is_a then
            write_line("12-else-renarrow-a: {t.a}");
        fi
    fi
si

// Generic args thread into the ONE_OF — t.b inside the inner
// is_b path is int, not unspecialised.
test_generic_args_thread_into_oneof() is
    let t: Trio[string] = Trio.B[string]("bee");
    if t.is_a then
        write_line("13-a-not-reached");
    else
        if t.is_b then
            let v: string = t.b;
            write_line("13-generic-thread: {v} ({v.length})");
        fi
    fi
si

// Disjunction in the then-branch: `is_a \/ is_b` narrows to
// ONE_OF{A, B}. Inside the body, refining with `is_a` exposes
// the variant's field.
test_disjunction_then_narrow_two_leaves() is
    let t: Trio[int] = Trio.A[int](1);
    if t.is_a \/ t.is_b then
        if t.is_a then
            write_line("14-disj-then-a: {t.a}");
        elif t.is_b then
            write_line("14-disj-then-b-not-reached: {t.b}");
        fi
    fi
si

// Three-leaf disjunction. Same shape, the chain happens to be the
// full union — body sees ONE_OF{A,B,C}, refines with is_b.
test_disjunction_then_narrow_three_leaves() is
    let t: Trio[int] = Trio.B[int](2);
    if t.is_a \/ t.is_b \/ t.is_c then
        if t.is_b then
            write_line("15-disj-then-three-b: {t.b}");
        fi
    fi
si

// Disjunction with two-branch if/else: else complement is
// U \ {leaves}. {A,B} disjunction → else narrows to {C} (singleton).
test_disjunction_else_complement() is
    let t: Trio[int] = Trio.C[int](33);
    if t.is_a \/ t.is_b then
        write_line("16-disj-then-not-reached");
    else
        let v: int = t.c;
        write_line("16-disj-else-c: {v}");
    fi
si

// Disjunction inside one elif of a longer chain. eliminated set
// after the if + elif is {A} ∪ {B,C} = {A,B,C}. With Trio that
// exhausts the union — else complement is empty, no narrowing.
test_disjunction_in_elif() is
    let t: Trio[int] = Trio.B[int](44);
    if t.is_a then
        write_line("17-disj-elif-a-not-reached");
    elif t.is_b \/ t.is_c then
        if t.is_b then
            write_line("17-disj-elif-b: {t.b}");
        fi
    else
        write_line("17-disj-elif-else-not-reached");
    fi
si

// Disjunction across different targets — chain disqualifies; the
// else of an if/else with this cond stays unnarrowed (we verify
// via the wide-type path).
test_disjunction_different_targets_no_narrow() is
    let a: Trio[int] = Trio.A[int](1);
    let b: Trio[int] = Trio.B[int](2);
    if a.is_a \/ b.is_a then
        write_line("18-disj-diff-targets-then");
    else
        if a.is_b then
            write_line("18-disj-diff-targets-else-not-reached: {a.b}");
        fi
    fi
si

// `\/` chain mixed with a non-is_<variant> leaf disqualifies the
// chain entirely — neither then nor else gets the ONE_OF narrow.
test_disjunction_mixed_with_non_is_no_narrow() is
    let t: Trio[int] = Trio.A[int](1);
    if t.is_a \/ false then
        if t.is_a then
            write_line("19-disj-mixed-then-via-isa: {t.a}");
        fi
    fi
si

// Repeated variants in a disjunction dedupe to a single eliminated
// entry. `is_a \/ is_a` over Trio leaves the else with complement
// {B, C}.
test_disjunction_singleton_after_dedup() is
    let t: Trio[int] = Trio.B[int](7);
    if t.is_a \/ t.is_a then
        write_line("20-disj-dedup-then-not-reached");
    else
        if t.is_b then
            write_line("20-disj-dedup-else-b: {t.b}");
        fi
    fi
si
