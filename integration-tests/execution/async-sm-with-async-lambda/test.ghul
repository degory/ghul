namespace Test is
    use Std = IO.Std;

    class Main is
        // Named async function (state-machine) containing an async lambda
        compute() -> Tasks.TASK[int] static is
            let a = await Tasks.TASK.from_result(10);
            let g = () is
                let b = await Tasks.TASK.from_result(20);
                return b * 2;
            si;
            let c = await g();
            return a + c;
        si

        entry() static is
            let r = compute();
            Std.write_line("got={r.result}");
        si
    si
si
