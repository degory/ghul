namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // `null` as a leaf matches when the source position is
            // null. Useful for tuples where one component is optional.
            show(make_pair(null, "first absent"));
            show(make_pair("present", "first set"));
            show(null);
        si

        make_pair(a: string?, b: string) -> (string?, string)? static => (a, b);

        show(pair: (string?, string)?) static is
            if let (null, label) = pair then
                Std.out.write_line("first is null: {label}");
            else
                Std.out.write_line("nope");
            fi
        si
    si
si
