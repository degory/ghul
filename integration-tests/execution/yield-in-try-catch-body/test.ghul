namespace Test is
    use Std = IO.Std;

    class Main is
        // yield inside try body, catch only sees thrown exceptions.
        gen(should_throw: bool) -> Collections.Iterable[int] static is
            try
                yield 10;
                if should_throw then
                    throw System.Exception("boom");
                fi
                yield 20;
            catch e: System.Exception
                Std.write_line("caught: {e.message}");
            yrt
        si

        entry() static is
            for x in gen(false) do
                Std.write_line("normal got {x}");
            od

            for x in gen(true) do
                Std.write_line("throwing got {x}");
            od
        si
    si
si
