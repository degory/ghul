namespace Test is
    use Std = IO.Std;

    class Main is
        compute() -> Tasks.TASK[int] static is
            let answer = await Tasks.TASK.from_result(42);

            return answer + 1;
        si

        entry() static is
            let result = compute();

            Std.write_line("let_await.result={result.result}");
        si
    si
si
