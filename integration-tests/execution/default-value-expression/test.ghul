namespace Test is
    use Std = IO.Std;

    class BOX is
        value: int;
        init(value: int) is self.value = value; si
    si

    struct POINT is
        x: int;
        y: int;
    si

    class Main is
        // `default` in a return position picks up the return type,
        // both as an expression body and in a `return` statement.
        zero() -> int static => default;

        zero_block() -> int static is
            return default;
        si

        // `default` in an argument position picks up the parameter type.
        is_null(b: BOX) -> bool static => !b?;

        entry() static is
            // explicit type argument
            let i = default[int];
            Std.out.write_line("default[int]: {i}");

            // context type from a `let` annotation
            let b: bool = default;
            Std.out.write_line("default bool: {b}");

            // reference type defaults to null
            let box: BOX = default;
            Std.out.write_line("default BOX is null: {!box?}");

            // value-type struct defaults to all-zero
            let p: POINT = default;
            Std.out.write_line("default POINT: {p.x}, {p.y}");

            // assignment RHS picks up the target type
            let j mut = 99;
            j = default;
            Std.out.write_line("after j = default: {j}");

            // return and argument positions
            Std.out.write_line("zero(): {zero()}");
            Std.out.write_line("zero_block(): {zero_block()}");
            Std.out.write_line("is_null(default[BOX]): {is_null(default[BOX])}");
        si
    si
si
