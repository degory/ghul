namespace Test is
    use IO.Std;
    use Collections;

    // Tests: LHS type `LIST[int -> bool]` pushes
    // an element-type constraint into the list literal, which
    // pushes the lambda type as constraint into each lambda. The
    // lambdas' parameters should resolve to int.

    class Main is
        entry() static is
            let predicates: (int -> bool)[] = [x => x > 0, x => x < 10];
            for p in predicates do
                Std.write_line("{p(5)}");
            od
            return;
        si
    si
si
