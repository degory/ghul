// Path narrowing on a member of a generic container. `find_member` on
// a specialised generic re-specialises via memberwise_clone every
// call, so two lookups of the same member on the same receiver produce
// distinct Symbol instances. ACCESS_PATH canonicalises hops to their
// unspecialised template (root_specialized_from) so structural
// equality still matches — without that, isa/if-let narrows on a
// generic container's field never apply at the load site.

use Std = IO.Std;

class ANIMAL is
    name: string public;
    init(n: string) is name = n; si
si

class CAT: ANIMAL is
    init(n: string) is super.init(n); si
    meow() -> string => "meow ({name})";
si

class DOG: ANIMAL is
    init(n: string) is super.init(n); si
    bark() -> string => "bark ({name})";
si

class BOX[T] is
    v: T public;
    counter: int public;
    init(v: T) is self.v = v; si
    poke() is counter = counter + 1; si
si

// Type narrow: isa on a generic container's field.
isa_narrows(b: BOX[ANIMAL]) is
    if isa CAT(b.v) then
        Std.write_line("isa: {b.v.meow()}");
    fi
si

// Type narrow via if-let: same shape, different surface syntax.
if_let_narrows(b: BOX[ANIMAL]) is
    if let c: CAT = b.v then
        Std.write_line("if let: {c.meow()}");
    fi
si

// Two hops of read after narrow.
two_reads(b: BOX[ANIMAL]) is
    if isa CAT(b.v) then
        Std.write_line("two-reads: {b.v.name} / {b.v.meow()}");
    fi
si

// Call transfer: a possibly-storing call kills the path narrow.
call_forgets(b: BOX[ANIMAL]) is
    if isa CAT(b.v) then
        Std.write_line("before call: {b.v.meow()}");
        b.poke();
        Std.write_line("after call: {b.v.name}");
    fi
si

entry() is
    let bc = BOX[ANIMAL](CAT("felix"));
    isa_narrows(bc);
    if_let_narrows(bc);
    two_reads(bc);
    call_forgets(bc);
si
