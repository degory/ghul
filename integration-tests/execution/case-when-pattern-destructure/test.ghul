namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            try_destructure(lookup("alice"));
            try_destructure(lookup("bob"));

            describe_first(lookup("alice"));
            describe_first(lookup("bob"));

            classify(CAT("Felix"), DOG("Rex"));
            classify(DOG("Rex"), DOG("Spot"));
            classify(null, DOG("Rex"));
        si

        lookup(key: string) -> (string, int)? static is
            if key == "alice" then
                return ("alice", 42);
            fi
            return null;
        si

        try_destructure(value: (string, int)?) static is
            case value
            when null then
                Std.out.write_line("nothing");
            when (name, age) then
                Std.out.write_line("destructured: {name} = {age}");
            esac
        si

        describe_first(value: (string, int)?) static is
            case value
            when null then
                Std.out.write_line("no first");
            when (name, _) then
                Std.out.write_line("first: {name}");
            esac
        si

        classify(a: ANIMAL?, b: ANIMAL?) static is
            let p: PAIR? = if a? /\ b? then PAIR(a!, b!) else null fi;

            case p
            when null then
                Std.out.write_line("no pair");
            when (c: CAT, d: DOG) then
                Std.out.write_line("cat-dog: {c.name}/{d.name}");
            when (d1: DOG, d2: DOG) then
                Std.out.write_line("dog-dog: {d1.name}/{d2.name}");
            else
                Std.out.write_line("other");
            esac
        si
    si

    class ANIMAL is
        name: string;
        init(name: string) is self.name = name; si
    si

    class CAT: ANIMAL is
        init(name: string) is super.init(name); si
    si

    class DOG: ANIMAL is
        init(name: string) is super.init(name); si
    si

    class PAIR is
        `0: ANIMAL field;
        `1: ANIMAL field;
        init(a: ANIMAL, b: ANIMAL) is `0 = a; `1 = b; si
    si
si
