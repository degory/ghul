use IO.Std.write_line;

// `val ... lav` whose body opens a `.try` containing a `return E`
// targeting the val-block. Capture mode (no state-machine
// suspend), so the spill-to-frame-field path doesn't apply. The
// value is stashed into a CLR-local TEMP pre-allocated at val-
// block entry, the protected region is `leave`'d to a cross-try
// join label sitting outside the inner try, and the join
// `ldloc`s the TEMP back onto the stack so it falls through into
// the val-block's end_label.

// 1. Return crosses a single `.try { } finally { }`, the finally
// must still run.
single_try(take_return: bool) -> int is
    let cleaned mut = "";

    let x = val
        try
            if take_return then
                return 42;
            fi
        finally
            cleaned = "done";
        yrt
        99
    lav;

    write_line("single_try({take_return}) cleaned={cleaned} x={x}");
    return x;
si

// 2. Multiple return paths inside the same `.try` — both stash
// to the same TEMP and `leave` to the same join.
multiple_returns_one_try(n: int) -> int is
    let x = val
        try
            if n == 1 then
                return 11;
            fi
            if n == 2 then
                return 22;
            fi
            if n == 3 then
                return 33;
            fi
        finally
            write_line("multiple_returns_one_try cleanup n={n}");
        yrt
        99
    lav;

    return x;
si

// 3. Nested `.try` blocks; the return crosses both.
nested_try() -> string is
    let outer_cleanup mut = "";
    let inner_cleanup mut = "";

    let s = val
        try
            try
                if true then
                    return "deep";
                fi
            finally
                inner_cleanup = "inner";
            yrt
        finally
            outer_cleanup = "outer";
        yrt
        "fallthrough"
    lav;

    write_line("nested_try outer={outer_cleanup} inner={inner_cleanup}");
    return s;
si

entry() is
    write_line("single_try returned {single_try(true)}");
    write_line("single_try returned {single_try(false)}");

    write_line("multiple_returns_one_try(1) = {multiple_returns_one_try(1)}");
    write_line("multiple_returns_one_try(2) = {multiple_returns_one_try(2)}");
    write_line("multiple_returns_one_try(5) = {multiple_returns_one_try(5)}");

    write_line("nested_try = {nested_try()}");
si
