use IO.Std.write_line;

// Lambdas whose body is a val-block — all four shapes:
//   non-void with explicit return + tail
//   non-void with tail only (no explicit return)
//   void with explicit `return;` + tail
//   void with tail only (no explicit return)
entry() is
    // Non-void lambda (inferred), val-block with a return AND a
    // tail expression. The lambda's return type infers from the
    // val-block's resolved LUB(returns, tail) = int.
    let classify = (n: int) =>
        val
            if n < 0 then
                return -1;
            elif n == 0 then
                return 0;
            fi
            n
        lav;

    write_line("classify(-5) = {classify(-5)}");
    write_line("classify(0) = {classify(0)}");
    write_line("classify(7) = {classify(7)}");

    // Non-void lambda (inferred), val-block tail only.
    let double = (n: int) =>
        val
            let scaled = n * 2;
            scaled
        lav;

    write_line("double(4) = {double(4)}");

    // Void lambda (inferred), val-block with `return;` early exit.
    // The lambda's return type infers void from the val-block's
    // resolved value type, which itself comes from the tail
    // `write_line` (void) + the bare-return early-exit path.
    let log_if = (skip: bool, label: string) =>
        val
            if skip then
                return;
            fi
            write_line("log_if: {label}");
        lav;

    log_if(true, "skipped");
    log_if(false, "ran");

    // Void lambda (inferred), val-block tail only.
    let log_pair = (a: string, b: string) =>
        val
            write_line("log_pair a = {a}");
            write_line("log_pair b = {b}");
        lav;

    log_pair("first", "second");
si
