namespace Test is
    use Std = IO.Std;
    use Ghul.Pipes.STREAM;
    use Ghul.Pipes.stream;
    use STREAM.DONE;
    use STREAM.YIELD;

    // Regression: when the outer lambda's parameter is unannotated and
    // its body's element type is only resolved after member-based
    // inference (`s.to_char_array()` pins `s = string`), the outer
    // stream(...) call latches T from the first walk before s is
    // resolved. Later walks settle char correctly, but the outer call's
    // type-arg binding doesn't refresh — the emitter then inserts a
    // bridge cast (STREAM<object,int>)(object)(STREAM<char,int>) which
    // passes verification but reads the wrong MethodTable at runtime
    // and crashes inside isinst.
    //
    // Adding `(s: string)` makes the bug disappear, as does
    // `stream[char, int](0, …)`. So this fixture pins the no-annotation
    // path explicitly.

    class Main is
        entry() static is
            let chars_of = s =>
                let xs = s.to_char_array() in
                stream(0, i => if i == xs.count then DONE() else xs[i] || (i + 1) fi);

            let p = chars_of("hi");

            for c in p do
                Std.out.write_line("char: {c}");
            od

            return;
        si
    si
si
