namespace Test is
    use Std = IO.Std;

    class Main is
        // Captured argument across await
        compute(base: int, multiplier: int) -> Tasks.TASK[int] static is
            let x = await Tasks.TASK.from_result(base);
            return x * multiplier;
        si

        entry() static is
            let r = compute(7, 3);
            Std.write_line("got={r.result}");
        si
    si
si
