namespace Test is
    use IO.Std;

    // A recursive lambda over a union where every variant has at
    // least one named field. The body accesses a variant-specific
    // field (`t.value` from LEAF) on the still-placeholder receiver
    // before the call-site back-feed has had a chance to widen the
    // inferred type. `MEMBER_CONSTRAINT("value")` is recorded
    // against the placeholder origin; later, when the call site
    // supplies `Tree[int]`, `try_get_inferred_type` rejects it
    // because `Tree[int].find_member("value")` returns null — only
    // the LEAF variant exposes `value` directly.
    //
    // Desired behaviour: a MEMBER_CONSTRAINT should discharge
    // against a union candidate when *any* variant exposes the
    // member, since narrowing inside the body's `if` branches makes
    // the field accessible at the access site. With that fix, `t`
    // resolves to `Tree[int]` in iter 2, narrowing fires in the
    // `is_leaf` / else arms, and the body type-checks.
    //
    // A control variant of this shape with a unit variant
    // (`EMPTY` instead of `LEAF(value: T)`) does pass — the
    // `.value` is on NODE, but the wider find_member path on the
    // unit-variant Tree happens to discharge differently.
    union Tree[T] is
        LEAF(value: T);
        NODE(left: Tree[T], right: Tree[T]);
    si

    use Tree.LEAF;
    use Tree.NODE;

    class Main is
        entry() static is
            let tree: Tree[int] = NODE(NODE(LEAF(1), LEAF(2)), NODE(LEAF(3), LEAF(4)));

            let stringify_tree = t rec =>
                if t.is_node then
                    let (left, right) = t in
                    "({rec(left)}, {rec(right)})"
                else
                    "{t.value}"
                fi;

            Std.write_line(stringify_tree(tree));
            return;
        si
    si
si
