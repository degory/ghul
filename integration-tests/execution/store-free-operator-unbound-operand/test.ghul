// An operator whose operand type is not trivially derivable stays
// store-free when no source type declares that operator as a member: a
// reflected type never exposes one under a ghūl operator name, and the
// free and innate operators are already bounded. `(x % 3)` is not
// trivially typed, yet the `+` over it reaches only the innate `+`, so
// the function proves store-free and satisfies a pure function-typed
// parameter without an impure-function-value warning.

use Std = IO.Std;

g(x: int) -> int => (x % 3) + 1;

apply(f: (int) -> int pure, x: int) -> int pure => f(x);

entry() is
    Std.write_line("{apply(i => g(i), 7)}");
si
