namespace Test is
    use IO.Std;

    // `if let` / `elif let` chain over an abstract closed hierarchy.
    // The else-arm narrow of the elif chains off the variable's
    // CURRENT narrowed type (set by the previous arm's else), not the
    // declared type — otherwise the second arm's complement would
    // re-introduce previously-eliminated subclasses and the final
    // else would intersect two unrelated concrete classes.

    class Animal abstract is
        init() is si
    si

    class CAT: Animal is
        init() is super.init(); si
        purr() -> string => "purr";
    si

    class DOG: Animal is
        init() is super.init(); si
        bark() -> string => "bark";
    si

    class HAMSTER: Animal is
        init() is super.init(); si
        squeak() -> string => "squeak";
    si

    class Main is
        entry() static is
            describe(CAT());
            describe(DOG());
            describe(HAMSTER());
        si

        describe(a: Animal) static is
            if let c: CAT = a then
                Std.out.write_line(c.purr());
            elif let d: DOG = a then
                Std.out.write_line(d.bark());
            else
                Std.out.write_line(a.squeak());
            fi
        si
    si
si
