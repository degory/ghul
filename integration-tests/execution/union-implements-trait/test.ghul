use IO.Std.write_line;

trait NAMED is
    name: string;

    label() -> string => "[{name}]";
si

trait COUNTED is
    count: int;
si

union COLOUR(name: string, count: int): NAMED, COUNTED is
    RED(..);
    GREEN(..);
    BLUE(..);
si

show_named(n: NAMED) is
    write_line("named: {n.name} {n.label()}");
si

show_counted(k: COUNTED) is
    write_line("counted: {k.count}");
si

entry() is
    let c: COLOUR = COLOUR.GREEN("green", 7);
    show_named(c);
    show_counted(c);

    let n: NAMED = c;
    write_line("through trait: {n.label()}");
si
