// A field narrowed by a presence guard survives a call to a curated
// store-free BCL read: the char Unicode classifiers and the sealed
// string reads and transforms cannot write any pre-existing heap slot
// or dispatch into user code, so the narrow holds across them. An
// imported call that is not on the trusted list still drops the narrow
// - trust is granted entry by entry, never by resemblance.
//
// The BCL results are each captured in an explicitly typed local so
// this test isolates the trust-list additions: it does not rely on the
// separate typing of a call result as an operator operand or as the
// receiver of a further call.

use IO.Std;

class BOX is
    v: int public;
    init() is si
    touch() -> int => v;
si

class HOLDER is
    _b: BOX?;
    init() is _b = BOX(); si

    // char classifier: trusted, narrow survives
    after_char_classifier() -> int is
        if _b? then
            let ok: bool = char.is_digit('7');
            return _b.touch() + (if ok then 1 else 0 fi);
        fi
        return -1;
    si

    // string read/transform: trusted, narrow survives
    after_string_trim() -> int is
        if _b? then
            let s: string = "  Hello, World ".trim();
            return _b.touch() + s.length;
        fi
        return -1;
    si

    // string replace returns a fresh string: trusted, narrow survives
    after_string_replace() -> int is
        if _b? then
            let s: string = "a-b-c".replace('-', '.');
            return _b.touch() + s.length;
        fi
        return -1;
    si

    // path manipulation: trusted static, narrow survives
    after_path_op() -> int is
        if _b? then
            let name: string? = IO.Path.get_file_name("dir/file.txt");
            return _b.touch() + (if name? then name.length else 0 fi);
        fi
        return -1;
    si

    // object.get_type is non-virtual: trusted, narrow survives
    after_get_type() -> int is
        if _b? then
            let t: System.Type = self.get_type();
            return _b.touch() + (if t? then 1 else 0 fi);
        fi
        return -1;
    si

    // reflected type name read: trusted, narrow survives
    after_type_name() -> int is
        if _b? then
            let t: System.Type = self.get_type();
            let n: string? = t.full_name;
            return _b.touch() + (if n? then 1 else 0 fi);
        fi
        return -1;
    si

    // an imported call that is not on the trusted list: narrow drops,
    // so the read below is flagged
    after_unlisted_string_call() -> int is
        if _b? then
            let s: string = "abc".normalize();
            return _b.touch() + s.length;
        fi
        return -1;
    si
si

class Main is
    entry() static is
        let h = HOLDER();
        Std.write_line("{h.after_char_classifier()}");
        Std.write_line("{h.after_string_trim()}");
        Std.write_line("{h.after_string_replace()}");
        Std.write_line("{h.after_path_op()}");
        Std.write_line("{h.after_get_type()}");
        Std.write_line("{h.after_type_name()}");
        Std.write_line("{h.after_unlisted_string_call()}");
    si
si
