namespace Test is
    use IO.Std;
    use Collections.LIST;

    class ITEM is
        index: int public;

        init(index: int) is
            self.index = index;
        si
    si

    class Main is
        entry() static is
            let items = LIST[ITEM]();
            items.add(ITEM(3));
            items.add(ITEM(1));
            items.add(ITEM(2));

            // Pattern from src/semantic/symbols/closure.ghul:145 — an
            // Iterable-via-pipe of T fed through .sort with a lambda
            // comparator whose arg types T,T must be inferred from
            // the formal (T, T) -> int. The lambda body accesses a
            // member of T, so a wild/error fallback for the arg
            // types breaks compilation.
            let sorted = items | .sort((a, b) => a.index - b.index) .collect();

            for i in sorted do
                Std.write_line("{i.index}");
            od

            return;
        si
    si
si
