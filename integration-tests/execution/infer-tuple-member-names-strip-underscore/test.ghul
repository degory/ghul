namespace Test is
    use Std = IO.Std;

    class COUNTER is
        _count: int;
        _total: int;

        init(count: int, total: int) is
            super.init();
            _count = count;
            _total = total;
        si

        print_snapshot() is
            // Field-load identifiers `_count` / `_total` infer tuple
            // element names `count` / `total` — the leading underscore
            // is stripped so the private-field convention doesn't leak
            // out through the tuple element names.
            let stats = (_count, _total);
            Std.out.write_line("count={stats.count} total={stats.total}");

            // A local `_scratch` isn't a field, so the strip rule does
            // not apply: the inferred tuple element name stays
            // `_scratch`.
            let _scratch = 7;
            let mixed = (_count, _scratch);
            Std.out.write_line("count={mixed.count} _scratch={mixed._scratch}");
        si
    si

    class Main is
        entry() static is
            COUNTER(3, 42).print_snapshot();

            return;
        si
    si
si
