namespace Test is
    use Std = IO.Std;

    class BASE is
        base_method() is
            Std.out.write_line("base_method");
        si
    si

    trait Walks is
        walk();
    si

    trait Talks is
        talk();
    si

    class PERSON: BASE, Walks, Talks is
        init() is si

        walk() is
            Std.out.write_line("walking");
        si

        talk() is
            Std.out.write_line("talking");
        si
    si

    class Main is
        entry() static is
            let v: BASE = PERSON();

            // Two stacked isa-narrows. After both, v's type is
            // BASE & Walks & Talks — base_method, walk, talk all
            // resolve.
            if isa Walks(v) then
                v.walk();
                v.base_method();

                if isa Talks(v) then
                    v.walk();
                    v.talk();
                    v.base_method();
                fi
            fi
        si
    si
si
