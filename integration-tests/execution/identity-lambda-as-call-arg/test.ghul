namespace Test is
    use IO.Std.write_line;

    apply(f: int -> int, n: int) -> int => f(n);

    invoke(action: int -> void, n: int) is
        action(n);
    si

    entry() is
        // Identity-bodied lambda: body is just the parameter reference.
        // The body offers no constraint on the parameter type, so resolution
        // depends on the formal-arg-type push from the call site.
        write_line("apply(a => a, 5) = {apply(a => a, 5)}");

        // Statement-bodied lambda whose body never references the parameter.
        // The parameter type can only come from the formal-arg-type push.
        invoke(element is
            write_line("invoke ran with arg ignored");
        si, 99);
    si
si
