namespace Test is
    use Std = IO.Std;

    class Main is
        gen() -> Collections.Iterable[int] static is
            let i = 100;
            let inc = () => i + 1;
            yield inc();
            yield inc();
        si

        entry() static is
            for x in gen() do
                Std.write_line("got {x}");
            od
        si
    si
si
