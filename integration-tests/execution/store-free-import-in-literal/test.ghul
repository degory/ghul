// A curated store-free import reached only through a function
// literal's body — never through a named body's call graph — must
// still be trusted store-free, so the literal satisfies a pure
// function-typed parameter without an impure-function-value warning.
// The `to_upper` / `length` reads here have no other caller in the
// program, so the classification cannot come from a fixpoint callee
// edge; it has to be decided at the point the import is queried.

use Std = IO.Std;

apply(f: (string) -> int pure, x: string) -> int pure => f(x);

entry() is
    let n = apply(s => s.to_upper().length, "hello");

    Std.write_line("{n}");
si
