namespace Test is
    use IO.Std.write_line;

    describe(n: int) -> string? =>
        case n
        when 0 then "zero"
        when 1, 2, 3 then "small"
        when 42 then "answer"
        esac;

    classify(p: (int, int)) -> string? =>
        case p
        when (0, 0) then "origin"
        when (0, y) then "y at {y}"
        when (x, 0) then "x at {x}"
        esac;

    pick(n: int) -> int? =>
        case n
        when 1 then 100
        when 2 then 200
        esac;

    show(s: string?) =>
        if s? then write_line(s) else write_line("(none)") fi;

    show_int(n: int?) =>
        if n? then write_line("{n}") else write_line("(none)") fi;

    entry() is
        show(describe(0));
        show(describe(2));
        show(describe(42));
        show(describe(99));

        show(classify((0, 0)));
        show(classify((0, 5)));
        show(classify((3, 0)));
        show(classify((3, 4)));

        show_int(pick(1));
        show_int(pick(2));
        show_int(pick(99));
    si
si
