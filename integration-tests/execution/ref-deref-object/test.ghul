namespace Test is
    use Std = IO.Std;

    class BOX is
        value: string;
        init(value: string) is self.value = value; si
    si

    class Main is
        entry() static is
            let b = BOX("before");
            replace(b ref);
            Std.out.write_line(b.value);
        si

        replace(p: BOX ref) static is
            p! = BOX("after");
        si
    si
si
