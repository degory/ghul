namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            test_value_type_receiver_ref_member();
            test_value_type_receiver_value_member();
        si

        // Value-type optional receiver (NULLABLE[POINT]) → ref-type
        // member (the `name` property returns string). Present and
        // absent paths exercise both branches.
        test_value_type_receiver_ref_member() static is
            present(POINT(3, 4));
            present(null);
        si

        present(p: POINT?) static is
            let n = p?.name;
            Std.out.write_line("ref-member: {if n? then n! else "<null>" fi}");
        si

        // Value-type optional receiver → value-type member (int).
        // Result is int? (NULLABLE[int]); IL emits a DEFAULT for the
        // null arm.
        test_value_type_receiver_value_member() static is
            check_x(POINT(7, 9));
            check_x(null);
        si

        check_x(p: POINT?) static is
            let x = p?.x;
            Std.out.write_line("value-member: {if x? then "{x!}" else "<null>" fi}");
        si
    si

    struct POINT is
        x: int public;
        y: int public;

        init(x: int, y: int) is
            self.x = x;
            self.y = y;
        si

        name: string => "({x},{y})";
    si
si
