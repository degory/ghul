// Construction is store-free only when the constructor writes nothing
// but the fresh object's own fields. A constructor that also writes a
// static — a pre-existing slot no receiver freshness covers — stays
// state-changing, so building one where a pure function-typed
// parameter is expected still draws the warning and drops heap facts.

use Std = IO.Std;

class COUNTER is
    _made: int static;
    n: int field;

    init(n: int) is
        self.n = n;
        _made = _made + 1;
    si
si

apply(f: (int) -> COUNTER pure, x: int) -> COUNTER => f(x);

entry() is
    let c = apply(k => COUNTER(k), 5);

    Std.write_line("{c.n}");
si
