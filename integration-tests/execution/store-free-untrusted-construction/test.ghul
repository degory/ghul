// A construction is store-free only when its constructor is. A source
// constructor that writes its own fields is not classified store-free,
// so building one where a pure function-typed parameter is expected
// still draws the warning and drops heap facts — construction is not
// trusted blanket, only when the constructor proves or is declared
// store-free.

use Std = IO.Std;

class BOX is
    v: int field;
    init(v: int) is self.v = v; si
si

apply(f: (int) -> BOX pure, x: int) -> BOX => f(x);

entry() is
    let b = apply(k => BOX(k), 5);

    Std.write_line("{b.v}");
si
