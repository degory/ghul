namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let task = Tasks.TASK.from_result(42);

            let chained = Tasks.TaskExtensions.unwrap(
                task.continue_with(
                    (t: Tasks.TASK[int]) -> Tasks.TASK[int] => Tasks.TASK.from_result(t.result + 1)
                )
            );

            Std.write_line("task_alias.result={chained.result}");
        si
    si
si
