use IO.Std.write_line;

class ANIMAL is
    name: string public;
    init(name: string) is self.name = name; si
si

class CAT: ANIMAL is
    init(name: string) is super.init(name); si
    purr() -> string => "{name} purrs";
si

entry() is
    test_bare_optional_present();
    test_isa_in_condition();
    test_and_chain_in_condition();
    test_member_access_after_narrow();
si

// `x?` in a while condition narrows `x` to non-optional inside
// the body — the body uses `x` without `!` or `if x?`.
test_bare_optional_present() is
    let xs: Collections.LIST[int]? = Collections.LIST[int]([3, 2, 1]);
    let total mut = 0;
    let i mut = 0;
    while xs? /\ i < xs.count do
        total = total + xs[i];
        i = i + 1;
    od
    write_line("01-bare-optional: total={total}");
si

// `isa T(x)` in a while condition narrows `x` to T inside the
// body — the body calls T-only members.
test_isa_in_condition() is
    let a: ANIMAL = CAT("felix");
    let n mut = 0;
    while isa CAT(a) /\ n < 1 do
        write_line("02-isa: {a.purr()}");
        n = n + 1;
    od
si

// Intra-condition `/\` narrowing: the left of `/\` narrows the
// right's scope. `xs?` narrows `xs` before `xs.count` is read.
test_and_chain_in_condition() is
    let xs: int[]? = [10, 20, 30];
    let i mut = 0;
    let saw mut = 0;
    while xs? /\ i < xs.count do
        saw = saw + xs[i];
        i = i + 1;
    od
    write_line("03-and-chain: saw={saw}");
si

// A divergent guard before the loop narrows `a`; the body
// doesn't write `a`, so the narrow is loop-invariant and
// survives into and across the loop (was already true; here as
// a regression guard).
test_member_access_after_narrow() is
    let a: ANIMAL = CAT("tom");
    if !isa CAT(a) then return; fi

    let n mut = 0;
    while n < 1 do
        write_line("04-after-narrow: {a.purr()}");
        n = n + 1;
    od
si
