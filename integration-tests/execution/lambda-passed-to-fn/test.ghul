namespace Test is
    use IO.Std;
    use Collections;

    // Regression guard: a lambda passed into a generic global
    // function expecting `T -> U` is bound from the call's first
    // arg via owner/function generic-arg inference (T = int from
    // xs), and the lambda's parameter type is then set as the
    // constraint pushed on the second call-arg's re-walk. The
    // PARTIAL-second-pass at `_visit(call)` is the path.
    //
    // Works today. Pinned so a regression to either the function-
    // generic-arg binding for `T` or the lambda-arg constraint
    // push surfaces a failing test.

    apply_each[T,U](xs: Iterable[T], f: T -> U) -> LIST[U] is
        let result = LIST[U]();
        for x in xs do
            result.add(f(x));
        od
        return result;
    si

    class Main is
        entry() static is
            let xs = [1, 2, 3];
            let doubled = apply_each(xs, x => x * 2);
            for d in doubled do
                Std.write_line("{d}");
            od
            return;
        si
    si
si
