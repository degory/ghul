// single-symbol member imports are declaration-order independent: the
// static method, global function, enum member and injected member these
// uses name are all declared later in the file than the uses themselves
namespace App is
    use IO.Std;

    use Late.TOOLS.make_tag;
    use Late.helper;
    use Late.Colour.GREEN;
    use Late.WIDGET.injected_tag;

    class Main is
        entry() static is
            Std.write_line(make_tag());
            Std.write_line(helper());
            Std.write_line("{cast int(GREEN)}");
            Std.write_line(injected_tag());
        si
    si
si

namespace Late is
    class TOOLS is
        make_tag() -> string static => "tag";
    si

    helper() -> string => "helper";

    enum Colour is
        RED, GREEN, BLUE
    si

    class WIDGET is
    si
si

namespace Ext is
    partial Late.WIDGET is
        injected_tag() -> string static => "injected";
    si
si
