use IO.Std.write_line;

// Narrowing must know the result of a constructor call holds a
// value, across all three construction forms (`Foo(args)`,
// `new Foo(args)`, `new(args)` with type inferred from the slot),
// for both the initializer and the assignment-to-optional-local
// paths. Without this, the `null-deref` warning fires on the
// immediately-following dereference even though the value is
// trivially non-null.

class BOX is
    contents: int;

    init(c: int) is
        self.contents = c;
    si

    describe() -> string => "box of {contents}";
si

entry() is
    // Assignment path.
    let a: BOX? mut = null;
    a = BOX(1);
    write_line(a.describe());

    let b: BOX? mut = null;
    b = new BOX(2);
    write_line(b.describe());

    let c: BOX? mut = null;
    c = new(3);
    write_line(c.describe());

    // Initializer path.
    let d: BOX? = BOX(4);
    write_line(d.describe());

    let e: BOX? = new BOX(5);
    write_line(e.describe());

    let f: BOX? = new(6);
    write_line(f.describe());
si
