namespace Test is
    use Std = IO.Std;

    class Main is
        // Lambda return position: a block-bodied lambda declared to
        // return TASK[int] returning a bare int should auto-wrap too.
        entry() static is
            let make = () -> Tasks.TASK[int] is
                return 13;
            si;

            let task = make();
            Std.write_line("got={task.result}");
        si
    si
si
