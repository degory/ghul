namespace Test is
    use Std = IO.Std;

    // General LHS-as-constraint propagation: the type of an assignment
    // target is pushed down as a constraint on the right-hand side
    // regardless of RHS shape. The RHS expression node is responsible
    // for either consuming the constraint (FUNCTION uses it for arg
    // inference, SEQUENCE / TUPLE forward to elements) or ignoring
    // it (literals, identifiers — Expression's empty default).
    //
    // The earlier scoped LHS-as-constraint PR handled FUNCTION RHS
    // only; this one extends the same plumbing to SEQUENCE and TUPLE
    // RHS so that lambdas buried inside list/tuple literals on the
    // right side of an assignment also get arg-type inference from
    // the LHS.

    class Main is
        entry() static is
            // ---- list literal RHS, assigned to typed list variable

            let listed: Collections.Iterable[int -> int];
            listed = [x => x + 1, y => y * 2];

            for fn in listed do
                Std.out.write_line("listed: " + fn(10));
            od

            // ---- tuple literal RHS with a lambda element, assigned
            // ---- to typed tuple variable

            let tupled: ((int) -> int, string);
            tupled = (x => x + 100, "hello");
            Std.out.write_line("tupled: " + tupled.`0(5) + " | " + tupled.`1);

            // ---- typed-initializer with a tuple of lambdas (already
            // ---- worked via the variable visitor's set_constraint;
            // ---- regression coverage now that the assignment path
            // ---- shares the same generalised plumbing)

            let pair: ((int) -> int, (int) -> int) = (a => a + 7, b => b - 3);
            Std.out.write_line("pair: " + pair.`0(0) + ", " + pair.`1(10));

            // ---- nested: list of tuples-of-lambdas

            let pairs: Collections.Iterable[((int) -> int, string)];
            pairs = [(x => x + 1, "incr"), (y => y * 10, "decimate")];

            for p in pairs do
                Std.out.write_line("pairs: " + p.`0(2) + " | " + p.`1);
            od

            return;
        si
    si
si
