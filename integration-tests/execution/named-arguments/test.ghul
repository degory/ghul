namespace Test is
    use Std = IO.Std;

    class Box is
        width: int;
        height: int;

        init(width: int, height: int) is
            self.width = width;
            self.height = height;
        si

        describe(label: string, scale: int) is
            Std.out.write_line("{label}: {width * scale} x {height * scale}");
        si
    si

    class Main is
        entry() static is
            print_point(x = 3, y = 7);
            print_point(y = 20, x = 10);

            let b = Box(width = 4, height = 5);

            b.describe(label = "box", scale = 2);
            b.describe(scale = 3, label = "again");
        si

        print_point(x: int, y: int) static is
            Std.out.write_line("x={x} y={y}");
        si
    si
si
