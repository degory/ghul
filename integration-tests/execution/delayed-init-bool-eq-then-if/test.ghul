namespace Test is
    use IO.Std;

    // Pins F07: a delayed-init binding `let v; v = false;` whose
    // subsequent use compares it with `==`/`!=` and *also* tests
    // it as a bool condition. The `==` overload resolves to
    // `==(object, object) -> bool` (no bool overload exists), and
    // before the upper-bound back-feed fix that pushed `object`
    // onto v's LUB, widening it past bool and making `if v` fail
    // with "if condition must be bool". With the fix, the formal
    // object is treated as an upper bound (vacuous — every type
    // satisfies it), the assignment's bool stays as the LUB
    // candidate, and `if v` is accepted.

    entry() is
        let v mut;
        v = false;
        if v != false then
            Std.out.write_line("never");
        fi
        if v then
            Std.out.write_line("never-too");
        else
            Std.out.write_line("ok");
        fi
    si
si
