namespace Test is
    use IO.Std;
    use Collections;

    // Tests: chain `flat_map[U]` then `.find(predicate)`.
    //
    //   flat_map[U](mapper: (T) -> Iterable[U]) -> Pipe[U]
    //   find(predicate: (T) -> bool) -> MAYBE[T]
    //
    // After flat_map, the pipe element type is U (the inner pipe's
    // element type). The subsequent find's predicate lambda's arg
    // type must resolve to U. The test exercises whether the new
    // element type from flat_map's U flows correctly into the next
    // lambda's arg.

    class Main is
        entry() static is
            let groups = [
                [1, 2, 3],
                [4, 5, 6],
                [7, 8, 9]
            ];

            let result = groups | .flat_map(g => g) .find(n => n > 5);

            if result? then
                Std.write_line("found={result!}");
            else
                Std.write_line("not found");
            fi

            return;
        si
    si
si
