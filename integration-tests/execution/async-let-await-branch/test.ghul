namespace Test is
    use Std = IO.Std;

    class Main is
        compute(should_await: bool) -> Tasks.TASK[int] static is
            if should_await then
                let answer = await Tasks.TASK.from_result(42);
                return answer + 100;
            else
                return -1;
            fi
        si

        entry() static is
            let async_path = compute(true);
            let sync_path = compute(false);

            Std.write_line("branch.async={async_path.result}");
            Std.write_line("branch.sync={sync_path.result}");
        si
    si
si
