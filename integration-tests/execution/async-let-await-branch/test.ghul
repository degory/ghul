namespace Test is
    use Std = IO.Std;

    class Main is
        compute(should_await: bool) -> Tasks.TASK[int] static =>
            if should_await then
                let await answer = Tasks.TASK.from_result(42);
                return Tasks.TASK.from_result(answer + 100);
            else
                Tasks.TASK.from_result(-1)
            fi;

        entry() static is
            let async_path = compute(true);
            let sync_path = compute(false);

            Std.write_line("branch.async={async_path.result}");
            Std.write_line("branch.sync={sync_path.result}");
        si
    si
si
