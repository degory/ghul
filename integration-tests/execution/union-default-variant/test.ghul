use IO.Std.write_line;

union Result[T,E] is
    OK(value: T) default;
    ERROR(error: E);
si

union Boxed is
    PAIR(a: int, b: int) default;
    EMPTY;
si

ok[T](v: T) -> Result[T,string] => Result.OK[T,string](v);
err[E](e: E) -> Result[int,E] => Result.ERROR[int,E](e);

entry() is
    let good = ok(42);
    let bad = err("oops");

    // `?` tests the default variant
    write_line(good?);
    write_line(bad?);
    write_line(good.has_value);
    write_line(bad.has_value);

    // `!` unwraps the default variant's single value
    write_line(good!);
    write_line(good.value);

    // `!` on a non-default variant throws
    try
        write_line(bad!);
    catch ex: System.Exception
        write_line("threw");
    yrt

    // a multi-field default variant unwraps to the variant itself
    let pair: Boxed = Boxed.PAIR(3, 4);
    write_line(pair?);

    let unwrapped = pair!;
    write_line(unwrapped.a);
    write_line(unwrapped.b);

    let empty: Boxed = Boxed.EMPTY();
    write_line(empty?);
si
