namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            Std.out.write_line(describe(Cat("Felix")));
            Std.out.write_line(describe(Dog("Rex")));
            Std.out.write_line(describe(Animal("creature")));
            Std.out.write_line(describe(null));
        si

        // case as expression: each arm body's last expression supplies
        // the arm's value; the case yields the matched arm's value.
        describe(animal: Animal?) -> string static is
            return case animal
            when null then
                "absent"
            when c: Cat then
                "cat: {c.name}"
            when d: Dog then
                "dog: {d.name}"
            else
                "other: {animal!.name}"
            esac;
        si
    si

    class Animal open is
        name: string;
        init(name: string) is self.name = name; si
    si

    class Cat: Animal open is
        init(name: string) is super.init(name); si
    si

    class Dog: Animal open is
        init(name: string) is super.init(name); si
    si
si
