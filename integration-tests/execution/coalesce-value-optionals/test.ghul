namespace Test is
    use IO.Std;

    // `a ?? b` across the three optional lowerings: reference `T?`,
    // value-type NULLABLE[T], and MAYBE[T] (unconstrained `T?`), in
    // same-kind and mixed-kind combinations. The result's optional
    // kind derives from the LUB of the inner types; the right
    // operand is evaluated only when the left is absent.

    class HOLDER[T] is
        slot: T?;
        init() is si
        store(v: T) is slot = Ghul.MAYBE[T](v); si
        get_or(fallback: T) -> T => slot ?? fallback;
        or_slot(other: HOLDER[T]) -> T? => slot ?? other.slot;
    si

    class Main is
        find_int(want: bool) -> int? static is
            if want then
                return 7;
            fi
            return null;
        si

        loud_fallback() -> int static is
            Std.write_line("fallback evaluated");
            return 99;
        si

        entry() static is
            let present: int? = find_int(true);
            let absent: int? = find_int(false);

            Std.write_line("present: {present ?? 0}");
            Std.write_line("absent: {absent ?? 9}");

            // right side runs only when the left is absent
            Std.write_line("no call: {present ?? loud_fallback()}");
            Std.write_line("call: {absent ?? loud_fallback()}");

            // the left can be any expression, not just a slot
            Std.write_line("call left: {find_int(true) ?? 0} {find_int(false) ?? 5}");

            // optional rights chain: intermediate results stay optional
            let b: int? = find_int(true);
            Std.write_line("chain: {absent ?? b ?? 0} {absent ?? absent ?? 1}");

            // bool? plugged with ?? reads as absent-means-false
            let flag: bool? = null;
            if flag ?? false then
                Std.write_line("unreachable");
            else
                Std.write_line("bool absent means false");
            fi

            // MAYBE from the runtime carrier, reference and value payloads
            let m_present = Ghul.MAYBE[string]("hit");
            Std.write_line("maybe ref present: {m_present ?? "miss"}");

            let mi_present = Ghul.MAYBE[int](21);
            Std.write_line("maybe val present: {mi_present ?? 1}");

            // mixed kinds: reference string? left, MAYBE[string] right
            let s_absent: string? = null;
            Std.write_line("ref then maybe: {(s_absent ?? m_present) ?? "none"}");

            // unconstrained T? in generic code: MAYBE ?? T and
            // MAYBE ?? T? (absent and present)
            let h = HOLDER[string]();
            Std.write_line("generic empty: {h.get_or("dflt")}");
            h.store("stored");
            Std.write_line("generic stored: {h.get_or("dflt")}");

            let hi = HOLDER[int]();
            Std.write_line("generic int: {hi.get_or(64)}");

            let ho = HOLDER[int]();
            let other = HOLDER[int]();
            Std.write_line("generic or_slot absent: {ho.or_slot(other) ?? 0}");
            other.store(8);
            Std.write_line("generic or_slot other: {ho.or_slot(other) ?? 0}");
            ho.store(3);
            Std.write_line("generic or_slot self: {ho.or_slot(other) ?? 0}");

            return;
        si
    si
si
