namespace Test is
    use Std = IO.Std;

    class Main is
        // Multiple `let await`s in an inferred-return lambda. Every
        // synthesised continuation lambda along the chain inherits
        // the flag and its bare-T return wraps to Task[T] in turn.
        entry() static is
            let f = () is
                let await a = Tasks.TASK.from_result(1);
                let await b = Tasks.TASK.from_result(2);
                let await c = Tasks.TASK.from_result(3);
                return a + b + c;
            si;

            Std.write_line("f={f().result}");
        si
    si
si
