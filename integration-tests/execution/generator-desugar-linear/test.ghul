
namespace Test is
    use Std = IO.Std;

    class Main is
        // First Phase 2 desugar test. Real `yield X;` source. The
        // compiler's DESUGAR_YIELD pass must:
        //   1. Detect this function as a generator (Iterable[int]
        //      return + yield-in-body).
        //   2. Slice the body at each yield into state-handler
        //      lambdas returning Ghul.Generators._GEN_STEP[int].
        //   3. Replace the body with a state-list + _gen_pipe call.
        three_yields() -> Collections.Iterable[int] static is
            yield 10;
            yield 20;
            yield 30;
        si

        entry() static is
            let total mut = 0;
            for x in three_yields() do
                total = total + x;
            od
            Std.write_line("total={total}");
        si
    si
si
