namespace Test is
    use Std = IO.Std;
    use Collections.Iterable;

    class Main is
        count_up_to(n: int) -> Iterable[int] static is
            let i mut = 1;
            while i <= n do
                yield i;
                i = i + 1;
            od
        si

        running_totals(xs: Iterable[int]) -> Iterable[int] static is
            let total mut = 0;
            for x in xs do
                total = total + x;
                yield total;
            od
        si

        entry() static is
            // piping a generator exhausts it, then the pipe rewinds via reset()
            Std.write_line("pipe: {count_up_to(5) | }");
            Std.write_line("evens: {count_up_to(10) | .filter(x => x % 2 == 0)}");
            Std.write_line("squares: {count_up_to(100) | .map(x => x * x) .take(4)}");

            // a generator as the source of another generator, piped
            Std.write_line("totals: {running_totals(count_up_to(5)) | }");

            // reuse one generator value across two pipes
            let g = count_up_to(3);
            Std.write_line("reuse1: {g | }");
            Std.write_line("reuse2: {g | }");
        si
    si
si
