namespace Test is
    use IO.Std;
    use Collections;

    // Tests: optional access `x?.member` on a
    // placeholder receiver. The `?` syntax tests for non-null
    // before accessing. With placeholder receiver, member access
    // should emit MEMBER_CONSTRAINT.

    class Box is
        value: int;
        init(v: int) is value = v; si
    si

    class Main is
        entry() static is
            let xs = [Box(1), Box(2)];
            let first = xs | .find(b => b.value > 1);
            if first? then
                Std.write_line("{first!.value}");
            fi
            return;
        si
    si
si
