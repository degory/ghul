// Sibling / class+trait narrowing on a member-access path. Neither the
// declared path type (ANIMAL) nor the isa target (PURRING trait) is a
// subtype of the other, so path narrow is composed as an INTERSECTION —
// subsequent reads of b.animal see BOTH the ANIMAL declaration and the
// PURRING trait, so both `.name` and `.purr()` type-check.

use Std = IO.Std;

trait PURRING is
    purr() -> string;
si

class ANIMAL is
    name: string public;
    init(name: string) is
        self.name = name;
    si
si

class CAT: ANIMAL, PURRING is
    init(name: string) is
        super.init(name);
    si

    purr() -> string => "prrrr ({name})";
si

class BOX is
    animal: ANIMAL public;
    init(a: ANIMAL) is
        animal = a;
    si
si

describe(b: BOX) is
    if isa PURRING(b.animal) then
        // b.animal narrows to ANIMAL & PURRING — .name (ANIMAL) and
        // .purr() (PURRING) both resolve.
        Std.write_line("purring {b.animal.name}: {b.animal.purr()}");
    fi
si

entry() is
    describe(BOX(CAT("felix")));
si
