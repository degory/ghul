namespace Test is
    use Std = IO.Std;

    // Generic instance method on a generic class — combines class T
    // (for `value`) with the method's U (for `xs`/`x`) in the yielded
    // tuple. The state-machine class becomes generic in both, in
    // class-then-method order; the substitution map carries both
    // rewrites uniformly.
    class Container[T] is
        value: T;
        init(v: T) is value = v; si

        pairs[U](xs: Collections.Iterable[U]) -> Ghul.Pipes.Pipe[(T, U)] is
            for x in xs do
                yield (value, x);
            od
        si
    si

    class Main is
        entry() static is
            let c = Container[int](42);
            for p in c.pairs[string](["a", "b", "c"]) do
                Std.write_line("p: {p}");
            od
        si
    si
si
