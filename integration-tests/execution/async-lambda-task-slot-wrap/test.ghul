namespace Test is
    use Std = IO.Std;

    class Main is
        run_lit(producer: () -> Tasks.TASK[int]) -> int static is
            return producer().result;
        si

        run_str(producer: () -> Tasks.TASK[string]) -> string static is
            return producer().result;
        si

        entry() static is
            // expression-body function literal, bare T body
            let a = run_lit(() => 3);

            // statement-body function literal, bare T body
            let b = run_lit(() is return 4; si);

            // body that already returns Tasks.TASK[int] passes through
            let c = run_lit(() => Tasks.TASK.from_result(5));

            // explicit Task return type, statement body
            let d = run_lit(() -> Tasks.TASK[int] is return 6; si);

            // explicit Task return type, expression body
            let e = run_lit(() -> Tasks.TASK[int] => 7);

            // different element type
            let f = run_str(() => "hello");

            // async let-await lambda (existing behavior)
            let g = run_lit(() is
                let v = await Tasks.TASK.from_result(8);
                return v;
            si);

            Std.write_line("a={a} b={b} c={c} d={d} e={e} f={f} g={g}");
        si
    si
si
