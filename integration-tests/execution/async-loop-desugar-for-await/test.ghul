namespace Test is
    use Std = IO.Std;

    // A `for` loop with `await` inside the body, running through
    // an async-classified function. Each iteration must await its
    // task and accumulate the result; the final total flows back
    // through the enclosing TASK[int].

    class Main is
        double_async(x: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => x * 2
            );

        compute(xs: Collections.List[int]) -> Tasks.TASK[int] static is
            let total mut = 0;
            for x in xs do
                let y = await double_async(x);
                total = total + y;
            od
            return total;
        si

        entry() static is
            let xs: Collections.List[int] = [10, 20, 30];
            let result = compute(xs).result;
            Std.write_line("result={result}");
        si
    si
si
