namespace Test is
    use Std = IO.Std;

    // Phase 2 — first desugar test. Uses **REAL** for-loop source
    // (not hand-rolled _for_async). The compiler's
    // DESUGAR_AWAIT-sibling pass must:
    //   1. Detect this for-loop has a let-await body inside an
    //      async-classified enclosing function.
    //   2. Synthesise a body lambda; wrap the user's `return ...`
    //      as `_LOOP_RESULT[T_ret](RETURN, ...)`; append fall-through
    //      `_LOOP_RESULT[T_ret]()` (CONTINUE) at end of body.
    //   3. Emit Ghul.Async._for_async(INTERNAL_ENSURE_ITERATOR(xs), body).
    //   4. Wrap helper task in `let await __lr = ...`.
    //   5. Synthesise post-loop `if __lr.type == RETURN then return __lr.value; fi`.

    class Main is
        double_async(x: int) -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => x * 2
            );

        // **REAL** for-loop source. The compiler must desugar this
        // into a call to Ghul.Async._for_async.
        compute(xs: Collections.List[int]) -> Tasks.TASK[int] static is
            let total mut = 0;
            for x in xs do
                let await y = double_async(x);
                total = total + y;
            od
            return total;
        si

        entry() static is
            let xs: Collections.List[int] = [10, 20, 30];
            let result = compute(xs).result;
            Std.write_line("result={result}");
        si
    si
si
