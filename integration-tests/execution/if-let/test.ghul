namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            describe(CAT("Felix"));
            describe(DOG("Rex"));
            describe(ANIMAL("creature"));

            greet(lookup(true));
            greet(lookup(false));

            show(PAIR(42, "hello"));
            show(null);
            show_first(PAIR(7, "seven"));
        si

        // type ascription + elif let: c.meow() / d.bark() are
        // subtype-only methods, so reaching them proves the binding
        // really has the narrowed type.
        describe(animal: ANIMAL) static is
            if let c: CAT = animal then
                c.meow();
            elif let d: DOG = animal then
                d.bark();
            else
                Std.out.write_line("just an animal: {animal.name}");
            fi
        si

        // bare binding: refutability is reference nullability
        greet(animal: ANIMAL?) static is
            if let found = animal then
                Std.out.write_line("hello, {found.name}");
            else
                Std.out.write_line("nobody here");
            fi
        si

        // destructuring a nullable reference
        show(p: PAIR?) static is
            if let (a, b) = p then
                Std.out.write_line("pair: {a}, {b}");
            else
                Std.out.write_line("no pair");
            fi
        si

        // discard inside a destructuring pattern
        show_first(p: PAIR?) static is
            if let (first, _) = p then
                Std.out.write_line("first: {first}");
            fi
        si

        lookup(yes: bool) -> ANIMAL? static is
            if yes then
                return CAT("found");
            fi

            return null;
        si
    si

    class ANIMAL is
        name: string;

        init(name: string) is
            self.name = name;
        si
    si

    class CAT: ANIMAL is
        init(name: string) is
            super.init(name);
        si

        meow() is
            Std.out.write_line("{name} says meow");
        si
    si

    class DOG: ANIMAL is
        init(name: string) is
            super.init(name);
        si

        bark() is
            Std.out.write_line("{name} says woof");
        si
    si

    class PAIR is
        `0: int field;
        `1: string field;

        init(a: int, b: string) is
            `0 = a;
            `1 = b;
        si
    si
si
