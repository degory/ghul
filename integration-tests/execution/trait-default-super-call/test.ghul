namespace Test is
    use Std = IO.Std;

    trait Greeter is
        greet() is
            Std.write_line("default greeting");
        si
    si

    class LoudGreeting: Greeter is
        init() is si

        greet() is
            super.greet();
            Std.write_line("loud!");
        si
    si

    class Main is
        entry() static is
            let g = LoudGreeting();
            g.greet();
        si
    si
si
