namespace Test is
    use Std = IO.Std;

    trait Greeter is
        greet() is
            Std.write_line("default greeting");
        si
    si

    class GREETING: Greeter is
        init() is si

        greet() is
            Std.write_line("class override");
        si
    si

    class Main is
        entry() static is
            let g = GREETING();
            g.greet();
        si
    si
si
