namespace Test is
    use IO.Std;

    // `if x?` on a value-type `T?` (`NULLABLE[T]` / `MAYBE[T]`)
    // narrows to `T` on the true edge — the same uniform optional
    // narrowing reference `T?` already gets. Member access, operator
    // dispatch and slot-boundary assignment all see `T`; `?`, `!`
    // and `if let` continue to see the wrapper.

    struct Point is
        x: int;
        y: int;
        init(x: int, y: int) is
            self.x = x;
            self.y = y;
        si
        describe() -> string => "Point({x},{y})";
    si

    class Main is
        wrap_int(present: bool, value: int) -> int? static is
            if present then
                return value;
            fi
            return null;
        si

        wrap_point(present: bool, p: Point) -> Point? static is
            if present then
                return p;
            fi
            return null;
        si

        take_int(n: int) static is
            Std.write_line("take_int: {n}");
        si

        entry() static is
            let n = wrap_int(true, 41);
            if n? then
                Std.write_line("plus: {n + 1}");
                take_int(n);
                let copy: int = n;
                Std.write_line("copy: {copy}");
            fi

            let none = wrap_int(false, 0);
            if none? then
                Std.write_line("unreachable");
            else
                Std.write_line("none: absent");
            fi

            let hit = wrap_point(true, Point(3, 4));
            if hit? then
                Std.write_line(hit.describe());
            fi

            let miss = wrap_point(false, Point(0, 0));
            if miss? then
                Std.write_line(miss.describe());
            else
                Std.write_line("miss: absent");
            fi

            return;
        si
    si
si
