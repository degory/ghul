namespace Test is
    use IO.Std;

    // `if x?` on a value-type `T?` (lowered to `NULLABLE[T]`)
    // narrows to `T` on the true edge — the same uniform optional
    // narrowing that applies to reference `T?` and unconstrained
    // `MAYBE[T]`. Member access on the narrowed local goes through
    // `T`'s members. `Point` carries a `describe` method that isn't
    // on the `Nullable[Point]` wrapper, so the projection has to
    // fire for the call to resolve.

    struct Point is
        x: int;
        y: int;
        init(x: int, y: int) is
            self.x = x;
            self.y = y;
        si
        describe() -> string => "Point({x},{y})";
    si

    class Main is
        wrap(present: bool, value: Point) -> Point? static is
            if present then
                return value;
            fi
            return null;
        si

        entry() static is
            let hit = wrap(true, Point(3, 4));
            if hit? then
                Std.write_line(hit.describe());
            else
                Std.write_line("none");
            fi

            let miss = wrap(false, Point(0, 0));
            if miss? then
                Std.write_line(miss.describe());
            else
                Std.write_line("none");
            fi

            return;
        si
    si
si
