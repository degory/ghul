namespace Traits is
    trait PRINTER is
        print() -> string;
    si

    trait TAGGED is
        tag() -> string;
    si
si

namespace Data is
    class WIDGET is
        _n: int;
        init(n: int) is _n = n; si
    si

    class GADGET[T] is
        value: T;
        init(value: T) is self.value = value; si
    si
si

namespace App is
    use IO.Std;

    use Traits;
    use Data;

    format(n: int) -> string => "n={n}";

    class NOTE is
        text: string;
        init(text: string) is self.text = text; si
    si

    // interface name from a use import, body calling a namespace-level
    // function and constructing a sibling class - all names resolved at
    // this write site, not at the target's declaration site
    impl PRINTER for Data.WIDGET is
        print() -> string => NOTE(format(_n)).text;
    si

    // unqualified target reached through this namespace's use import
    partial WIDGET is
        described() -> string => "widget {format(_n)}";
    si

    // generic unqualified target: T resolves to the target's own type
    // parameter, TAGGED from this namespace's use import
    impl TAGGED for GADGET[T] is
        tag() -> string is
            let v: T = value;
            return "gadget {v}";
        si
    si

    // target declared later in the file than this block
    impl PRINTER for Late.THING is
        print() -> string => format(-1);
    si

    class Main is
        entry() static is
            let w = WIDGET(42);
            let p: PRINTER = w;
            Std.write_line(p.print());
            Std.write_line(w.described());

            let g = GADGET("hello");
            let t: TAGGED = g;
            Std.write_line(t.tag());

            let l: PRINTER = Late.THING();
            Std.write_line(l.print());

            UseInjected.Report.run();
            return;
        si
    si
si

namespace Late is
    class THING is
        init() is si
    si
si

namespace Lib is
    class TOOLS is
    si
si

namespace Ext is
    // inject a static member into a type in another namespace
    partial Lib.TOOLS is
        make_tag() -> string static => "tag";
    si
si

namespace UseInjected is
    use IO.Std;

    // imports a member that only exists once Ext's partial has been
    // processed - use resolution retries after member injection
    use Lib.TOOLS.make_tag;

    class Report is
        run() static is
            Std.write_line(make_tag());
        si
    si
si
