use IO.Std.write_line;

union BOX[T](id: int) is
    FULL(payload: T, ..);
    EMPTY(..);
si

entry() is
    let full_int: BOX[int] = BOX.FULL[int](42, 7);
    let empty_int: BOX[int] = BOX.EMPTY[int](99);
    let full_str: BOX[string] = BOX.FULL[string]("hi", 1);

    write_line(full_int.id);
    write_line(empty_int.id);
    write_line(full_str.id);

    if let f: BOX.FULL[int] = full_int then
        write_line(f.id);
        write_line(f.payload);
    fi

    if let f: BOX.FULL[string] = full_str then
        write_line(f.id);
        write_line(f.payload);
    fi
si
