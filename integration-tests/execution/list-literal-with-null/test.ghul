namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let leading = [null, "a", "b"];
            let trailing = ["x", "y", null];
            let middle = ["m", null, "n"];

            Std.out.write_line("leading: {leading[0]?}, {leading[1]}, {leading[2]}");
            Std.out.write_line("trailing: {trailing[0]}, {trailing[1]}, {trailing[2]?}");
            Std.out.write_line("middle: {middle[0]}, {middle[1]?}, {middle[2]}");
        si
    si
si
