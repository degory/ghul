namespace Test is
    use Std = IO.Std;

    class Main is
        // Inside a `let await` block, the synthesised continuation
        // lambda now inherits its enclosing function's declared return
        // type, so `T → TASK[T]` auto-wrap at return position works
        // for returns INSIDE the let-await body — not only outside.
        compute() -> Tasks.TASK[int] static is
            let await a = Tasks.TASK.from_result(5);

            return a * 10;
        si

        // Branched return inside a let-await block.
        classify(n: int) -> Tasks.TASK[string] static is
            let await doubled = Tasks.TASK.from_result(n * 2);

            if doubled > 50 then
                return "big";
            fi

            return "small";
        si

        entry() static is
            Std.write_line("compute={compute().result}");
            Std.write_line("classify(10)={classify(10).result}");
            Std.write_line("classify(100)={classify(100).result}");
        si
    si
si
