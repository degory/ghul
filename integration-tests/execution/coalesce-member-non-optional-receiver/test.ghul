namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Non-optional ref-type receiver — the null test is
            // legal defensive code and is emitted even though the
            // static type says it cannot fail. The result keeps the
            // plain member type, so no unwrap is needed.
            let h = HOLDER("hi");
            let n = h?.name;
            Std.out.write_line("ref-recv: {if n? then n else "<null>" fi}");

            // Flow-narrowed-from-optional value-type receiver — the
            // declared type is `POINT?` but the flow has narrowed it
            // to `POINT`, so this hits the statically-present fast
            // path; the redundancy warning is suppressed here.
            let maybe_p: POINT? = POINT(11, 13);
            let y = maybe_p?.y;
            Std.out.write_line("flow-narrowed: {if y? then "{y!}" else "<null>" fi}");
        si
    si

    struct POINT is
        x: int public;
        y: int public;
        init(x: int, y: int) is self.x = x; self.y = y; si
    si

    class HOLDER is
        name: string public;
        init(name: string) is self.name = name; si
    si
si
