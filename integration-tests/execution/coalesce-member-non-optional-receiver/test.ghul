namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Non-optional value-type receiver — must skip the
            // null-test (struct on stack can't satisfy `dup;
            // brfalse`) and just widen to int?.
            let p = POINT(7, 9);
            let x = p?.x;
            Std.out.write_line("value-recv: {if x? then "{x!}" else "<null>" fi}");

            // Non-optional ref-type receiver — same fast path, ref
            // already shares IL with its optional form. The result
            // keeps the plain member type, so no unwrap is needed.
            let h = HOLDER("hi");
            let n = h?.name;
            Std.out.write_line("ref-recv: {if n? then n else "<null>" fi}");

            // Flow-narrowed-from-optional value-type receiver — the
            // declared type is `POINT?` but the flow has narrowed it
            // to `POINT`, so this hits the same fast path.
            let maybe_p: POINT? = POINT(11, 13);
            // maybe_p is now flow-narrowed to non-optional POINT.
            let y = maybe_p?.y;
            Std.out.write_line("flow-narrowed: {if y? then "{y!}" else "<null>" fi}");
        si
    si

    struct POINT is
        x: int public;
        y: int public;
        init(x: int, y: int) is self.x = x; self.y = y; si
    si

    class HOLDER is
        name: string public;
        init(name: string) is self.name = name; si
    si
si
