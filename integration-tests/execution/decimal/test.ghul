namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let a = 100m;
            let b = 12.34m;
            let c = 0.001m;

            Std.out.write_line("literals: {a} {b} {c}");

            let sum = a + b;
            let diff = a - b;
            let prod = b * 10m;
            let quot = a / 4m;
            let neg = -b;

            Std.out.write_line("sum: {sum}");
            Std.out.write_line("diff: {diff}");
            Std.out.write_line("prod: {prod}");
            Std.out.write_line("quot: {quot}");
            Std.out.write_line("neg: {neg}");

            Std.out.write_line("eq: {a == 100m} {a == b}");
            Std.out.write_line("ne: {a != 100m} {a != b}");
            Std.out.write_line("gt: {a > b} {b > a}");
            Std.out.write_line("ge: {a >= 100m} {b >= a}");
            Std.out.write_line("lt: {b < a} {a < b}");
            Std.out.write_line("le: {a <= 100m} {a <= b}");

            let from_int = cast decimal(42);
            let from_long = cast decimal(9_999_999_999l);
            let from_double = cast decimal(3.5D);
            let to_int = cast int(b);
            let to_long = cast long(from_int);
            let to_double = cast double(b);

            Std.out.write_line("from_int: {from_int}");
            Std.out.write_line("from_long: {from_long}");
            Std.out.write_line("from_double: {from_double}");
            Std.out.write_line("to_int: {to_int}");
            Std.out.write_line("to_long: {to_long}");
            Std.out.write_line("to_double: {to_double}");

            let total mut = 0m;
            for i in 0..5 do
                total = total + cast decimal(i) * 0.5m;
            od
            Std.out.write_line("total: {total}");
        si
    si
si
