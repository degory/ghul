namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A fused `index()` stage keeps a running counter and builds
    // INDEXED_VALUE(counter, element) per element, so the INDEX_PIPE object
    // is never allocated. It composes with map/filter in any position, over
    // both a sealed source (fused directly) and a collection source (fused
    // behind the runtime guard). The counter advances only for elements
    // that reach the stage, so `index()` after a `filter` numbers the
    // surviving elements 0, 1, 2, ...

    class Main is
        entry() static is
            let xs = LIST[string](["a", "b", "c"]);

            // guarded collection source, destructured
            for (i, x) in pipe(xs).index() do
                Std.write_line("idx {i}={x}");
            od

            // non-destructured: read the INDEXED_VALUE members
            for iv in pipe(xs).index() do
                Std.write_line("iv {iv.index}:{iv.value}");
            od

            let ns = LIST[int]([1, 2, 3, 4, 5, 6]);

            // index() after filter numbers the surviving elements
            for (i, x) in pipe(ns).filter(n => n % 2 == 0).index() do
                Std.write_line("even {i}->{x}");
            od

            // index() in the middle, then filter on the index
            for (i, x) in pipe(ns).map(n => n * 10).index().filter(v => v.index % 2 == 0) do
                Std.write_line("mid {i}->{x}");
            od

            // sealed value-type source (range): fused directly, no guard
            for (i, x) in (100..103) | .index() do
                Std.write_line("range {i}={x}");
            od
        si
    si
si
