namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A user Pipe whose filter override IGNORES the predicate and lets
    // everything through. If fusion ever fired through a Pipe-typed
    // source, the default filter would run and drop elements - so this
    // pins that a user override is honoured (the gate must not fuse it).
    class WEIRD_PIPE: Pipe[int] is
        _values: LIST[int];
        _index: int;

        init(values: LIST[int]) is
            _values = values;
            _index = -1;
        si

        iterator: Iterator[int] => self;
        current: int => _values[_index];

        move_next() -> bool is
            _index = _index + 1;
            return _index < _values.count;
        si

        reset() is
            _index = -1;
        si

        dispose() is
        si

        filter(predicate: (int) -> bool pure) -> Pipe[int] pure => self;
    si

    class Main is
        entry() static is
            let weird = WEIRD_PIPE(LIST[int]([1, 2, 3, 4]));
            // `weird |` short-circuits pipe() to weird (already a Pipe).
            // The override must run: predicate ignored, all pass.
            for x in weird | .filter(n => n > 100) do
                Std.write_line("weird: {x}");
            od
        si
    si
si
