namespace Test is
    use IO.Std;
    use Collections;

    // Tests: `SACK()` should infer T from the
    // sibling argument's element type. Today it typechecks but
    // crashes at runtime with AccessViolationException — boxed
    // ints stored where references are expected.

    trait Sack[T] is
        add(thing: T);
        count() -> int;
    si

    class SACK[T]: Sack[T] is
        _things: MutableList[T];

        init() is
            _things = LIST[T]();
        si

        add(thing: T) =>
            _things.add(thing);

        count() -> int =>
            _things.count;
    si

    use_sack[T](sack: Sack[T], things: Iterable[T]) is
        for thing in things do
            sack.add(thing);
        od
    si

    class Main is
        entry() static is
            // SACK() — T should come from the sibling Iterable[int].
            use_sack(SACK(), [1, 2, 3]);
            Std.write_line("done");
            return;
        si
    si
si
