namespace Test is
    use IO.Std;

    // The strategic-goal case for iterative full-method type
    // inference. The lambda's argument type is not annotated, and
    // there is no formal-argument constraint at the lambda site
    // (it's a let-bound expression, not an argument to a function
    // with a typed formal). The argument type can only be inferred
    // by looking forward in the method body to the call `f(42)` and
    // pushing `int` back into the lambda definition.
    //
    // This test deliberately fails today; it captures what the
    // call-site constraint pushback work needs to make pass.
    class Main is
        entry() static is
            let f = x => x + 1;
            Std.write_line("{f(42)}");
            return;
        si
    si
si
