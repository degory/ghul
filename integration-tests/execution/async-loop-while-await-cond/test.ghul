namespace Test is
    use Std = IO.Std;

    // Phase 1 — while-await-cond: WHILE_DRIVER with **async**
    // predicate (the predicate itself contains let await). Same
    // driver as while-await; difference is the predicate also
    // returns an incomplete TASK[bool], forcing pump to yield via
    // on_condition_complete before each body invocation.

    enum LOOP_RESULT_TYPE is CONTINUE, BREAK, RETURN si

    struct LOOP_RESULT[T] is
        type: LOOP_RESULT_TYPE;
        value: T;

        init() is si

        init(type: LOOP_RESULT_TYPE, value: T) is
            self.type = type;
            self.value = value;
        si
    si

    class WHILE_DRIVER[T_ret] is
        _condition: () -> Tasks.TASK[bool];
        _body: () -> Tasks.TASK[LOOP_RESULT[T_ret]];
        _tcs: Tasks.TaskCompletionSource[LOOP_RESULT[T_ret]];
        _on_condition_complete: (Tasks.TASK[bool]) -> void;
        _on_body_complete: (Tasks.TASK[LOOP_RESULT[T_ret]]) -> void;

        init(
            condition: () -> Tasks.TASK[bool],
            body: () -> Tasks.TASK[LOOP_RESULT[T_ret]]
        ) is
            _condition = condition;
            _body = body;
            _tcs = Tasks.TaskCompletionSource[LOOP_RESULT[T_ret]]();
            _on_condition_complete = t => on_condition_complete(t);
            _on_body_complete = t => on_body_complete(t);
        si

        start() -> Tasks.TASK[LOOP_RESULT[T_ret]] is
            pump();
            return _tcs.task;
        si

        // Evaluate condition; if true, run body; loop.
        pump() is
            try
                while true do
                    let cond_task = _condition();
                    if !cond_task.is_completed then
                        cond_task.continue_with(_on_condition_complete);
                        return;
                    fi
                    if handle_condition(cond_task) then return; fi
                    // Condition was true — run body.
                    let body_task = _body();
                    if !body_task.is_completed then
                        body_task.continue_with(_on_body_complete);
                        return;
                    fi
                    if handle_body(body_task) then return; fi
                od
            catch ex: System.Exception
                _tcs.set_exception(ex);
            yrt
        si

        on_condition_complete(t: Tasks.TASK[bool]) is
            if handle_condition(t) then return; fi
            // Condition was true async — run body, then continue pumping.
            let body_task = _body();
            if !body_task.is_completed then
                body_task.continue_with(_on_body_complete);
                return;
            fi
            if handle_body(body_task) then return; fi
            pump();
        si

        on_body_complete(t: Tasks.TASK[LOOP_RESULT[T_ret]]) is
            if handle_body(t) then return; fi
            pump();
        si

        // Returns true if iteration should stop (condition false or faulted).
        handle_condition(t: Tasks.TASK[bool]) -> bool is
            if t.is_faulted then
                _tcs.set_exception(t.exception);
                return true;
            fi
            if !t.result then
                // Condition false — loop ends as CONTINUE-fallthrough.
                _tcs.set_result(LOOP_RESULT[T_ret]());
                return true;
            fi
            return false;
        si

        // Returns true if iteration should stop (RETURN/BREAK or faulted).
        handle_body(t: Tasks.TASK[LOOP_RESULT[T_ret]]) -> bool is
            if t.is_faulted then
                _tcs.set_exception(t.exception);
                return true;
            fi
            let r = t.result;
            if r.type == LOOP_RESULT_TYPE.RETURN \/ r.type == LOOP_RESULT_TYPE.BREAK then
                _tcs.set_result(r);
                return true;
            fi
            return false;
        si
    si

    class COUNTER is
        count: int;
        init() is count = 0; si
        bump() is count = count + 1; si
    si

    class Main is
        // Simulates an async step that returns the next integer.
        step_async() -> Tasks.TASK[int] static =>
            Tasks.TASK.delay(2).continue_with(
                (t: Tasks.TASK) -> int => 1
            );

        // Async predicate — itself contains let await. Returns true
        // while count < 3. Bumps `predicate_calls` so we can verify
        // it was actually invoked each iteration (not short-circuited).
        condition_async(counter: COUNTER, predicate_calls: COUNTER) -> Tasks.TASK[bool] static is
            let await dummy = Tasks.TASK.delay(1).continue_with(
                (t: Tasks.TASK) -> int => 0
            );
            predicate_calls.bump();
            Std.write_line("predicate: invoked count_now={counter.count}");
            return counter.count < 3;
        si

        entry() static is
            let counter = COUNTER();
            let predicate_calls = COUNTER();

            let driver = WHILE_DRIVER[int](
                () => condition_async(counter, predicate_calls),
                () is
                    let await x = step_async();
                    counter.bump();
                    Std.write_line("body: count_now={counter.count} step_returned={x}");
                    return LOOP_RESULT[int]();
                si
            );

            let r = driver.start().result;
            Std.write_line("final.type={r.type} value={r.value} count={counter.count} predicates={predicate_calls.count}");
        si
    si
si
