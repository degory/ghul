
namespace Test is
    use Std = IO.Std;

    class Main is
        // Early `return;` inside a generator: state machine reaches
        // DONE immediately at that point. Anything after the return
        // is dead code (still gets sliced into states by the
        // rewriter, but the driver never reaches them).
        early_done() -> Collections.Iterable[int] static is
            yield 1;
            yield 2;
            return;
            yield 3;
        si

        entry() static is
            let total mut = 0;
            for x in early_done() do
                total = total + x;
            od
            Std.write_line("total={total}");
        si
    si
si
