namespace Test is
    use IO.Std;
    use Collections;

    // Tests: deep pipe chain with map → filter →
    // reduce. Each stage's element type is inferred from the
    // previous stage's lambda's return type. The reduce stage
    // introduces a fresh T (the accumulator type) that must be
    // inferred from the seed.

    class Main is
        entry() static is
            let xs = [1, 2, 3, 4, 5];
            let sum_of_squares_of_evens =
                xs |
                    .filter(n => n % 2 == 0) .map(n => n * n)
                    .reduce(0, (acc, n) => acc + n);
            Std.write_line("{sum_of_squares_of_evens}");
            return;
        si
    si
si
