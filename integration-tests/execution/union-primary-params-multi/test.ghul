use IO.Std.write_line;

union SPAN(start: int, end: int) is
    LABELLED(name: string, ..);
    PLAIN(..);
si

entry() is
    let labelled: SPAN = SPAN.LABELLED("frob", 1, 9);
    let plain: SPAN = SPAN.PLAIN(2, 5);

    write_line(labelled.start);
    write_line(labelled.end);
    write_line(plain.start);
    write_line(plain.end);

    if let l: SPAN.LABELLED = labelled then
        write_line(l.name);
        write_line(l.start);
        write_line(l.end);
    fi
si
