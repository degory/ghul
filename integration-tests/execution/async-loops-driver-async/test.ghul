namespace Test is
    use Std = IO.Std;

    enum _LOOP_RESULT_TYPE is
        CONTINUE,
        BREAK,
        RETURN,
    si

    struct _LOOP_RESULT[T] is
        type: _LOOP_RESULT_TYPE;
        value: T;

        init() is
        si

        init(type: _LOOP_RESULT_TYPE, value: T) is
            self.type = type;
            self.value = value;
        si
    si

    class _FOR_EACH_DRIVER[T_elem, T_ret] is
        _iter: Collections.Iterator[T_elem];
        _body: T_elem -> Tasks.TASK[_LOOP_RESULT[T_ret]];
        _tcs: Tasks.TaskCompletionSource[_LOOP_RESULT[T_ret]];
        _on_complete_callback: (Tasks.TASK[_LOOP_RESULT[T_ret]]) -> void;

        init(
            iter: Collections.Iterator[T_elem],
            body: T_elem -> Tasks.TASK[_LOOP_RESULT[T_ret]]
        ) is
            _iter = iter;
            _body = body;
            _tcs = Tasks.TaskCompletionSource[_LOOP_RESULT[T_ret]]();
            _on_complete_callback = t => on_complete(t);
        si

        start() -> Tasks.TASK[_LOOP_RESULT[T_ret]] is
            pump();
            return _tcs.task;
        si

        pump() is
            try
                while _iter.move_next() do
                    let body_task = _body(_iter.current);
                    if !body_task.is_completed then
                        body_task.continue_with(_on_complete_callback);
                        return;
                    fi
                    if handle_result(body_task) then return; fi
                od
                _tcs.set_result(_LOOP_RESULT[T_ret]());
            catch ex: System.Exception
                _tcs.set_exception(ex);
            yrt
        si

        on_complete(t: Tasks.TASK[_LOOP_RESULT[T_ret]]) is
            if handle_result(t) then return; fi
            pump();
        si

        handle_result(t: Tasks.TASK[_LOOP_RESULT[T_ret]]) -> bool is
            if t.is_faulted then
                _tcs.set_exception(t.exception);
                return true;
            fi
            let r = t.result;
            if r.type == _LOOP_RESULT_TYPE.RETURN \/ r.type == _LOOP_RESULT_TYPE.BREAK then
                _tcs.set_result(r);
                return true;
            fi
            return false;
        si
    si

    class COUNTER is
        count: int;
        init() is count = 0; si
        bump() is count = count + 1; si
    si

    class Main is
        entry() static is
            // Stage 1: minimal async driver (already proven to work).
            let xs: Collections.List[int] = [10, 20, 30];
            let body1: int -> Tasks.TASK[_LOOP_RESULT[int]] =
                x => Tasks.TASK.delay(5).continue_with(
                    (t: Tasks.TASK) -> _LOOP_RESULT[int] => _LOOP_RESULT[int]()
                );
            let driver1 = _FOR_EACH_DRIVER[int, int](xs.iterator, body1);
            let r1 = driver1.start().result;
            Std.write_line("stage1.type={r1.type} value={r1.value}");

            // Stage 2: add a COUNTER captured by the body lambda.
            let counter2 = COUNTER();
            let body2: int -> Tasks.TASK[_LOOP_RESULT[int]] =
                x is
                    counter2.bump();
                    return Tasks.TASK.delay(5).continue_with(
                        (t: Tasks.TASK) -> _LOOP_RESULT[int] => _LOOP_RESULT[int]()
                    );
                si;
            let driver2 = _FOR_EACH_DRIVER[int, int](xs.iterator, body2);
            let r2 = driver2.start().result;
            Std.write_line("stage2.type={r2.type} value={r2.value} iterations={counter2.count}");

            // Stage 3: body returns RETURN(99) from inside an async
            // continuation on the third element. Requires the body
            // lambda to capture x and inspect it inside the
            // continue_with callback.
            let counter3 = COUNTER();
            let body3: int -> Tasks.TASK[_LOOP_RESULT[int]] =
                x is
                    counter3.bump();
                    let captured = x;
                    return Tasks.TASK.delay(5).continue_with(
                        (t: Tasks.TASK) -> _LOOP_RESULT[int] =>
                            if captured == 30 then
                                _LOOP_RESULT[int](_LOOP_RESULT_TYPE.RETURN, 99)
                            else
                                _LOOP_RESULT[int]()
                            fi
                    );
                si;
            let driver3 = _FOR_EACH_DRIVER[int, int](xs.iterator, body3);
            let r3 = driver3.start().result;
            Std.write_line("stage3.type={r3.type} value={r3.value} iterations={counter3.count}");

            // Stage 4: 1000 async yields to verify the static-call
            // cycle (pump→on_complete→pump) is iterative at runtime
            // because each .continue_with hop is dispatched on a fresh
            // thread-pool task. If it were stack-recursive, this would
            // blow the stack.
            let counter4 = COUNTER();
            let large_mutable = Collections.LIST[int]();
            for i in 0..1000 do
                large_mutable.add(i);
            od
            let large: Collections.List[int] = large_mutable;
            let body4: int -> Tasks.TASK[_LOOP_RESULT[int]] =
                x is
                    counter4.bump();
                    return Tasks.TASK.delay(0).continue_with(
                        (t: Tasks.TASK) -> _LOOP_RESULT[int] => _LOOP_RESULT[int]()
                    );
                si;
            let driver4 = _FOR_EACH_DRIVER[int, int](large.iterator, body4);
            let r4 = driver4.start().result;
            Std.write_line("stage4.type={r4.type} iterations={counter4.count}");
        si
    si
si
