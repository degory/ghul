namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            outer: for i in 0..3 do
                for j in 0..3 do
                    if i == 1 /\ j == 1 then
                        continue outer;
                    fi

                    if i == 2 /\ j == 0 then
                        break outer;
                    fi

                    Std.out.write_line("for i {i} j {j}");
                od
            od

            let k mut = 0;

            countdown: do
                let m mut = 0;

                do
                    if m == 2 then
                        if k == 3 then
                            break countdown;
                        fi

                        k = k + 1;
                        continue countdown;
                    fi

                    Std.out.write_line("do k {k} m {m}");

                    m = m + 1;
                od
            od

            Std.out.write_line("done");
        si
    si
si
