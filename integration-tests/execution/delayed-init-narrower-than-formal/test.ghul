namespace Test is
    use IO.Std;

    // Generalises F07 beyond the `==(object, object)` surface
    // form: a delayed-init binding `let v` is assigned a CAT,
    // then passed to a function expecting ANIMAL, then later
    // assigned BACK into a CAT-typed slot. Without the upper-
    // bound back-feed split, the ANIMAL formal widens v's LUB
    // to ANIMAL, breaking the CAT assignment. With the fix, the
    // ANIMAL formal is recorded as an upper bound (validated:
    // CAT is assignable to ANIMAL — passes) without polluting
    // the LUB; v stays CAT.

    class ANIMAL is
        kind: string;

        init(kind: string) is
            self.kind = kind;
        si
    si

    class CAT: ANIMAL is
        whiskers: int;

        init(whiskers: int) is
            super.init("cat");
            self.whiskers = whiskers;
        si
    si

    describe(a: ANIMAL) -> string => "{a.kind}";

    entry() is
        let v mut;
        v = CAT(8);
        let label = describe(v);
        let c: CAT = v;
        Std.out.write_line("{label} {c.whiskers}");
    si
si
