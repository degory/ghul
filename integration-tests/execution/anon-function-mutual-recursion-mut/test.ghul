use IO.Std.write_line;

// Two anonymous functions referring to each other via a
// forward-declared mutable. `is_odd` is captured by reference
// inside `is_even` — the box is allocated at the declaration,
// then the later assignment populates the cell both closures
// see.
entry() is
    let is_odd mut;

    let is_even = n => if n == 0 then true else is_odd(n - 1) fi;
    is_odd = n rec => if n == 0 then false else is_even(n - 1) fi;

    write_line("is_even(10): {is_even(10)}");
    write_line("is_odd(10): {is_odd(10)}");
si
