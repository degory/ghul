namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // `t`'s tuple type carries `v`'s inference placeholder
            // as its first element type. The placeholder emits the
            // resolved type's IL, so it has to agree that the
            // element is a value type — otherwise the element gets
            // boxed in front of a ctor signature that expects it
            // unboxed, and the JIT rejects the method.
            let v mut;
            v = 77;
            let t mut;
            t = (v, 1);

            Std.write_line("t = {t}");

            // Same cascade with the placeholder in later positions,
            // and mixed with a reference element.
            let s mut;
            s = "hello";
            let u mut;
            u = (s, v, 2.5);

            Std.write_line("u = {u}");

            // The placeholder-typed local still boxes where boxing
            // is genuinely required.
            let o: object mut;
            o = v;

            Std.write_line("o = {o}");

            return;
        si
    si
si
