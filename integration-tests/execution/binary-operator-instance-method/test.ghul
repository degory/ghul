namespace Test is








    use Std = IO.Std;

    class Main is
        entry() static is
            

            let t = THING(111);

            let u = THING(222);

            let z = t % u;

            Std.out.write_line("z is: {z}");
        si
    si

    class THING is
        _value: int;

        init(value: int) is
            _value = value;
        si
        
        %(other: THING) -> THING is
            return THING(self._value + other._value);
        si

        to_string() -> string is
            return "T{_value}";
        si
    si
si

