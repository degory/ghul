namespace Test is
    use IO.Std;

    // Regression guard: an `isa` test on a parameter narrows that
    // parameter's type within the branch. Pinned for the case
    // where the parameter starts with an explicit Animal type and
    // gets narrowed to Cat / Dog inside the branches.
    //
    // Note: ghūl does not yet support generic constraints like
    // `[T: Animal]` (errors with "type constraints are not
    // supported"). When constraints land, this test should be
    // rewritten to exercise the constrained-generic-param form.

    class Animal is
        init() is si
    si

    class Cat: Animal is
        init() is si
        meow() -> string => "meow";
    si

    class Dog: Animal is
        init() is si
        woof() -> string => "woof";
    si

    describe(a: Animal) -> string is
        if isa Cat(a) then
            let c = cast Cat(a);
            return c.meow();
        elif isa Dog(a) then
            let d = cast Dog(a);
            return d.woof();
        else
            return "unknown";
        fi
    si

    class Main is
        entry() static is
            Std.write_line(describe(Cat()));
            Std.write_line(describe(Dog()));
            return;
        si
    si
si
