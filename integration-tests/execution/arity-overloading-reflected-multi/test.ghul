namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // System.Lazy[T] (arity 1) and System.Lazy[T, M] (arity 2)
            // arrive from reflection sharing the bare ghul name `Lazy`
            // — they form a TYPE_GROUP and dispatch by arity at the
            // use site.
            let single = System.Lazy[int](() => 7);
            Std.write_line("arity-1: {single.value}");

            let metadata = System.Lazy[string, int](() => "payload", 42);
            Std.write_line("arity-2: {metadata.value} meta={metadata.metadata}");

            return;
        si
    si
si
