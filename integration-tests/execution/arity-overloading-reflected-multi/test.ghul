namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // System.Lazy[T] (one generic argument) and
            // System.Lazy[T, M] (two generic arguments) arrive from
            // reflection sharing the bare ghul name `Lazy` — they form a
            // TYPE_GROUP and dispatch by argument count at the use site.
            let single = System.Lazy[int](() => 7);
            Std.write_line("one-arg: {single.value}");

            let metadata = System.Lazy[string, int](() => "payload", 42);
            Std.write_line("two-args: {metadata.value} meta={metadata.metadata}");

            return;
        si
    si
si
