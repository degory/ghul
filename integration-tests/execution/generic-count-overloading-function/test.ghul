namespace Test is
    use Std = IO.Std;

    foo() is
        Std.write_line("foo");
    si

    foo[T](value: T) is
        Std.write_line("foo[T] {value}");
    si

    foo[T, U](a: T, b: U) is
        Std.write_line("foo[T,U] {a} {b}");
    si

    class Main is
        entry() static is
            foo();
            foo[int](42);
            foo[int, string](1, "two");

            return;
        si
    si
si
