// Constructing a KeyValuePair writes only the fresh pair struct, so a
// function literal that builds one satisfies a pure function-typed
// parameter without an impure-function-value warning — the
// construction is store-free and keeps the caller's narrowings.

use Std = IO.Std;
use Collections;

apply(f: (int) -> KeyValuePair[int, int] pure, x: int) -> KeyValuePair[int, int] => f(x);

entry() is
    let p = apply(k => KeyValuePair(k, k * 2), 3);

    Std.write_line("{p.key}={p.value}");
si
