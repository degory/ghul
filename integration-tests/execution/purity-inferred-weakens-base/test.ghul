namespace Test is
    use Std = IO.Std;

    // Closed-hierarchy reconciliation: an inferred MUT override
    // silently weakens an inferred PURE base. Both base and
    // override end up classified MUT. No error; the program
    // compiles and runs.

    class STATE is
        _counter: int;
        init() is si
        counter: int => _counter;
        increment() mut is _counter = _counter + 1; si
    si

    class BASE is
        // Body has no impurity signal — inferred PURE.
        describe() -> string is
            return "base";
        si
    si

    class DERIVED: BASE is
        _state: STATE;
        init(state: STATE) is _state = state; si

        // Body calls `this._state.increment()` — receiver of the
        // call is `_state`, a field of `this`. The
        // call-target's purity is MUT but the assignment to
        // `this._state.counter` isn't here; the impurity
        // signal in this body is the bare-identifier assignment
        // pattern below (count = _state.counter). That's a
        // bare-local assignment so it's PURE on its own.
        // What pushes this to MUT is the `=` write to
        // `_count` (a field of `this`).
        _count: int;

        describe() -> string is
            _count = _state.counter;
            return "derived count={_count}";
        si
    si

    class Main is
        entry() static is
            let s = STATE();
            let d = DERIVED(s);
            Std.write_line(d.describe());
            return;
        si
    si
si
