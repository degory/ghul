namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.flat_map[U]` in
    // `ghul-runtime/src/pipe.ghul`:
    //   flat_map[U](mapper: (T) -> Iterable[U]) -> Pipe[U]
    //
    // The outer flat_map's U comes from the inner pipe expression's
    // element type. The inner pipe itself is a `Pipe[int]` formed
    // from a filtered range. Two levels of inference: the inner
    // filter must resolve its predicate's arg type (string), and
    // the inner pipe's element type (int — from the lambda body
    // producing a list of ints) must propagate up to bind U in
    // the outer flat_map.
    //
    // Distinct from `flat-map` (which uses a simple
    // array literal as the mapper return) — this exercises whether
    // a *piped* result with downstream operations satisfies the
    // `Iterable[U]` formal.

    class Main is
        entry() static is
            let words = ["one", "two", "three"];

            // Build per-word digit sequences: for each word, take
            // its length and yield 1..length.
            let digits = words | .flat_map(w => [1, 2, 3] | .take(w.length) .collect()) .collect();

            for d in digits do
                Std.write_line("{d}");
            od

            return;
        si
    si
si
