namespace Test is
    use Std = IO.Std;

    class POINT(
        x: int,
        y: int,
    ) is
        _x;
        _y;

        show() is
            Std.write_line("({_x}, {_y})");
        si
    si

    class Main is
        entry() static is
            POINT(3, 4).show();
        si
    si
si
