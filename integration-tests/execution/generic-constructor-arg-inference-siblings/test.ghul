namespace Test is
    use Std = IO.Std;

    // Regression test for LUB inference of generic class type arguments
    // in constructor expressions. When a generic class is constructed
    // with sibling argument types — e.g. `Box(Cat(), Dog())` where the
    // formal init takes `(T, T)` and Cat/Dog are siblings of Animal —
    // the owner's generic argument T should be inferred as Animal via
    // LUB, mirroring the behaviour PR #1205 added for generic function
    // calls. Previously the bind-results pairwise widening gave up on
    // siblings and either failed overload resolution outright or fell
    // through to `object`.

    class Animal is
        init() is si
        speak() -> string => "animal";
    si

    class Cat: Animal is
        init() is si
    si

    class Dog: Animal is
        init() is si
    si

    class Plant is
        init() is si
    si

    class Box[T] is
        a: T;
        b: T;

        init(a: T, b: T) is
            self.a = a;
            self.b = b;
        si

        first() -> T => a;
        second() -> T => b;
    si

    class Triple[T] is
        a: T;
        b: T;
        c: T;

        init(a: T, b: T, c: T) is
            self.a = a;
            self.b = b;
            self.c = c;
        si

        any() -> T => a;
    si

    class Main is
        entry() static is
            // Two siblings — T should be inferred as Animal.
            let two = Box(Cat(), Dog());
            Std.out.write_line("siblings: {two.first().speak()}");

            // Sibling + ancestor (both orders) — pairwise widening already handles this.
            let ancestor_first = Box(Animal(), Cat());
            Std.out.write_line("ancestor first: {ancestor_first.first().speak()}");

            let ancestor_second = Box(Cat(), Animal());
            Std.out.write_line("ancestor second: {ancestor_second.first().speak()}");

            // Three siblings — T should still be Animal.
            let three = Triple(Cat(), Dog(), Cat());
            Std.out.write_line("three siblings: {three.any().speak()}");

            // Unrelated types — T falls back to object.
            let unrelated = Box(Cat(), Plant());
            Std.out.write_line("unrelated: {unrelated.first().to_string()}");

            return;
        si
    si
si
