namespace Test is
    use IO.Std;
    use Collections;
    use Ghul.Pipes;

    // A guarded (collection) source combined with NON-inlined stages: a
    // delegate variable, a block-bodied capturing lambda, and an argument
    // that is itself an if-expression (a composite-value BLOCK). In the
    // guarded lowering such a stage argument is emitted at two sites - the
    // fused-setup delegate temp and the fallback pipe chain - so this pins
    // that the double emission produces correct IL on both the fused and
    // fallback paths (the guard test resolves at run time; a plain List
    // source is not a Pipe, so the fused branch runs).

    class Main is
        entry() static is
            let xs = LIST[int]([1, 2, 3, 4, 5]);

            // delegate variable stage over a guarded source
            let doubler = (n: int) -> int => n * 2;
            let sum1 mut = 0;
            for x in pipe(xs).map(doubler).filter(n => n > 4) do
                sum1 = sum1 + x;
            od
            // 2,4,6,8,10 ; >4 => 6,8,10 ; 24
            Std.write_line("delegate: {sum1}");

            // block-bodied capturing lambda stages (not inlinable)
            let factor = 10;
            let sum2 mut = 0;
            for x in pipe(xs).map((n: int) is return n * factor; si).filter((n: int) is return n > 20; si) do
                sum2 = sum2 + x;
            od
            // 10..50 ; >20 => 30,40,50 ; 120
            Std.write_line("block: {sum2}");

            // argument is an if-expression whose value is a BLOCK
            let f = (n: int) -> int => n * 10;
            let g = (n: int) -> int => n * 100;
            let use_f = true;
            let sum3 mut = 0;
            for x in pipe(xs).map(if use_f then f else g fi).filter(n => n > 20) do
                sum3 = sum3 + x;
            od
            // f: 10..50 ; >20 => 30,40,50 ; 120
            Std.write_line("if-block: {sum3}");
        si
    si
si
