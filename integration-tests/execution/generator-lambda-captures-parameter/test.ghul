namespace Test is
    use Std = IO.Std;

    class Main is
        // Captured argument
        gen(base: int) -> Ghul.Pipes.Pipe[int] static is
            let scale = (n: int) => base * n;
            yield scale(1);
            yield scale(2);
            yield scale(3);
        si

        entry() static is
            for x in gen(10) do
                Std.write_line("got {x}");
            od
        si
    si
si
