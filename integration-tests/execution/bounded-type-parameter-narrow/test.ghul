use IO.Std.write_line;

// A value of a type parameter bounded by a union narrows and
// destructures through its bound, the way member access already
// resolves through it - no manual widening to the bound needed.

union List[T] is
    NIL;
    CONS(head: T, tail: List[T]);
si

use List.NIL;
use List.CONS;

union Pair[T] is
    BOTH(first: T, second: T);
si

use Pair.BOTH;

// refutable destructure + recursion through the bound
join_list[L: List[E], E](xs: L) -> string =>
    if let (head, tail): CONS = xs then
        "{head} {join_list[List[E], E](tail)}"
    else
        "."
    fi;

// isa narrow of an existing variable, then member access
head_or[L: List[E], E](xs: L, fallback: E) -> E is
    if isa CONS(xs) then
        return xs.head;
    fi

    return fallback;
si

// irrefutable destructure when the bound is a positional variant
swap[P: BOTH[E], E](p: P) -> string is
    let (a, b) = p;

    return "{b} {a}";
si

entry() is
    let xs = CONS(1, CONS(2, CONS(3, NIL)));

    write_line(join_list[List[int], int](xs));
    write_line("head {head_or[List[int], int](xs, -1)}");
    write_line("empty head {head_or[List[int], int](NIL, -1)}");
    write_line(swap[BOTH[string], string](BOTH("left", "right")));
si
