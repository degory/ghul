namespace Test is
    use Std = IO.Std;

    class Main is
        // captured-mutable across `let await` AND across an if/else.
        // Both branches of the if mutate the captured `total`; a
        // second `let await` reads it after the join. The branches
        // are compiled inside the first continuation lambda's body;
        // both arms share the same BOX[int] via the enclosing
        // capture chain.
        compute(seed: int) -> Tasks.TASK[int] static is
            let total mut = 0;

            let first = await Tasks.TASK.from_result(seed);

            if first > 0 then
                total = first + 1;
            else
                total = -first;
            fi

            let second = await Tasks.TASK.from_result(5);
            total = total + second;

            return total;
        si

        entry() static is
            let positive = compute(3);
            let negative = compute(-7);

            Std.write_line("positive = {positive.result}");
            Std.write_line("negative = {negative.result}");
        si
    si
si
