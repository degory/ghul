namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            test_bare_optional_drain();
            test_narrow_type();
            test_narrow_type_with_guard();
            test_destructure_pair();
            test_zero_iterations();
            test_break_exits_early();
        si

        // Bare `while let x = e` keeps looping while `e` produces a
        // non-null value. A queue of optional reads.
        test_bare_optional_drain() static is
            let q = QUEUE();
            q.push("a"); q.push("b"); q.push("c");

            while let s = q.pop() do
                Std.out.write_line("01-pop: {s}");
            od
            Std.out.write_line("01-done");
        si

        // `while let c: CAT = a` — `a` narrows to CAT inside the
        // body; the loop exits when the cast fails. We mutate `a`
        // in the body to break the loop.
        test_narrow_type() static is
            let a: ANIMAL mut = CAT("felix");
            let n mut = 0;

            while let c: CAT = a do
                Std.out.write_line("02-narrow: {c.purr()}");
                n = n + 1;
                if n >= 2 then
                    a = DOG("rex");
                fi
            od
            Std.out.write_line("02-done after {n}");
        si

        // The common case the user called out: narrow-type binding
        // plus a `/\` guard against the bound name. Both must hold
        // each iteration.
        test_narrow_type_with_guard() static is
            let a: ANIMAL mut = CAT("whiskers");
            let n mut = 0;

            while let c: CAT = a /\ c.has_whiskers do
                Std.out.write_line("03-guarded: {c.purr()}");
                n = n + 1;
                if n >= 1 then
                    // Mutate so c.has_whiskers fails: still a CAT,
                    // but the guard rejects.
                    a = CAT.bald("baldy");
                fi
            od
            Std.out.write_line("03-done after {n}");
        si

        // Destructuring binding — pop pairs while available.
        test_destructure_pair() static is
            let q = PAIR_QUEUE();
            q.push(PAIR(1, "one"));
            q.push(PAIR(2, "two"));

            while let (n, s) = q.pop() do
                Std.out.write_line("04-pair: {n}={s}");
            od
            Std.out.write_line("04-done");
        si

        // An immediately-absent scrutinee → loop body never runs.
        test_zero_iterations() static is
            let q = QUEUE();
            while let s = q.pop() do
                Std.out.write_line("05-unexpected: {s}");
            od
            Std.out.write_line("05-skipped");
        si

        // `break` exits the loop cleanly.
        test_break_exits_early() static is
            let q = QUEUE();
            q.push("x"); q.push("y"); q.push("z");

            while let s = q.pop() do
                if s =~ "y" then
                    break;
                fi
                Std.out.write_line("06-saw: {s}");
            od
            Std.out.write_line("06-done");
        si
    si

    class QUEUE is
        _items: Collections.LIST[string];

        init() is _items = Collections.LIST[string](); si

        push(s: string) is _items.add(s); si

        pop() -> string? is
            if _items.count == 0 then
                return null;
            fi
            let result = _items[0];
            _items.remove_at(0);
            return result;
        si
    si

    class PAIR is
        a: int public;
        b: string public;

        init(a: int, b: string) is
            self.a = a;
            self.b = b;
        si
    si

    class PAIR_QUEUE is
        _items: Collections.LIST[PAIR];

        init() is _items = Collections.LIST[PAIR](); si

        push(p: PAIR) is _items.add(p); si

        pop() -> (int, string)? is
            if _items.count == 0 then
                return null;
            fi
            let p = _items[0];
            _items.remove_at(0);
            return (p.a, p.b);
        si
    si

    class ANIMAL is
        name: string public;
        init(name: string) is self.name = name; si
    si

    class CAT: ANIMAL is
        has_whiskers: bool public;

        init(name: string) is
            super.init(name);
            has_whiskers = true;
        si

        bald(name: string) -> CAT static is
            let c = CAT(name);
            c.has_whiskers = false;
            return c;
        si

        purr() -> string => "{name} purrs";
    si

    class DOG: ANIMAL is
        init(name: string) is super.init(name); si
    si
si
