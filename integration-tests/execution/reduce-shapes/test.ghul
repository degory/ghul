namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by ghul-runtime's `Pipe.reduce`
    // (`pipe.ghul` lines 69-87). Combines several inference paths
    // in one expression:
    //
    //   - Owner-generic inference for `ACCUMULATOR[T]` from the
    //     LIST literal passed to the constructor.
    //   - Method-generic inference for `reduce[R]`'s R from the
    //     seed argument.
    //   - Lambda-param inference for the (R, T) -> R accumulator's
    //     two args from the formal Function type.
    //
    // Pinned because the runtime's reduce is heavily used by
    // downstream code and any regression here would ripple wide.

    class ACCUMULATOR[T] is
        _items: LIST[T];

        init(items: LIST[T]) is
            _items = items;
        si

        reduce[R](seed: R, accumulator: (R, T) -> R) -> R is
            let running mut = seed;

            for e in _items do
                running = accumulator(running, e);
            od

            return running;
        si
    si

    class Main is
        entry() static is
            let ints = LIST[int]();
            ints.add(1); ints.add(2); ints.add(3); ints.add(4);

            let a = ACCUMULATOR(ints);
            let sum = a.reduce(0, (r, e) => r + e);
            Std.write_line("sum={sum}");

            let words = LIST[string]();
            words.add("alpha");
            words.add("beta");

            let acc_words = ACCUMULATOR(words);
            let concatenated = acc_words.reduce("", (r, e) => "{r}{e}");
            Std.write_line("concat={concatenated}");

            return;
        si
    si
si
