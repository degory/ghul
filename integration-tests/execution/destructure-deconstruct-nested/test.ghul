
use IO.Std.write_line;
use Collections.KeyValuePair;

entry() is
    let outer =
        KeyValuePair[string, KeyValuePair[int, int]](
            "size",
            KeyValuePair[int, int](80, 24)
        );

    let (label, (w, h)) = outer;
    write_line("{label} {w}x{h}");

    let pair_tuple: (int, KeyValuePair[string, int]) =
        (7, KeyValuePair[string, int]("seven", 49));

    let (n, (word, sq)) = pair_tuple;
    write_line("{n} -> {word} {sq}");
si
