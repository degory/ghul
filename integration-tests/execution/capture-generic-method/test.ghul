namespace Test is
    use IO.Std;
    use Collections;

    // Tests: lambda captures a concrete LIST[int] and
    // calls a generic method (like .filter, .map) on it inside the
    // body. The captured type is already resolved before the lambda
    // walks, so the generic method's T should bind cleanly.

    class Main is
        entry() static is
            let xs = [1, 2, 3, 4, 5];
            let evens = () => xs | .filter(n => n % 2 == 0) .collect();
            let e = evens();
            for v in e do
                Std.write_line("{v}");
            od
            return;
        si
    si
si
