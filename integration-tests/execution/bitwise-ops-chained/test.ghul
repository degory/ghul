namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let or_chain: int = 8 | 4 | 1; // 13
            let and_chain: int = 14 & 13 & 11; // 8
            let xor_chain: int = 10 ^ 12 ^ 1; // 7

            Std.out.write_line(or_chain);
            Std.out.write_line(and_chain);
            Std.out.write_line(xor_chain);

            return;
        si
    si
si
