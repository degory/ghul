use IO.Std.write_line;

// `val ... lav` sitting entirely inside a `try ... yrt`. The val-
// block opens no `.try` of its own, so a return-targeted return
// inside the body brs to end_label within the SAME try region —
// valid intra-region `br`, no boundary crossing. End_label is
// inside the same try as the return.
try_around_val(n: int) -> int is
    try
        let x = val
            if n < 0 then
                return 0;
            fi
            n * 2
        lav;

        write_line("try_around_val({n}) saw x = {x}");
        return x + 1;
    catch e: System.Exception
        write_line("caught: {e.message}");
        return -999;
    yrt
si

entry() is
    write_line("try_around_val(5) = {try_around_val(5)}");
    write_line("try_around_val(-3) = {try_around_val(-3)}");
si
