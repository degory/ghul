use IO.Std.write_line;

flag() -> bool => true;

// `if` with non-value-providing branches as the `=> body` of a
// void-returning function. The void return type pushes
// want_value=false down through the wrapping Expressions.STATEMENT,
// so the IF accepts branches that are pure side-effect statements.
if_void_body(label: string) =>
    if flag() then
        write_line("{label} then");
    else
        write_line("{label} else");
    fi;

// Same for `case`.
case_void_body(label: string) =>
    case label
    when "a" then write_line("{label} a");
    when "b" then write_line("{label} b");
    else         write_line("{label} other");
    esac;

entry() is
    if_void_body("if");
    case_void_body("a");
    case_void_body("z");
si
