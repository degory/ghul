use IO.Std.write_line;

// calls a function and constructs a class defined lower in the file
write_line("double(21) = {double(21)}");

double(n: int) -> int => n + n;

let p = POINT(3, 4);
write_line("point sum = {p.sum()}");

// bare top-level calls whose first argument begins with an identifier and
// continues compound — a nested call, a member access, an index. These are
// the `(identifier (`, `(identifier .`, `(identifier [` shapes the peek must
// classify as a statement rather than a definition.
write_line(double(double(2)).to_string());
write_line(p.sum().to_string());
let xs = [10, 20, 30];
write_line(xs[1].to_string());

class POINT(x: int, y: int) is
    sum() -> int => x + y;
si
