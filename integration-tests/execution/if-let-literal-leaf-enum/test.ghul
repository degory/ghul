namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // Enum member at a destructure position — qualified-name
            // expression in pattern position, value-equality test
            // against the source's element.
            show((Color.RED, "stop"));
            show((Color.GREEN, "go"));
            show((Color.RED, "halt"));
            show(null);
        si

        show(pair: (Color, string)?) static is
            if let (Color.RED, label) = pair then
                Std.out.write_line("red: {label}");
            else
                Std.out.write_line("nope");
            fi
        si
    si

    enum Color is
        RED,
        GREEN,
        BLUE
    si
si
