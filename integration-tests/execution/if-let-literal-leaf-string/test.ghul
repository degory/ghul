namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            // String literal at first position. String literals are
            // interned, so reference identity works for these
            // literal-equality tests; arbitrary runtime strings need
            // an explicit `=~` guard rather than a literal-leaf.
            show(("hello", 1));
            show(("hello", 2));
            show(("world", 3));
            show(null);
        si

        show(pair: (string, int)?) static is
            if let ("hello", n) = pair then
                Std.out.write_line("got hello with {n}");
            else
                Std.out.write_line("nope");
            fi
        si
    si
si
