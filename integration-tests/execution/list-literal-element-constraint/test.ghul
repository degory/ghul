namespace Test is
    use Std = IO.Std;

    // List-literal-element-as-constraint propagation: when the
    // surrounding context tells the SEQUENCE compile path what the
    // list's element type should be (either via an inline annotation
    // `[…]: T[]` or via a constraint pushed by the parent — typed
    // initializer, list-of-lambdas, ...), push the corresponding
    // element type down to each element so element-side inference
    // (notably function-literal arg-type inference) can use it.
    //
    // Implements the "list literal element types" item in #1174 and
    // delivers the maintainer-flagged target shape:
    //
    //   let it: Iterable[int -> int] = [x => x + 1, y => y * 2];

    class Main is
        entry() static is
            // ---- the target case: list of lambdas behind an
            // ---- Iterable[function-type] declaration

            let it: Collections.Iterable[int -> int] = [x => x + 1, y => y * 2];

            for fn in it do
                Std.out.write_line("it: " + fn(10));
            od

            // ---- single-element list, unary lambda

            let single: Collections.Iterable[int -> int] = [x => x + 100];

            for fn in single do
                Std.out.write_line("single: " + fn(0));
            od

            // ---- multi-arg lambda inside a list

            let multi: Collections.Iterable[(int, int) -> int] = [(a, b) => a + b, (a, b) => a * b];

            for fn in multi do
                Std.out.write_line("multi: " + fn(3, 4));
            od

            // ---- mixed-type lambda return

            let mixed: Collections.Iterable[int -> string] = [n => "val=" + n];

            for fn in mixed do
                Std.out.write_line("mixed: " + fn(42));
            od

            // ---- regression: list of non-lambda elements with a
            // ---- container type that has a meaningful element type
            // ---- but where the element constraint is irrelevant
            // ---- (each element is a value-typed literal, the
            // ---- existing assignability check still drives the
            // ---- check). Element constraint pushed down is silently
            // ---- ignored by the literal Expressions.

            let nums: Collections.Iterable[int] = [1, 2, 3];

            for n in nums do
                Std.out.write_line("nums: " + n);
            od

            // ---- regression: typed-initializer with strings — the
            // ---- previous behaviour was that string elements could
            // ---- still satisfy an `object` element constraint via
            // ---- assignability; that path stays intact here too.

            let oa: Collections.Iterable[object] = ["a", "b", "c"];

            for o in oa do
                Std.out.write_line("oa: " + o);
            od

            return;
        si
    si
si
