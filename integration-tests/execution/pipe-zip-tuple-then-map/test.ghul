namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.zip[U]` 2-arg form
    // in `ghul-runtime/src/pipe.ghul`:
    //   zip[U](other: Iterable[U]) -> Pipe[(T,U)]
    //
    // The result is a `Pipe[(int, string)]` — element type is a
    // tuple. A subsequent `.map` lambda's arg type must resolve
    // to that tuple, and the lambda body accesses the tuple's
    // positional fields. verifies tuple-typed pipe elements +
    // positional-field access on the lambda's arg.

    class Main is
        entry() static is
            let ns = [1, 2, 3];
            let words = ["a", "b", "c"];

            let labelled = ns | .zip(words) .map(p => "{p.`0}:{p.`1}") .collect();

            for line in labelled do
                Std.write_line(line);
            od

            return;
        si
    si
si
