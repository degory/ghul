namespace Test is
    use Std = IO.Std;

    class Main is
        compute() -> Tasks.TASK[int] static is
            let total mut = 0;
            for n in [1, 2, 3, 4] do
                let x = await Tasks.TASK.from_result(n * 10);
                total = total + x;
            od
            return total;
        si

        entry() static is
            let r = compute();
            Std.write_line("total={r.result}");
        si
