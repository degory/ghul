use IO.Std.write_line;

// A zero-capture lambda in an instance method that never reads self is
// stateless: its delegate is built once and reused from a static cache,
// so two loads (even on different receivers) yield the same instance and
// the same behaviour.
class BOX is
    id: int;

    init(id: int) is
        self.id = id;
    si

    stateless() -> (int) -> int => n => n + 1;
si

entry() is
    let a = BOX(10);
    let b = BOX(20);

    let fa = a.stateless();
    let fb = b.stateless();

    write_line("same instance: {object.reference_equals(fa, fb)}");
    write_line("fa(1) = {fa(1)}");
    write_line("fb(1) = {fb(1)}");
si
