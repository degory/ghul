namespace Test is
    use Std = IO.Std;

    use System.Exception;
    use System.InvalidOperationException;

    class Main is
        entry() static is
            run("assert true else exception should not throw", () -> void is
                assert true else InvalidOperationException("ignored");
            si);

            run("assert false else exception should throw the supplied exception", () -> void is
                assert false else InvalidOperationException("custom message");
            si);

            run("assert false else exception expression should throw the supplied exception", () -> void is
                let message = "computed message";
                assert false else InvalidOperationException(message);
            si);
        si

        run(description: string, test: () -> void) static is
            try
                Std.out.write_line(description);
                test();
                Std.out.write_line("did not throw");
            catch ex: Exception
                Std.out.write_line("threw: {ex.get_type().name} {ex.message}");
            finally
                Std.out.write_line();
            yrt
        si
    si
si
