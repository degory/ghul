namespace Test is
    use IO.Std;
    use Collections;

    // Inspired by `Pipe.index() -> Pipe[INDEXED_VALUE[T]]`
    // in `ghul-runtime/src/pipe.ghul`. The downstream `.map` lambda's
    // arg type is `INDEXED_VALUE[string]` — a generic struct whose
    // T must propagate from the original pipe element type through
    // the `index()` stage's return.
    //
    // Verifies member access (`.index`, `.value`) on a placeholder
    // receiver whose type resolves to a generic struct.

    class Main is
        entry() static is
            let words = ["alpha", "beta", "gamma"];

            let lines = words | .index() .map(iv => "{iv.index}: {iv.value}") .collect();

            for line in lines do
                Std.write_line(line);
            od

            return;
        si
    si
si
