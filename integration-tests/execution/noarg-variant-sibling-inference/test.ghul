namespace Test is
    use Std = IO.Std;

    // A no-arg union variant has no value arguments from which to
    // infer its enclosing union's type parameter. When it appears as
    // a sibling argument alongside a value that *does* pin the type
    // parameter, the bind from the concrete sibling should specialise
    // the formal expected of the no-arg variant call, mirroring the
    // sibling-arg inference that already works for value-bearing
    // generic constructor calls.

    union List[T] is
        NIL;
        CONS(head: T, tail: List[T]);
    si

    use List.NIL;
    use List.CONS;

    class Main is
        entry() static is
            // Concrete int T — works even without the back-feed,
            // because the int sibling forces T at the outer CONS.
            let plain = CONS(1, NIL());
            Std.out.write_line("plain: {render(plain)}");

            // Multi-level nesting, also concrete int.
            let deep_int = CONS(1, CONS(2, CONS(3, NIL())));
            Std.out.write_line("deep_int: {render(deep_int)}");

            // Generic-function T — the regression case. Without
            // back-feeding T into NIL's owner-type-arg phantom, the
            // phantom defaults to object and the construction emits
            // List<object> in build_three's IL.
            build_three[int](10, 20, 30);

            return;
        si

        build_three[T](a: T, b: T, c: T) static is
            let list = CONS(a, CONS(b, CONS(c, NIL())));
            Std.out.write_line("build_three: {render(list)}");
            return;
        si

        render[T](l: List[T]) -> string static is
            if isa CONS(l) then
                return "{l.head}, {render(l.tail)}";
            fi
            return "nil";
        si
    si
si
