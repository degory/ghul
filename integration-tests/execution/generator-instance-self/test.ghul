namespace Test is
    use Std = IO.Std;

    class Source is
        base: int;

        init(b: int) is base = b; si

        add_base(n: int) -> int is return base + n; si

        items() -> Ghul.Pipes.Pipe[int] is
            yield base;
            yield base + 1;
            yield self.add_base(100);
            yield self.add_base(200);
        si
    si

    class Main is
        entry() static is
            let s = Source(10);
            for x in s.items() do
                Std.write_line("v: {x}");
            od
        si
    si
si
