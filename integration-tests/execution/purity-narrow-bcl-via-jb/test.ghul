namespace Test is
    use Std = IO.Std;

    // JetBrains ExternalAnnotations marks `System.Math.Abs(int)`
    // (and many other BCL methods) as `[Pure]` via the XML
    // bundled with the compiler. The reflection-import path
    // looks the method's doc ID up in JB's XML and sets
    // `Function.purity` to PURE, so path-presence narrowing
    // survives the call. Without JB the BCL method would have
    // no purity marker (modern BCL has dropped
    // [System.Diagnostics.Contracts.Pure]) and the call would
    // clear the narrowing under default-IMPURE.

    class HOLDER is
        value: int?;
        init(value: int?) is self.value = value; si
    si

    class Main is
        entry() static is
            let h = HOLDER(7);

            if h.value? then
                let abs_value = System.Math.abs(h.value);
                // System.Math.Abs(int) is PURE via JB
                // ExternalAnnotations. h.value's path narrowing
                // is intact, so the assignment to a non-optional
                // local type-checks.
                let v: int = h.value;
                Std.write_line("via jb pure: v={v} abs={abs_value}");
            fi
            return;
        si
    si
si
