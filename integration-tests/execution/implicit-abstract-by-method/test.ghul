namespace Test is
    use IO.Std;

    // `ANIMAL` has a body-less `describe` method — calling it on a
    // bare `ANIMAL` instance would invoke the synthesised throw
    // body. Treat the class as implicitly abstract so closed-class
    // narrowing on `isa CAT(a)` can soundly collapse the else
    // edge to the singleton sibling.

    class ANIMAL is
        init() is si
        describe() -> string;
    si

    class CAT: ANIMAL is
        init() is super.init(); si
        describe() -> string => "cat";
    si

    class DOG: ANIMAL is
        init() is super.init(); si
        describe() -> string => "dog";
        bark() -> string => "bark";
    si

    class Main is
        entry() static is
            sniff(CAT());
            sniff(DOG());
        si

        sniff(a: ANIMAL) static is
            if isa CAT(a) then
                Std.out.write_line(a.describe());
            else
                Std.out.write_line(a.bark());
            fi
        si
    si
si
