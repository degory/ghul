namespace Test is
    read_int(p: int ref) -> int is
        @IL.output("il.out")
        return p!;
    si

    write_int(p: int ref, v: int) is
        @IL.output("il.out")
        p! = v;
    si

    write_string(p: string ref, v: string) is
        @IL.output("il.out")
        p! = v;
    si
si
