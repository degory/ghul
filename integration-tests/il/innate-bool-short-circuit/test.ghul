namespace Test is
    use Std = IO.Std;

    class Main is
        entry() static is
            let t: bool mut; // = true;
            let f: bool mut; // = false;

            let b: bool mut;

            @IL.output("il.out")
            b = t \/ t;
            @IL.output("il.out")
            b = t \/ f;

            @IL.output("il.out")
            b = f \/ t;
            @IL.output("il.out")
            b = f \/ f;

            @IL.output("il.out")
            b = t /\ t;
            @IL.output("il.out")
            b = t /\ f;

            @IL.output("il.out")
            b = f /\ t;
            @IL.output("il.out")
            b = f /\ f;
        si
    si
si
