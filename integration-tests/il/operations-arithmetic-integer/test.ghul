namespace Test is








    use Std = IO.Std;

    class Main is
        test_int() is
            let x: int mut , y: int mut, z: int mut;

            @IL.output("il.out")
            x = y + z;

            @IL.output("il.out")
            x = y - z;

            @IL.output("il.out")
            x = y * z;

            @IL.output("il.out")
            x = y / z;
        si

        test_long() is
            let x: long mut , y: long mut, z: long mut;

            @IL.output("il.out")
            x = y + z;

            @IL.output("il.out")
            x = y - z;

            @IL.output("il.out")
            x = y * z;

            @IL.output("il.out")
            x = y / z;
        si

    si
si