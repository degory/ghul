namespace Test is
    use Std = IO.Std;
    use Ghul.Pipes.Pipe;

    class Main is
        nums(n: int) -> Pipe[int] static is
            let i mut = 1;
            while i <= n do
                yield i;
                i = i + 1;
            od
        si

        entry() static is
            // operand is already a Pipe -> `|` is a no-op: take() is
            // called directly on the generator, no pipe() wrap emitted
            @IL.output("il.out")
            let a = nums(3) | .take(2);

            // operand is a List -> `|` wraps it via Ghul.Pipes.$globals.pipe
            @IL.output("il.out")
            let b = [1, 2, 3] | .take(2);

            Std.out.write_line("{a}");
            Std.out.write_line("{b}");
        si
    si
si
