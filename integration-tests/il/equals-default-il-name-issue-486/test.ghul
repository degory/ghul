namespace Test is
    use IO.Std;

    class Box is
        value: int;

        init(value: int) is
            self.value = value;
        si

        @IL.output("il.out")
        =~(other: Box) -> bool => other? /\ value == other.value;
    si

    class Main is
        entry() static is
            let a = Box(42);
            let b = Box(42);
            let c = Box(7);
            Std.write_line("a =~ b: {a =~ b}");
            Std.write_line("a =~ c: {a =~ c}");
            return;
        si
    si
si
