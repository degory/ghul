namespace TestUnitVariantSingleton is
    use Std = IO.Std;

    @IL.output("il.out")
    union COLOR is
        RED;
        GREEN;
        BLUE;
    si

    @IL.output("opt.out")
    union OPT[T] is
        SOME(value: T);
        NONE;
    si

    @IL.output("main.out")
    class Main is
        entry() static is
            // Non-generic unit variant: lowered to `ldsfld _instance`.
            let c: COLOR = COLOR.RED();

            // Generic unit variant: `ldsfld` uses the open-generic field
            // signature (`<!0>`) but the specialised declaring type
            // (`<int32>`) — the two-form split that distinguishes a
            // valid fieldref from one that triggers `MissingFieldException`.
            let n: OPT[int] = OPT.NONE[int]();

            // Payload-bearing variant: still allocates.
            let s: OPT[int] = OPT.SOME[int](42);
        si
    si
si
