namespace Test is
    class Main is
        test() is
            let b: bool mut;
            let x: ubyte mut , y: ubyte, z: ubyte;

            @IL.output("il.out")
            x = y + z;

            @IL.output("il.out")
            x = y - z;

            @IL.output("il.out")
            x = y * z;

            @IL.output("il.out")
            x = y / z;

            @IL.output("il.out")
            b = y < z;

            @IL.output("il.out")
            b = y <= z;

            @IL.output("il.out")
            b = y > z;

            @IL.output("il.out")
            b = y >= z;

            @IL.output("il.out")
            b = y == z;

            @IL.output("il.out")
            b = y != z;
 
            @IL.output("il.out")
            x = \y;

            @IL.output("il.out")
            x = y << z;

            @IL.output("il.out")
            x = y >> z;

            @IL.output("il.out")
            x = y & z;

            @IL.output("il.out")
            x = y | z;
        si
    si
si