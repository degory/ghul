use System.Exception;
use IO.Std.write_line;

class THING is
    init() is        
    si
si

class GET_A_THING is
    get_a_thing() -> THING;
si

class THINGER: GET_A_THING is
    name: string;

    init(name: string) is
        self.name = name;
    si
    
    get_a_thing() -> THING => THING();

    to_string() -> string => name;
si

test_convert_of_object_to_class() is
    let s = THINGER("hello");

    let o: GET_A_THING mut;
    let t: THINGER mut;

    o = s;
    
    @IL.output("il.out")
    t = cast THINGER(o);

    write_line("result is: {t.get_a_thing()}");
si


