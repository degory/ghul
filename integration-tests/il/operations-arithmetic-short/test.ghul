namespace Test is
    class Main is
        test() is
            let b: bool mut;
            let x: short mut , y: short mut, z: short mut;

            @IL.output("il.out")
            x = -y;

            @IL.output("il.out")
            x = y + z;

            @IL.output("il.out")
            x = y - z;

            @IL.output("il.out")
            x = y * z;

            @IL.output("il.out")
            x = y / z;

            @IL.output("il.out")
            b = y < z;

            @IL.output("il.out")
            b = y <= z;

            @IL.output("il.out")
            b = y > z;

            @IL.output("il.out")
            b = y >= z;

            @IL.output("il.out")
            b = y == z;

            @IL.output("il.out")
            b = y != z;
 
            @IL.output("il.out")
            x = \y;

            @IL.output("il.out")
            x = y << z;

            @IL.output("il.out")
            x = y >> z;

            @IL.output("il.out")
            x = y & z;

            @IL.output("il.out")
            x = y | z;
        si
    si
si