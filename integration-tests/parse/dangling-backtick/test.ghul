    entry() static is
        // A backtick must be immediately followed by an identifier, an
        // operator, or [. Here it is separated from the following [ by
        // whitespace, so it escapes nothing and is reported as a
        // dangling backtick. Written adjacent, Main`[int] is the
        // explicit-type-argument token.
        let a = Main` [int];

        return;
