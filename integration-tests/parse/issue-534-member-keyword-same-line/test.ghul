namespace Test is
    f(s: string) is
        // `s.is` mid-typing en route to `s.is_empty`. The parser
        // accepts the keyword in identifier position after `.`,
        // letting the completer anchor suggestions on a real MEMBER
        // node instead of returning enclosing-scope candidates.
        // Type-check then reports the (real) member-not-found.
        let b = s.is;
    si
si
