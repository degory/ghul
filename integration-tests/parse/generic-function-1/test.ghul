// Parsing of generic functions, including constraints on function type
// parameters. Function type-parameter constraints were rejected outright
// before Phase 2 ("type constraints are not supported"); they now parse.

namespace TEST is
    generic[T](i: int) -> int is
        return i;
    si

    generic[T,U](i: int, j: int) -> int is
        return i + j;
    si

    generic[T: object, U: object](i: int, j: int, k: int) -> int is
        return i + j + k;
    si

    class TEST is
        generic[T](i: int) -> int is
            return i;
        si

        generic[T: Iterable[U],U](i: int, j: int) -> int is
            return i + j;
        si
    si

    class Main is
        entry() static is
        si
    si
si
