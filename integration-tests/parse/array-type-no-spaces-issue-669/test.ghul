namespace Test is
    use IO.Std;

    class Main is
        entry() static is
            let with_space: int[ ];
            let with_tab: int[	];
            let with_newline: int[
            ];

            with_space = [1, 2, 3];
            with_tab = [4, 5];
            with_newline = [6];

            Std.write_line("space: {with_space.count}");
            Std.write_line("tab: {with_tab.count}");
            Std.write_line("newline: {with_newline.count}");
            return;
        si
