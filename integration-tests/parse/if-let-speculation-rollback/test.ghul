namespace T is
    class M is
        f(a: int?) is
            // A malformed clause under `if let` whose speculative parse is
            // abandoned — no `then` follows, so it is re-parsed as an
            // ordinary let-in condition expression. The syntax error the
            // clause contains must still be reported: the speculative parse
            // rolls its diagnostics back, so the re-parse's identical error
            // must not be mistaken for a repeat and dropped.
            if let x = ) in a then
            fi
        si
    si
si
